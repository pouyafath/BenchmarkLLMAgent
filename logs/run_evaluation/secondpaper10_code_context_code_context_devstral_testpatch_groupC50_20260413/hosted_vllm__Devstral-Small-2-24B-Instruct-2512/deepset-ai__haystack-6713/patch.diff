+def serialize_torch_dtype(dtype):
+    """
+    Serialize a torch.dtype object to a string representation.
+
+    :param dtype: A torch.dtype object or a string representation.
+    :return: String representation of the dtype.
+    """
+    import torch
+    if isinstance(dtype, str):
+        return dtype
+    elif isinstance(dtype, torch.dtype):
+        return str(dtype)
+    else:
+        return dtype
+
+def deserialize_torch_dtype(dtype_str):
+    """
+    Deserialize a string representation back to a torch.dtype object.
+
+    This function dynamically checks which torch dtypes are available in the current PyTorch version
+    and only maps those that exist.
+
+    :param dtype_str: String representation of a torch.dtype.
+    :return: torch.dtype object or the original value if not a recognized torch dtype string.
+    """
+    import torch
+
+    if isinstance(dtype_str, torch.dtype):
+        return dtype_str
+    elif not isinstance(dtype_str, str):
+        return dtype_str
+
+    # Build a dynamic mapping of available torch dtypes
+    dtype_map = {}
+
+    # Common dtype names to check
+    dtype_names = [
+        'float16', 'float32', 'float64', 'bfloat16',
+        'complex32', 'complex64', 'complex128',
+        'bool',
+        'uint8', 'int8', 'int16', 'int32', 'int64',
+        'float8_e4m3fn', 'float8_e5m2',
+        'bits8', 'bits16', 'bits32', 'bits64',
+        'quint8', 'qint8',
+        'quint4x2', 'quint2x4', 'qint4x2', 'qint2x4',
+        'bits1x8', 'bits2x4', 'bits4x2',
+        'float8',
+        'double', 'float', 'long', 'int', 'short', 'half',
+        'cfloat', 'cdouble', 'chalf',
+    ]
+
+    for name in dtype_names:
+        try:
+            dtype_map[f'torch.{name}'] = getattr(torch, name)
+        except AttributeError:
+            # This dtype doesn't exist in this version of PyTorch
+            pass
+
+    # Try to get the dtype
+    return dtype_map.get(dtype_str, dtype_str)
