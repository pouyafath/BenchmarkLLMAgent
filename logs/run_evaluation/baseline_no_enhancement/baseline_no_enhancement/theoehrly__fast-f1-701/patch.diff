+# ---------------------------------------------------------------------------
+# Helper to replace the placeholder string "auto" recursively in nested
+# structures (dicts, lists, tuples). This is used by ``get_driver_style`` to
+# ensure that any occurrence of the keyword ``auto`` – no matter how deeply
+# nested – is substituted with the appropriate driver colour.
+def _replace_auto(obj: Any, replacement: str) -> Any:
+    """
+    Recursively replace occurrences of the string ``"auto"`` in *obj* with
+    *replacement*.
+
+    Parameters
+    ----------
+    obj : Any
+        The object to process. Can be a dict, list, tuple, or any other type.
+    replacement : str
+        The string that should replace every ``"auto"`` occurrence.
+
+    Returns
+    -------
+    Any
+        The processed object with all ``"auto"`` strings replaced.
+    """
+    if isinstance(obj, dict):
+        return {k: _replace_auto(v, replacement) for k, v in obj.items()}
+    if isinstance(obj, (list, tuple)):
+        # Preserve the original container type
+        return type(obj)(_replace_auto(v, replacement) for v in obj)
+    if obj == "auto":
+        return replacement
+    return obj
