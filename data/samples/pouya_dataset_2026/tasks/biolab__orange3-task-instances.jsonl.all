=\"(300, 150)\" />\n\t\t<node id=\"2\" name=\"Bag of Words\" qualified_name=\"orangecontrib.text.widgets.owbagofwords.OWTBagOfWords\" project_name=\"Orange3-Text\" version=\"\" title=\"Bag of Words\" position=\"(450, 150)\" />\n\t\t<node id=\"3\" name=\"Distances\" qualified_name=\"Orange.widgets.unsupervised.owdistances.OWDistances\" project_name=\"Orange3\" version=\"\" title=\"Distances\" position=\"(600, 150)\" />\n\t\t<node id=\"4\" name=\"Hierarchical Clustering\" qualified_name=\"Orange.widgets.unsupervised.owhierarchicalclustering.OWHierarchicalClustering\" project_name=\"Orange3\" version=\"\" title=\"Hierarchical Clustering\" position=\"(750, 150)\" />\n\t</nodes>\n\t<links>\n\t\t<link id=\"0\" source_node_id=\"0\" sink_node_id=\"1\" source_channel=\"Corpus\" sink_channel=\"Corpus\" enabled=\"true\" source_channel_id=\"corpus\" sink_channel_id=\"corpus\" />\n\t\t<link id=\"1\" source_node_id=\"1\" sink_node_id=\"2\" source_channel=\"Corpus\" sink_channel=\"Corpus\" enabled=\"true\" source_channel_id=\"corpus\" sink_channel_id=\"corpus\" />\n\t\t<link id=\"2\" source_node_id=\"2\" sink_node_id=\"3\" source_channel=\"Corpus\" sink_channel=\"Data\" enabled=\"true\" source_channel_id=\"corpus\" sink_channel_id=\"data\" />\n\t\t<link id=\"3\" source_node_id=\"3\" sink_node_id=\"4\" source_channel=\"Distances\" sink_channel=\"Distances\" enabled=\"true\" source_channel_id=\"distances\" sink_channel_id=\"distances\" />\n\t</links>\n\t<annotations />\n\t<thumbnail />\n\t<node_properties>\n\t\t<properties node_id=\"0\" format=\"pickle\">gASVCAIAAAAAAAB9lCiMEmNvbnRyb2xBcmVhVmlzaWJsZZSIjAxyZWNlbnRfZmlsZXOUXZQojBFi\nb29rLWV4Y2VycHRzLnRhYpSMGGdyaW1tLXRhbGVzLXNlbGVjdGVkLnRhYpSMGGVsZWN0aW9uLXR3\nZWV0cy0yMDE2LnRhYpSMF2ZyaWVuZHMtdHJhbnNjcmlwdHMudGFilIwMYW5kZXJzZW4udGFilGWM\nE3NhdmVkV2lkZ2V0R2VvbWV0cnmUQ0IB2dDLAAMAAAAAAY8AAADCAAAEEAAAAsEAAAGQAAAA4QAA\nBA8AAALAAAAAAAAAAAAFVgAAAZAAAADhAAAEDwAAAsCUjAtfX3ZlcnNpb25fX5RLAowQY29udGV4\ndF9zZXR0aW5nc5RdlIwVb3Jhbmdld2lkZ2V0LnNldHRpbm