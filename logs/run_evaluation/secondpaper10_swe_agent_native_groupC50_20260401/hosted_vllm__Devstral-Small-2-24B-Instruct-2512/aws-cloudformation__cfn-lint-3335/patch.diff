+def parse_dynamic_reference(dynamic_ref_string):
+    """
+    Parse a dynamic reference string, handling CloudFormation intrinsic functions.
+
+    Args:
+        dynamic_ref_string (str): The dynamic reference string (e.g., "resolve:ssm:${AWS::AccountId}/${AWS::Region}/ac")
+
+    Returns:
+        list: The parsed parts of the dynamic reference
+    """
+    # Find all ${...} expressions, including those with colons
+    intrinsic_funcs = re.findall(r'\$\{[^!][^}]*\}', dynamic_ref_string)
+
+    # Replace ${...} with a placeholder to avoid splitting on colons inside them
+    temp_string = re.sub(r'\$\{[^!][^}]*\}', 'INTRINSIC_PLACEHOLDER', dynamic_ref_string)
+
+    # Split by colon
+    parts = temp_string.split(':')
+
+    # Restore the original intrinsic functions in the parameter name
+    if len(parts) >= 3:
+        parameter_name = parts[2]
+        # Replace placeholders with the actual intrinsic functions
+        placeholder_count = parameter_name.count('INTRINSIC_PLACEHOLDER')
+        for i in range(placeholder_count):
+            parameter_name = parameter_name.replace('INTRINSIC_PLACEHOLDER', intrinsic_funcs[i], 1)
+        parts[2] = parameter_name
+
+    return parts
+
