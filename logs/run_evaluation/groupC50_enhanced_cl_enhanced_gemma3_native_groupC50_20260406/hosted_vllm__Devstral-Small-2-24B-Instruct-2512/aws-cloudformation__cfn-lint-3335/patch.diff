+def parse_dynamic_reference(dynamic_ref):
+    """
+    Parse a dynamic reference string, handling ${} blocks correctly.
+
+    Args:
+        dynamic_ref (str): The dynamic reference string (e.g., "resolve:ssm:${AWS::AccountId}/${AWS::Region}/ac")
+
+    Returns:
+        list: The parsed parts of the dynamic reference
+    """
+    import re
+
+    # This pattern matches ${...} blocks
+    pattern = r'\$\{([^}]+)\}'
+
+    # Find all ${...} blocks
+    blocks = re.findall(pattern, dynamic_ref)
+
+    # Replace ${...} blocks with a placeholder to avoid splitting on colons inside them
+    temp_str = dynamic_ref
+    for i, block in enumerate(blocks):
+        placeholder = f"__PLACEHOLDER_{i}__"
+        temp_str = temp_str.replace(f"${{{block}}}", placeholder)
+
+    # Now split on colons
+    parts = temp_str.split(":")
+
+    # Restore the ${...} blocks
+    for i, block in enumerate(blocks):
+        placeholder = f"__PLACEHOLDER_{i}__"
+        parts = [p.replace(placeholder, f"${{{block}}}") for p in parts]
+
+    return parts
 
 class DynamicReference(BaseFn):
     id = "E1050"
