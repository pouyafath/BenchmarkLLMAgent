{"repo": "jxxghp/MoviePilot", "pull_number": 4709, "instance_id": "jxxghp__MoviePilot-4709", "issue_numbers": [4708], "base_commit": "426e920fff4990512a632f6b19bab79ecd5e7491", "patch": "diff --git a/app/chain/transfer.py b/app/chain/transfer.py\nindex 968d4c117..80753879b 100755\n--- a/app/chain/transfer.py\n+++ b/app/chain/transfer.py\n@@ -1450,6 +1450,10 @@ def _can_delete_torrent(self, download_hash: str, downloader: str, transfer_excl\n             if not torrents:\n                 return False\n \n+            # \u672a\u4e0b\u8f7d\u5b8c\u6210\n+            if torrents[0].progress < 100:\n+                return False\n+\n             # \u83b7\u53d6\u79cd\u5b50\u6587\u4ef6\u5217\u8868\n             torrent_files = self.torrent_files(download_hash, downloader)\n             if not torrent_files:\ndiff --git a/app/modules/transmission/__init__.py b/app/modules/transmission/__init__.py\nindex 7b5ef44c0..48d43e395 100644\n--- a/app/modules/transmission/__init__.py\n+++ b/app/modules/transmission/__init__.py\n@@ -253,7 +253,8 @@ def list_torrents(self, status: TorrentStatus = None,\n                             path=Path(torrent.download_dir) / torrent.name,\n                             hash=torrent.hashString,\n                             size=torrent.total_size,\n-                            tags=\",\".join(torrent.labels or [])\n+                            tags=\",\".join(torrent.labels or []),\n+                            progress=torrent.progress\n                         ))\n                 finally:\n                     torrents.clear()\n", "test_patch": "", "problem_statement": "[\u9519\u8bef\u62a5\u544a]: \u79fb\u52a8\u6a21\u5f0f\u5220\u9664\u79cd\u5b50\u6210\u529f\uff0c\u5728\u4e0b\u8f7d\u7535\u89c6\u5267\u65f6\u53ea\u8981\u4e0b\u8f7d\u5b8c\u4e00\u96c6\u5c31\u4f1a\u5220\u9664\u79cd\u5b50\n### \u786e\u8ba4\n\n- [x] \u6211\u7684\u7248\u672c\u662f\u6700\u65b0\u7248\u672c\uff0c\u6211\u7684\u7248\u672c\u53f7\u4e0e [version](https://github.com/jxxghp/Movie