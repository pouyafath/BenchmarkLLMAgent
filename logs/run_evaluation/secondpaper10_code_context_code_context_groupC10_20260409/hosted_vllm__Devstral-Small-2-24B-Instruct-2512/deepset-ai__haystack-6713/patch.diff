+def serialize_torch_dtype(dtype):
+    """
+    Serialize a torch.dtype to a string representation.
+
+    :param dtype: A torch.dtype object to serialize.
+    :return: String representation of the dtype.
+    """
+    if hasattr(dtype, '__name__'):
+        return dtype.__name__
+    return str(dtype)
+
+def deserialize_torch_dtype(dtype_str):
+    """
+    Deserialize a string representation back to a torch.dtype.
+
+    :param dtype_str: String representation of a torch.dtype.
+    :return: The corresponding torch.dtype object.
+    :raises DeserializationError: If the dtype cannot be deserialized.
+    """
+    try:
+        import torch
+        # Handle both "float16" and "torch.float16" formats
+        if dtype_str.startswith('torch.'):
+            dtype_str = dtype_str.split('.', 1)[1]
+
+        return getattr(torch, dtype_str)
+    except AttributeError as e:
+        raise DeserializationError(f"Could not deserialize torch dtype: {dtype_str}") from e
+
+def serialize_model_kwargs(model_kwargs):
+    """
+    Serialize model_kwargs by converting torch.dtype objects to strings.
+
+    :param model_kwargs: Dictionary of model kwargs that may contain non-serializable types.
+    :return: Serialized dictionary with torch.dtype objects converted to strings.
+    """
+    if not model_kwargs:
+        return model_kwargs
+
+    serialized = {}
+    for key, value in model_kwargs.items():
+        if hasattr(value, '__class__') and value.__class__.__module__ == 'torch' and value.__class__.__name__ == 'dtype':
+            # This is a torch.dtype, serialize it as a string
+            serialized[key] = serialize_torch_dtype(value)
+        else:
+            serialized[key] = value
+    return serialized
+
+def deserialize_model_kwargs(model_kwargs):
+    """
+    Deserialize model_kwargs by converting string representations of torch.dtype back to actual types.
+
+    :param model_kwargs: Dictionary of model kwargs that may contain string representations of torch.dtype.
+    :return: Deserialized dictionary with string representations converted back to torch.dtype objects.
+    """
+    if not model_kwargs:
+        return model_kwargs
+
+    deserialized = {}
+    for key, value in model_kwargs.items():
+        if isinstance(value, str):
+            # Check if this looks like a torch dtype string
+            # Common torch dtypes: float16, float32, float64, int8, int16, int32, int64, bool, etc.
+            if (value.startswith('float') or value.startswith('int') or value.startswith('bool') or
+                value.startswith('torch.float') or value.startswith('torch.int') or value.startswith('torch.bool')):
+                try:
+                    deserialized[key] = deserialize_torch_dtype(value)
+                    continue
+                except DeserializationError:
+                    # If it's not a torch.dtype, keep it as a string
+                    pass
+
+        deserialized[key] = value
+    return deserialized
