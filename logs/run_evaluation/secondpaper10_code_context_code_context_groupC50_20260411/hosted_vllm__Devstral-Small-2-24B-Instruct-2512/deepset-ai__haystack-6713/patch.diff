+
+
+def serialize_model_kwargs(model_kwargs: Dict[str, Any]) -> Dict[str, Any]:
+    """
+    Serializes model_kwargs by converting non-serializable types to strings.
+
+    This function handles special types like torch.dtype that cannot be directly
+    serialized to YAML. It converts these types to their string representations.
+
+    :param model_kwargs: Dictionary of model kwargs, potentially containing non-serializable types.
+    :return: Dictionary with non-serializable types converted to strings.
+    """
+    if not model_kwargs:
+        return model_kwargs
+
+    serialized = {}
+    for key, value in model_kwargs.items():
+        if hasattr(value, '__module__') and value.__module__.startswith('torch'):
+            # Handle torch.dtype objects
+            serialized[key] = str(value)
+        elif isinstance(value, dict):
+            # Recursively handle nested dictionaries
+            serialized[key] = serialize_model_kwargs(value)
+        else:
+            serialized[key] = value
+    return serialized
+
+def deserialize_model_kwargs(model_kwargs: Dict[str, Any]) -> Dict[str, Any]:
+    """
+    Deserializes model_kwargs by converting string representations back to their original types.
+
+    This function handles special types like torch.dtype that were converted to strings
+    during serialization.
+
+    :param model_kwargs: Dictionary of model kwargs, potentially containing string representations.
+    :return: Dictionary with string representations converted back to their original types.
+    """
+    if not model_kwargs:
+        return model_kwargs
+
+    deserialized = {}
+    for key, value in model_kwargs.items():
+        if isinstance(value, str) and value.startswith('torch.'):
+            # Handle torch.dtype string representations
+            try:
+                import torch
+                # Remove the 'torch.' prefix to get the actual dtype name
+                dtype_name = value.replace('torch.', '')
+                deserialized[key] = getattr(torch, dtype_name)
+            except (ImportError, AttributeError):
+                # If torch is not available or the attribute doesn't exist, keep as string
+                deserialized[key] = value
+        elif isinstance(value, dict):
+            # Recursively handle nested dictionaries
+            deserialized[key] = deserialize_model_kwargs(value)
+        else:
+            deserialized[key] = value
+    return deserialized
