@@ -86,6 +86,30 @@ logger = logging.getLogger(__name__)
 PROTOCOL_VERSION = os.getenv("PROTOCOL_VERSION", "2025-03-26")
 
 
+def _get_gateway_protocol() -> str:
+    """Detect the protocol used by this gateway.
+
+    Checks for TLS/HTTPS configuration in the following order:
+    1. GATEWAY_HTTPS environment variable
+    2. SSL_CERT_FILE environment variable (Gunicorn SSL)
+    3. Default to HTTP
+
+    Returns:
+        str: "http" or "https"
+    """
+    # Check environment variable for explicit protocol setting
+    if os.environ.get("GATEWAY_HTTPS", "").lower() == "true":
+        return "https"
+
+    # Check for Gunicorn SSL configuration
+    if os.environ.get("SSL_CERT_FILE"):
+        return "https"
+
+    # Default to HTTP
+    return "http"
+
