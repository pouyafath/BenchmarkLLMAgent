 class _ForEach:
     def __init__(self, key: str, value: Any, collections: MutableMapping[str, str]) -> None:
         self.key = key
         self.value = value
         self.collections = collections
 
     def items(self, cfn: Any) -> Iterator[Any]:
         values = self.value[1]
         resolved_values = self._get_for_each_values(values, {}, cfn)
         for item in resolved_values:
             yield item
 
     def _get_for_each_values(self, values: Any, params: MutableMapping[str, Any], cfn: Any):
         if isinstance(values, list) and not values:
             return []
         return self._get_value(values, params, cfn)
 
     def _get_value(self, value: Any, params: MutableMapping[str, Any], cfn: Any):
         if isinstance(value, list):
             return [self._get_value(v, params, cfn) for v in value]
         if isinstance(value, dict):
             return {k: self._get_value(v, params, cfn) for k, v in value.items()}
         if isinstance(value, str):
             if value in params:
                 return params[value]
         return value
