+    def _get_vars(self) -> list[Var]:
+        """Walk all Vars used in this component, including those in match cases.
+
+        Returns:
+            Each var referenced by the component (props, styles, event handlers, and vars in match cases).
+        """
+        vars = super()._get_vars()
+
+        # Get Vars from all components in match cases
+        for case in self.match_cases:
+            for element in case:
+                if isinstance(element, BaseComponent):
+                    vars.extend(element._get_vars())
+                elif isinstance(element, BaseVar):
+                    vars.append(element)
+
+        # Get Vars from the default case component
+        if isinstance(self.default, BaseComponent):
+            vars.extend(self.default._get_vars())
+        elif isinstance(self.default, BaseVar):
+            vars.append(self.default)
+
+        return vars
+
+    def _get_events_hooks(self) -> set[str]:
+        """Get the hooks required by events referenced in this component or its children.
+
+        Returns:
+            The hooks for the events (including those in child components).
+        """
+        hooks = super()._get_events_hooks()
+
+        # Check for event triggers in child components
+        for case in self.match_cases:
+            for element in case:
+                if isinstance(element, BaseComponent) and element.event_triggers:
+                    hooks.add(Hooks.EVENTS)
+                    break
+
+        # Check for event triggers in the default case
+        if isinstance(self.default, BaseComponent) and self.default.event_triggers:
+            hooks.add(Hooks.EVENTS)
+
+        return hooks
