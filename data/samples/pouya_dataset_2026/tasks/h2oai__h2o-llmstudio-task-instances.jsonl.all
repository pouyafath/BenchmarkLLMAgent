{"repo": "h2oai/h2o-llmstudio", "pull_number": 926, "instance_id": "h2oai__h2o-llmstudio-926", "issue_numbers": [925], "base_commit": "de76720720badb5f192e352e59514ecafacc27cb", "patch": "diff --git a/documentation/docs/guide/datasets/view-dataset.md b/documentation/docs/guide/datasets/view-dataset.md\nindex 5aa01626b..1ecc6e05b 100644\n--- a/documentation/docs/guide/datasets/view-dataset.md\n+++ b/documentation/docs/guide/datasets/view-dataset.md\n@@ -19,7 +19,7 @@ To view an imported dataset:\n     ![view-datasets](view-imported-dataset.png)\n \n     :::info\n-    For more information about the dataset details you see on the table above, see [dataset configurations](import-dataset.md#configure-a-dataset).\n+    For more information about the dataset details you see on the table above, see [dataset configurations](import-dataset.md#configure-dataset).\n     :::\n \n ## Dataset tabs\n", "test_patch": "", "problem_statement": "[DOC] FIx broken anchor\n### \ud83d\udcc3 Documentation\n\nFIxing a broken anchor\n\n### Motivation\n\nFIxing a broken anchor that leads to a page that doesnt exist\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/h2oai/h2o-llmstudio/commit/82e954dd61ffad109bcb4a11c14a97b41a8e88bb", "https://github.com/h2oai/h2o-llmstudio/commit/ab9424480893eab4b1594148cdbebd4ba954e5d0"], "created_at": "2025-08-01T06:17:29Z"}
{"repo": "h2oai/h2o-llmstudio", "pull_number": 955, "instance_id": "h2oai__h2o-llmstudio-955", "issue_numbers": [928], "base_commit": "957bd35d0761700b0868fe08f355070ae6b6b33c", "patch": "diff --git a/llm_studio/app_utils/config.py b/llm_studio/app_utils/config.py\nindex e37c817fa..1836d95f4 100644\n--- a/llm_studio/app_utils/config.py\n+++ b/llm_studio/app_utils/config.py\n@@ -94,7 +94,7 @@ def get_size(x):\n         os.getenv(\"MIN_DISK_SPACE_FOR_EXPERIMENTS\", \"2GB\")\n     ),\n     \"allowed_file_extensions\": os.getenv(\n-        \"ALLOWED_FILE_EXTENSIONS\", \".zip,.csv,.pq,.parquet\"\n+        \"ALLOWED_FILE_EXTENSIONS\", \".zip,.ZIP,.csv,.CSV,.pq,.PQ,.parquet,.PARQUET\"\n     ).split(\",\"),\n     \"llm_studio_workdir\": f\"{os.getenv('H2O_LLM_STUDIO_WORKDIR', os.getcwd())}\",\n     \"heap_mode\": os.getenv(\"H2O_LLM_STUDIO_ENABLE_HEAP\", \"False\") == \"True\",\ndiff --git a/llm_studio/python_configs/text_causal_classification_modeling_config.py b/llm_studio/python_configs/text_causal_classification_modeling_config.py\nindex dfaac3b90..6a3bd7161 100644\n--- a/llm_studio/python_configs/text_causal_classification_modeling_config.py\n+++ b/llm_studio/python_configs/text_causal_classification_modeling_config.py\n@@ -43,7 +43,14 @@ class ConfigNLPCausalClassificationDataset(ConfigNLPCausalLMDataset):\n     add_eos_token_to_prompt: bool = False\n     add_eos_token_to_answer: bool = False\n \n-    _allowed_file_extensions: tuple[str, ...] = (\"csv\", \"pq\", \"parquet\")\n+    _allowed_file_extensions: tuple[str, ...] = (\n+        \"csv\",\n+        \"CSV\",\n+        \"pq\",\n+        \"PQ\",\n+        \"parquet\",\n+        \"PARQUET\",\n+    )\n \n     def __post_init__(self):\n         self.prompt_column = (\ndiff --git a/llm_studio/python_configs/text_causal_language_modeling_config.py b/llm_studio/python_configs/text_causal_language_modeling_config.py\nindex 658394ff5..a456de5d8 100644\n--- a/llm_studio/python_configs/text_causal_language_modeling_config.py\n+++ b/llm_studio/python_configs/text_causal_language_modeling_config.py\n@@ -61,7 +61,14 @@ class ConfigNLPCausalLMDataset(DefaultConfig):\n     mask_prompt_labels: bool = True\n     only_last_answer: bool = False\n \n-    _allowed_file_extensions: tuple[str, ...] = (\"csv\", \"pq\", \"parquet\")\n+    _allowed_file_extensions: tuple[str, ...] = (\n+        \"csv\",\n+        \"CSV\",\n+        \"pq\",\n+        \"PQ\",\n+        \"parquet\",\n+        \"PARQUET\",\n+    )\n \n     def __post_init__(self):\n         self.prompt_column = (\ndiff --git a/llm_studio/src/possible_values.py b/llm_studio/src/possible_values.py\nindex 5b09dcb27..a29c9da95 100644\n--- a/llm_studio/src/possible_values.py\n+++ b/llm_studio/src/possible_values.py\n@@ -25,7 +25,15 @@ def _scan_dirs(dirname: str) -> list[str]:\n \n \n def _scan_files(\n-    dirname: str, extensions: tuple[str, ...] = (\".csv\", \".pq\", \".parquet\", \".json\")\n+    dirname: str,\n+    extensions: tuple[str, ...] = (\n+        \".csv\",\n+        \".CSV\",\n+        \".pq\",\n+        \".PQ\",\n+        \".parquet\",\n+        \".PARQUET\",\n+    ),\n ) -> list[str]:\n     \"\"\"\n     Scans a directory for files with given extension\n@@ -43,7 +51,7 @@ def _scan_files(\n         os.path.join(dirpath, filename)\n         for dirpath, _, filenames in os.walk(dirname)\n         for filename in filenames\n-        if any(map(filename.__contains__, extensions))\n+        if any([filename.endswith(ext) for ext in extensions])\n         and not filename.startswith(\"__meta_info__\")\n     ]\n     return sorted(path_list)\ndiff --git a/llm_studio/src/utils/data_utils.py b/llm_studio/src/utils/data_utils.py\nindex e720a6979..fb4a4b808 100644\n--- a/llm_studio/src/utils/data_utils.py\n+++ b/llm_studio/src/utils/data_utils.py\n@@ -61,14 +61,12 @@ def read_dataframe(\n     if meta_only and os.path.exists(meta_info_path):\n         path = meta_info_path\n \n-    if path.endswith(\".csv\"):\n+    path_lower = path.lower()\n+    if path_lower.endswith(\".csv\"):\n         df = pd.read_csv(path, lineterminator=\"\\n\").reset_index(drop=True)\n-    elif path.endswith(\".pq\") or path.endswith(\".parquet\"):\n-        try:\n-            df = pd.read_parquet(path, engine=\"pyarrow\").reset_index(drop=True)\n-        except Exception:\n-            df = pd.read_parquet(path, engine=\"fastparquet\").reset_index(drop=True)\n-    elif path.endswith(\".json\") or path == \"\":\n+    elif path_lower.endswith(\".pq\") or path_lower.endswith(\".parquet\"):\n+        df = pd.read_parquet(path, engine=\"pyarrow\").reset_index(drop=True)\n+    elif path == \"\":\n         return pd.DataFrame()\n     else:\n         raise ValueError(\n@@ -170,9 +168,10 @@ def is_valid_data_frame(path: str, csv_rows: int = 100) -> bool:\n \n     \"\"\"\n     try:\n-        if path.endswith(\".csv\"):\n+        path_lower = path.lower()\n+        if path_lower.endswith(\".csv\"):\n             pd.read_csv(path, nrows=csv_rows, lineterminator=\"\\n\")\n-        elif path.endswith(\".pq\") or path.endswith(\".parquet\"):\n+        elif path_lower.endswith(\".pq\") or path_lower.endswith(\".parquet\"):\n             pq.ParquetFile(path)\n         else:\n             raise ValueError(\ndiff --git a/pyproject.toml b/pyproject.toml\nindex e90bcd2ef..fd20a2397 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -25,7 +25,6 @@ dependencies = [\n     \"toml>=0.10.2, <0.11.0\",\n     \"pyyaml>=6.0.0, <7.0.0\",\n     \"protobuf>=3.20.3\",\n-    \"fastparquet>=2023.7.0\",\n     \"gputil>=1.4.0, <2.0.0\",\n     \"huggingface-hub==0.34.4\",\n     \"bitsandbytes==0.47.0\",\ndiff --git a/requirements.txt b/requirements.txt\nindex 0fc428bee..02687e814 100644\n--- a/requirements.txt\n+++ b/requirements.txt\n@@ -100,8 +100,6 @@ contourpy==1.3.2\n     # via bokeh\n coolname==2.2.0\n     # via h2o-llmstudio\n-cramjam==2.11.0\n-    # via fastparquet\n cryptography==46.0.3\n     # via\n     #   azure-storage-blob\n@@ -127,8 +125,6 @@ eino