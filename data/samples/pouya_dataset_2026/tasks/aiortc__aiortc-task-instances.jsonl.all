{"repo": "aiortc/aiortc", "pull_number": 1318, "instance_id": "aiortc__aiortc-1318", "issue_numbers": [1299], "base_commit": "03f0d491daab5d9a0f300d470cf58a9a10ee4bb5", "patch": "diff --git a/src/aiortc/rtcpeerconnection.py b/src/aiortc/rtcpeerconnection.py\nindex 50ba85e04..b53ea8225 100644\n--- a/src/aiortc/rtcpeerconnection.py\n+++ b/src/aiortc/rtcpeerconnection.py\n@@ -393,30 +393,38 @@ def signalingState(self) -> str:\n         \"\"\"\n         return self.__signalingState\n \n-    async def addIceCandidate(self, candidate: RTCIceCandidate) -> None:\n+    async def addIceCandidate(self, candidate: Optional[RTCIceCandidate]) -> None:\n         \"\"\"\n         Add a new :class:`RTCIceCandidate` received from the remote peer.\n \n         The specified candidate must have a value for either `sdpMid` or\n         `sdpMLineIndex`.\n \n-        :param candidate: The new remote candidate.\n+        :param candidate: The new remote candidate or `None` to signal\n+                            end-of-candidates.\n         \"\"\"\n-        if candidate.sdpMid is None and candidate.sdpMLineIndex is None:\n+        if (\n+            candidate is not None\n+            and candidate.sdpMid is None\n+            and candidate.sdpMLineIndex is None\n+        ):\n             raise ValueError(\"Candidate must have either sdpMid or sdpMLineIndex\")\n \n         for transceiver in self.__transceivers:\n             if (\n-                candidate.sdpMid == transceiver.mid\n-                or candidate.sdpMLineIndex == transceiver._get_mline_index()\n-            ) and not transceiver._bundled:\n+                candidate is None\n+                or (\n+                    candidate.sdpMid == transceiver.mid\n+                    or candidate.sdpMLineIndex == transceiver._get_mline_index()\n+                )\n+                and not transceiver._bundled\n+            ):\n                 iceTransport = transceiver.receiver.transport.transport\n                 await iceTransport.addRemoteCandidate(candidate)\n-                return\n \n-        if (\n-            self.__sctp\n-            and (\n+        if self.__sctp and (\n+            candidate is None\n+            or (\n                 candidate.sdpMid == self.__sctp.mid\n                 or candidate.sdpMLineIndex == self.__sctp_mline_index\n             )\n@@ -425,6 +433,17 @@ async def addIceCandidate(self, candidate: RTCIceCandidate) -> None:\n             iceTransport = self.__sctp.transport.transport\n             await iceTransport.addRemoteCandidate(candidate)\n \n+        # Update the remote description.\n+        media = self.__remoteDescription().media\n+        for sdp_m_line_index in range(0, len(media)):\n+            if candidate is None:\n+                media[sdp_m_line_index].ice_candidates_complete = True\n+            elif (\n+                candidate.sdpMLineIndex == sdp_m_line_index\n+                or candidate.sdpMid == media[sdp_m_line_index].rtp.muxId\n+            ):\n+                media[sdp_m_line_index].ice_candidates.append(candidate)\n+\n     def addTrack(self, track: MediaStreamTrack) -> RTCRtpSender:\n         \"\"\"\n         Add a :class:`MediaStreamTrack` to the set of media tracks which\n", "test_patch": "diff --git a/tests/test_rtcpeerconnection.py b/tests/test_rtcpeerconnection.py\nindex 07e5da104..82911fd3c 100644\n--- a/tests/test_rtcpeerconnection.py\n+++ b/tests/test_rtcpeerconnection.py\n@@ -575,6 +575,39 @@ def tearDown(self) -> None:\n         aioice.stun.RETRY_MAX = self.retry_max\n         aioice.stun.RETRY_RTO = self.retry_rto\n \n+    @asynctest\n+    async def test_addIceCandidate(self) -> None:\n+        pc = RTCPeerConnection()\n+        pc.createDataChannel(\"test\")\n+        offer = await pc.createOffer()\n+        await pc.setRemoteDescription(offer)\n+        self.assertFalse(\"a=candidate:\" in pc.remoteDescription.sdp)\n+        candidate_with_index = RTCIceCandidate(\n+            component=1,\n+            foundation=\"0\",\n+            ip=\"192.168.99.7\",\n+            port=33543,\n+            priority=2122252543,\n+            protocol=\"UDP\",\n+            type=\"host\",\n+            sdpMLineIndex=0,\n+        )\n+        await pc.addIceCandidate(candidate_with_index)\n+        self.assertTrue(\"a=candidate:\" in pc.remoteDescription.sdp)\n+\n+        candidate_with_mid = RTCIceCandidate(\n+            component=1,\n+            foundation=\"0\",\n+            ip=\"192.168.99.7\",\n+            port=33544,\n+            priority=2122252543,\n+            protocol=\"UDP\",\n+            type=\"host\",\n+            sdpMid=pc.sctp.mid,\n+        )\n+        await pc.addIceCandidate(candidate_with_mid)\n+        self.assertEqual(pc.remoteDescription.sdp.count(\"a=candidate:\"), 2)\n+\n     @asynctest\n     async def test_addIceCandidate_no_sdpMid_or_sdpMLineIndex(self) -> None:\n         pc = RTCPeerConnection()\n@@ -594,6 +627,18 @@ async def test_addIceCandidate_no_sdpMid_or_sdpMLineIndex(self) -> None:\n             str(cm.exception), \"Candidate must have either sdpMid or sdpMLineIndex\"\n         )\n \n+    @asynctest\n+    async def test_addIceCandidate_null(self) -> None:\n+        pc = RTCPeerConnection()\n+        pc.createDataChannel(\"test\")\n+        pc.addTransceiver(\"audio\")\n+        pc.addTransceiver(\"video\")\n+        offer = await pc.createOffer()\n+        await pc.setRemoteDescription(offer)\n+        self.assertFalse(\"a=end-of-candidates\" in pc.remoteDescription.sdp)\n+        await pc.addIceCandidate(None)\n+        self.assertTrue(\"a=end-of-candidates\" in pc.remoteDescription.sdp)\n+\n     @asynctest\n     async def test_addTrack_audio(self) -> None:\n         pc = RTCPeerConnection()\n", "problem_statement": "End of candidates type error\nI am connecting to JS WebRTC, after gathering it gives end of candidates with empty candidate but still has sdpMid and sdpMLineIndex, so I can still make the candidate class with it and the rest is empty. The addIceCandidate() checks whether there is sdpMid and sdpMLineIndex:\n\nhttps://github.com/aiortc/aiortc/blob/9664b669bcee50dc41e341656b2f8ab19ce69623/src/aiortc/rtcpeerconnection.py#L405-L406\n\nnext it will pass the candidate to addRemoteCandidate(), but in there, it checks if the candidate is None as the end of candidates, but the parameter is always a class object in addIceCandidate() so it will never know if its end of candidates:\n\nhttps://github.com/aiortc/aiortc/blob/9664b669bcee50dc41e341656b2f8ab19ce69623/src/aiortc/rtcicetransport.py#L282-L291\n\nthe addIceCandidate() requires the RTCIceCandidate as parameter, even if I pass a None type, it will be cause an error because it checks the sdpMid and sdpMLineIndex. aiortc gatherer doesn't seem to make end of candidates, but Isn't it better to either check for end of candidates in addIceCandidate() too or checks for sdpMid and sdpMLineIndex on the addRemoteCandidate() instead of addIceCandidate()?\n\nSorry if I made a mistake, I'm a beginner\n", "hints_text": "There was some discussion and a spec change (and a lot of back and forth) back in 2018:\nhttps://github.com/w3c/webrtc-pc/issues/2039\n\nMaking the candidate optional in RTCPeerConnection makes sense and one also needs to handle Firefox' candidate-with-empty-string:\n```\nRTCIceCandidate { candidate: \"\", sdpMid: \"0\", sdpMLineIndex: 0, foundation: null, \ncomponent: null, priority: null, address: null, protocol: null, port: null, type: null }\n```\n\nI'm not sure I understand what you are saying @fippo , if we allowed `addIceCandidate(None)` how do we know which ICE transport we should pass this end-of-candidates to?\nJoining in on this discussion since I had a hacky workaround \u25e1\u0308\n\nWe could add the candidate string to RTCIceCandidate, and set it to empty to signal end of candidate similar to [this](https://developer.mozilla.org/en-US/docs/Web/API/RTCIceCandidate/candidate):\n\n> A string representing the transport address for the candidate that can be used for connectivity checks. The format of this address is a candidate-attribute as defined in [RFC 5245](https://datatracker.ietf.org/doc/html/rfc5245). This string is empty (\"\") if the RTCIceCandidate is an \"end of candidates\" indicator.\n\nWe still pass in `sdpMid` and `sdpMLineIndex` to select the right transport.\n\nAlternatively, we can break parity with the web by having an `signalEndOfCandidate(sdpMid, sdpMLinIndex)` function.\n> if we allowed addIceCandidate(None) how do we know which ICE transport we should pass this end-of-candidates to?\n\nNone -> all of the ice candidates get end-of-candidates. This is a bit of a hack in the spec which has a [note](https://w3c.github.io/webrtc-pc/#dom-peerconnection-addicecandidate):\n> Due to WebIDL processing, [addIceCandidate](https://w3c.github.io/webrtc-pc/#dom-peerconnection-addicecandidate)(null) is interpreted as a call with the default dictionary present, which, in the above algorithm, indicates end-of-candidates for all media descriptions and ICE candidate generation. This is by design for legacy reasons.\n\nFirefox emits:\n* one \"\" candidate for each (non-bundled) transport\n* null candidate after that\n\n", "all_hints_text": "There was some discussion and a spec change (and a lot of back and forth) back in 2018:\nhttps://github.com/w3c/webrtc-pc/issues/2039\n\nMaking the candidate optional in RTCPeerConnection makes sense and one also needs to handle Firefox' candidate-with-empty-string:\n```\nRTCIceCandidate { candidate: \"\", sdpMid: \"0\", sdpMLineIndex: 0, foundation: null, \ncomponent: null, priority: null, address: null, protocol: null, port: null, type: null }\n```\n\nI'm not sure I understand what you are saying @fippo , if we allowed `addIceCandidate(None)` how do we know which ICE transport we should pass this end-of-candidates to?\nJoining in on this discussion since I had a hacky workaround \u25e1\u0308\n\nWe could add the candidate string to RTCIceCandidate, and set it to empty to signal end of candidate similar to [this](https://developer.mozilla.org/en-US/docs/Web/API/RTCIceCandidate/candidate):\n\n> A string representing the transport address for the candidate that can be used for connectivity checks. The format of this address is a candidate-attribute as defined in [RFC 5245](https://datatracker.ietf.org/doc/html/rfc5245). This string is empty (\"\") if the RTCIceCandidate is an \"end of candidates\" indicator.\n\nWe still pass in `sdpMid` and `sdpMLineIndex` to select the right transport.\n\nAlternatively, we can break parity with the web by having an `signalEndOfCandidate(sdpMid, sdpMLinIndex)` function.\n> if we allowed addIceCandidate(None) how do we know which ICE transport we should pass this end-of-candidates to?\n\nNone -> all of the ice candidates get end-of-candidates. This is a bit of a hack in the spec which has a [note](https://w3c.github.io/webrtc-pc/#dom-peerconnection-addicecandidate):\n> Due to WebIDL processing, [addIceCandidate](https://w3c.github.io/webrtc-pc/#dom-peerconnection-addicecandidate)(null) is interpreted as a call with the default dictionary present, which, in the above algorithm, indicates end-of-candidates for all media descriptions and ICE candidate generation. This is by design for legacy reasons.\n\nFirefox emits:\n* one \"\" candidate for each (non-bundled) transport\n* null candidate after that\n@fippo in addition to your PR #1318 should we also have a change to both RTCPeerTransport and RTCIceTransport which treats a \"\" candidate as an end-of-candidates for a specific transport?\nWill work on that. I wonder why nobody complained about interop woes with Firefox yet!\nhrm... the  spec is a [bit weasely](https://w3c.github.io/webrtc-pc/#constructor-0)I, returning early in the algorithm and leaving a lot of non-optional attributes as null.\n\nSo this would require changing the addIceCandidate signature in aiortc from\n```\naddIceCandidate(self, candidate: Optional[RTCIceCandidate])\n```\nto (for backward compat reasons)\n```\naddIceCandidate(self, candidate: Optional[RTCIceCandidateInit|RTCIceCandidate])\n```\nI'm fine with going in increments. Supporting `Optional[RTCIceCandidate]` is already a step in the right direction, especially as you caught the fact we were not updating the remote description!\n\n", "commit_urls": ["https://github.com/aiortc/aiortc/commit/dc39c0772663435cd1f9ea8d6edc123bbe36f4a7"], "created_at": "2025-05-23T03:13:44Z"}
{"repo": "aiortc/aiortc", "pull_number": 1321, "instance_id": "aiortc__aiortc-1321", "issue_numbers": [1315], "base_commit": "f96d88c9c8a804c8981c933b96e5762818ea29fb", "patch": "diff --git a/src/aiortc/codecs/vpx.py b/src/aiortc/codecs/vpx.py\nindex 7232d47aa..0e8c2a052 100644\n--- a/src/aiortc/codecs/vpx.py\n+++ b/src/aiortc/codecs/vpx.py\n@@ -1,3 +1,4 @@\n+import logging\n import multiprocessing\n import random\n from struct import pack, unpack_from\n@@ -13,6 +14,8 @@\n from ..mediastreams import VIDEO_TIME_BASE, convert_timebase\n from .base import Decoder, Encoder\n \n+logger = logging.getLogger(__name__)\n+\n DEFAULT_BITRATE = 500000  # 500 kbps\n MIN_BITRATE = 250000  # 250 kbps\n MAX_BITRATE = 1500000  # 1.5 Mbps\n@@ -168,10 +171,14 @@ def __init__(self) -> None:\n         self.codec = CodecContext.create(\"libvpx\", \"r\")\n \n     def decode(self, encoded_frame: JitterFrame) -> list[Frame]:\n-        packet = Packet(encoded_frame.data)\n-        packet.pts = encoded_frame.timestamp\n-        packet.time_base = VIDEO_TIME_BASE\n-        return cast(list[Frame], self.codec.decode(packet))\n+        try:\n+            packet = Packet(encoded_frame.data)\n+            packet.pts = encoded_frame.timestamp\n+            packet.time_base = VIDEO_TIME_BASE\n+            return cast(list[Frame], self.codec.decode(packet))\n+        except av.FFmpegError as e:\n+            logger.warning(\"Vp8Decoder() failed to decode, skipping package: \" + str(e))\n+            return []\n \n \n class Vp8Encoder(Encoder):\n", "test_patch": "diff --git a/tests/test_vpx.py b/tests/test_vpx.py\nindex d80aff161..0da19734c 100644\n--- a/tests/test_vpx.py\n+++ b/tests/test_vpx.py\n@@ -1,4 +1,6 @@\n import fractions\n+import io\n+from contextlib import redirect_stderr\n from unittest import TestCase\n \n from aiortc.codecs import get_decoder, get_encoder\n@@ -8,6 +10,7 @@\n     VpxPayloadDescriptor,\n     number_of_threads,\n )\n+from aiortc.jitterbuffer import JitterFrame\n from aiortc.rtcrtpparameters import RTCRtpCodecParameters\n \n from .codecs import CodecTestCase\n@@ -161,6 +164,11 @@ def test_decoder(self) -> None:\n         decoder = get_decoder(VP8_CODEC)\n         self.assertIsInstance(decoder, Vp8Decoder)\n \n+        # decode junk\n+        with redirect_stderr(io.StringIO()):\n+            frames = decoder.decode(JitterFrame(data=b\"123\", timestamp=0))\n+        self.assertEqual(frames, [])\n+\n     def test_encoder(self) -> None:\n         encoder = self.ensureIsInstance(get_encoder(VP8_CODEC), Vp8Encoder)\n \n", "problem_statement": "Invalid data found when processing input: 'avcodec_send_packet()' on VP8 track\nHello,\n\nI encountered an issue when subscribing to a VP8 video track. When I call the `recv()` method on the `RemoteStreamTrack` within an `asyncio.Task`, it throws the following error:\n\n```\nException in thread video-decoder:\nTraceback (most recent call last):\n  File \"/usr/lib/python3.12/threading.py\", line 1073, in _bootstrap_inner\n    self.run()\n  File \"/usr/lib/python3.12/threading.py\", line 1010, in run\n    self._target(*self._args, **self._kwargs)\n  File \"/home/<redacted>/venv/lib/python3.12/site-packages/aiortc/rtcrtpreceiver.py\", line 68, in decoder_worker\n    for frame in decoder.decode(encoded_frame):\n                 ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"/home/<redacted>/venv/lib/python3.12/site-packages/aiortc/codecs/vpx.py\", line 162, in decode\n    return cast(list[Frame], self.codec.decode(packet))\n                             ^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"av/codec/context.pyx\", line 433, in av.codec.context.CodecContext.decode\n  File \"av/codec/context.pyx\", line 448, in av.codec.context.CodecContext.decode\n  File \"av/codec/context.pyx\", line 340, in av.codec.context.CodecContext._send_packet_and_recv\n  File \"av/error.pyx\", line 424, in av.error.err_check\nav.error.InvalidDataError: [Errno 1094995529] Invalid data found when processing input: 'avcodec_send_packet()'\n```\n\nAfter this error, the `video-decoder` thread stops completely. I was wondering what could cause this issue, and whether a `try...except` block could be added to the `decoder_worker` function in aiortc to handle this case gracefully?\n\nThanks in advance for your help.\n", "hints_text": "Before we blindly ignore this error, could you try to narrow down what causes this to happen? At the very least I'd like to capture a realistic unit test for this.\nFor context, the subscribed stream come from Janus (SFU). I instrument a bit of the code to display further information about this exception:\n```\nprocessing track <aiortc.rtcrtpreceiver.RemoteStreamTrack object at 0x769b3a1d2450>\n[packet] > 0 | False | False >> av.Packet of #0, dts=None, pts=0; 1861 bytes at 0x769b3a1c5f80>\n0 | b'\\xd1(\\x00\\xdf\\xa7\\xb7\\xdeH0\\xbc\\x80\\xbe\\x81>\\x81\\x7f\\xa0)\\x00b+\\x82\\t\\xcaz%\\xeb\\xb4!\\xa5\\xc2\\xa6\\xfc\\xef<W\\x0cj\\x8f\\x9c\\xa3\\xb1\\x1cC.\\xc8\\rw\\x14\\xfcL\\x9d/\\x7fh9\\x05\\x86\\x02\\x0e\\xb0\\xb5C\\xb3\\t\\x12\\x9f\\xdf)C\\xa1F\\x86\\x19\\x9a4T\\xaf\\x92\\x9fF\\x0b\\xcaM<a\\xbb\\x0f\\xf6\"\\x98~\\xb8y\\xa1\\xb5B1\\xbaAn\\xd16\\x18>n\\'\\xae\\xa4\\xc9\\xee;\\xcf(S\\x85\\x93\\x80\\x86\\xddN\\x8aB\\n\\\\\\xa2\\x0c6\\x95\\xdf\\xbc\\x18\\xae\\xbf\\xd0~l\\xe4\\x1a`\\xff\\x12m\\xa6\\x0ce\\xbeQ\\xea\\x06@L\\x04\\xfd\\x0c\\\\\\rJ\\xe7CJ\\x8c\\xf4O\\xec\\x01\\x08B\\xca\\xf8kw\\xf1_\\x93k\\xcd1\\xe8\\x1f\\xfa\\x9f\\xe1\\x94\\xd9\\x19\\x00,\\xc7\\xbf \\x0c<\\xb0\\xd9$\\x11\\xec\\xa2\\x7fv\\xaa\\x05\\x88OL\\x05\\x02\\x84ec\\x9b*\\xb07\\xbf\\x1crid\\x00+\\xd2L.\\x96\\x07\\xdd\\x9e\\xdeihUa\\x00\\xff\\x82\\xa1\\x92\\xe3^$\\xb3@F\\xfd\\x89\\xad\\xba\\xfaJa\\xdaJ\\xe7\\xf7\\x86\\xe4^\\xc7\\xc0\\x9e$\\xc0/>\\xbc\\xb9*\\x0c\\xe5\\xcc\\xe3\"Q-\\x1c\\xb6b\\xdd\\x84\\xe9}Z?h\\xb2#\\xe5\\x06\\xb7\\xd2\\x81\\xab2XJ\\xc8F\\xb6\\xbb\\xda\\x85\\xc8$!C\\xb1\\x1d\\xd4\\xa7P1D\\xcd]\\xaa\\xdfH\\x16\\x84\\x80\\x03\\xfae\\x93\\xb4\\xa5\\x00i\\x0c\\xb0R\\xb5~(M\\xa5e!1\\xf9\\xa0\\x88S\\xac