ripping-machine/commit/9600221190c216ceea3cbdd524e99e2e91b0606e", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/b63c43ed570f54e6836ebc11d5526c92b6c7ad06", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/8adb991edb43bb3f8a1dfb0b18dce16f50419fcd", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/93610a94166ea74b80e73bca89bcb35aa5b268bf", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/ae2ffee12002e69f6946531d05b84c9ebe1a6ecd", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/c03b68034099a149a6fb3939af85b3636467619e", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/47d2103a890bf726f1468cce0ee6c8f4f73ca382", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/a39883f023e394413773a3a9863089a8866a2363", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/5ae16d77e8071abae574a8ad96dc222b75a5023d", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/54d5c6bd1e34d0f254d6738fb328489a7c8c9f0b", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/a1f2968001de4f7700167a270ef0e143fd638574", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/3a28f74648f0288c561ad02b201a6c318386491b", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/435c4ba49af04a27003b98cd6384b8e448e6f042", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/906a25e09dc252c750a2fe1cf500b1d07478349f", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/cf4664b8baeaaac095cb0c5addd09bc615863dfa", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/39448ad8535a820828dd105734362a00dfb7031d", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/369ffb81b679ac1744b7ade6e