+    def __init__(self, *args, **kwargs):
+        super().__init__(*args, **kwargs)
+        # Cache for @var values
+        self._var_cache: Dict[str, Any] = {}
+        # Dependency graph: var -> set of vars that depend on it
+        self._var_dependencies: Dict[str, Set[str]] = defaultdict(set)
+
+    # Thread‑local storage to track which var is currently being computed
+    _var_compute_context = threading.local()
+
+    def _record_dependency(self, var_name: str) -> None:
+        """Record that the currently computing var depends on ``var_name``."""
+        current = getattr(self._var_compute_context, "current", None)
+        if current and current != var_name:
+            self._var_dependencies[current].add(var_name)
+
+    def _invalidate_dependents(self, var_name: str, _visited: Set[str] | None = None) -> None:
+        """Recursively invalidate cached values of vars that depend on ``var_name``."""
+        if _visited is None:
+            _visited = set()
+        if var_name in _visited:
+            return
+        _visited.add(var_name)
+        for dependent in self._var_dependencies.get(var_name, set()):
+            if dependent in self._var_cache:
+                del self._var_cache[dependent]
+            self._invalidate_dependents(dependent, _visited)
+        # Once invalidated, clear the dependency edges for this var
+        self._var_dependencies[var_name].clear()
