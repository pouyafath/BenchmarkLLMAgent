bd50a7f5dcd120eb3ada59", "https://github.com/beeware/toga/commit/84b148e011861a452a73f2d242cb04c65dc47292", "https://github.com/beeware/toga/commit/6a58f36ed5cbe1ef6a1f55b2c78c0d6b7b903de7"], "created_at": "2025-09-18T23:06:44Z"}
{"repo": "beeware/toga", "pull_number": 3508, "instance_id": "beeware__toga-3508", "issue_numbers": [1688], "base_commit": "cf815dd18398093630836bbc33c199b2e4c178bf", "patch": "diff --git a/changes/1688.doc.rst b/changes/1688.doc.rst\nnew file mode 100644\nindex 0000000000..c9f043e666\n--- /dev/null\n+++ b/changes/1688.doc.rst\n@@ -0,0 +1,1 @@\n+Documentation for installing platform-specific dependencies is improved.\ndiff --git a/docs/tutorial/tutorial-0.rst b/docs/tutorial/tutorial-0.rst\nindex 6dbecaf74a..0a1fdb8dfb 100644\n--- a/docs/tutorial/tutorial-0.rst\n+++ b/docs/tutorial/tutorial-0.rst\n@@ -46,15 +46,13 @@ virtual environment, open a fresh terminal session, and run:\n \n Your prompt should now have a ``(venv)`` prefix in front of it.\n \n-Next, install Toga into your virtual environment:\n+In addition, make sure that you have the platform-specific dependencies for your platform:\n \n .. tabs::\n \n   .. group-tab:: macOS\n \n-    .. code-block:: console\n-\n-      (venv) $ python -m pip install toga\n+    No additional dependencies are necessary.\n \n   .. group-tab:: Linux\n \n@@ -62,7 +60,22 @@ Next, install Toga into your virtual environment:\n \n     .. include:: /reference/platforms/unix-prerequisites.rst\n \n-    Then, install Toga:\n+  .. group-tab:: Windows\n+\n+    Confirm that your system meets the :ref:`Windows prerequisites\n+    <windows-prerequisites>`.\n+\n+Next, install Toga into your virtual environment:\n+\n+.. tabs::\n+\n+  .. group-tab:: macOS\n+\n+    .. code-block:: console\n+\n+      (venv) $ python -m pip install toga\n+\n+  .. group-tab:: Linux\n \n     .. code-block:: console\n \n@@ -73,9 +86,6 @@ Next, install Toga into your virtual environment:\n \n   .. group-tab:: Windows\n \n-    Confirm that your system meets the :ref:`Windows prerequisites\n-    <windows-prerequisites>`; then run:\n-\n     .. code-block:: doscon\n \n       (venv) C:\\...>python -m pip install toga\n", "test_patch": "", "problem_statement": "Linux OS package instructions are not obvious enough\nWhen installing Toga on Ubuntu (and Raspberri Pi) I had the same issue regarding pycairo (details pasted below)\r\n\r\n\r\n**Environment:**\r\n - Operating System: Ubuntu\r\n - Python version: 3.10.6\r\n - Software versions: toga_demo-0.3.0.dev39-py3-none-any.whl\r\n\r\n\r\n\r\nUBUNTU: python3 -m pip install --pre toga-demo\r\n\r\n\r\n\r\n```\r\nInstalling build dependencies ... error\r\n  error: subprocess-exited-with-error\r\n  \r\n  \u00d7 pip subprocess to install build dependencies did not run successfully.\r\n  \u2502 exit code: 1\r\n  \u2570\u2500> [38 lines of output]\r\n      Collecting setuptools\r\n        Using cached setuptools-65.5.1-py3-none-any.whl (1.2 MB)\r\n      Collecting wheel\r\n        Using cached wheel-0.38.4-py3-none-any.whl (36 kB)\r\n      Collecting pycairo\r\n        Using cached pycairo-1.21.0.tar.gz (340 kB)\r\n        Installing build dependencies: started\r\n        Installing build dependencies: finished with status 'done'\r\n        Getting requirements to build wheel: started\r\n        Getting requirements to build wheel: finished with status 'done'\r\n        Preparing metadata (pyproject.toml): started\r\n        Preparing metadata (pyproject.toml): finished with status 'done'\r\n      Building wheels for collected packages: pycairo\r\n        Building wheel for pycairo (pyproject.toml): started\r\n        Building wheel for pycairo (pyproject.toml): finished with status 'error'\r\n        error: subprocess-exited-with-error\r\n      \r\n        \u00d7 Building wheel for pycairo (pyproject.toml) did not run successfully.\r\n        \u2502 exit code: 1\r\n        \u2570\u2500> [12 lines of output]\r\n            running bdist_wheel\r\n            running build\r\n            running build_py\r\n            creating build\r\n            creating build/lib.linux-x86_64-cpython-310\r\n            creating build/lib.linux-x86_64-cpython-310/cairo\r\n            copying cairo/__init__.py -> build/lib.linux-x86_64-cpython-310/cairo\r\n            copying cairo/__init__.pyi -> build/lib.linux-x86_64-cpython-310/cairo\r\n            copying cairo/py.typed -> build/lib.linux-x86_64-cpython-310/cairo\r\n            running build_ext\r\n            'pkg-config' not found.\r\n            Command ['pkg-config', '--print-errors', '--exists', 'cairo >= 1.15.10']\r\n            [end of output]\r\n      \r\n        note: This error originates from a subprocess, and is likely not a problem with pip.\r\n        ERROR: Failed building wheel for pycairo\r\n      Failed to build pycairo\r\n      ERROR: Could not build wheels for pycairo, which is required to install pyproject.toml-based projects\r\n      [end of output]\r\n  \r\n  note: This error originates from a subprocess, and is likely not a problem with pip.\r\nerror: subprocess-exited-with-error\r\n\r\n\u00d7 pip subprocess to install build dependencies did not run successfully.\r\n\u2502 exit code: 1\r\n\u2570\u2500> See above for output.\r\n```\r\n\r\nSuggestions for installing pycairo to get around this issue:\r\n\r\nhttps://stackoverflow.com/questions/70508775/error-could-not-build-wheels-for-pycairo-which-is-required-to-install-pyprojec\r\n\r\n`sudo apt-get install libcairo2`\r\n\r\nlibcairo2 is already the newest version (1.16.0-5ubuntu2).\r\n\r\n`apt-get install libcairo2-dev`\r\n\r\nLots of libraries installed following this command. Now try Toga again:\r\n\r\n`UBUNTU: python3 -m pip install --pre toga-demo`\r\n\r\n```\r\nPackage gobject-introspection-1.0 was not found in the pkg-config search path.\r\n      Perhaps you should add the directory containing `gobject-introspection-1.0.pc'\r\n      to the PKG_CONFIG_PATH environment variable\r\n      No package 'gobject-introspection-1.0' found\r\n      Command '('pkg-config', '--print-errors', '--exists', 'gobject-introspection-1.0 >= 1.56.0')' returned non-zero exit status 1.\r\n      \r\n      Try installing it with: 'sudo apt install libgirepository1.0-dev'\r\n\r\n```\r\n\r\n\r\n\r\n`sudo apt install libgirepository1.0-dev`\r\n\r\nInstalled fine, try Toga again:\r\n\r\n`Successfully installed gbulb-0.6.3 pycairo-1.21.0 pygobject-3.42.2 toga-0.3.0.dev39 toga-core-0.3.0.dev39 toga-demo-0.3.0.dev39 toga-gtk-0.3.0.dev39 travertino-0.1.3`\r\n\r\nToga now working beautifully !!!\n", "hints_text": "These OS packages are already mentioned in the [first page of the tutorial](https://toga.readthedocs.io/en/latest/tutorial/tutorial-0.html), in the \"Linux\" tab of \"install Toga into your virtual environment\". However, if I was reading that, I wouldn't bother clicking on the Linux tab because I already know that the `pip install` command is the same on all platforms, so I would probably have missed it too.\r\n\r\nInstead, it would be better for the OS dependencies to be a separate section, as it is on the [\"How to contribute code\"](https://toga.readthedocs.io/en/latest/how-to/contribute-code.html) page. Or even better, create a separate page for the whole process of installing Python, creating the virtual environment and installing OS packages, and reference it from both locations.\nFyi I had the same issue for Ubuntu. I copy pasted the line from Ubuntu 18.04+ / Debian 10+. Installing python3-cairo-dev fixed it for me. \r\n\nWorking on a PR.\n\n", "all_hints_text": "These OS packages are already mentioned in the [first page of the tutorial](https://toga.readthedocs.io/en/latest/tutorial/tutorial-0.html), in the \"Linux\" tab of \"install Toga into your virtual environment\". However, if I was reading that, I wouldn't bother clicking on the Linux tab because I already know that the `pip install` command is the same on all platforms, so I would probably have missed it too.\r\n\r\nInstead, it would be better for the OS dependencies to be a separate section, as it is on the [\"How to contribute code\"](https://toga.readthedocs.io/en/latest/how-to/contribute-code.html) page. Or even better, create a separate page for the whole process of installing Python, creating the virtual environment and installing OS packages, and reference it from both locations.\nFyi I had the same issue for Ubuntu. I copy pasted the line from Ubuntu 18.04+ / Debian 10+. Installing python3-cairo-dev fixed it for me. \r\n\nWorking on a PR.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/b7693b24551c0603b78b55118825635294b51980", "https://github.com/beeware/toga/commit/453206d03241df82fbaa987c0cefd2ca87b7e1f6", "https://github.com/beeware/toga/commit/a6946bd1b235f8d60855334e629e319beca15d0b"], "created_at": "2025-05-31T17:27:14Z"}
{"repo": "beeware/toga", "pull_number": 4106, "instance_id": "beeware__toga-4106", "issue_numbers": [2206, 4110], "base_commit": "cfda3be107abb2d2ab35f629cc5eda8b94ec3243", "patch": "diff --git a/android/src/toga_android/widgets/canvas.py b/android/src/toga_android/widgets/canvas.py\nindex b37fef5325..b30c8261ca 100644\n--- a/android/src/toga_android/widgets/canvas.py\n+++ b/android/src/toga_android/widgets/canvas.py\n@@ -30,9 +30,10 @@\n class State(NamedTuple):\n     fill: Paint\n     stroke: Paint\n+    transform: Matrix\n \n     def __deepcopy__(self, memo):\n-        return type(self)(Paint(self.fill), Paint(self.stroke))\n+        return type(self)(Paint(self.fill), Paint(self.stroke), Matrix())\n \n \n class Context:\n@@ -40,7 +41,6 @@ def __init__(self, impl, native):\n         self.native = native\n         self.impl = impl\n         self.path = Path()\n-        self.reset_transform()\n \n         # Backwards compatibility for Toga <= 0.5.3\n         self.in_fill = False\n@@ -57,7 +57,8 @@ def __init__(self, impl, native):\n         stroke.setStrokeWidth(2.0)\n         stroke.setColor(BLACK)\n \n-        self.states = [State(fill, stroke)]\n+        self.states = [State(fill, stroke, Matrix())]\n+        self.reset_transform()\n \n     @property\n     def state(self):\n@@ -71,6 +72,8 @@ def save(self):\n \n     def restore(self):\n         self.native.restore()\n+        # Transform active path to current coordinates\n+        self.path.transform(self.state.transform)\n         self.states.pop()\n \n     # Setting attributes\n@@ -171,14 +174,57 @@ def stroke(self):\n     def rotate(self, radians):\n         self.native.rotate(degrees(radians))\n \n+        # Update state transform\n+        self.state.transform.postRotate(degrees(radians))\n+\n+        # Transform active path to current coordinates\n+        inverse = Matrix()\n+        inverse.setRotate(-degrees(radians))\n+        self.path.transform(inverse)\n+\n     def scale(self, sx, sy):\n+        # Can't apply inverse transform if scale is 0,\n+        # so use a small epsilon which will almost be the same\n+        if sx == 0:\n+            sx = 2**-24\n+        if sy == 0:\n+            sy = 2**-24\n+\n         self.native.scale(sx, sy)\n \n+        # Update state transform\n+        self.state.transform.postScale(sx, sy)\n+\n+        # Transform active path to current coordinates\n+        inverse = Matrix()\n+        inverse.setScale(1 / sx, 1 / sy)\n+        self.path.transform(inverse)\n+\n     def translate(self, tx, ty):\n         self.native.translate(tx, ty)\n \n+        # Update state transform\n+        self.state.transform.postTranslate(tx, ty)\n+\n+        # Transform active path to current coordinates\n+        inverse = Matrix()\n+        inverse.setTranslate(-tx, -ty)\n+        self.path.transform(inverse)\n+\n     def reset_transform(self):\n         self.native.setMatrix(None)\n+\n+        # current matrix needs to unwind all previous states\n+        # can't just ask for current total transform as `getMatrix` is deprecated\n+        for state in reversed(self.states):\n+            self.path.transform(state.transform)\n+            inverse = Matrix()\n+            # if we can't invert, ignore for now\n+            if state.transform.invert(inverse):  # pragma: no branch\n+                # Update current state transform\n+                self.state.transform.postConcat(inverse)\n+\n+        # Rescale to standard units\n         self.scale(self.impl.dpi_scale, self.impl.dpi_scale)\n \n     # Text\ndiff --git a/changes/2206.bugfix.md b/changes/2206.bugfix.md\nnew file mode 100644\nindex 0000000000..239dd78002\n--- /dev/null\n+++ b/changes/2206.bugfix.md\n@@ -0,0 +1,1 @@\n+The Android, Qt and Winforms canvases now match the behavior of the HTML Canvas when a transform is applied while preparing a path.\ndiff --git a/changes/4110.removal.md b/changes/4110.removal.md\nnew file mode 100644\nindex 0000000000..b81369da4f\n--- /dev/null\n+++ b/changes/4110.removal.md\n@@ -0,0 +1,1 @@\n+The behaviour of the Canvas widget when a drawing was scaled by a factor of 0 in either axis was unspecified and varied across backends and HTML Canvas implementations.  The Canvas widget now follows a consistent, reasonable behavior when this happens which should produce similar results on all backends. On some backends, to avoid errors or other drawing problems, a very small scale factor is used instead of 0 when asked to scale by 0.\ndiff --git a/gtk/src/toga_gtk/widgets/canvas.py b/gtk/src/toga_gtk/widgets/canvas.py\nindex 4f5f46bd37..892514ad70 100644\n--- a/gtk/src/toga_gtk/widgets/canvas.py\n+++ b/gtk/src/toga_gtk/widgets/canvas.py\n@@ -155,6 +155,13 @@ def rotate(self, radians):\n         self.native.rotate(radians)\n \n     def scale(self, sx, sy):\n+        # Cairo throws an exception if scale is 0,\n+        # so use a small epsilon which will almost be the same\n+        if sx == 0:\n+            sx = 2**-24\n+        if sy == 0:\n+            sy = 2**-24\n+\n         self.native.scale(sx, sy)\n \n     def translate(self, tx, ty):\ndiff --git a/qt/src/toga_qt/widgets/canvas.py b/qt/src/toga_qt/widgets/canvas.py\nindex e70a37208d..ad14f97f7f 100644\n--- a/qt/src/toga_qt/widgets/canvas.py\n+++ b/qt/src/toga_qt/widgets/canvas.py\n@@ -28,9 +28,10 @@\n \n \n class State:\n-    \"\"\"Doesn't need to track transform, only fill/stroke-related properties.\"\"\"\n+    \"\"\"Track transform and fill/stroke-related properties.\"\"\"\n \n     def __init__(self, former_state=None):\n+        self.transform = QTransform()\n         if former_state:\n             self.fill_style = former_state.fill_style\n             self.stroke = QPen(former_state.stroke)\n@@ -63,6 +64,8 @@ def save(self):\n         self.native.save()\n \n     def restore(self):\n+        # Transform active path to current coordinates\n+        self._path = self.state.transform.map(self._path)\n         self.states.pop()\n         self.native.restore()\n \n@@ -183,15 +186,52 @@ def stroke(self):\n     def rotate(self, radians):\n         self.native.rotate(degrees(radians))\n \n+        # Update state transform\n+        self.state.transform.rotateRadians(radians)\n+\n+        # Transform active path to current coordinates\n+        inverse = QTransform()\n+        inverse.rotateRadians(-radians)\n+        self._path = inverse.map(self._path)\n+\n     def scale(self, sx, sy):\n+        # Can't apply inverse transform if scale is 0,\n+        # so use a small epsilon which will almost be the same\n+        if sx == 0:\n+            sx = 2**-24\n+        if sy == 0:\n+            sy = 2**-24\n+\n         self.native.scale(sx, sy)\n \n+        # Update state transform\n+        self.state.transform.scale(sx, sy)\n+\n+        # Transform active path to current coordinates\n+        inverse = QTransform()\n+        inverse.scale(1 / sx, 1 / sy)\n+        self._path = inverse.map(self._path)\n+\n     def translate(self, tx, ty):\n         self.native.translate(tx, ty)\n \n+        # Update state transform\n+        self.state.transform.translate(tx, ty)\n+\n+        # Transform active path to current coordinates\n+        inverse = QTransform()\n+        inverse.translate(-tx, -ty)\n+        self._path = inverse.map(self._path)\n+\n     def reset_transform(self):\n+        transform = self.native.transform()\n         self.native.resetTransform()\n \n+        # Update state transform\n+        inverse, _ = transform.inverted()\n+        self._path = transform.map(self._path)\n+        self.state.transform *= inverse\n+\n     # Text\n     def write_text(self, text, x, y, font, baseline, line_height):\n         left_offset, top_offset, _, bottom_offset, scaled_line_height = (\ndiff --git a/winforms/src/toga_winforms/widgets/canvas.py b/winforms/src/toga_winforms/widgets/canvas.py\nindex 93a1ea3049..ac6f0cf9c9 100644\n--- a/winforms/src/toga_winforms/widgets/canvas.py\n+++ b/winforms/src/toga_winforms/widgets/canvas.py\n@@ -1,4 +1,3 @@\n-from copy import deepcopy\n from math import degrees\n \n import System.Windows.Forms as WinForms\n@@ -42,24 +41,29 @@ class State:\n     we used it. And it would still need to be kept in a list.\n     \"\"\"\n \n-    def __init__(self, matrix, brush, pen):\n-        self.matrix = matrix\n+    def __init__(self, previous_state, brush, pen, singular=False):\n+        # This is the previous graphics state, so we can restore.\n+        self.previous_state = previous_state\n         self.brush = brush\n         self.pen = pen\n+        # When we are in a singular state, should not draw anything\n+        self.singular = singular\n+        self.transform = Matrix()\n \n     @classmethod\n     def for_impl(cls, impl):\n         return cls(\n-            matrix=Matrix(),\n+            previous_state=None,\n             brush=SolidBrush(BLACK),\n             pen=Pen(BLACK, impl.scale_in(2.0, rounding=None)),\n         )\n \n-    def __deepcopy__(self, memo):\n+    def new_state(self, previous_state):\n         return type(self)(\n-            matrix=self.matrix.Clone(),\n+            previous_state=previous_state,\n             brush=self.brush.Clone(),\n             pen=self.pen.Clone(),\n+            singular=self.singular,\n         )\n \n \n@@ -99,6 +103,15 @@ def get_last_point(self, default_x, default_y):\n         else:\n             return PointF(default_x, default_y)\n \n+    def transform_path(self, matrix):\n+        \"\"\"Transform the current path using a matrix.\"\"\"\n+        for path in self.paths:\n+            path.Transform(matrix)\n+        if self.start_point:\n+            points = Array[PointF]([self.start_point])\n+            matrix.TransformPoints(points)\n+            self.start_point = points[0]\n+\n     # Context management\n \n     @property\n@@ -106,10 +119,13 @@ def state(self):\n         return self.states[-1]\n \n     def save(self):\n-        self.states.append(deepcopy(self.state))\n+        graphics_state = self.native.Save()\n+        self.states.append(self.state.new_state(graphics_state))\n \n     def restore(self):\n-        self.states.pop()\n+        state = self.states.pop()\n+        self.native.Restore(state.previous_state)\n+        self.transform_path(state.transform)\n \n     # Setting attributes\n \n@@ -218,32 +234,79 @@ def rect(self, x, y, width, height):\n     # Drawing Paths\n \n     def fill(self, fill_rule):\n+        if self.state.singular:\n+            # draw nothing\n+            return\n         for path in self.paths:\n             if fill_rule == FillRule.EVENODD:\n                 path.FillMode = FillMode.Alternate\n             else:  # Default to NONZERO\n                 path.FillMode = FillMode.Winding\n-            path.Transform(self.state.matrix)\n             self.native.FillPath(self.state.brush, path)\n \n     def stroke(self):\n+        if self.state.singular:\n+            # draw nothing\n+            return\n         for path in self.paths:\n-            path.Transform(self.state.matrix)\n             self.native.DrawPath(self.state.pen, path)\n \n     # Transformations\n \n     def rotate(self, radians):\n-        self.state.matrix.Rotate(degrees(radians))\n+        self.native.RotateTransform(degrees(radians))\n+\n+        # Update state transform\n+        self.state.transform.Rotate(degrees(radians))\n+\n+        # Transform active path to current coordinates\n+        inverse = Matrix()\n+        inverse.Rotate(-degrees(radians))\n+        self.transform_path(inverse)\n \n     def scale(self, sx, sy):\n-        self.state.matrix.Scale(sx, sy)\n+        # Can't apply inverse transform if scale is 0,\n+        # so use a small epsilon which will almost be the same\n+        if sx == 0:\n+            sx = 2**-24\n+            self.state.singular = True\n+        if sy == 0:\n+            sy = 2**-24\n+            self.state.singular = True\n+\n+        self.native.ScaleTransform(sx, sy)\n+\n+        # Update state transform\n+        self.state.transform.Scale(sx, sy)\n+\n+        # Transform active path to current coordinates\n+        inverse = Matrix()\n+        inverse.Scale(1 / sx, 1 / sy)\n+        self.transform_path(inverse)\n \n     def translate(self, tx, ty):\n-        self.state.matrix.Translate(tx, ty)\n+        self.native.TranslateTransform(tx, ty)\n+\n+        # Update state transform\n+        self.state.transform.Translate(tx, ty)\n+\n+        # Transform active path to current coordinates\n+        inverse = Matrix()\n+        inverse.Translate(-tx, -ty)\n+        self.transform_path(inverse)\n \n     def reset_transform(self):\n-        self.state.matrix.Reset()\n+        matrix = self.native.Transform\n+        self.native.ResetTransform()\n+\n+        # Transform active path to current coordinates\n+        self.transform_path(matrix)\n+\n+        # Update state transform\n+        matrix.Invert()\n+        self.state.transform.Multiply(matrix)\n+\n+        self.state.singular = False\n         self.scale(self.impl.dpi_scale, self.impl.dpi_scale)\n \n     # Text\n@@ -287,10 +350,7 @@ def _text_path(self, text, x, y, font, baseline, line_height):\n             )\n \n     def draw_image(self, image, x, y, width, height):\n-        self.native.ResetTransform()\n-        self.native.Transform = self.state.matrix\n         self.native.DrawImage(image._impl.native, x, y, width, height)\n-        self.native.ResetTransform()\n \n \n class Canvas(Box):\n", "test_patch": "diff --git a/testbed/src/testbed/resources/canvas/singular_transforms.png b/testbed/src/testbed/resources/canvas/singular_transforms.png\nnew file mode 100644\nindex 0000000000..60cd8ad9f5\nBinary files /dev/null and b/testbed/src/testbed/resources/canvas/singular_transforms.png differ\ndiff --git a/testbed/src/testbed/resources/canvas/transforms_mid_path.png b/testbed/src/testbed/resources/canvas/transforms_mid_path.png\nnew file mode 100644\nindex 0000000000..1c9aa790c7\nBinary files /dev/null and b/testbed/src/testbed/resources/canvas/transforms_mid_path.png differ\ndiff --git a/testbed/tests/widgets/test_canvas.py b/testbed/tests/widgets/test_canvas.py\nindex 70156c7f8a..351b8ae924 100644\n--- a/testbed/tests/widgets/test_canvas.py\n+++ b/testbed/tests/widgets/test_canvas.py\n@@ -697,6 +697,96 @@ async def test_transforms(canvas, probe):\n     assert_reference(probe, \"transforms\")\n \n \n+async def test_transforms_mid_path(canvas, probe):\n+    \"Transforms can be applied mid-path\"\n+\n+    # draw a series of rotated rectangles\n+    canvas.root_state.begin_path()\n+    canvas.root_state.translate(100, 100)\n+    with canvas.root_state.state() as ctx:\n+        for _ in range(12):\n+            ctx.rect(50, 0, 10, 10)\n+            ctx.scale(1.1, 1)\n+            ctx.rotate(math.pi / 6)\n+\n+        canvas.root_state.fill()\n+        canvas.root_state.stroke(GOLDENROD)\n+\n+    # draw a series of line segments\n+    canvas.root_state.begin_path()\n+    canvas.root_state.move_to(25, 0)\n+    for _ in range(12):\n+        canvas.root_state.line_to(25, 0)\n+        canvas.root_state.rotate(math.pi / 6)\n+        canvas.root_state.translate(5, 3)\n+    canvas.root_state.close_path()\n+    canvas.root_state.reset_transform()\n+    canvas.root_state.move_to(110, 100)\n+    canvas.root_state.scale(5, 1)\n+    canvas.root_state.ellipse(20, 100, 2, 20, 0, 0, 2 * pi)\n+    canvas.root_state.stroke(CORNFLOWERBLUE)\n+\n+    await probe.redraw(\"Transforms can be applied\")\n+    assert_reference(probe, \"transforms_mid_path\", threshold=0.015)\n+\n+\n+async def test_singular_transforms(canvas, probe):\n+    \"Singular transforms behave reasonably\"\n+    ctx = canvas.root_state\n+\n+    ctx.begin_path()\n+    with ctx.state() as ctx2:\n+        # flip about the line x = y\n+        ctx2.rotate(-pi / 2)\n+        ctx2.scale(-1, 1)\n+\n+        ctx2.move_to(40, 20)\n+        ctx2.line_to(80, 20)\n+        ctx2.line_to(100, 30)\n+\n+        with ctx2.state() as ctx3:\n+            # Apply a scale factor of zero\n+            ctx3.scale(0.9, 0)\n+            ctx3.line_to(180, 20)\n+\n+        ctx2.rotate(pi / 4)\n+        ctx2.line_to(180, 20)\n+\n+        ctx2.stroke(GOLDENROD, line_width=8)\n+\n+    # Same shape, but not flipped, using reset_transform()\n+    ctx.begin_path()\n+\n+    ctx.move_to(40, 20)\n+    ctx.line_to(80, 20)\n+    ctx.line_to(100, 30)\n+\n+    # Apply a scale factor of zero\n+    ctx.scale(0.9, 0)\n+    ctx.line_to(180, 20)\n+    # Total transform is singular\n+    ctx.reset_transform()\n+\n+    ctx.rotate(pi / 4)\n+    ctx.line_to(180, 20)\n+\n+    ctx.stroke(CORNFLOWERBLUE, line_width=8)\n+\n+    ctx.reset_transform()\n+    ctx.begin_path()\n+    ctx.scale(0, 0.9)\n+    ctx.translate(50, 50)\n+\n+    ctx.rect(0, 0, 25, 25)\n+\n+    # Should draw nothing.\n+    ctx.fill()\n+    ctx.stroke(line_width=10)\n+\n+    await probe.redraw(\"Transforms can be applied\")\n+    assert_reference(probe, \"singular_transforms\")\n+\n+\n @pytest.mark.xfail(\n     condition=os.environ.get(\"RUNNING_IN_CI\") != \"true\",\n     reason=\"Canvas tests are unstable outside of CI. Manual inspection may be required\",\n", "problem_statement": "Canvas transformation bugs on WinForms and Android\n### Describe the bug\r\n\r\nThe [HTML spec says](https://html.spec.whatwg.org/multipage/canvas.html#building-paths) that points \"must be transformed according to the [current transformation matrix](https://html.spec.whatwg.org/multipage/canvas.html#transformations) before being added to the path\". \r\n\r\nToga does this correctly on Cocoa and GTK, but on WinForms and Android it doesn't apply the matrix until the path is actually drawn, so the entire path is transformed with whatever happens to be the matrix at that moment.\r\n\r\n<table>\r\n<tr>\r\n<td>\r\n\r\n```js\r\nctx.lineWidth = 2\r\nctx.moveTo(40, 20)\r\nctx.lineTo(80, 20)\r\n\r\nctx.rotate(Math.PI / 4)\r\nctx.lineTo(180, 20)\r\n                                  \r\nctx.stroke()\r\n```\r\n</td>\r\n<td>\r\n\r\n```py\r\n    ctx.move_to(40, 20)\r\n    ctx.line_to(80, 20)\r\n                                  \r\n    ctx.rotate(math.pi / 4)\r\n    ctx.line_to(180, 20)\r\n\r\n    ctx.stroke()\r\n```\r\n</td>\r\n</tr>\r\n</table>\r\n\r\nHTML (https://jsfiddle.net/mhsmith/9ewqnvz5/14/), and Toga on Cocoa and GTK:\r\n<img width=\"225\" alt=\"Screenshot 2023-11-08 at 12 53 40\" src=\"https://github.com/beeware/toga/assets/166954/c66cd2bc-8903-4193-a435-261c4a86565a\">\r\n\r\nToga on WinForms and Android:\r\n<img width=\"225\" alt=\"Screenshot 2023-11-08 at 12 28 03\" src=\"https://github.com/beeware/toga/assets/166954/e1604d8b-b52e-463f-bc4a-503defcff6bd\">\r\n\r\n### Environment\r\n\r\n- Software versions:\r\n  - Toga: main (536a60f)\nHandling singular transformations  in Canvas\n### What is the problem or limitation you are having?\n\nIn #4106 we need to be able to apply the inverse of an affine transformation to a path, which is fine unless the transformation is singular and so has no inverse. The most common way of seeing this is setting a scale value of 0.\n\nIn #4106 we handle this by raising a division by zero exception, but it would be nice to handle this more gracefully.\n\n### Describe the solution you'd like\n\nWe should follow whatever the HTML canvas does, if we can.\n\nThis probably means adding tests for scaling to zero and related behaviour.\n\n### Describe alternatives you've considered\n\nLeave the behaviour undefined. It may be the case that different platforms behave differently, which would add complexity in trying to force them to act like the HTML Canvas, and I'm not sure it's worth the effort to force them to conform.\n\n### Additional context\n\nWhen you have a singular transform, all rendering will be confined to a single line (or point) which technically has 0 width, so it's not clear that *anything* should be drawn when the current transformation is not invertible.\n\nThe HTML canvas spec doesn't say anything about what to do or not to do when the transform is singular.\n\nSome definitions of \"affine transform\" *require* invertibility.\n", "hints_text": "The transformation should also apply to the stroke width. This is happening on Cocoa, GTK and Android, but not on WinForms.\n\nThis cannot be done simply by multiplying the width by a constant. For example, if there are different scale factors in the X and Y dimensions, the stroke width of a circle should change continuously around its circumference.\n\n<table style=\"width: 100%\">\n<tr>\n<td>\n\n```js\nctx.lineWidth = 2\nctx.moveTo(0, 25)\nctx.lineTo(50, 25)\n                                  \nctx.moveTo(25, 0)\nctx.lineTo(25, 50)\n\nctx.scale(3, 1)\nctx.stroke()\n```\n</td>\n<td>\n\n```py\n    ctx.move_to(0, 25)\n    ctx.line_to(50, 25)\n                                  \n    ctx.move_to(25, 0)\n    ctx.line_to(25, 50)\n\n    ctx.scale(3, 1)\n    ctx.stroke()\n```\n</td>\n</tr>\n</table>\n\nHTML (https://jsfiddle.net/mhsmith/21ehgadk/9/), and Toga on Cocoa and GTK:\n<img width=\"225\" alt=\"Screenshot 2023-11-08 at 12 37 35\" src=\"https://github.com/beeware/toga/assets/166954/67bd8ef7-e805-41d4-9360-1726583735b1\">\n\nToga on Android:\n<img width=\"225\" alt=\"Screenshot 2023-11-08 at 12 38 21\" src=\"https://github.com/beeware/toga/assets/166954/ddf7cbb9-4ee6-4d16-a188-28f6ab77e27f\">\n\nToga on WinForms:\n<img width=\"225\" alt=\"Screenshot 2023-11-08 at 12 45 39\" src=\"https://github.com/beeware/toga/assets/166954/d11a7fb6-6683-4287-82e0-cd918125da9c\">\n\n\n\n", "all_hints_text": "The transformation should also apply to the stroke width. This is happening on Cocoa, GTK and Android, but not on WinForms.\n\nThis cannot be done simply by multiplying the width by a constant. For example, if there are different scale factors in the X and Y dimensions, the stroke width of a circle should change continuously around its circumference.\n\n<table style=\"width: 100%\">\n<tr>\n<td>\n\n```js\nctx.lineWidth = 2\nctx.moveTo(0, 25)\nctx.lineTo(50, 25)\n                                  \nctx.moveTo(25, 0)\nctx.lineTo(25, 50)\n\nctx.scale(3, 1)\nctx.stroke()\n```\n</td>\n<td>\n\n```py\n    ctx.move_to(0, 25)\n    ctx.line_to(50, 25)\n                                  \n    ctx.move_to(25, 0)\n    ctx.line_to(25, 50)\n\n    ctx.scale(3, 1)\n    ctx.stroke()\n```\n</td>\n</tr>\n</table>\n\nHTML (https://jsfiddle.net/mhsmith/21ehgadk/9/), and Toga on Cocoa and GTK:\n<img width=\"225\" alt=\"Screenshot 2023-11-08 at 12 37 35\" src=\"https://github.com/beeware/toga/assets/166954/67bd8ef7-e805-41d4-9360-1726583735b1\">\n\nToga on Android:\n<img width=\"225\" alt=\"Screenshot 2023-11-08 at 12 38 21\" src=\"https://github.com/beeware/toga/assets/166954/ddf7cbb9-4ee6-4d16-a188-28f6ab77e27f\">\n\nToga on WinForms:\n<img width=\"225\" alt=\"Screenshot 2023-11-08 at 12 45 39\" src=\"https://github.com/beeware/toga/assets/166954/d11a7fb6-6683-4287-82e0-cd918125da9c\">\n\nBut I *want* to be able to divide by zero! Stupid math... \ud83e\udd23 \n\nI don't have any strong feelings here. Adherence to HTML5 canvas is a definitely a guiding principle, and when faced with implementation options, \"do what HTML5 does\" is certainly a good fallback. But if we need to make certain mathematical edge case behaviors undefined, then I'm OK with that. \n> The HTML canvas spec doesn't say anything about what to do or not to do when the transform is singular.\n\nIt doesn't need to, because the spec doesn't require any transform inversions as far as I know. The result is well-defined; if our implementation has undefined intermediate calculations, then that's our fault.\n\nThis is a bit more than an edge case, it'll come up immediately if anyone goes through a range of scale factors which happens to include zero. The existing canvas example may already do this, and it would be a fairly common thing to do while simulating a 3D rotation, like [this](https://www.presentermedia.com/powerpoint-animation/spinning-text-pid-13063).\n\nCan we work around this by treating a zero scale factor as if it was something very small like 0.000001? That should give a result that's visually close enough to what the user intended, just as at least one of the backends uses a Bezier curve to approximate a circle, even though that isn't mathematically perfect.\n\nAlternatively, since we know that at least some of the native backends can handle this, how do they do that? Do they apply the series of transformations backwards to the path immediately before drawing it, rather than doing it progressively as the path is built? Would that make the mathematics easier?\n\n> Alternatively, since we know that at least some of the native backends can handle this, how do they do that? Do they apply the series of transformations backwards to the path immediately before drawing it, rather than doing it progressively as the path is built? Would that make the mathematics easier?\n\nI think this may be a good idea.  Instead of backwards-transforming the existent path, I think we might get away with transforming each point by the current transformation matrix as we go, then apply the inverse of the \"final\" transformation matrix we've got to the points at the point where stroke() or something is called, and then tell native to apply that \"final\" transformation matrix (so we get stroke widths).  That way, it'll only fail if our \"final\" transformation matrix (that is before we call stroke) is non-invertible, which means that the path probably would come down to a degenerate point anyways.\n> Alternatively, since we know that at least some of the native backends can handle this, how do they do that? Do they apply the series of transformations backwards to the path immediately before drawing it, rather than doing it progressively as the path is built? Would that make the mathematics easier?\n\n> Instead of backwards-transforming the existent path, I think we might get away with transforming each point by the current transformation matrix as we go, then apply the inverse of the \"final\" transformation matrix we've got to the points at the point where stroke() or something is called, and then tell native to apply that \"final\" transformation matrix (so we get stroke widths). That way, it'll only fail if our \"final\" transformation matrix (that is before we call stroke) is non-invertible, which means that the path probably would come down to a degenerate point anyways.\n\nIt's possible I'm not fully wrapping my head around the math here, but it seems to me like both of those options still require calculating the inverse of matrices that may not have them.\n\nAlso \u2014 it's debatable if leaving this behavior as undefined / exception-throwing for the moment is exactly a *regression*, since any code that would cause that to happen is also currently code that causes any filling or stroking of the path to work incorrectly, due to #2206. It's true that it can make something already broken *more* broken, though \u2014 crashing the program isn't ideal.\n\nIdeally, of course, we fix this so that transforms are always handled correctly. But unless a solution is immediately apparent, I can think of two options for mitigating this problem for the time being in #4106. When, while building a path on Android or Windows, we encounter a non-invertible mid-path transform, we could either:\n\n- Abort drawing the preexisting path and begin a new one in the now-current transform.\n- Revert to previous functionality, where the entire path is simply drawn all in the final transformation.\n\nThe latter doesn't disrupt any existing code that accidentally relies on the incorrect behavior, but it seems like it would require a good bit more shimming for what's ideally only a temporary transitional state.\n@HalfWhitt \n\n> > Alternatively, since we know that at least some of the native backends can handle this, how do they do that? Do they apply the series of transformations backwards to the path immediately before drawing it, rather than doing it progressively as the path is built? Would that make the mathematics easier?\n> \n> > Instead of backwards-transforming the existent path, I think we might get away with transforming each point by the current transformation matrix as we go, then apply the inverse of the \"final\" transformation matrix we've got to the points at the point where stroke() or something is called, and then tell native to apply that \"final\" transformation matrix (so we get stroke widths). That way, it'll only fail if our \"final\" transformation matrix (that is before we call stroke) is non-invertible, which means that the path probably would come down to a degenerate point anyways.\n> \n> It's possible I'm not fully wrapping my head around the math here, but it seems to me like both of those options still require calculating the inverse of matrices that may not have them.\n\nIf our transform matrix is non-invertible only in the middle of building the path but not at the final drawing, then the path should still draw properly because the final transform is nondegenerate.  However, if a matrix is noninvertible at the final drawing, then there is no way it will draw *anything* because all the line widths / radii will be scaled to 0.\n\nThe current approach of #4106 is backwards-transforming the existing path when a new transform is pushed.  This relies on the matrix being invertible *at each point in the transformation building process*.  However, using the approach I put above, it only relies on *the final matrix being invertible*, which will be better, becaues if the final matrix were to be non-invertible, we wouldn't have anything to be drawn anyways.\n\n[Also good luck with your move if you're still in the process.]\n\n**EDIT** For resetting transforms, perhaps we could store the initial transform and use that directly instead of inverting the ones we pushed?\n> If our transform matrix is non-invertible only in the middle of building the path but not at the final drawing, then the path should still draw properly because the final transform is nondegenerate. However, if a matrix is noninvertible at the final drawing, then there is no way it will draw _anything_ because all the line widths / radii will be scaled to 0.\n\nIf at any point the canvas is scaled down to a line or a point, there's no coming back from that by applying further transformations. Multiplying zero by anything is still zero.\n\n> For resetting transforms, perhaps we could store the initial transform and use that directly instead of inverting the ones we pushed?\n\nThat works as long as the APIs in question support *setting* the transform matrix (of a path or of the graphics state) as opposed to only modifying it. I don't think Android, at least allows this for paths; and I was having similar difficulty in #4045 because Cocoa/iOS doesn't let you assign to the graphics state's matrix.\n\nNow that I think about: if all non-invertible matrices result in not being able to draw anything anyway \u2014 then we could just stop tracking points when that happens.\n> > If our transform matrix is non-invertible only in the middle of building the path but not at the final drawing, then the path should still draw properly because the final transform is nondegenerate. However, if a matrix is noninvertible at the final drawing, then there is no way it will draw _anything_ because all the line widths / radii will be scaled to 0.\n> \n> If at any point the canvas is scaled down to a line or a point, there's no coming back from that by applying further transformations. Multiplying zero by anything is still zero.\n> \n> >\n\nPerhaps when things like reset_transform happens?  But then...\n\n> > For resetting transforms, perhaps we could store the initial transform and use that directly instead of inverting the ones we pushed?\n> \n> That works as long as the APIs in question support _setting_ the transform matrix (of a path or of the graphics state) as opposed to only modifying it. I don't think Android, at least allows this for paths; and I was having similar difficulty in [#4045](https://github.com/beeware/toga/pull/4045) because Cocoa/iOS doesn't let you assign to the graphics state's matrix.\n\nOof, I'd have to agree with you here.  So we can't implement reset_transform as soon as a noninvertible operation happens...  I think this falls into the category of \"can't be implemented/supported by native layer\", so we can advise people to *not* scale to 0.\n\n> Now that I think about: if all non-invertible matrices result in not being able to draw anything anyway \u2014 then we could just stop tracking points when that happens.\n\nYes -- and hand-wavy idea:  don't push the 0 transformation matrix, but when we get a reset_transform we just reset the transforms before the 0 and then keep tracking?\n> Yes -- and hand-wavy idea: don't push the 0 transformation matrix, but when we get a reset_transform we just reset the transforms before the 0 and then keep tracking?\n\nHand-waviness aside, yes, that does seem like it makes sense. Basically, if we're handed a degenerate transformation, we essentially go into hibernation mode, as far as adding points and doing transforms, until either the transform is reset or the state is restored.\n\nThis is, of course, assuming that it's true that all non-invertible transforms are also non-drawable (because they've collapsed to a line or point). I *think* that's true, but I'm not knowledgeable enough about matrix math to say that for certain without further looking into it (or, more likely, hearing from Corran \ud83d\ude09).\n\n(Oh, and yes, move is accomplished, thank you. Everything's here, anyway \u2014 and in time before getting snowed in.)\n> > Yes -- and hand-wavy idea: don't push the 0 transformation matrix, but when we get a reset_transform we just reset the transforms before the 0 and then keep tracking?\n> \n> Hand-waviness aside, yes, that does seem like it makes sense. Basically, if we're handed a degenerate transformation, we essentially go into hibernation mode, as far as adding points and doing transforms, until either the transform is reset or the state is restored.\n> \n> This is, of course, assuming that it's true that all non-invertible transforms are also non-drawable (because they've collapsed to a line or point). I _think_ that's true, but I'm not knowledgeable enough about matrix math to say that for certain without further looking into it (or, more likely, hearing from Corran).\n\nCan confirm that the determinant of the matrix measures area change of the operation, so a determinant of 0 will basically flatten the area to 0... and since stroke widths are dependent on the transform, they can also be considered as part of the area and will be flattened to 0.  A matrix should be invertible if its determinant is nonzero -- since A^(-1) is 1/det(A) adj(A) and all square matrices have adjugates the only way for this to be undefined is if det(A)=0.\n\n(Math... yes, memories.  I remember a year ago deriving the 2x2 determinant formula by myself...)\nA lot of discussion. If there's time today I'll look at what HTML Canvas does.  In particular, I think we need to see what the HTML canvas does in the following situations to know what we want to do:\n \n- start building a path\n- save the state\n- apply a singular transform\n- add more things to the path\n- restore the state\n- add some more things to the path\n- stroke\n\n> > Alternatively, since we know that at least some of the native backends can handle this, how do they do that? Do they apply the series of transformations backwards to the path immediately before drawing it, rather than doing it progressively as the path is built? Would that make the mathematics easier?\n> \n> > Instead of backwards-transforming the existent path, I think we might get away with transforming each point by the current transformation matrix as we go, then apply the inverse of the \"final\" transformation matrix we've got to the points at the point where stroke() or something is called, and then tell native to apply that \"final\" transformation matrix (so we get stroke widths). That way, it'll only fail if our \"final\" transformation matrix (that is before we call stroke) is non-invertible, which means that the path probably would come down to a degenerate point anyways.\n> \n> It's possible I'm not fully wrapping my head around the math here, but it seems to me like both of those options still require calculating the inverse of matrices that may not have them.\n\nThe catch is the line widths (and in the future patterns and gradients): to get these correct, all drawing has to be done in the current transformed coordinates or the line thicknesses do not get stretched in the right way. If we transform path points to global/screen coordinates and track them that way in the path, even then we still need to transform them into the current coordinates before drawing, and that requires taking the inverse of the entire current transform - which once you hit a singular transform somewhere will still be singular.\n\nI think that the underlying libraries handle this in ways we can't because they have complete control of the rendering of the paths. In particular, stroking the path is almost certainly done by thickening the path in the correct directions and rendering the resulting polygon. I don't think we want to do that due to the algorithmic complexity.\n\n> Ideally, of course, we fix this so that transforms are always handled correctly. But unless a solution is immediately apparent, I can think of two options for mitigating this problem for the time being in [#4106](https://github.com/beeware/toga/pull/4106). When, while building a path on Android or Windows, we encounter a non-invertible mid-path transform, we could either:\n> \n> * Abort drawing the preexisting path and begin a new one in the now-current transform.\n> * Revert to previous functionality, where the entire path is simply drawn all in the final transformation.\n> \n> The latter doesn't disrupt any existing code that accidentally relies on the incorrect behavior, but it seems like it would require a good bit more shimming for what's ideally only a temporary transitional state.\n\nAnother possibility is to keep track of whether the total transform is singular and:\n- not draw anything on fill or stroke\n- track the additions to the path differently (basically track in the last non-singular coordinate system, so we can recover to that point).\n\nBut it may also be the case that if someone uses a singular transformation we can't do anything that doesn't draw incorrectly without significant complexity, and so it may be best to draw incorrectly and warn so the user knows why things didn't work.\nThinking about this over morning coffee. The following might be an acceptable compromise based on this:\n\n> Can we work around this by treating a zero scale factor as if it was something very small like 0.000001? That should give a result that's visually close enough to what the user intended, just as at least one of the backends uses a Bezier curve to approximate a circle, even though that isn't mathematically perfect.\n\nWhen asked to scale to 0 (or other singular matrix), we:\n- apply the transform to the coordinate system as specified\n- apply an *almost* zero transform to the path (and the path transform state we are tracking). This could be for example adding some small epsilon (like `2**-20` or something) times the identity matrix\n- possibly throw a flag to turn off filling (stroke should be fine - the lines should end up with width 0) depending on what the backend does\n- and most importantly, *warn* the user that drawing won't be quite right\n\nIf the state is restored to something which is non-singular with the path still live then anything added during the singular portion should be perfectly collinear if drawing was perfect, but instead may be slightly off by the epsilon factor.\n\nThe only way this could fail is if we get really unlucky, and our adjustment factor happens to exactly cancel out the non-zero eigenvalue, and if needs be we *can* calculate the eigenvalues reasonably easily (or in the case of scaling, we know the other value already).\n\n**BUT**\n\nOf course now that I try with the HTML canvas (on Firefox), it does something completely different:\n``` javascript\n  ctx.moveTo(40, 20);\n  ctx.lineTo(80, 20);\n  ctx.lineTo(100, 30);\n\n  ctx.save();\n  ctx.scale(1.0, 0.0);\n  ctx.lineTo(180, 20);\n  ctx.restore();\n\n  ctx.rotate(Math.PI/4);\n  ctx.lineTo(180, 20);\n                                  \n  ctx.stroke();\n```\nProduces:\n\n<img width=\"222\" height=\"173\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/08968f0e-47a9-474c-a6bf-4793cdc52e1e\" />\n\ninstead of what I would have expected:\n\n<img width=\"195\" height=\"154\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/4bd2a552-6fd5-4d15-b5fd-32d5747c5482\" />\n\n`resetTransform` works similarly.\n\nAnd we can get that, I think, by just whenever we see a scale by 1/0, scaling by 1 instead.\nAnd *of course* macOS is different (it matches what I expected):\n\n<img width=\"200\" height=\"200\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/5c2e73fd-b819-4461-885c-24c62ebd9871\" />\n\nBut then it also draws things when the current transform has a scale factor of 0... which is *not* what I expected (it draws the path in global coordinates, but with a line thickness of 1 in the scale 0 direction).\n\nI'm not sure how hard we want to work to get macOS (and probably iOS) to agree with HTML Canvas in these cases. If we do, it's an argument in favour of what @HalfWhitt was suggesting of taking state management completely out of the hands of the backend..\n\nEdit to add: Chrome agrees with macOS (I suspect that Safari and Edge will do the same), so Firefox is *different* for HTML Canvas (!); also Chrome *doesn't* draw when the total transformation is singular.\n> The current approach of [#4106](https://github.com/beeware/toga/pull/4106) is backwards-transforming the existing path when a new transform is pushed. This relies on the matrix being invertible _at each point in the transformation building process_. However, using the approach I put above, it only relies on _the final matrix being invertible_, which will be better, becaues if the final matrix were to be non-invertible, we wouldn't have anything to be drawn anyways.\n\nJust a quick comment here that these two cases are exactly the same: the final matrix is invertible if and only if it is invertible every step along the way.\nI'm despairing a little right now. The following Javascript works as expected:\n``` javascript\n\n  ctx.lineWidth = 2;\n  ctx.beginPath();\n  ctx.save();\n\n  // This reflects in line x = y\n  ctx.rotate(-Math.PI/2);\n  ctx.scale(-1, 1);\n \n  ctx.moveTo(40, 20);\n  ctx.lineTo(80, 20);\n  ctx.lineTo(100, 30);\n\n  ctx.save();\n  ctx.scale(0.9, 0.000001);\n  ctx.lineTo(180, 20);\n  ctx.restore();\n  ctx.rotate(Math.PI/4);\n  ctx.lineTo(180, 20);\n                                  \n  ctx.stroke();\n  ctx.restore();\n\n  // Do the same but without the flip and with resetTransform\n  ctx.beginPath();\n\n  ctx.moveTo(40, 20);\n  ctx.lineTo(80, 20);\n  ctx.lineTo(100, 30);\n\n  ctx.scale(0.9, 0.000001);\n  ctx.lineTo(180, 20);\n  ctx.resetTransform();\n\n  ctx.rotate(Math.PI/4);\n  ctx.lineTo(180, 20);\n\n  ctx.lineWidth = 2;\n  ctx.stroke();\n```\nIn all browsers, this produces something which looks like this:\n\n<img width=\"183\" height=\"187\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/9fc11fb9-0a91-4219-bdcd-2872e3fd4f3b\" />\n\nI'd generally expect that if we replace the 0.000001 with 0.0, a correct implementation should produce something which looks like this, just from general limit arguments (it looks much the same with -0.000001, so there isn't any sort of discontinuity).\n\nOn Firefox, making things singular gives:\n\n<img width=\"194\" height=\"201\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/4ae48a98-d578-4097-9e1f-8ab94eb829ef\" />\n\nWhich is at least consistent, and matches the approach of #4054 if we scaled by 1 instead of throwing an exception when updating the paths.\n\nOn Chrome, we get this (!):\n\n<img width=\"203\" height=\"196\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/292261af-2002-4839-b8de-206e12ea849e\" />\n\nIt doesn't matter if I do `save()`/`restore()` or `resetTransform()`. Playing a bit more, it looks like Chrome loses track of any transforms applied before the singular one, even if it should be restored by a `restore()`.\n\nFor what it's worth, the corresponding code on macOS gives:\n\n<img width=\"200\" height=\"200\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/f30c343d-eba4-42fd-a58a-723f1536d3de\" />\n\nWhich I think is right in this case.\n> > The current approach of [#4106](https://github.com/beeware/toga/pull/4106) is backwards-transforming the existing path when a new transform is pushed. This relies on the matrix being invertible _at each point in the transformation building process_. However, using the approach I put above, it only relies on _the final matrix being invertible_, which will be better, becaues if the final matrix were to be non-invertible, we wouldn't have anything to be drawn anyways.\n> \n> Just a quick comment here that these two cases are exactly the same: the final matrix is invertible if and only if it is invertible every step along the way.\n\nI *think* this is true except with reset_transform... but yes, this should be correct.  Sorry for missing this.\n\n**EDIT** -- with reset_transform depending on this behavior's invertibility.  Sorry.\n\n-----\n\nI think given all the inconsistencies, erroring on a singular transform makes sense to match HTML5 canvas.  I can also see how the \"stop tracking points once we get a singular transform and then start again\" is inconsistent because we can scale points down to a single line which should still be drawn if the final transform (if we reset_transform) is nonsingular.\n\nI think at this point we might as well do whatever we want given the massive inconsistency of browsers.  With that said the scaling to epsilon approach does look promising.\n\n> I'd generally expect that if we replace the 0.000001 with 0.0, a correct implementation should produce something which looks like this, just from general limit arguments (it looks much the same with -0.000001, so there isn't any sort of discontinuity).\n\nIn this case the path of the point should be a straight line as the scale in y varies, so I think this can be rigorously argued for without using -eps to compare.\n\n> The only way this could fail is if we get really unlucky, and our adjustment factor happens to exactly cancel out the non-zero eigenvalue, and if needs be we _can_ calculate the eigenvalues reasonably easily (or in the case of scaling, we know the other value already).\n\nI agree that this would be unfortunate.  I think we can let epsilon = max(2e-20, 2e-10*minimum eigenvalue so far) (adjusting 2e-20 to be a reasonable small value that's noticably nonzero, and 2e-10 to a small value that can effectively cancel the eigenvalue mostly.\n\n@corranwebster FYI:  Really thanks for working on this-- even though the process isn't completely *smooth* I salute you for persisting on this *continuous*ly (pun intended).\nI don't see anything about this specific situation in the [HTML5 spec](https://html.spec.whatwg.org/multipage/canvas.html#transformations), so I suppose this is technically undefined behavior \u2014 and the difference between browsers would seem to corroborate this. However...\n\n> For what it's worth, the corresponding code on macOS gives:\n> <img alt=\"Image\" width=\"200\" height=\"200\" src=\"https://private-user-images.githubusercontent.com/600761/540526167-f30c343d-eba4-42fd-a58a-723f1536d3de.png?jwt=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJnaXRodWIuY29tIiwiYXVkIjoicmF3LmdpdGh1YnVzZXJjb250ZW50LmNvbSIsImtleSI6ImtleTUiLCJleHAiOjE3Njk0NzkxNzMsIm5iZiI6MTc2OTQ3ODg3MywicGF0aCI6Ii82MDA3NjEvNTQwNTI2MTY3LWYzMGMzNDNkLWViYTQtNDJmZC1hNThhLTcyM2YxNTM2ZDNkZS5wbmc_.uvipQLuaDGuNI8XuO7ckpIo2TPMm-mgwkWP7hmeW1Lg\">\n> \n> Which I think is right in this case.\n\nThat certainly does seem the most logically consistent. Ideally, I think that's what we should aim for, if possible \u2014 whether than means the epsilon approach, or special-casing zero transforms in whatever way necessary to correct for platform differences.\n\n\n> That certainly does seem the most logically consistent. Ideally, I think that's what we should aim for, if possible \u2014 whether than means the epsilon approach, or special-casing zero transforms in whatever way necessary to correct for platform differences.\n\nI've just added a test for this in #4106 a a probe to see what different backends actually do. I expect that macOS and iOS should be correct, that Gtk will likely also be good (but may not, depending on the idiosyncrasies of Cairo graphics), and that Android, Qt and Winforms will fail with division by zero.\n\nEdit: and of course the test gets derailed by an unrelated GitHub infrastructure issue.\n\nSo it looks like the GTK backends already raised exceptions when scaling by zero, so there is precedent for the behaviour we had on #4106.\nI think I've resolved this for now in #4106 - I've got the tests working on all platforms. Other than on iOS and macOS, scaling by zero is now in fact scaling by 2**-24, which is visually identical to scaling by 0, but if you then scale up by a very large factor you might see the difference. I think this is OK.\n\nCurrently, the PR doesn't try to warn the user, and doesn't track singular state except on Windows where it is needed to pass the tests.\n\nIf a general `transform()` method is added (following the HTML Canvas API) we will need to do something there to handle singular matrices.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/309103e0c9cbd8acea8c799dd1aa2dc617711f77", "https://github.com/beeware/toga/commit/470601ea2ea53638ecd141b192a687bc1fdbb3ec", "https://github.com/beeware/toga/commit/d922f3212c327d053b6b66249a4c8e52e2b8646c", "https://github.com/beeware/toga/commit/7a4f5a9a5ef2eb546c6120c60e4712dfc386b5f6", "https://github.com/beeware/toga/commit/fea893b0885115397bbefc4cd7889a3ed5fe94d0", "https://github.com/beeware/toga/commit/364fef092660a526c92ffd11919869daa4866c51", "https://github.com/beeware/toga/commit/70026511e525963328eacbdf79f46cc2f566d92d", "https://github.com/beeware/toga/commit/e49aaf440c078ff93403fbf86e1cbede7eaa7478", "https://github.com/beeware/toga/commit/bb6c7e01d13869b5fe203306297ccd80f55afdd1", "https://github.com/beeware/toga/commit/130038a15aafe461780f139f2576a0dc6a39e284", "https://github.com/beeware/toga/commit/ffecac1f4219410a4cf32d4c000ca97f4a35b2fc", "https://github.com/beeware/toga/commit/7de753daaaa75480a3af5ecf06591d90c248090a", "https://github.com/beeware/toga/commit/9e003448f5472c7aa3015322dd0590c31b2c4e91", "https://github.com/beeware/toga/commit/5b1bd433c863c11ec05f18bedaf08e989a5b77b9", "https://github.com/beeware/toga/commit/887a7a64303d71f2a00e68055bd78884e5ec016a", "https://github.com/beeware/toga/commit/eafb5e8f461639d3bcd3a2d34acb34b95313bcf0", "https://github.com/beeware/toga/commit/d99ca42b3a4aee74436c8c0ddcd559b3844955a7", "https://github.com/beeware/toga/commit/56fb7cabbd60785787edb65fb76080e3265f52fd", "https://github.com/beeware/toga/commit/e18ace80e3525302bece3c7cb5fc2022687432ed", "https://github.com/beeware/toga/commit/53a6ebf5ca1654fc7970c8db6f6a9694f976ba93", "https://github.com/beeware/toga/commit/7c9a301efa072c2c802e1b4631b5ddb81dd3844f", "https://github.com/beeware/toga/commit/fdd68033e4008b9d098151beef3cdf7326a9f1c4", "https://github.com/beeware/toga/commit/e38420a75c93160c10ceae8b3062701132a20e9d", "https://github.com/beeware/toga/commit/1f9d6479e1f21b5c81c4e80bcc20646e11e6c66d", "https://github.com/beeware/toga/commit/8730d7ffc80ffb655b28bc3e9f47bc76c8fc364e", "https://github.com/beeware/toga/commit/c6a2f23b00dcea9f531cc53d30a39b77f0fb383f", "https://github.com/beeware/toga/commit/d37c12666f269ff1c47d2661961ae7d348476a9e", "https://github.com/beeware/toga/commit/e2cbc620fbecbcf0fa36b8471f0c7ae11ff3f716", "https://github.com/beeware/toga/commit/9e6c3e3c05742eda6981dfb0f0e48cf032032005", "https://github.com/beeware/toga/commit/5dda0763f3e91f342633e354a25fd5d445ebb81e", "https://github.com/beeware/toga/commit/e4cb48fb3233c15d3ac3ab2e6499a9d268b873c2", "https://github.com/beeware/toga/commit/364194b353ca0a5cf59c0eaa14192d0602c1dd91", "https://github.com/beeware/toga/commit/4d61d61c0f320520acdb7941ccd7bedb8afc260d", "https://github.com/beeware/toga/commit/512f208ea03df4021aa9f789ca1f48e52e5d1087", "https://github.com/beeware/toga/commit/0396c727cf1cc6add1ed657fa3e762f206884352", "https://github.com/beeware/toga/commit/69638e23c593caaf1c0512cd75812be52de627b0", "https://github.com/beeware/toga/commit/65d766e8bfd832ee3f2fe01dfb046aeb22898584", "https://github.com/beeware/toga/commit/5c39a5ca3a1044755bd447697b9058da2a962cfe", "https://github.com/beeware/toga/commit/b8c51b88040a4c05ed55ad8974078db6af2ab8c1", "https://github.com/beeware/toga/commit/a386e779c738714617a11825f987d6879e0d62c2", "https://github.com/beeware/toga/commit/0c87003e31545f0ba99dcedafb4a5d9d3359ae72"], "created_at": "2026-01-19T18:28:00Z"}
{"repo": "beeware/toga", "pull_number": 4008, "instance_id": "beeware__toga-4008", "issue_numbers": [2207], "base_commit": "5149c6f6c8c646633eeb878f2758eb9d2cb9414f", "patch": "diff --git a/android/src/toga_android/widgets/canvas.py b/android/src/toga_android/widgets/canvas.py\nindex 0d659c6359..333cbf81f5 100644\n--- a/android/src/toga_android/widgets/canvas.py\n+++ b/android/src/toga_android/widgets/canvas.py\n@@ -165,7 +165,6 @@ def fill(self, color, fill_rule, path, canvas, **kwargs):\n             }.get(fill_rule, Path.FillType.WINDING)\n         )\n         canvas.drawPath(path, draw_paint)\n-        path.reset()\n \n     def stroke(self, color, line_width, line_dash, path, canvas, **kwargs):\n         draw_paint = Paint()\n@@ -179,7 +178,6 @@ def stroke(self, color, line_width, line_dash, path, canvas, **kwargs):\n             draw_paint.setPathEffect(DashPathEffect(line_dash, 0))\n \n         canvas.drawPath(path, draw_paint)\n-        path.reset()\n \n     # Transformations\n \ndiff --git a/changes/2207.bugfix.md b/changes/2207.bugfix.md\nnew file mode 100644\nindex 0000000000..792eb65e65\n--- /dev/null\n+++ b/changes/2207.bugfix.md\n@@ -0,0 +1,1 @@\n+Calling `stroke()` or `fill()` in a Canvas context no longer clears the current path.\ndiff --git a/cocoa/src/toga_cocoa/libs/core_graphics.py b/cocoa/src/toga_cocoa/libs/core_graphics.py\nindex ca75f37a11..ace469dcef 100644\n--- a/cocoa/src/toga_cocoa/libs/core_graphics.py\n+++ b/cocoa/src/toga_cocoa/libs/core_graphics.py\n@@ -171,6 +171,13 @@ class CGAffineTransform(Structure):\n core_graphics.CGContextTranslateCTM.restype = c_void_p\n core_graphics.CGContextTranslateCTM.argtypes = [CGContextRef, CGFloat, CGFloat]\n \n+CGPathRef = c_void_p\n+register_preferred_encoding(b\"^{__CGPath=}\", CGPathRef)\n+core_graphics.CGContextCopyPath.restype = CGPathRef\n+core_graphics.CGContextCopyPath.argtypes = [CGContextRef]\n+core_graphics.CGContextAddPath.restype = c_void_p\n+core_graphics.CGContextAddPath.argtypes = [CGContextRef, CGPathRef]\n+\n ######################################################################\n # CGEvent.h\n \ndiff --git a/cocoa/src/toga_cocoa/widgets/canvas.py b/cocoa/src/toga_cocoa/widgets/canvas.py\nindex 31d14c8270..ec3274cbfe 100644\n--- a/cocoa/src/toga_cocoa/widgets/canvas.py\n+++ b/cocoa/src/toga_cocoa/widgets/canvas.py\n@@ -211,7 +211,10 @@ def fill(self, color, fill_rule, draw_context, **kwargs):\n         core_graphics.CGContextSetRGBFillColor(\n             draw_context, color.r / 255, color.g / 255, color.b / 255, color.a\n         )\n-        core_graphics.CGContextDrawPath(draw_context, mode)\n+        if not core_graphics.CGContextIsPathEmpty(draw_context):\n+            path = core_graphics.CGContextCopyPath(draw_context)\n+            core_graphics.CGContextDrawPath(draw_context, mode)\n+            core_graphics.CGContextAddPath(draw_context, path)\n \n     def stroke(self, color, line_width, line_dash, draw_context, **kwargs):\n         core_graphics.CGContextSetLineWidth(draw_context, line_width)\n@@ -225,7 +228,10 @@ def stroke(self, color, line_width, line_dash, draw_context, **kwargs):\n             )\n         else:\n             core_graphics.CGContextSetLineDash(draw_context, 0, None, 0)\n-        core_graphics.CGContextDrawPath(draw_context, mode)\n+        if not core_graphics.CGContextIsPathEmpty(draw_context):\n+            path = core_graphics.CGContextCopyPath(draw_context)\n+            core_graphics.CGContextDrawPath(draw_context, mode)\n+            core_graphics.CGContextAddPath(draw_context, path)\n \n     # Transformations\n     def rotate(self, radians, draw_context, **kwargs):\ndiff --git a/gtk/src/toga_gtk/widgets/canvas.py b/gtk/src/toga_gtk/widgets/canvas.py\nindex 93bc97de20..3511989302 100644\n--- a/gtk/src/toga_gtk/widgets/canvas.py\n+++ b/gtk/src/toga_gtk/widgets/canvas.py\n@@ -278,14 +278,14 @@ def fill(self, color, fill_rule, cairo_context, **kwargs):\n         else:\n             cairo_context.set_fill_rule(cairo.FILL_RULE_WINDING)\n \n-        cairo_context.fill()\n+        cairo_context.fill_preserve()\n \n     def stroke(self, color, line_width, line_dash, cairo_context, **kwargs):\n         cairo_context.set_source_rgba(*native_color(color))\n         cairo_context.set_line_width(line_width)\n         if line_dash is not None:\n             cairo_context.set_dash(line_dash)\n-        cairo_context.stroke()\n+        cairo_context.stroke_preserve()\n \n     # Transformations\n \n@@ -306,10 +306,17 @@ def reset_transform(self, cairo_context, **kwargs):\n     def write_text(\n         self, text, x, y, font, baseline, line_height, cairo_context, **kwargs\n     ):\n+        # Writing text should not affect current path, so save current path\n+        current_path = cairo_context.copy_path()\n+        # New path for text\n+        cairo_context.new_path()\n+        self._text_path(text, x, y, font, baseline, line_height, cairo_context)\n         for op in [\"fill\", \"stroke\"]:\n             if color := kwargs.pop(f\"{op}_color\", None):\n-                self._text_path(text, x, y, font, baseline, line_height, cairo_context)\n                 getattr(self, op)(color, cairo_context=cairo_context, **kwargs)\n+        # Restore previous path\n+        cairo_context.new_path()\n+        cairo_context.append_path(current_path)\n \n     # No need to check whether Pango or PangoCairo are None, because if they were, the\n     # user would already have received an exception when trying to create a Font.\ndiff --git a/iOS/src/toga_iOS/libs/core_graphics.py b/iOS/src/toga_iOS/libs/core_graphics.py\nindex 356fcd2419..285730cb86 100644\n--- a/iOS/src/toga_iOS/libs/core_graphics.py\n+++ b/iOS/src/toga_iOS/libs/core_graphics.py\n@@ -171,6 +171,13 @@ class CGAffineTransform(Structure):\n core_graphics.CGContextTranslateCTM.restype = c_void_p\n core_graphics.CGContextTranslateCTM.argtypes = [CGContextRef, CGFloat, CGFloat]\n \n+CGPathRef = c_void_p\n+register_preferred_encoding(b\"^{__CGPath=}\", CGPathRef)\n+core_graphics.CGContextCopyPath.restype = CGPathRef\n+core_graphics.CGContextCopyPath.argtypes = [CGContextRef]\n+core_graphics.CGContextAddPath.restype = c_void_p\n+core_graphics.CGContextAddPath.argtypes = [CGContextRef, CGPathRef]\n+\n ######################################################################\n # CGEventTypes.h\n kCGImageAlphaNone = 0\ndiff --git a/iOS/src/toga_iOS/widgets/canvas.py b/iOS/src/toga_iOS/widgets/canvas.py\nindex 5b90c80279..a547eac0e3 100644\n--- a/iOS/src/toga_iOS/widgets/canvas.py\n+++ b/iOS/src/toga_iOS/widgets/canvas.py\n@@ -195,7 +195,10 @@ def fill(self, color, fill_rule, draw_context, **kwargs):\n         core_graphics.CGContextSetRGBFillColor(\n             draw_context, color.r / 255, color.g / 255, color.b / 255, color.a\n         )\n-        core_graphics.CGContextDrawPath(draw_context, mode)\n+        if not core_graphics.CGContextIsPathEmpty(draw_context):\n+            path = core_graphics.CGContextCopyPath(draw_context)\n+            core_graphics.CGContextDrawPath(draw_context, mode)\n+            core_graphics.CGContextAddPath(draw_context, path)\n \n     def stroke(self, color, line_width, line_dash, draw_context, **kwargs):\n         core_graphics.CGContextSetLineWidth(draw_context, line_width)\n@@ -209,7 +212,10 @@ def stroke(self, color, line_width, line_dash, draw_context, **kwargs):\n             )\n         else:\n             core_graphics.CGContextSetLineDash(draw_context, 0, None, 0)\n-        core_graphics.CGContextDrawPath(draw_context, mode)\n+        if not core_graphics.CGContextIsPathEmpty(draw_context):\n+            path = core_graphics.CGContextCopyPath(draw_context)\n+            core_graphics.CGContextDrawPath(draw_context, mode)\n+            core_graphics.CGContextAddPath(draw_context, path)\n \n     # Transformations\n     def rotate(self, radians, draw_context, **kwargs):\ndiff --git a/winforms/src/toga_winforms/widgets/canvas.py b/winforms/src/toga_winforms/widgets/canvas.py\nindex 1446abe40d..d373e4d40e 100644\n--- a/winforms/src/toga_winforms/widgets/canvas.py\n+++ b/winforms/src/toga_winforms/widgets/canvas.py\n@@ -280,7 +280,6 @@ def fill(self, color, fill_rule, draw_context, **kwargs):\n                 path.FillMode = FillMode.Winding\n             path.Transform(draw_context.matrix)\n             draw_context.graphics.FillPath(brush, path)\n-        draw_context.clear_paths()\n \n     def stroke(self, color, line_width, line_dash, draw_context, **kwargs):\n         pen = Pen(native_color(color), self.scale_in(line_width, rounding=None))\n@@ -290,7 +289,6 @@ def stroke(self, color, line_width, line_dash, draw_context, **kwargs):\n         for path in draw_context.paths:\n             path.Transform(draw_context.matrix)\n             draw_context.graphics.DrawPath(pen, path)\n-        draw_context.clear_paths()\n \n     # Transformations\n \n@@ -318,10 +316,16 @@ def _line_height(self, font, line_height):\n     def write_text(\n         self, text, x, y, font, baseline, line_height, draw_context, **kwargs\n     ):\n+        # Writing text should not affect current path, so save current paths\n+        current_paths = draw_context.paths\n+        # new path for text\n+        draw_context.clear_paths()\n+        self._text_path(text, x, y, font, baseline, line_height, draw_context)\n         for op in [\"fill\", \"stroke\"]:\n             if color := kwargs.pop(f\"{op}_color\", None):\n-                self._text_path(text, x, y, font, baseline, line_height, draw_context)\n                 getattr(self, op)(color, draw_context=draw_context, **kwargs)\n+        # restore previous current paths - this is a bit hacky\n+        draw_context.paths = current_paths\n \n     def _text_path(self, text, x, y, font, baseline, line_height, draw_context):\n         lines = text.splitlines()\n", "test_patch": "diff --git a/android/tests_backend/widgets/canvas.py b/android/tests_backend/widgets/canvas.py\nindex 55fc16f15d..c83854f6c9 100644\n--- a/android/tests_backend/widgets/canvas.py\n+++ b/android/tests_backend/widgets/canvas.py\n@@ -13,7 +13,7 @@ class CanvasProbe(SimpleProbe):\n     native_class = DrawHandlerView\n \n     def reference_variant(self, reference):\n-        if reference in {\"multiline_text\", \"write_text\"}:\n+        if reference in {\"multiline_text\", \"write_text\", \"write_text_and_path\"}:\n             return f\"{reference}-android\"\n         return reference\n \ndiff --git a/cocoa/tests_backend/widgets/canvas.py b/cocoa/tests_backend/widgets/canvas.py\nindex 900f313f0c..7845259bfa 100644\n--- a/cocoa/tests_backend/widgets/canvas.py\n+++ b/cocoa/tests_backend/widgets/canvas.py\n@@ -22,7 +22,7 @@ def background_color(self):\n             return TRANSPARENT\n \n     def reference_variant(self, reference):\n-        if reference in {\"multiline_text\", \"write_text\"}:\n+        if reference in {\"multiline_text\", \"write_text\", \"write_text_and_path\"}:\n             # System font and default size is platform dependent.\n             return f\"{reference}-macOS\"\n         return reference\ndiff --git a/gtk/tests_backend/widgets/canvas.py b/gtk/tests_backend/widgets/canvas.py\nindex 1a826f8dde..7d1cd8ae5f 100644\n--- a/gtk/tests_backend/widgets/canvas.py\n+++ b/gtk/tests_backend/widgets/canvas.py\n@@ -16,7 +16,7 @@ def reference_variant(self, reference):\n                 return f\"{reference}-gtk-wayland\"\n             else:\n                 return f\"{reference}-gtk-x11\"\n-        elif reference == \"write_text\":\n+        elif reference in {\"write_text\", \"write_text_and_path\"}:\n             return f\"{reference}-gtk\"\n         else:\n             return reference\ndiff --git a/iOS/tests_backend/widgets/canvas.py b/iOS/tests_backend/widgets/canvas.py\nindex 45de11f784..b6167fa974 100644\n--- a/iOS/tests_backend/widgets/canvas.py\n+++ b/iOS/tests_backend/widgets/canvas.py\n@@ -25,7 +25,7 @@ class CanvasProbe(SimpleProbe):\n \n     def reference_variant(self, reference):\n         # System fonts and sizes are platform specific\n-        if reference in {\"write_text\", \"multiline_text\"}:\n+        if reference in {\"multiline_text\", \"write_text\", \"write_text_and_path\"}:\n             return f\"{reference}-iOS\"\n         else:\n             return reference\ndiff --git a/testbed/src/testbed/resources/canvas/paths.png b/testbed/src/testbed/resources/canvas/paths.png\nindex 5c754fbb69..21b66f3fdf 100644\nBinary files a/testbed/src/testbed/resources/canvas/paths.png and b/testbed/src/testbed/resources/canvas/paths.png differ\ndiff --git a/testbed/src/testbed/resources/canvas/stroke_and_fill.png b/testbed/src/testbed/resources/canvas/stroke_and_fill.png\nnew file mode 100644\nindex 0000000000..923e3ac6cc\nBinary files /dev/null and b/testbed/src/testbed/resources/canvas/stroke_and_fill.png differ\ndiff --git a/testbed/src/testbed/resources/canvas/stroke_and_fill_context.png b/testbed/src/testbed/resources/canvas/stroke_and_fill_context.png\nnew file mode 100644\nindex 0000000000..eeb4f3f69e\nBinary files /dev/null and b/testbed/src/testbed/resources/canvas/stroke_and_fill_context.png differ\ndiff --git a/testbed/src/testbed/resources/canvas/write_text_and_path-android.png b/testbed/src/testbed/resources/canvas/write_text_and_path-android.png\nnew file mode 100644\nindex 0000000000..8e53dfe73a\nBinary files /dev/null and b/testbed/src/testbed/resources/canvas/write_text_and_path-android.png differ\ndiff --git a/testbed/src/testbed/resources/canvas/write_text_and_path-gtk.png b/testbed/src/testbed/resources/canvas/write_text_and_path-gtk.png\nnew file mode 100644\nindex 0000000000..e9c991d2c4\nBinary files /dev/null and b/testbed/src/testbed/resources/canvas/write_text_and_path-gtk.png differ\ndiff --git a/testbed/src/testbed/resources/canvas/write_text_and_path-iOS.png b/testbed/src/testbed/resources/canvas/write_text_and_path-iOS.png\nnew file mode 100644\nindex 0000000000..e1fb2a27e1\nBinary files /dev/null and b/testbed/src/testbed/resources/canvas/write_text_and_path-iOS.png differ\ndiff --git a/testbed/src/testbed/resources/canvas/write_text_and_path-macOS.png b/testbed/src/testbed/resources/canvas/write_text_and_path-macOS.png\nnew file mode 100644\nindex 0000000000..3cc52f3128\nBinary files /dev/null and b/testbed/src/testbed/resources/canvas/write_text_and_path-macOS.png differ\ndiff --git a/testbed/src/testbed/resources/canvas/write_text_and_path-winforms.png b/testbed/src/testbed/resources/canvas/write_text_and_path-winforms.png\nnew file mode 100644\nindex 0000000000..9d8a28b19b\nBinary files /dev/null and b/testbed/src/testbed/resources/canvas/write_text_and_path-winforms.png differ\ndiff --git a/testbed/tests/widgets/test_canvas.py b/testbed/tests/widgets/test_canvas.py\nindex 30a2146ff9..2999998a4d 100644\n--- a/testbed/tests/widgets/test_canvas.py\n+++ b/testbed/tests/widgets/test_canvas.py\n@@ -9,6 +9,7 @@\n import toga\n from toga import Font\n from toga.colors import (\n+    BLACK,\n     CORNFLOWERBLUE,\n     GOLDENROD,\n     REBECCAPURPLE,\n@@ -340,7 +341,17 @@ async def test_paths(canvas, probe):\n     canvas.context.move_to(160, 160)\n     canvas.context.stroke(RED)\n \n-    await probe.redraw(\"Pair of triangles should be drawn\")\n+    # A path is not cleared after being stroked or filled.\n+    canvas.context.move_to(20, 10)\n+    canvas.context.line_to(60, 10)\n+    canvas.context.stroke(color=CORNFLOWERBLUE, line_width=10)\n+    canvas.context.move_to(60, 10)\n+    canvas.context.line_to(100, 10)\n+    canvas.context.fill(color=REBECCAPURPLE)\n+    canvas.context.line_to(140, 10)\n+    canvas.context.stroke()\n+\n+    await probe.redraw(\"Pair of triangles and a black line should be drawn\")\n     assert_reference(probe, \"paths\", threshold=0.04)\n \n \n@@ -557,6 +568,33 @@ async def test_stroke(canvas, probe):\n     assert_reference(probe, \"stroke\", threshold=0.02)\n \n \n+async def test_stroke_and_fill(canvas, probe):\n+    \"A shape drawn with primitives can be stroked and filled.\"\n+    # Draw a closed path\n+    canvas.context.begin_path()\n+    canvas.context.move_to(x=20, y=20)\n+    canvas.context.line_to(x=100, y=20)\n+    canvas.context.line_to(x=180, y=180)\n+    canvas.context.line_to(x=100, y=180)\n+    canvas.context.close_path()\n+    canvas.context.stroke(color=REBECCAPURPLE)\n+    canvas.context.fill(color=CORNFLOWERBLUE)\n+\n+    # Draw an open path inside it\n+    canvas.context.begin_path()\n+    # At the start of a path, line_to is equivalent to move_to.\n+    canvas.context.line_to(x=50, y=40)\n+    canvas.context.line_to(x=90, y=40)\n+    canvas.context.line_to(x=150, y=160)\n+    canvas.context.line_to(x=110, y=160)\n+    canvas.context.fill(color=GOLDENROD, fill_rule=FillRule.EVENODD)\n+    canvas.context.stroke(color=REBECCAPURPLE)\n+\n+    await probe.redraw(\"Stroke should be drawn\")\n+    # TODO: Check threshold after #4011\n+    assert_reference(probe, \"stroke_and_fill\", threshold=0.02)\n+\n+\n async def test_closed_path_context(canvas, probe):\n     \"A closed path can be built with a context\"\n \n@@ -602,6 +640,23 @@ async def test_stroke_context(canvas, probe):\n     assert_reference(probe, \"stroke_context\", threshold=0.02)\n \n \n+async def test_stroke_and_fill_context(canvas, probe):\n+    \"A shape can be stroked and filled using contexts\"\n+\n+    # Draw a filled parallelogram\n+    with canvas.context.Fill(x=20, y=20, color=REBECCAPURPLE) as fill:\n+        with fill.Stroke(\n+            line_width=20, line_dash=[20, 10], color=CORNFLOWERBLUE\n+        ) as path:\n+            path.line_to(x=100, y=20)\n+            path.line_to(x=180, y=180)\n+            path.line_to(x=100, y=180)\n+\n+    await probe.redraw(\"Stroke and Fill should be drawn with context\")\n+    # TODO: Check threshold after #4011\n+    assert_reference(probe, \"stroke_and_fill_context\", threshold=0.02)\n+\n+\n async def test_transforms(canvas, probe):\n     \"Transforms can be applied\"\n \n@@ -785,3 +840,58 @@ def caption(baseline):\n     # RMSE, as they are 100% edges; and due to minor font rendering discrepancies\n     # and antialiasing introduced by image scaling, edges are the source of error.\n     assert_reference(probe, \"multiline_text\", threshold=0.09)\n+\n+\n+@pytest.mark.xfail(\n+    condition=os.environ.get(\"RUNNING_IN_CI\") != \"true\",\n+    reason=\"may fail outside of a GitHub runner environment\",\n+)\n+async def test_write_text_and_path(canvas, probe):\n+    \"Text doesn't affect the current path.\"\n+\n+    # Use fonts which look different from the system fonts on all platforms.\n+    Font.register(\"Droid Serif\", \"resources/fonts/DroidSerif-Regular.ttf\")\n+\n+    hello_text = \"Hello\"\n+    hello_font = Font(\"Droid Serif\", 24)\n+    hello_size = canvas.measure_text(hello_text, hello_font)\n+\n+    with canvas.Fill(BLACK) as fill:\n+        # start building a path\n+        fill.begin_path()\n+        fill.rect(\n+            100 - (hello_size[0] // 2),\n+            10,\n+            hello_size[0],\n+            hello_size[1],\n+        )\n+\n+        # Draw some text independent of the path\n+        # Uses fill color of black.\n+        fill.write_text(\n+            hello_text,\n+            100 - (hello_size[0] // 2),\n+            10,\n+            font=hello_font,\n+            baseline=Baseline.TOP,\n+        )\n+\n+        # continue building the path\n+        fill.move_to(\n+            100 - (hello_size[0] // 2),\n+            10,\n+        )\n+        fill.line_to(\n+            100 + (hello_size[0] // 2),\n+            10 + hello_size[1],\n+        )\n+\n+        # now stroke the path, but *not* the text\n+        fill.stroke(CORNFLOWERBLUE)\n+\n+        # start a new path so Fill context doesn't fill current path with black\n+        fill.begin_path()\n+\n+    await probe.redraw(\"Text and path should be drawn independently\")\n+    # TODO: Check threshold after #4011\n+    assert_reference(probe, \"write_text_and_path\", threshold=0.08)\ndiff --git a/winforms/tests_backend/widgets/canvas.py b/winforms/tests_backend/widgets/canvas.py\nindex c102b7d8f3..d1eae208a3 100644\n--- a/winforms/tests_backend/widgets/canvas.py\n+++ b/winforms/tests_backend/widgets/canvas.py\n@@ -10,7 +10,7 @@ class CanvasProbe(SimpleProbe):\n     native_class = Panel\n \n     def reference_variant(self, reference):\n-        if reference in {\"multiline_text\", \"write_text\"}:\n+        if reference in {\"multiline_text\", \"write_text\", \"write_text_and_path\"}:\n             return f\"{reference}-winforms\"\n         return reference\n \n", "problem_statement": "Canvas should not clear the current path when calling `fill` or `stroke`\n### Describe the bug\r\n\r\nToga clears the current path when calling `fill` or `stroke`. The HTML Canvas does not do this.\r\n\r\n<table>\r\n<tr>\r\n<td>\r\n\r\n```js\r\nctx.lineWidth = 2\r\nctx.moveTo(20, 20)\r\nctx.lineTo(60, 20)\r\nctx.stroke()\r\n                               \r\nctx.moveTo(60, 20)\r\nctx.lineTo(100, 20)\r\nctx.strokeStyle = \"red\"\r\nctx.stroke()\r\n\r\nctx.lineTo(140, 20)\r\nctx.strokeStyle = \"cyan\"\r\nctx.stroke()\r\n```\r\n</td>\r\n<td>\r\n\r\n```py\r\n    ctx.move_to(20, 20)\r\n    ctx.line_to(60, 20)\r\n    ctx.stroke()\r\n                               \r\n    ctx.move_to(60, 20)\r\n    ctx.line_to(100, 20)\r\n    ctx.stroke(color=\"red\")\r\n\r\n    ctx.line_to(140, 20)\r\n    ctx.stroke(color=\"cyan\")\r\n```\r\n</td>\r\n</tr>\r\n</table>\r\n\r\nHTML (https://jsfiddle.net/mhsmith/jdnfqpL9/9/):\r\n<img width=\"225\" alt=\"Screenshot 2023-11-08 at 12 59 44\" src=\"https://github.com/beeware/toga/assets/166954/50dce8a5-2625-4acd-8850-8a42766c0e99\">\r\n\r\nToga (all backends):\r\n<img width=\"225\" alt=\"Screenshot 2023-11-08 at 13 07 51\" src=\"https://github.com/beeware/toga/assets/166954/ab40da52-b5d5-42f5-a338-a5eacdce8f1d\">\r\n\r\nAs well as the color difference, notice that the last segment of the path is not drawn at all, because its starting point has been lost.\r\n\r\n### Environment\r\n\r\n- Software versions:\r\n  - Toga: main (536a60f)\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/11dd336b0e014e26bb91901c435fb2d9d2aea077", "https://github.com/beeware/toga/commit/d9d855074e242e0ec3a1b0f31c586c6750fe6482", "https://github.com/beeware/toga/commit/d676171f190f7cb6199247fad6a03b3183178659", "https://github.com/beeware/toga/commit/877c51c615c03fa4e649762f153dce9fb3b2b0ac", "https://github.com/beeware/toga/commit/cb763891144f1a518c85964bafff38e48b2aa479", "https://github.com/beeware/toga/commit/fee5d8973949a6a2dbc30f29c3a6e0cc954f05a2", "https://github.com/beeware/toga/commit/4f65daf410e656973858d394acb693f1be51faff", "https://github.com/beeware/toga/commit/aa42e86a12ed53d9cc3f284e8123dc21a3f23d00", "https://github.com/beeware/toga/commit/842fae4c401043c2d48882544ec77b32a168c7e4", "https://github.com/beeware/toga/commit/a62808a96e24eae548ab038a9bb71f7dbb669bd8", "https://github.com/beeware/toga/commit/1790143b87353a452e9be30c31925af1c47564b3", "https://github.com/beeware/toga/commit/68c8ee43aa041636490a2c6b75e048466aa6669c", "https://github.com/beeware/toga/commit/800e50ae4cc41dac1f0c20fa6bfd6b4a7fed4d48", "https://github.com/beeware/toga/commit/33a4add65531073ad69d922f16f5fe386f28fc02", "https://github.com/beeware/toga/commit/fbe24763cb08e889c88611b78496eeaa88e91c58", "https://github.com/beeware/toga/commit/2b587aa7e69b1d6a6bd1b9bda11a96d02aeaae63", "https://github.com/beeware/toga/commit/d37874cfc6e7aa3b2206eda4751e0d835636f65f", "https://github.com/beeware/toga/commit/7088ca8d090ef78589ed01f8f769874a07bef500", "https://github.com/beeware/toga/commit/271d71c0a4a98fdde7fc79c7535a6410d7cfd0c9", "https://github.com/beeware/toga/commit/0f048fb8880b471fba1bb77f688b14df594986a4"], "created_at": "2025-12-22T16:46:42Z"}
{"repo": "beeware/toga", "pull_number": 4010, "instance_id": "beeware__toga-4010", "issue_numbers": [2288], "base_commit": "5149c6f6c8c646633eeb878f2758eb9d2cb9414f", "patch": "diff --git a/changes/2288.bugfix.md b/changes/2288.bugfix.md\nnew file mode 100644\nindex 0000000000..305f02803b\n--- /dev/null\n+++ b/changes/2288.bugfix.md\n@@ -0,0 +1,1 @@\n+SplitContainers in a non-primary tab of OptionContainer will now correctly apply its split on Cocoa.\ndiff --git a/changes/4010.bugfix.1.md b/changes/4010.bugfix.1.md\nnew file mode 100644\nindex 0000000000..bcffb49118\n--- /dev/null\n+++ b/changes/4010.bugfix.1.md\n@@ -0,0 +1,1 @@\n+Cocoa and GTK OptionContainers now rehints properly to accommodate for all of its content sizes at all times, in addition to the decorations around them.\ndiff --git a/changes/4010.bugfix.2.md b/changes/4010.bugfix.2.md\nnew file mode 100644\nindex 0000000000..88fdd127b5\n--- /dev/null\n+++ b/changes/4010.bugfix.2.md\n@@ -0,0 +1,1 @@\n+OptionContainers and ScrollContainers inside OptionContainers will no longer error on layout on Cocoa.\ndiff --git a/cocoa/src/toga_cocoa/widgets/optioncontainer.py b/cocoa/src/toga_cocoa/widgets/optioncontainer.py\nindex aaaa69189a..ded0c931bf 100644\n--- a/cocoa/src/toga_cocoa/widgets/optioncontainer.py\n+++ b/cocoa/src/toga_cocoa/widgets/optioncontainer.py\n@@ -1,3 +1,4 @@\n+import asyncio\n import warnings\n \n from rubicon.objc import objc_method\n@@ -60,13 +61,28 @@ def set_bounds(self, x, y, width, height):\n         # Setting the bounds changes the constraints, but that doesn't mean\n         # the constraints have been fully applied. Force realization of the\n         # new layout, and then refresh the content.\n-        self.interface.window._impl.native.layoutIfNeeded()\n+        self.native.layoutSubtreeIfNeeded()\n         self.native.refreshContent()\n \n     def content_refreshed(self, container):\n         container.min_width = container.content.interface.layout.min_width\n         container.min_height = container.content.interface.layout.min_height\n \n+        # Re-layout and schedule a second refresh if intrinsic size has changed,\n+        # since if the subcontainers' minimum size changes, the widget itself's\n+        # minimum size may change as well.\n+        prev_intrinsic_size = (\n+            self.interface.intrinsic.width,\n+            self.interface.intrinsic.height,\n+        )\n+        self.rehint()\n+        intrinsic_size = (\n+            self.interface.intrinsic.width,\n+            self.interface.intrinsic.height,\n+        )\n+        if prev_intrinsic_size != intrinsic_size:\n+            asyncio.get_running_loop().call_soon_threadsafe(self.interface.refresh)\n+\n     def add_option(self, index, text, widget, icon):\n         # Create the container for the widget\n         container = Container(on_refresh=self.content_refreshed)\n@@ -140,13 +156,35 @@ def set_current_tab_index(self, current_tab_index):\n         self.native.selectTabViewItemAtIndex(current_tab_index)\n \n     def rehint(self):\n-        # The optionContainer must be at least the size of it's largest content,\n-        # with a hard minimum to prevent absurdly small optioncontainers.\n-        min_width = self.interface._MIN_WIDTH\n-        min_height = self.interface._MIN_HEIGHT\n+        # The optionContainer must be at least the size of it's largest content\n+        # plus the decors around the OptionContainer.\n+        min_width = 0\n+        min_height = 0\n         for sub_container in self.sub_containers:\n             min_width = max(min_width, sub_container.min_width)\n             min_height = max(min_height, sub_container.min_height)\n \n-        self.interface.intrinsic.width = at_least(min_width)\n-        self.interface.intrinsic.height = at_least(min_height)\n+        # The below logic to get the width and height of the tab bar and decorations\n+        # uses the sizes of the widget itself, which might seem conunterintuitive as\n+        # rehinting is done before the widget is laid out.  However, the calculations\n+        # here will not change regardless of layout if the widget has a non-zero\n+        # frame, and rehint is always called at a certain point when the widget has\n+        # a non-zero frame in Toga's sequence.\n+        self.native.layoutSubtreeIfNeeded()\n+        decor_width = (\n+            self.native.alignmentRectForFrame(self.native.frame).size.width\n+            - self.native.contentRect.size.width\n+        )\n+        decor_height = (\n+            self.native.alignmentRectForFrame(self.native.frame).size.height\n+            - self.native.contentRect.size.height\n+        )\n+\n+        # Be on the defensive side and prevent absurdly small OptionContainers by maxing\n+        # in an artificially imposed minimum size.\n+        self.interface.intrinsic.width = at_least(\n+            max(min_width + decor_width, self.interface._MIN_WIDTH)\n+        )\n+        self.interface.intrinsic.height = at_least(\n+            max(min_height + decor_height, self.interface._MIN_HEIGHT)\n+        )\ndiff --git a/cocoa/src/toga_cocoa/widgets/scrollcontainer.py b/cocoa/src/toga_cocoa/widgets/scrollcontainer.py\nindex 7fab4a80bb..51c7c716e9 100644\n--- a/cocoa/src/toga_cocoa/widgets/scrollcontainer.py\n+++ b/cocoa/src/toga_cocoa/widgets/scrollcontainer.py\n@@ -77,7 +77,7 @@ def set_bounds(self, x, y, width, height):\n         # Setting the bounds changes the constraints, but that doesn't mean\n         # the constraints have been fully applied. Force realization of the\n         # new layout, and then refresh the content.\n-        self.interface.window._impl.native.layoutIfNeeded()\n+        self.native.layoutSubtreeIfNeeded()\n         self.native.refreshContent()\n \n     def content_refreshed(self, container):\ndiff --git a/cocoa/src/toga_cocoa/widgets/splitcontainer.py b/cocoa/src/toga_cocoa/widgets/splitcontainer.py\nindex 8ce5296d3f..38b6167911 100644\n--- a/cocoa/src/toga_cocoa/widgets/splitcontainer.py\n+++ b/cocoa/src/toga_cocoa/widgets/splitcontainer.py\n@@ -28,7 +28,17 @@ def splitViewDidResizeSubviews_(self, notification) -> None:\n \n     @objc_method\n     def applySplit(self) -> None:\n-        if self.impl._split_proportion:\n+        # Special-case the case where the frame is 0.  This could happen\n+        # during layouts such as a SplitContainer in a secondary tab in\n+        # an OptionContainer.\n+        # All other dummy / incorrect but non-zero layouts does not matter,\n+        # since Cocoa preserves the split proportion when changing bounds.\n+        # However, you can't preserve 0/0 as a proportion.\n+        if (\n+            self.impl._split_proportion\n+            and self.frame.size.width\n+            and self.frame.size.height\n+        ):\n             if self.interface.direction == self.interface.VERTICAL:\n                 position = self.impl._split_proportion * self.frame.size.width\n             else:\ndiff --git a/gtk/src/toga_gtk/container.py b/gtk/src/toga_gtk/container.py\nindex 08c91b20f3..900330c354 100644\n--- a/gtk/src/toga_gtk/container.py\n+++ b/gtk/src/toga_gtk/container.py\n@@ -126,6 +126,8 @@ def __init__(self):\n             self.min_width = 100\n             self.min_height = 100\n \n+            self.on_recompute = None\n+\n             self.dpi = 96\n             self.baseline_dpi = self.dpi\n \n@@ -218,6 +220,9 @@ def recompute(self):\n                 self.min_width = self._content.interface.layout.min_width\n                 self.min_height = self._content.interface.layout.min_height\n \n+            if self.on_recompute:\n+                self.on_recompute(self)\n+\n else:  # pragma: no-cover-if-gtk4\n \n     class TogaContainer(Gtk.Fixed):\n@@ -232,6 +237,8 @@ def __init__(self):\n             self.min_width = 100\n             self.min_height = 100\n \n+            self.on_recompute = None\n+\n             self.dpi = 96\n             self.baseline_dpi = self.dpi\n \n@@ -321,6 +328,9 