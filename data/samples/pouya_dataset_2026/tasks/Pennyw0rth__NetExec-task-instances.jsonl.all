                                                                     \u2502                  \n                    \u2502 /home/pb/.local/share/pipx/venvs/netexec/lib/python3.13/site-packages/nxc/protocols/smb.py:644 in gen_relay_list                                                                                                                                                           \u2502                  \n                    \u2502                                                                                                                                                                                                                                                                            \u2502                  \n                    \u2502    641 \u2502                                                                                                                                                                                                                                                                   \u2502                  \n                    \u2502    642 \u2502   def gen_relay_list(self):                                                                                                                                                                                                                                       \u2502                  \n                    \u2502    643 \u2502   \u2502   if self.server_os.lower().find(\"windows\") != -1 and self.signing is False:                                                                                                                                                                                  \u2502                  \n                    \u2502 \u2771  644 \u2502   \u2502   \u2502   with sem, open(self.args.gen_relay_list, \"a+\") as relay_list:                                                                                                                                                                                           \u2502                  \n                    \u2502    645 \u2502   \u2502   \u2502   \u2502   if self.host not in relay_list.read():                                                                                                                                                                                                              \u2502                  \n                    \u2502    646 \u2502   \u2502   \u2502   \u2502   \u2502   relay_list.write(self.host + \"\\n\")                                                                                                                                                                                                              \u2502                  \n                    \u2502    647                                                                                                                                                                                                                                                                     \u2502                  \n                    \u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f                  \n                    FileNotFoundError: [Errno 2] No such file or directory: 'nonexistent/a.txt' \n```\n\nMore commands that trigger the issue:\n```\nnxc ldap 192.168.56.12 -u 'khal.drogo' -p 'horse' --users-export nonexistent/users.txt\nnxc ldap 192.168.56.12 -u 'khal.drogo' -p 'horse' --asreproast nonexistent/a.txt\nnxc smb 192.168.56.23 --generate-hosts-file nonexistent/a.txt\nnxc smb 192.168.56.10 --generate-krb5-file nonexistent/a.txt\n```\n\nInterestingly kerberoast doesn't create a stacktrace:\n```\nnxc ldap 192.168.56.12 -u 'khal.drogo' -p 'horse' --kerberoasting nonexistent/a.txt\n\nLDAP        192.168.56.12   389    MEEREEN          [*] Windows 10 / Server 2016 Build 14393 (name:MEEREEN) (domain:essos.local) (signing:None) (channel binding:Never) \nLDAP        192.168.56.12   389    MEEREEN          [+] essos.local\\khal.drogo:horse \nLDAP        192.168.56.12   389    MEEREEN          [*] Skipping disabled account: krbtgt\nLDAP        192.168.56.12   389    MEEREEN          [*] Total of records returned 2\nLDAP        192.168.56.12   389    MEEREEN          [*] sAMAccountName: gmsaDragon$, memberOf: [], pwdLastSet: 2025-02-11 11:31:16.437250, lastLogon: <never>\nLDAP        192.168.56.12   389    MEEREEN          $krb5tgs$23$*gmsaDragon$$ESSOS.LOCAL$essos.local\\gmsaDragon$*$f1a6a4f2d6918dc84f61f9043a0ac593$\nLDAP        192.168.56.12   389    MEEREEN          [-] Principal: essos.local\\gmsaDragon$ - [Errno 2] No such file or directory: 'nonexistent/a.txt'\nLDAP        192.168.56.12   389    MEEREEN          [*] sAMAccountName: sql_svc, memberOf: [], pwdLastSet: 2025-02-11 11:29:39.955516, lastLogon: 2025-08-21 09:52:32.306681\nLDAP        192.168.56.12   389    MEEREEN          $krb5tgs$23$*sql_svc$ESSOS.LOCAL$essos.local\\sql_svc*$0e89537303c6b01627ac26b3841d2de7$\nLDAP        192.168.56.12   389    MEEREEN          [-] Principal: essos.local\\sql_svc - [Errno 2] No such file or directory: 'nonexistent/a.txt'\n```\n\n**Expected behavior**\nShow error without stacktrace and exit the program.\n\n**NetExec info**\n - OS: Kali\n - Version of nxc: 1.4.0 - SmoothOperator - 8af4bfa6 - 816\n - Installed from: pipx\n\nnopac module with null session results in \"KerberosException\" stacktrace\n**Describe the bug**\nnopac module with null session results in \"KerberosException\" stacktrace. It works as expected when a user is specified.\n\n**To Reproduce**\nCommand to trigger the exception:\n```\nnxc smb meereen.essos.local -u '' -p '' -M nopac --debug\n[09:52:27] DEBUG    NXC VERSION: 1.4.0 - SmoothOperator - 8af4bfa6 - 816                                                                                                                                                                                                                               netexec.py:82\n           DEBUG    PYTHON VERSION: 3.13.3 (main, Apr 10 2025, 21:38:51) [GCC 14.2.0]                                                                                                                                                                                                                  netexec.py:83\n           DEBUG    RUNNING ON: Linux Release: 6.12.25-amd64                                                                                             