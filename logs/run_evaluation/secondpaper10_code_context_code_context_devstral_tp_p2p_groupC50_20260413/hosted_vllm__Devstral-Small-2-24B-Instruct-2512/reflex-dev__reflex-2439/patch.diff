     def _get_vars(self) -> list[Var]:
+        """Walk all Vars used in this component.
+
+        Returns:
+            Each var referenced by the component (condition, match cases, default).
+        """
+        vars = getattr(self, "__vars", None)
+        if vars is not None:
+            return vars
+
+        vars = self.__vars = []
+
+        # Add the condition variable
+        if isinstance(self.cond, Var):
+            vars.append(self.cond)
+
