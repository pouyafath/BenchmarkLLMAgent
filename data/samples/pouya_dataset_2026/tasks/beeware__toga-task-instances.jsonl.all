ow animation before assertion.\n         await second_window_probe.wait_for_window(\"Secondary window is visible\")\n         assert second_window_probe.instantaneous_state == WindowState.NORMAL\n \n+        closure_exception = None\n+\n+        def check_initial_state_size(window):\n+            if second_window_probe.instantaneous_state == initial_state:\n+                assert second_window.size > previous_state_window_size\n+\n+        def check_final_state_size(window):\n+            if second_window_probe.instantaneous_state == final_state:\n+                current_size = second_window.size\n+                nonlocal closure_exception\n+                try:\n+                    if initial_state == WindowState.NORMAL:\n+                        assert current_size > previous_state_window_size\n+                    elif initial_state == WindowState.MAXIMIZED:\n+                        if final_state in {\n+                            WindowState.FULLSCREEN,\n+                            WindowState.PRESENTATION,\n+                        }:\n+                            if (  # noqa: E501\n+                                second_window_probe.maximize_fullscreen_presentation_equal_size\n+                            ):\n+                                assert current_size == previous_state_window_size\n+                            else:\n+                                assert current_size > previous_state_window_size\n+                        else:\n+                            assert current_size < previous_state_window_size\n+                    elif initial_state == WindowState.FULLSCREEN:\n+                        if final_state == WindowState.PRESENTATION:\n+                            if second_window_probe.fullscreen_presentation_equal_size:\n+                                assert current_size == previous_state_window_size\n+                            else:\n+                                assert current_size > previous_state_window_size\n+                        elif final_state == WindowState.MAXIMIZED:\n+                            if (  # noqa: E501\n+                                second_window_probe.maximize_fullscreen_presentation_equal_size\n+                            ):\n+                                assert current_size == previous_state_window_size\n+                            else:\n+                                assert current_size < previous_state_window_size\n+                        else:\n+                            assert current_size < previous_state_window_size\n+                    elif initial_state == WindowState.PRESENTATION:\n+                        if final_state == WindowState.FULLSCREEN:\n+                            if second_window_probe.fullscreen_presentation_equal_size:\n+                                assert current_size == previous_state_window_size\n+                            else:\n+                                assert current_size < previous_state_window_size\n+                        elif final_state == WindowState.MAXIMIZED:\n+                            if (  # noqa: E501\n+                                second_window_probe.maximize_fullscreen_presentation_equal_size\n+                            ):\n+                                assert current_size == previous_state_window_size\n+                            else:\n+                                assert current_size < previous_state_window_size\n+                        else:\n+                            assert current_size < previous_state_window_size\n+                except Exception as e:\n+                    closure_exception = e\n+\n+        # Set up event mocks after the test window has been initialized.\n+        # This prevents unnecessary mock triggers during setup, which could\n+        # lead to false assertion errors later by incorrectly indicating that\n+        # the event was triggered.\n+        second_window.on_show = Mock()\n+        second_window.on_hide = Mock()\n+        second_window_on_resize_handler = Mock()\n+        second_window.on_resize = second_window_on_resize_handler\n+\n+        previous_state_window_size = second_window.size\n+        second_window_on_resize_handler.side_effect = check_initial_state_size\n+\n         # Set to initial state\n         second_window.state = initial_state\n         # Wait for window animation before assertion.\n@@ -800,6 +869,23 @@ async def test_window_state_change(\n         )\n         assert second_window_probe.instantaneous_state == initial_state\n \n+        # Check and raise exceptions that may have occurred inside closures.\n+        if closure_exception:\n+            raise closure_exception\n+\n+        # Check for resize event notification\n+        if initial_state in {WindowState.NORMAL, WindowState.MINIMIZED}:\n+            # on_resize() will not be triggered, as the state change\n+            # between NORMAL <-> MINIMIZED doesn't resize the window,\n+            # and state change between NORMAL <-> NORMAL is a no-op.\n+            second_window_on_resize_handler.assert_not_called()\n+            second_window_on_resize_handler.reset_mock()\n+            # Window size should remain the same\n+            assert second_window.size == previous_state_window_size\n+        else:\n+            second_window_on_resize_handler.assert_called_with(second_window)\n+            second_window_on_resize_handler.reset_mock()\n+\n         # Check for visibility event notification\n         if initial_state == WindowState.MINIMIZED:\n             # on_hide() will be triggered, as it was set to a\n@@ -811,13 +897,40 @@ async def test_window_state_change(\n             # was set to a visible-to-user(not minimized) state.\n             assert_window_on_show(second_window, trigger_expected=False)\n \n+        previous_state_window_size = second_window.size\n+        second_window_on_resize_handler.side_effect = check_final_state_size\n+\n         # Set to final state\n         second_window.state = final_state\n         # Wait for window animation before assertion.\n         await second_window_probe.wait_for_window(\n             f\"Secondary window is in {final_state}\", state=final_state\n         )\n-        assert second_window_probe.instantaneous_state == final_state\n+\n+        # Check and raise exceptions that may have occurred inside closures.\n+        if closure_exception:\n+            raise closure_exception\n+\n+        # Check for resize event notification\n+        # State change between NORMAL <-> MINIMIZED doesn't\n+        # constitute a window resize operation.\n+        resize_expected = (initial_state != final_state) and not (\n+            {initial_state, final_state} == {WindowState.NORMAL, WindowState.MINIMIZED}\n+        )\n+        if resize_expected:\n+            # on_resize() event may be triggered multiple times, depending\n+            # upon the backend. For example: for a state change between:\n+            # FULLSCREEN -> MAXIMIZED, the actual window transition would\n+            # be: FULLSCREEN -> NORMAL -> MAXIMIZED. Therefore, on_resize()\n+            # would be triggered multiple times. Hence, just assert that the\n+            # on_resize() event has been called.\n+            second_window_on_resize_handler.assert_called_with(second_window)\n+            second_window_on_resize_handler.reset_mock()\n+        else:\n+            second_window_on_resize_handler.assert_not_called()\n+            second_window_on_resize_handler.reset_mock()\n+            # Window size should remain the same\n+            assert second_window.size == previous_state_window_size\n \n         # Check for visibility event notification\n         if initial_state == WindowState.MINIMIZED:\n@@ -1107,6 +1220,54 @@ async def test_visibility_events(second_window, second_window_probe):\n         await second_window_probe.wait_for_window(f\"Showing {second_window.title}\")\n         assert_window_on_show(second_window)\n \n+    @pytest.mark.parametrize(\n+        \"second_window_class, second_window_kwargs\",\n+        [\n+            (\n+                toga.Window,\n+                {\"title\": \"Secondary Window\", \"position\": (200, 150)},\n+            )\n+        ],\n+    )\n+    async def test_resize_event(second_window, second_window_probe):\n+        \"\"\"The window can trigger on_resize() event handler, when the window\n+        size is changed.\"\"\"\n+        second_window.content = toga.Box(style=Pack(background_color=CORNFLOWERBLUE))\n+        second_window.show()\n+        expected_window_size = None\n+\n+        def check_new_size_on_resize(window):\n+            assert window.size == expected_window_size\n+\n+        second_window_on_resize_handler = Mock()\n+        second_window_on_resize_handler.side_effect = check_new_size_on_resize\n+        # Register the event handler.\n+        second_window.on_resize = second_window_on_resize_handler\n+        await second_window_probe.wait_for_window(\"Second window has been shown\")\n+        initial_size = second_window.size\n+\n+        # Resize the window, on_resize() will be triggered with the new size.\n+        expected_window_size = (200, 150)\n+        second_window.size = (200, 150)\n+        await second_window_probe.wait_for_window(\"Second window has been resized\")\n+        assert second_window.size == (200, 150)\n+        second_window_on_resize_handler.assert_called_with(second_window)\n+        second_window_on_resize_handler.reset_mock()\n+\n+        # Resize to initial size, on_resize() will be triggered with the new size.\n+        expected_window_size = initial_size\n+        second_window.size = initial_size\n+        await second_window_probe.wait_for_window(\"Second window has been resized\")\n+        assert second_window.size == initial_size\n+        second_window_on_resize_handler.assert_called_with(second_window)\n+        second_window_on_resize_handler.reset_mock()\n+\n+        # Again resize to initial size, on_resize() will not be triggered\n+        second_window.size = initial_size\n+        await second_window_probe.wait_for_window(\"Second window has been resized\")\n+        assert second_window.size == initial_size\n+        second_window_on_resize_handler.assert_not_called()\n+\n     @pytest.mark.parametrize(\n         \"second_window_class, second_window_kwargs\",\n         [\ndiff --git a/winforms/tests_backend/window.py b/winforms/tests_backend/window.py\nindex 8acc618e89..013cb78a6a 100644\n--- a/winforms/tests_backend/window.py\n+++ b/winforms/tests_backend/window.py\n@@ -29,6 +29,8 @@ class WindowProbe(BaseProbe, DialogsMixin):\n     supports_placement = True\n     supports_as_image = True\n     supports_focus = True\n+    fullscreen_presentation_equal_size = True\n+    maximize_fullscreen_presentation_equal_size = False\n \n     def __init__(self, app, window):\n         self.app = app\n", "problem_statement": "Add \"on_resize\" to MainWindow\n### What is the problem or limitation you are having?\r\n\r\nI currently don't know when the window is getting resized, so I can't make adaptive decisions about how the content is being displayed unless I keep a background task continually \"manually\" checking. Example:\r\n\r\n```\r\nasync def update_background_image(self, app, **kwargs):\r\n\twhile True:\r\n\t\tif self.main_window.size[0] != self.background_image.width:\r\n\t\t\tnew_image_size = (self.main_window.size[0], self.background_image.height)\r\n\t\t\tscaled_image = self.background_image.resize(new_image_size)\r\n\t\t\tself.background_image_view.image = scaled_image\r\n\r\n\t\tawait asyncio.sleep(1)\r\n```\r\n\r\n### Describe the solution you'd like\r\n\r\nAn `on_change` method in MainWindow.\r\n\r\nThis way, I can specify a function to be called only when the window has changed.\r\n\r\n### Describe alternatives you've considered\r\n\r\n1. Keep doing it manually;\r\n2. For the exemplified use case, it would be better if I was able to tell the image to adopt the window's width (or its box's width), so I wouldn't have to do any resizing.\r\n\r\n### Additional context\r\n\r\n_No response_\n", "hints_text": "This wouldn't be an `on_change` signal - it would be an `on_resize` signal. A change signal would describe the fact that the *content* of the widget had changed.\r\n\r\nHowever, I should caution that if you're using Toga as intended, an `on_resize` signal should *generally* not be needed. if you're hard-coding sizes, or responding specifically to window size changes, you're missing the point of Toga's style-based layout language. In the specific case you've described, the issue is that there's no style directive to resize the image to fill the box. *That* is the real underlying issue here.\r\n\r\nThat said - it wouldn't be too difficult to add an `on_resize` handler, as the signal is already being generated to manage window size changes. All we would be doing is adding a user callback once that size change had been applied. Since the implementation should be relatively straightforward, and could be useful for situations like mobile phones changing rotation (which *may* require a layout change), I guess adding an on_resize handler would make sense.\r\n\n\n", "all_hints_text": "This wouldn't be an `on_change` signal - it would be an `on_resize` signal. A change signal would describe the fact that the *content* of the widget had changed.\r\n\r\nHowever, I should caution that if you're using Toga as intended, an `on_resize` signal should *generally* not be needed. if you're hard-coding sizes, or responding specifically to window size changes, you're missing the point of Toga's style-based layout language. In the specific case you've described, the issue is that there's no style directive to resize the image to fill the box. *That* is the real underlying issue here.\r\n\r\nThat said - it wouldn't be too difficult to add an `on_resize` handler, as the signal is already being generated to manage window size changes. All we would be doing is adding a user callback once that size change had been applied. Since the implementation should be relatively straightforward, and could be useful for situations like mobile phones changing rotation (which *may* require a layout change), I guess adding an on_resize handler would make sense.\r\n\n~~I will implement this feature in #2096 as they are related, but after the completion of window states API #1884.~~\r\n\r\nDone in #2364 \n\n", "commit_urls": ["https://github.com/beeware/toga/commit/bbceb8c2426dd7d6a7d37592270baf5dd5aa40c6", "https://github.com/beeware/toga/commit/9429020e55b818e7d0d820d444445bcf6ffb68be", "https://github.com/beeware/toga/commit/cd8abe045e57f7c4fe1d59a0dc7d4658850f9044", "https://github.com/beeware/toga/commit/b80483be20a3e0615dae6827e6e25c3fe7acb4a4", "https://github.com/beeware/toga/commit/55a8f4b7eb895cb2bc82a678de4192448b5c868c", "https://github.com/beeware/toga/commit/935314851969c664d411f1834059f03ee4322a62", "https://github.com/beeware/toga/commit/5429987cf8085cba4533d592605c04692b2967ed", "https://github.com/beeware/toga/commit/8d131cd9916a174b589959cf5df4fdbce76748d9", "https://github.com/beeware/toga/commit/96ddd647dcb57bb10ad907cf0de6cfa4c4d733fe", "https://github.com/beeware/toga/commit/3291ae1d30644ef8489bd3da5c2b2d559f7d067b", "https://github.com/beeware/toga/commit/0b24cc804c8f3c349e137b6957f49426c07a05cc", "https://github.com/beeware/toga/commit/702c1db661fc71c08d54e1d454037d43d51924bc", "https://github.com/beeware/toga/commit/b494da225c7f995d8db776fc88a2551bffce33af", "https://github.com/beeware/toga/commit/8edded791e43030a3e57cf5427437d5d4c35aea3", "https://github.com/beeware/toga/commit/bf8b9ed93fb3568e12f71fe8beb2dc518cd6c025", "https://github.com/beeware/toga/commit/857ff3e2d0c2f5c7782d4aa9b33f7ce6c75ca82f", "https://github.com/beeware/toga/commit/3d8d9522c46a09edf8352417e1102ba37f94cbaf", "https://github.com/beeware/toga/commit/38999e3fabe52492c460d691144ffa27ea7df090", "https://github.com/beeware/toga/commit/c2d5ab5bdc0048860552e785310cf303abab7a9f", "https://github.com/beeware/toga/commit/e10f7292efdf40e8a166bfaf0c6976f5c6d1d3aa", "https://github.com/beeware/toga/commit/a1c9b53405ee97e95c73cb06a20a49bebd5d6064", "https://github.com/beeware/toga/commit/522798a555b26e3f9f830cafa638cb44784551ad", "https://github.com/beeware/toga/commit/a5d7e12dc93085d0797ba993d0c63d125bb0dbaf", "https://github.com/beeware/toga/commit/877b7362a1126a23a1b3c9cfcf22f0bb007f0032", "https://github.com/beeware/toga/commit/b8672e25e9a7f352f2750494e19cef4d2ac35d61", "https://github.com/beeware/toga/commit/0091aed11d42510925259241dd0aa0f73e7114ee", "https://github.com/beeware/toga/commit/c17b1ec27f711639aed1cd2c42b2941481ff49da", "https://github.com/beeware/toga/commit/81be13af2620bc47c0493504833801c9d8778e03", "https://github.com/beeware/toga/commit/38bf5707940ea0da39bc4cfbf7656b18ecf0cc0f", "https://github.com/beeware/toga/commit/7e9867589a61198ec32a91ecf001b6dbd19cb12a", "https://github.com/beeware/toga/commit/fc59fe4a02c6fa6c908adf51bbcf813e78b6bfd5", "https://github.com/beeware/toga/commit/33a21e85491bfc502921fed55e5c0d3b55bad61b", "https://github.com/beeware/toga/commit/a7794639fde29b8b31ed41da9f37b61275e6ed2d", "https://github.com/beeware/toga/commit/071d039a598c4ce91a04247b8893feddcf754f67", "https://github.com/beeware/toga/commit/fd58fccfee6fe031cd369b001193e2adc860fb9c", "https://github.com/beeware/toga/commit/7733a31858994ca5bb41cab9b130032b265819b4", "https://github.com/beeware/toga/commit/d6cec42b9f4f3e64a2c25487ea959bbe788e19f3", "https://github.com/beeware/toga/commit/aef5b8d6b78e4144e57a69019fffaea078f70b26", "https://github.com/beeware/toga/commit/6fe11677778d738c476310d98b71b3c1bca56f44", "https://github.com/beeware/toga/commit/aa54e5b63ab78d21f46569a13dbdb36c840eab87", "https://github.com/beeware/toga/commit/eb5c3cb1dfab35f62a6c428afd45a5d2b68b9dec", "https://github.com/beeware/toga/commit/9adea65f809b1cb4862898b621681166c10556b2", "https://github.com/beeware/toga/commit/6c01b602ab10e303e331cab5a71c6492bbbd0abf", "https://github.com/beeware/toga/commit/2759ffb87ffb0ee39e783c501ae13b42b6a6223f", "https://github.com/beeware/toga/commit/24be047f89171885a055aa840094b0d32afefaff", "https://github.com/beeware/toga/commit/8fa656d5bf891f37b2839ef6d58a99c0470b28c4", "https://github.com/beeware/toga/commit/7509eca20ba9eaa15778d4d1bc9519af667951dc", "https://github.com/beeware/toga/commit/6479d749b0664aa4c296d083132230ef581b01ae", "https://github.com/beeware/toga/commit/f16f18f0b4cc914dc15b03c2d03d151c0ef78b72", "https://github.com/beeware/toga/commit/c39854a552463d9c3d61f795275064eac0c8073b", "https://github.com/beeware/toga/commit/ebe2e6776cebea5759604f87af7058da30af96f3", "https://github.com/beeware/toga/commit/1ac2e6eb5ae5fbd8a2235d4b7f135d1e1ab0a230", "https://github.com/beeware/toga/commit/2d35ceb2193cf041aa079d9d7ae80c216e1ef6f1", "https://github.com/beeware/toga/commit/cbda777719f246ef99b0a8d2776eba9b066d7c74", "https://github.com/beeware/toga/commit/393f73f09887eddbcaf54c97a3485b14701d8c1b", "https://github.com/beeware/toga/commit/07daff0eda17fa622bd11f95a0bbe0c132460628", "https://github.com/beeware/toga/commit/98048f61ef44627aecf5f19ef36a1a4eb6e1c2fc", "https://github.com/beeware/toga/commit/a86cd6550142cda08f34b6f04f409758fd86ca7e", "https://github.com/beeware/toga/commit/1d3bc3b75e78dd840900c5e21f31dc5847c8ee2d", "https://github.com/beeware/toga/commit/5a9982579b0c1f9a243039a69701a39cd1d01c66", "https://github.com/beeware/toga/commit/1516450aba15c5ef1513627135d7326e76c3bd27", "https://github.com/beeware/toga/commit/6ad56d6837e6fd7cd0236744c1e22ab28e267f59", "https://github.com/beeware/toga/commit/2e4bfbaf4cde75a492e5b63961a0a09c4ca2cc35", "https://github.com/beeware/toga/commit/b796fe32f00f7868ebb3fb99f766d24d0da44e22", "https://github.com/beeware/toga/commit/e2baadee3bdcc7efd83bf4dac587d3c6f2d323f6", "https://github.com/beeware/toga/commit/3a15780984a8b6dadf22ccf9bfe615efffcc96c0", "https://github.com/beeware/toga/commit/c932b65f8a3b38a1534d1441bf40845649a89a36", "https://github.com/beeware/toga/commit/202df9c1ea306e6756e06b5525725eb224c0022b", "https://github.com/beeware/toga/commit/a5e822198bb66020756f01a1c87c712761c2e61a", "https://github.com/beeware/toga/commit/0f100d9192cd7a0ba6d3fe0cc7b7efe2c740d36d", "https://github.com/beeware/toga/commit/453b3ca8c09d43573542dfffb255cf857106dddc", "https://github.com/beeware/toga/commit/c9edf5f4eded8c8f7d87de997582b8b8ebb514cc", "https://github.com/beeware/toga/commit/ee4070025bb24f703a785d8d8e25479148ab46c4", "https://github.com/beeware/toga/commit/3f484e194b8f9ba319638e1ded578bad66fe272b", "https://github.com/beeware/toga/commit/88932ed0bbc68be2d67b1c7cb5b8d51f6e565ef1", "https://github.com/beeware/toga/commit/10e293ea6dd92f53f624c9e04d36c056231e8d7f", "https://github.com/beeware/toga/commit/f51cb2de4722d00c23a38508b91e6db92e113892", "https://github.com/beeware/toga/commit/4adc628792b5b578d1a699caa4d1868ede7383ee", "https://github.com/beeware/toga/commit/63516e48eb43aa43d5671caa71a2ad8dc127f0b7", "https://github.com/beeware/toga/commit/572ad55c310efc4dc8e0e76c9ea2353216ec2564", "https://github.com/beeware/toga/commit/a51aafdb5a3b5b8379a1c23036c6f06c03b138bf", "https://github.com/beeware/toga/commit/ee7d23cd2dea2e59964078e9efa2a0bae2083c9d", "https://github.com/beeware/toga/commit/f66cb0b1b14b6e3ae6ea1819ee921f40b25997b1", "https://github.com/beeware/toga/commit/1bf9bfd2af23348e1bd150877d1c68c407475d42", "https://github.com/beeware/toga/commit/084b090ff2408b73f0918ef0ba53c888d9ed05fe", "https://github.com/beeware/toga/commit/fcf6ccfe005741d255f940b38687d1f28c60a9dc", "https://github.com/beeware/toga/commit/cc471fc4d082ea0ce31846a1910e492de1c96dee", "https://github.com/beeware/toga/commit/88a247424af223f3722dcb1b2fd37bb97e02e6d3", "https://github.com/beeware/toga/commit/2beb643cfa80a20ac15f95030285ad374de7fd05", "https://github.com/beeware/toga/commit/0496e353814e8445f790c7fcc5ca6fe95c40c71e", "https://github.com/beeware/toga/commit/b5397426bf4bfd7e7641a2ff2497078a08cee9d8", "https://github.com/beeware/toga/commit/d79c10ef16ff304332b710fe8d740ef05a2480af"], "created_at": "2024-01-26T12:29:56Z"}
{"repo": "beeware/toga", "pull_number": 3680, "instance_id": "beeware__toga-3680", "issue_numbers": [2411], "base_commit": "4c26910d4332b45433021bded49e7c7e05ca2d31", "patch": "diff --git a/changes/2411.bugfix.rst b/changes/2411.bugfix.rst\nnew file mode 100644\nindex 0000000000..c18c377728\n--- /dev/null\n+++ b/changes/2411.bugfix.rst\n@@ -0,0 +1,1 @@\n+Buttons and other interactive widgets in scroll containers now respond properly to touch events on iOS when scrolled into view.\ndiff --git a/iOS/src/toga_iOS/widgets/scrollcontainer.py b/iOS/src/toga_iOS/widgets/scrollcontainer.py\nindex a95b9296f0..ccdaf93f14 100644\n--- a/iOS/src/toga_iOS/widgets/scrollcontainer.py\n+++ b/iOS/src/toga_iOS/widgets/scrollcontainer.py\n@@ -1,4 +1,11 @@\n-from rubicon.objc import SEL, NSMakePoint, NSMakeSize, objc_method, objc_property\n+from rubicon.objc import (\n+    SEL,\n+    CGRectMake,\n+    NSMakePoint,\n+    NSMakeSize,\n+    objc_method,\n+    objc_property,\n+)\n from travertino.size import at_least\n \n from toga_iOS.container import Container\n@@ -68,6 +75,12 @@ def content_refreshed(self, container):\n \n         self.native.contentSize = NSMakeSize(width, height)\n \n+        # Update the document container frame to match the content size so that\n+        # buttons outside the original scroll view frame can receive touch events.\n+        # Without this, hit testing fails for views outside the original container\n+        # bounds\n+        self.document_container.native.frame = CGRectMake(0, 0, width, height)\n+\n     def rehint(self):\n         self.interface.intrinsic.width = at_least(self.interface._MIN_WIDTH)\n         self.interface.intrinsic.height = at_least(self.interface._MIN_HEIGHT)\n", "test_patch": "diff --git a/iOS/tests_backend/widgets/scrollcontainer.py b/iOS/tests_backend/widgets/scrollcontainer.py\nindex 1fbadb4948..15e829036c 100644\n--- a/iOS/tests_backend/widgets/scrollcontainer.py\n+++ b/iOS/tests_backend/widgets/scrollcontainer.py\n@@ -17,11 +17,23 @@ def has_content(self):\n \n     @property\n     def document_height(self):\n-        return self.native.contentSize.height\n+        # Assert that the document container and the document itself have the same size.\n+        # This is necessary to ensure that events propagate; see #2411.\n+        assert self.impl.document_container.native.frame.size.height == (\n+            content_height := self.native.contentSize.height\n+        )\n+\n+        return content_height\n \n     @property\n     def document_width(self):\n-        return self.native.contentSize.width\n+        # Assert that the document container and the document itself have the same size.\n+        # This is necessary to ensure that events propagate; see #2411.\n+        assert self.impl.document_container.native.frame.size.width == (\n+            content_width := self.native.contentSize.width\n+        )\n+\n+        return content_width\n \n     async def scroll(self):\n         if self.document_height <= self.height:\n", "problem_statement": "iOS widgets not responsive when below the fold of a scroll container \n### Describe the bug\r\n\r\nIf a scroll container contains a button in a scroll container, and that button is initially off the screen, it does not generate button press events when scrolled into view.\r\n\r\n### Steps to reproduce\r\n\r\nRun the following app:\r\n```\r\nimport toga\r\nfrom toga.style import Pack\r\nfrom toga.style.pack import COLUMN\r\n\r\nclass TestApp(toga.App):\r\n    def press(self, widget, *kwargs):\r\n        print(\"press\", widget)\r\n\r\n    def startup(self):\r\n        main_box = toga.ScrollContainer(\r\n            content=toga.Box(\r\n                children=[\r\n                    toga.Button(\r\n                        f\"Button {i}\", on_press=self.press, style=Pack(padding=20)\r\n                    )\r\n                    for i in range(0, 20)\r\n                ],\r\n                style=Pack(direction=COLUMN),\r\n            )\r\n        )\r\n\r\n        self.main_window = toga.MainWindow(title=self.formal_name)\r\n        self.main_window.content = main_box\r\n        self.main_window.show()\r\n\r\ndef main():\r\n    return TestApp()\r\n```\r\n\r\nButtons 0-9 are initially visible on an iPhone 15 simulator, and will output a log message when pressed. If the scroll container is scrolled to make buttons 10-20 visible, they will *not* respond to a press event. Buttons 0-9 will continue to respond to press events as long as they are visible.\r\n\r\nThis doesn't appear to be specific to buttons - it appears to be any widget. If a TextInput is added to bottom of the stack of buttons, it won't accept focus.\r\n\r\n### Expected behavior\r\n\r\nWidgets should always respond to press events, regardless of their container.\r\n\r\n### Screenshots\r\n\r\n_No response_\r\n\r\n### Environment\r\n\r\n- Operating System: iOS 17\r\n- Python version: 3.10\r\n- Software versions:\r\n  - Briefcase: 0.3.17\r\n  - Toga: 0.4.2\r\n  - ...\r\n\r\n\r\n### Logs\r\n\r\n_No response_\r\n\r\n### Additional context\r\n\r\nMy guess is that this is viewport related. The scroll container is configured so that content is *visible*, but there's something in the sizing of the content area that is being restricted to the initially visible size, which is restricting press events from being passed down to the button.\r\n\r\nThe same problem does *not* appear to exist on macOS.\r\n\r\nIt occurs on both the simulator and on physical devices.\n", "hints_text": "just encountered this as well on iOS.\r\n\r\n- Operating System: iOS 17\r\n- Python version: 3.11\r\nSoftware versions:\r\n- Briefcase: 0.3.19\r\n- Toga: 0.4.5\r\n\r\n```\r\nimport toga\r\nfrom toga.style import Pack\r\nfrom toga.style.pack import COLUMN, ROW\r\n\r\n\r\nclass iosscrollbug(toga.App):\r\n    def startup(self):\r\n        main_box = toga.Box(style=Pack(direction=ROW))\r\n\r\n        container = create_scroll_list()\r\n        main_box.add(container)\r\n\r\n        self.main_window = toga.MainWindow(title=self.formal_name)\r\n        self.main_window.content = main_box\r\n        self.main_window.show()\r\n\r\ndef create_scroll_list():\r\n    scroll_container = toga.ScrollContainer(horizontal=False, style=Pack(flex=1))\r\n    scroll_box = toga.Box(\r\n        style=Pack(direction=COLUMN, padding=5)\r\n    )\r\n    scroll_container.content = scroll_box\r\n\r\n    for i in range(100):\r\n        item_box = toga.Box(style=Pack(direction=ROW, padding=5))\r\n        item_box.add(toga.Label(f\"Item {i}\", style=Pack(flex=1)))\r\n        item_box.add(toga.Button(\"Click\",\r\n                                 on_press=lambda widget: print(f\"Button {i} clicked\"),\r\n                                 style=Pack(width=100, padding_left=10)))\r\n        item_box.add(toga.Switch(on_change=lambda widget, value: print(f\"Switch {i} toggled to {value}\"),\r\n                                 style=Pack(padding_left=10),\r\n                                 text=\"\"))\r\n        scroll_box.add(item_box)\r\n\r\n    return scroll_container\r\n\r\ndef main():\r\n    return iosscrollbug()\r\n```\r\n\r\nare there any hacks or workarounds to get the widgets to be active past the scroll barrier?\nUnfortunately not - I haven't had a chance to dig into this, so there's no workaround. The issue is almost certainly related to the size of the native container boxes involved, but beyond that, I can't provide any advice. \n\n", "all_hints_text": "just encountered this as well on iOS.\r\n\r\n- Operating System: iOS 17\r\n- Python version: 3.11\r\nSoftware versions:\r\n- Briefcase: 0.3.19\r\n- Toga: 0.4.5\r\n\r\n```\r\nimport toga\r\nfrom toga.style import Pack\r\nfrom toga.style.pack import COLUMN, ROW\r\n\r\n\r\nclass iosscrollbug(toga.App):\r\n    def startup(self):\r\n        main_box = toga.Box(style=Pack(direction=ROW))\r\n\r\n        container = create_scroll_list()\r\n        main_box.add(container)\r\n\r\n        self.main_window = toga.MainWindow(title=self.formal_name)\r\n        self.main_window.content = main_box\r\n        self.main_window.show()\r\n\r\ndef create_scroll_list():\r\n    scroll_container = toga.ScrollContainer(horizontal=False, style=Pack(flex=1))\r\n    scroll_box = toga.Box(\r\n        style=Pack(direction=COLUMN, padding=5)\r\n    )\r\n    scroll_container.content = scroll_box\r\n\r\n    for i in range(100):\r\n        item_box = toga.Box(style=Pack(direction=ROW, padding=5))\r\n        item_box.add(toga.Label(f\"Item {i}\", style=Pack(flex=1)))\r\n        item_box.add(toga.Button(\"Click\",\r\n                                 on_press=lambda widget: print(f\"Button {i} clicked\"),\r\n                                 style=Pack(width=100, padding_left=10)))\r\n        item_box.add(toga.Switch(on_change=lambda widget, value: print(f\"Switch {i} toggled to {value}\"),\r\n                                 style=Pack(padding_left=10),\r\n                                 text=\"\"))\r\n        scroll_box.add(item_box)\r\n\r\n    return scroll_container\r\n\r\ndef main():\r\n    return iosscrollbug()\r\n```\r\n\r\nare there any hacks or workarounds to get the widgets to be active past the scroll barrier?\nUnfortunately not - I haven't had a chance to dig into this, so there's no workaround. The issue is almost certainly related to the size of the native container boxes involved, but beyond that, I can't provide any advice. \n\n", "commit_urls": ["https://github.com/beeware/toga/commit/7eee5bc9abbfc008e020f7c64405f64a6bcb856f", "https://github.com/beeware/toga/commit/5ee68aa592d1cf0e8ec44db0dce9fd62f77f7958", "https://github.com/beeware/toga/commit/8ef9dc0e253b94e282d1f3a4a9689d1b6a52e28d", "https://github.com/beeware/toga/commit/3255c703eab676660c56bbb3ccd44bb79b023ce9", "https://github.com/beeware/toga/commit/0526dab50ab9e638d16ada6f8d53461fabae35b7", "https://github.com/beeware/toga/commit/53a196d07e2bc0ad2de2fa498312dc995742bbe0"], "created_at": "2025-08-05T16:16:39Z"}
{"repo": "beeware/toga", "pull_number": 3595, "instance_id": "beeware__toga-3595", "issue_numbers": [2451], "base_commit": "2b57e9171cda2e708265f70f2ac2a44646b3bf74", "patch": "diff --git a/android/src/toga_android/libs/events.py b/android/src/toga_android/libs/events.py\nindex fcf5ef78d2..93c8f47e4d 100644\n--- a/android/src/toga_android/libs/events.py\n+++ b/android/src/toga_android/libs/events.py\n@@ -13,7 +13,7 @@\n from java.lang import Runnable\n \n # Some methods in this file are based on CPython's implementation. Per\n-# https://github.com/python/cpython/blob/master/LICENSE , re-use is permitted via the\n+# https://github.com/python/cpython/blob/master/LICENSE , reuse is permitted via the\n # Python Software Foundation License Version 2, which includes inclusion into this\n # project under its BSD license terms so long as we retain this copyright notice:\n #\ndiff --git a/changes/3595.bugfix.rst b/changes/3595.bugfix.rst\nnew file mode 100644\nindex 0000000000..29574b9325\n--- /dev/null\n+++ b/changes/3595.bugfix.rst\n@@ -0,0 +1,1 @@\n+All but one codespell error is now ignored inline. ``MapPin`` remains a global ignore.\ndiff --git a/examples/detailedlist/detailedlist/translations.py b/examples/detailedlist/detailedlist/translations.py\nindex 27bacd139e..4f85635d40 100644\n--- a/examples/detailedlist/detailedlist/translations.py\n+++ b/examples/detailedlist/detailedlist/translations.py\n@@ -77,7 +77,7 @@\n     {\"locale\": \"sv\", \"country\": \"Swedish\", \"string\": \"Bi\"},\n     {\"locale\": \"sw\", \"country\": \"Swahili\", \"string\": \"Nyuki\"},\n     {\"locale\": \"ta\", \"country\": \"Tamil\", \"string\": \"\u0ba4\u0bc7\u0ba9\u0bc0\"},\n-    {\"locale\": \"te\", \"country\": \"Telugu\", \"string\": \"\u0c2c\u0c40\"},\n+    {\"locale\": \"te\", \"country\": \"Telugu\", \"string\": \"\u0c2c\u0c40\"},  # codespell:ignore te\n     {\"locale\": \"tg\", \"country\": \"Tajik\", \"string\": \"\u0425\u0443\u0448\u043a\"},\n     {\"locale\": \"th\", \"country\": \"Thai\", \"string\": \"\u0e1c\u0e36\u0e49\u0e07\"},\n     {\"locale\": \"tl\", \"country\": \"Filipino\", \"string\": \"Bee\"},\ndiff --git a/pyproject.toml b/pyproject.toml\nindex b634f89e67..433bf74d39 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -2,7 +2,7 @@\n skip = \".git,*.pdf,*.svg\"\n # the way to make case sensitive skips of words etc\n ignore-regex = \"\\bNd\\b\"\n-ignore-words-list = \"te,crate,re-use,MapPin\"\n+ignore-words-list = \"MapPin\"\n \n # The coverage settings in this file only control `coverage report`. `coverage run` and\n # `coverage combine` are controlled by the pyproject.toml files in each package's\n", "test_patch": "", "problem_statement": "Replace codespell global ignore with line-specific ignores\n### Describe the bug\n\nThe top-level pyproject.toml includes a codespell configuration that adds a global ignore-words-list. This is because codespell is incorrectly identifying some words as misspellings. Ideally, we'd use a per-usage ignore, rather than a global ignore.\n\nThis was logged as codespell-project/codespell#1212, which was implemented as codespell-project/codespell#2400. We should use the new feature in Toga.\n\n### Steps to reproduce\n\n1. Disable the `ignore-words-list` configuration  in the top level pyproject.toml\n2. Run `pre-commit run --all`\n\n### Expected behavior\n\nPre-commit should pass the codespell test without error.\n\n### Additional context\n\nOur codespell dependency is set at v2.2.6 at time of writing. When a new version of codespell is released, our pre-commit update task will automatically upgrade the version, at which point we can replace the ignore-words-list global config with per-line ignores (e.g., `# codespell:ignore crate`)for the specific places where there is a problem.\n", "hints_text": "\n\n", "all_hints_text": "`MapPin` remains a global ignore, at the request of mhsmith. There was a conflict between `codespell` and `pyenchant` within the docs, attempting to ignore `MapPin` inline. Malcolm decided that it should remain global.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/6984465b0a444487e80cbf929e213e94160ad0ee", "https://github.com/beeware/toga/commit/557a541c0d601714b7d828fe53cf3f1eb09505ad", "https://github.com/beeware/toga/commit/0a3817a140206bcbfe40d8772ad1aa349fc45c22", "https://github.com/beeware/toga/commit/b9eaceea9a2b4fffd03833d23935168e2d9d025f"], "created_at": "2025-06-30T01:02:40Z"}
{"repo": "beeware/toga", "pull_number": 4205, "instance_id": "beeware__toga-4205", "issue_numbers": [2687, 2928], "base_commit": "90cca2b135f754f501a4413f4fa31943fc84383f", "patch": "diff --git a/android/pyproject.toml b/android/pyproject.toml\nindex 12d39196a2..173f06ad52 100644\n--- a/android/pyproject.toml\n+++ b/android/pyproject.toml\n@@ -57,6 +57,57 @@ Changelog = \"https://toga.beeware.org/en/stable/background/project/releases\"\n [project.entry-points.\"toga.backends\"]\n android = \"toga_android\"\n \n+[project.entry-points.\"toga_core.backend.toga_android\"]\n+App = \"toga_android.app:App\"\n+# DocumentApp = \"toga_dummy.app:DocumentApp\"\n+Command = \"toga_android.command:Command\"\n+Font = \"toga_android.fonts:Font\"\n+Icon = \"toga_android.icons:Icon\"\n+Image = \"toga_android.images:Image\"\n+Paths = \"toga_android.paths:Paths\"\n+dialogs = \"toga_android.dialogs\"\n+resources = \"toga_android.resources\"\n+\n+# Hardware\n+Camera = \"toga_android.hardware.camera:Camera\"\n+Location = \"toga_android.hardware.location:Location\"\n+\n+# Status Icons\n+MenuStatusIcon = \"toga_android.statusicons:MenuStatusIcon\"\n+SimpleStatusIcon = \"toga_android.statusicons:SimpleStatusIcon\"\n+StatusIconSet = \"toga_android.statusicons:StatusIconSet\"\n+\n+# Widgets\n+ActivityIndicator = \"toga_android.widgets.activityindicator:ActivityIndicator\"\n+Box = \"toga_android.widgets.box:Box\"\n+Button = \"toga_android.widgets.button:Button\"\n+Canvas = \"toga_android.widgets.canvas:Canvas\"\n+DateInput = \"toga_android.widgets.dateinput:DateInput\"\n+DetailedList = \"toga_android.widgets.detailedlist:DetailedList\"\n+Divider = \"toga_android.widgets.divider:Divider\"\n+ImageView = \"toga_android.widgets.imageview:ImageView\"\n+Label = \"toga_android.widgets.label:Label\"\n+MapView = \"toga_android.widgets.mapview:MapView\"\n+MultilineTextInput = \"toga_android.widgets.multilinetextinput:MultilineTextInput\"\n+NumberInput = \"toga_android.widgets.numberinput:NumberInput\"\n+OptionContainer = \"toga_android.widgets.optioncontainer:OptionContainer\"\n+PasswordInput = \"toga_android.widgets.passwordinput:PasswordInput\"\n+ProgressBar = \"toga_android.widgets.progressbar:ProgressBar\"\n+ScrollContainer = \"toga_android.widgets.scrollcontainer:ScrollContainer\"\n+Selection = \"toga_android.widgets.selection:Selection\"\n+Slider = \"toga_android.widgets.slider:Slider\"\n+# SplitContainer = \"toga_android.widgets.splitcontainer:SplitContainer\"\n+Switch = \"toga_android.widgets.switch:Switch\"\n+Table = \"toga_android.widgets.table:Table\"\n+TextInput = \"toga_android.widgets.textinput:TextInput\"\n+TimeInput = \"toga_android.widgets.timeinput:TimeInput\"\n+# Tree = \"toga_android.widgets.tree:Tree\"\n+WebView = \"toga_android.widgets.webview:WebView\"\n+\n+# Windows\n+MainWindow = \"toga_android.window:MainWindow\"\n+Window = \"toga_android.window:Window\"\n+\n [tool.setuptools_scm]\n root = \"..\"\n \ndiff --git a/android/src/toga_android/factory.py b/android/src/toga_android/factory.py\nindex c7f16a0671..78fc80e7d4 100644\n--- a/android/src/toga_android/factory.py\n+++ b/android/src/toga_android/factory.py\n@@ -1,3 +1,5 @@\n+import warnings\n+\n from toga import NotImplementedWarning\n \n from . import dialogs\n@@ -35,8 +37,14 @@\n from .widgets.webview import WebView\n from .window import MainWindow, Window\n \n+warnings.warn(\n+    \"Factory modules are deprecated. Use 'toga.platform.get_factory' instead.\",\n+    DeprecationWarning,\n+    stacklevel=1,\n+)\n+\n \n-def not_implemented(feature):\n+def not_implemented(feature):  # pragma: no cover\n     NotImplementedWarning.warn(\"Android\", feature)\n \n \ndiff --git a/android/src/toga_android/resources/__init__.py b/android/src/toga_android/resources/__init__.py\nnew file mode 100644\nindex 0000000000..e69de29bb2\ndiff --git a/changes/2687.feature.md b/changes/2687.feature.md\nnew file mode 100644\nindex 0000000000..21f61cb914\n--- /dev/null\n+++ b/changes/2687.feature.md\n@@ -0,0 +1,1 @@\n+Widget implementations are now contributed by entry points, allowing lazy loading on a per-widget basis.\ndiff --git a/changes/2687.removal.md b/changes/2687.removal.md\nnew file mode 100644\nindex 0000000000..187828fc0a\n--- /dev/null\n+++ b/changes/2687.removal.md\n@@ -0,0 +1,1 @@\n+The `get_platform_factory` function and backend `factory` modules are deprecated. Widget authors should use `get_factory` instead and writers of new backends should use entry points to declare the implemented objects.  The new factory objects are not modules but instead are lazy namespace objects.\ndiff --git a/cocoa/pyproject.toml b/cocoa/pyproject.toml\nindex febb7cca14..653b4f6868 100644\n--- a/cocoa/pyproject.toml\n+++ b/cocoa/pyproject.toml\n@@ -58,6 +58,56 @@ Changelog = \"https://toga.beeware.org/en/stable/background/project/releases\"\n [project.entry-points.\"toga.backends\"]\n macOS = \"toga_cocoa\"\n \n+[project.entry-points.\"toga_core.backend.toga_cocoa\"]\n+App = \"toga_cocoa.app:App\"\n+Command = \"toga_cocoa.command:Command\"\n+Font = \"toga_cocoa.fonts:Font\"\n+Icon = \"toga_cocoa.icons:Icon\"\n+Image = \"toga_cocoa.images:Image\"\n+Paths = \"toga_cocoa.paths:Paths\"\n+dialogs = \"toga_cocoa.dialogs\"\n+resources = \"toga_cocoa.resources\"\n+\n+# Hardware\n+Camera = \"toga_cocoa.hardware.camera:Camera\"\n+Location = \"toga_cocoa.hardware.location:Location\"\n+\n+# Status Icons\n+MenuStatusIcon = \"toga_cocoa.statusicons:MenuStatusIcon\"\n+SimpleStatusIcon = \"toga_cocoa.statusicons:SimpleStatusIcon\"\n+StatusIconSet = \"toga_cocoa.statusicons:StatusIconSet\"\n+\n+# Widgets\n+ActivityIndicator = \"toga_cocoa.widgets.activityindicator:ActivityIndicator\"\n+Box = \"toga_cocoa.widgets.box:Box\"\n+Button = \"toga_cocoa.widgets.button:Button\"\n+Canvas = \"toga_cocoa.widgets.canvas:Canvas\"\n+DateInput = \"toga_cocoa.widgets.dateinput:DateInput\"\n+DetailedList = \"toga_cocoa.widgets.detailedlist:DetailedList\"\n+Divider = \"toga_cocoa.widgets.divider:Divider\"\n+ImageView = \"toga_cocoa.widgets.imageview:ImageView\"\n+Label = \"toga_cocoa.widgets.label:Label\"\n+MapView = \"toga_cocoa.widgets.mapview:MapView\"\n+MultilineTextInput = \"toga_cocoa.widgets.multilinetextinput:MultilineTextInput\"\n+NumberInput = \"toga_cocoa.widgets.numberinput:NumberInput\"\n+OptionContainer = \"toga_cocoa.widgets.optioncontainer:OptionContainer\"\n+PasswordInput = \"toga_cocoa.widgets.passwordinput:PasswordInput\"\n+ProgressBar = \"toga_cocoa.widgets.progressbar:ProgressBar\"\n+ScrollContainer = \"toga_cocoa.widgets.scrollcontainer:ScrollContainer\"\n+Selection = \"toga_cocoa.widgets.selection:Selection\"\n+Slider = \"toga_cocoa.widgets.slider:Slider\"\n+SplitContainer = \"toga_cocoa.widgets.splitcontainer:SplitContainer\"\n+Switch = \"toga_cocoa.widgets.switch:Switch\"\n+Table = \"toga_cocoa.widgets.table:Table\"\n+TextInput = \"toga_cocoa.widgets.textinput:TextInput\"\n+TimeInput = \"toga_cocoa.widgets.timeinput:TimeInput\"\n+Tree = \"toga_cocoa.widgets.tree:Tree\"\n+WebView = \"toga_cocoa.widgets.webview:WebView\"\n+\n+# Windows\n+MainWindow = \"toga_cocoa.window:MainWindow\"\n+Window = \"toga_cocoa.window:Window\"\n+\n [tool.setuptools_scm]\n root = \"..\"\n \ndiff --git a/cocoa/src/toga_cocoa/factory.py b/cocoa/src/toga_cocoa/factory.py\nindex a28ec9f846..e0873f03c3 100644\n--- a/cocoa/src/toga_cocoa/factory.py\n+++ b/cocoa/src/toga_cocoa/factory.py\n@@ -1,3 +1,5 @@\n+import warnings\n+\n from toga import NotImplementedWarning\n \n from . import dialogs\n@@ -39,8 +41,14 @@\n from .widgets.webview import WebView\n from .window import MainWindow, Window\n \n+warnings.warn(\n+    \"Factory modules are deprecated. Use 'toga.platform.get_factory' instead.\",\n+    DeprecationWarning,\n+    stacklevel=1,\n+)\n+\n \n-def not_implemented(feature):\n+def not_implemented(feature):  # pragma: no cover\n     NotImplementedWarning.warn(\"Cocoa\", feature)\n \n \ndiff --git a/cocoa/src/toga_cocoa/resources/__init__.py b/cocoa/src/toga_cocoa/resources/__init__.py\nnew file mode 100644\nindex 0000000000..e69de29bb2\ndiff --git a/core/src/toga/app.py b/core/src/toga/app.py\nindex 61dc1d2fad..e4533d7ad8 100644\n--- a/core/src/toga/app.py\n+++ b/core/src/toga/app.py\n@@ -18,7 +18,7 @@\n from toga.handlers import simple_handler, wrapped_handler\n from toga.icons import Icon\n from toga.paths import Paths\n-from toga.platform import get_platform_factory\n+from toga.platform import get_factory\n from toga.statusicons import StatusIconSet\n from toga.window import MainWindow, Window, WindowSet\n \n@@ -307,7 +307,7 @@ def __init__(\n             self._description = self.metadata.get(\"Summary\", None)\n \n         # Get a platform factory.\n-        self.factory = get_platform_factory()\n+        self.factory = get_factory()\n \n         # Instantiate the paths instance for this app.\n         self._paths = Paths()\ndiff --git a/core/src/toga/command.py b/core/src/toga/command.py\nindex 67125971a8..e3f73b2b1a 100644\n--- a/core/src/toga/command.py\n+++ b/core/src/toga/command.py\n@@ -6,7 +6,7 @@\n from toga.handlers import simple_handler, wrapped_handler\n from toga.icons import Icon\n from toga.keys import Key\n-from toga.platform import get_platform_factory\n+from toga.platform import get_factory\n \n if TYPE_CHECKING:\n     from toga.app import App\n@@ -297,7 +297,7 @@ def __init__(\n \n         self.action = action\n \n-        self.factory = get_platform_factory()\n+        self.factory = get_factory()\n         self._impl = self.factory.Command(interface=self)\n \n         self._enabled = True\n@@ -329,7 +329,7 @@ def standard(cls, app: App, id, **kwargs):\n             cmd_kwargs[\"action\"] = None\n \n         # Get the platform-specific keyword arguments for the command\n-        factory = get_platform_factory()\n+        factory = get_factory()\n         platform_kwargs = factory.Command.standard(app, id)\n \n         if platform_kwargs:\ndiff --git a/core/src/toga/dialogs.py b/core/src/toga/dialogs.py\nindex 4e60b02e3