+    def _pad_pack(self, pack: Dict[str, List[int]]) -> Dict[str, torch.Tensor]:
+        """
+        Pad a packed sample to ``self.max_seq_len``.
+
+        This method now robustly handles the edge‑case where a single packed
+        sequence exceeds ``max_seq_len`` (which can happen when
+        ``split_across_pack=True`` and the original sequence length is greater
+        than ``2 * max_seq_len``).  In such scenarios the previous implementation
+        attempted to create a ``torch.arange`` with a negative length, raising
+        ``RuntimeError: upper bound and larger bound inconsistent with step sign``.
+
+        The updated logic truncates any over‑length sequence to ``max_seq_len``
+        and only pads when the sequence is shorter than the target length.
+
+        Args:
+            pack (Dict[str, List[int]]): A dictionary containing the packed
+                ``tokens`` and ``labels``.
+
+        Returns:
+            Dict[str, torch.Tensor]: The padded (or truncated) sample.
+        """
+        # Truncate if the packed sequence is longer than ``max_seq_len``.
+        if len(pack[\"tokens\"]) > self.max_seq_len:
+            pack[\"tokens\"] = pack[\"tokens\"][: self.max_seq_len]
+            pack[\"labels\"] = pack[\"labels\"][: self.max_seq_len]
+
+        # Compute how many padding tokens we need.
+        pad_len = self.max_seq_len - len(pack[\"tokens\"])
+
+        # ``pad_len`` is guaranteed to be non‑negative here.
+        pad_range = torch.arange(pad_len, dtype=torch.long)
+
+        # Pad tokens and labels with the appropriate padding values.
+        padded_tokens = torch.cat(
+            [torch.tensor(pack[\"tokens\"], dtype=torch.long), pad_range]
+        )
+        padded_labels = torch.cat(
+            [torch.tensor(pack[\"labels\"], dtype=torch.long), pad_range]
+        )
+
+        return {
+            \"tokens\": padded_tokens,
+            \"labels\": padded_labels,
+        }