      {generationStatus.bundle.commit}\n-                                      <ExternalLink className=\"h-3 w-3\" />\n-                                        </a>\n-                                    </div>\n-                                </div>\n-                            )}\n-                            <div className=\"flex gap-2\">\n-                                <Button asChild className=\"flex-1\">\n-                                    <a href={generationStatus.download_url} download>\n-                                        <Download className=\"mr-2 h-4 w-4\" />\n-                                        Download Bundle\n-                                    </a>\n-                                </Button>\n-                                <Button variant=\"outline\" onClick={() => {\n-                                    setGenerationStatus({ status: 'idle' });\n-                                    setRepoUrl('');\n-                                    setProgress(0);\n-                                }}>\n-                                    Generate Another\n-                                </Button>\n-                            </div>\n-                            <div className=\"bg-muted p-3 rounded-md text-sm\">\n-                                <p className=\"font-mono\">cgc load {generationStatus.bundle?.bundle_name || 'bundle.cgc'}</p>\n-                            </div>\n-                        </CardContent>\n-                    </Card>\n-                );\n-\n-            case 'error':\n-                return (\n-                    <Alert variant=\"destructive\">\n-                        <XCircle className=\"h-4 w-4\" />\n-                        <AlertDescription>\n-                            {generationStatus.error}\n-                            <Button\n-                                variant=\"link\"\n-                                className=\"ml-2 p-0 h-auto text-destructive underline\"\n-                                onClick={() => {\n-                                    setGenerationStatus({ status: 'idle' });\n-                                    setProgress(0);\n-                                }}\n-                            >\n-                                Try Again\n-                            </Button>\n-                        </AlertDescription>\n-                    </Alert>\n-                );\n-\n-            default:\n-                return null;\n-        }\n-    };\n-\n-    return (\n-        <section id=\"bundle-generator\" className=\"py-20 px-4 bg-muted/30\">\n-            <div className=\"container mx-auto max-w-4xl\">\n-                <div className=\"text-center mb-12\" data-aos=\"fade-up\">\n-                    <Badge variant=\"secondary\" className=\"mb-4\">\n-                        <Package className=\"w-4 h-4 mr-2\" />\n-                        On-Demand Generation\n-                    </Badge>\n-                    <h2 className=\"text-4xl font-bold mb-4\">Generate Custom Bundle</h2>\n-                    <p className=\"text-xl text-muted-foreground\">\n-                        Index any public GitHub repository and get a downloadable .cgc bundle\n-                    </p>\n-                </div>\n-\n-                <div data-aos=\"fade-up\" data-aos-delay=\"200\">\n-                    {import.meta.env.DEV && (\n-                        <Alert className=\"mb-4 border-yellow-500 bg-yellow-50 dark:bg-yellow-950/20\">\n-                            <AlertDescription className=\"text-yellow-800 dark:text-yellow-200\">\n-                                <strong>Development Mode:</strong> API endpoints require deployment to Vercel.\n-                                The UI will show mock responses for testing purposes.\n-                            </AlertDescription>\n-                        </Alert>\n-                    )}\n-                    {renderStatusContent()}\n-                </div>\n-\n-                <div className=\"mt-8 text-center text-sm text-muted-foreground\" data-aos=\"fade-up\" data-aos-delay=\"400\">\n-                    <p>\u23f1\ufe0f Generation typically takes 5-10 minutes depending on repository size</p>\n-                    <p className=\"mt-2\">\ud83d\udce6 Bundles are cached for 30 days for faster access</p>\n-                </div>\n+      } catch (err) {\n+        console.error(\"Error polling status:\", err);\n+      }\n+    }, 10000); // Poll every 10 seconds\n+\n+    // Stop polling after 30 minutes\n+    setTimeout(() => clearInterval(pollInterval), 30 * 60 * 1000);\n+  };\n+\n+  const renderStatusContent = () => {\n+    switch (generationStatus.status) {\n+      case \"idle\":\n+        return (\n+          <div className=\"space-y-4\">\n+            <div className=\"flex flex-col sm:flex-row gap-2\">\n+              <Input\n+                type=\"url\"\n+                placeholder=\"https://github.com/owner/repo\"\n+                value={repoUrl}\n+                onChange={(e) => setRepoUrl(e.target.value)}\n+                className=\"flex-1\"\n+                onKeyDown={(e) => e.key === \"Enter\" && handleGenerateBundle()}\n+              />\n+              <Button\n+                onClick={handleGenerateBundle}\n+                size=\"lg\"\n+                className=\"w-full sm:w-auto\"\n+              >\n+                <Package className=\"mr-2 h-4 w-4\" />\n+                Generate Bundle\n+              </Button>\n             </div>\n-        </section>\n-    );\n+            <p className=\"text-sm text-muted-foreground\">\n+              \ud83d\udca1 Enter any public GitHub repository URL to generate a .cgc\n+              bundle\n+            </p>\n+          </div>\n+        );\n+\n+      case \"validating\":\n+        return (\n+          <Alert>\n+            <Loader2 className=\"h-4 w-4 animate-spin\" />\n+            <AlertDescription>Validating repository...</AlertDescription>\n+          </Alert>\n+        );\n+\n+      case \"triggered\":\n+      case \"processing\":\n+        return (\n+          <Card>\n+            <CardHeader>\n+              <CardTitle className=\"flex items-center gap-2\">\n+                <Clock className=\"h-5 w-5 text-blue-500\" />\n+                Generating Bundle\n+              </CardTitle>\n+              <CardDescription>{generationStatus.repository}</CardDescription>\n+            </CardHeader>\n+            <CardContent className=\"space-y-4\">\n+              <Progress value={progress} className=\"w-full\" />\n+              <div className=\"space-y-2 text-sm\">\n+                <p>\n+                  <strong>Status:</strong>{\" \"}\n+                  {generationStatus.status === \"triggered\"\n+                    ? \"Queued\"\n+                    : \"Indexing repository\"}\n+                </p>\n+                <p>\n+                  <strong>Estimated Time:</strong>{\" \"}\n+                  {generationStatus.estimated_time}\n+                </p>\n+                {generationStatus.repo_size_mb && (\n+                  <p>\n+                    <strong>Repository Size:</strong>{\" \"}\n+                    {generationStatus.repo_size_mb} MB\n+                  </p>\n+                )}\n+                {generationStatus.run_url && (\n+                  <Button variant=\"link\" asChild className=\"p-0 h-auto\">\n+                    <a\n+                      href={generationStatus.run_url}\n+                      target=\"_blank\"\n+                      rel=\"noopener noreferrer\"\n+                    >\n+                      View Progress on GitHub{\" \"}\n+                      <ExternalLink className=\"ml-1 h-3 w-3\" />\n+                    </a>\n+                  </Button>\n+                )}\n+              </div>\n+            </CardContent>\n+          </Card>\n+        );\n+\n+      case \"exists\":\n+      case \"ready\":\n+        return (\n+          <Card className=\"border-green-500\">\n+            <CardHeader>\n+              <CardTitle className=\"flex items-center gap-2\">\n+                <CheckCircle2 className=\"h-5 w-5 text-green-500\" />\n+                Bundle Ready!\n+              </CardTitle>\n+              <CardDescription>{generationStatus.repository}</CardDescription>\n+            </CardHeader>\n+            <CardContent className=\"space-y-4\">\n+              {generationStatus.bundle && (\n+                <div className=\"grid grid-cols-2 gap-2 text-sm\">\n+                  <div>\n+                    <strong>Bundle:</strong>{\" \"}\n+                    {generationStatus.bundle.bundle_name}\n+                  </div>\n+                  <div>\n+                    <strong>Size:</strong> {generationStatus.bundle.size}\n+                  </div>\n+                  <div>\n+                    <strong>Generated:</strong>{\" \"}\n+                    {new Date(\n+                      generationStatus.bundle.generated_at,\n+                    ).toLocaleDateString()}\n+                  </div>\n+                  <div>\n+                    <strong>Commit:</strong>{\" \"}\n+                    <a\n+                      href={`https://github.com/${generationStatus.repository}/commit/${generationStatus.bundle.commit}`}\n+                      target=\"_blank\"\n+                      rel=\"noopener noreferrer\"\n+                      className=\"font-mono text-purple-500 hover:underline inline-flex items-center gap-1\"\n+                    >\n+                      {generationStatus.bundle.commit}\n+                      <ExternalLink className=\"h-3 w-3\" />\n+                    </a>\n+                  </div>\n+                </div>\n+              )}\n+              <div className=\"flex gap-2\">\n+                <Button asChild className=\"flex-1\">\n+                  <a href={generationStatus.download_url} download>\n+                    <Download className=\"mr-2 h-4 w-4\" />\n+                    Download Bundle\n+                  </a>\n+                </Button>\n+                <Button\n+                  variant=\"outline\"\n+                  onClick={() => {\n+                    setGenerationStatus({ status: \"idle\" });\n+                    setRepoUrl(\"\");\n+                    setProgress(0);\n+                  }}\n+                >\n+                  Generate Another\n+                </Button>\n+              </div>\n+              <div className=\"bg-muted p-3 rounded-md text-sm\">\n+                <p className=\"font-mono\">\n+                  cgc load{\" \"}\n+                  {generationStatus.bundle?.bundle_name || \"bundle.cgc\"}\n+                </p>\n+              </div>\n+            </CardContent>\n+          </Card>\n+        );\n+\n+      case \"error\":\n+        return (\n+          <Alert variant=\"destructive\">\n+            <XCircle className=\"h-4 w-4\" />\n+            <AlertDescription>\n+              {generationStatus.error}\n+              <Button\n+                variant=\"link\"\n+                className=\"ml-2 p-0 h-auto text-destructive underline\"\n+                onClick={() => {\n+                  setGenerationStatus({ status: \"idle\" });\n+                  setProgress(0);\n+                }}\n+              >\n+                Try Again\n+              </Button>\n+            </AlertDescription>\n+          </Alert>\n+        );\n+\n+      default:\n+        return null;\n+    }\n+  };\n+\n+  return (\n+    <section id=\"bundle-generator\" className=\"py-20 px-4 bg-muted/30\">\n+      <div className=\"container mx-auto max-w-4xl\">\n+        <div className=\"text-center mb-12\" data-aos=\"fade-up\">\n+          <Badge variant=\"secondary\" className=\"mb-4\">\n+            <Package className=\"w-4 h-4 mr-2\" />\n+            On-Demand Generation\n+          </Badge>\n+          <h2 className=\"text-4xl font-bold mb-4\">Generate Custom Bundle</h2>\n+          <p className=\"text-xl text-muted-foreground\">\n+            Index any public GitHub repository and get a downloadable .cgc\n+            bundle\n+          </p>\n+        </div>\n+\n+        <div data-aos=\"fade-up\" data-aos-delay=\"200\">\n+          {import.meta.env.DEV && (\n+            <Alert className=\"mb-4 border-yellow-500 bg-yellow-50 dark:bg-yellow-950/20\">\n+              <AlertDescription className=\"text-yellow-800 dark:text-yellow-200\">\n+                <strong>Development Mode:</strong> API endpoints require\n+                deployment to Vercel. The UI will show mock responses for\n+                testing purposes.\n+              </AlertDescription>\n+            </Alert>\n+          )}\n+          {renderStatusContent()}\n+        </div>\n+\n+        <div\n+          className=\"mt-8 text-center text-sm text-muted-foreground\"\n+          data-aos=\"fade-up\"\n+          data-aos-delay=\"400\"\n+        >\n+          <p>\n+            \u23f1\ufe0f Generation typically takes 5-10 minutes depending on repository\n+            size\n+          </p>\n+          <p className=\"mt-2\">\n+            \ud83d\udce6 Bundles are cached for 30 days for faster access\n+          </p>\n+        </div>\n+      </div>\n+    </section>\n+  );\n };\n \n export default BundleGeneratorSection;\n", "test_patch": "", "problem_statement": "Mobile view should put generate bundle in the next line and give full space to the url bar\n![Image](https://github.com/user-attachments/assets/c4e93a58-cc5a-40a7-8ff9-a2d5c33608c3)\n", "hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\n/assign\n\nAsigned!\n\n", "all_hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\n/assign\n\nAsigned!\n\n", "commit_urls": ["https://github.com/CodeGraphContext/CodeGraphContext/commit/88a6e98f8c589962182cf4fa6c10d5d039913b65"], "created_at": "2026-02-13T16:20:44Z"}
{"repo": "CodeGraphContext/CodeGraphContext", "pull_number": 618, "instance_id": "CodeGraphContext__CodeGraphContext-618", "issue_numbers": [607], "base_commit": "9983c7053e8c969b696b91e3eebae03ad8aac1f3", "patch": "diff --git a/website/api/trigger-bundle.ts b/website/api/trigger-bundle.ts\nindex 9f03289c..15826041 100644\n--- a/website/api/trigger-bundle.ts\n+++ b/website/api/trigger-bundle.ts\n@@ -7,7 +7,8 @@ export default async function handler(req: any, res: any) {\n         return res.status(405).json({ error: 'Method not allowed' });\n     }\n \n-    const { repoUrl } = req.body;\n+    const rawRepoUrl = req.body.repoUrl;\n+    const repoUrl = rawRepoUrl ? rawRepoUrl.trim() : rawRepoUrl;\n \n     // Validate input\n     if (!repoUrl) {\n@@ -15,7 +16,8 @@ export default async function handler(req: any, res: any) {\n     }\n \n     // Validate GitHub URL format\n-    const githubUrlPattern = /^https?:\\/\\/(www\\.)?github\\.com\\/([^\\/]+)\\/([^\\/]+)(\\.git)?$/;\n+    // Allow optional trailing slash and .git extension\n+    const githubUrlPattern = /^https?:\\/\\/(www\\.)?github\\.com\\/([^\\/]+)\\/([^\\/]+)(\\.git)?\\/?$/;\n     const match = repoUrl.match(githubUrlPattern);\n \n     if (!match) {\n", "test_patch": "", "problem_statement": "We need to handle this bug in input box for indexing repos on website\nhttps://github.com/user-attachments/assets/c7357a82-43c7-48ff-9289-67a72daab16b\n", "hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\nHi @Shashankss1205 , Shall I work on this?\n\n\n", "all_hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\nHi @Shashankss1205 , Shall I work on this?\n\n\n", "commit_urls": ["https://github.com/CodeGraphContext/CodeGraphContext/commit/7301ff186a0c8f42a3b89622d4bd62e306c2f88d", "https://github.com/CodeGraphContext/CodeGraphContext/commit/c28322c67e3d00ab5d5f14f45215799eb24fac3a", "https://github.com/CodeGraphContext/CodeGraphContext/commit/13ef790cce42101a1d34b930e364ecfaa6310d89"], "created_at": "2026-02-09T05:59:48Z"}
{"repo": "CodeGraphContext/CodeGraphContext", "pull_number": 620, "instance_id": "CodeGraphContext__CodeGraphContext-620", "issue_numbers": [612], "base_commit": "179955f56b347a6c82af3f1cef0bcdfb03cdabec", "patch": "diff --git a/README.md b/README.md\nindex ca31fe0f..9dc5cc2c 100644\n--- a/README.md\n+++ b/README.md\n@@ -209,7 +209,7 @@ Use CodeGraphContext as a **powerful command-line toolkit** for code analysis:\n \n #### \ud83e\udd16 Mode 2: MCP Server (AI-Powered)\n Use CodeGraphContext as an **MCP server** for AI assistants:\n-- Connect to AI IDEs (VS Code, Cursor, Windsurf, Claude, etc.)\n+- Connect to AI IDEs (VS Code, Cursor, Windsurf, Claude, Kiro, etc.)\n - Let AI agents query your codebase using natural language\n - Automatic code understanding and relationship analysis\n - Perfect for AI-assisted development workflows\n@@ -309,6 +309,7 @@ cgc help\n     *   Cline\n     *   RooCode\n     *   Amazon Q Developer\n+    *   Kiro\n \n     Upon successful configuration, `cgc mcp setup` will generate and place the necessary configuration files:\n     *   It creates an `mcp.json` file in your current directory for reference.\ndiff --git a/docs/docs/getting-started/installation.md b/docs/docs/getting-started/installation.md\nindex f00f1b6e..96820d60 100644\n--- a/docs/docs/getting-started/installation.md\n+++ b/docs/docs/getting-started/installation.md\n@@ -76,7 +76,7 @@ cgc doctor\n \n ## Step 4: Configure AI Assistant (For MCP Users)\n \n-If you plan to use CodeGraphContext with **Cursor**, **Claude**, or **VS Code**, you must configure the MCP server.\n+If you plan to use CodeGraphContext with **Cursor**, **Claude**, **VS Code**, or **Kiro**, you must configure the MCP server.\n \n 1.  **Run the MCP wizard:**\n     ```bash\n@@ -84,7 +84,7 @@ If you plan to use CodeGraphContext with **Cursor**, **Claude**, or **VS Code**,\n     ```\n \n 2.  **What it does:**\n-    *   \ud83d\udd0d **Asks you to choose** your IDE from a supported list (Cursor, VS Code, Claude, Windsurf, Cline, etc.).\n+    *   \ud83d\udd0d **Asks you to choose** your IDE from a supported list (Cursor, VS Code, Claude, Windsurf, Cline, Kiro, etc.).\n     *   \u2699\ufe0f **Updates** the configuration file (e.g., `mcp.json`) to invoke `cgc`.\n     *   \ud83d\udd10 **Saves** local database credentials so the AI can connect.\n \ndiff --git a/src/codegraphcontext/cli/setup_wizard.py b/src/codegraphcontext/cli/setup_wizard.py\nindex 2ac229c8..080a4837 100644\n--- a/src/codegraphcontext/cli/setup_wizard.py\n+++ b/src/codegraphcontext/cli/setup_wizard.py\n@@ -114,7 +114,7 @@ def _configure_ide(mcp_config):\n     questions = [\n         {\n             \"type\": \"confirm\",\n-            \"message\": \"Automatically configure your IDE/CLI (VS Code, Cursor, Windsurf, Claude, Gemini, Cline, RooCode, ChatGPT Codex, Amazon Q Developer, Aider)?\",\n+            \"message\": \"Automatically configure your IDE/CLI (VS Code, Cursor, Windsurf, Claude, Gemini, Cline, RooCode, ChatGPT Codex, Amazon Q Developer, Aider, Kiro)?\",\n             \"name\": \"configure_ide\",\n             \"default\": True,\n         }\n@@ -128,7 +128,7 @@ def _configure_ide(mcp_config):\n         {\n             \"type\": \"list\",\n             \"message\": \"Choose your IDE/CLI to configure:\",\n-            \"choices\": [\"VS Code\", \"Cursor\", \"Windsurf\", \"Claude code\", \"Gemini CLI\", \"ChatGPT Codex\", \"Cline\", \"RooCode\", \"Amazon Q Developer\", \"JetBrainsAI\", \"Aider\", \"None of the above\"],\n+            \"choices\": [\"VS Code\", \"Cursor\", \"Windsurf\", \"Claude code\", \"Gemini CLI\", \"ChatGPT Codex\", \"Cline\", \"RooCode\", \"Amazon Q Developer\", \"JetBrainsAI\", \"Aider\", \"Kiro\", \"None of the above\"],\n             \"name\": \"ide_choice\",\n         }\n     ]\n@@ -140,7 +140,7 @@ def _configure_ide(mcp_config):\n         return\n \n \n-    if ide_choice in [\"VS Code\", \"Cursor/CLI\", \"Claude code\", \"Gemini CLI\", \"ChatGPT Codex\", \"Cline\", \"Windsurf\", \"RooCode\", \"Amazon Q Developer , JetBrainsAI\", \"Aider\"]:\n+    if ide_choice in [\"VS Code\", \"Cursor/CLI\", \"Claude code\", \"Gemini CLI\", \"ChatGPT Codex\", \"Cline\", \"Windsurf\", \"RooCode\", \"Amazon Q Developer , JetBrainsAI\", \"Aider\", \"Kiro\"]:\n         console.print(f\"\\n[bold cyan]Configuring for {ide_choice}...[/bold cyan]\")\n \n         if ide_choice == \"Amazon Q Developer\":\n@@ -198,6 +198,11 @@ def _configure_ide(mcp_config):\n                 Path.home() / \"Library\" / \"Application Support\" / \"aider\" / \"settings.json\",\n                 Path.home() / \"AppData\" / \"Roaming\" / \"aider\" / \"settings.json\",\n                 Path.home() / \".config\" / \"Aider\" / \"User\" / \"settings.json\",\n+            ],\n+            \"Kiro\": [\n+                Path.home() / \".kiro\" / \"settings\" / \"mcp.json\",                                   # macOS / Linux / Windows (user-level global)\n+                Path.home() / \".config\" / \"kiro\" / \"settings\" / \"mcp.json\",                         # Linux (XDG config)\n+                Path.home() / \"AppData\" / \"Roaming\" / \"Kiro\" / \"settings\" / \"mcp.json\",             # Windows\n             ]\n         }\n \n", "test_patch": "", "problem_statement": "Add support for kiro code/cli in cgc mcp setup\nCheckout how we added VSCode, roocode, cursor etc etc\n", "hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\nI can work on this. \n\n", "all_hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\nI can work on this. \n\n", "commit_urls": ["https://github.com/CodeGraphContext/CodeGraphContext/commit/b787a26ea9f1a118c927bb7c17f686253097cf88"], "created_at": "2026-02-09T18:49:31Z"}
{"repo": "CodeGraphContext/CodeGraphContext", "pull_number": 654, "instance_id": "CodeGraphContext__CodeGraphContext-654", "issue_numbers": [627], "base_commit": "37ff6bc13e243fd4b86e27d1962b4c1a29d62a75", "patch": "diff --git a/src/codegraphcontext/cli/config_manager.py b/src/codegraphcontext/cli/config_manager.py\nindex 20a02841..cf62db60 100644\n--- a/src/codegraphcontext/cli/config_manager.py\n+++ b/src/codegraphcontext/cli/config_manager.py\n@@ -28,6 +28,7 @@\n     \"DEBUG_LOGS\": \"false\",\n     \"DEBUG_LOG_PATH\": str(Path.home() / \"mcp_debug.log\"),\n     \"ENABLE_APP_LOGS\": \"CRITICAL\",\n+    \"LIBRARY_LOG_LEVEL\": \"WARNING\",\n     \"LOG_FILE_PATH\": str(CONFIG_DIR / \"logs\" / \"cgc.log\"),\n     \"MAX_FILE_SIZE_MB\": \"10\",\n     \"IGNORE_TEST_FILES\": \"false\",\n@@ -54,6 +55,7 @@\n     \"DEBUG_LOGS\": \"Enable debug logging (for development/troubleshooting)\",\n     \"DEBUG_LOG_PATH\": \"Path to debug log file\",\n     \"ENABLE_APP_LOGS\": \"Application log level (DEBUG|INFO|WARNING|ERROR|CRITICAL|DISABLED)\",\n+    \"LIBRARY_LOG_LEVEL\": \"Log level for third-party libraries (neo4j, asyncio, urllib3) (DEBUG|INFO|WARNING|ERROR|CRITICAL)\",\n     \"LOG_FILE_PATH\": \"Path to application log file\",\n     \"MAX_FILE_SIZE_MB\": \"Maximum file size to index (in MB)\",\n     \"IGNORE_TEST_FILES\": \"Skip test files during indexing\",\n@@ -76,6 +78,7 @@\n     \"ALLOW_DB_DELETION\": [\"true\", \"false\"],\n     \"DEBUG_LOGS\": [\"true\", \"false\"],\n     \"ENABLE_APP_LOGS\": [\"DEBUG\", \"INFO\", \"WARNING\", \"ERROR\", \"CRITICAL\", \"DISABLED\"],\n+    \"LIBRARY_LOG_LEVEL\": [\"DEBUG\", \"INFO\", \"WARNING\", \"ERROR\", \"CRITICAL\"],\n     \"IGNORE_TEST_FILES\": [\"true\", \"false\"],\n     \"IGNORE_HIDDEN_FILES\": [\"true\", \"false\"],\n     \"ENABLE_AUTO_WATCH\": [\"true\", \"false\"],\ndiff --git a/src/codegraphcontext/cli/main.py b/src/codegraphcontext/cli/main.py\nindex a3e4e8ef..0bb7d0ff 100644\n--- a/src/codegraphcontext/cli/main.py\n+++ b/src/codegraphcontext/cli/main.py\n@@ -44,10 +44,24 @@\n     list_watching_helper,\n )\n \n-# Set the log level for the noisy neo4j, asyncio, and urllib3 loggers to WARNING to keep the output clean.\n-logging.getLogger(\"neo4j\").setLevel(logging.WARNING)\n-logging.getLogger(\"asyncio\").setLevel(logging.WARNING)\n-logging.getLogger(\"urllib3\").setLevel(logging.WARNING)\n+# Set the log level for the noisy neo4j, asyncio, and urllib3 loggers to keep the output clean.\n+# Get the log level from config, defaulting to WARNING\n+def _configure_library_loggers():\n+    \"\"\"Configure third-party library loggers based on config setting.\"\"\"\n+    try:\n+        log_level_str = config_manager.get_config_value('LIBRARY_LOG_LEVEL')\n+        if log_level_str is None:\n+            log_level_str = 'WARNING'\n+        log_level_str = str(log_level_str).upper()\n+        log_level = getattr(logging, log_level_str, logging.WARNING)\n+    except (AttributeError, Exception):\n+        log_level = logging.WARNING\n+    \n+    logging.getLogger(\"neo4j\").setLevel(log_level)\n+    logging.getLogger(\"asyncio\").setLevel(log_level)\n+    logging.getLogger(\"urllib3\").setLevel(log_level)\n+\n+_configure_library_loggers()\n \n \n # Import visualization module\n", "test_patch": "", "problem_statement": "The values here \"logging.WARNING\" should be picked up either as default i.e. Warning or from the config\n<img width=\"2402\" height=\"1216\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/59733dc5-02f9-442f-a9c5-0ef5323c468f\" />\n", "hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\n@Shashankss1205 can i work on this?\nHi @Shashankss1205 , Shall I work on this?\n\n\n", "all_hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\n@Shashankss1205 can i work on this?\nHi @Shashankss1205 , Shall I work on this?\n\n\n", "commit_urls": ["https://github.com/CodeGraphContext/CodeGraphContext/commit/08a1965638cc4dbe7818c251e2b5dac76603a105"], "created_at": "2026-02-24T18:48:19Z"}
{"repo": "CodeGraphContext/CodeGraphContext", "pull_number": 638, "instance_id": "CodeGraphContext__CodeGraphContext-638", "issue_numbers": [636], "base_commit": "584538f3792b97e0ea10a77285404c5a13bf98f3", "patch": "diff --git a/src/codegraphcontext/tools/languages/swift.py b/src/codegraphcontext/tools/languages/swift.py\nindex f3795984..79f19232 100644\n--- a/src/codegraphcontext/tools/languages/swift.py\n+++ b/src/codegraphcontext/tools/languages/swift.py\n@@ -9,27 +9,32 @@\n         [\n             (function_declaration\n                 name: (simple_identifier) @name\n-                parameters: (parameter)* @params\n             ) @function_node\n-            (init_declaration\n-                parameters: (parameter)* @params\n-            ) @init_node\n+            (init_declaration) @init_node\n         ]\n     \"\"\",\n     \"classes\": \"\"\"\n         [\n             (class_declaration\n+                declaration_kind: \"class\"\n                 name: (type_identifier) @name\n             ) @class\n-            (struct_declaration\n+            (class_declaration\n+                declaration_kind: \"struct\"\n                 name: (type_identifier) @name\n             ) @struct\n-            (enum_declaration\n+            (class_declaration\n+                declaration_kind: \"enum\"\n                 name: (type_identifier) @name\n             ) @enum\n-            (protocol_declaration\n+            (class_declaration\n+                declaration_kind: \"protocol\"\n                 name: (type_identifier) @name\n             ) @protocol\n+            (class_declaration\n+                declaration_kind: \"actor\"\n+                name: (type_identifier) @name\n+            ) @class\n         ]\n     \"\"\",\n     \"imports\": \"\"\"\n@@ -41,13 +46,13 @@\n     \"variables\": \"\"\"\n         [\n             (property_declaration\n-                (pattern) @pattern\n-            ) @variable\n-            (constant_declaration\n-                (pattern_binding\n-                    pattern: (simple_identifier) @name\n+                name: (pattern\n+                    bound_identifier: (simple_identifier) @name\n                 )\n-            ) @constant\n+            ) @variable\n+            (property_declaration\n+                name: (pattern) @pattern\n+            ) @variable\n         ]\n     \"\"\",\n }\n", "test_patch": "diff --git a/tests/unit/parsers/test_swift_parser.py b/tests/unit/parsers/test_swift_parser.py\nnew file mode 100644\nindex 00000000..64035b77\n--- /dev/null\n+++ b/tests/unit/parsers/test_swift_parser.py\n@@ -0,0 +1,65 @@\n+from unittest.mock import MagicMock\n+\n+import pytest\n+\n+from codegraphcontext.tools.languages.swift import SwiftTreeSitterParser\n+from codegraphcontext.utils.tree_sitter_manager import get_tree_sitter_manager\n+\n+\n+@pytest.fixture(scope=\"module\")\n+def swift_parser():\n+    manager = get_tree_sitter_manager()\n+    if not manager.is_language_available(\"swift\"):\n+        pytest.skip(\"Swift tree-sitter grammar is not available in this environment\")\n+\n+    wrapper = MagicMock()\n+    wrapper.language_name = \"swift\"\n+    wrapper.language = manager.get_language_safe(\"swift\")\n+    wrapper.parser = manager.create_parser(\"swift\")\n+    return SwiftTreeSitterParser(wrapper)\n+\n+\n+def test_parse_swift_declarations_with_current_grammar(swift_parser, temp_test_dir):\n+    code = \"\"\"\n+import Foundation\n+\n+struct MetricTracker {\n+    let sampleCount: Int\n+    func record(value: Int) {\n+        print(value)\n+    }\n+}\n+\n+enum ProcessingState {\n+    case idle\n+    case running\n+}\n+\n+actor TaskWorker {\n+    func compute() {}\n+}\n+\n+class GenericController {\n+    let name: String\n+\n+    init(name: String) {\n+        self.name = name\n+    }\n+\n+    func track() {\n+        print(name)\n+    }\n+}\n+\"\"\"\n+    f = temp_test_dir / \"sample.swift\"\n+    f.write_text(code)\n+\n+    result = swift_parser.parse(f)\n+\n+    assert len(result[\"functions\"]) >= 4\n+    assert any(item[\"name\"] == \"MetricTracker\" for item in result[\"structs\"])\n+    assert any(item[\"name\"] == \"ProcessingState\" for item in result[\"enums\"])\n+    assert any(item[\"name\"] == \"TaskWorker\" for item in result[\"classes\"])\n+    assert any(item[\"name\"] == \"GenericController\" for item in result[\"classes\"])\n+    assert len(result[\"imports\"]) == 1\n+    assert any(item[\"name\"] == \"sampleCount\" for item in result[\"variables\"])\n", "problem_statement": "Swift indexing returns zero symbols due to incompatible tree-sitter Swift queries\n## Summary\nOn `CodeGraphContext 0.2.2`, indexing a Swift codebase can complete successfully but still store `0` Swift symbols (`Function/Class`).\n\n## Environment\n- CodeGraphContext: `0.2.2`\n- Database backend: FalkorDB (reproduced in parser-only checks too)\n- Repo type: iOS Swift project\n\n## Repro\n1. Index a Swift repo:\n   ```bash\n   cgc index /path/to/swift-repo\n   ```\n2. Check stats:\n   ```bash\n   cgc stats /path/to/swift-repo\n   ```\n3. Observe `Functions=0`, `Classes=0` (despite many `.swift` files).\n\n## Root cause\n`tools/languages/swift.py` query patterns are incompatible with the currently loaded Swift tree-sitter grammar.\n\nExamples of runtime query errors:\n- `Invalid field name ... parameters`\n- `Invalid node type ... struct_declaration`\n- `Invalid node type ... constant_declaration`\n\nThe grammar in use represents many declarations as `class_declaration` + `declaration_kind` (`\"struct\"`, `\"enum\"`, `\"class\"`, `\"extension\"`, `\"actor\"`), rather than separate `struct_declaration`/`enum_declaration` nodes.\n\n## Suggested fix\nUpdate Swift queries to current grammar:\n- Functions:\n  - remove invalid `parameters:` field constraint from `function_declaration`\n  - keep `name: (simple_identifier)` capture\n- Types:\n  - match `class_declaration` with `declaration_kind: \"class\"|\"struct\"|\"enum\"|\"protocol\"|\"actor\"`\n  - capture `name: (type_identifier)`\n- Variables:\n  - replace `constant_declaration` query with `property_declaration` pattern captures\n\n## Validation after patch\nWith only Swift query updates applied locally, re-indexing the same repo produced non-zero Swift symbols (functions/structs/variables) and normal graph behavior.\n\nIf useful, I can open a PR with the exact query diff used to validate this.\n", "hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\nAdditional finding (same environment) on search behavior with FalkorDB:\n\n### FalkorDB `find_code` fulltext incompatibility + fallback recommendation\n- Current search paths use Neo4j fulltext procedure `db.index.fulltext.queryNodes(...)`.\n- On FalkorDB this can fail with: `Procedure db.index.fulltext.queryNodes is not registered`.\n\n#### Expected\n- `find_code` should still return results on FalkorDB without hard-failing.\n\n#### Suggested fallback behavior\n- When fulltext procedure throws, fall back to substring matching:\n  - Function/class name lookup: `toLower(node.name) CONTAINS toLower($term)`.\n  - Content lookup: substring on `node.name`, `node.source`, `node.docstring` for `Function|Class|Variable`.\n- This keeps FalkorDB usable for search, with the known tradeoff that ranking/edit-distance/fulltext relevance is reduced vs Neo4j fulltext.\n\nIf preferred, this could be tracked as a separate issue, but it was observed during the same Swift-indexing investigation.\nCorrection: please ignore my previous FalkorDB fallback comment on this issue. I split that into a dedicated issue for tracking:\n\n- https://github.com/CodeGraphContext/CodeGraphContext/issues/637\n\nKeeping this issue (`#636`) focused only on the Swift tree-sitter indexing/query incompatibility.\n\n", "all_hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\nAdditional finding (same environment) on search behavior with FalkorDB:\n\n### FalkorDB `find_code` fulltext incompatibility + fallback recommendation\n- Current search paths use Neo4j fulltext procedure `db.index.fulltext.queryNodes(...)`.\n- On FalkorDB this can fail with: `Procedure db.index.fulltext.queryNodes is not registered`.\n\n#### Expected\n- `find_code` should still return results on FalkorDB without hard-failing.\n\n#### Suggested fallback behavior\n- When fulltext procedure throws, fall back to substring matching:\n  - Function/class name lookup: `toLower(node.name) CONTAINS toLower($term)`.\n  - Content lookup: substring on `node.name`, `node.source`, `node.docstring` for `Function|Class|Variable`.\n- This keeps FalkorDB usable for search, with the known tradeoff that ranking/edit-distance/fulltext relevance is reduced vs Neo4j fulltext.\n\nIf preferred, this could be tracked as a separate issue, but it was observed during the same Swift-indexing investigation.\nCorrection: please ignore my previous FalkorDB fallback comment on this issue. I split that into a dedicated issue for tracking:\n\n- https://github.com/CodeGraphContext/CodeGraphContext/issues/637\n\nKeeping this issue (`#636`) focused only on the Swift tree-sitter indexing/query incompatibility.\n\n", "commit_urls": ["https://github.com/CodeGraphContext/CodeGraphContext/commit/cdf6e9f1554bfa85a329f98cd42253da0d4cad8e"], "created_at": "2026-02-13T01:21:00Z"}
{"repo": "CodeGraphContext/CodeGraphContext", "pull_number": 650, "instance_id": "CodeGraphContext__CodeGraphContext-650", "issue_numbers": [645], "base_commit": "584538f3792b97e0ea10a77285404c5a13bf98f3", "patch": "diff --git a/website/index.html b/website/index.html\nindex 40016846..3ad7ba2a 100644\n--- a/website/index.html\n+++ b/website/index.html\n@@ -8,10 +8,19 @@\n     <meta name=\"author\" content=\"Shashank Shekhar Singh\" />\n     <meta name=\"keywords\" content=\"code analysis, knowledge graph, AI assistant, MCP server, Python, Neo4j, code indexing\" />\n \n+    <!-- Open Graph meta tags -->\n     <meta property=\"og:title\" content=\"CodeGraphContext - AI-Powered Code Knowledge Graphs\" />\n     <meta property=\"og:description\" content=\"Transform your codebase into an intelligent knowledge graph for AI assistants. Index Python code, analyze relationships, and provide context.\" />\n     <meta property=\"og:type\" content=\"website\" />\n+    <meta property=\"og:url\" content=\"https://codegraphcontext.vercel.app\" />\n+    <meta property=\"og:image\" content=\"/preview-image.png\" />\n+\n+    <!-- Twitter Card meta tags -->\n     <meta name=\"twitter:card\" content=\"summary_large_image\" />\n+    <meta name=\"twitter:url\" content=\"https://codegraphcontext.vercel.app\" />\n+    <meta name=\"twitter:title\" content=\"CodeGraphContext - AI-Powered Code Knowledge Graphs\" />\n+    <meta name=\"twitter:description\" content=\"Transform your codebase into an intelligent knowledge graph for AI assistants. Index Python code, analyze relationships, and provide context.\" />\n+    <meta name=\"twitter:image\" content=\"/preview-image.png\" />\n   </head>\n \n   <body>\ndiff --git a/website/public/preview-image.png b/website/public/preview-image.png\nnew file mode 100644\nindex 00000000..d2236fcc\nBinary files /dev/null and b/website/public/preview-image.png differ\n", "test_patch": "", "problem_statement": "Add missing preview image in the preview card of the website\n### Description\nAdd missing preview image in the preview card of the website which helps in better social media sharing of the website.\n\n### Screenshots\n\n<img width=\"1896\" height=\"923\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/c3f48227-a362-4829-81e4-e172b2db51f4\" />\n<img width=\"622\" height=\"539\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/e7bc7db5-54a6-46b9-b13d-35277304cbbf\" />\n\n---\n\nPlease assign me this issue under SWOC'26.\n", "hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\n@Shashankss1205 Please assign me this issue under SWOC'26.\nHey @StephanosNikitis , assigned!!\n\n", "all_hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\n@Shashankss1205 Please assign me this issue under SWOC'26.\nHey @StephanosNikitis , assigned!!\n\n", "commit_urls": ["https://github.com/CodeGraphContext/CodeGraphContext/commit/bbd46527ebb516008504bb8958d4ef7c0e00e06b"], "created_at": "2026-02-22T17:34:15Z"}
{"repo": "CodeGraphContext/CodeGraphContext", "pull_number": 658, "instance_id": "CodeGraphContext__CodeGraphContext-658", "issue_numbers": [646], "base_commit": "37ff6bc13e243fd4b86e27d1962b4c1a29d62a75", "patch": "diff --git a/.gitignore b/.gitignore\nindex 872e4449..b5769987 100644\n--- a/.gitignore\n+++ b/.gitignore\n@@ -39,6 +39,18 @@ mcp.json\n # Docker\n docker-compose.yml \n \n+# macOS system files\n+.DS_Store\n+src/.DS_Store\n+src/codegraphcontext/.DS_Store\n+\n+# PR templates and guides\n+CGC_PR_DESCRIPTION.md\n+PR_SUBMISSION_GUIDE.txt\n+\n+# Ignore the PR submission script if not to be tracked\n+submit_pr.sh\n+\n # yaml file for amazon Q developer\n devfile.yaml \n \ndiff --git a/src/codegraphcontext/cli/config_manager.py b/src/codegraphcontext/cli/config_manager.py\nindex 20a02841..1c658a4d 100644\n--- a/src/codegraphcontext/cli/config_manager.py\n+++ b/src/codegraphcontext/cli/config_manager.py\n@@ -42,6 +42,7 @@\n     # SCIP indexer feature flag (default off \u2014 existing Tree-sitter behaviour unchanged)\n     \"SCIP_INDEXER\": \"false\",\n     \"SCIP_LANGUAGES\": \"python,typescript,go,rust,java\",\n+    \"SKIP_EXTERNAL_RESOLUTION\": \"false\",\n }\n \n # Configuration key descriptions\n@@ -67,6 +68,7 @@\n     \"INDEX_SOURCE\": \"Store full source code in graph database (for faster indexing use false, for better performance use true)\",\n     \"SCIP_INDEXER\": \"Use SCIP-based indexing for higher accuracy call/inheritance resolution (requires scip-<lang> tools installed)\",\n     \"SCIP_LANGUAGES\": \"Comma-separated languages to index via SCIP when SCIP_INDEXER=true (python,typescript,go,rust,java)\",\n+    \"SKIP_EXTERNAL_RESOLUTION\": \"Skip resolution attempts for external library method calls (recommended for enterprise large Java/Spring codebases)\",\n }\n \n # Valid values for each config key\n@@ -82,6 +84,7 @@\n     \"CACHE_ENABLED\": [\"true\", \"false\"],\n     \"INDEX_SOURCE\": [\"true\", \"false\"],\n     \"SCIP_INDEXER\": [\"true\", \"false\"],\n+    \"SKIP_EXTERNAL_RESOLUTION\": [\"true\", \"false\"],\n }\n \n \ndiff --git a/src/codegraphcontext/tools/graph_builder.py b/src/codegraphcontext/tools/graph_builder.py\nindex 7484789a..272dfed5 100644\n--- a/src/codegraphcontext/tools/graph_builder.py\n+++ b/src/codegraphcontext/tools/graph_builder.py\n@@ -461,6 +461,9 @@ def _create_function_calls(self, session, file_data: Dict, imports_map: dict):\n         local_imports = {imp.get('alias') or imp['name'].split('.')[-1]: imp['name'] \n                         for imp in file_data.get('imports', [])}\n         \n+        # Check if we should skip external resolution attempts - \n+        skip_external = (get_config_value(\"SKIP_EXTERNAL_RESOLUTION\") or \"false\").lower() == \"true\"\n+        \n         for call in file_data.get('function_calls', []):\n             called_name = call['name']\n             if called_name in __builtins__: continue\n@@ -517,7 +520,13 @@ def _create_function_calls(self, session, file_data: Dict, imports_map: dict):\n                                     break\n             \n             if not resolved_path:\n-                 warning_logger(f\"Could not resolve call {called_name} (lookup: {lookup_name}) in {caller_file_path}\")\n+                # Only log warning if we're not skipping external resolution\n+                if not skip_external:\n+                    warning_logger(f\"Could not resolve call {called_name} (lookup: {lookup_name}) in {caller_file_path}\")\n+                # Track that this was an unresolved external call\n+                is_unresolved_external = True\n+            else:\n+                is_unresolved_external = False\n             # else:\n             #      info_logger(f\"Resolved call {called_name} -> {resolved_path}\")\n             \n@@ -539,6 +548,7 @@ def _create_function_calls(self, session, file_data: Dict, imports_map: dict):\n             if not resolved_path:\n                 if called_name in local_names:\n                     resolved_path = caller_file_path\n+                    is_unresolved_external = False  # This is a local call, not external\n                 elif called_name in imports_map and imports_map[called_name]:\n                     # Check if any path in imports_map for called_name matches current file's imports\n                     candidates = imports_map[called_name]\n@@ -546,12 +556,17 @@ def _create_function_calls(self, session, file_data: Dict, imports_map: dict):\n                         for imp_name in local_imports.values():\n                             if imp_name.replace('.', '/') in path:\n                                 resolved_path = path\n+                                is_unresolved_external = False  # Found a match\n                                 break\n                         if resolved_path: break\n                     if not resolved_path:\n                         resolved_path = candidates[0]\n                 else:\n                     resolved_path = caller_file_path\n+            \n+            # Skip creating CALLS relationship for unresolved external calls when skip_external is enabled\n+            if skip_external and is_unresolved_external:\n+                continue\n \n             caller_context = call.get('context')\n             if caller_context and len(caller_context) == 3 and caller_context[0] is not None:\n", "test_patch": "diff --git a/tests/unit/core/test_skip_external_resolution.py b/tests/unit/core/test_skip_external_resolution.py\nnew file mode 100644\nindex 00000000..133d98a4\n--- /dev/null\n+++ b/tests/unit/core/test_skip_external_resolution.py\n@@ -0,0 +1,156 @@\n+\"\"\"\n+Unit tests for SKIP_EXTERNAL_RESOLUTION configuration option.\n+Tests config_manager.py and graph_builder.py integration.\n+\"\"\"\n+\n+import os\n+import asyncio\n+import pytest\n+from unittest.mock import MagicMock, patch, call\n+from codegraphcontext.cli.config_manager import (\n+    get_config_value,\n+    set_config_value,\n+    CONFIG_DESCRIPTIONS,\n+    CONFIG_VALIDATORS,\n+    DEFAULT_CONFIG\n+)\n+\n+\n+class TestSkipExternalResolutionConfig:\n+    \"\"\"Test the SKIP_EXTERNAL_RESOLUTION configuration cli option.\"\"\"\n+\n+    def test_config_exists_in_descriptions(self):\n+        \"\"\"Test that SKIP_EXTERNAL_RESOLUTION has a description.\"\"\"\n+        assert \"SKIP_EXTERNAL_RESOLUTION\" in CONFIG_DESCRIPTIONS\n+        assert len(CONFIG_DESCRIPTIONS[\"SKIP_EXTERNAL_RESOLUTION\"]) > 0\n+        assert \"external\" in CONFIG_DESCRIPTIONS[\"SKIP_EXTERNAL_RESOLUTION\"].lower()\n+\n+    def test_config_has_validator(self):\n+        \"\"\"Test that SKIP_EXTERNAL_RESOLUTION has valid values list.\"\"\"\n+        assert \"SKIP_EXTERNAL_RESOLUTION\" in CONFIG_VALIDATORS\n+        valid_values = CONFIG_VALIDATORS[\"SKIP_EXTERNAL_RESOLUTION\"]\n+        assert isinstance(valid_values, list)\n+        assert len(valid_values) == 2\n+\n+    def test_validator_accepts_true(self):\n+        \"\"\"Test that validator list includes 'true'.\"\"\"\n+        valid_values = CONFIG_VALIDATORS[\"SKIP_EXTERNAL_RESOLUTION\"]\n+        assert \"true\" in valid_values\n+\n+    def test_validator_accepts_false(self):\n+        \"\"\"Test that validator list includes 'false'.\"\"\"\n+        valid_values = CONFIG_VALIDATORS[\"SKIP_EXTERNAL_RESOLUTION\"]\n+        assert \"false\" in valid_values\n+\n+    def test_validator_rejects_invalid_values(self):\n+        \"\"\"Test that validator list does not include invalid values.\"\"\"\n+        valid_values = CONFIG_VALIDATORS[\"SKIP_EXTERNAL_RESOLUTION\"]\n+        assert \"yes\" not in valid_values\n+        assert \"no\" not in valid_values\n+        assert \"1\" not in valid_values\n+        assert \"0\" not in valid_values\n+        assert \"enabled\" not in valid_values\n+\n+    def test_default_value_is_false(self):\n+        \"\"\"Test that default value is 'false' for backward compatibility.\"\"\"\n+        from codegraphcontext.cli.config_manager import DEFAULT_CONFIG\n+        assert \"SKIP_EXTERNAL_RESOLUTION\" in DEFAULT_CONFIG\n+        assert DEFAULT_CONFIG[\"SKIP_EXTERNAL_RESOLUTION\"] == \"false\"\n+\n+    def test_set_and_get_config_value(self):\n+        \"\"\"Test setting and getting the configuration value.\"\"\"\n+        # Set to true\n+        set_config_value(\"SKIP_EXTERNAL_RESOLUTION\", \"true\")\n+        assert get_config_value(\"SKIP_EXTERNAL_RESOLUTION\").lower() == \"true\"\n+\n+        # Set to false\n+        set_config_value(\"SKIP_EXTERNAL_RESOLUTION\", \"false\")\n+        assert get_config_value(\"SKIP_EXTERNAL_RESOLUTION\").lower() == \"false\"\n+\n+    def test_environment_variable_override(self):\n+        \"\"\"Test that environment variable SKIP_EXTERNAL_RESOLUTION works.\"\"\"\n+        with patch.dict(os.environ, {\"SKIP_EXTERNAL_RESOLUTION\": \"true\"}):\n+            value = get_config_value(\"SKIP_EXTERNAL_RESOLUTION\")\n+            assert value == \"true\"\n+\n+        with patch.dict(os.environ, {\"SKIP_EXTERNAL_RESOLUTION\": \"false\"}):\n+            value = get_config_value(\"SKIP_EXTERNAL_RESOLUTION\")\n+            assert value == \"false\"\n+\n+\n+class TestSkipExternalResolutionBehavior:\n+    \"\"\"Test the behavior of SKIP_EXTERNAL_RESOLUTION in graph_builder.py\n+    \n+    Note: Full behavior testing requires Neo4j session mocking, which is complex.\n+    These tests verify the code structure and imports are correct.\n+    The actual behavior is tested implicitly through the integration tests.\n+    \"\"\"\n+\n+    def test_graph_builder_uses_config_value(self):\n+        \"\"\"Test that GraphBuilder imports and can call get_config_value.\"\"\"\n+        from codegraphcontext.tools.graph_builder import GraphBuilder\n+        from codegraphcontext.cli.config_manager import get_config_value\n+        \n+        # Verify the import exists and is callable\n+        assert callable(get_config_value)\n+        \n+        # Verify GraphBuilder class exists\n+        assert GraphBuilder is not None\n+\n+    def test_skip_external_logic_exists_in_code(self):\n+        \"\"\"Test that the skip_external logic is present in graph_builder.py\"\"\"\n+        import inspect\n+        from codegraphcontext.tools.graph_builder import GraphBuilder\n+        \n+        # Get source code of _create_function_calls method\n+        source = inspect.getsource(GraphBuilder._create_function_calls)\n+        \n+        # Verify key logic is present\n+        assert \"skip_external\" in source\n+        assert \"SKIP_EXTERNAL_RESOLUTION\" in source\n+        assert \"is_unresolved_external\" in source\n+        assert \"if skip_external and is_unresolved_external:\" in source\n+\n+\n+class TestBackwardCompatibility:\n+    \"\"\"Test that existing behavior is preserved when config is not set.\"\"\"\n+\n+    def test_default_behavior_unchanged(self):\n+        \"\"\"Test that default behavior matches original (warnings + attempts).\"\"\"\n+        # When SKIP_EXTERNAL_RESOLUTION is not set or is \"false\",\n+        # behavior should match original cgc behavior\n+        \n+        with patch.dict(os.environ, {}, clear=True):\n+            from codegraphcontext.cli.config_manager import get_config_value\n+            \n+            # Default should be None or \"false\"\n+            value = get_config_value(\"SKIP_EXTERNAL_RESOLUTION\")\n+            assert value is None or value.lower() == \"false\"\n+\n+    def test_existing_configs_not_affected(self):\n+        \"\"\"Test that other configuration options still work.\"\"\"\n+        # Setting SKIP_EXTERNAL_RESOLUTION should not affect other configs\n+        set_config_value(\"SKIP_EXTERNAL_RESOLUTION\", \"true\")\n+        set_config_value(\"INDEX_VARIABLES\", \"false\")\n+        \n+        assert get_config_value(\"SKIP_EXTERNAL_RESOLUTION\").lower() == \"true\"\n+        assert get_config_value(\"INDEX_VARIABLES\").lower() == \"false\"\n+\n+\n+# Integration test (would require actual Neo4j - marked as e2e)\n+@pytest.mark.e2e\n+class TestSkipExternalResolutionE2E:\n+    \"\"\"End-to-end tests for SKIP_EXTERNAL_RESOLUTION (requires Neo4j).\"\"\"\n+    \n+    def test_indexing_with_skip_external_enabled(self):\n+        \"\"\"Test full indexing cycle with SKIP_EXTERNAL_RESOLUTION=true.\"\"\"\n+        # This would be an actual integration test\n+        # Requires Neo4j running and test Java project\n+        # Should verify: no external warnings, only internal CALLS created\n+        pytest.skip(\"E2E test - requires Neo4j database\")\n+\n+    def test_performance_improvement(self):\n+        \"\"\"Test that indexing is faster with SKIP_EXTERNAL_RESOLUTION=true.\"\"\"\n+        # This would measure performance\n+        # Expected: significantly faster for Java projects with Spring/Commons\n+        pytest.skip(\"E2E test - requires Neo4j database and performance benchmarks\")\n", "problem_statement": "# Feature Request: Configuration to Skip External Library Resolution for Enterprise Java Codebases\n## Summary\n\nFor large Java codebases with heavy framework dependencies (Spring, Jakarta EE, etc.), the relationship building phase gets stuck in an infinite loop attempting to resolve external library method calls. This consumes significant CPU resources (6+ hours at 99% CPU) without making progress on building actual CALLS relationships for internal codebase methods.\n\n## Environment\n\n- **CodeGraphContext Version:** 0.2.1 (confirmed in 0.2.3 as well)\n- **Database:** Neo4j 5.x (Docker)\n- **Codebase:** Java application\n  - Files: 28,663 (85% Java, 8% Python, 5% JS/TS)\n  - Functions: 256,684 (237,828 Java, 219 Python)\n  - Classes: 35,017\n  - Heavy use of Spring Framework, Apache Commons, JUnit\n- **System:** macOS M-series, 36 GB RAM, 12 cores\n- **Configuration:**\n  ```bash\n  PARALLEL_WORKERS=8\n  INDEX_SOURCE=false\n  INDEX_VARIABLES=false\n  ```\n\n## Problem Description\n\n### What Happened\n\nDuring the relationship building phase, cgc spent **6 hours 13 minutes** at **99% Neo4j CPU** attempting to build CALLS relationships. Despite the high CPU usage:\n- **No disk writes** occurred for the final 5+ hours\n- Only **6.7% of Java functions** (15,896 of 237,828) ended up with CALLS relationships\n- **93.3% of relationship building** failed to complete\n\n### Root Cause Analysis\n\nLog analysis of the indexing session revealed:\n\n**Log Statistics (396,234 total lines):**\n- 261,261 INFO messages (66%) - \"Processing import\" messages\n- 134,973 WARNING messages (34%) - Mostly \"Could not resolve call\"\n- **134,959 warnings** specifically about unresolved external library method calls\n\n**Pattern Example:**\n```\nWARNING - Could not resolve call getLog (lookup: LogFactory) in .../AssociationTestBase.java\nWARNING - Could not resolve call assertEquals (lookup: Assert) in .../AssociationUtils.java\nWARNING - Could not resolve call Bean (lookup: Bean) in .../configuration/AppConfig.java\nWARNING - Could not resolve call entrySet (lookup: map) in .../EvaluatorUtil.java\nWARNING - Could not resolve call LinkedHashMap<> (lookup: LinkedHashMap<>) in .../EvaluatorUtil.java\n```\n\n### What Went Wrong\n\ncgc attempts to resolve **every method call** by querying the Neo4j database, including:\n- Spring Framework methods (e.g., `@Bean`, `LogFactory.getLog()`)\n- Apache Commons utilities\n- JUnit test methods (e.g., `Assert.assertEquals()`)\n- Java standard library methods (e.g., `Map.entrySet()`, `LinkedHashMap<>`)\n\nSince these external library methods don't exist in the local codebase:\n1. Each lookup queries Neo4j (expensive database operation)\n2. Lookup fails (method not in local database)\n3. Warning logged\n4. Process moves to next unresolved call\n5. **Repeat 134,959+ times**\n\n**Result:** All CPU time consumed on failed lookups instead of building internal codebase relationships.\n\n### Impact\n\n**Time Cost:**\n- 134,959 failed lookups \u00d7 ~1.5 seconds average = **56+ hours of wasted computation**\n- Actual runtime: 6h 13min terminated early (would have continued indefinitely)\n\n**Relationship Coverage:**\n- **Java:** 6.7% CALLS coverage (15,896 / 237,828 functions)\n- **Python:** 43.8% CALLS coverage (96 / 219 functions) - much better due to simpler dependencies\n- **Missing:** 221,932 Java function relationships never built\n\n**Team Impact:**\n- Cannot deploy to 50-engineer team with incomplete call graph\n- Limited value for \"find callers/callees\" queries\n- Forces engineers to index locally (8-12 hours each) instead of using centralized server\n\n## Proposed Solution\n\nAdd configuration options to control external dependency resolution:\n\n### Option 1: Skip External Resolution (Recommended)\n\n```bash\n# Skip resolution attempts for methods not found in local codebase\nSKIP_EXTERNAL_RESOLUTION=true\n```\n\n**Behavior:**\n- Attempt to resolve method call once\n- If not found in database \u2192 assume external library \u2192 skip and continue\n- No repeated lookups, no warnings logged\n\n### Option 2: Internal-Only Mode\n\n```bash\n# Only resolve method calls within the same codebase\nRESOLVE_INTERNAL_ONLY=true\n```\n\n**Behavior:**\n- Only attempt resolution for methods in files already indexed\n- Never query for external library methods\n- Fastest approach\n\n### Option 3: Resolution Depth Limit\n\n```bash\n# Limit depth of transitive dependency resolution\nMAX_CALL_RESOLUTION_DEPTH=1\n```\n\n**Behavior:**\n- `1` = Only resolve direct calls to internal methods\n- `2` = Resolve calls to methods that call other methods (1 level deep)\n- `unlimited` = Current behavior (default)\n\n### Option 4: External Library Whitelist\n\n```bash\n# Specify which external libraries to attempt resolving\nRESOLVE_EXTERNAL_LIBS=internal-only\n# or\nRESOLVE_EXTERNAL_LIBS=spring,apache-commons\n```\n\n**Behavior:**\n- `internal-only`: Skip all external libraries\n- Comma-separated list: Only attempt resolution for specified libraries\n- `all`: Current behavior (default)\n\n## Expected Benefits\n\nWith `SKIP_EXTERNAL_RESOLUTION=true`:\n\n**Performance:**\n- Eliminate 134,959+ wasteful database lookups\n- Reduce relationship building from 6+ hours to estimated **30-60 minutes**\n- 10-20x speedup for large Java enterprise projects\n\n**Relationship Coverage:**\n- Expected **80-95% CALLS coverage** for internal methods\n- Only missing relationships would be to genuinely external libraries (which is expected)\n\n**Scalability:**\n- Enable centralized server deployment for large teams\n- One-time indexing completes in reasonable timeframe (< 2 hours total)\n- 50 engineers \u00d7 8 hours saved = **400 engineer hours saved**\n\n## Workarounds (Current)\n\nNone effective. Current options:\n1. **Accept 6.7% coverage** - Limited call graph queries\n2. **Terminate early** - Stop relationship building phase manually\n3. **Selective indexing** - Index only modules without Spring (incomplete solution)\n4. **Wait indefinitely** - Process may never complete for large enterprise codebases\n\n## Related Information\n\n**Python Works Better:**\n- Python achieved 43.8% CALLS coverage (vs 6.7% Java)\n- Python has simpler import structure and fewer external dependencies\n- Suggests problem is specific to complex Java dependency graphs\n\n**Database Still Valuable Despite Limited CALLS:**\n- \u2705 All 256,684 functions indexed (searchable)\n- \u2705 All 35,017 classes indexed\n- \u2705 Complexity metrics complete\n- \u2705 IMPORTS relationships complete (232,485)\n- \u2705 INHERITS relationships complete (3,475)\n- \u2705 Dead code detection works (409+ unused functions found)\n- \u26a0\ufe0f Call graph queries limited (only 6.7% coverage)\n\n## Additional Context\n\n**Code Location:**\nThe resolution logic appears to be in [`graph_builder.py`](https://github.com/Shashankss1205/CodeGraphContext/blob/main/codegraphcontext/tools/graph_builder.py):\n\n```python\nif not resolved_path:\n    warning_logger(f\"Could not resolve call {called_name} (lookup: {lookup_name}) in {caller_file_path}\")\n```\n\n**Suggested Implementation:**\n```python\n# Check config\nskip_external = config.get(\"SKIP_EXTERNAL_RESOLUTION\", \"false\").lower() == \"true\"\n\nif not resolved_path:\n    if skip_external:\n        # Don't log warning, don't retry, just skip\n        continue\n    else:\n        # Current behavior\n        warning_logger(f\"Could not resolve call {called_name} (lookup: {lookup_name}) in {caller_file_path}\")\n```\n\n## Use Case\n\n**Target Users:**\n- Enterprise Java teams using Spring Boot, Jakarta EE\n- Large codebases (10K+ files) with heavy framework dependencies\n- Teams wanting to deploy centralized cgc server (50+ engineers)\n- DevOps teams integrating cgc into CI/CD pipelines\n\n**Prevalence:**\n- Most enterprise Java applications use Spring Framework\n- Apache Commons utilities extremely common\n- JUnit in virtually all Java projects\n- This issue likely affects majority of Java enterprise users\n\n## Request\n\nPlease add a configuration option to skip or limit external library resolution for large Java codebases. This would make cgc practical for enterprise teams and enable successful indexing of large Spring-based applications.\n\nHappy to provide additional logs, test the feature, or contribute a PR if needed.\n\n---\n\n**References:**\n- Indexing log: 396,234 lines, 134,959 unresolved call warnings\n- Database: Neo4j 2.6 GB, 791,240 nodes, 1.4M relationships\n- Repository: https://github.com/Shashankss1205/CodeGraphContext\n- Issue Type: Feature Request / Enhancement\n\n", "hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\nHey @k282 Can you try using the .cgcignore and a comparatively smaller repo for Java before jumping on to a larger project. Also, the idea looks cool and I will try adding this in the next version. https://codegraphcontext.github.io/CodeGraphContext/reference/cgcignore/\nI have made the code changes and the codegraphcontext can successfully complete. I will test the relationship graph for couple weeks and will contribute the code.\n\n", "all_hints_text": "Hi! \ud83d\udc4b Join our CodeGraphContext Discord channel to collaborate: https://discord.gg/dR4QY32uYQ\nHey @k282 Can you try using the .cgcignore and a comparatively smaller repo for Java before jumping on to a larger project. Also, the idea looks cool and I will try adding this in the next version. https://codegraphcontext.github.io/CodeGraphContext/reference/cgcignore/\nI have made the code changes and the codegraphcontext can successfully complete. I will test the relationship graph for couple weeks and will contribute the code.\n\n", "commit_urls": ["https://github.com/CodeGraphContext/CodeGraphContext/commit/69089e4599edb7c624a38a285d289fccfd894c4f", "https://github.com/CodeGraphContext/CodeGraphContext/commit/fe625bd5659bf443f8b8255ceb75ddcb521b71a0", "https://github.com/CodeGraphContext/CodeGraphContext/commit/e04e1231db05709b76b00b9641d87744d2ee9ba8", "https://github.com/CodeGraphContext/CodeGraphContext/commit/06da4af1fa28d055b576ccd2274a249270d7302d", "https://github.com/CodeGraphContext/CodeGraphContext/commit/17b04d87b5f6c8bb2a42d5cd32aaf1c6702e647c"], "created_at": "2026-02-25T21:59:30Z"}
{"repo": "CodeGraphContext/CodeGraphContext", "pull_number": 704, "instance_id": "CodeGraphContext__CodeGraphContext-704", "issue_numbers": [696], "base_commit": "20ea630580cca8f10cf6be72c205e293181e138e", "patch": "diff --git a/website/.gitignore b/website/.gitignore\nindex a547bf36..4329047f 100644\n--- a/website/.gitignore\n+++ b/website/.gitignore\n@@ -22,3 +22,5 @@ dist-ssr\n *.njsproj\n *.sln\n *.sw?\n+.vercel\n+.env*.local\ndiff --git a/website/src/pages/Playground/PlaygroundPage.tsx b/website/src/pages/Playground/PlaygroundPage.tsx\nindex 65dd0cbc..d2bee887 100644\n--- a/website/src/pages/Playground/PlaygroundPage.tsx\n+++ b/website/src/pages/Playground/PlaygroundPage.tsx\n@@ -6,16 +6,15 @@ import { processFiles } from './core/astWorker';\n import type { FileData, GraphData } from './core/astWorker';\n import { fetchRemoteRepo } from './core/remoteRepo';\n import { GraphCanvas, EDGE_STYLES } from './components/GraphCanvas';\n-import { CityCanvas } from './components/CityCanvas';\n-import { UploadCloud, Box, Search, Settings, HelpCircle, Heart, X, FileCode2, FileText, Link, Lock, Globe, Filter, ChevronRight, ChevronDown, Lightbulb, Share2, Menu, Pipette, Download, Twitter, MessageSquare, ExternalLink, Map } from 'lucide-react';\n+import { UploadCloud, Box, Search, Settings, HelpCircle, Heart, X, FileCode2, FileText, Link, Lock, Globe, Filter, ChevronRight, ChevronDown, Lightbulb, Share2, Menu, Pipette, Download, Twitter, MessageSquare, ExternalLink } from 'lucide-react';\n \n // Node colour map for search results (mirrors GitNexus Header.tsx)\n const NODE_TYPE_COLORS: Record<string, string> = {\n-  file:       '#22c55e',\n-  folder:     '#3b82f6',\n+  file:       '#3b82f6',\n+  folder:     '#6366f1',\n   class:      '#f59e0b',\n   interface:  '#ec4899',\n-  function:   '#ef5be8',\n+  function:   '#10b981',\n   method:     '#14b8a6',\n   struct:     '#f97316',\n   enum:       '#a78bfa',\n@@ -24,6 +23,8 @@ const NODE_TYPE_COLORS: Record<string, string> = {\n   default:    '#6b7280',\n };\n \n+const MOBILE_BREAKPOINT = 768;\n+\n function App() {\n   const [loading, setLoading] = useState(false);\n   const [progressMsg, setProgressMsg] = useState('');\n@@ -38,7 +39,12 @@ function App() {\n   const [repoUrl, setRepoUrl] = useState('');\n   const [repoToken, setRepoToken] = useState('');\n   const [explorerWidth, setExplorerWidth] = useState(260);\n-  const [isExplorerCollapsed, setIsExplorerCollapsed] = useState(false);\n+  const [isMobileView, setIsMobileView] = useState(() =>\n+    typeof window !== 'undefined' ? window.innerWidth < MOBILE_BREAKPOINT : false,\n+  );\n+  const [isExplorerCollapsed, setIsExplorerCollapsed] = useState(() =>\n+    typeof window !== 'undefined' ? window.innerWidth < MOBILE_BREAKPOINT : false,\n+  );\n   const [isResizing, setIsResizing] = useState(false);\n   const [collapsedPaths, setCollapsedPaths] = useState<Set<string>>(new Set());\n   const [customNodeColors, setCustomNodeColors] = useState<Record<string, string>>({});\n@@ -54,7 +60,22 @@ function App() {\n   const [searchParams, setSearchParams] = useSearchParams();\n   const actionProcessedRef = useRef(false);\n   const [isExportDropdownOpen, setIsExportDropdownOpen] = useState(false);\n-  const [viewMode, setViewMode] = useState<'2d' | '3d'>('2d');\n+\n+  useEffect(() => {\n+    const mediaQuery = window.matchMedia(`(max-width: ${MOBILE_BREAKPOINT - 1}px)`);\n+    const onChange = (event: MediaQueryListEvent) => setIsMobileView(event.matches);\n+\n+    setIsMobileView(mediaQuery.matches);\n+    mediaQuery.addEventListener('change', onChange);\n+\n+    return () => mediaQuery.removeEventListener('change', onChange);\n+  }, []);\n+\n+  useEffect(() => {\n+    if (isMobileView) {\n+      setIsExplorerCollapsed(true);\n+    }\n+  }, [isMobileView]);\n  \n   const performRemoteFetch = useCallback(async (url: string, token?: string) => {\n     if (!url.trim()) return;\n@@ -273,8 +294,13 @@ function App() {\n       <header className=\"flex items-center justify-between px-5 py-3 bg-deep border-b border-dashed border-border-subtle shrink-0 z-50\">\n \n         {/* Left: logo + project badge */}\n-        <div className=\"flex items-center gap-4\">\n-          <button className=\"md:hidden p-1.5 -ml-1 text-text-muted hover:text-white transition-colors\">\n+        <div className=\"flex min-w-0 items-center gap-4\">\n+          <button\n+            onClick={() => graphData && setIsExplorerCollapsed(prev => !prev)}\n+            className={`md:hidden p-1.5 -ml-1 text-text-muted transition-colors ${graphData ? 'hover:text-white' : 'cursor-not-allowed opacity-40'}`}\n+            disabled={!graphData}\n+            aria-label=\"Toggle explorer\"\n+          >\n             <Menu className=\"w-5 h-5\" />\n           </button>\n           <RouterLink to=\"/\" className=\"flex items-center gap-2.5 hover:opacity-80 transition-opacity\">\n@@ -296,8 +322,8 @@ function App() {\n \n         {/* Center: search (only when graph loaded) */}\n         {graphData ? (\n-          <div className=\"flex-1 max-w-md mx-6 relative\" ref={searchRef}>\n-            <div className=\"flex items-center gap-2.5 px-3.5 py-2 bg-surface border border-border-subtle rounded-lg transition-all focus-within:border-accent focus-within:ring-2 focus-within:ring-accent/20\">\n+          <div className=\"relative mx-2 flex-1 min-w-0 max-w-md sm:mx-6\" ref={searchRef}>\n+            <div className=\"flex w-full min-w-0 items-center gap-2.5 px-3.5 py-2 bg-surface border border-border-subtle rounded-lg transition-all focus-within:border-accent focus-within:ring-2 focus-within:ring-accent/20\">\n               <Search className=\"w-4 h-4 text-text-muted flex-shrink-0\" />\n               <input\n                 ref={inputRef}\n@@ -307,9 +333,9 @@ function App() {\n                 onChange={e => { setSearchQuery(e.target.value); setIsSearchOpen(true); }}\n                 onFocus={() => setIsSearchOpen(true)}\n                 onBlur={() => setTimeout(() => setIsSearchOpen(false), 150)}\n-                className=\"flex-1 bg-transparent border-none outline-none text-sm text-text-primary placeholder:text-text-muted\"\n+                className=\"min-w-0 flex-1 bg-transparent border-none outline-none text-sm text-text-primary placeholder:text-text-muted\"\n               />\n-              <kbd className=\"px-1.5 py-0.5 bg-elevated border border-border-subtle rounded text-[10px] text-text-muted font-mono\">\u2318K</kbd>\n+              <kbd className=\"hidden shrink-0 px-1.5 py-0.5 bg-elevated border border-border-subtle rounded text-[10px] text-text-muted font-mono md:inline-flex\">\u2318K</kbd>\n             </div>\n \n             {/* Search dropdown */}\n@@ -347,16 +373,16 @@ function App() {\n         )}\n \n         {/* Right: icons */}\n-        <div className=\"flex items-center gap-2\">\n+        <div className=\"flex shrink-0 items-center gap-2\">\n           {graphData && (\n             <div className=\"flex items-center gap-2\">\n               <div className=\"relative\">\n                 <button \n-                  className=\"px-3 h-9 flex items-center gap-2 rounded-md bg-purple-600/10 border border-purple-500/20 text-purple-400/60 cursor-not-allowed transition-all text-xs font-semibold\"\n+                  className=\"h-9 px-2 sm:px-3 flex items-center gap-2 rounded-md bg-purple-600/10 border border-purple-500/20 text-purple-400/60 cursor-not-allowed transition-all text-xs font-semibold\"\n                   title=\"Exporting features are coming soon!\"\n                 >\n                   <Share2 className=\"w-4 h-4\" />\n-                  <span>Work in Progress</span>\n+                  <span className=\"hidden sm:inline\">Work in Progress</span>\n                 </button>\n                 \n                 {isExportDropdownOpen && (\n@@ -397,22 +423,13 @@ function App() {\n                 )}\n               </div>\n \n-              <button \n-                onClick={() => setViewMode(prev => prev === '2d' ? '3d' : '2d')}\n-                className=\"px-3 h-9 flex items-center gap-2 rounded-md bg-accent/10 border border-accent/20 text-accent hover:bg-accent hover:text-white transition-all shadow-glow-soft text-xs font-medium\"\n-                title={viewMode === '2d' ? 'Switch to 3D City View' : 'Switch to 2D Graph View'}\n-              >\n-                {viewMode === '2d' ? <Map className=\"w-4 h-4\" /> : <Globe className=\"w-4 h-4\" />}\n-                <span>{viewMode === '2d' ? '3D City' : '2D Graph'}</span>\n-              </button>\n-\n               <button \n                 onClick={() => graphCanvasRef.current?.exportHTML()}\n-                className=\"px-3 h-9 flex items-center gap-2 rounded-md bg-accent/10 border border-accent/20 text-accent hover:bg-accent hover:text-white transition-all shadow-glow-soft text-xs font-medium\"\n+                className=\"h-9 px-2 sm:px-3 flex items-center gap-2 rounded-md bg-accent/10 border border-accent/20 text-accent hover:bg-accent hover:text-white transition-all shadow-glow-soft text-xs font-medium\"\n                 title=\"Download Standalone Interactive HTML\"\n               >\n                 <Download className=\"w-4 h-4\" />\n-                <span>Download Graph</span>\n+                <span className=\"hidden sm:inline\">Download Graph</span>\n               </button>\n             </div>\n           )}\n@@ -530,7 +547,7 @@ function App() {\n                   {/* Resize Handle */}\n                   <div \n                     onMouseDown={startResizing}\n-                    className=\"absolute top-0 right-0 w-1 h-full cursor-col-resize hover:bg-accent/40 active:bg-accent transition-colors z-20\"\n+                    className=\"absolute top-0 right-0 z-20 hidden h-full w-1 cursor-col-resize transition-colors hover:bg-accent/40 active:bg-accent md:block\"\n                   />\n                 </div>\n               ) : (\n@@ -547,48 +564,35 @@ function App() {\n             </div>\n             {/* Graph Canvas */}\n             <div className=\"flex-1 relative min-w-0\">\n-              {viewMode === '2d' ? (\n-                <GraphCanvas \n-                  ref={graphCanvasRef}\n-                  data={graphData} \n-                  onReset={() => { setGraphData(null); setSelectedFile(null); setIllustratedPath(null); setSelectedNodeLabel(null); }}\n-                  selectedFile={selectedFile}\n-                  selectedPath={illustratedPath}\n-                  customNodeColors={customNodeColors}\n-                  customEdgeColors={customEdgeColors}\n-                  visibleNodeTypes={visibleNodeTypes}\n-                  visibleEdgeTypes={visibleEdgeTypes}\n-                  onNodeClick={(file, label) => {\n-                    setSelectedFile(file);\n-                    setSelectedNodeLabel(label);\n-                  }}\n-                  onStageClick={() => {\n-                     setIllustratedPath(null);\n-                     setSelectedFile(null);\n-                     setSelectedNodeLabel(null);\n-                  }}\n-                />\n-              ) : (\n-                <CityCanvas\n-                  data={graphData}\n-                  visibleNodeTypes={visibleNodeTypes}\n-                  visibleEdgeTypes={visibleEdgeTypes}\n-                  customNodeColors={customNodeColors}\n-                  onNodeClick={(file, label) => {\n-                    setSelectedFile(file);\n-                    setSelectedNodeLabel(label);\n-                  }}\n-                />\n-              )}\n+              <GraphCanvas \n+                ref={graphCanvasRef}\n+                data={graphData} \n+                onReset={() => { setGraphData(null); setSelectedFile(null); setIllustratedPath(null); setSelectedNodeLabel(null); }}\n+                selectedFile={selectedFile}\n+                selectedPath={illustratedPath}\n+                customNodeColors={customNodeColors}\n+                customEdgeColors={customEdgeColors}\n+                visibleNodeTypes={visibleNodeTypes}\n+                visibleEdgeTypes={visibleEdgeTypes}\n+                onNodeClick={(file, label) => {\n+                  setSelectedFile(file);\n+                  setSelectedNodeLabel(label);\n+                }}\n+                onStageClick={() => {\n+                   setIllustratedPath(null);\n+                   setSelectedFile(null);\n+                   setSelectedNodeLabel(null);\n+                }}\n+              />\n               \n               {/* Type Toggles Floating Panel */}\n               <div className=\"absolute top-4 left-4 z-20 flex flex-col gap-4\">\n                 <div className={`bg-[#12121c]/90 border border-[#2a2a3a] rounded-xl backdrop-blur-md shadow-2xl transition-all duration-300 overflow-hidden ${isFiltersCollapsed ? 'w-10 h-10' : 'px-4 py-3 max-w-xs'}`}>\n-                  <div className={`flex items-center justify-between ${isFiltersCollapsed ? 'w-full h-full flex justify-center items-center' : 'mb-3 border-b border-border-subtle/50 pb-2'}`}>\n+                  <div className={isFiltersCollapsed ? 'flex w-full h-full items-center justify-center' : 'mb-3 flex items-center justify-between border-b border-border-subtle/50 pb-2'}>\n                     {!isFiltersCollapsed && <span className=\"text-[11px] font-bold text-text-muted uppercase tracking-wider font-mono\">Filters</span>}\n                     <button \n                       onClick={() => setIsFiltersCollapsed(!isFiltersCollapsed)}\n-                      className=\"p-1.5 rounded-md hover:bg-white/10 transition-colors\"\n+                      className={`flex items-center justify-center rounded-md hover:bg-white/10 transition-colors ${isFiltersCollapsed ? 'w-full h-full p-0' : 'p-1.5'}`}\n                       title={isFiltersCollapsed ? 'Expand Filters' : 'Collapse Filters'}\n                     >\n                       <Filter className={`w-3.5 h-3.5 text-text-m