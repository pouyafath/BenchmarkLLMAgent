+    def scm_to_conandata(self, conandata_key="scm", remote="origin", repository=False):
+        """
+        Updates the conandata.yml file with SCM information (URL and commit).
+
+        This is a convenience method that combines ``get_url_and_commit()`` with
+        ``update_conandata()`` to provide a one-liner for capturing SCM coordinates.
+
+        :param conandata_key: Key to use in conandata.yml (default: "scm").
+        :param remote: Name of the remote git repository ('origin' by default).
+        :param repository: By default gets the commit of the defined folder, use repo=True to get
+                         the commit of the repository instead.
+        """
+        from conan.tools.files import update_conandata
+        url, commit = self.get_url_and_commit(remote=remote, repository=repository)
+        update_conandata(self._conanfile, {conandata_key: {"commit": commit, "url": url}})
+
