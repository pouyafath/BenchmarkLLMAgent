+@keras_export("keras.ops.stop_gradient")
+def stop_gradient(x):
+    """
+    Stop gradient propagation for a tensor or KerasTensor.
+
+    This mirrors `tf.stop_gradient` but also supports symbolic `KerasTensor`
+    objects used in the Keras functional API. When a symbolic tensor is
+    provided, the operation returns a new symbolic tensor with the same
+    shape, dtype, and sparsity, ensuring the graph can be built without
+    invoking TensorFlow's eager `tf.stop_gradient` on a placeholder.
+    """
