 logger = logging.getLogger(__name__)
 
+# ---------------------------------------------------------------------------
+# Helper: Decorator to ensure any unexpected exception is logged with a proper
+# formatted message.  Using ``logger.exception`` guarantees that the traceback
+# is included and that the exception object is converted to a string safely.
+# This addresses issues where ``logger.error`` was previously called with an
+# exception object that could not be formatted correctly, causing the logging
+# itself to raise an exception and hide the original error.
+# ---------------------------------------------------------------------------
+def _log_exceptions(func):
+    """Wrap a function to log any exception before re‑raising it."""
+    @functools.wraps(func)
+    def wrapper(*args, **kwargs):
+        try:
+            return func(*args, **kwargs)
+        except Exception as exc:  # pylint: disable=broad-except
+            # ``logger.exception`` formats the message safely and adds the
+            # traceback, avoiding formatting errors that occurred with
+            # ``logger.error`` when the exception object was passed directly.
+            logger.exception("Unhandled exception in %s: %s", func.__name__, exc)
+            raise
+    return wrapper
+
