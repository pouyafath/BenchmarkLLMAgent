                                                                    ldap.py:349\n           DEBUG    Trying to authenticate using plaintext with domain                                                                                                                                                                                                                             connection.py:498\n           INFO     Connecting to ldap://meereen.essos.local - DC=essos,DC=local - 192.168.56.12 [3]                                                                                                                                                                                                     ldap.py:510\n           DEBUG    Search Filter=(userAccountControl:1.2.840.113556.1.4.803:=8192)                                                                                                                                                                                                                      ldap.py:705\n           DEBUG    Search Filter=(|(objectSid=S-1-5-21-172464323-4131766124-2513152192-512)(objectSid=S-1-5-21-172464323-4131766124-2513152192-544)(objectSid=S-1-5-21-172464323-4131766124-2513152192-519)(objectSid=S-1-5-32-549)(objectSid=S-1-5-32-551))                                            ldap.py:705\n           DEBUG    Search Filter=(&(objectCategory=user)(sAMAccountName=khal.drogo)(|(memberOf:1.2.840.113556.1.4.1941:=CN=Server Operators,CN=Builtin,DC=essos,DC=local)(memberOf:1.2.840.113556.1.4.1941:=CN=Backup                                                                                   ldap.py:705\n                    Operators,CN=Builtin,DC=essos,DC=local)(memberOf:1.2.840.113556.1.4.1941:=CN=Domain Admins,CN=Users,DC=essos,DC=local)(memberOf:1.2.840.113556.1.4.1941:=CN=Enterprise Admins,CN=Users,DC=essos,DC=local)))                                                                                     \n           DEBUG    Adding credential: essos.local/khal.drogo:horse                                                                                                                                                                                                                                      ldap.py:514\n           DEBUG    Adding credentials: [{'id': 26, 'domain': 'essos.local', 'username': 'khal.drogo', 'password': 'horse', 'credtype': 'plaintext', 'pillaged_from_hostid': None}]                                                                                                                  database.py:155\n[00:02:03] INFO     LDAP        192.168.56.12   389    MEEREEN          essos.local\\khal.drogo:horse                                                                                                                                                                                                     ldap.py:518\n           DEBUG    Calling command arguments                                                                                                                                                                                                                                                      connection.py:253\n           DEBUG    Calling dc_list()                                                                                                                                                                                                                                                              connection.py:275\n           DEBUG    DNS Server option: None, using DNS server: ['192.168.56.12']                                                                                                                                                                                                                         ldap.py:825\n           INFO     Enumerating Domain Controllers in current domain...                                                                                                                               