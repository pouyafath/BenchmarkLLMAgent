{"repo": "mlcommons/inference", "pull_number": 2439, "instance_id": "mlcommons__inference-2439", "issue_numbers": [2429], "base_commit": "36c8d3ac00bf71795063cb857791be131209b011", "patch": "diff --git a/.github/workflows/auto-update-dev.yml b/.github/workflows/auto-update-dev.yml\nindex 1eaf1a987e..f75f9874ba 100644\n--- a/.github/workflows/auto-update-dev.yml\n+++ b/.github/workflows/auto-update-dev.yml\n@@ -3,7 +3,7 @@ name: Auto-Update Dev Branches from Master\n on:\n   push:\n     branches:\n-      - master  # Trigger workflow on commits to 'master' branch\n+      - master  # Trigger workflow on commits to 'master' branch.\n   workflow_dispatch: {}\n \n jobs:\ndiff --git a/recommendation/dlrm_v3/generative_recommenders/common.py b/recommendation/dlrm_v3/generative_recommenders/common.py\nindex 3b9ca73bb8..797e2851ec 100644\n--- a/recommendation/dlrm_v3/generative_recommenders/common.py\n+++ b/recommendation/dlrm_v3/generative_recommenders/common.py\n@@ -31,9 +31,8 @@\n from triton.runtime.autotuner import Autotuner\n \n try:\n-    torch.ops.load_library(\"//deeplearning/fbgemm/fbgemm_gpu:sparse_ops\")\n-    torch.ops.load_library(\"//deeplearning/fbgemm/fbgemm_gpu:sparse_ops_cpu\")\n-except OSError:\n+    import fbgemm_gpu  # noqa: F401\n+except ImportError:\n     pass\n \n try:\ndiff --git a/recommendation/dlrm_v3/generative_recommenders/modules/dynamic_stu.py b/recommendation/dlrm_v3/generative_recommenders/modules/dynamic_stu.py\nindex c8d5d4cdbf..a603e8c491 100644\n--- a/recommendation/dlrm_v3/generative_recommenders/modules/dynamic_stu.py\n+++ b/recommendation/dlrm_v3/generative_recommenders/modules/dynamic_stu.py\n@@ -27,11 +27,9 @@\n     hstu_split_l2_embeddings,\n )\n \n-\n try:\n-    torch.ops.load_library(\"//deeplearning/fbgemm/fbgemm_gpu:sparse_ops\")\n-    torch.ops.load_library(\"//deeplearning/fbgemm/fbgemm_gpu:sparse_ops_cpu\")\n-except OSError:\n+    import fbgemm_gpu  # noqa: F401\n+except ImportError:\n     pass\n \n \ndiff --git a/recommenda