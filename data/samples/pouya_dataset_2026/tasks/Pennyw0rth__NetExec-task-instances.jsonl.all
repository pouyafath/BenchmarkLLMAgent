   \n                    \u2502                                                                                                                                                                                                                                                                            \u2502                  \n                    \u2502    820 \u2502                                                                                                                                                                                                                                                                   \u2502                  \n                    \u2502    821 \u2502   def dc_list(self):                                                                                                                                                                                                                                              \u2502                  \n                    \u2502    822 \u2502   \u2502   # Building the search filter                                                                                                                                                                                                                                \u2502                  \n                    \u2502 \u2771  823 \u2502   \u2502   resolv = resolver.Resolver()                                                                                                                                                                                                                                \u2502                  \n                    \u2502    824 \u2502   \u2502   if self.args.dns_server:                                                                                                                                                                                                                                    \u2502                  \n                    \u2502    825 \u2502   \u2502   \u2502   resolv.nameservers = [self.args.dns_server]                                                                                                                                                                                                             \u2502                  \n                    \u2502    826 \u2502   \u2502   else:                                                                                                                                                                                                                                                       \u2502                  \n                    \u2502                                                                                                                                                                                                                                                                            \u2502                  \n                    \u2502 /home/pb/.local/share/pipx/venvs/netexec/lib/python3.13/site-packages/dns/resolver.py:945 in __init__                                                                                                                                                                      \u2502                  \n                    \u2502                                                                                                                                                                                                                                                                            \u2502                  \n                    \u2502    942 \u2502   \u2502   \u2502   if sys.platform == \"win32\":  # pragma: no cover                                                                                                                                                                                                         \u2502                  \n                    \u2502    943 \u2502   \u2502   \u2502   \u2502   self.read_registry()                                                                                                                                                                                                                                \u2502                  \n                    \u2502    944 \u2502   \u2502   \u2502   elif filename:                                                                                                                                                                                                                                          \u2502                  \n                    \u2502 \u2771  945 \u2502   \u2502   \u2502   \u2502   self.read_resolv_conf(filename)                                                                                                                                                                                                                     \u2502                  \n                    \u2502    946 \u2502                                                                                                                                                                                                                                                                   \u2502                  \n                    \u2502    947 \u2502   def reset(self) -> None:                                                                                                                                                                                                                                        \u2502                  \n                    \u2502    948 \u2502   \u2502   \"\"\"Reset all resolver configuration to the defaults.\"\"\"                                                                                                                                                                                                     \u2502                  \n                    \u2502                                                                                                                                                                                                                                                                            \u2502                  \n                    \u2502 /home/pb/.local/share/pipx/venvs/netexec/lib/python3.13/site-packages/dns/resolver.py:1039 in read_resolv_conf                                                                                                                                                             \u2502                  \n                    \u2502                                                                                                                                                                                                                                                                            \u2502                  \n                    \u2502   1036 \u2502   \u2502   \u2502   \u2502   \u2502   \u2502   \u2502   except (ValueError, IndexError):                                                                                                                                                                                                        \u2502                  \n                    \u2502   1037 \u2502   \u2502   \u2502   \u2502   \u2502   \u2502   \u2502   \u2502   pass                                                                                                                                                                                                                                \u2502                  \n                    \u2502   1038 \u2502   \u2502   if len(nameservers) == 0:                                                                                                                                                                                                                                   \u2502                  \n                    \u2502 \u2771 1039 \u2502   \u2502   \u2502   raise NoResolverConfiguration(\"no nameservers\")                                                                                                                                                                                                         \u2502                  \n                    \u2502   1040 \u2502   \u2502   # Assigning directly instead of appending means we invoke the                                                                                                                                                                                               \u2502                  \n                    \u2502   1041 \u2502   \u2502   # setter logic, with additonal checking and enrichment.                                                                                                                                                                                                     \u2502                  \n                    \u2502   1042 \u2502   \u2502   self.nameservers = nameservers                                                                                                                                                                                                                              \u2502                  \n                    \u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f                  \n                    NoResolverConfiguration: no nameservers                                                                                                                                                                                                                                                         \n           DEBUG    Closing connection to: 192.168.56.12  \n```\n@seihtam What DNS resolver is your host using? can you `cat /etc/resolv.conf`?\n`/etc/resolv.conf` is empty:\n\n```\ncat /etc/resolv.conf\n# Generated by NetworkManager\n```\n\nI hardcoded the IPs in `/etc/hosts` as specified in the earlier comment.\n`/etc/hosts` is not a DNS resolver in this context though (it's not a \"nameserver\"), that's the issue, we attempt to use an actual resolver (nameserver) to query but your system does not have one configured.\nThat being said, I would think that `--dns-server` would set this internally and it would work, so we'll have to look into why that isn't happening.\nYes that's the problem!\n\nChanged the DNS in my network settings to 192.168.56.10 (which was \"Automatic\" before):\n\n<img width=\"725\" height=\"230\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/7e34610b-591c-493f-80cb-b5ab1de3013c\" />\n\nAnd now it works:\n```\nnxc ldap 192.168.56.12 -u 'khal.drogo' -p 'horse' --dc-list                                     \nLDAP        192.168.56.12   389    MEEREEN          [*] Windows 10 / Server 2016 Build 14393 (name:MEEREEN) (domain:essos.local) (signing:None) (channel binding:Never) \nLDAP        192.168.56.12   389    MEEREEN          [+] essos.local\\khal.drogo:horse \nLDAP        192.168.56.12   389    MEEREEN          meereen.essos.local = 192.168.56.12\nLDAP        192.168.56.12   389    MEEREEN          [+] Found DC in trusted domain: kingslanding.sevenkingdoms.local\nLDAP        192.168.56.12   389    MEEREEN          sevenkingdoms.local -> Bidirectional -> Forest Transitive\nLDAP        192.168.56.12   389    MEEREEN          kingslanding.sevenkingdoms.local = 192.168.56.10\n```\n\nGlad to see it's working for you now.\n\nI think we should still update the error message to be clear to the user, and also see why using `--dns-server` isn't properly setting the nameserver to use for resolving.\nTested the pull request #875 and now it works without setting up the system DNS or using `--dns-server`:\n```\nnetexec-env/bin/nxc ldap 192.168.56.12 -u 'khal.drogo' -p 'horse' --dc-list --debug\n[00:02:03] DEBUG    NXC VERSION: 1.4.0 - SmoothOperator - 40f57248 - 818                                                                                                                                                                                                                               netexec.py:82\n           DEBUG    PYTHON VERSION: 3.13.3 (main, Apr 10 2025, 21:38:51) [GCC 14.2.0]                                                                                                                                                                                                                  netexec.py:83\n           DEBUG    RUNNING ON: Linux Release: 6.12.25-amd64                                                                                                                                                                                                                                           netexec.py:84\n           DEBUG    Passed args: Namespace(version=False, threads=256, timeout=None, jitter=None, verbose=False, debug=True, no_progress=False, log=None, force_ipv6=False, dns_server=None, dns_tcp=False, dns_timeout=3, protocol='ldap', target=['192.168.56.12'], username=['khal.drogo'],         netexec.py:85\n                    password=['horse'], cred_id=[], ignore_pw_decoding=False, no_bruteforce=False, continue_on_success=False, gfail_limit=None, ufail_limit=None, fail_limit=None, kerberos=False, use_kcache=False, aesKey=None, kdcHost=None, pfx_cert=None, pfx_base64=None, pfx_pass=None,                      \n                    pem_cert=None, pem_key=None, module=None, module_options=[], list_modules=False, show_module_options=False, hash=[], port=389, domain=None, local_auth=False, asreproast=None, kerberoasting=None, no_preauth_targets=None, base_dn=None, query=None, find_delegation=False,                    \n                    trusted_for_delegation=False, password_not_required=False, admin_count=False, users=None, users_export=None, groups=None, computers=False, dc_list=True, get_sid=False, active_users=None, pso=False, gmsa=False, gmsa_convert_id=None, gmsa_decrypt_lsa=None, bloodhound=False,                \n                    collection='Default')                                                                                                                                                                                                                                                                           \n           DEBUG    Protocol: ldap                                                                                                                                                                                                                                                                    netexec.py:138\n           DEBUG    Protocol Path: /home/pb/nxc_test/netexec-env/lib/python3.13/site-packages/nxc/protocols/ldap.py                                                                                                                                                                                   netexec.py:141\n           DEBUG    Protocol DB Path: /home/pb/nxc_test/netexec-env/lib/python3.13/site-packages/nxc/protocols/ldap/database.py                                                                                                                                                                       netexec.py:143\n           DEBUG    Protocol Object: <class 'protocol.ldap'>, type: <class 'type'>                                                                                                                                                                                                                    netexec.py:146\n           DEBUG    Protocol DB Object: <class 'protocol.database'>                                                                                                                                                                                                                                   netexec.py:148\n           DEBUG    DB Path: /home/pb/.nxc/workspaces/default/ldap.db                                                                                                                                                                                                                                 netexec.py:151\n           DEBUG    Creating ThreadPoolExecutor                                                                                                                                                                                                                    