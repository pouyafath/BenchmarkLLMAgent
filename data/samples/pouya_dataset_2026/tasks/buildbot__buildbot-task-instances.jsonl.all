rder-color: var(--bb-card-border-color);\n+  }\n+\n+  .card-header {\n+    background-color: var(--bb-card-bg-color);\n+    border-bottom-color: var(--bb-card-border-color);\n+    color: var(--bb-card-header-text-color);\n+  }\n+\n+  .card-body {\n+    background-color: var(--bb-background-color);\n+    color: var(--bb-text-color);\n+  }\n+\n+  .form-control {\n+    background-color: var(--bb-background-color);\n+    border-color: var(--bb-btn-border-color);\n+    color: var(--bb-text-color);\n+  }\n+\n+  .form-control:focus {\n+    background-color: var(--bb-background-color);\n+    color: var(--bb-text-color);\n+  }\n+\n+  .navbar {\n+    background-color: var(--bb-card-bg-color) !important;\n+    border-color: var(--bb-border-color);\n+  }\n+\n+  .navbar-brand,\n+  .navbar-text {\n+    color: var(--bb-text-color) !important;\n+  }\n+\n+  .navbar .nav-link {\n+    // In light mode, falls back to Bootstrap's original rgba(0,0,0,.5).\n+    // In dark mode, ThemeManager sets --bb-navbar-link-color to a readable value.\n+    color: var(--bb-navbar-link-color, rgba(0, 0, 0, 0.5));\n+  }\n+\n+  .breadcrumb {\n+    background-color: var(--bb-card-bg-color);\n+    color: var(--bb-text-color);\n+  }\n+\n+  .list-group-item {\n+    background-color: var(--bb-background-color);\n+    border-color: var(--bb-card-border-color);\n+    color: var(--bb-text-color);\n+  }\n+\n+  .table {\n+    color: var(--bb-text-color);\n+  }\n+\n+  .table-striped tbody tr:nth-of-type(odd) {\n+    background-color: var(--bb-card-bg-color);\n+  }\n+\n+  .table td,\n+  .table th {\n+    border-color: var(--bb-border-color);\n+  }\n+\n+  .table-hover tbody tr:hover {\n+    color: var(--bb-text-color);\n+    background-color: var(--bb-card-bg-color);\n+  }\n+\n+  .table thead th {\n+    color: var(--bb-text-color);\n+    border-color: var(--bb-border-color);\n+  }\n+\n+  .modal-content {\n+    background-color: var(--bb-background-color);\n+    border-color: var(--bb-border-color);\n+    color: var(--bb-text-color);\n+  }\n+\n+  .modal-header {\n+    border-bottom-color: var(--bb-border-color);\n+  }\n+\n+  .modal-footer {\n+    border-top-color: var(--bb-border-color);\n+  }\n+\n+  .form-check-label {\n+    color: var(--bb-text-color);\n+  }\n+\n+  select.form-control,\n+  .custom-select {\n+    background-color: var(--bb-background-color);\n+    border-color: var(--bb-btn-border-color);\n+    color: var(--bb-text-color);\n+    color-scheme: light dark;\n+  }\n+\n+  .dropdown-menu {\n+    background-color: var(--bb-background-color);\n+    border-color: var(--bb-border-color);\n+  }\n+\n+  .dropdown-item {\n+    color: var(--bb-text-color);\n+  }\n+\n+  .dropdown-item:hover,\n+  .dropdown-item:focus {\n+    background-color: var(--bb-card-bg-color);\n+    color: var(--bb-text-color);\n+  }\n+\n+  pre:not(.log) {\n+    color: var(--bb-text-color);\n+    background-color: var(--bb-card-bg-color);\n+    border-color: var(--bb-border-color);\n+  }\n+\n+  code {\n+    color: var(--bb-text-color);\n+  }\n+\n+  .page-link {\n+    background-color: var(--bb-background-color);\n+    border-color: var(--bb-border-color);\n+    color: var(--bb-link-color);\n+  }\n+\n+  .page-link:hover {\n+    background-color: var(--bb-card-bg-color);\n+    border-color: var(--bb-border-color);\n+    color: var(--bb-link-color);\n+  }\n+\n+  .page-item.active .page-link {\n+    background-color: var(--bb-link-color);\n+    border-color: var(--bb-link-color);\n+    color: #fff;\n+  }\n+\n+  .page-item.disabled .page-link {\n+    background-color: var(--bb-card-bg-color);\n+    border-color: var(--bb-border-color);\n+    color: var(--bb-muted-text-color);\n   }\n }\ndiff --git a/www/base/src/views/BuildView/BuildView.scss b/www/base/src/views/BuildView/BuildView.scss\nindex 4d0f0d377410..a0caf8727080 100644\n--- a/www/base/src/views/BuildView/BuildView.scss\n+++ b/www/base/src/views/BuildView/BuildView.scss\n@@ -24,8 +24,8 @@\n \n .bb-build-view-nav-button {\n   padding: 5px 14px;\n-  background-color: #fff;\n-  border: 1px solid #ddd;\n+  background-color: var(--bb-background-color);\n+  border: 1px solid var(--bb-border-color);\n   border-radius: 15px;\n   display: block;\n }\ndiff --git a/www/base/src/views/BuildersView/BuildersView.scss b/www/base/src/views/BuildersView/BuildersView.scss\nindex e6b5a2482fad..2a0ea7d31594 100644\n--- a/www/base/src/views/BuildersView/BuildersView.scss\n+++ b/www/base/src/views/BuildersView/BuildersView.scss\n@@ -6,9 +6,9 @@\n   margin-bottom: 20px;\n   font-size: 14px;\n   line-height: 1.42857143;\n-  color: #555555;\n-  background-color: #fff;\n-  border: 1px solid #ccc;\n+  color: var(--bb-muted-text-color);\n+  background-color: var(--bb-background-color);\n+  border: 1px solid var(--bb-btn-border-color);\n   border-radius: 4px;\n   box-shadow: inset 0 1px 1px rgba(0, 0, 0, 0.075);\n   transition:\ndiff --git a/www/base/src/views/HomeView/HomeView.scss b/www/base/src/views/HomeView/HomeView.scss\nindex bd9dfed1663f..62e47803f1d4 100644\n--- a/www/base/src/views/HomeView/HomeView.scss\n+++ b/www/base/src/views/HomeView/HomeView.scss\n@@ -1,10 +1,10 @@\n .bb-home-view {\n   .card-header {\n     a {\n-      color: white;\n+      color: white !important;\n     }\n-    background-color: #337ab7;\n-    border-color: #337ab7;\n+    background-color: var(--bb-home-card-header-bg-color) !important;\n+    border-color: var(--bb-home-card-header-bg-color) !important;\n     padding: 10px 15px;\n   }\n \n@@ -13,6 +13,6 @@\n   }\n \n   .bb-home-builder-card {\n-    border-color: #337ab7;\n+    border-color: var(--bb-home-card-header-bg-color);\n   }\n }\ndiff --git a/www/base/src/views/ProjectsView/ProjectsView.scss b/www/base/src/views/ProjectsView/ProjectsView.scss\nindex ebed8c4c9a1c..7ec5002c6201 100644\n--- a/www/base/src/views/ProjectsView/ProjectsView.scss\n+++ b/www/base/src/views/ProjectsView/ProjectsView.scss\n@@ -6,9 +6,9 @@\n   margin-bottom: 20px;\n   font-size: 14px;\n   line-height: 1.42857143;\n-  color: #555555;\n-  background-color: #fff;\n-  border: 1px solid #ccc;\n+  color: var(--bb-muted-text-color);\n+  background-color: var(--bb-background-color);\n+  border: 1px solid var(--bb-btn-border-color);\n   border-radius: 4px;\n   box-shadow: inset 0 1px 1px rgba(0, 0, 0, 0.075);\n   transition:\n@@ -18,7 +18,7 @@\n \n .bb-projects-view-list {\n   & > a:hover > li {\n-    background-color: #dddddd;\n+    background-color: var(--bb-btn-hover-background-color);\n   }\n   & > a > li {\n     padding: 0.5rem 0.75rem;\ndiff --git a/www/console_view/src/views/ConsoleView/ConsoleView.scss b/www/console_view/src/views/ConsoleView/ConsoleView.scss\nindex 5e80167b033c..1e2d99332686 100644\n--- a/www/console_view/src/views/ConsoleView/ConsoleView.scss\n+++ b/www/console_view/src/views/ConsoleView/ConsoleView.scss\n@@ -1,7 +1,8 @@\n tr.bb-console-table-first-row {\n-  background-color: #fff !important;\n+  background-color: var(--bb-background-color) !important;\n   th {\n     border: none;\n+    background-color: var(--bb-background-color) !important;\n   }\n }\n \ndiff --git a/www/ui/src/components/BuildLinkWithSummaryTooltip/BuildLinkWithSummaryTooltip.scss b/www/ui/src/components/BuildLinkWithSummaryTooltip/BuildLinkWithSummaryTooltip.scss\nindex 8cc3f36466ec..ef1b5de727ca 100644\n--- a/www/ui/src/components/BuildLinkWithSummaryTooltip/BuildLinkWithSummaryTooltip.scss\n+++ b/www/ui/src/components/BuildLinkWithSummaryTooltip/BuildLinkWithSummaryTooltip.scss\n@@ -4,8 +4,8 @@\n   border: 1.5px;\n   padding: 1px;\n   min-width: 600px;\n-  color: #262626;\n-  background-color: white;\n+  color: var(--bb-text-color) !important;\n+  background-color: var(--bb-background-color) !important;\n   border-style: solid;\n   font-size: 12px;\n }\ndiff --git a/www/ui/src/components/BuildSummaryTooltip/BuildSummaryTooltip.scss b/www/ui/src/components/BuildSummaryTooltip/BuildSummaryTooltip.scss\nindex 6d5b1be82ddc..f546924c662f 100644\n--- a/www/ui/src/components/BuildSummaryTooltip/BuildSummaryTooltip.scss\n+++ b/www/ui/src/components/BuildSummaryTooltip/BuildSummaryTooltip.scss\n@@ -12,3 +12,22 @@\n .bb-buildsummary-tooltip-step-time {\n   float: right;\n }\n+\n+// Theme overrides for tooltip card (rendered outside #root via portal)\n+.tooltip .card {\n+  background-color: var(--bb-background-color) !important;\n+  border-color: var(--bb-card-border-color) !important;\n+  color: var(--bb-text-color) !important;\n+}\n+\n+.tooltip .card-header {\n+  background-color: var(--bb-card-bg-color) !important;\n+  border-bottom-color: var(--bb-card-border-color) !important;\n+  color: var(--bb-text-color) !important;\n+}\n+\n+.tooltip .list-group-item {\n+  background-color: var(--bb-background-color) !important;\n+  border-color: var(--bb-card-border-color) !important;\n+  color: var(--bb-text-color) !important;\n+}\ndiff --git a/www/ui/src/components/ChangeUserAvatar/ChangeUserAvatar.scss b/www/ui/src/components/ChangeUserAvatar/ChangeUserAvatar.scss\nindex 81ff56139e99..086756e120bb 100644\n--- a/www/ui/src/components/ChangeUserAvatar/ChangeUserAvatar.scss\n+++ b/www/ui/src/components/ChangeUserAvatar/ChangeUserAvatar.scss\n@@ -10,7 +10,7 @@\n   img {\n     height: 20px;\n     width: 20px;\n-    background-color: #ccc;\n+    background-color: var(--bb-avatar-bg-color);\n     display: block;\n   }\n }\ndiff --git a/www/ui/src/util/TagFilterManager.scss b/www/ui/src/util/TagFilterManager.scss\nindex f0407d1fb912..0c32a8baa76d 100644\n--- a/www/ui/src/util/TagFilterManager.scss\n+++ b/www/ui/src/util/TagFilterManager.scss\n@@ -4,14 +4,14 @@\n   font-weight: 700;\n   line-height: 1;\n   color: #fff;\n-  background-color: #777777;\n+  background-color: var(--bb-tag-bg-color);\n   text-align: center;\n   white-space: nowrap;\n   border-radius: 0.25em;\n }\n \n .bb-tag-filter-manager-tag-filtered {\n-  background-color: #5cb85c;\n+  background-color: var(--bb-tag-active-bg-color);\n }\n \n #bb-tag-filter-manager-help-popover {\n@@ -24,8 +24,8 @@\n     padding: 8px 14px;\n     margin: 0;\n     font-size: 14px;\n-    background-color: #f7f7f7;\n-    border-bottom: 1px solid #ebebeb;\n+    background-color: var(--bb-dropdown-bg-color);\n+    border-bottom: 1px solid var(--bb-dropdown-border-color);\n     border-radius: 5px 5px 0 0;\n   }\n \n@@ -39,8 +39,8 @@\n       font-size: 13px;\n       word-break: break-all;\n       word-wrap: break-word;\n-      background-color: #f5f5f5;\n-      border: 1px solid #ccc;\n+      background-color: var(--bb-dropdown-hover-bg-color);\n+      border: 1px solid var(--bb-btn-border-color);\n       border-radius: 4px;\n     }\n   }\ndiff --git a/www/waterfall_view/src/views/WaterfallView/Visualizer.ts b/www/waterfall_view/src/views/WaterfallView/Visualizer.ts\nindex f140929da57d..5f7941dc378d 100644\n--- a/www/waterfall_view/src/views/WaterfallView/Visualizer.ts\n+++ b/www/waterfall_view/src/views/WaterfallView/Visualizer.ts\n@@ -343,7 +343,7 @@ export class Visualizer {\n       .attr('y', -this.layoutSettings.margin.top)\n       .attr('width', this.layoutSettings.margin.left)\n       .attr('height', this.containerHeight)\n-      .style('fill', '#fff');\n+      .style('fill', 'var(--bb-background-color)');\n \n     const ticks = this.getTickValues(y);\n \ndiff --git a/www/waterfall_view/src/views/WaterfallView/WaterfallView.scss b/www/waterfall_view/src/views/WaterfallView/WaterfallView.scss\nindex 063bfc36e41e..03cb45102180 100644\n--- a/www/waterfall_view/src/views/WaterfallView/WaterfallView.scss\n+++ b/www/waterfall_view/src/views/WaterfallView/WaterfallView.scss\n@@ -84,7 +84,7 @@ $main-color: #3498db;\n                 }\n \n                 polygon {\n-                  fill: #fff;\n+                  fill: var(--bb-background-color);\n                 }\n \n                 .buildstep {\n", "test_patch": "diff --git a/master/buildbot/test/unit/www/test_config.py b/master/buildbot/test/unit/www/test_config.py\nindex c4f246647eb4..6852aa5947e1 100644\n--- a/master/buildbot/test/unit/www/test_config.py\n+++ b/master/buildbot/test/unit/www/test_config.py\n@@ -44,18 +44,40 @@ def test_serialize_www_frontend_theme_to_css(self) -> None:\n         self.assertEqual(\n             config.serialize_www_frontend_theme_to_css({}, indent=4),\n             \"\"\"\\\n---bb-sidebar-background-color: #30426a;\n-    --bb-sidebar-header-background-color: #273759;\n-    --bb-sidebar-header-text-color: #fff;\n-    --bb-sidebar-title-text-color: #627cb7;\n-    --bb-sidebar-footer-background-color: #273759;\n-    --bb-sidebar-button-text-color: #b2bfdc;\n-    --bb-sidebar-button-hover-background-color: #1b263d;\n-    --bb-sidebar-button-hover-text-color: #fff;\n+--bb-avatar-bg-color: #ccc;\n+    --bb-background-color: #fff;\n+    --bb-border-color: #ddd;\n+    --bb-btn-background-color: #fff;\n+    --bb-btn-border-color: #ccc;\n+    --bb-btn-hover-background-color: #e6e6e6;\n+    --bb-btn-hover-border-color: #adadad;\n+    --bb-card-bg-color: #f5f5f5;\n+    --bb-card-border-color: #ddd;\n+    --bb-card-header-text-color: #333;\n+    --bb-dropdown-bg-color: #f7f7f7;\n+    --bb-dropdown-border-color: #ebebeb;\n+    --bb-dropdown-hover-bg-color: #f5f5f5;\n+    --bb-highlight-border-color: #ffff00;\n+    --bb-home-card-header-bg-color: #337ab7;\n+    --bb-link-color: #337ab7;\n+    --bb-muted-text-color: #555;\n+    --bb-navbar-separator-color: #ccc;\n+    --bb-panel-separator-bg-color: #ddd;\n+    --bb-sidebar-background-color: #30426a;\n     --bb-sidebar-button-current-background-color: #273759;\n     --bb-sidebar-button-current-text-color: #b2bfdc;\n+    --bb-sidebar-button-hover-background-color: #1b263d;\n+    --bb-sidebar-button-hover-text-color: #fff;\n+    --bb-sidebar-button-text-color: #b2bfdc;\n+    --bb-sidebar-footer-background-color: #273759;\n+    --bb-sidebar-header-background-color: #273759;\n+    --bb-sidebar-header-text-color: #fff;\n+    --bb-sidebar-stripe-current-color: #8c5e10;\n     --bb-sidebar-stripe-hover-color: #e99d1a;\n-    --bb-sidebar-stripe-current-color: #8c5e10;\"\"\",\n+    --bb-sidebar-title-text-color: #627cb7;\n+    --bb-tag-active-bg-color: #5cb85c;\n+    --bb-tag-bg-color: #777;\n+    --bb-text-color: #333;\"\"\",\n         )\n \n \n", "problem_statement": "Feature request: dark theme\nFor buildbot-www I presume.\r\nMeanwhile, any hints on how to mod the css-files or whatever locally to change all white into something dark?\r\n\n", "hints_text": "You can create a www plugin that defines a css which overrides the original bootstrap colors\r\n\r\n\r\nI just tried and made PoC based on a ready to use bootstrap theme:\r\nhttps://bootswatch.com/darkly/\r\n```\r\n0 % git diff\r\ndiff --git a/www/base/src/styles/styles.less b/www/base/src/styles/styles.less\r\nindex 32fa99084..c881be92a 100644\r\n--- a/www/base/src/styles/styles.less\r\n+++ b/www/base/src/styles/styles.less\r\n@@ -5,6 +5,7 @@\r\n @import \"./colors.less\";\r\n @import \"./mobile.less\";\r\n @import (inline) \"~guanlecoja-ui/dist/styles.css\";\r\n+@import (inline) \"./dark.css\";\r\n /* base css for angular, don't display anything until angular is running */\r\n [ng\\:cloak], [ng-cloak], [data-ng-cloak], [x-ng-cloak], .ng-cloak, .x-ng-cloak {\r\n   display: none !important;\r\n```\r\n\r\n![image](https://user-images.githubusercontent.com/109859/64728763-04cdca80-d4dc-11e9-805f-3a4615bd179f.png)\r\n\r\n![image](https://user-images.githubusercontent.com/109859/64728717-ec5db000-d4db-11e9-8486-aca49e086564.png)\r\n\r\nThere are a bunch of colors to override\nno idea if i did this right :-) \r\ni did inspect on that page, downloaded the bootstrap.css and renamed it dark.css, then added that import line and put the css file in the same folder. then built buildbot and reinstalled.\r\ndidnt seem to make a difference.  but css is not something i've ever studied.\r\neither way, leaving this open for an official settings button for dark/light :-)\nI made a quick and dirty dark mode theme (incomplete) to avoid burning my eyes out at 0200 after a recent OS/gitlab/buildbot upgrade. Maybe someone else can use it as a starting point. Here's some snippets in a text file:\r\n\r\n\r\n[style.css.txt](https://github.com/buildbot/buildbot/files/9847121/style.css.txt)\r\n\r\n\nBTW I had to modify buildbot_console_view/static/styles.css and buildbot_waterfall_view/static/scripts.js as well to finish the 'hardcoded' dark mode. Finished it up while waiting on a build here.\r\n\r\n![Screenshot from 2022-10-26 17-26-39](https://user-images.githubusercontent.com/3432441/198141993-a6cb6e6e-b66b-48ab-bafc-aa6180bbd381.png)\r\n\r\n![Screenshot from 2022-10-26 17-21-40](https://user-images.githubusercontent.com/3432441/198142076-6e02d24a-5099-4ffc-9d91-5c3a12f3bc37.png)\r\n\r\n\r\n\nWould love a darkmode as an official addition, since these days it seems to be quite the norm for applications doing a light/dark mode implementation for the UI!\nFor those with accessibility needs, it is disappointing that a dark mode still has to be requested in 2024 :-(\nHello, Buildbot is a voluntary open-source project. Feature requests are welcome, but patches are even more.\nIndeed and as a brand new user day 1 I just use a browser plugin to make everything dark.\n\nNo expectation or demand from my comment, merely surprised, but after 5 years its obviously not in high demand \ud83d\ude42\n\nI also saw reference to react elsewhere, so is css modding relevant with more recent releases? \nWe indeed rework the web ui to react since last message, but its still the web, so css override will probably work.\r\n\r\nFor a clean dark mode support, please see the implementation here.\r\nA few of the colors are already in variables, but there is probably a bit more work to make sure all the colors can be themeable.\nThere is now some theming support. See `theme` configuration key in https://buildbot.readthedocs.io/en/latest/manual/configuration/www.html#web-server. It should be possible to add more colors relatively easily.\r\n\n> It should be possible to add more colors relatively easily.\r\n\r\nWith this I mean the following steps:\r\n - find color you want to change in CSS. \r\n - convert it to CSS variable\r\n - add trivial changes in 4 additional places to support theming as shown here: https://github.com/search?q=repo%3Abuildbot%2Fbuildbot+bb-sidebar-background-color&type=code\n\n", "all_hints_text": "You can create a www plugin that defines a css which overrides the original bootstrap colors\r\n\r\n\r\nI just tried and made PoC based on a ready to use bootstrap theme:\r\nhttps://bootswatch.com/darkly/\r\n```\r\n0 % git diff\r\ndiff --git a/www/base/src/styles/styles.less b/www/base/src/styles/styles.less\r\nindex 32fa99084..c881be92a 100644\r\n--- a/www/base/src/styles/styles.less\r\n+++ b/www/base/src/styles/styles.less\r\n@@ -5,6 +5,7 @@\r\n @import \"./colors.less\";\r\n @import \"./mobile.less\";\r\n @import (inline) \"~guanlecoja-ui/dist/styles.css\";\r\n+@import (inline) \"./dark.css\";\r\n /* base css for angular, don't display anything until angular is running */\r\n [ng\\:cloak], [ng-cloak], [data-ng-cloak], [x-ng-cloak], .ng-cloak, .x-ng-cloak {\r\n   display: none !important;\r\n```\r\n\r\n![image](https://user-images.githubusercontent.com/109859/64728763-04cdca80-d4dc-11e9-805f-3a4615bd179f.png)\r\n\r\n![image](https://user-images.githubusercontent.com/109859/64728717-ec5db000-d4db-11e9-8486-aca49e086564.png)\r\n\r\nThere are a bunch of colors to override\nno idea if i did this right :-) \r\ni did inspect on that page, downloaded the bootstrap.css and renamed it dark.css, then added that import line and put the css file in the same folder. then built buildbot and reinstalled.\r\ndidnt seem to make a difference.  but css is not something i've ever studied.\r\neither way, leaving this open for an official settings button for dark/light :-)\nI made a quick and dirty dark mode theme (incomplete) to avoid burning my eyes out at 0200 after a recent OS/gitlab/buildbot upgrade. Maybe someone else can use it as a starting point. Here's some snippets in a text file:\r\n\r\n\r\n[style.css.txt](https://github.com/buildbot/buildbot/files/9847121/style.css.txt)\r\n\r\n\nBTW I had to modify buildbot_console_view/static/styles.css and buildbot_waterfall_view/static/scripts.js as well to finish the 'hardcoded' dark mode. Finished it up while waiting on a build here.\r\n\r\n![Screenshot from 2022-10-26 17-26-39](https://user-images.githubusercontent.com/3432441/198141993-a6cb6e6e-b66b-48ab-bafc-aa6180bbd381.png)\r\n\r\n![Screenshot from 2022-10-26 17-21-40](https://user-images.githubusercontent.com/3432441/198142076-6e02d24a-5099-4ffc-9d91-5c3a12f3bc37.png)\r\n\r\n\r\n\nWould love a darkmode as an official addition, since these days it seems to be quite the norm for applications doing a light/dark mode implementation for the UI!\nFor those with accessibility needs, it is disappointing that a dark mode still has to be requested in 2024 :-(\nHello, Buildbot is a voluntary open-source project. Feature requests are welcome, but patches are even more.\nIndeed and as a brand new user day 1 I just use a browser plugin to make everything dark.\n\nNo expectation or demand from my comment, merely surprised, but after 5 years its obviously not in high demand \ud83d\ude42\n\nI also saw reference to react elsewhere, so is css modding relevant with more recent releases? \nWe indeed rework the web ui to react since last message, but its still the web, so css override will probably work.\r\n\r\nFor a clean dark mode support, please see the implementation here.\r\nA few of the colors are already in variables, but there is probably a bit more work to make sure all the colors can be themeable.\nThere is now some theming support. See `theme` configuration key in https://buildbot.readthedocs.io/en/latest/manual/configuration/www.html#web-server. It should be possible to add more colors relatively easily.\r\n\n> It should be possible to add more colors relatively easily.\r\n\r\nWith this I mean the following steps:\r\n - find color you want to change in CSS. \r\n - convert it to CSS variable\r\n - add trivial changes in 4 additional places to support theming as shown here: https://github.com/search?q=repo%3Abuildbot%2Fbuildbot+bb-sidebar-background-color&type=code\nPlease see PR #8980.\n\n", "commit_urls": ["https://github.com/buildbot/buildbot/commit/b0c2127108cdd838129196e91a2960e3183b8258"], "created_at": "2026-03-23T18:06:52Z"}
{"repo": "buildbot/buildbot", "pull_number": 8824, "instance_id": "buildbot__buildbot-8824", "issue_numbers": [5211], "base_commit": "df0d3ccbb7cece0d5e600ebf27855ab97b28603f", "patch": "diff --git a/master/buildbot/clients/usersclient.py b/master/buildbot/clients/usersclient.py\nindex f4b49562752b..877f164f5bc3 100644\n--- a/master/buildbot/clients/usersclient.py\n+++ b/master/buildbot/clients/usersclient.py\n@@ -21,6 +21,8 @@\n from twisted.internet import reactor\n from twisted.spread import pb\n \n+from buildbot.util import unicode2bytes\n+\n \n class UsersClient:\n     \"\"\"\n@@ -31,8 +33,8 @@ class UsersClient:\n \n     def __init__(self, master, username, password, port):\n         self.host = master\n-        self.username = username\n-        self.password = password\n+        self.username = unicode2bytes(username)\n+        self.password = unicode2bytes(password)\n         self.port = int(port)\n \n     @defer.inlineCallbacks\ndiff --git a/newsfragments/5211-encode-before-hashing.bugfix b/newsfragments/5211-encode-before-hashing.bugfix\nnew file mode 100644\nindex 000000000000..044dcd611d5f\n--- /dev/null\n+++ b/newsfragments/5211-encode-before-hashing.bugfix\n@@ -0,0 +1,1 @@\n+Encode the username and password for use as credentials in `UsersClient` (:issue:`5211`)\n", "test_patch": "", "problem_statement": "builtins.TypeError: Unicode-objects must be encoded before hashing\nI have a problem by the command:\r\nbuildbot user --op=add --master=ip:port --username=user --passwd=pw --info=cvs=add\r\n\r\n**Error:**\r\nbuiltins.TypeError: Unicode-objects must be encoded before hashing\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/buildbot/buildbot/commit/203af8c784ad6d9c2ba1d6eec22340928a84f857"], "created_at": "2026-03-02T14:26:55Z"}
{"repo": "buildbot/buildbot", "pull_number": 8839, "instance_id": "buildbot__buildbot-8839", "issue_numbers": [8138, 8316], "base_commit": "6ab685890230bfd68697e088e063ebd1b489d59e", "patch": "diff --git a/newsfragments/8316.bugfix b/newsfragments/8316.bugfix\nnew file mode 100644\nindex 000000000000..c916ec0b5b8c\n--- /dev/null\n+++ b/newsfragments/8316.bugfix\n@@ -0,0 +1,1 @@\n+Fixed NestedParameter tabs layout not showing tab content (:issue:`8316`).\ndiff --git a/www/base/src/components/ForceBuildModal/Fields/FieldNested.tsx b/www/base/src/components/ForceBuildModal/Fields/FieldNested.tsx\nindex 3410f7b14f95..307626693431 100644\n--- a/www/base/src/components/ForceBuildModal/Fields/FieldNested.tsx\n+++ b/www/base/src/components/ForceBuildModal/Fields/FieldNested.tsx\n@@ -64,14 +64,26 @@ export const FieldNested = observer(({field, fieldsState}: FieldNestedProps) =>\n   const columnClass = `col-sm-${(12 / columns).toString()}`;\n \n   if (field.layout === 'tabs') {\n+    const firstVisibleIndex = field.fields.findIndex((f) => !shouldHideField(f));\n+    const firstField = firstVisibleIndex >= 0 ? field.fields[firstVisibleIndex] : null;\n+    const defaultKey =\n+      firstField !== null\n+        ? firstField.name === ''\n+          ? firstVisibleIndex\n+          : firstField.name\n+        : undefined;\n+\n     return (\n       <div>\n-        <Tabs>\n-          {filteredMap(field.fields, (f, index) => (\n-            <Tab key={f.name === '' ? index : f.name} title={f.tablabel} className={columnClass}>\n-              <FieldAny field={f} fieldsState={fieldsState}></FieldAny>\n-            </Tab>\n-          ))}\n+        <Tabs defaultActiveKey={defaultKey}>\n+          {filteredMap(field.fields, (f, index) => {\n+            const eventKey = f.name === '' ? index : f.name;\n+            return (\n+              <Tab key={eventKey} eventKey={eventKey} title={f.tablabel} className={columnClass}>\n+                <FieldAny field={f} fieldsState={fieldsState}></FieldAny>\n+              </Tab>\n+            );\n+          })}\n         </Tabs>\n       </div>\n     );\n", "test_patch": "", "problem_statement": "react ui: NestedParameter not displayed\nI can still reproduce this issue.\r\nBuildbot v4.0.4\r\nOnly happens with \"tabs\" layout, \"vertical\" and \"simple\" work fine\r\n\r\n![image](https://github.com/user-attachments/assets/02d86bc9-9818-45cc-8ea0-26dffbec93d0)\r\n\r\n\r\n\r\n             Fixed in master by #7571\r\n\r\n_Originally posted by @tdesveaux in https://github.com/buildbot/buildbot/issues/7624#issuecomment-2226880041_\r\n            \nNestedParameters tabs layout non functional\n**Version Information**\nPython version: 3.11.2\nBuildbot version: 4.2.1\nTwisted version: 24.11.0\n\nI noticed an issue with NestedParameters using the tabs layout appearing to not function/rendered properly. I was able to reproduce the issue using a clean install and the master.cfg from https://github.com/buildbot/buildbot-docker-example-config with the following modification to the 'force' ForceScheduler.\n\n\n\n```\nc['schedulers'].append(schedulers.ForceScheduler(\n                          name=\"force\",\n                          builderNames=[\"runtests\"],\n                          properties=[\n                              util.NestedParameter(name=\"options\", label=\"\",\n                                                  layout=\"tabs\", fields=[\n                                  util.NestedParameter(name=\"first\", label=\"First Option\",\n                                                  layout=\"vertical\", fields=[\n                                      util.StringParameter(name=\"pull_url\",\n                                                          label=\"optionally give a public Git pull url:\",\n                                                          default=\"\")\n                                                          ]),\n                                  util.NestedParameter(name=\"second\", label=\"Second Option\",\n                                                  layout=\"vertical\", fields=[\n                                      util.BooleanParameter(name=\"force_build_clean\",\n                                                          label=\"force a make clean\",\n                                                          default=False)\n                                                          ])\n                                                  ])\n                          ]))\n```\n\nClicking on the tabs doesn't reveal any options, as well no tabs are shown by default.\n\n![Image](https://github.com/user-attachments/assets/95e221d6-3e6c-440c-8c0e-0c07725c912e)\n\n\nInspecting the buildmaster webpage and comparing to bootstraps docs on [Navs & Tabs](https://getbootstrap.com/docs/5.0/components/navs-tabs/#show) I believe I found a few potential issues from the auto generated code from ForceBuildModal. Adjusting the web page with the fixes does make the tabs intractable and visible but does not solve the issue entirely. \n\n> Note that if you\u2019re using &lt;nav&gt;, you shouldn\u2019t add role=\"tablist\" directly to it, as this would override the element\u2019s native role as a navigation landmark. Instead, switch to an alternative element (in the example below, a simple &lt;div&gt;) and wrap the &lt;nav&gt; around it.\n\n> To make tabs fade in, add .fade to each .tab-pane. The first tab pane must also have .show to make the initial content visible.\n\n```\nCurrent\n<nav class=\"nav nav-tabs\" role=\"tablist\">\n...\n<div role=\"tabpanel\" aria-hidden=\"true\" class=\"fade col-sm-12 tab-pane\">\n\nFixed from above.\n\n<nav><div class=\"nav nav-tabs\" role=\"tablist\">\n...\n<div role=\"tabpanel\" aria-hidden=\"true\" class=\"fade col-sm-12 tab-pane show active\">\n\n```\n\n\n", "hints_text": "\n\nThis Issue may be a duplicate of [react ui: NestedParameter not displayed #8138](https://github.com/buildbot/buildbot/issues/8138)\n\n", "all_hints_text": "\n\nThis Issue may be a duplicate of [react ui: NestedParameter not displayed #8138](https://github.com/buildbot/buildbot/issues/8138)\n\n", "commit_urls": ["https://github.com/buildbot/buildbot/commit/4e94567d78279f37fea713f9dc92ef2569f193ac"], "created_at": "2026-03-03T19:45:30Z"}
