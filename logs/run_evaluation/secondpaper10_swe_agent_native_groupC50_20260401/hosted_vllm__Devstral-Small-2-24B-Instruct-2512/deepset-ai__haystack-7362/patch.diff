+    @classmethod
+    def from_dict(cls, data: Dict[str, Any]) -> "PyPDFToDocument":
+        """
+        Deserializes the component from a dictionary.
+
+        :param data:
+            Dictionary with serialized data.
+        :returns:
+            Deserialized PyPDFToDocument instance.
+        """
+        init_params = data.get("init_parameters", {})
+        converter_data = init_params.get("converter")
+
+        if converter_data:
+            # Deserialize the converter
+            converter_type = converter_data["type"]
+            if converter_type == "haystack.components.converters.pypdf.DefaultConverter":
+                converter = DefaultConverter.from_dict(converter_data)
+            else:
+                # For custom converters, we need to dynamically import the class
+                module_name, class_name = converter_type.rsplit(".", 1)
+                module = __import__(module_name, fromlist=[class_name])
+                converter_class = getattr(module, class_name)
+                converter = converter_class.from_dict(converter_data)
+        else:
+            converter = None
+
+        return cls(converter=converter)
+
+# Backward compatibility: Keep the registry for existing code that might use it
+# This is deprecated and will be removed in future versions
+CONVERTERS_REGISTRY: Dict[str, PyPDFConverter] = {"default": DefaultConverter()}
+
+def __getattr__(name):
+    """
+    Handle backward compatibility for the old converter_name parameter.
+    """
+    if name == "CONVERTERS_REGISTRY":
+        warnings.warn(
+            "CONVERTERS_REGISTRY is deprecated and will be removed in future versions. "
+            "Use PyPDFToDocument(converter=your_converter_instance) instead.",
+            DeprecationWarning,
+            stacklevel=2
+        )
+        return CONVERTERS_REGISTRY
+    raise AttributeError(f"module '{__name__}' has no attribute '{name}'")
