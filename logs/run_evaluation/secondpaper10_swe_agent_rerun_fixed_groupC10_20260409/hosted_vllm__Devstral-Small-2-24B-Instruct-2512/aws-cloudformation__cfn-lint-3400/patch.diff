+def _contains_intrinsic_function(instance: Any) -> bool:
+    """Check if a value contains any intrinsic functions"""
+    if isinstance(instance, dict):
+        if len(instance) == 1 and next(iter(instance.keys())) in {
+            "Ref", "Fn::GetAtt", "Fn::Sub", "Fn::Join", "Fn::Select",
+            "Fn::FindInMap", "Fn::ImportValue", "Fn::Base64", "Fn::Cidr",
+            "Fn::GetAZs", "Fn::If", "Fn::Contains", "Fn::Length", "Fn::Split",
+            "Fn::Transform", "Fn::ToJsonString", "Fn::ForEach::[a-zA-Z0-9]+"
+        }:
+            return True
+        for value in instance.values():
+            if _contains_intrinsic_function(value):
+                return True
+    elif isinstance(instance, list):
+        for item in instance:
+            if _contains_intrinsic_function(item):
+                return True
+    return False
+
 class Policy(CfnLintJsonSchema):
     """Check IAM policies"""
 
