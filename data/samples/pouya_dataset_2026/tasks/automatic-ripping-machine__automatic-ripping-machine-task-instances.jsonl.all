ripping-machine/automatic-ripping-machine/commit/b4a8c2baa53f22adf526ba9140ad02ea257cf0d8"], "created_at": "2024-12-10T22:03:42Z"}
{"repo": "automatic-ripping-machine/automatic-ripping-machine", "pull_number": 1441, "instance_id": "automatic-ripping-machine__automatic-ripping-machine-1441", "issue_numbers": [1440], "base_commit": "ce9b7381d5aa7fb07c80b61f9b1eb4284d1ed08f", "patch": "diff --git a/VERSION b/VERSION\nindex 15d0fc4cf..b92cdb1db 100755\n--- a/VERSION\n+++ b/VERSION\n@@ -1,1 +1,1 @@\n-2.17.3\n+2.17.4\ndiff --git a/arm/ui/auth/auth.py b/arm/ui/auth/auth.py\nindex b16de3614..5862d4b31 100644\n--- a/arm/ui/auth/auth.py\n+++ b/arm/ui/auth/auth.py\n@@ -15,7 +15,7 @@\n \n from arm.ui import app, db, constants   # noqa: F811\n from arm.models.user import User\n-from arm.ui.forms import SetupForm, DBUpdate\n+from arm.ui.forms import SetupForm, DBUpdate, PasswordReset\n import arm.ui.utils as ui_utils\n \n route_auth = Blueprint('route_auth', __name__,\n@@ -62,15 +62,16 @@ def login():\n         return_redirect = redirect(constants.HOME_PAGE)\n \n     form = SetupForm()\n-    if request.method == 'POST' and form.validate_on_submit():\n-        login_username = request.form['username']\n+    if form.validate_on_submit():\n+        login_username = form.username.data.strip()\n+        login_password = form.password.data.strip().encode('utf-8')\n         # we know there is only ever 1 admin account, so we can pull it and check against it locally\n         admin = User.query.filter_by().first()\n         app.logger.debug(\"user= \" + str(admin))\n         # our pass\n         password = admin.password\n         # hashed pass the user provided\n-        login_hashed = bcrypt.hashpw(str(request.form['password']).strip().encode('utf-8'), admin.hash)\n+        login_hashed = bcrypt.hashpw(login_password, admin.hash)\n \n         if login_hashed == password and login_username == admin.email:\n             login_user(admin)\n@@ -105,20 +106,25 @@ def update_password():\n     \"\"\"\n     # get current user\n     user = User.query.first()\n-\n     session[\"page_title\"] = \"Update Admin Password\"\n \n     # After a login for is submitted\n-    form = SetupForm()\n-    if request.method == 'POST' and form.validate_on_submit():\n-        username = str(request.form['username']).strip()\n-        new_password = str(request.form['newpassword']).strip().encode('utf-8')\n+    form = PasswordReset()\n+\n+    if form.validate_on_submit():\n+        # Get form values\n+        username = form.username.data.strip()\n+        new_password = form.new_password.data.strip().encode('utf-8')\n+        old_password = form.old_password.data.strip().encode('utf-8')\n+\n+        # Get current password and dehash\n         user = User.query.filter_by(email=username).first()\n-        password = user.password\n+        current_password = user.password\n         hashed = user.hash\n-        # our new one\n-        login_hashed = bcrypt.hashpw(str(request.form['password']).strip().encode('utf-8'), hashed)\n-        if login_hashed == password:\n+        login_hashed = bcrypt.hashpw(old_password, hashed)\n+\n+        # If user entered correct password\n+        if login_hashed == current_password:\n             hashed_password = bcrypt.hashpw(new_password, hashed)\n             user.password = hashed_password\n             user.hash = hashed\n@@ -131,8 +137,8 @@ def update_password():\n                 flash(str(error), \"danger\")\n                 app.logger.error(f\"Error in updating password: {error}\")\n         else:\n-            flash(\"Password couldn't be updated. Problem with old password\", \"danger\")\n-            app.logger.error(\"Password not updated, issue with old password\")\n+            flash(\"Current password does not match\", \"danger\")\n+            app.logger.error(\"Current password does not match\")\n \n     return render_template('update_password.html', user=user.email, form=form)\n \ndiff --git a/arm/ui/auth/templates/login.html b/arm/ui/auth/templates/login.html\nindex aedeefc57..116900e8a 100755\n--- a/arm/ui/auth/templates/login.html\n+++ b/arm/ui/auth/templates/login.html\n@@ -11,12 +11,18 @@\n \t\t\t\t\t\t<span class=\"input-group-text\" id=\"usr\">Username:</span>\n \t\t\t\t\t</div>\n \t\t\t\t\t<input type=\"text\" class=\"form-control\" aria-label=\"username\" name=\"username\" placeholder=\"username\" value=\"\" aria-describedby=\"usr\">\n+\t\t\t\t\t{% for error in form.username.errors %}\n+\t\t\t\t\t\t<div class=\"text-danger\">{{ error }}</div>\n+\t\t\t\t\t{% endfor %}\n \t\t\t\t</div>\n \t\t\t\t<div class=\"input-group mb-3\">\n \t\t\t\t\t<div class=\"input-group-prepend\">\n \t\t\t\t\t\t<span class=\"input-group-text\" id=\"basic-addon1\">Password:</span>\n \t\t\t\t\t</div>\n \t\t\t\t\t<input type=\"password\" class=\"form-control\" name=\"password\" aria-label=\"password\" aria-describedby=\"basic-addon1\">\n+\t\t\t\t\t{% for error in form.password.errors %}\n+\t\t\t\t\t\t<div class=\"text-danger\">{{ error }}</div>\n+\t\t\t\t\t{% endfor %}\n \t\t\t\t</div>\n \t\t\t\t<input class=\"form-control\" name=\"save\" value=\"save\" hidden>\n \t\t\t\t<button class=\"btn btn-secondary btn-lg btn-block\" form=\"form1\" type=\"submit\">Login</button>\ndiff --git a/arm/ui/auth/templates/update_password.html b/arm/ui/auth/templates/update_password.html\nindex e7cca38ea..07418f25c 100755\n--- a/arm/ui/auth/templates/update_password.html\n+++ b/arm/ui/auth/templates/update_password.html\n@@ -17,16 +17,22 @@\n                         <div class=\"input-group-prepend\">\n                             <span class=\"input-group-text\" id=\"basic-addon1\">Old Password:</span>\n                         </div>\n-                        <input type=\"password\" class=\"form-control\" name=\"password\" aria-label=\"password\"\n+                        <input type=\"password\" class=\"form-control\" name=\"old_password\" aria-label=\"password\"\n                                aria-describedby=\"basic-addon1\">\n+                        {% for error in form.old_password.errors %}\n+                            <div class=\"text-danger\">{{ error }}</div>\n+                        {% endfor %}\n                     </div>\n \n                     <div class=\"input-group mb-3\">\n                         <div class=\"input-group-prepend\">\n                             <span class=\"input-group-text\" id=\"basic-addon2\">New Password:</span>\n                         </div>\n-                        <input type=\"password\" class=\"form-control\" name=\"newpassword\" aria-label=\"newpassword\"\n+                        <input type=\"password\" class=\"form-control\" name=\"new_password\" aria-label=\"new_password\"\n                                aria-describedby=\"basic-addon2\">\n+                        {% for error in form.new_password.errors %}\n+                            <div class=\"text-danger\">{{ error }}</div>\n+                        {% endfor %}\n                     </div>\n                     <button class=\"btn btn-secondary btn-lg btn-block\" form=\"form1\" type=\"submit\">\n                         Update User\ndiff --git a/arm/ui/forms.py b/arm/ui/forms.py\nindex ff6224411..a0847739b 100755\n--- a/arm/ui/forms.py\n+++ b/arm/ui/forms.py\n@@ -59,14 +59,39 @@ class UiSettingsForm(FlaskForm):\n \n \n class SetupForm(FlaskForm):\n-    \"\"\"Login/admin account creation on pages\\n\n+    \"\"\"\"\n+    ARM User Login form.\n+    This form is used on:\n       - /login\n-      - /update_password\"\"\"\n+\n+    Fields:\n+        username (StringField): The user's username (required).\n+        password (PasswordField): The user's password (required).\n+        submit (SubmitField): Button to submit the login form.\n+    \"\"\"\n     username = StringField('username', validators=[DataRequired()])\n     password = PasswordField('password', validators=[DataRequired()])\n     submit = SubmitField('Submit')\n \n \n+class PasswordReset(FlaskForm):\n+    \"\"\"\n+    Password reset form.\n+    This form is used on:\n+      - /update_password (for authenticated users to change their password)\n+\n+    Fields:\n+        username (StringField): The user's username (required).\n+        old_password (PasswordField): The user's current password (required).\n+        new_password (PasswordField): The new password to set (required).\n+        submit (SubmitField): Button to submit the form.\n+    \"\"\"\n+    username = StringField('username', validators=[DataRequired()])\n+    old_password = PasswordField('password', validators=[DataRequired()])\n+    new_password = PasswordField('password', validators=[DataRequired()])\n+    submit = SubmitField('Submit')\n+\n+\n class AbcdeForm(FlaskForm):\n     \"\"\"abcde config form used on pages\\n\n               - /settings\"\"\"\n", "test_patch": "", "problem_statement": "Allows you to reset password with blank\n### Is there an existing issue for this?\n\n- [x] I have searched the existing issues\n\n### I have checked the wiki\n\n- [x] I have searched the wiki for this problem\n\n### Does this issue exist in the latest version?\n\n- [x] I'm using the latest release\n\n### Describe the bug?\n\nIf you go to reset your password and input your existing password, but leave the new password blank it will allow you to continue. I then can't login at all blank or no. This was a new installation, so solution for me was to just delete the db folder and start the docker container again, but I figured it would probably be a quick fix to prevent blank password resets.\n\n### To Reproduce\n\nIf you go to reset your password and input your existing password, but leave the new password blank\n\n### What OS are you seeing the problem on?\n\nOther (please state in Anything else? section)\n\n### ARM Release Version or Git hash (You can find this in the arm settings page)\n\nDebian 12\n\n### Expected behavior?\n\nNo to let you proceed with password reset.\n\n### Relevant log output\n\n```shell\n\n```\n\n### Anything else?\n\n_No response_\n\n### Code of Conduct\n\n- [x] I agree to follow this project's Code of Conduct\n", "hints_text": "If youre having issues, please remember to read the [wiki](https://github.com/automatic-ripping-machine/automatic-ripping-machine/wiki/FAQ) and follow the instructions carefully\n\n", "all_hints_text": "If youre having issues, please remember to read the [wiki](https://github.com/automatic-ripping-machine/automatic-ripping-machine/wiki/FAQ) and follow the instructions carefully\nNice find, will raise a PR and fix\n\n", "commit_urls": ["https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/377c548d89828de2c72fcd910e62d52fc1ec777c", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/79ec486f92f195b2a7152b86c3743d406255fd77", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/f10d5ccc704c525fdf84fe6c381a0e9584263162", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/24836c92700092100cb1c65c5c92bda76d9045a6", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/c5d1d006bec8dfa29029ce3c238d76868c5900f4", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/71088da3b8a4f3b3cc775654d834db3d8e6609b0"], "created_at": "2025-07-01T13:32:54Z"}
{"repo": "automatic-ripping-machine/automatic-ripping-machine", "pull_number": 1447, "instance_id": "automatic-ripping-machine__automatic-ripping-machine-1447", "issue_numbers": [1443], "base_commit": "30f5a9e15c8c0b73bb29e13584200e6783974d89", "patch": "diff --git a/VERSION b/VERSION\nindex 6618ab545..94c60781e 100755\n--- a/VERSION\n+++ b/VERSION\n@@ -1,1 +1,1 @@\n-2.17.0\n\\ No newline at end of file\n+2.17.1\n\\ No newline at end of file\ndiff --git a/arm/ripper/music_brainz.py b/arm/ripper/music_brainz.py\nindex 499bf586f..3f1f27a57 100755\n--- a/arm/ripper/music_brainz.py\n+++ b/arm/ripper/music_brainz.py\n@@ -47,7 +47,7 @@ def music_brainz(discid, job):\n     # Tell musicbrainz what your app is, and how to contact you\n     # (this step is required, as per the webservice access rules\n     # at http://wiki.musicbrainz.org/XML_Web_Service/Rate_Limiting )\n-    mb.set_useragent(app=\"arm\", version=job.arm_version, contact=\"https://github.com/automatic-ripping-machine\")\n+    mb.set_useragent(app=\"arm\", version=str(job.arm_version), contact=\"https://github.com/automatic-ripping-machine\")\n     try:\n         infos = mb.get_releases_by_discid(discid, includes=['artist-credits', 'recordings'])\n         logging.debug(f\"Infos: {infos}\")\n@@ -165,7 +165,7 @@ def get_title(discid, job):\n     # Tell musicbrainz what your app is, and how to contact you\n     # (this step is required, as per the webservice access rules\n     # at http://wiki.musicbrainz.org/XML_Web_Service/Rate_Limiting )\n-    mb.set_useragent(\"arm\", version=job.arm_version, contact=\"https://github.com/automatic-ripping-machine\")\n+    mb.set_useragent(\"arm\", version=str(job.arm_version), contact=\"https://github.com/automatic-ripping-machine\")\n     try:\n         infos = mb.get_releases_by_discid(discid, includes=['artist-credits'])\n         logging.debug(f\"Infos: {infos}\")\n", "test_patch": "", "problem_statement": "\ud83d\udc0b Musicbrainz look up not working for CD\n### Is there an existing issue for this?\n\n- [x] I have searched the existing issues\n\n### Does this issue exist in the latest version?\n\n- [x] I'm using the latest release\n\n### Describe the bug?\n\nWhen inserting a music CD and using musicbrainz, the device fails to search for this\n\n### To Reproduce\n\n1. Insert CD\n2. Set to use musicbrainz to look up device\n3. Nothing happens\n\n### Built from source files ?\n\n- [ ] I Built the image from source\n\n### What architecture are you seeing the problem on?\n\namd64\n\n### Expected behavior?\n\nFor it to be able to search musicbrainz\n\n### Relevant log output\n\n```shell\nTraceback (most recent call last):\n  File \"/opt/arm/arm/ripper/main.py\", line 172, in <module>\n    log_file = logger.setup_logging(job)\n  File \"/opt/arm/arm/ripper/logger.py\", line 24, in setup_logging\n    logfile = job.logfile = job.identify_audio_cd()\n  File \"/opt/arm/arm/models/job.py\", line 175, in identify_audio_cd\n    mb_title = music_brainz.get_title(disc_id, self)\n  File \"/opt/arm/arm/ripper/music_brainz.py\", line 168, in get_title\n    mb.set_useragent(app=\"arm\", version=job.arm_version, contact=\"https://github.com/automatic-ripping-machine\")\n  File \"/usr/local/lib/python3.10/dist-packages/musicbrainzngs/musicbrainz.py\", line 320, in set_useragent\n    raise ValueError(\"App and version can not be empty\")\nValueError: App and version can not be empty\n```\n\n### Anything else?\n\nThis seems to be related to cdc7c1b02fadb19d6926704e09fdb71dd4141936\n\nif you modify line 50 and 168 to explicitly set the app version (i.e. \"2.16.3\" instead of job.arm_version), it works without issue\n\n### Code of Conduct\n\n- [x] I agree to follow this project's Code of Conduct\n", "hints_text": "I'm experiencing this as well, but was able to temporarily resolve it by editing the lines referenced by Kaik541\nSeems that the function needs a string, https://python-musicbrainzngs.readthedocs.io/en/v0.7.1/api/#musicbrainzngs.set_useragent\n\nAgree, broke with the recent update\n\nif you modify `version=job.arm_version` to `version=str(job.arm_version)`\n\nDoes that solve it? If so I can raise a PR and resolve\nyes that worked too\n\n", "all_hints_text": "I'm experiencing this as well, but was able to temporarily resolve it by editing the lines referenced by Kaik541\nSeems that the function needs a string, https://python-musicbrainzngs.readthedocs.io/en/v0.7.1/api/#musicbrainzngs.set_useragent\n\nAgree, broke with the recent update\n\nif you modify `version=job.arm_version` to `version=str(job.arm_version)`\n\nDoes that solve it? If so I can raise a PR and resolve\nyes that worked too\n\n", "commit_urls": ["https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/ed1d6612fcf5c11e79e53cb69cda9240dc5188a7", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/a4b2a88b7808c623edffc0a2057d146c4a64a0c2", "https://github.com/automatic-ripping-machine/automatic-ripping-machine/commit/66479959b9b8c77e2cfa77d4d6b4e54f4af4530c"], "created_at": "2025-07-07T08:03:25Z"}
{"repo": "automatic-ripping-machine/automatic-ripping-machine", "pull_number": 1581, "instance_id": "automatic-ripping-machine__automatic-ripping-machine-1581", "issue_numbers": [1452], "base_commit": "f2093ee35ee911f07402b535df8fadcb1881cf6c", "patch": "diff --git a/.github/workflows/publish-image.yml b/.github/workflows/publish-image.yml\nindex ff2d4f4c1..367394f8d 100644\n--- a/.github/workflows/publish-image.yml\n+++ b/.github/workflows/publish-image.yml\n@@ -100,8 +100,10 @@ jobs:\n           tags: |\n             ${{ env.IMAGE_NAME }}:${{ env.TAG }}\n             ${{ env.IMAGE_NAME }}:${{ env.VERSION }}\n-          labels: ${{ steps.meta.outputs.labels }}\n-\n+          labels: |\n+            ${{ steps.meta.outputs.labels }}\n+            org.opencontainers.image.version=${{ env.VERSION }}\n+      \n       # Fetches all tags for the repo\n       - name: Fetch tags\n         run: git fetch --depth=1 origin +refs/tags/*:refs/tags/*\n", "test_patch": "", "problem_statement": "\ud83d\udc0b Docker Container Image Version - Incorrect, does not have latest tag version, but always 'main'.\n### Is there an existing issue for this?\n\n- [x] I have searched the existing issues\n\n### Does this issue exist in the latest version?\n\n- [x] I'm using the latest release\n\n### Describe the bug?\n\nThe docker container does not embed the ARM release version properly within the 'org.opencontainers.image.version' tag. It always just returns 'main' which is not correct.\n\n### To Reproduce\n\nHere is an example checking my jellyfin container:\n\n# docker inspect jellyfin --format '{{ index .Config.Labels '\\\"'org.opencontainers.image.version'\\\"' }}'\n10.10.7\n\nHere is an example checking my arm container:\n\n# docker inspect arm --format '{{ index .Config.Labels '\\\"'org.opencontainers.image.version'\\\"' }}'\nmain\n\n### Built from source files ?\n\n- [ ] I Built the image from source\n\n### What architecture are you seeing the problem on?\n\nall\n\n### Expected behavior?\n\nShould return the version -- for example, 2.16.1\n\n### Relevant log output\n\n```shell\n\n```\n\n### Anything else?\n\nI have custom maintenance scripts to backup compose files when I modify them, backup files associated with a container, and their images. These rely on the correct population of the version tag.\n\nSince I perform testing with docker compose build to bake in Intel QSV hardware acceleration, it is important that I know when the image has to be rebuilt based upon an updated base published docker image.\n\n### Code of Conduct\n\n- [x] I agree to follow this project's Code of Conduct\n", "hints_text": "Here is a way to potentially fix this issue:\n\n<img width=\"698\" height=\"533\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/3eae12c2-dbca-4098-8799-ad111fdebcb4\" />\n\nSince I build my own docker container with Intel QSV baked in, it made to sense to use the pre-built docker container. Switched my dockerfile_inline directive to use the following:\n\n```\nFROM automaticrippingmachine/arm-dependencies:latest AS base\n```\n\nAs expected, there is a hard coded tag here for the version as well:\n\n```\n/docker/arm# docker inspect arm --format '{{ index .Config.Labels '\\\"'org.opencontainers.image.version'\\\"' }}'\nnightly\n```\n\nSadly, there is no way to *easily* determine the version of the ARM container using this label. Thinking it would make sense to instead tag it with the latest date, for example, '20250715' for tonight's build. Then one can easily figure out which night it was built on ;)\n\nHOWEVER, depending on code, this may cause some issues. Ideally, Version should have the actual version of the ARM docker image -- latest is '2.17.2' and perhaps use a different label for the build date. I have seen other docker containers use 'build-date' for this.\n\nIt may just be that the ARGs set at https://github.com/automatic-ripping-machine/arm-dependencies/blob/main/Dockerfile are blank, so things are a bit wonky. In particular, VERSION and BUILD_DATE. So these may not be copied properly into the docker image. I am not a Github expert, but looks like there is a workflow to re-build the arm dependencies image every night. Not sure how one would be able to store/update the required variables to pass the correct VERSION and BUILD_DATE values to the dockerfile.\n\n", "all_hints_text": "Here is a way to potentially fix this issue:\n\n<img width=\"698\" height=\"533\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/3eae12c2-dbca-4098-8799-ad111fdebcb4\" />\n\nSince I build my own docker container with Intel QSV baked in, it made to sense to use the pre-built docker container. Switched my dockerfile_inline directive to use the following:\n\n```\nFROM automaticrippingmachine/arm-dependencies:latest AS base\n```\n\nAs expected, there is a hard coded tag here for the version as well:\n\n```\n/docker/arm# docker inspect arm --format '{{ index .Config.Labels '\\\"'org.opencontainers.image.version'\\\"' }}'\nnightly\n```\n\nSadly, there is no way to *easily* determine the version of the ARM container using this label. Thinking it would make sense to instead tag it with the latest date, for example, '20250715' for tonight's build. Then one can easily figure out which night it was built on ;)\n\nHOWEVER, depending on code, this may cause some issues. Ideally, Version should have the actual version of the ARM docker image -- latest is '2.17.2' and perhaps use a different label for the build date. I have seen other docker containers use 'build-date' for this.\n\nIt may just be that the ARGs set at https://github.com/automatic-ripping-machine/arm-dependencies/blob/main/Dockerfile are blank, so things are a bit wonky. In particular, VERSION and BUILD_DATE. So these may not be copied properly into the docker image. I am not a Github expert, but looks like there is a workflow to re-build the arm dependencies image every night. Not sure how one would be able to store/update the required variables to pass the correct VERSION and BUILD_DATE values to the dockerfile.\n@1337-server This issue still persists. Pulled the newest image and see the following when performing an inspect:\n\n```\n'org.opencontainers.image.created': '2025-10-04T15:59:24.142Z', 'org.opencontainers.image.description': 'Automatic Ripping Machine for fully automated Blu-ray, DVD and audio disc ripping.', 'org.opencontainers.image.documentation': 'https://raw.githubusercontent.com/automatic-ripping-machine/arm-dependencies/main/README.md', 'org.opencontainers.image.license': 'MIT', 'org.opencontainers.image.licenses': 'MIT', 'org.opencontainers.image.ref.name': 'ubuntu', 'org.opencontainers.image.revision': 'aeffc5400263163f2c09c759fb4b8e92ac4c3e6d', 'org.opencontainers.image.source': 'https://github.com/automatic-ripping-machine/automatic-ripping-machine', 'org.opencontainers.image.title': 'arm-dependencies', 'org.opencontainers.image.url': 'https://github.com/automatic-ripping-machine/arm-dependencies', 'org.opencontainers.image.version': 'main'\n```\n\nTitle and Version still dont update properly. We probably want a different name for the final image -- 'Automatic Ripping Machine' or 'ARM' or something.\n\n\nSorry this was my mix-up, I thought you meant for this repo. But you are referencing the arm-dependencies repo. Issues about the deps image should be opened there.\n\nThe main image does contain the version as requested. \n\nI did repull the main image from this repo, and it does contain the tags as requested\nMaybe I am missing something? This is not the main image from this repo?\n\ncontext: 'https://github.com/automatic-ripping-machine/automatic-ripping-machine.git'\n\n\nI pulled the main image (`automaticrippingmachine/automatic-ripping-machine:2.20.5`) and got \n\n```\n{\n  \"Id\" : \"sha256:f50e3cacd85c9fa5d401f8916c6b3657d37aea14cb84bb906a3baf01e04ffc9a\",\n  \"RepoTags\" : [ \"automaticrippingmachine/automatic-ripping-machine:2.20.5\" ],\n  \"RepoDigests\" : [ \"automaticrippingmachine/automatic-ripping-machine@sha256:297f1ade5fe1bc6b823bed29cfc9125a83f559f1b74bb700f72bebe452446e47\" ],\n  \"Parent\" : \"\",\n  \"Comment\" : \"buildkit.dockerfile.v0\",\n  \"Created\" : \"2025-10-22T00:44:28.075463549Z\",\n  \"DockerVersion\" : \"\",\n  \"Author\" : \"\",\n  \"Config\" : {\n    \"ExposedPorts\" : {\n      \"8080/tcp\" : { }\n    },\n    \"Env\" : [ \"PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\", \"DEBIAN_FRONTEND=teletype\", \"LANG=en_US.UTF-8\", \"LANGUAGE=en_US:en\", \"LC_ALL=en_US.UTF-8\", \"ARM_UID=1000\", \"ARM_GID=1000\", \"TZ=Etc/UTC\" ],\n    \"Cmd\" : [ \"/sbin/my_init\" ],\n    \"WorkingDir\" : \"/home/arm\",\n    \"Labels\" : {\n      \"org.opencontainers.image.created\" : \"2025-10-22T00:43:45.483Z\",\n      \"org.opencontainers.image.description\" : \"Automatic Ripping Machine (ARM) Scripts\",\n      \"org.opencontainers.image.documentation\" : \"https://raw.githubusercontent.com/automatic-ripping-machine/arm-dependencies/main/README.md\",\n      \"org.opencontainers.image.license\" : \"MIT\",\n      \"org.opencontainers.image.licenses\" : \"MIT\",\n      \"org.opencontainers.image.ref.name\" : \"ubuntu\",\n      \"org.opencontainers.image.revision\" : \"20cd4ee96962cd7161f5231611e00b87fed0382c\",\n      \"org.opencontainers.image.source\" : \"https://github.com/automatic-ripping-machine/automatic-ripping-machine\",\n      \"org.opencontainers.image.title\" : \"automatic-ripping-machine\",\n      \"org.opencontainers.image.url\" : \"https://github.com/automatic-ripping-machine/automatic-ripping-machine\",\n      \"org.opencontainers.image.version\" : \"2.20.5\"\n    },\n    \"ArgsEscaped\" : true,\n    \"Healthcheck\" : {\n      \"Test\" : [ \"CMD-SHELL\", \"/healthcheck.sh\" ],\n      \"Interval\" : 300000000000,\n      \"Timeout\" : 15000000000,\n      \"StartPeriod\" : 30000000000\n    }\n  },\n  \"Architecture\" : \"amd64\",\n  \"Os\" : \"linux\",\n  \"Size\" : 2700167975,\n  \"GraphDriver\" : {\n    \"Data\" : {\n      \"LowerDir\" : \"/var/lib/docker/overlay2/04c47efd98b0d50e197f770b77e2612b8253d479453266d607b85930685731f4/diff:/var/lib/docker/overlay2/4a528459c29700ec6eba875c5216fafca1d674b1a83c2d85c86b314e32d0e71f/diff:/var/lib/docker/overlay2/0b62d53d5bf476c1a624ceda5c5568dfb86e09de32888c9fded68ab16c71a073/diff:/var/lib/docker/overlay2/8407a18acc00b22d092feba8d48f75c4e880274da25fbddce99c07c29074f879/diff:/var/lib/docker/overlay2/589f6eb19459b21604fe1c560dd62cbc54e614f51d2d71befd0f210a458517a6/diff:/var/lib/docker/overlay2/42e60d44a224703990571742ed6a6f776eed4b0f870f1a116402dcb79f821493/diff:/var/lib/docker/overlay2/592cfb9a9de9ce61ce006b4a85c05d95476bf69aab094c9da57f05a6573313cb/diff:/var/lib/docker/overlay2/43a0d8a725d02141929cae2568fba0063b0c529f6a61bfc9416d1c69dfb87bef/diff:/var/lib/docker/overlay2/1bc2fd0e5dc4830021079f5c9251559305d198c639e6ffe1dbf0eec3af4dd5d3/diff:/var/lib/docker/overlay2/a408bba152f66f48313f3cc7d2fca05a3944fba0f68460af3f4147cbf51609ae/diff:/var/lib/docker/overlay2/a41f06acb324a6ee07f6818dbf709f443fa5655fbb0aee0f02683c955e4cc3c5/diff:/var/lib/docker/overlay2/d47f8235838b2509b96aea6ee91ee55b7eef5a497dec54ce10461666dd73083c/diff:/var/lib/docker/overlay2/c12e2143ee44e96ccb5225f0b09d07170eea60e993ca542b511e671019b31c1c/diff:/var/lib/docker/overlay2/9f3f2dd7b41abef7a5139299247a0a05aa720c31c74f80856d7800cafe818e51/diff:/var/lib/docker/overlay2/4cd50f2a6d1ede5373b68a0a2ead86b8f2dc8417ffb979e3c6c42e7a6e632b61/diff:/var/lib/docker/overlay2/7bfb096d15ddd41eb43587ec90137875ddc7f7efc320db64be6c339023497f18/diff:/var/lib/docker/overlay2/eb17a8334934a93d6d7070e0dd4bb85592ee40899f4ab6483213d66d48e2451c/diff:/var/lib/docker/overlay2/4e6b4d537cd4f36ea8eb71963289421c2af00742626f7be70780938072d8e44e/diff:/var/lib/docker/overlay2/4a0e31a61189c978a470e2723cbe4f874cf6f4fd56bb950c763b52051ab6514a/diff:/var/lib/docker/overlay2/61bc9fd10f8dd09142dfe3830d95d69b17c5bd63bfb877a21b5a159d180a2775/diff:/var/lib/docker/overlay2/ccc07fb6e21052940529fb6a4b013929483f