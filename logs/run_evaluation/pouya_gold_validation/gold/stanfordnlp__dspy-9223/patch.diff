+    return json.dumps(msg)
+
+
+def _jsonrpc_result(result: Any, id: int | str) -> str:
+    """Create a JSON-RPC 2.0 success response."""
+    return json.dumps({"jsonrpc": "2.0", "result": result, "id": id})
+
