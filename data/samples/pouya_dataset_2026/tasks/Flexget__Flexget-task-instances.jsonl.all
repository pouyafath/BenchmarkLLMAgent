{"repo": "Flexget/Flexget", "pull_number": 4750, "instance_id": "Flexget__Flexget-4750", "issue_numbers": [4708], "base_commit": "80a2981b5f2f63e5d3c930aff8c90737c137751e", "patch": "diff --git a/flexget/components/sites/sites/lostfilm.py b/flexget/components/sites/sites/lostfilm.py\nindex 360f4352a0..4f8958f65b 100644\n--- a/flexget/components/sites/sites/lostfilm.py\n+++ b/flexget/components/sites/sites/lostfilm.py\n@@ -21,9 +21,13 @@\n     r'^(?P<sr_rus>[^)(]+?)(?: \\((?P<sr_org>[^)]+)\\))?\\. (?:(?P<ep_rus>.*)\\. )?\\(S(?P<season>\\d+)E(?P<episode>\\d+)\\)$'\n )\n RSS_LINK_REGEXP = re.compile(\n-    r'^https?://[a-z./]+/series/(?P<sr_org2>.+)/season_(?P<season>\\d+)/episode_(?P<episode>\\d+)/$'\n+    r'^https?://[a-zA-Z0-9./_-]+/series/(?P<sr_org2>.+)/season_(?P<season>\\d+)/episode_(?P<episode>\\d+)/$'\n )\n RSS_LF_ID_REGEXP = re.compile(r'/Images/(?P<id>\\d+)/Posters/image\\.(?:png|jpg|jpeg)')\n+RSS_TITLE_MOVIE_REGEXP = re.compile(\n+    r'^(?P<movie_name_rus>[^)(]+?)(?: \\((?P<movie_name>[^)]+)\\))?\\. \\(\u0424\u0438\u043b\u044c\u043c\\)$'\n+)\n+RSS_LINK_MOVIE_REGEXP = re.compile(r'^https?://[a-zA-Z0-9./_-]+/movies/(?P<movie_name2>[^/]+)$')\n PAGE_TEXT_REGEXP = re.compile(\n     r'^\\s*(?P<season>\\d+)\\s+\u0441\u0435\u0437\u043e\u043d\\s+(?P<episode>\\d+)\\s+\u0441\u0435\u0440\u0438\u044f\\.(?:\\s(?P<ep_rus>[^(]+?(?:\\([^)]+?\\))??))?(?:\\s+\\((?P<ep_org>[^)(]*?(?:\\([^)]+?\\))??)\\s?\\))?$'\n )\n@@ -32,23 +36,23 @@\n )\n \n quality_map = {\n-    'SD': '480p.mp3.xvid',\n-    '1080': '1080p.ac3.h264',\n-    'MP4': '720p.aac.h264',\n-    'HD': '720p.ac3.h264',\n+    'SD': '480p.xvid.sdr.mp3',\n+    '1080': '1080p.h264.sdr.ac3',\n+    'MP4': '720p.h264.sdr.aac',\n+    'HD': '720p.h264.sdr.ac3',\n }\n \n # All URLs must have '/' at the end\n SITE_URLS = [\n+    'https://www.lostfilm.download/',\n+    'https://www.lostfilm.today/',\n     'https://www.lostfilmtv2.site/',\n     'https://www.lostfilm.top/',\n-    'https://www.lostfilm.tw/',\n-    'https://www.lostfilmtv.site/',\n-    'https://www.lostfilmtv.uno/',\n     'https://www.lostfilm.run/',\n     'https://www.lostfilm.uno/',\n-    'https://www.lostfilm.win/',\n+    'https://www.lostfilmtv3.site/',\n     'https://www.lostfilm.tv/',\n+    'https://www.lostfilm.tw/',\n ]\n \n SIMPLIFY_MAP = str.maketrans({\n@@ -184,7 +188,7 @@ def on_task_input(self, task, config):\n             logger.error('Failed to get the RSS feed')\n             return None\n \n-        # Use failed site locations as the last resot option for the redirect page\n+        # Use failed site locations as the last resort option for the redirect page\n         site_urls.extend(tried_urls)\n \n         entries = []\n@@ -212,6 +216,14 @@ def on_task_input(self, task, config):\n                     episode_num = int(title_match['episode'])\n                     episode_name_rus = title_match['ep_rus']\n                 else:\n+                    title_movie_match = RSS_TITLE_MOVIE_REGEXP.fullmatch(item['title'])\n+                    if title_movie_match is not None:\n+                        logger.debug(\n+                            'Skipping movie \"{}\" (\"{}\")',\n+                            title_movie_match['movie_name'],\n+                            title_movie_match['movie_name_rus'],\n+                        )\n+                        continue\n                     logger.warning('Cannot parse RSS item title: {}', item['title'])\n \n             # Skip series names that are not configured.\n@@ -228,8 +240,8 @@ def on_task_input(self, task, config):\n                         folded_name = None\n                     if folded_name and folded_name not in prefilter_list:\n                         if idx != len(rss.entries) or entries or task.no_entries_ok:\n-                            logger.debug(\n-                                'Skipping \"{}\" as \"{}\" was not found in the list of configured series',\n+                            logger.verbose(\n+                                'Skipping \"{}\" as \"{}\" is not found in the list of configured series',\n                                 item['title'],\n                                 series_name_org,\n                             )\n@@ -265,7 +277,14 @@ def on_task_input(self, task, config):\n                     continue\n                 link_match = RSS_LINK_REGEXP.fullmatch(item['link'])\n                 if link_match is None:\n-                    logger.warning('Cannot parse RSS item link, skipping: {}', item['link'])\n+                    link_movie_match = RSS_LINK_MOVIE_REGEXP.fullmatch(item['link'])\n+                    if link_movie_match is not None:\n+                        logger.warning(\n+                            'Strange: series item has \"{}\" movie download link',\n+                            link_movie_match['movie_name2'],\n+                        )\n+                    else:\n+                        logger.warning('Cannot parse RSS item link, skipping: {}', item['link'])\n                     continue\n                 series_name_org = link_match['sr_org2'].replace('_', ' ')\n                 season_num = int(link_match['season'])\n@@ -315,7 +334,7 @@ def on_task_input(self, task, config):\n                 response = None\n                 tried_urls.append(site_urls.pop(0))\n \n-            # Use failed site locations as the last resot option for the next attempts\n+            # Use failed site locations as the last resort option for the next attempts\n             site_urls.extend(tried_urls)\n \n             if not response:\n@@ -334,28 +353,46 @@ def on_task_input(self, task, config):\n             page = get_soup(response.content)\n \n             download_page_url = None\n-            find_item = page.find('html', recursive=False)\n-            if find_item is not None:\n-                find_item = find_item.find('head', recursive=False)\n-                if find_item is not None:\n-                    find_item = find_item.find(\n+            html_item = page.find('html', recursive=False)\n+            if html_item is not None:\n+                found_item = html_item.find('head', recursive=False)\n+                if found_item is not None:\n+                    found_item = found_item.find(\n                         'meta', attrs={'http-equiv': 'refresh'}, recursive=False\n                     )\n-                    if (\n-                        find_item is not None\n-                        and find_item.has_attr('content')\n-                        and find_item['content'].startswith('0; url=http')\n-                    ):\n-                        download_page_url = find_item['content'][7:]\n+                    if found_item is not None:\n+                        if found_item.has_attr('content'):\n+                            if found_item['content'].startswith('0; url=/'):\n+                                download_page_url = site_urls[0] + found_item['content'][7:]\n+                            elif found_item['content'].startswith('0; url=https://') or found_item[\n+                                'content'\n+                            ].startswith('0; url=http://'):\n+                                download_page_url = found_item['content'][7:]\n+                            else:\n+                                logger.debug(\n+                                    'Failed to parse \"content\" value \"{}\"', found_item['content']\n+                                )\n+                        else:\n+                            logger.debug(\n+                                'Header meta \"refresh\" item has no \"content\": {}', found_item\n+                            )\n+                    else:\n+                        logger.debug('Header meta \"refresh\" item not found')\n+                else:\n+                    logger.debug('Failed to find the \"<head>\" section on the redirect page')\n+            else:\n+                logger.debug('Failed to parse the redirect page as HTML data')\n+            found_item = None\n+            html_item = None\n             if not download_page_url:\n                 if config.get('lf_session') is not None:\n                     logger.error(\n-                        'Links were not foung on lostfilm.tv torrent download page. '\n+                        'Links are not found on lostfilm.tv redirect page. '\n                         'Check whether \"lf_session\" parameter is correct.'\n                     )\n                 else:\n                     logger.error(\n-                        'Links were not foung on lostfilm.tv torrent download page. '\n+                        'Links are not found on lostfilm.tv redirect page. '\n                         'Specify your \"lf_session\" cookie value in plugin parameters.'\n                     )\n                 continue\n", "test_patch": "", "problem_statement": "Lostfilm plugin stopped working\n### Summary\n\nI'm downloading one weekly show from Lostfilm. The task using the Lostfilm plugin worked last week, but doesn't work this week. I tried re-login on the site and update the lf_session value, but it didn't help. Tried it with a basic config from the plugin description - same result.\n\n### Minimal reproducible config\n\n```yaml\ntasks:\n  download-task:\n    lostfilm: ###COOKIE REDACTED\n    series:\n      '1080p':\n        - 'Calls'\n        - 'High Potential'\n```\n\n### Log\n\n```text\n2025-10-31 11:07:24 DEBUG    task          download-task   executing download-task\n2025-10-31 11:07:24 DEBUG    status        download-task   Adding new task download-task\n2025-10-31 11:07:24 DEBUG    series        download-task   adding series `High Potential` `high potential` into db (on_task_start)\n2025-10-31 11:07:24 DEBUG    series        download-task   adding series `High Potential` into db (on_task_start)\n2025-10-31 11:07:24 DEBUG    series        download-task   -> added `<Series(id=1,name=High Potential,identified_by=None)>`\n2025-10-31 11:07:24 DEBUG    series        download-task   connecting series `High Potential` to task `download-task`\n2025-10-31 11:07:24 DEBUG    series        download-task   adding series `Calls` `calls` into db (on_task_start)\n2025-10-31 11:07:24 DEBUG    series        download-task   adding series `Calls` into db (on_task_start)\n2025-10-31 11:07:24 DEBUG    series        download-task   -> added `<Series(id=2,name=Calls,identified_by=None)>`\n2025-10-31 11:07:24 DEBUG    series        download-task   connecting series `Calls` to task `download-task`\n2025-10-31 11:07:24 DEBUG    lostfilm      download-task   lf_session is set\n2025-10-31 11:07:24 VERBOSE  lostfilm      download-task   Generated pre-filter list with 2 entries\n2025-10-31 11:07:25 VERBOSE  lostfilm      download-task   Received RSS feed from https://www.lostfilmtv2.site/rss.xml\n2025-10-31 11:07:25 WARNING  lostfilm      download-task   Cannot parse RSS item title: \u0412\u0441\u043f\u043e\u043c\u043d\u0438\u0442\u044c \u0432\u0441\u0451 (Total Recall). (\u0424\u0438\u043b\u044c\u043c)\n2025-10-31 11:07:25 DEBUG    lostfilm      download-task   Not skipping RSS item as series names may be detected incorrectly\n2025-10-31 11:07:25 WARNING  lostfilm      download-task   Cannot parse RSS item link, skipping: https://www.lostfilm.download/mr/movies/Total_Recall\n2025-10-31 11:07:25 DEBUG    lostfilm      download-task   Skipping \"\u0423\u0431\u0438\u0439\u0441\u0442\u0432\u0430 \u0432 \u043e\u0434\u043d\u043e\u043c \u0437\u0434\u0430\u043d\u0438\u0438 (Only Murders in the Building). \u0414\u043e\u043c \u0432\u0441\u0435\u0433\u0434\u0430.... (S05E10)\" as \"Only Murders in the Building\" was not found in the list of configured series\n2025-10-31 11:07:25 DEBUG    utils.requests download-task   GETing URL https://www.lostfilmtv2.site/v_search.php with args () and kwargs {'params': {'c': 1040, 's': 1, 'e': 9}, 'allow_redirects': True, 'timeout': 30}\n2025-10-31 11:07:25 DEBUG    lostfilm      download-task   The redirect page is downloaded from https://www.lostfilmtv2.site/v_search.php\n2025-10-31 11:07:25 ERROR    lostfilm      download-task   Links were not foung on lostfilm.tv torrent download page. Check whether \"lf_session\" parameter is correct.\n2025-10-31 11:07:25 DEBUG    utils.requests download-task   GETing URL https://www.lostfilmtv2.site/v_search.php with args () and kwargs {'params': {'c': 893, 's': 2, 'e': 7}, 'allow_redirects': True, 'timeout': 30}\n2025-10-31 11:07:25 DEBUG    lostfilm      download-task   The redirect page is downloaded from https://www.lostfilmtv2.site/v_search.php\n2025-10-31 11:07:25 ERROR    lostfilm      download-task   Links were not foung on lostfilm.tv torrent download page. Check whether \"lf_session\" parameter is correct.\n2025-10-31 11:07:25 DEBUG    utils.requests download-task   GETing URL https://www.lostfilmtv2.site/v_search.php with args () and kwargs {'params': {'c': 1040, 's': 1, 'e': 8}, 'allow_redirects': True, 'timeout': 30}\n2025-10-31 11:07:25 DEBUG    lostfilm      download-task   The redirect page is downloaded from https://www.lostfilmtv2.site/v_search.php\n2025-10-31 11:07:25 ERROR    lostfilm      download-task   Links were not foung on lostfilm.tv torrent download page. Check whether \"lf_session\" parameter is correct.\n2025-10-31 11:07:25 DEBUG    lostfilm      download-task   Skipping \"\u041e\u043d\u043e: \u0414\u043e\u0431\u0440\u043e \u043f\u043e\u0436\u0430\u043b\u043e\u0432\u0430\u0442\u044c \u0432 \u0414\u0435\u0440\u0440\u0438 (It: Welcome to Derry). \u041f\u0438\u043b\u043e\u0442. (S01E01)\" as \"It: Welcome to Derry\" was not found in the list of configured series\n2025-10-31 11:07:25 DEBUG    utils.requests download-task   GETing URL https://www.lostfilmtv2.site/v_search.php with args () and kwargs {'params': {'c': 1040, 's': 1, 'e': 7}, 'allow_redirects': True, 'timeout': 30}\n2025-10-31 11:07:25 DEBUG    lostfilm      download-task   The redirect page is downloaded from https://www.lostfilmtv2.site/v_search.php\n2025-10-31 11:07:25 ERROR    lostfilm      download-task   Links were not foung on lostfilm.tv torrent download page. Check whether \"lf_session\" parameter is correct.\n2025-10-31 11:07:25 DEBUG    utils.requests download-task   GETing URL https://www.lostfilmtv2.site/v_search.php with args () and kwargs {'params': {'c': 1040, 's': 1, 'e': 6}, 'allow_redirects': True, 'timeout': 30}\n2025-10-31 11:07:25 DEBUG    lostfilm      download-task   The redirect page is downloaded from https://www.lostfilmtv2.site/v_search.php\n2025-10-31 11:07:25 ERROR    lostfilm      download-task   Links were not foung on lostfilm.tv torrent download page. Check whether \"lf_session\" parameter is correct.\n2025-10-31 11:07:25 DEBUG    lostfilm      download-task   Skipping \"\u041c\u044d\u0440 \u041a\u0438\u043d\u0433\u0441\u0442\u0430\u0443\u043d\u0430 (Mayor of Kingstown). . (S04E01)\" as \"Mayor of Kingstown\" was not found in the list of configured series\n2025-10-31 11:07:25 DEBUG    lostfilm      download-task   Skipping \"\u041a\u043e\u0440\u043e\u043b\u044c \u0422\u0430\u043b\u0441\u044b (Tulsa King). \u041f\u0443\u0437\u044b\u0440\u044c\u043a\u0438. (S03E06)\" as \"Tulsa King\" was not found in the list of configured series\n2025-10-31 11:07:26 DEBUG    lostfilm      download-task   Skipping \"\u0414\u043e\u043c \u0414\u0430\u0432\u0438\u0434\u0430 (House of David). \u0411\u043e\u0433 \u043c\u0435\u0447\u0435\u0439. (S02E05)\" as \"House of David\" was not found in the list of configured series\n2025-10-31 11:07:26 DEBUG    utils.requests download-task   GETing URL https://www.lostfilmtv2.site/v_search.php with args () and kwargs {'params': {'c': 1040, 's': 1, 'e': 5}, 'allow_redirects': True, 'timeout': 30}\n2025-10-31 11:07:26 DEBUG    lostfilm      download-task   The redirect page is downloaded from https://www.lostfilmtv2.site/v_search.php\n2025-10-31 11:07:26 ERROR    lostfilm      download-task   Links were not foung on lostfilm.tv torrent download page. Check whether \"lf_session\" parameter is correct.\n2025-10-31 11:07:26 DEBUG    utils.requests download-task   GETing URL https://www.lostfilmtv2.site/v_search.php with args () and kwargs {'params': {'c': 1040, 's': 1, 'e': 4}, 'allow_redirects': True, 'timeout': 30}\n2025-10-31 11:07:26 DEBUG    lostfilm      download-task   The redirect page is downloaded from https://www.lostfilmtv2.site/v_search.php\n2025-10-31 11:07:26 ERROR    lostfilm      download-task   Links were not foung on lostfilm.tv torrent download page. Check whether \"lf_session\" parameter is correct.\n2025-10-31 11:07:26 DEBUG    utils.requests download-task   GETing URL https://www.lostfilmtv2.site/v_search.php with args () and kwargs {'params': {'c': 1040, 's': 1, 'e': 3}, 'allow_redirects': True, 'timeout': 30}\n2025-10-31 11:07:26 DEBUG    lostfilm      download-task   The redirect page is downloaded from https://www.lostfilmtv2.site/v_search.php\n2025-10-31 11:07:26 ERROR    lostfilm      download-task   Links were not foung on lostfilm.tv torrent download page. Check whether \"lf_session\" parameter is correct.\n2025-10-31 11:07:26 DEBUG    utils.requests download-task   GETing URL https://www.lostfilmtv2.site/v_search.php with args () and kwargs {'params': {'c': 1040, 's': 1, 'e': 2}, 'allow_redirects': True, 'timeout': 30}\n2025-10-31 11:07:26 DEBUG    lostfilm      download-task   The redirect page is downloaded from https://www.lostfilmtv2.site/v_search.php\n2025-10-31 11:07:26 ERROR    lostfilm      download-task   Links were not foung on lostfilm.tv torrent download page. Check whether \"lf_session\" parameter is correct.\n2025-10-31 11:07:26 DEBUG    backlog       download-task   0 entries purged from backlog\n2025-10-31 11:07:26 WARNING  details       download-task   Task didn't produce any entries. This is likely due to a misconfigured or non-functional input.\n2025-10-31 11:07:26 DEBUG    series        download-task   series on_task_metainfo took 0.01504091700000032 to parse\n2025-10-31 11:07:26 DEBUG    series        download-task   processing series took 0.003539374999999012\n2025-10-31 11:07:26 DEBUG    urlrewriter   download-task   Checking 0 entries\n2025-10-31 11:07:26 VERBOSE  details       download-task   Summary - Accepted: 0 (Rejected: 0 Undecided: 0 Failed: 0)\n2025-10-31 11:07:26 WARNING  task          download-task   Task doesn't have any output plugins, you should add (at least) one!\n2025-10-31 11:07:26 DEBUG    series        download-task   on_task_learn\n2025-10-31 11:07:26 DEBUG    util.simple_persistence download-task   Flushing simple persistence for task download-task to db.\n```\n\n### Additional information\n\n**FlexGet Version:** 3.18.20\n**Python Version:** 3.10.4\n**OS Version:** Armbian 21.02.3\n**Installation Method:** pip\n**Using Daemon (yes/no):** yes\n\n", "hints_text": "Any other info you need to fix it?\n@Karlson2k, maybe you can fix it? \ud83e\udd47 \nI may look on it next week, but lostfilm goes down periodically or some mirror may not work properly, so this situation could be just temporary. \n\nIt's been like this at least for the past two weeks, so it doesn't look temporary.\n\nA bit more information:\nIn my config, I'm always using the same (main) mirror: `site_urls: \"https://lostfilm.tv/\"`\nIt is accessible via web browser, and the cookies are grabbed from that specific mirror (idk if that matters, or if the same `lf_session` cookie works for any mirror). \nThe item links in RSS are referring to `https://www.lostfilm.download/`, which gets redirected to `https://www.lostfilm.today/`  Not sure if that's a recent change or if it was always this way. \n\nI tried to use each of those specific mirrors in the config, with the corresponding`lf_session` cookie. The results are the same:\n```\n2025-11-11 16:48:15 VERBOSE  lostfilm      LOSTFILM2       Received RSS feed from https://www.lostfilm.download/rss.xml\n2025-11-11 16:48:16 ERROR    lostfilm      LOSTFILM2       Links were not foung on lostfilm.tv torrent download page. Check whether \"lf_session\" parameter is correct.\n\n\n2025-11-11 16:59:32 VERBOSE  lostfilm      LOSTFILM2       Received RSS feed from https://www.lostfilm.today/rss.xml\n2025-11-11 16:59:32 ERROR    lostfilm      LOSTFILM2       Links were not foung on lostfilm.tv torrent download page. Check whether \"lf_session\" parameter is correct.\n```\nMaybe they changed something on the download page, so the parser is no longer working? It looks like the RSS feed gets downloaded, so it's probably not about the mirror outage or some other connection issue.\n\nOn a side note, there's a mistype in the error message, it says \"not founG\", instead of \"not founD\" :)\nThe cookie works for any mirror.\nThe new URL is a good hint. Probably some regexps matching should be fixed.\nI can take a look next week.\nAny luck?\n@shotfirer Thanks for a gentle reminder. I finally can get my hands on it. I should fix it soon.\n\n", "all_hints_text": "Any other info you need to fix it?\n@Karlson2k, maybe you can fix it? \ud83e\udd47 \nI may look on it next week, but lostfilm goes down periodically or some mirror may not work properly, so this situation could be just temporary. \n\nIt's been like this at least for the past two weeks, so it doesn't look temporary.\n\nA bit more information:\nIn my config, I'm always using the same (main) mirror: `site_urls: \"https://lostfilm.tv/\"`\nIt is accessible via web browser, and the cookies are grabbed from that specific mirror (idk if that matters, or if the same `lf_session` cookie works for any mirror). \nThe item links in RSS are referring to `https://www.lostfilm.download/`, which gets redirected to `https://www.lostfilm.today/`  Not sure if that's a recent change or if it was always this way. \n\nI tried to use each of those specific mirrors in the config, with the corresponding`lf_session` cookie. The results are the same:\n```\n2025-11-11 16:48:15 VERBOSE  lostfilm      LOSTFILM2       Received RSS feed from https://www.lostfilm.download/rss.xml\n2025-11-11 16:48:16 ERROR    lostfilm      LOSTFILM2       Links were not foung on lostfilm.tv torrent download page. Check whether \"lf_session\" parameter is correct.\n\n\n2025-11-11 16:59:32 VERBOSE  lostfilm      LOSTFILM2       Received RSS feed from https://www.lostfilm.today/rss.xml\n2025-11-11 16:59:32 ERROR    lostfilm      LOSTFILM2       Links were not foung on lostfilm.tv torrent download page. Check whether \"lf_session\" parameter is correct.\n```\nMaybe they changed something on the download page, so the parser is no longer working? It looks like the RSS feed gets downloaded, so it's probably not about the mirror outage or some other connection issue.\n\nOn a side note, there's a mistype in the error message, it says \"not founG\", instead of \"not founD\" :)\nThe cookie works for any mirror.\nThe new URL is a good hint. Probably some regexps matching should be fixed.\nI can take a look next week.\nAny luck?\n@shotfirer Thanks for a gentle reminder. I finally can get my hands on it. I should fix it soon.\n@shotfirer You may try a [full update](https://github.com/Flexget/Flexget/blob/78241e64e1d725caa2523533e61750b9f0c881de/flexget/components/sites/sites/lostfilm.py) of lostfilm plugin or just [the fix for this problem](https://github.com/Flexget/Flexget/blob/a8bc55b89917ca9da9f544592146e5b7e9e4edfc/flexget/components/sites/sites/lostfilm.py).\n@Karlson2k thanks, I have no clue how to compile it myself, so I'll just wait for the next release. I assume it will be included?\n@shotfirer This PR should be merged first by the project maintainers. Then it may spend some time in \"staging\". The it will be (hopefully) released with the Flexget.\nIn the meantime if maintainers will get independent confirmation for the fix, it may speed-up merging (and probably publishing the new release).\n\nYou do not need any programming skills to test the changes (and wait for the merge-test-release process).\nJust down load the file from aforementioned PR (or just use the direct link https://github.com/Flexget/Flexget/raw/027e5f03e5c4ca62121e078aa0181a6586590bf8/flexget/components/sites/sites/lostfilm.py) and overwrite file `flexget/components/sites/sites/lostfilm.py` in your Flexget installation.\nNext time you update Flexget, this file will be overwritten with upstream version. Make a backup if you wish, but it makes a little sense since current version is broken anyway.\n@zankevich, can you test the fix?\n@Karlson2k thank you for the explanation. I just tried and can confirm that it's working. Thanks for fixing!\n\n", "commit_urls": ["https://github.com/Flexget/Flexget/commit/cfe8ee3b94835672dbe60e8d9406d2b8fd57b4d2", "https://github.com/Flexget/Flexget/commit/db87b75a1980f684aacad5a8c193587008b7a5b3", "https://github.com/Flexget/Flexget/commit/be811cfe660b1afcb4d6af57c60ee3b8e6dd3205", "https://github.com/Flexget/Flexget/commit/46ea8fc14740c9b238b61f029b56e1baeadc62d6", "https://github.com/Flexget/Flexget/commit/491cd10c5fc3c64b80e48a78f79f39e538fa7e53", "https://github.com/Flexget/Flexget/commit/3599bf123f27575ed6c0c6abf4aa3c646320a4bd", "https://github.com/Flexget/Flexget/commit/b176d50bebe12e754869eba9c49b1b4dc84190a6", "https://github.com/Flexget/Flexget/commit/ac627a2ae5506891b5b54ade45ec6e64a5cd8ab3"], "created_at": "2025-11-29T22:07:55Z"}
{"repo": "Flexget/Flexget", "pull_number": 4816, "instance_id": "Flexget__Flexget-4816", "issue_numbers": [4749], "base_commit": "9bb03dbca7d1dc129fb598cc364bfb045aeed5a0", "patch": "diff --git a/.github/PULL_REQUEST_TEMPLATE.md b/.github/PULL_REQUEST_TEMPLATE.md\nindex 4b33b35c76..2ce5855037 100644\n--- a/.github/PULL_REQUEST_TEMPLATE.md\n+++ b/.github/PULL_REQUEST_TEMPLATE.md\n@@ -1,5 +1,21 @@\n-<!-- Thank you for submitting a pull request. Please:\n-* Read our pull request guidelines:\n-  https://github.com/Flexget/Flexget/blob/develop/.github/CONTRIBUTING.md#pull-requests\n-* Include a description of the proposed changes and how to test them.\n--->\n+### Motivation for changes:\n+\n+### Detailed changes:\n+\n+-\n+\n+### Addressed issues/feature requests:\n+\n+- Fixes #\n+\n+### Config usage if relevant (new plugin or updated schema):\n+\n+```\n+paste_config_here\n+```\n+\n+### Log and/or tests output (preferably both):\n+\n+```\n+paste output here\n+```\ndiff --git a/flexget/components/trakt/db.py b/flexget/components/trakt/db.py\nindex 565a17e86f..bc51c048e1 100644\n--- a/flexget/components/trakt/db.py\n+++ b/flexget/components/trakt/db.py\n@@ -1,5 +1,8 @@\n+from __future__ import annotations\n+\n import time\n from datetime import datetime, timedelta\n+from typing import TYPE_CHECKING\n \n from dateutil.parser import parse as dateutil_parse\n from loguru import logger\n@@ -14,6 +17,9 @@\n from flexget.utils.database import json_synonym\n from flexget.utils.tools import split_title_year\n \n+if TYPE_CHECKING:\n+    from flexget.entry import Entry\n+\n Base = db_schema.versioned_base('api_trakt', 7)\n AuthBase = db_schema.versioned_base('trakt_auth', 0)\n logger = logger.bind(name='api_trakt')\n@@ -218,7 +224,7 @@ def upgrade(ver, session):\n     return ver\n \n \n-def get_entry_ids(entry):\n+def get_entry_ids(entry: Entry):\n     \"\"\"Create a trakt ids dict from id fields on an entry. Prefer already populated info over lazy lookups.\"\"\"\n     ids = {}\n     for lazy in [False, True]:\n@@ -464,10 +470,10 @@ def update(self, trakt_episode, session):\n             raise ValueError('Tried to update db ep with different ep data')\n         if not self.id:\n             self.id = trakt_episode['ids']['trakt']\n-        self.imdb_id = trakt_episode['ids']['imdb']\n-        self.tmdb_id = trakt_episode['ids']['tmdb']\n-        self.tvrage_id = trakt_episode['ids']['tvrage']\n-        self.tvdb_id = trakt_episode['ids']['tvdb']\n+        self.imdb_id = trakt_episode['ids'].get('imdb')\n+        self.tmdb_id = trakt_episode['ids'].get('tmdb')\n+        self.tvrage_id = trakt_episode['ids'].get('tvrage')\n+        self.tvdb_id = trakt_episode['ids'].get('tvdb')\n         self.first_aired = None\n         if trakt_episode.get('first_aired'):\n             self.first_aired = dateutil_parse(trakt_episode['first_aired'], ignoretz=True)\n@@ -513,9 +519,9 @@ def update(self, trakt_season, session):\n             raise ValueError('Tried to update db season with different season data')\n         if not self.id:\n             self.id = trakt_season['ids']['trakt']\n-        self.tmdb_id = trakt_season['ids']['tmdb']\n-        self.tvrage_id = trakt_season['ids']['tvrage']\n-        self.tvdb_id = trakt_season['ids']['tvdb']\n+        self.tmdb_id = trakt_season['ids'].get('tmdb')\n+        self.tvrage_id = trakt_season['ids'].get('tvrage')\n+        self.tvdb_id = trakt_season['ids'].get('tvdb')\n         self.first_aired = None\n         if trakt_season.get('first_aired'):\n             self.first_aired = dateutil_parse(trakt_season['first_aired'], ignoretz=True)\n@@ -620,10 +626,10 @@ def update(self, trakt_show, session):\n         if not self.id:\n             self.id = trakt_show['ids']['trakt']\n         self.slug = trakt_show['ids']['slug']\n-        self.imdb_id = trakt_show['ids']['imdb']\n-        self.tmdb_id = trakt_show['ids']['tmdb']\n-        self.tvrage_id = trakt_show['ids']['tvrage']\n-        self.tvdb_id = trakt_show['ids']['tvdb']\n+        self.imdb_id = trakt_show['ids'].get('imdb')\n+        self.tmdb_id = trakt_show['ids'].get('tmdb')\n+        self.tvrage_id = trakt_show['ids'].get('tvrage')\n+        self.tvdb_id = trakt_show['ids'].get('tvdb')\n         if trakt_show.get('airs'):\n             airs = trakt_show.get('airs')\n             self.air_day = airs.get('day')\n@@ -820,8 +826,8 @@ def update(self, trakt_movie, session):\n         if not self.id:\n             self.id = trakt_movie['ids']['trakt']\n         self.slug = trakt_movie['ids']['slug']\n-        self.imdb_id = trakt_movie['ids']['imdb']\n-        self.tmdb_id = trakt_movie['ids']['tmdb']\n+        self.imdb_id = trakt_movie['ids'].get('imdb')\n+        self.tmdb_id = trakt_movie['ids'].get('tmdb')\n         for col in [\n             'title',\n             'overview',\ndiff --git a/flexget/components/trakt/trakt_lookup.py b/flexget/components/trakt/trakt_lookup.py\nindex e2b54c4a62..e84cfe7334 100644\n--- a/flexget/components/trakt/trakt_lookup.py\n+++ b/flexget/components/trakt/trakt_lookup.py\n@@ -14,6 +14,7 @@\n \n if TYPE_CHECKING:\n     from flexget.entry import Entry\n+    from flexget.utils.sqlalchemy_utils import ContextSession\n \n # TODO: not very nice ..\n lookup_series = plugin_api_trakt.ApiTrakt.lookup_series\n@@ -60,7 +61,13 @@ def trakt_user_data_lookup(entry, field_name, data_type, media_type, username, a\n         with Session() as session:\n             result = user_data_lookup(get_db_data_for(media_type, entry, session), entry['title'])\n     except LookupError as e:\n-        logger.debug(e)\n+        logger.debug(\n+            \"Failed lazy lookup of `{}` field `{}` from `{}`'s `{}`\",\n+            media_type,\n+            e,\n+            username,\n+            data_type,\n+        )\n     else:\n         entry[field_name] = result\n \n@@ -93,7 +100,7 @@ def _get_lookup_args(entry: Entry) -> dict:\n     return args\n \n \n-def get_db_data_for(data_type: str, entry: Entry, session: Session):\n+def get_db_data_for(data_type: str, entry: Entry, session: ContextSession):\n     if data_type == 'movie':\n         movie_lookup_args = _get_lookup_args(entry)\n         return lookup_movie(session=session, **movie_lookup_args)\n@@ -200,12 +207,12 @@ def get_db_data_for(data_type: str, entry: Entry, session: Session):\n \n \n @register_lazy_lookup('trakt_lazy_lookup')\n-def lazy_lookup(entry, lazy_lookup_name, media_type):\n+def lazy_lookup(entry: Entry, lazy_lookup_name: str, media_type: str):\n     with Session() as session:\n         try:\n             db_data = get_db_data_for(media_type, entry, session)\n         except LookupError as e:\n-            logger.debug(e)\n+            logger.debug('Failed {} lazy lookup: {}', media_type, e)\n         else:\n             entry.update_using_map(lazy_lookup_types[lazy_lookup_name], db_data)\n     return entry\n", "test_patch": "", "problem_statement": "trakt_lookup returns only \"None\"\n### Summary\n\nI just noticed that for about two weeks my downloads stopped working and when investigating I saw that all my trakt_lookup fields return \"None\". The same config was working fine for years.\n\nIn the log the first instance of \"utils.requests\" looks like flexget can find the correct series using the trakt api, since in the second \"utils.requests\" then uses the correct input. But the next line \"trakt_lookup tv 'tvrage'\" feels like the parsing of the second answer is incorrect?\n\nThe fields that return None for me are:\n\ntrakt_series_name\ntrakt_ep_id\ntrakt_season\ntrakt_ep_name\ntmdb_id\n\n### Minimal reproducible config\n\n```yaml\nschedules:\n  - tasks: \"*\"\n    interval:\n      minutes: 15\ntasks:\n  tv:\n    trakt_lookup: yes\n    rss:\n      url: https://XXX\n      other_fields: [content]\n    configure_series:\n      from:\n        trakt_list:\n          username: XXX\n          account: XXX\n          strip_dates: true\n          list: Download\n          type: shows\n      settings:\n        propers: 24 hours\n        upgrade: true\n        quality: 720p-1080p\n    manipulate:\n      - content:\n          extract: (http\\S+?\\.(?:mkv|mp4|rar.html))\n    exec:\n      on_output:\n        for_accepted: /usr/bin/systemd-cat -t flexget-download /srv/flexget/flexget-download.sh \"{{trakt_series_name}}\" \"{{trakt_ep_id}}\" \"{{trakt_season}}\" \"{{trakt_ep_name}}\" \"{{content}}\" \"{{title}}\" \"{{tmdb_id}}\"\n```\n\n### Log\n\n```text\n2025-11-27 14:58:10 VERBOSE  details       tv              Summary - Accepted: 1 (Rejected: 5 Undecided: 494 Failed: 0)\n2025-11-27 14:58:10 TRACE    modif_torrent tv              Pluribus.S01E05.Got.Milk.1080p.ATVP.WEB-DL.DD+5.1.Atmos.H.264-playWEB \u2013 3.5 GB doesn't have a file associated\n2025-11-27 14:58:10 TRACE    nzb_size      tv              Pluribus.S01E05.Got.Milk.1080p.ATVP.WEB-DL.DD+5.1.Atmos.H.264-playWEB \u2013 3.5 GB does not seem to be nzb\n2025-11-27 14:58:10 DEBUG    exec          tv              running phase_name: on_output operation: for_accepted entries: 1\n2025-11-27 14:58:10 DEBUG    api_trakt     tv              Searching with params: tvdb=436457\n2025-11-27 14:58:10 DEBUG    utils.requests tv              GETing URL https://api.trakt.tv/search with args () and kwargs {'params': {'id_type': 'tvdb', 'id': 436457}, 'allow_redirects': True, 'timeout': 30}\n2025-11-27 14:58:10 DEBUG    utils.requests tv              GETing URL https://api.trakt.tv/shows/206790 with args () and kwargs {'params': {'extended': 'full'}, 'allow_redirects': True, 'timeout': 30}\n2025-11-27 14:58:10 DEBUG    trakt_lookup  tv              'tvrage'\n2025-11-27 14:58:10 DEBUG    api_trakt     tv              Searching with params: tvdb=436457\n2025-11-27 14:58:10 DEBUG    utils.requests tv              GETing URL https://api.trakt.tv/search with args () and kwargs {'params': {'id_type': 'tvdb', 'id': 436457}, 'allow_redirects': True, 'timeout': 30}\n2025-11-27 14:58:11 DEBUG    utils.requests tv              GETing URL https://api.trakt.tv/shows/206790 with args () and kwargs {'params': {'extended': 'full'}, 'allow_redirects': True, 'timeout': 30}\n2025-11-27 14:58:11 DEBUG    trakt_lookup  tv              'tvrage'\n2025-11-27 14:58:11 DEBUG    exec          tv              phase_name: on_output operation: for_accepted cmd: /usr/bin/systemd-cat -t flexget-download /srv/flexget/flexget-download.sh \"None\" \"None\" \"None\" \"None\" \"https://XXX\" \"Pluribus.S01E05.Got.Milk.1080p.ATVP.WEB-DL.DD+5.1.Atmos.H.264-playWEB \u2013 3.5 GB\" \"None\"\n2025-11-27 14:58:11 VERBOSE  exec          tv              Executing: /usr/bin/systemd-cat -t flexget-download /srv/flexget/flexget-download.sh \"None\" \"None\" \"None\" \"None\" \"https://XXX\" \"Pluribus.S01E05.Got.Milk.1080p.ATVP.WEB-DL.DD+5.1.Atmos.H.264-playWEB \u2013 3.5 GB\" \"None\"\n```\n\n### Additional information\n\n**FlexGet Version:** 3.18.27\n**Python Version:** 3.12.3\n**OS Version:** Ubuntu Server 24.04.3\n**Installation Method:** PIP inside virtualenv\n**Using Daemon (yes/no):** yes\n\n", "hints_text": "I have the same issue and it's been like this for maybe a month now \ud83d\ude1e \nSeems the same type of problem I'm seeing here: https://github.com/Flexget/Flexget/discussions/4762 \nPhew, I was wondering if it was something I changed but now I see it's not just me.\nInstalled via UV tool as well shows same behavior, I doubt that's a difference maker but just adding for information too. Still present as of 3.18.34\n\nEdit:\nAs a workaround, at least for my case, I enabled thetvdb_lookups and changed:\ntrakt_ep_name\nto\ntvdb_ep_name\nI'm not sure, but I believe around the same time `season_packs` also broke. Flexget discovers them, adds to the library (marks as downloaded/processed), but notifications are not sent and they are never added to Deluge. I might create another issue about this when I get to my PC at some point\n\n", "all_hints_text": "I have the same issue and it's been like this for maybe a month now \ud83d\ude1e \nSeems the same type of problem I'm seeing here: https://github.com/Flexget/Flexget/discussions/4762 \nPhew, I was wondering if it was something I changed but now I see it's not just me.\nInstalled via UV tool as well shows same behavior, I doubt that's a difference maker but just adding for information too. Still present as of 3.18.34\n\nEdit:\nAs a workaround, at least for my case, I enabled thetvdb_lookups and changed:\ntrakt_ep_name\nto\ntvdb_ep_name\nI'm not sure, but I believe around the same time `season_packs` also broke. Flexget discovers them, adds to the library (marks as downloaded/processed), but notifications are not sent and they are never added to Deluge. I might create another issue about this when I get to my PC at some point\n\n", "commit_urls": ["https://github.com/Flexget/Flexget/commit/9295b850e005b39309748d19a5f2254c1584e7a3", "https://github.com/Flexget/Flexget/commit/bd220ca3da3ec1dc16f9f29d0ac240ac6a747a5d", "https://github.com/Flexget/Flexget/commit/b2115d4b9711136f286aae2e62642107e2213341", "https://github.com/Flexget/Flexget/commit/0e3340e5a19944ae94eea97811a2db0d84efa70d"], "created_at": "2026-01-15T18:43:58Z"}
{"repo": "Flexget/Flexget", "pull_number": 4779, "instance_id": "Flexget__Flexget-4779", "issue_numbers": [4760], "base_commit": "6b75a4803b8b5d66ad445003ed9f5bff4a2ca2f8", "patch": "diff --git a/flexget/utils/database.py b/flexget/utils/database.py\nindex fe94ee6c6f..cadfe82f97 100644\n--- a/flexget/utils/database.py\n+++ b/flexget/utils/database.py\n@@ -147,7 +147,10 @@ def __getattr__(self, item):\n \n def quality_property(text_attr):\n     def getter(self):\n-        return qualities.Quality(getattr(self, text_attr))\n+        try:\n+            return qualities.get(getattr(self, text_attr))\n+        except (ValueError, AttributeError):\n+            return qualities.Quality(getattr(self, text_attr))\n \n     def setter(self, value):\n         if isinstance(value, str):\n", "test_patch": "", "problem_statement": "Quality Recognization Error\n### Summary\n\n**Issue Summary**\n\nTwo releases are being parsed differently even though one of them contains a strictly better HDR profile:\n\n- **Name:** Pluribus S01E05 2160p WEB-DL DD+5.1 **DoVi HDR10+** HEVC-NTb  \n  **Detected:**  2160p webdl h265 hdr dd+5.1 (wrong)\n\n- **Name:** Pluribus S01E05 2160p WEB-DL DD+5.1 **DoVi** HEVC-NTb  \n  **Detected:** 2160p webdl h265 dolbyvision dd+5.1 (correct)\n\nThe first release contains **Dolby Vision + HDR10+**, but is only recognized as standard **hdr** (rather than hdrplus or dolbyvision or hybrid_hdr) , causing the quality comparer to incorrectly allow a downgrade when an upgrade check is performed. (Flexget will make second one a upgrade of first one)\n\n---\n\n**Proposed Improvement**\n\nThe first one should be recognized as hybird_hdr. After that there is a issue that hybird_hdr do not have internal logic does not distinguish different mixed HDR formats by *relative quality*.  \nI suggest enhancing the `hybrid_hdr` handling with a simple **scoring-based model** so that hybrid HDR stacks evaluate correctly.\n\n**Example Scoring:**\n\n- Dolby Vision = 40  \n- HDR10+ = 20  \n- HDR10 = 10  \n\nApplied to the above releases:\n\n- **DoVi + HDR10+ \u2192 60** (correctly highest)\n- **DoVi + HDR10 \u2192 50**\n- **DoVi only \u2192 40**\n\nThis prevents scenarios where a lower-quality DoVi-only release is treated as an upgrade over a DoVi+HDR10+ release.\n\n---\n\n**Additional Suggestion**\n\n`reorder_quality` should support assigning `Hybrid_HDR` qualities based on this scoring structure.  \nThis ensures the comparer can reliably rank hybrid HDR releases and avoid unintended downgrades.\n\n### Minimal reproducible config\n\n```yaml\n\n```\n\n### Log\n\n```text\n\n```\n\n### Additional information\n\n**FlexGet Version:** 3.18.28\n**Python Version:** \n**OS Version:** \n**Installation Method:**  Docker\n**Using Daemon (yes/no):** Yes\n\n", "hints_text": "The parsing is already scored\nhttps://github.com/Flexget/Flexget/blob/f73d6fa46e78af3aeec6ba5a0f1e2b6a714ca9b3/flexget/utils/qualities.py#L158-L169\nAlso, cannot repro the issue, hybrid was recognized as expected\n```yaml\ntasks:\n  test:\n    mock:\n      - Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb\n      - Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HEVC-NTb\n    series:\n       - Pluribus\n```\n```\ntitle               : Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb\nquality             : 2160p webdl h265 hybrid_hdr dd+5.1\n\ntitle               : Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb\nquality             : 2160p webdl h265 dolbyvision dd+5.1\n```\n\n\n> The parsing is already scored\n> \n> [Flexget/flexget/utils/qualities.py](https://github.com/Flexget/Flexget/blob/f73d6fa46e78af3aeec6ba5a0f1e2b6a714ca9b3/flexget/utils/qualities.py#L158-L169)\n> \n> Lines 158 to 169 in [f73d6fa](/Flexget/Flexget/commit/f73d6fa46e78af3aeec6ba5a0f1e2b6a714ca9b3)\n> \n>  hdr = r'hdr([^\\w]?10)?' \n>  hdr_plus = r'hdr(10)?[^\\w]?(\\+|p|plus)' \n>  dovi = r'(dolby[^\\w]?vision|dv|dovi)' \n>  _color_ranges = [ \n>      QualityComponent('color_range', 10, '8bit', r'8[^\\w]?bits?|hi8p?|sdr'), \n>      QualityComponent('color_range', 20, '10bit', r'10[^\\w]?bits?|hi10p?'), \n>      QualityComponent('color_range', 30, 'hdr', hdr), \n>      QualityComponent('color_range', 40, 'hdrplus', hdr_plus), \n>      QualityComponent('color_range', 50, 'dolbyvision', dovi), \n>      QualityComponent('color_range', 60, 'hybrid_hdr', f'(({dovi}|{hdr_plus}|{hdr})\\\\W?){{2,3}}'), \n>  ]\n\n\nThanks for sharing the code and example, from my understanding hybrid_hdr is currently treated as a single fixed value (60), so it can\u2019t differentiate combinations (e.g., DoVi+HDR10+ vs DoVi+HDR10). So if it supports combo-aware/additive scoring for this field,  hybrid formats can be ranked more accurately and future proof if more combination is possible.\n\n\n> Also, cannot repro the issue, hybrid was recognized as expected\n> \n> tasks:\n>   test:\n>     mock:\n>       - Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb\n>       - Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HEVC-NTb\n>     series:\n>        - Pluribus\n>  ```\n> title               : Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb\n> quality             : 2160p webdl h265 hybrid_hdr dd+5.1\n> \n> title               : Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb\n> quality             : 2160p webdl h265 dolbyvision dd+5.1\n> ```\n\nThanks for clarification, I rerun the test it's recognized correctly with 3.18.28. \n\n@BrutuZ After another experiment, I found something strange.\n\nWhen I using `flexget exec --task task_name --dump trace --no-cache --now` the dump result show correct quality \n\n> quality                    : 2160p webdl h265 hybrid_hdr dd+5.1\n> reason                     : target quality\n> release_group              : None\n> rss_pubdate                : 2025-12-05 02:14:54+00:00\n> season_pack                : None\n> series_episode             : 6\n> series_episodes            : 1\n> series_exact               : False\n> series_guessed             : True\n> series_id                  : S01E06\n> series_id_type             : ep\n> series_identified_by       : ep\n> series_name                : Pluribus\n> series_parser              : <SeriesParseResult(data=Pluribus S01E06 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb,name=Pluribus,id=(1, 6),season=1,season_pack=None,episode=6,quality=2160p webdl h265 hybrid_hdr\n>                              dd+5.1,proper=0,special=False,status=OK)>\n\nBut after the entry has been accept  I run `flexget series show Pluribus` to confirm what series plugin record, and it show a different record.\n\nThe Table show a different quality result \n| Identifier | Last seen | Release titles                                                    | Quality                             | Proper |\n|------------|-----------|-------------------------------------------------------------------|-------------------------------------|--------|\n| S01E06     | 0h        | Pluribus S01E06 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb *        | 2160p webdl h265 hdr dd+5.1         |        |\n\n\nHere is my configuration that related to this task \n\n```yml\ntemplates:\n  site_general:\n    transmission:\n      host: transmission\n      username: REPLACE_ME\n      password: REPLACE_ME\n      path: /data/SITE\n\ntasks:\n  site_watchlist_shows:\n    no_entries_ok: yes\n    template: site_general\n    rss:\n      url: \"REPLACE_WITH_PRIVATE_RSS_URL\"\n      all_entries: no\n    priority: 5\n\n    trakt_lookup: yes\n    imdb_lookup: yes\n    tmdb_lookup: yes\n\n    all_series:\n      timeframe: 6 hours\n      quality: 1080p+ webdl\n      target: 2160p+ dolbyvision+ webdl\n      upgrade: yes\n      season_packs: always\n      propers: yes\n\n    reorder_quality:\n      webdl:\n        above: bluray\n\n    sort_by:\n      field: quality\n      reverse: yes\n\n    best_quality:\n      identified_by: \"{{ media_id }} {{ series_id|default('') }}\"\n      on_best: do_nothing\n      on_lower: reject\n      single_best: no\n\n    set:\n      path: \"/data/SITE/{{series_name}}/Season {{series_season}}/\"\n      bandwidth_priority: 1\n\n    exists_series:\n      path: \"/data/SITE/{{series_name}}/\"\n      allow_different_qualities: better\n```\n\nNot sure why series plugin log the quality difference than what tasks emitting.\n\nThat also the reason I find originally believe it's a mismatch. \nBased on my initial analysis, the root cause appears to be:\n1. It originally correctly detected as `2160p webdl h265 hybrid_hdr dd+5.1`.\n2. It was saved into the database using the detected results `2160p webdl h265 hybrid_hdr dd+5.1` rather than the original input.\n3. When retrieving from the database, `2160p webdl h265 hybrid_hdr dd+5.1` will convert into `hdr` due to the matching rule. (hybrid_hdr will be based on hdr rather than hybrid_hdr)\nIf we change add hybird_hdr matching to it should quickly solve the problem \n\nhttps://github.com/Flexget/Flexget/blob/f73d6fa46e78af3aeec6ba5a0f1e2b6a714ca9b3/flexget/utils/qualities.py#L167\n`QualityComponent('color_range', 60, 'hybrid_hdr', f'(({dovi}|{hdr_plus}|{hdr})\\\\W?){{2,3}}|hybrid[\\\\W_]?hdr'),`\n\nMy local test passes with this patch: running  `flexget series show Pluribus` will print a table that quality is `hybrid_hdr`\n\nThat said, I\u2019m not fully confident this is the best fix yet\u2014it may have unintended side effects in other components.\n> When retrieving from the database, 2160p webdl h265 hybrid_hdr dd+5.1 will convert into hdr due to the matching rule. (hybrid_hdr will be based on hdr rather than hybrid_hdr)\n\nNo idea how that could be the case, the RegEx matching is done on the title, not on the string representation of the recognized quality\nIf I\u2019m understanding correctly, the `EpisodeRelease` class reads data from the dataset via SQLAlchemy ORM, including: `id, title, identifier, quality, series_id`.\n\nLooking at the series-related file: the `quality` column read from the database becomes `_quality`, is wrapped by `quality_property`, and is exposed as `quality`. That means when `quality` is accessed, it does not read from `title`.\nhttps://github.com/Flexget/Flexget/blob/35c1cef147d403ea16efa980a64d64f782d7b9b0/flexget/components/series/db.py#L418-L419\n\n`quality_property` sends the stored attribute through the Qualities plugin:\nhttps://github.com/Flexget/Flexget/blob/35c1cef147d403ea16efa980a64d64f782d7b9b0/flexget/utils/database.py#L148-L156\n\nSo, when a record is read, it starts from the database `quality` column, gets processed through `quality_property`, and becomes `release.quality`.\n\nHowever, when it is saved, the quality has already been set using `quality: Quality`, and when accessing `quality.name`, it returns a `hybird_hdr` name rather than the original name.\nhttps://github.com/Flexget/Flexget/blob/35c1cef147d403ea16efa980a64d64f782d7b9b0/flexget/components/series/db.py#L1507\n\nAnd since `quality` has a backing variable `_quality`, the setter shown above uses `quality.name` to set `_quality`, which is ultimately what gets saved into the database.\n\nSo the full chain maps `quality` through the Qualities plugin twice. For `hybird_hdr`, the repeated process is not idempotent, but for the others it is (e.g., `DoVi -> dolbyvision -> dolbyvision -> ...`, `HDR10 -> hdr -> hdr -> ...`, instead of `DoVi HDR -> hybird_hdr -> hdr -> hdr -> ...`.)\n\nThat means, if I\u2019m not misunderstanding (I\u2019m new to this project\u2019s source code, so I may be interpreting it wrong): when a record is fetched from the dataset, the qualities are based on the stored quality string (not the title), and that quality string is then sent through the Qualities plugin again for processing. From that process, only `hybird_hdr` has an issue, since it replaces the original `DoVi HDR` with `hybird_hdr`, and the next time it won\u2019t match as `hybird_hdr` but as `hdr`.\n\nThat also explains what I saw earlier: when dumping, it was recognized as `hybird_hdr`, but when running `flexget series show Pluribus`, the table shows a different result.\n\nI applied a quick fix:\n\n1. I patched it to `QualityComponent('color_range', 60, 'hybrid_hdr', f'(({dovi}|{hdr_plus}|{hdr})\\\\W?){{2,3}}|hybrid[\\\\W_]?hdr'),` by adding `hybrid[\\\\W_]?hdr` at score 60 to make the mapping idempotent.\n2. Restarted the FlexGet Docker container, and\n3. Ran `flexget series show Pluribus` again \u2014 it returned `hybird_hdr` in the result table.\n\nIn other words, after the patch I didn\u2019t need to rerun any tasks or modify the database. Just reading the existing table now produces the correct result in the CLI and Web page.\nI see, so the issue is not the expression per-se, but the way it's saved on the DB as a string and then re-parsed with the RegEx instead of using the names directly.\n\nI suppose this could be a better approach to hard-coding the title in the RegEx?\nhttps://github.com/Flexget/Flexget/blob/35c1cef147d403ea16efa980a64d64f782d7b9b0/flexget/utils/database.py#L150\n```diff\n-        return qualities.Quality(getattr(self, text_attr))\n+        return qualities.get(getattr(self, text_attr))\n```\nhttps://github.com/Flexget/Flexget/issues/4760#issuecomment-3621527351\nYes \u2014 that would be a more fundamental fix. Thanks for the suggestion/change. \ud83d\udc4d \n\nThe core issue isn\u2019t really the regex itself, but that the value gets processed twice: it\u2019s stored in the DB as a string though `Quality(...)`, and then later parsed again via `Quality(...)`. For most quality strings that\u2019s effectively idempotent, but `hybrid_hdr` isn\u2019t, so the second pass can change the content.\n\nSince I\u2019m still new to this repo, I wasn\u2019t confident that changing the behavior around the DB-backed values wouldn\u2019t introduce side effects in other parts of the project. So I went with a safer workaround in my own running environment by make `hybrid_hdr` idempotent. \n\n\n", "all_hints_text": "The parsing is already scored\nhttps://github.com/Flexget/Flexget/blob/f73d6fa46e78af3aeec6ba5a0f1e2b6a714ca9b3/flexget/utils/qualities.py#L158-L169\nAlso, cannot repro the issue, hybrid was recognized as expected\n```yaml\ntasks:\n  test:\n    mock:\n      - Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb\n      - Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HEVC-NTb\n    series:\n       - Pluribus\n```\n```\ntitle               : Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb\nquality             : 2160p webdl h265 hybrid_hdr dd+5.1\n\ntitle               : Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb\nquality             : 2160p webdl h265 dolbyvision dd+5.1\n```\n\n\n> The parsing is already scored\n> \n> [Flexget/flexget/utils/qualities.py](https://github.com/Flexget/Flexget/blob/f73d6fa46e78af3aeec6ba5a0f1e2b6a714ca9b3/flexget/utils/qualities.py#L158-L169)\n> \n> Lines 158 to 169 in [f73d6fa](/Flexget/Flexget/commit/f73d6fa46e78af3aeec6ba5a0f1e2b6a714ca9b3)\n> \n>  hdr = r'hdr([^\\w]?10)?' \n>  hdr_plus = r'hdr(10)?[^\\w]?(\\+|p|plus)' \n>  dovi = r'(dolby[^\\w]?vision|dv|dovi)' \n>  _color_ranges = [ \n>      QualityComponent('color_range', 10, '8bit', r'8[^\\w]?bits?|hi8p?|sdr'), \n>      QualityComponent('color_range', 20, '10bit', r'10[^\\w]?bits?|hi10p?'), \n>      QualityComponent('color_range', 30, 'hdr', hdr), \n>      QualityComponent('color_range', 40, 'hdrplus', hdr_plus), \n>      QualityComponent('color_range', 50, 'dolbyvision', dovi), \n>      QualityComponent('color_range', 60, 'hybrid_hdr', f'(({dovi}|{hdr_plus}|{hdr})\\\\W?){{2,3}}'), \n>  ]\n\n\nThanks for sharing the code and example, from my understanding hybrid_hdr is currently treated as a single fixed value (60), so it can\u2019t differentiate combinations (e.g., DoVi+HDR10+ vs DoVi+HDR10). So if it supports combo-aware/additive scoring for this field,  hybrid formats can be ranked more accurately and future proof if more combination is possible.\n\n\n> Also, cannot repro the issue, hybrid was recognized as expected\n> \n> tasks:\n>   test:\n>     mock:\n>       - Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb\n>       - Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HEVC-NTb\n>     series:\n>        - Pluribus\n>  ```\n> title               : Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb\n> quality             : 2160p webdl h265 hybrid_hdr dd+5.1\n> \n> title               : Pluribus S01E05 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb\n> quality             : 2160p webdl h265 dolbyvision dd+5.1\n> ```\n\nThanks for clarification, I rerun the test it's recognized correctly with 3.18.28. \n\n@BrutuZ After another experiment, I found something strange.\n\nWhen I using `flexget exec --task task_name --dump trace --no-cache --now` the dump result show correct quality \n\n> quality                    : 2160p webdl h265 hybrid_hdr dd+5.1\n> reason                     : target quality\n> release_group              : None\n> rss_pubdate                : 2025-12-05 02:14:54+00:00\n> season_pack                : None\n> series_episode             : 6\n> series_episodes            : 1\n> series_exact               : False\n> series_guessed             : True\n> series_id                  : S01E06\n> series_id_type             : ep\n> series_identified_by       : ep\n> series_name                : Pluribus\n> series_parser              : <SeriesParseResult(data=Pluribus S01E06 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb,name=Pluribus,id=(1, 6),season=1,season_pack=None,episode=6,quality=2160p webdl h265 hybrid_hdr\n>                              dd+5.1,proper=0,special=False,status=OK)>\n\nBut after the entry has been accept  I run `flexget series show Pluribus` to confirm what series plugin record, and it show a different record.\n\nThe Table show a different quality result \n| Identifier | Last seen | Release titles                                                    | Quality                             | Proper |\n|------------|-----------|-------------------------------------------------------------------|-------------------------------------|--------|\n| S01E06     | 0h        | Pluribus S01E06 2160p WEB-DL DD+5.1 DoVi HDR10+ HEVC-NTb *        | 2160p webdl h265 hdr dd+5.1         |        |\n\n\nHere is my configuration that related to this task \n\n```yml\ntemplates:\n  site_general:\n    transmission:\n      host: transmission\n      username: REPLACE_ME\n      password: REPLACE_ME\n      path: /data/SITE\n\ntasks:\n  site_watchlist_shows:\n    no_entries_ok: yes\n    template: site_general\n    rss:\n      url: \"REPLACE_WITH_PRIVATE_RSS_URL\"\n      all_entries: no\n    priority: 5\n\n    trakt_lookup: yes\n    imdb_lookup: yes\n    tmdb_lookup: yes\n\n    all_series:\n      timeframe: 6 hours\n      quality: 1080p+ webdl\n      target: 2160p+ dolbyvision+ webdl\n      upgrade: yes\n      season_packs: always\n      propers: yes\n\n    reorder_quality:\n      webdl:\n        above: bluray\n\n    sort_by:\n      field: quality\n      reverse: yes\n\n    best_quality:\n      identified_by: \"{{ media_id }} {{ series_id|default('') }}\"\n      on_best: do_nothing\n      on_lower: reject\n      single_best: no\n\n    set:\n      path: \"/data/SITE/{{series_name}}/Season {{series_season}}/\"\n      bandwidth_priority: 1\n\n    exists_series:\n      path: \"/data/SITE/{{series_name}}/\"\n      allow_different_qualities: better\n```\n\nNot sure why series plugin log the quality difference than what tasks emitting.\n\nThat also the reason I find originally believe it's a mismatch. \nBased on my initial analysis, the root cause appears to be:\n1. It originally correctly detected as `2160p webdl h265 hybrid_hdr dd+5.1`.\n2. It was saved into the database using the detected results `2160p webdl h265 hybrid_hdr dd+5.1` rather than the original input.\n3. When retrieving from the database, `2160p webdl h265 hybrid_hdr dd+5.1` will convert into `hdr` due to the matching rule. (hybrid_hdr will be based on hdr rather than hybrid_hdr)\nIf we change add hybird_hdr matching to it should quickly solve the problem \n\nhttps://github.com/Flexget/Flexget/blob/f73d6fa46e78af3aeec6ba5a0f1e2b6a714ca9b3/flexget/utils/qualities.py#L167\n`QualityComponent('color_range', 60, 'hybrid_hdr', f'(({dovi}|{hdr_plus}|{hdr})\\\\W?){{2,3}}|hybrid[\\\\W_]?hdr'),`\n\nMy local test passes with this patch: running  `flexget series show Pluribus` will print a table that quality is `hybrid_hdr`\n\nThat said, I\u2019m not fully confident this is the best fix yet\u2014it may have unintended side effects in other components.\n> When retrieving from the database, 2160p webdl h265 hybrid_hdr dd+5.1 will convert into hdr due to the matching rule. (hybrid_hdr will be based on hdr rather than hybrid_hdr)\n\nNo idea how that could be the case, the RegEx matching is done on the title, not on the string representation of the recognized quality\nIf I\u2019m understanding correctly, the `EpisodeRelease` class reads data from the dataset via SQLAlchemy ORM, including: `id, title, identifier, quality, series_id`.\n\nLooking at the series-related file: the `quality` column read from the database becomes `_quality`, is wrapped by `quality_property`, and is exposed as `quality`. That means when `quality` is accessed, it does not read from `title`.\nhttps://github.com/Flexget/Flexget/blob/35c1cef147d403ea16efa980a64d64f782d7b9b0/flexget/components/series/db.py#L418-L419\n\n`quality_property` sends the stored attribute through the Qualities plugin:\nhttps://github.com/Flexget/Flexget/blob/35c1cef147d403ea16efa980a64d64f782d7b9b0/flexget/utils/database.py#L148-L156\n\nSo, when a record is read, it starts from the database `quality` column, gets processed through `quality_property`, and becomes `release.quality`.\n\nHowever, when it is saved, the quality has already been set using `quality: Quality`, and when accessing `quality.name`, it returns a `hybird_hdr` name rather than the original name.\nhttps://github.com/Flexget/Flexget/blob/35c1cef147d403ea16efa980a64d64f782d7b9b0/flexget/components/series/db.py#L1507\n\nAnd since `quality` has a backing variable `_quality`, the setter shown above uses `quality.name` to set `_quality`, which is ultimately what gets saved into the database.\n\nSo the full chain maps `quality` through the Qualities plugin twice. For `hybird_hdr`, the repeated process is not idempotent, but for the others it is (e.g., `DoVi -> dolbyvision -> dolbyvision -> ...`, `HDR10 -> hdr -> hdr -> ...`, instead of `DoVi HDR -> hybird_hdr -> hdr -> hdr -> ...`.)\n\nThat means, if I\u2019m not misunderstanding (I\u2019m new to this project\u2019s source code, so I may be interpreting it wrong): when a record is fetched from the dataset, the qualities are based on the stored quality string (not the title), and that quality string is then sent through the Qualities plugin again for processing. From that process, only `hybird_hdr` has an issue, since it replaces the original `DoVi HDR` with `hybird_hdr`, and the next time it won\u2019t match as `hybird_hdr` but as `hdr`.\n\nThat also explains what I saw earlier: when dumping, it was recognized as `hybird_hdr`, but when running `flexget series show Pluribus`, the table shows a different result.\n\nI applied a quick fix:\n\n1. I patched it to `QualityComponent('color_range', 60, 'hybrid_hdr', f'(({dovi}|{hdr_plus}|{hdr})\\\\W?){{2,3}}|hybrid[\\\\W_]?hdr'),` by adding `hybrid[\\\\W_]?hdr` at score 60 to make the mapping idempotent.\n2. Restarted the FlexGet Docker container, and\n3. Ran `flexget series show Pluribus` again \u2014 it returned `hybird_hdr` in the result table.\n\nIn other words, after the patch I didn\u2019t need to rerun any tasks or modify the database. Just reading the existing table now produces the correct result in the CLI and Web page.\nI see, so the issue is not the expression per-se, but the way it's saved on the DB as a string and then re-parsed with the RegEx instead of using the names directly.\n\nI suppose this could be a better approach to hard-coding the title in the RegEx?\nhttps://github.com/Flexget/Flexget/blob/35c1cef147d403ea16efa980a64d64f782d7b9b0/flexget/utils/database.py#L150\n```diff\n-        return qualities.Quality(getattr(self, text_attr))\n+        return qualities.get(getattr(self, text_attr))\n```\nhttps://github.com/Flexget/Flexget/issues/4760#issuecomment-3621527351\nYes \u2014 that would be a more fundamental fix. Thanks for the suggestion/change. \ud83d\udc4d \n\nThe core issue isn\u2019t really the regex itself, but that the value gets processed twice: it\u2019s stored in the DB as a string though `Quality(...)`, and then later parsed again via `Quality(...)`. For most quality strings that\u2019s effectively idempotent, but `hybrid_hdr` isn\u2019t, so the second pass can change the content.\n\nSince I\u2019m still new to this repo, I wasn\u2019t confident that changing the behavior around the DB-backed values wouldn\u2019t introduce side effects in other parts of the project. So I went with a safer workaround in my own running environment by make `hybrid_hdr` idempotent. \n\nI generated a pull request https://github.com/Flexget/Flexget/pull/4779. To apply suggested change on https://github.com/Flexget/Flexget/issues/4760#issuecomment-3621527351\n\n", "commit_urls": ["https://github.com/Flexget/Flexget/commit/ad0083002726d337c8ec615290d539e092be6d59", "https://github.com/Flexget/Flexget/commit/e0ec73c7a61e534b4076493a297088593d364aeb"], "created_at": "2025-12-12T20:40:54Z"}
{"repo": "Flexget/Flexget", "pull_number": 4898, "instance_id": "Flexget__Flexget-4898", "issue_numbers": [4800], "base_commit": "84ee6c15b3b0e54cc075e661beae9b37ff2789bf", "patch": "diff --git a/flexget/plugins/clients/pyload.py b/flexget/plugins/clients/pyload.py\nindex 48419218a0..f59bd24e92 100644\n--- a/flexget/plugins/clients/pyload.py\n+++ b/flexget/plugins/clients/pyload.py\n@@ -13,37 +13,26 @@\n \n \n class PyloadApi:\n-    def __init__(self, requests, url):\n+    def __init__(self, requests, url, username, password):\n         self.requests = requests\n-        self.url = url\n+        self.url = url.rstrip('/') + '/'\n+        self.auth = username, password\n \n-    def get_session(self, config):\n-        # Login\n-        data = {'username': config['username'], 'password': config['password']}\n-        result = self.post('login', data=data)\n-        response = result.json()\n-        if not response:\n-            raise plugin.PluginError('Login failed', logger)\n-\n-        if isinstance(response, str):\n-            return response.replace('\"', '')\n-        return response\n-\n-    def get(self, method):\n+    def get(self, endpoint):\n         try:\n-            return self.requests.get(self.url.rstrip('/') + '/' + method.strip('/'))\n+            return self.requests.get(self.url + endpoint.strip('/'), auth=self.auth)\n         except RequestException as e:\n             if e.response and e.response.status_code == 500:\n-                raise plugin.PluginError(f'Internal API Error: <{method}> <{self.url}>', logger)\n+                raise plugin.PluginError(f'Internal API Error: <{endpoint}> <{self.url}>', logger)\n             raise\n \n-    def post(self, method, data):\n+    def post(self, endpoint, data):\n         try:\n-            return self.requests.post(self.url.rstrip('/') + '/' + method.strip('/'), data=data)\n+            return self.requests.post(self.url + endpoint.strip('/'), data=data, auth=self.auth)\n         except RequestException as e:\n             if e.response and e.response.status_code == 500:\n                 raise plugin.PluginError(\n-                    f'Internal API Error: <{method}> <{self.url}> <{data}>', logger\n+                    f'Internal API Error: <{endpoint}> <{self.url}> <{data}>', logger\n                 )\n             raise\n \n@@ -78,9 +67,6 @@ class PluginPyLoad:\n           enabled: yes\n     \"\"\"\n \n-    __author__ = 'http://pyload.org'\n-    __version__ = '0.5'\n-\n     DEFAULT_API = 'http://localhost:8000/api'\n     DEFAULT_QUEUE = False\n     DEFAULT_FOLDER = ''\n@@ -122,33 +108,7 @@ def on_task_output(self, task, config):\n     def add_entries(self, task, config):\n         \"\"\"Add accepted entries.\"\"\"\n         apiurl = config.get('api', self.DEFAULT_API)\n-        api = PyloadApi(task.requests, apiurl)\n-\n-        try:\n-            session = api.get_session(config)\n-        except OSError:\n-            raise plugin.PluginError('pyLoad not reachable', logger)\n-        except plugin.PluginError:\n-            raise\n-        except Exception as e:\n-            raise plugin.PluginError(f'Unknown error: {e!s}', logger)\n-\n-        # old pyload (stable)\n-        is_pyload_ng = False\n-        parse_urls_command = 'parseURLs'\n-        add_package_command = 'addPackage'\n-        set_package_data_command = 'setPackageData'\n-        package_id_parameter = 'pid'\n-        folder_key = 'folder'\n-\n-        # pyload-ng is returning dict instead of session string on login\n-        if isinstance(session, dict):\n-            is_pyload_ng = True\n-            parse_urls_command = 'parse_urls'\n-            add_package_command = 'add_package'\n-            set_package_data_command = 'set_package_data'\n-            package_id_parameter = 'package_id'\n-            folder_key = '_folder'\n+        api = PyloadApi(task.requests, apiurl, config['username'], config['password'])\n \n         hoster = config.get('hoster', self.DEFAULT_HOSTER)\n \n@@ -159,25 +119,15 @@ def add_entries(self, task, config):\n             if description is not None:\n                 contents.append(description)\n             contents.append(quote(entry['url']))\n-            content = ' '.join(contents)\n \n-            content = repr(content)\n+            content = repr(' '.join(contents))\n \n-            if is_pyload_ng:\n-                url = repr(entry['url'] if config.get('parse_url', self.DEFAULT_PARSE_URL) else '')\n-            else:\n-                url = (\n-                    json.dumps(entry['url'])\n-                    if config.get('parse_url', self.DEFAULT_PARSE_URL)\n-                    else \"''\"\n-                )\n+            url = repr(entry['url'] if config.get('parse_url', self.DEFAULT_PARSE_URL) else '')\n \n             logger.debug('Parsing url {}', url)\n \n             data = {'html': content, 'url': url}\n-            if not is_pyload_ng:\n-                data['session'] = session\n-            result = api.post(parse_urls_command, data=data)\n+            result = api.post('parse_urls', data=data)\n \n             parsed = result.json()\n \n@@ -225,21 +175,12 @@ def add_entries(self, task, config):\n                     name = entry['title']\n                     logger.error('Error rendering jinja event: {}', e)\n \n-                if is_pyload_ng:\n-                    data = {\n-                        'name': repr(name.encode('ascii', 'ignore').decode()),\n-                        'links': repr(urls),\n-                        'dest': dest,\n-                    }\n-                else:\n-                    data = {\n-                        'name': json.dumps(name.encode('ascii', 'ignore').decode()),\n-                        'links': json.dumps(urls),\n-                        'dest': json.dumps(dest),\n-                        'session': session,\n-                    }\n-\n-                pid = api.post(add_package_command, data=data).text\n+                data = {\n+                    'name': repr(name.encode('ascii', 'ignore').decode()),\n+                    'links': repr(urls),\n+                    'dest': dest,\n+                }\n+                pid = api.post('add_package', data=data).text\n                 logger.debug('added package pid: {}', pid)\n \n                 # Set Folder\n@@ -253,20 +194,16 @@ def add_entries(self, task, config):\n                         folder = self.DEFAULT_FOLDER\n                         logger.error('Error rendering jinja event: {}', e)\n                     # set folder with api\n-                    data = json.dumps({folder_key: folder})\n-                    post_data = {package_id_parameter: pid, 'data': data}\n-                    if not is_pyload_ng:\n-                        post_data['session'] = session\n-                    api.post(set_package_data_command, data=post_data)\n+                    data = json.dumps({'_folder': folder})\n+                    post_data = {'package_id': pid, 'data': data}\n+                    api.post('set_package_data', data=post_data)\n \n                 # Set Package Password\n                 package_password = config.get('package_password')\n                 if package_password:\n                     data = json.dumps({'password': package_password})\n-                    post_data = {package_id_parameter: pid, 'data': data}\n-                    if not is_pyload_ng:\n-                        post_data['session'] = session\n-                    api.post(set_package_data_command, data=post_data)\n+                    post_data = {'package_id': pid, 'data': data}\n+                    api.post('set_package_data', data=post_data)\n \n             except Exception as e:\n                 entry.fail(str(e))\ndiff --git a/pyproject.toml b/pyproject.toml\nindex 912f773a8b..5788c20cc9 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -242,7 +242,7 @@ max_supported_python = \"3.14\"\n keep_full_version = true\n \n [tool.typos]\n-default.extend-ignore-re = [\n+default.extend-ignore-identifiers-re = [\n   \"idel\",\n   \"parametros\",\n   \"Programe\",\n@@ -250,11 +250,14 @@ default.extend-ignore-re = [\n   \"SerieS\",\n   \"23BA98\",\n   \"IST\",\n+  \"McClory\",\n+  \"[Pp]yload\",\n+]\n+default.extend-ignore-words-re = [\n+  \"nd\",\n+  \"sur\",\n+  \"hime\",\n ]\n-default.extend-identifiers.McClory = \"McClory\"\n-default.extend-words.nd = \"nd\"\n-default.extend-words.sur = \"sur\"\n-default.extend-words.hime = \"hime\"\n files.extend-exclude = [\n   \"**/cassettes/*\",\n   \"tests/couchpotato_movie_list_test_response.json\",\n", "test_patch": "", "problem_statement": "Upgrade pyLoad plugin to support recent API changes\n### Summary\n\nPyload version 0.5.0b3.dev94 seems to have breaking changes in the  API. There is not much useful information other than \"pyload not reachable\" in debug logs and CLI output, which would indicate that the get_session call is failing.\n\n\n`2025-12-30 11:58:44 DEBUG    series        DownloadTask processing series took 0.20829401800000014`\n`2025-12-30 11:58:44 DEBUG    urlrewriter   DownloadTask Checking 5 entries`\n`2025-12-30 11:58:44 VERBOSE  details       DownloadTask Summary - Accepted: 5 (Rejected: 25 Undecided: 0 Failed: 0)`\n`2025-12-30 11:58:44 DEBUG    utils.requests DownloadTask POSTing URL http://pyload-ng:8000/api/login with args () and kwargs {'data': {'username': 'user', 'password': 'pass'}, 'json': None, 'timeout': 30}`\n`2025-12-30 11:58:44 CRITICAL pyload        DownloadTask pyLoad not reachable`\n`2025-12-30 11:58:44 WARNING  task          DownloadTask Aborting task (plugin: pyload)`\n`2025-12-30 11:58:44 DEBUG    backlog       DownloadTask Remembering all entries to backlog because of task abort.`\n\nDowngrade to pyload 0.5.0b3.dev93 fixes the issue. See also [here](https://github.com/pyload/pyload/issues/4673) for a similar issue in another API integration.\n\n**FlexGet Version:**3.18.34\n**Python Version:**3.11.14\n**OS Version:**official docker container\n**Installation Method:**docker\n**Using Daemon (yes/no):**yes\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/Flexget/Flexget/commit/ad53f0d1feb65a43e1dde0bd1c63d2df0d365d88"], "created_at": "2026-03-02T11:02:32Z"}
{"repo": "Flexget/Flexget", "pull_number": 4987, "instance_id": "Flexget__Flexget-4987", "issue_numbers": [4941], "base_commit": "6e26ac8624b898f695968eac8177bb07fe35cc13", "patch": "diff --git a/flexget/plugins/filter/exists_series.py b/flexget/plugins/filter/exists_series.py\nindex d088900248..d2305b085b 100644\n--- a/flexget/plugins/filter/exists_series.py\n+++ b/flexget/plugins/filter/exists_series.py\n@@ -36,6 +36,7 @@ class FilterExistsSeries:\n                         'enum': ['better', True, False],\n                         'default': False,\n                     },\n+                    'recursive': {'type': 'boolean', 'default': False},\n                 },\n                 'required': ['path'],\n                 'additionalProperties': False,\n@@ -88,7 +89,7 @@ def on_task_filter(self, task, config):\n                     logger.warning('Directory {} does not exist', folder)\n                     continue\n \n-                for filename in folder.iterdir():\n+                for filename in folder.rglob('*') if config.get('recursive') else folder.iterdir():\n                     # run parser on filename data\n                     try:\n                         disk_parser = plugin.get('parsing', self).parse_series(\n", "test_patch": "", "problem_statement": "exists_series does not scan subdirectories (non-recursive)\n### Summary\n\n`exists_series` uses `folder.iterdir()` ([source](https://github.com/Flexget/Flexget/blob/develop/flexget/plugins/filter/exists_series.py#L91)) which only lists direct children of the configured path. It does **not** recurse into subdirectories.                                                                                                              \n                                                   \n  This means it fails to find episodes in typical media library structures organized by season:                                                                                                                                                                                                                                                                      \n                                                   \n  /storage/series/Show Name/                                                                                                                                                                                                                                                                                                                                         \n  \u251c\u2500\u2500 Season 1/                                    \n  \u2502   \u2514\u2500\u2500 Show.Name.S01E01.1080p.mkv   \u2190 never found\n  \u251c\u2500\u2500 Season 2/                                                                                                                                                                                                                                                                                                                                                      \n  \u2502   \u2514\u2500\u2500 Show.Name.S02E01.1080p.mkv   \u2190 never found\n  \u251c\u2500\u2500 poster.jpg                        \u2190 scanned (useless)                                                                                                                                                                                                                                                                                                          \n  \u2514\u2500\u2500 tvshow.nfo                        \u2190 scanned (useless)                                                                                                                                                                                                                                                                                                          \n                                         \n  ## Expected Behavior                                                                                                                                                                                                                                                                                                                                               \n                                                   \n  The [documentation](https://flexget.com/Plugins/exists_series) shows:                                                                                                                                                                                                                                                                                              \n   \n  ```yaml                                                                                                                                                                                                                                                                                                                                                            \n  exists_series: /storage/series/                  \n   ```                                   \n  This implies the plugin scans the entire series collection recursively. The \"Performance\" section even suggests using {{series_name}} to optimize by narrowing the scan scope \u2014 which only makes sense if the default behavior is to scan recursively.                                                                                                             \n   \n  ## Actual Behavior                                                                                                                                                                                                                                                                                                                                                    \n                                                   \n  The plugin only scans the top-level directory. With the common config:                                                                                                                                                                                                                                                                                             \n  ``` \n  exists_series:                                                                                                                                                                                                                                                                                                                                                     \n    path:                                          \n      - '/storage/series/{{series_name}}/'\n  ```                                                                                                                                                                                                                                                                                                                                                               \n  It sees Season 1/ and Season 2/ as directory names (which fail to parse as episodes) but never enters them to find the actual .mkv files. The plugin produces no rejections and no errors \u2014 it silently does nothing.                                                                                                                                              \n                                                                                                                                                                                                                                                                                                                                                                     \n  Zero output at debug AND trace log levels for the actual matching logic, since no valid episodes are ever found.                                                                                                                                                                                                                                                   \n                                                   \n##  Workaround                                                                                                                                                                                                                                                                                                                                                         \n                                                   \n  Include the season subdirectory in the path using the series_season template variable:                                                                                                                                                                                                                                                                             \n```   \n  exists_series:                                                                                                                                                                                                                                                                                                                                                     \n    path:                                          \n      - '/storage/series/{{series_name}}/Season {{series_season}}/'\n```\n                                                                                                                                                                      \n                                                   \n##  Environment                                                                                                                                                                                                                                                                                                                                                        \n                                                   \n  - FlexGet 3.19.3                       \n  - Python 3.12\n  - Linux\n\n\n### Minimal reproducible config\n\n```yaml\n\n```\n\n### Log\n\n```text\n\n```\n\n### Additional information\n\n**FlexGet Version:** 3.19.3\n**Python Version:** 3.12\n**OS Version:** 24.04\n**Installation Method:** \n**Using Daemon (yes/no):**\n\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/Flexget/Flexget/commit/673448e793fe5311209e1cb8207ae781f8f2e243"], "created_at": "2026-04-19T22:00:38Z"}
{"repo": "Flexget/Flexget", "pull_number": 4986, "instance_id": "Flexget__Flexget-4986", "issue_numbers": [4942], "base_commit": "e4cce84ad955161e5fae890beccf1c3a6e32d837", "patch": "diff --git a/flexget/plugins/filter/exists_series.py b/flexget/plugins/filter/exists_series.py\nindex d2305b085b..175357b67b 100644\n--- a/flexget/plugins/filter/exists_series.py\n+++ b/flexget/plugins/filter/exists_series.py\n@@ -25,6 +25,8 @@ class FilterExistsSeries:\n       exists_series: /storage/series/\n     \"\"\"\n \n+    VIDEO_EXTENSIONS = {'.avi', '.mkv', '.mp4', '.mpg', '.m4v', '.ts', '.wmv', '.webm'}\n+\n     schema = {\n         'anyOf': [\n             one_or_more({'type': 'string', 'format': 'path'}),\n@@ -90,6 +92,8 @@ def on_task_filter(self, task, config):\n                     continue\n \n                 for filename in folder.rglob('*') if config.get('recursive') else folder.iterdir():\n+                    if filename.is_file() and filename.suffix.lower() not in self.VIDEO_EXTENSIONS:\n+                        continue\n                     # run parser on filename data\n                     try:\n                         disk_parser = plugin.get('parsing', self).parse_series(\n", "test_patch": "diff --git a/tests/test_exists_series.py b/tests/test_exists_series.py\nindex 0344a848f4..3fc0556152 100644\n--- a/tests/test_exists_series.py\n+++ b/tests/test_exists_series.py\n@@ -84,6 +84,13 @@ class TestExistsSeries:\n             - title: jinja2 s01e01\n             accept_all: yes\n             exists_series: __tmp__\n+\n+          test_non_video_skipped:\n+            mock:\n+              - {title: 'Foo.Bar.S01E02.XViD'}\n+            series:\n+              - foo bar\n+            exists_series: __tmp__/nonvideo\n     \"\"\"\n \n     test_dirs = [\n@@ -102,6 +109,11 @@ def config(self, request, tmp_path):\n         \"\"\"Override and parametrize default config fixture for all series tests.\"\"\"\n         for test_dir in self.test_dirs:\n             (tmp_path / test_dir).mkdir(parents=True)\n+        # Create non-video directory with subtitle/nfo files matching a series\n+        nonvideo = tmp_path / 'nonvideo'\n+        nonvideo.mkdir(exist_ok=True)\n+        (nonvideo / 'Foo.Bar.S01E02.XViD.srt').touch()\n+        (nonvideo / 'Foo.Bar.S01E02.XViD.nfo').touch()\n         return self._config.replace('__parser__', request.param).replace('__tmp__', str(tmp_path))\n \n     def test_existing(self, execute_task):\n@@ -177,3 +189,10 @@ def test_jinja_path(self, manager, execute_task):\n         assert task.find_entry('accepted', title='jinja s01e02'), (\n             'jinja s01e02 should have been accepted'\n         )\n+\n+    def test_non_video_skipped(self, execute_task):\n+        \"\"\"Non-video files (srt, nfo) should be ignored by exists_series.\"\"\"\n+        task = execute_task('test_non_video_skipped')\n+        assert task.find_entry('accepted', title='Foo.Bar.S01E02.XViD'), (\n+            'Foo.Bar.S01E02.XViD should have been accepted (only non-video files on disk)'\n+        )\n", "problem_statement": "exists_series matches non-video files (.srt, .nfo, .jpg) causing false rejections\n### Summary\n\n## Bug Description\n\n  `exists_series` parses **every file** in the configured directory, including subtitle files (`.srt`), metadata (`.nfo`), and images (`.jpg`, `.png`). Any file whose name contains a valid series pattern (e.g., `Show.S01E01.720p.eng.srt`) is treated as an existing episode and can trigger a rejection.                                                        \n   \n  ## Expected Behavior                                                                                                                                                                                                                                                                                                                                               \n                                                   \n  Only video files (`.mkv`, `.avi`, `.mp4`, `.m4v`, `.ts`, `.wmv`) should be considered when determining whether an episode already exists on disk.                                                                                                                                                                                                                  \n   \n  ## Actual Behavior                                                                                                                                                                                                                                                                                                                                                 \n                                                   \n  From debug logs, the plugin parses and matches subtitle files:                                                                                                                                                                                                                                                                                                     \n   ```\n2026-03-24 19:52:53 DEBUG    parser_internal TV_DDL          Parsing series: `The.Night.Manager.S01E03.Episode.3.720p.eng.srt` kwargs: {'name': 'The Night Manager'}\n2026-03-24 19:52:53 DEBUG    parser_internal TV_DDL          Parsing result: <SeriesParser(data=The.Night.Manager.S01E03.Episode.3.720p.eng.srt,name=The Night Manager,id=(1, 3),id_type=ep,identified_by=auto,season=1,season_pack=None,episode=3,quality=720p,proper=0,status=OK)> (in 0.18041800012724707 ms)\n2026-03-24 19:52:53 DEBUG    exists_series TV_DDL          name The.Night.Manager.S01E03.Episode.3.720p.eng.srt is same series as The Night Manager\n2026-03-24 19:52:53 DEBUG    exists_series TV_DDL          disk_parser.identifier = S01E03\n2026-03-24 19:52:53 DEBUG    exists_series TV_DDL          disk_parser.quality = 720p\n2026-03-24 19:52:53 DEBUG    exists_series TV_DDL          disk_parser.proper_count = 0                                                                                                                                                                                                                                                                                                             \n```\n                                                                                                                                                                                                                                                                   \n                                                                                                                                                                                                                                                                                                                                                                     \n ##  Environment                                      \n                                         \n  - FlexGet 3.19.3\n  - Python 3.12\n  - Linux                                       \n\n### Minimal reproducible config\n\n```yaml\n\n```\n\n### Log\n\n```text\n2026-03-24 19:52:52 DEBUG    parser_internal TV_DDL          Parsing series: `The.Night.Manager.S02E05.Episode.5.WEBRip-1080p.mkv` kwargs: {'name': 'The Night Manager'}\n2026-03-24 19:52:52 DEBUG    parser_internal TV_DDL          Parsing result: <SeriesParser(data=The.Night.Manager.S02E05.Episode.5.WEBRip-1080p.mkv,name=The Night Manager,id=(2, 5),id_type=ep,identified_by=auto,season=2,season_pack=None,episode=5,quality=1080p webrip,proper=0,status=OK)> (in 0.1904779999222228 ms)\n2026-03-24 19:52:52 DEBUG    exists_series TV_DDL          name The.Night.Manager.S02E05.Episode.5.WEBRip-1080p.mkv is same series as The Night Manager\n2026-03-24 19:52:52 DEBUG    exists_series TV_DDL          disk_parser.identifier = S02E05\n2026-03-24 19:52:52 DEBUG    exists_series TV_DDL          disk_parser.quality =