diff --git a/scrapy/utils/asyncio.py b/scrapy/utils/asyncio.py
index e03b7b38a..34baa8e66 100644
--- a/scrapy/utils/asyncio.py
+++ b/scrapy/utils/asyncio.py
@@ -84,6 +84,25 @@ def is_asyncio_available() -> bool:
     # Check if there is an installed asyncio reactor (it doesn't need to be
     # running).
     if not is_reactor_installed():
+        # In reactorless mode, check if we have a reactorless loop
+        # We can't use is_reactorless() here because it calls is_asyncio_available()
+        # So we check if there's an asyncio loop policy or loop that's been set up
+        try:
+            # Check if there's an asyncio loop (even if not running)
+            loop = asyncio.get_event_loop()
+            if loop is not None:
+                return True
+        except RuntimeError:
+            pass
+
+        # Check if there's an asyncio event loop policy (indicates asyncio is being used)
+        try:
+            from asyncio import events
+            if events._get_running_loop is not None:
+                return True
+        except Exception:
+            pass
+
         raise RuntimeError(
             "is_asyncio_available() called without an installed reactor"
             " or running asyncio loop."
