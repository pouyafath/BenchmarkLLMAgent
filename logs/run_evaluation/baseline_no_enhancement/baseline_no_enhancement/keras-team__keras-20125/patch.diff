diff --git a/keras/src/ops/core.py b/keras/src/ops/core.py
--- a/keras/src/ops/core.py
+++ b/keras/src/ops/core.py
@@ -1,3 +1,16 @@
 @keras_export("keras.ops.stop_gradient")
 def stop_gradient(variable):
-    return backend.core.stop_gradient(variable)
+    """Stop gradient propagation for a tensor.
+
+    For eager tensors this forwards the call to the backend implementation.
+    For symbolic `KerasTensor` objects (used when building Functional models),
+    the operation is a no‑op and returns the input tensor unchanged. This
+    mirrors the expected behaviour of `tf.stop_gradient` in a symbolic graph
+    where the gradient flow is controlled by the Keras functional API rather
+    than by the TensorFlow operation itself.
+    """
+    # If the input is a symbolic KerasTensor, simply return it unchanged.
+    if any_symbolic_tensors((variable,)):
+        return variable
+    # Otherwise delegate to the backend implementation.
+    return backend.core.stop_gradient(variable)