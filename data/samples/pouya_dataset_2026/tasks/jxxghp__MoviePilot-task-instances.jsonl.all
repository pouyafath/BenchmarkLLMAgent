...\n\u3010INFO\u30112025-08-06 20:40:08,531 - transfer.py - \u624b\u52a8\u6574\u7406\uff1a/downloads/\u56fd\u6f2b/Zhongguo Qi Tan S01 1080p Blu-ray Remux AVC DTS-HD MA 5.1-E.N.D/\u4e2d\u56fd\u5947\u8c2d - S01E01 - \u7b2c 1 \u96c6.mkv ...\n\u3010INFO\u30112025-08-06 20:37:22,950 - plugin.py - \u5171\u83b7\u53d6\u5230 230 \u4e2a\u7ebf\u4e0a\u63d2\u4ef6\n\n", "commit_urls": ["https://github.com/jxxghp/MoviePilot/commit/1f6dc93ea3435fcbeeed57ea5b961c0cb6280e64"], "created_at": "2025-08-06T13:30:42Z"}
{"repo": "jxxghp/MoviePilot", "pull_number": 4902, "instance_id": "jxxghp__MoviePilot-4902", "issue_numbers": [4810], "base_commit": "ac2b6c76ce65d8e93e31e91b110a99eafa2baa77", "patch": "diff --git a/app/modules/filemanager/storages/u115.py b/app/modules/filemanager/storages/u115.py\nindex 18efaf838..f4a8e61d1 100644\n--- a/app/modules/filemanager/storages/u115.py\n+++ b/app/modules/filemanager/storages/u115.py\n@@ -195,6 +195,7 @@ def __refresh_access_token(self, refresh_token: str) -> Optional[dict]:\n         result = resp.json()\n         if result.get(\"code\") != 0:\n             logger.warn(f\"\u3010115\u3011\u5237\u65b0 access_token \u5931\u8d25\uff1a{result.get('code')} - {result.get('message')}\uff01\")\n+            return None\n         return result.get(\"data\")\n \n     def _request_api(self, method: str, endpoint: str,\n@@ -233,7 +234,12 @@ def _request_api(self, method: str, endpoint: str,\n         # \u8fd4\u56de\u6570\u636e\n         ret_data = resp.json()\n         if ret_data.get(\"code\") != 0:\n-            logger.warn(f\"\u3010115\u3011{method} \u8bf7\u6c42 {endpoint} \u51fa\u9519\uff1a{ret_data.get('message')}\uff01\")\n+            error_msg = ret_data.get(\"message\")\n+            logger.warn(f\"\u3010115\u3011{method} \u8bf7\u6c42 {endpoint} \u51fa\u9519\uff1a{error_msg}\uff01\")\n+            if \"\u5df2\u8fbe\u5230\u5f53\u524d\u8bbf\u95ee\u4e0a\u9650\" in error_msg:\n+                time.sleep(70)\n+                return self._request_api(method, endpoint, result_key, **kwargs)\n+            return None\n \n         if result_key:\n             return ret_data.get(result_key)\n@@ -259,8 +265,8 @@ def _delay_get_item(self, path: Path) -> Optional[schemas.FileItem]:\n         \"\"\"\n         \u81ea\u52a8\u5ef6\u8fdf\u91cd\u8bd5 get_item \u6a21\u5757\n         \"\"\"\n-        for _ in range(2):\n-            time.sleep(2)\n+        for i in range(1, 4):\n+            time.sleep(2 ** i)\n             fileitem = self.get_item(path)\n             if fileitem:\n                 return fileitem\n@@ -435,6 +441,9 @@ def encode_callback(cb: str) -> str:\n             )\n             if not init_resp:\n                 return None\n+            if not init_resp.get(\"state\"):\n+                logger.warn(f\"\u3010115\u3011\u4e0a\u4f20\u4e8c\u6b21\u8ba4\u8bc1\u5931\u8d25: {init_resp.get('error')}\")\n+                return None\n             # \u4e8c\u6b21\u8ba4\u8bc1\u7ed3\u679c\n             init_result = init_resp.get(\"data\")\n             logger.debug(f\"\u3010115\u3011\u4e0a\u4f20 Step 2 \u4e8c\u6b21\u8ba4\u8bc1\u7ed3\u679c: {init_result}\")\n@@ -787,8 +796,10 @@ def copy(self, fileitem: schemas.FileItem, path: Path, new_name: str) -> bool:\n         if resp[\"state\"]:\n             new_path = Path(path) / fileitem.name\n             new_item = self._delay_get_item(new_path)\n-            self.rename(new_item, new_name)\n-            return True\n+            if not new_item:\n+                return False\n+            if self.rename(new_item, new_name):\n+                return True\n         return False\n \n     def move(self, fileitem: schemas.FileItem, path: Path, new_name: str) -> bool:\n@@ -817,8 +828,10 @@ def move(self, fileitem: schemas.FileItem, path: Path, new_name: str) -> bool:\n         if resp[\"state\"]:\n             new_path = Path(path) / fileitem.name\n             new_file = self._delay_get_item(new_path)\n-            self.rename(new_file, new_name)\n-            return True\n+            if not new_file:\n+                return False\n+            if self.rename(new_file, new_name):\n+                return True\n         return False\n \n     def link(self, fileitem: schemas.FileItem, target_file: Path) -> bool:\n", "test_patch": "", "problem_statement": "[Feature Request]: \u6587\u4ef6\u7ba1\u7406-\u6574\u7406\u961f\u5217 \u76ee\u7684\u5730\u4e3a\u7f51\u76d8\u65f6\u4f18\u5316\n### \u5f53\u524d\u7a0b\u5e8f\u7248\u672c\n\nv2.7.4\n\n### \u8fd0\u884c\u73af\u5883\n\nDocker\n\n### \u529f\u80fd\u6539\u8fdb\u7c7b\u578b\n\n\u4e3b\u7a0b\u5e8f\n\n### \u529f\u80fd\u6539\u8fdb\n\n\u5f53\u628a\u672c\u5730\u4e4b\u524d\u4e0b\u8f7d\u7684\u5927\u91cf\u6570\u636e\uff0c\u4f7f\u7528\u624b\u52a8\u6574\u7406\u529f\u80fd\u5230\u7f51\u76d8\u65f6\uff0c\u5bb9\u6613\u89e6\u53d1\u6d41\u63a7\n\n<img width=\"1149\" height=\"1037\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/14b4cfa9-c286-4d4d-b88d-2a6b41ca0ae1\" />\n\n\u5e0c\u671b\u5f53\u6e90\u76ee\u5f55\u4e3a\u672c\u5730 - \u76ee\u7684\u5730\u4e3a\u7f51\u76d8\u65f6\u589e\u52a02\u4e2a\u5224\u65ad\n\n1,\u6bcf\u4e2a\u6587\u4ef6\u5904\u7406\u95f4\u9694\u65f6\u95f4\u7a0d\u5fae\u518d\u62c9\u957f\u4e00\u70b9\n\n2, \u5f53\u68c0\u6d4b\u5230\u7b2c\u4e00\u8d77\u6d41\u63a7\u89e6\u53d1\u65f6\uff08\u3010115\u3011POST \u8bf7\u6c42 /open/folder/get_info \u51fa\u9519\uff1a\u5df2\u8fbe\u5230\u5f53\u524d\u8bbf\u95ee\u4e0a\u9650\uff0c\u8bf7\u7a0d\u540e\u518d\u8bd5\uff09  \u6682\u505c\u6574\u7406\u961f\u5217\u8f6e\u8be2\uff0c\u9009\u62e9\u7b49\u5f85\u800c\u4e0d\u662f\u7ee7\u7eed\u8f6e\u8be2\uff0c \u7b49\u534a\u5c0f\u65f6\u540e\u518d\u8fdb\u884c\u961f\u5217\u6574\u7406\u3002   \uff08\u7c7b\u4f3c\u65ad\u70b9\u7eed\u4f20 + \u6d41\u63a7\u4fdd\u62a4\uff09\n\n\u76ee\u524d\u5f53\u7f51\u76d8\u6d41\u63a7\u540e\uff0c\u6574\u7406\u961f\u5217\u4f1a\u4e00\u77ac\u95f4\u5f80\u4e0b\u628a\u6240\u6709\u5269\u4f59\u8d44\u6e90\u5904\u7406\u4e00\u6b21\uff0c\u4f1a\u9020\u6210\u7d2f\u8ba1\u5927\u91cf\u5931\u8d25\u8bb0\u5f55\uff0c\u540c\u65f6\u6bcf\u6761\u5931\u8d25\u8bb0\u5f55\u4f1a\u89e6\u53d1\u63a8\u9001\u901a\u77e5 \u3002\n\n\u7b2c\u4e8c\u4e2a\u662f\uff0c\u5f53\u6e90\u76ee\u5f55\u4e3a\u7f51\u76d8 - \u76ee\u7684\u5730\u4e5f\u4e3a\u7f51\u76d8\u65f6\n\n\u5982\u679c\u4e00\u6b21\u6027\u6574\u7406\u8d44\u6e90\u8fc7\u591a\uff0c\u5219\u4f1a\u56e0\u4e3a\u5728\u5f00\u59cb\u6574\u7406\u65f6\uff0c\u56e0\u5927\u91cf\u67e5\u8be2\u6587\u4ef6\u76ee\u5f55\uff0c\u7ed3\u6784\u7b49\u884c\u4e3a\u9020\u6210\u98ce\u63a7\uff0c\u5b9e\u9645\u6574\u7406\u8fd8\u672a\u5f00\u59cb\u5c31\u5df2\u7ecf\u6d41\u63a7\u4e86\u3002\n\n\u5efa\u8bae\u6e90\u76ee\u5f55\u4e3a\u7f51\u76d8\u65f6\uff0c\u4e0d\u91c7\u7528\u4e00\u6b21\u6027\u7edf\u8ba1\u5f85\u6574\u7406\u961f\u5217\uff0c\u800c\u9009\u62e91\u4e2a\uff0c10\u4e2a\uff0c\u6216\u800520\u4e2a\u5f53\u524d\u987a\u5e8f\u5f00\u59cb\u6574\u7406\u3002\u3002  \n\n\u4ee5\u4e0a\u573a\u666f\u5927\u90e8\u5206\u4e3a\u672c\u5730\u6279\u91cf\u6574\u7406\u5230\u4e0a\u4f20\u7f51\u76d8\uff0c\u6216\u8005\u7f51\u76d8\u8f6c\u5b58\u6279\u91cf\u6574\u7406\u65f6\u5bb9\u6613\u89e6\u53d1\u3002\n\n\n\n### \u53c2\u8003\u8d44\u6599\n\n_No response_\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/jxxghp/MoviePilot/commit/8e6021c5e719715e6d2fc5bb6cfdf7e78dbba88e", "https://github.com/jxxghp/MoviePilot/commit/926343ee86a03b5b2764c8ca8bebb45f9d3f827f"], "created_at": "2025-09-05T11:33:32Z"}
{"repo": "jxxghp/MoviePilot", "pull_number": 4918, "instance_id": "jxxghp__MoviePilot-4918", "issue_numbers": [4853], "base_commit": "f013bf1931fd343bed0ce70d1a0190779f2c2a56", "patch": "diff --git a/app/helper/rss.py b/app/helper/rss.py\nindex 829995a7a..caf820f03 100644\n--- a/app/helper/rss.py\n+++ b/app/helper/rss.py\n@@ -384,6 +384,9 @@ def parse(self, url, proxy: bool = False,\n                             pubdate = \"\"\n                             if pubdate_nodes and pubdate_nodes[0].text:\n                                 pubdate = StringUtils.get_time(pubdate_nodes[0].text)\n+                                if pubdate is not None:\n+                                    # \u8f6c\u4e3a\u672c\u5730\u65f6\u533a\n+                                    pubdate = pubdate.astimezone(tz=None)\n \n                             # \u83b7\u53d6\u8c46\u74e3\u6635\u79f0\n                             nickname_nodes = item.xpath('.//*[local-name()=\"creator\"]')\n", "test_patch": "", "problem_statement": "[\u9519\u8bef\u62a5\u544a]: \u9992\u5934 RSS \u4e2d\u7684 pubDate \u65f6\u533a\u662f UTC\uff0c\u800c\u975e\u672c\u5730\u65f6\u533a\n### \u786e\u8ba4\n\n- [x] \u6211\u7684\u7248\u672c\u662f\u6700\u65b0\u7248\u672c\uff0c\u6211\u7684\u7248\u672c\u53f7\u4e0e [version](https://github.com/jxxghp/MoviePilot/releases/latest) \u76f8\u540c\u3002\n- [x] \u6211\u5df2\u7ecf [issue](https://github.com/jxxghp/MoviePilot/issues) \u4e2d\u641c\u7d22\u8fc7\uff0c\u786e\u8ba4\u6211\u7684\u95ee\u9898\u6ca1\u6709\u88ab\u63d0\u51fa\u8fc7\u3002\n- [x] \u6211\u5df2\u7ecf [Telegram\u9891\u9053](https://t.me/moviepilot_channel) \u4e2d\u641c\u7d22\u8fc7\uff0c\u786e\u8ba4\u6211\u7684\u95ee\u9898\u6ca1\u6709\u88ab\u63d0\u51fa\u8fc7\u3002\n- [x] \u6211\u5df2\u7ecf\u4fee\u6539\u6807\u9898\uff0c\u5c06\u6807\u9898\u4e2d\u7684 \u63cf\u8ff0 \u66ff\u6362\u4e3a\u6211\u9047\u5230\u7684\u95ee\u9898\u3002\n\n### \u5f53\u524d\u7a0b\u5e8f\u7248\u672c\n\n2.7.6\n\n### \u8fd0\u884c\u73af\u5883\n\nDocker\n\n### \u95ee\u9898\u7c7b\u578b\n\n\u5176\u4ed6\u95ee\u9898\n\n### \u95ee\u9898\u63cf\u8ff0\n\n\u9992\u5934 RSS \u4e2d\u7684 pubDate \u65f6\u533a\u662f UTC\uff0c\u800c\u975e\u672c\u5730\u65f6\u533a\uff0c\u4e0b\u9762\u662f\u4ece\u9992\u5934RSS\u94fe\u63a5\u4e2d\u590d\u5236\u7684\u4e00\u6bb5\u6587\u5b57\uff1a\n\n<pubDate>Wed, 27 Aug 2025 14:41:40 GMT</pubDate>\n\n\u8fd9\u4e2a\u5b9e\u9645\u4e0a\u662f8\u670827\u65e522:41\u53d1\u5e03\u7684\uff0c\u4f46\u662fMoviePilot\u5728\u53d1\u9001\u901a\u77e5\u65f6\u76f4\u63a5\u5f15\u7528\u4e86\u4e0a\u8ff0\u65f6\u95f4\uff0c\u5efa\u8bae\u505a\u4e00\u4e0b\u8c03\u6574\uff0c\u8c22\u8c22\uff01\n\n### \u53d1\u751f\u95ee\u9898\u65f6\u7cfb\u7edf\u65e5\u5fd7\u548c\u914d\u7f6e\u6587\u4ef6\n\n```bash\n\n```\n", "hints_text": "\u8865\u5145\u622a\u56fe\uff1a\n\n<img width=\"516\" height=\"684\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/9661311f-e8a3-48ba-bf4a-db8a90e66589\" />\n\u8865\u5145\u9992\u5934\u8bba\u575b\u7ba1\u7406\u5458\u7684\u56de\u590d\uff1a\n\n<img width=\"731\" height=\"508\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/f23e5f41-3715-4744-8266-6c9f162322c3\" />\n\n", "all_hints_text": "\u8865\u5145\u622a\u56fe\uff1a\n\n<img width=\"516\" height=\"684\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/9661311f-e8a3-48ba-bf4a-db8a90e66589\" />\n\u8865\u5145\u9992\u5934\u8bba\u575b\u7ba1\u7406\u5458\u7684\u56de\u590d\uff1a\n\n<img width=\"731\" height=\"508\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/f23e5f41-3715-4744-8266-6c9f162322c3\" />\n\u95ee\u9898\u5df2\u89e3\u51b3\uff0c\u8c22\u8c22\uff01\n\n", "commit_urls": ["https://github.com/jxxghp/MoviePilot/commit/e00514d36db9427e49ce3a669da26d3cec50ad9d"], "created_at": "2025-09-08T03:29:36Z"}
{"repo": "jxxghp/MoviePilot", "pull_number": 5498, "instance_id": "jxxghp__MoviePilot-5498", "issue_numbers": [4861, 5475], "base_commit": "bf7cc6caf0d9a84b17c5d938c49422ea164b6778", "patch": "diff --git a/app/api/endpoints/system.py b/app/api/endpoints/system.py\nindex 6673b0ae0..6f8c7c81e 100644\n--- a/app/api/endpoints/system.py\n+++ b/app/api/endpoints/system.py\n@@ -615,7 +615,10 @@ def run_scheduler(jobid: str,\n     \"\"\"\n     if not jobid:\n         return schemas.Response(success=False, message=\"\u547d\u4ee4\u4e0d\u80fd\u4e3a\u7a7a\uff01\")\n-    Scheduler().start(jobid)\n+    if jobid in {\"recommend_refresh\", \"cookiecloud\"}:\n+        Scheduler().start(jobid, manual=True)\n+    else:\n+        Scheduler().start(jobid)\n     return schemas.Response(success=True)\n \n \n@@ -628,5 +631,8 @@ def run_scheduler2(jobid: str,\n     if not jobid:\n         return schemas.Response(success=False, message=\"\u547d\u4ee4\u4e0d\u80fd\u4e3a\u7a7a\uff01\")\n \n-    Scheduler().start(jobid)\n+    if jobid in {\"recommend_refresh\", \"cookiecloud\"}:\n+        Scheduler().start(jobid, manual=True)\n+    else:\n+        Scheduler().start(jobid)\n     return schemas.Response(success=True)\ndiff --git a/app/chain/recommend.py b/app/chain/recommend.py\nindex 25bbdb0e8..7747f3c8c 100644\n--- a/app/chain/recommend.py\n+++ b/app/chain/recommend.py\n@@ -6,7 +6,7 @@\n from app.chain.bangumi import BangumiChain\n from app.chain.douban import DoubanChain\n from app.chain.tmdb import TmdbChain\n-from app.core.cache import cached\n+from app.core.cache import cached, fresh\n from app.core.config import settings, global_vars\n from app.helper.image import ImageHelper\n from app.log import logger\n@@ -27,9 +27,11 @@ class RecommendChain(ChainBase, metaclass=Singleton):\n     # \u63a8\u8350\u7f13\u5b58\u533a\u57df\n     recommend_cache_region = \"recommend\"\n \n-    def refresh_recommend(self):\n+    def refresh_recommend(self, manual: bool = False):\n         \"\"\"\n         \u5237\u65b0\u63a8\u8350\n+\n+        :param manual: \u624b\u52a8\u89e6\u53d1\n         \"\"\"\n         logger.debug(\"Starting to refresh Recommend data.\")\n \n@@ -62,7 +64,9 @@ def refresh_recommend(self):\n                 if method in methods_finished:\n                     continue\n                 logger.debug(f\"Fetch {method.__name__} data for page {page}.\")\n-                data = method(page=page)\n+                # \u624b\u52a8\u89e6\u53d1\u7684\u5237\u65b0\uff0c\u603b\u662f\u9700\u8981\u83b7\u53d6\u6700\u65b0\u6570\u636e\n+                with fresh(manual):\n+                    data = method(page=page)\n                 if not data:\n                     logger.debug(\"All recommendation methods have finished fetching data. Ending pagination early.\")\n                     methods_finished.add(method)\n@@ -90,7 +94,6 @@ def __cache_posters(self, datas: List[dict]):\n             poster_path = data.get(\"poster_path\")\n             if poster_path:\n                 poster_url = poster_path.replace(\"original\", \"w500\")\n-                logger.debug(f\"Caching poster image: {poster_url}\")\n                 self.__fetch_and_save_image(poster_url)\n \n     @staticmethod\n", "test_patch": "", "problem_statement": "[\u9519\u8bef\u62a5\u544a]: \u63a8\u8350\u9875\u9762\u4e0d\u663e\u793a\u6765\u81eaTMDB\u7684\u76f8\u5173\u5185\u5bb9\uff0c\u4f46\u662f\u63a2\u7d22\u9875\u9762\u663e\u793a\n### \u786e\u8ba4\n\n- [x] \u6211\u7684\u7248\u672c\u662f\u6700\u65b0\u7248\u672c\uff0c\u6211\u7684\u7248\u672c\u53f7\u4e0e [version](https://github.com/jxxghp/MoviePilot/releases/latest) \u76f8\u540c\u3002\n- [x] \u6211\u5df2\u7ecf [issue](https://github.com/jxxghp/MoviePilot/issues) \u4e2d\u641c\u7d22\u8fc7\uff0c\u786e\u8ba4\u6211\u7684\u95ee\u9898\u6ca1\u6709\u88ab\u63d0\u51fa\u8fc7\u3002\n- [x] \u6211\u5df2\u7ecf [Telegram\u9891\u9053](https://t.me/moviepilot_channel) \u4e2d\u641c\u7d22\u8fc7\uff0c\u786e\u8ba4\u6211\u7684\u95ee\u9898\u6ca1\u6709\u88ab\u63d0\u51fa\u8fc7\