+def get_driver_style(style: dict) -> dict:
+    """
+    Replace any occurrence of the string ``"auto"`` in the provided ``style`` mapping
+    with the corresponding value from the driver style. The replacement is performed
+    recursively so that nested dictionaries or iterables are also processed.
+
+    Parameters
+    ----------
+    style: dict
+        A mapping describing the desired style. Values equal to ``"auto"`` act as a
+        placeholder that will be substituted with the driver‑specific default.
+
+    Returns
+    -------
+    dict
+        The style mapping with all ``"auto"`` placeholders resolved.
+    """
+    driver_style = {
+        "fillcolor": "red",
+        "line": {"color": "blue"},
+        # ... other default driver style entries
+    }
+
+    def _lookup_driver(path):
+        """
+        Retrieve a value from ``driver_style`` following the sequence of keys in ``path``.
+        If any key is missing, ``None`` is returned.
+        """
+        cur = driver_style
+        for p in path:
+            if isinstance(cur, dict) and p in cur:
+                cur = cur[p]
+            else:
+                return None
+        return cur
+
+    def _replace(value, path):
+        """
+        Recursively replace ``"auto"`` placeholders.
+
+        Parameters
+        ----------
+        value : Any
+            Current value to process.
+        path : list
+            List of keys representing the location of ``value`` within the original
+            ``style`` dict. This is used to fetch the appropriate driver default.
+        """
+        # Direct placeholder – try to fetch the driver default for this path
+        if value == "auto":
+            driver_val = _lookup_driver(path)
+            # If a driver default exists, use it; otherwise keep the placeholder
+            return driver_val if driver_val is not None else value
+
+        # Dictionaries – recurse into each item, extending the path with the key
+        if isinstance(value, dict):
+            return {k: _replace(v, path + [k]) for k, v in value.items()}
+
+        # Lists or tuples – recurse into each element, path unchanged (no key)
+        if isinstance(value, (list, tuple)):
+            replaced = [_replace(v, path) for v in value]
+            return type(value)(replaced)
+
+        # All other types are returned unchanged
+        return value
+
+    # Build the resolved style dict by processing each top‑level entry
+    resolved = {}
+    for key, val in style.items():
+        resolved[key] = _replace(val, [key])
+    return resolved