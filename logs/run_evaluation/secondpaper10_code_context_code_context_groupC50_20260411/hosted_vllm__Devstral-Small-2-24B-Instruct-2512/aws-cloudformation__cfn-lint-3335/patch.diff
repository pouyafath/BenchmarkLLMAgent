+def _split_dynamic_ref_parts(dynamic_ref: str) -> List[str]:
+    """
+    Split a dynamic reference string into parts, preserving colons inside ${...} blocks.
+
+    This function mimics the behavior of str.split(':') but preserves colons inside ${...} blocks.
+
+    Example:
+    Input: "resolve:ssm:${AWS::AccountId}/${AWS::Region}/ac"
+    Output: ["resolve", "ssm", "${AWS::AccountId}/${AWS::Region}/ac"]
+    """
+    parts = []
+    current_part = ""
+    i = 0
+    n = len(dynamic_ref)
+
+    while i < n:
+        if i < n - 1 and dynamic_ref[i] == '$' and dynamic_ref[i+1] == '{':
+            # Start of ${...} block - find the closing }
+            current_part += '${'
+            i += 2
+            brace_depth = 1
+            while i < n and brace_depth > 0:
+                if dynamic_ref[i] == '{':
+                    brace_depth += 1
+                elif dynamic_ref[i] == '}':
+                    brace_depth -= 1
+                current_part += dynamic_ref[i]
+                i += 1
+        elif dynamic_ref[i] == ':':
+            # Colon outside of ${...} block - split here
+            parts.append(current_part)
+            current_part = ""
+            i += 1
+        else:
+            current_part += dynamic_ref[i]
+            i += 1
+
+    # Add the last part (even if empty, to match str.split(':') behavior)
+    parts.append(current_part)
+
+    return parts
 
 class DynamicReference(BaseFn):
     id = "E1050"
