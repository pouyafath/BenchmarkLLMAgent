jectName(u\"wLabel\")\n-        sizePolicy1.setHeightForWidth(self.wLabel.sizePolicy().hasHeightForWidth())\n-        self.wLabel.setSizePolicy(sizePolicy1)\n+        sizePolicy2.setHeightForWidth(self.wLabel.sizePolicy().hasHeightForWidth())\n+        self.wLabel.setSizePolicy(sizePolicy2)\n \n         self.gridLayout_3.addWidget(self.wLabel, 0, 0, 1, 1)\n \n@@ -223,11 +234,8 @@ def setupUi(self, mainWindow):\n \n         self.preserveMarginBox = QSpinBox(self.croppingWidget)\n         self.preserveMarginBox.setObjectName(u\"preserveMarginBox\")\n-        sizePolicy2 = QSizePolicy(QSizePolicy.Policy.Fixed, QSizePolicy.Policy.Fixed)\n-        sizePolicy2.setHorizontalStretch(0)\n-        sizePolicy2.setVerticalStretch(0)\n-        sizePolicy2.setHeightForWidth(self.preserveMarginBox.sizePolicy().hasHeightForWidth())\n-        self.preserveMarginBox.setSizePolicy(sizePolicy2)\n+        sizePolicy1.setHeightForWidth(self.preserveMarginBox.sizePolicy().hasHeightForWidth())\n+        self.preserveMarginBox.setSizePolicy(sizePolicy1)\n         self.preserveMarginBox.setMaximum(99)\n         self.preserveMarginBox.setSingleStep(5)\n         self.preserveMarginBox.setValue(0)\n@@ -434,9 +442,7 @@ def setupUi(self, mainWindow):\n         self.statusBar.setSizeGripEnabled(False)\n         mainWindow.setStatusBar(self.statusBar)\n         QWidget.setTabOrder(self.convertButton, self.clearButton)\n-        QWidget.setTabOrder(self.clearButton, self.directoryButton)\n-        QWidget.setTabOrder(self.directoryButton, self.fileButton)\n-        QWidget.setTabOrder(self.fileButton, self.deviceBox)\n+        QWidget.setTabOrder(self.clearButton, self.deviceBox)\n         QWidget.setTabOrder(self.deviceBox, self.formatBox)\n         QWidget.setTabOrder(self.formatBox, self.mangaBox)\n         QWidget.setTabOrder(self.mangaBox, self.rotateBox)\n@@ -479,24 +485,28 @@ def retranslateUi(self, mainWindow):\n         self.kofiButton.setText(QCoreApplication.translate(\"mainWindow\", u\"Support me on Ko-fi\", None))\n         self.wikiButton.setText(QCoreApplication.translate(\"mainWindow\", u\"Wiki\", None))\n #if QT_CONFIG(tooltip)\n-        self.directoryButton.setToolTip(QCoreApplication.translate(\"mainWindow\", u\"<html><head/><body><p style='white-space:pre'>Add directory containing JPG, PNG or GIF files to queue.<br/><span style=\\\" font-weight:600;\\\">CBR, CBZ and CB7 files inside will not be processed!</span></p></body></html>\", None))\n+        self.convertButton.setToolTip(QCoreApplication.translate(\"mainWindow\", u\"<html><head/><body><p style='white-space:pre'>Shift+Click to select the output directory for this list.</p></body></html>\", None))\n+#endif // QT_CONFIG(tooltip)\n+        self.convertButton.setText(QCoreApplication.translate(\"mainWindow\", u\"Convert\", None))\n+        self.clearButton.setText(QCoreApplication.translate(\"mainWindow\", u\"Clear list\", None))\n+#if QT_CONFIG(tooltip)\n+        self.deviceBox.setToolTip(QCoreApplication.translate(\"mainWindow\", u\"<html><head/><body><p style='white-space:pre'>Target device.</p></body></html>\", None))\n #endif // QT_CONFIG(tooltip)\n-        self.directoryButton.setText(QCoreApplication.translate(\"mainWindow\", u\"Add image folder\", None))\n #if QT_CONFIG(tooltip)\n         self.fileButton.setToolTip(QCoreApplication.translate(\"mainWindow\", u\"<html><head/><body><p style='white-space:pre'>Add CBR, CBZ, CB7 or PDF file to queue.</p></body></html>\", None))\n #endif // QT_CONFIG(tooltip)\n         self.fileButton.setText(QCoreApplication.translate(\"mainWindow\", u\"Add file(s)\", None))\n #if QT_CONFIG(tooltip)\n-        self.deviceBox.setToolTip(QCoreApplication.translate(\"mainWindow\", u\"<html><head/><body><p style='white-space:pre'>Target device.</p></body></html>\", None))\n+        self.defaultOutputFolderButton.setToolTip(QCoreApplication.translate(\"mainWindow\", u\"<html><head/><body><p>Use this to select the default output directory.</p></body></html>\", None))\n #endif // QT_CONFIG(tooltip)\n+        self.defaultOutputFolderButton.setText(QCoreApplication.translate(\"mainWindow\", u\"Default Output Folder\", None))\n #if QT_CONFIG(tooltip)\n-        self.formatBox.setToolTip(QCoreApplication.translate(\"mainWindow\", u\"<html><head/><body><p style='white-space:pre'>Output format.</p></body></html>\", None))\n+        self.defaultOutputFolderBox.setToolTip(QCoreApplication.translate(\"mainWindow\", u\"<html><head/><body><p>Click to enable custom directory.</p></body></html>\", None))\n #endif // QT_CONFIG(tooltip)\n+        self.defaultOutputFolderBox.setText(\"\")\n #if QT_CONFIG(tooltip)\n-        self.convertButton.setToolTip(QCoreApplication.translate(\"mainWindow\", u\"<html><head/><body><p style='white-space:pre'>Shift+Click to select the output directory.</p></body></html>\", None))\n+        self.formatBox.setToolTip(QCoreApplication.translate(\"mainWindow\", u\"<html><head/><body><p style='white-space:pre'>Output format.</p></body></html>\", None))\n #endif // QT_CONFIG(tooltip)\n-        self.convertButton.setText(QCoreApplication.translate(\"mainWindow\", u\"Convert\", None))\n-        self.clearButton.setText(QCoreApplication.translate(\"mainWindow\", u\"Clear list\", None))\n #if QT_CONFIG(tooltip)\n         self.hLabel.setToolTip(QCoreApplication.translate(\"mainWindow\", u\"<html><head/><body><p style='white-space:pre'>Resolution of the target device.</p></body></html>\", None))\n #endif // QT_CONFIG(tooltip)\n", "test_patch": "", "problem_statement": "Inconsistencies with output directory in Windows 10\n# Use case\r\n**I like to keep my source and output files separate**, so I would prefer not having to shift-click the convert button and having to specify my output directory each and every time I start a conversion.\r\n\r\n# Current inconsistent behaviour\r\n- By default, when I click the \"Convert\" button (without holding shift) the output directory defaults to individually matching each source item.\r\n- When I shift click the \"Convert\" button, I am prompted to select an output directory (for all items in my queue), **the starting point directory is always the same as application executable**.\r\n- Each time I add files or directories to the queue by clicking the \"Add file\" or \"Add directory\" buttons, **the application changes its starting point directory** for the dialogue which appears when I shift-click the \"Convert\" button. The starting point directory will now match the source file's location (instead of the executable directory). This change persists after the application is closed.\r\n- When I shift-click the convert button but choose \"Cancel\" in the output directory selection dialogue, **the app starts the conversion process regardless** (placing each output file in the directory that corresponds with its source file, as if I hadn't shift-clicked the \"Convert\" button in the first place.)\r\n\r\n# My current workaround\r\n1. Make a temporary copy of a random source file and place this in my desired output directory\r\n2. Add this temporary file to the conversion queue using the \"Add file\" button in the application GUI (the \"Add directory\" button also works)\r\n3. Clear the queue or close the application, and delete the temporary source file\r\n4. Add any files I actually intend to convert using drag & drop into the application window, instead of using the \"Add file\" or \"Add directory\" buttons (since that would reset the starting point directory to be same as the source)\r\n5. Shift-click the \"Convert\" button (the output directory selection prompt should now start in the directory where the temporary file was) and choose \"Select folder\" in the output directory selection prompt (the starting directory will now be where the temporary file was, rather than where the application executable is)\r\n\r\n# Feature request\r\nAn optional setting for selecting a default output directory which will be used whenever i click the convert button normally (without needing to hold the shift key)\n", "hints_text": "\n\n", "all_hints_text": "@christian-aksdal Please test these test builds to see if it satisfies your use case.\n\n https://github.com/axu2/kcc/releases/tag/v7.5.1-custom-output-folder\nNew test build with png issue fixed: https://github.com/axu2/kcc/releases/tag/v7.5.1-png @christian-aksdal \n\n", "commit_urls": ["https://github.com/ciromattia/kcc/commit/1efe29d475f93097ba2be10b17cafe05d5c5c83e", "https://github.com/ciromattia/kcc/commit/3f2047995fa694fdd1ee308e42685602d69bee3e", "https://github.com/ciromattia/kcc/commit/a7c3645759cd984d42020c7adb2a04814527ca5b", "https://github.com/ciromattia/kcc/commit/3879ba75cc386a390ce428d7acd9782bf7b3444a", "https://github.com/ciromattia/kcc/commit/e4ebf67f3e299bfcf342530e3873a71c2525da75", "https://github.com/ciromattia/kcc/commit/a1bc760b9b6d7d3e40c128d78bf7c16d8a82b590"], "created_at": "2025-06-17T19:45:42Z"}
{"repo": "ciromattia/kcc", "pull_number": 1204, "instance_id": "ciromattia__kcc-1204", "issue_numbers": [768, 1163], "base_commit": "c58387f4f47f1b2c82a82095e0740d749223ea81", "patch": "diff --git a/README.md b/README.md\nindex 0055e6c0..8e900385 100644\n--- a/README.md\n+++ b/README.md\n@@ -255,6 +255,7 @@ PROCESSING:\n   --forcecolor          Don't convert images to grayscale\n   --forcepng            Create PNG files instead JPEG\n   --mozjpeg             Create JPEG files using mozJpeg\n+  --jpeg-quality        The JPEG quality, on a scale from 0 (worst) to 95 (best). Default 85 for most devices.\n   --maximizestrips      Turn 1x4 strips to 2x2 strips\n   -d, --delete          Delete source file(s) or a directory. It's not recoverable.\n \ndiff --git a/kindlecomicconverter/comic2ebook.py b/kindlecomicconverter/comic2ebook.py\nindex 1f1f35a4..3c79bcb1 100755\n--- a/kindlecomicconverter/comic2ebook.py\n+++ b/kindlecomicconverter/comic2ebook.py\n@@ -1380,6 +1380,8 @@ def makeParser():\n                                     help=\"Create PNG files instead JPEG\")\n     processing_options.add_argument(\"--mozjpeg\", action=\"store_true\", dest=\"mozjpeg\", default=False,\n                                     help=\"Create JPEG files using mozJpeg\")\n+    processing_options.add_argument(\"--jpeg-quality\", type=int, dest=\"jpegquality\", \n+                                    help=\"The JPEG quality, on a scale from 0 (worst) to 95 (best). Default 85 for most devices.\")\n     processing_options.add_argument(\"--maximizestrips\", action=\"store_true\", dest=\"maximizestrips\", default=False,\n                                     help=\"Turn 1x4 strips to 2x2 strips\")\n     processing_options.add_argument(\"-d\", \"--delete\", action=\"store_true\", dest=\"delete\", default=False,\n@@ -1479,6 +1481,11 @@ def checkOptions(options):\n         image.ProfileData.Profiles[\"Custom\"] = newProfile\n         options.profile = \"Custom\"\n     options.profileData = image.ProfileData.Profiles[options.profile]\n+    if not options.jpegquality:\n+        if options.profile.startswith('KS') or options.profile == 'KCS':\n+            options.jpegquality = 90\n+        else:\n+            options.jpegquality = 85\n     return options\n \n \ndiff --git a/kindlecomicconverter/image.py b/kindlecomicconverter/image.py\nindex c4e5ed2c..3199c23f 100755\n--- a/kindlecomicconverter/image.py\n+++ b/kindlecomicconverter/image.py\n@@ -408,13 +408,13 @@ def save_with_codec(self, image, targetPath):\n             targetPath += '.jpg'\n             if self.opt.mozjpeg:\n                 with io.BytesIO() as output:\n-                    image.save(output, format=\"JPEG\", optimize=1, quality=85)\n+                    image.save(output, format=\"JPEG\", optimize=1, quality=self.opt.jpegquality)\n                     input_jpeg_bytes = output.getvalue()\n                     output_jpeg_bytes = mozjpeg_lossless_optimization.optimize(input_jpeg_bytes)\n                     with open(targetPath, \"wb\") as output_jpeg_file:\n                         output_jpeg_file.write(output_jpeg_bytes)\n             else:\n-                image.save(targetPath, 'JPEG', optimize=1, quality=85)\n+                image.save(targetPath, 'JPEG', optimize=1, quality=self.opt.jpegquality)\n         return targetPath\n \n     def gammaCorrectImage(self):\n@@ -584,7 +584,7 @@ def crop_main_cover(self):\n     def save_to_epub(self, target, tomeid, len_tomes=0):\n         try:\n             if tomeid == 0:\n-                self.image.save(target, \"JPEG\", optimize=1, quality=85)\n+                self.image.save(target, \"JPEG\", optimize=1, quality=self.options.jpegquality)\n             else:\n                 copy = self.image.copy()\n                 draw = ImageDraw.Draw(copy)\n@@ -598,7 +598,7 @@ def save_to_epub(self, target, tomeid, len_tomes=0):\n                     stroke_fill=0,\n                     stroke_width=25\n                 )\n-                copy.save(target, \"JPEG\", optimize=1, quality=85)\n+                copy.save(target, \"JPEG\", optimize=1, quality=self.options.jpegquality)\n         except IOError:\n             raise RuntimeError('Failed to save cover.')\n \n@@ -606,6 +606,6 @@ def saveToKindle(self, kindle, asin):\n         self.image = ImageOps.contain(self.image, (300, 470), Image.Resampling.LANCZOS)\n         try:\n             self.image.save(os.path.join(kindle.path.split('documents')[0], 'system', 'thumbnails',\n-                                         'thumbnail_' + asin + '_EBOK_portrait.jpg'), 'JPEG', optimize=1, quality=85)\n+                                         'thumbnail_' + asin + '_EBOK_portrait.jpg'), 'JPEG', optimize=1, quality=self.options.jpegquality)\n         except IOError:\n             raise RuntimeError('Failed to upload cover.')\n", "test_patch": "", "problem_statement": "Blank Page Issues on Kindle Colorsoft\nHello,\r\n\r\nI have had the new Kindle Colorsoft e-reader for 2 days. When I try to convert mangas with KCC using the CS12 profile, I get a white blank page every few pages. When I go back to the main menu and reopen the manga, the page then loads correctly instead of being blank.\r\n\r\nHowever, this is very annoying as I have to repeat this every few pages. I didn't have this problem with my previous Kindle Paperwhite 7. Is there a workaround for this?\r\n\r\nThank you in advance for the response!\r\n\r\n![grafik](https://github.com/user-attachments/assets/2ee68e61-247f-4211-90d0-e48ff872e521)\r\n\nKindle Scribe blank pages\n**Describe the bug**\nThe bottom 1/4 of a page is often cut. Not always but often enough to be an issue.\n\n![Image](https://github.com/user-attachments/assets/1130cf12-372b-4467-b89b-4f87e819d574)\n\nOn top of that I have been getting blank pages here and there.\n\n**Settings**\n\n<img width=\"490\" height=\"642\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/c17dc73e-71d8-4547-9715-7957b291965f\" />\n\n**Desktop:**\n - OS: Windows 10\n - Device: Kindle Scribe 1st gen\n\n**The Issue**\nI believe the issues arises as an effect of the `Inter-panel crop`.\nI am trying to eliminate vertical lines in double pages and it works to some extent (they get narrower) but in return I get this issue.\n\nNow, I haven't narrowed it down to that specific setting but I will update the issue when I do.\n\n**Additional Notes**\nHow come I can't select just `vertical lines` in the `Inter-panel crop`.\n", "hints_text": "That's concerning. Maybe the colorsoft has a bug? Blank pages happen on scribe with PNG and turning pages too fast. \n\nTry normal jpg. \n\n\nTry no upscale. \n\nTry PNG too, though this will convert slowly due to bug I can fix later. \nI have tried JPG, no upscale and PNG. Unfortunately, this problem also occurs here. \r\n\r\nHowever, if I turn the pages very slowly, it seems to occur only rarely.\nIdeas: uncheck color mode \n\nOr\n\nUse scribe profile with color checked. \n> Ideas: uncheck color mode\n> \n> Or\n> \n> Use scribe profile with color checked.\n\nI am also having this issue I will try these suggestions.\n@utopiafallen Do you have any insight into this issue?\n> However, if I turn the pages very slowly, it seems to occur only rarely.\n\nThis has been my experience as well. Other than that, sorry, I don't have much to add.\nJumping on here to say that I am also experiencing this issue. Normally, I turn the Kindle off and back on to be able to see the pages or I get out of the book and get back in. I\u2019ve been using KCC for a long time now with my paper white and just recently got my color soft and started to experience this blank page issue\nCan anyone test if issue happens with humble bundle epubs sent via Send to Kindle?\n\nIf it doesn't happen something is wrong with kcc epub formatting. \n\nIf it does then it's a colorsoft bug that amazon is unlikely to fix since kcc uses the old kf8 comic format. \n\nI do not have a colorsoft so I cannot debug \n> Can anyone test if issue happens with humble bundle epubs sent via Send to Kindle?\n> \n> If it doesn't happen something is wrong with kcc epub formatting.\n> \n> If it does then it's a colorsoft bug that amazon is unlikely to fix since kcc uses the old kf8 comic format.\n> \n> I do not have a colorsoft so I cannot debug\n\nJust tried it. My settings for KCC were:\n\n- Manga Mode\n- Spread Splitter\n- Stretch/Upscale\n- Color Mode\n- Cropping Mode\n\nI used the Colorsoft 12 option and EPUB format. Once it converted the .cbz, I used the Send to Kindle option in the browser. I had to scroll through 40 pages quickly, but it did eventually show a blank page that would not display the correct images until I left the book and went back in. Interestingly enough, I did briefly have a blank page earlier, but it loaded up after going back and forth a page. \nI meant sending an EPUB from humble bundle directly via Send to Kindle, not using KCC at all.\nExperiencing this bug as well. I'm giving up on tweaking with KCC settings, none of them seem to work. As last resort, I slide from the bottom to the center of the screen to correctly view the page (opening chapter view) though it's disturbing.\nThe other option is using EPUB -> AZW3 but then I get wide margins and don't know how to reduce them.\nCan confirm that sending EPUB trough Send To Kindle also has this issue.\nI have a suspicion about this issue. \n\nCould you please tell me the general file size of the final problematic KCC output? I'm specifically looking for the filesizes of the individyal images inside the epub that KCC generates. \n\nA screenshot of the unzipped epub images folder is fine if i can see individual filesizes.\n\nPotentially related: \n\n- #932 \nHere you go, if you need anything more feel free to ask :)\nSettings used, sent with \"Send To Kindle\"\n\n![Image](https://github.com/user-attachments/assets/fcfc7c9a-d10c-4f03-a342-3a1feff06932)\n![Image](https://github.com/user-attachments/assets/88204135-1886-43e0-ae4f-74d5583dbcc7)\n![Image](https://github.com/user-attachments/assets/9fa89e6b-6bb5-4b97-a4ba-31e245003c83)\n![Image](https://github.com/user-attachments/assets/b891b9e6-670c-421f-bd05-38b8a842689c)\n\nI wonder if switching to 8 bit color instead of 24 bit color would help. \n\n\nI have bad news, even with color mode off (the images seem to be grayscale 8 bit now) the blank page issue its still here.\n@JuanPardos \n\nI have another thing you can try.\n\nDo:\n\n1) use kcc 7.5.0 (just released)\n2) scribe profile\n3) try both color mode and non color\n3) jpg unchecked\n4) use a source file >1920 pixels in height so it triggers special rendering mode\n\nAnd tell me if problem still exists\nMake sure Embeded Style is ON in the footer settings. And set T/B margins to as small as possible. May need to set L/R margins smaller also.\nI am back. Some tests I did:\n\nSource images were 800x11130, KCC 7.5.0. \n\n1. Scribe profile, jpeg unchecked, color **ON**, MOBI/AZW3 output, side loaded with USB Calibre -> Blank page issue still here.\n2. Scribe profile, jpeg unchecked, color **OFF**, MOBI/AZW3 output, side loaded with USB Calibre -> Blank page also.\n3. Scribe profile, jpeg unchecked, color **ON**, EPUB (200MB limit) output, sent with Send to Kindle Web-> No blank page issue (hurray!). However something weird happened. Note not all pages looks the same, don't know if this is the special rendering in action but it looks like 1 image on top left, two if there is enough space for second. In pages with only 1 image there is wide right and bottom margin, the first image starts at top left always.\n\nExcept for the special rendering mode this is almost perfect, it has no blank page issue, color and no (top left) fixed margins.\nWill try more setups and configs once I have some spare free time.\n\n\nDidn't try to set margins or Embedded Style. Last time I did some Calibre CSS tweaks the books become unreadable.\n\nOutput of 3.\n![Image](https://github.com/user-attachments/assets/acea4f91-91f9-4a10-bd9f-9ca5e48038e8)\n\nSettings used in 3.\n![Image](https://github.com/user-attachments/assets/00088b96-cc0d-4812-a153-4e55089aacb9)\nOk don't convert or edit with calibre, that will break formatting. \n\nUSB load by dropping the mobi directly into kindle documents folder. Don't involve calibre at all. \n\nMay be worth going back to colorsoft profile to test if you used calibre previously. \nUPDATE: With these settings (note: colorsoft profile) and the same source I was able to skip 50~ pages with no blank pages.\nNo calibre this time, sideloaded to documents folder.\n\nCan't tell if this time was the source used, new KCC version, some settings, no calibre...\nNeed to do more testing but this looks promising.\n\n![Image](https://github.com/user-attachments/assets/1a9c56a9-d256-4b40-91cf-6e9785b45ec1)\nOh no, the blank page is back.\nI don't know what to say... this looks random.\nIn general, it seems to be a problem if you turn pages too fast on colorsoft\n@JuanPardos feel free to try 7.5.1, it should be available in a few minutes with the fix for \n\n> However something weird happened. Note not all pages looks the same, don't know if this is the special rendering in action but it looks like 1 image on top left, two if there is enough space for second. In pages with only 1 image there is wide right and bottom margin, the first image starts at top left always.\n\nIf the scribe special rendering mode fixes the colorsoft issue I'll add it to colorsoft. \nThis is the result of 7.5.1 Kindle Scribe profile + Color + Epub with Send To Kindle:\n\nNot fully fixed as I still get wide margins, though now only 1 image per page which is nice. And still not blank pages with this format (Calibre reports as .kfx). Even when turning pages very fast.\n\nSame pages as the other day plus one random, but all seem to have this huge margin.\nI mean... if there is any way to reduce or delete these huge margins would be better than Colorsoft profile + MOBI which still has the blank page issue with the new version.\n\nStarting to think if .kfx format would be better than MOBI, because at the end is the format I am getting after using Send To Kindle.\n\n![Image](https://github.com/user-attachments/assets/5a414016-b837-4ede-ae4d-536a98c374fe)\n![Image](https://github.com/user-attachments/assets/a8536ad9-6800-408d-9300-98e95260e569)\n![Image](https://github.com/user-attachments/assets/e075cefb-19c3-4a62-a6a6-295d6b6361a3)\nUPDATE: This is the same configuration but Colorsoft profile:\n\nAt this point the only problem I find is the align. And the slowness of Send To Kindle of course...\n\n![Image](https://github.com/user-attachments/assets/df486ccf-2aa7-4e66-8565-98a994fbf5f7)\n![Image](https://github.com/user-attachments/assets/1f181698-b715-4cf8-9b84-37f03a41ba91)\nI have the same problem with colorsoft, tried diferent settings and the blank page allways came back. but i found the following you can export your file with whattever setting from kcc in mobi/azw3 or epub then import it to calibre and in calibre reformat to KFX then errase the other format from calibre and send the KFX file to kindle, this method errased the blank page issue and reading was normal the only issue is no matter what changes you make in the calibre KFX formating it adds a small margin to the top and bottom if it doesnt bother you then stick with this method its super simple and it works. \n\nBut to me i find it a little bit distracting so i continued the search for a way to delete the margins and luckily i found this method.\nBasically you use Kindle create to create a kpf file and use CLI to convert  to kfx. by doing this the margins are set correcly and the blanc page issue is resolved.\n\nHere you can find the detailed process: https://innocen.at/2022/02/creating-kfx-manga-for-kindle-side-loading/\n\nBy the way i start the process from step 2 converting to CBZ with KCC this is done so all the images files have a sequential name so they follow the chapter order.\n\n\n> I have the same problem with colorsoft, tried diferent settings and the blank page allways came back. but i found the following you can export your file with whattever setting from kcc in mobi/azw3 or epub then import it to calibre and in calibre reformat to KFX then errase the other format from calibre and send the KFX file to kindle, this method errased the blank page issue and reading was normal the only issue is no matter what changes you make in the calibre KFX formating it adds a small margin to the top and bottom if it doesnt bother you then stick with this method its super simple and it works.\n> \n> But to me i find it a little bit distracting so i continued the search for a way to delete the margins and luckily i found this method. Basically you use Kindle create to create a kpf file and use CLI to convert to kfx. by doing this the margins are set correcly and the blanc page issue is resolved.\n> \n> Here you can find the detailed process: https://innocen.at/2022/02/creating-kfx-manga-for-kindle-side-loading/\n> \n> By the way i start the process from step 2 converting to CBZ with KCC this is done so all the images files have a sequential name so they follow the chapter order.\n\nYup, this is what we've already been doing and discussed over at the discord. \nOk, I copied some of the special scribe code to the colorsoft code path, MAYBE it works. Please test, I don't have a colorsoft myself. From past experience, JPG/PNG is likely the only setting that makes a difference.\n\nAnd don't turn your pages TOO fast. Kindles always freak out if its too fast, but as long as a good reading pace doesn't blank out.\n\nhttps://github.com/axu2/kcc/releases/tag/v8.0.4-colorsoft\n\n@BastiGit @Antheology @dusk-exhale-paging @JuanPardos @tailune \n\nWhile you are at it, this also includes a new sharper rainbow eraser algorithm and enhanced pdf support including humble/fanatical that I'd love to hear your thoughts on.\n\n\n> Ok, I copied some of the special scribe code to the colorsoft code path, MAYBE it works. Please test, I don't have a colorsoft myself. From past experience, JPG/PNG is likely the only setting that makes a difference.\n> \n> And don't turn your pages TOO fast. Kindles always freak out if its too fast, but as long as a good reading pace doesn't blank out.\n> \n> https://github.com/axu2/kcc/releases/tag/v8.0.4-colorsoft\n> \n> [@BastiGit](https://github.com/BastiGit) [@Antheology](https://github.com/Antheology) [@dusk-exhale-paging](https://github.com/dusk-exhale-paging) [@JuanPardos](https://github.com/JuanPardos) [@tailune](https://github.com/tailune)\n> \n> While you are at it, this also includes a new sharper rainbow eraser algorithm and enhanced pdf support including humble/fanatical that I'd love to hear your thoughts on.\n\nI tested with the new build you sugested: if you leave upscaling unchecked and read at a slow pace the blank page almost never happens, it mostly happens with double spread pages and some times its not a completely blank page but it only renders de bottom 1/4 page, closing at a fully rendered page and re opening renders the blank pages and semi rendered pages correctly.\nI also noticed a slight decrease on blank pages with the new build for Colorsoft. Didn't test a lot of configs though.\nMake sure you try both jpg/png. That makes the difference on scribe at least.\n\nThe upscale unchecked might matter...\n\nWe want to solve the problem of blank pages when reading at a normal pace. Faster than that will always blank out.\n\nBut feedback so far seems that the change doens't make much of a difference...\nJust got a colorsoft and transferred over Humble Bundle manga that I'd converted using KCC and I'm also getting this issue.  It's worth mentioning that on my Kindle Voyage the very same files do not have this issue.  I haven't reconverted them at all.\nGot my kindle colorsoft recently and I'm having the same issue with the converted comics, any updates on a future fix update or something?\nIt doesn't seem to have a pattern on fast page turning or different settings of conversion, it seems really random for me. \nUnfortunately I don't think Amazon will ever fix this.\n\nKey points are\n\n1) Colorsoft never supported the Download & Transfer feature, which enabled you to download and usb transfer manga AZW3 directly from the Kindle store. So this means that the AZW3 manga renderer was never tested on Colorsoft in Amazon internally and that they don't care it's currently broken.\n\nI'd suggest just getting the 7\" Kobo Libra Colour\nYeah, make sense, but the comics that are bought and downloaded directly from Amazon are not the same format? Couldn't be that KCC just hadn't figure it out what is the issue with the format that is converted?\nComics directly downloaded are KFX. KCC is kf8. \n\nThe x is basically 10\nGotcha! Then I believe is not that easy to update the KCC to convert to KFX instead of KF8.\n (I'm not a coder, just a curious user by the way :)\nNo idea about Colorsoft but older Kindles had the same issue and it was caused by page structure and incorrect size of output images.\nSo yeah, I was wondering if it was a KCC or a Kindle issue. Looks like is maybe both? Cause Amazon wouldn't fix a bug of a format that they don't use anymore and for the KCC could be hard to update to the newest format that Amazon uses.\n\nI can live with this bug, just exit the comic and go back solves it. BUT i hope this gets fixed someday.\n\nThanks guys \nThere is no way currently to automate kfx creation of comic style books. \nPlease try this build where jpg quality was changed from 85 to 90:\n\nhttps://github.com/axu2/kcc/releases/tag/v9.3.7-jpg90\n\nThis creates files that take less cpu time to decode but are larger. I suspect that a blank page occurs when the cpu times out during image decoding. Please use jpg unchecked.\n\n@BastiGit @Antheology @utopiafallen @dusk-exhale-paging @JuanPardos @tailune @ValadAmoleo @RaiBoeira \nYou may be right. Tested this build a bit and got a blank after 44 pages. That is while turning pages pretty fast.\nDon't remember exactly but I think I was getting them more often. Can't tell for sure though, haven't been using my kindle lately...\n@JuanPardos turning pages rapidly puts a lot of cpu strain, it will always happen that way. This hopefully prevents it from happening at normal reading pace\nI messed around with the settings in the 9.1.0 version a few months ago and with a simple configuration I got the blank screen issue gone, in a comic of 130 pages using panel view all the time I didnt have the issue once. Using this settings I reconverted comics that previously had the issue and seems to work 99%. In another 130 page comic I had 1 blank screen in page 3 and never again, and it was on page view, when it zoom in with panel view it was visible.\n\nIm using the Kindle Colorsoft, probably wont work in every device that had the issue but is worth the try. the settings are pretty simple , thats may be the reason that worked\n\n(I also had a few comics with pages with no dialogs that resulted in fast page turning and had no issue)\n\n<img width=\"1110\" height=\"549\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/bbf67877-158c-4d43-815e-a37c06c3d2a0\" />\n\nThat's unusual.\n\nI would uncheck upscale, uncheck panel view. In fact, why are you using 2 panel? Scribe is big enough that you don't need to zoom.\n\nUsually those problems only occur for me if I turn pages unreasonably fast.\n\nThat problem never occurs for me when I'm just reading normally.\n\nI really doubt the crop options affect anything.\n\nMaybe it's cause I use an old version of kindlegen from Kindle Comic Creator?\nI think I figured it out, it seems to be the `Cropping mode`.\n\n<img width=\"490\" height=\"642\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/daaf0250-9e92-4120-a8b8-83653f9b6943\" />\n\nHere is the funny thing. I switched the output to **CBZ** to investigate the output directly rather than through my kindle and surprise surprise not a single image was badly cropped.\n\nIt could be something to do with **kindlegen**.\n\nSo I re-generated the MOBI that I generated before (the exact same settings that reproduced the issue).\nAnd this time completely different pages were affected.\n\nI think it's **kindlegen**.\n\nKCC cuts Scribe images into two sections to get around the 1920 limit of kindlegen and then reassembles it on kindle:\n\n<img width=\"1123\" height=\"630\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/3f70bba0-10d7-4ce3-ad84-6f136e7e0b70\" />\n\nhttps://www.youtube.com/watch?v=OhrEWBmvhx8&t=104s\n> That's unusual.\n> \n> I would uncheck upscale, uncheck panel view. In fact, why are you using 2 panel? Scribe is big enough that you don't need to zoom.\n> \n> Usually those problems only occur for me if I turn pages unreasonably fast.\n> \n> That problem never occurs for me when I'm just reading normally.\n> \n> I really doubt the crop options affect anything.\n> \n> Maybe it's cause I use an old version of kindlegen from Kindle Comic Creator?\n\n\nCould be **kindlegen**.\nI downloaded and installed the **Kindle Previewer 3** from the [link ](https://www.amazon.com/Kindle-Previewer/b?ie=UTF8&node=21381691011) in the README. It says it's version `3.99.0`.\n\nI did recently re-install **W10**\nHonestly I feel like I had issues with the kindlegen included in Previewer in the past, but currently it's the only officially distributed version.\n> KCC cuts Scribe images into two sections to get around the 1920 limit of kindlegen and then reassembles it on kindle:\n> \n> <img alt=\"Image\" width=\"1123\" height=\"630\" src=\"https://private-user-images.githubusercontent.com/20757319/514958725-3f70bba0-10d7-4ce3-ad84-6f136e7e0b70.png?jwt=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..i5bCkxmqiSRY7iy2oBDL1qwp2MaUvmTB8pIyVjElR6M\">\n> https://www.youtube.com/watch?v=OhrEWBmvhx8&t=104s\n\nIt seems to match roughly what I am getting, but why only some images?\nThey are all the same res. Perhaps a bit smaller with KCC's cropping.\nThe problem is intermittent and won't occur on same pages if you close and re-open book.\n\nI think it's the panel view setting honestly. I never tested the special panel view options on scribe. They are probably broken.\n\nAnd the box's only have three states, so had to pick 3 of the options.\nYou can try finding an old version of kindlegen to see if that helps.\n\nAlso, how did you even check upscale? That should be disabled on scribe.\n\nAlso, 9.2.2 is out. Kind of surprised it doesn't tell you.\n> The problem is intermittent and won't occur on same pages if you close and re-open book.\n\nActually, for me it persists. I even did a full device restart. It's still in the same spot.\nIt only changes between generations.\n\n> I think it's the panel view setting honestly. And the box's only have three states, so had to pick 3 of the options.\n\nCould be, I am not disputing that but as I mentioned before it seems to be only happening with `Cropping Mode` enabled (any level).\nAnd these settings still produce the issue.\n\n<img width=\"489\" height=\"642\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/c3f5c868-851d-43b0-ba34-627f5635025a\" />\n\n> You can try finding an old version of kindlegen to see if that helps.\n\nCould. Probably would work. But... isn't this debt?\n\n> Also, how did you even check upscale? That should be disabled on scribe.\n> Also, 9.2.2 is out. Kind of surprised it doesn't tell you.\n\nI am running from source. Need to make a PR to phase out the conda env file (since it's not maintained and bit of a hassle to update) and replace it with a command recommendation in the README. I can bump the version but I doubt it will fix the issues. Will update the issue if it does.\n\n\nOkay so bumping the version up did nothing.\nBut... this works\n\n<img width=\"570\" height=\"644\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/8c8e588c-5706-49cf-90c8-b229e5fabf13\" />\n\nNow that I have a baseline I'll try to narrow down which setting, or combination of settings is responsible for this behaviour.\nI am almost sure it's one of the **cropping settings**. I'll try adjusting `cropping power` too see how that affects it (though default should be fine from what I understand), not even sure what `cropping power` does. Might dig into the code a bit.\n\nAnd since the CBZ output is fine the damn **kindlegen** is almost definitely a factor too. Will try an older version of it.\n>> The problem is intermittent and won't occur on same pages if you close and re-open book. \n>\n>Actually, for me it persists. I even did a full device restart. It's still in the same spot.\n\nInteresting. So this is a different issue.\n\n>Actually, for me it persists. I even did a full device restart. It's still in the same spot.\nIt only changes between generations.\n\nSo it's a constant issue?! So easily replicated? Hmmmm\n\nMaybe examine the epub that kcc feeds to kindlegen to see if there's anything weird happening there.\n\n\n> They are all the same res. Perhaps a bit smaller with KCC's cropping.\n\n\nMaybe Kindle Scribe doesn't like high res images that change resolution page to page. Since cropping mode makes each image slightly different res.\n\nOkay so it also happens on **kindlegen 2.9**.\n\nAlso **either** of the **crop settings**, that is\n`Cropping mode` (level 1 and presumably 2 too)\n`Inter-panel crop` (level 2 and presumably 1 too)\ntrigger it.\n\nCould it be that cropping is somehow interfering with https://github.com/ciromattia/kcc/issues/1163#issuecomment-3539704396 ?\nIt seems too much of a coincidence for the missing part of the image to almost exactly match that stitched bottom part of it.\n\nIt would be nice if someone with a Scribe could reproduce it.\nMaybe it's just me.\n\n---\n\n> Maybe examine the epub that kcc feeds to kindlegen to see if there's anything weird happening there.\n\nWill do that, but after I have slept.\nI assume I can just change the output to EPUB?\n\n> Maybe Kindle Scribe doesn't like high res images that change resolution page to page. Since cropping mode makes each image slightly different res.\n\nNever had issues before, and I've been using KCC with cropping enabled for quite a while now.\nIf push comes to shove I will step back through the versions until I find the change that presumably broke it - if such change exists.\n> Never had issues before, and I've been using KCC with cropping enabled for quite a while now.\n\nMaybe kindle firmware change?\n\n> It would be nice if someone with a Scribe could reproduce it.\n\nI guess I can try\n\n> I assume I can just change the output to EPUB?\n\nYes\nI just used these settings with a humble bundle pdf:\n\n<img width=\"621\" height=\"382\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/f452b232-6b1e-4b91-939a-5bf36001402e\" />\n\ncould not replicate. The spread splitter option shouldn't matter since pdf is only split pages.\n\nHave you tried restarting your Kindle? Sometimes weird bugs go away after restart.\n\nAnd splitting happens after cropping, it shouldn't matter...\n> Have you tried restarting your Kindle? Sometimes weird bugs go away after restart.\n\nI have\n\n---\n\nI am going to do a proper investigation and see if I can figure something out.\n\nTried again with these settings: \n\n<img width=\"627\" height=\"323\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/70000a6a-ba09-4094-b4ee-8f486fa5a155\" />\n\nCould not replicate your issue. The blank page/blank bottom third only occured if I turned pages EXTREMELY fast. And went away if I paged back to a good page, exited book, and re-entered book.\nAlso, sometimes weird bugs occur when you have books transferred via Calibre, maybe delete any calibre transferred books via file explorer and usb transfer manually.\n> Also, sometimes weird bugs occur when you have books transferred via Calibre, maybe delete any calibre transferred books via file explorer and usb transfer manually.\n\nWell... the original book and whatever metadata was surrounding it was transferred via Calibre.\nBut this entire investigation I have been dragging the `.mobi` manually - it's faster.\n\nI remove all Calibre stuff and dragged and dropped the `.mobi`.\nIt still has the issue.\n\nSo we can rule out Calibre being a factor.\n>Usually those problems only occur for me if I turn pages unreasonably fast.\n>\n>That problem never occurs for me when I'm just reading normally.\n\nRight... I just noticed that if I go back a page, go out of the book, go back to the book it seems to fix itself.\nI think before I wasn't going back a page.\n\nI'll keep an eye on it, see if that's the issue (turning to fast), though when I usually read manga I don't turn mages very quickly so I am not sure how I run into the issue in the first place.\n\nAnyway, will keep an eye on it. Any idea if it's a kindle thing or of it's because of the page split #962 or whatever else?\n## So Far\n\nOkay, so here is what I know so far:\n- **Blank pages** tend to appear but going back a page, leaving the book and entering it again seems to fix the missing page\n- The above _\"fix\"_ also seems to work for **cut pages** that I showed https://github.com/ciromattia/kcc/issues/1163#issue-3631415022\n- **Blank pages** happen regardless of setting as far as I noticed, but **cut pages** only happen when either `Cropping mode` or/and `Inter-panel crop` is enabled. I tried to force a cut page with the two disabled but it just didn't happen (seems I was wrong about it - read more)\n- It happens with `JPEG` and `mozJPEG`, I didn't test PNGs\n\n\n## Experiment\n\nI decided to do a little experiment, I created a **Test.cbz** from [this file](https://images-wixmp-ed30a86b8c4ca887773594c2.wixmp.com/f/6ef22233-f677-44ed-a031-fe0484d55813/dey43yt-215e4bdc-e74d-4d82-8c1d-5eb1e33bc26b.png/v1/fill/w_1192,h_670,q_70,strp/wallpaper_16_borderless___test_card_by_hexandcube_dey43yt-pre.jpg?token=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..uZYryo3x3bFA2Gh46P29RFiAbiv85k2s3K3qFs2UUl0) and made it into the exact same resolution as the Berserk manga I was using to test before. I created three versions of it,  **Test - nc**, **Test**, and **Test - mod**.\n\n**Test - nc** \nIt's the file as is with cropping disabled. I could not trigger either of the issues and I tried very hard.\n\n**Test**\nIt's the same file as above but with `Cropping mode` and `Inter-panel crop` checked to level 2.\nIn practice no cropping is taking place because there is nothing to crop in the image so visually it's the same at **Test - nc**.\n\nI flipped through it a lot. One time I managed to replicate the **cut page** but haven't managed to repeat it since then. I tried \nhundreds of times but nothing. \n\n**Test - mod**\nI modified every odd page so that there it something to crop, both margins and internally.\n\nI managed to trigger a **cut page** on this several of times. But it's still not as easily achievable as in manga.\n\n\n## Thoughts and more\nOverall I found it much more difficult to trigger a **cut page** on the test files and not once did I encounter a blank page. Why? Could it be that file size matters? The test pages are the same resolution as the Berserk manga but are only `248 KB` rather than `2-3MB`.\n\nThis makes it somewhat interesting and could be related to #665. It could be firmware but I wouldn't be surprised if it's some form of silicon degradation - could be the storage, could even be the CPU (if it's slower). I wonder if anyone with a 2nd gen Scribe or a brand new 1st gen Scribe has encountered this issue.\n\nBut even if that's the case why can't I replicate it with manga when `Cropping mode` and `Inter-panel crop` are turned off.\nSo I tried again, I converted **Berserk Vol.1** (I own a physical copy) and after flipping through it very furiously three times I encountered one **cut page** that fixed itself once I flipped back and forward and two **blank pages** which required me to re-open the manga.\n\n\n## Conclusion\nWhatever it is, seems to be significantly worse (at least for me) when `Cropping mode` and `Inter-panel crop` are enabled but it also happened with the two cropping settings disabled. So I am lost.\n\nThere seems to be some sort of relation between the settings and the issue but at this stage I can't pinpoint with certainty what might be the cause of such behaviour.\n\nMaybe someone more knowledgeable about inner workings of KCC and Kindles can figure it out.\nBut that someone isn't me. I did my best.\n> I wouldn't be surprised if it's some form of silicon degradation - could be the storage, could even be the CPU (if it's slower). I wonder if anyone with a 2nd gen Scribe or a brand new 1st gen Scribe has encountered this issue.\n\nThis is some weird stuff, I haven't seen this issue on my Scribe. I purchased the 64 GB model in early 2023. I feel like a small number of users have this issue even on jpg. Maybe it's a hardware difference, maybe newer Scribe's are slower,  maybe you you lost the CPU speed silicon lottery, perhaps the Scribe is just failing to load the image in time for an arbitrary time limit hardcoded in kindle os. Maybe a factory reset might help but doubtful.\n\nMaybe a video of the issue might help.\n\ncropping literally just crops the image, there's nothing special happening, \n\nwhen did you get your scribe? what gb?\n> Maybe a video of the issue might help.\n\nI mean... I just flip through the manga rapidly to get a **cut page**. But it also happens when I flip through it normally just less frequently. This and my previous investigation is what makes me think it can be something hardware of firmware related.\nAnyway, a video won't be of much help but I'll see if I can do something for my next comment.\n\n> cropping literally just crops the image, there's nothing special happening.\n\nI am well aware. But maybe it somehow changes how #962 behaves.\nOr some weird interaction within the Kindle's firmware?\nMaybe it preloads the next page or something?\nI really don't know. The issue just refuses to play by any rules and all testing is a mix of results as shown by all the messages above.\nOverall the issue is not too bad.\n\n> When did you get your scribe? What GB?\n\nAbout the same time and the same spec as you, though I had it replaced 3 months later because of a dead pixel and then again 3 months after that because of uneven backlight.\n\n---\nI think silicone degradation fits.\nI just wish I understood how the cropping settings factors into all of this.\n\nWhen I find the time I'll jump to just before and right after #962 and see if changes anything to rule that out. \n>> cropping literally just crops the image, there's nothing special happening.\n\n> I am well aware. But maybe it somehow changes how https://github.com/ciromattia/kcc/pull/962 behaves.\n\nIn theory, using the cropping option in KCC is identical to using pre-cropped images into KCC with cropping disabled.\n\nTo be explicit, say 1860x2480 images were cropped to 1600x2480 by KCC with cropping enabled.\n\nIf I instead fed 1600x2480 images into KCC directly with cropping disabled, the output would be identical.\n\n\n> > > cropping literally just crops the image, there's nothing special happening.\n> \n> > I am well aware. But maybe it somehow changes how [#962](https://github.com/ciromattia/kcc/pull/962) behaves.\n> \n> In theory, using the cropping option in KCC is identical to using pre-cropped images into KCC with cropping disabled.\n> \n> To be explicit, say 1860x2480 images were cropped to 1600x2480 by KCC with cropping enabled.\n> \n> If I instead fed 1600x2480 images into KCC directly with cropping disabled, the output would be identical.\n\nOf course, but you are overlooking one crucial aspect of this puzzle, or at least I think so.\nThe outputs are different because each image is unique and requires different cropping.\n\nSay I have a set of images with a resolution of `1860x2480`, as you described.\nSome images will be cropped to `1600x2480` while other will be cropped to `1700x2300` etc etc.\nSo the outputs will differ, yes?\n\nI wonder if I run the conversion with the cropping settings enabled but output a `.cbz` format and then run that with cropping setting disabled, will it still result in the same issue?\n\nEither way, further testing is required. \nMaybe uninstalling Kindle Previewer and using this old version of kindlegen helps? I personally use this version for Mac\n\nhttps://kc2.s3.amazonaws.com/KindleComicCreatorInstall.exe\nhttps://kc2.s3.amazonaws.com/KindleComicCreatorInstall.dmg\nHaving this issue as well with my Scribe.\n\nMy solution was to go back to KCC 6.0 \n> Maybe uninstalling Kindle Previewer and using this old version of kindlegen helps? I personally use this version for Mac\n> \n> https://kc2.s3.amazonaws.com/KindleComicCreatorInstall.exe https://kc2.s3.amazonaws.com/KindleComicCreatorInstall.dmg\n\n@axu2 \nWhat version is this?\n\n> Okay so it also happens on kindlegen 2.9.\n> Having this issue as well with my Scribe.\n> \n> My solution was to go back to KCC 6.0\n\n@Mkilbride \nNice, that's at least something.\nWhat kindlegen version are you on?\n\nAny chance you could check if `7.4.1` also works?\nOK, looks like I've been running the version in the Mac Kindle Previewer version actually. I don't think amazon ever changed the version number at some point.\n\nThe one in Kindle Comic Creator has a slightly different filesize. But since I wasn't actually using it, I don't think it makes any difference. Unless there's a difference between windows and Mac...\n\nKCC 7.5 was a big change in Scribe support, adding 2480 support.\n\nAt this point, I suspect only some Kindle Scribe's have the issue. @Mkilbride Which Scribe do you have? Maybe you just lost a silicon lottery and your scribe is too slow to handle large images.\nHmmm maybe making a shorter image filename might help, wild guess. \n> Hmmm maybe making a shorter image filename might help, wild guess.\n\nThat's not it. I used `Test1.cbz` and still had the same issue.\nMy best guess is it is something to do whit how images are loaded.\n\nThe scribe has to fetch two images right?\nWhat if upon getting just one image it renders it without waiting for the other or something like that, also a wild guess.\nLike... what if it's to do with timing?\nI was referring to the image filename, like `kcc-0001-kcc-a-above.jpg`\n\n> The scribe has to fetch two images right?\n\nYes\n\n> What if upon getting just one image it renders it without waiting for the other or something like that, also a wild guess.\nLike... what if it's to do with timing?\n\nMaybe there's a maximum time to load an image and if it exceeds it just doesn't load.\n> I was referring to the image filename, like `kcc-0001-kcc-a-above.jpg`\n\nWell then my `Test.cbz` -> `Test.mobi` had double digits filenames (`1.jpg, 2.jpg ... 3.jpg`)\n> Well then my Test.cbz -> Test.mobi had double digits filenames (1.jpg, 2.jpg ... 3.jpg)\n\nI'm not talking about the input filenames, I'm talking about the final output filenames that kcc creates. You can see them if you unzip the final epub.\n> > Well then my Test.cbz -> Test.mobi had double digits filenames (1.jpg, 2.jpg ... 3.jpg)\n> \n> I'm not talking about the input filenames, I'm talking about the final output filenames that kcc creates. You can see them if you unzip the final epub.\n\nAh I get ya now.\nIt makes sense to me now.\n\n<img width=\"638\" height=\"386\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/e50b62ea-ba10-416f-a98b-21b5297db211\" />\n\nWell... at this stage anything is worth a try.\nI'll shorten them and see if it changes anything, will tag you when I have something.\n> OK, looks like I've been running the version in the Mac Kindle Previewer version actually. I don't think amazon ever changed the version number at some point.\n> \n> The one in Kindle Comic Creator has a slightly different filesize. But since I wasn't actually using it, I don't think it makes any difference. Unless there's a difference between windows and Mac...\n> \n> KCC 7.5 was a big change in Scribe support, adding 2480 support.\n> \n> At this point, I suspect only some Kindle Scribe's have the issue. [@Mkilbride](https://github.com/Mkilbride) Which Scribe do you have? Maybe you just lost a silicon lottery and your scribe is too slow to handle large images.\n\n32GB Kindle Scribe, got it in 2024.  \nWhich kindle scribe? The 2022 model or the newer one?\n\nAlso, maybe increasing the jpg quality from 80 might help.  Higher quality means less compression means less cpu to decompress. But larger file size. @jaroslawjanas \n> Which kindle scribe? The 2022 model or the newer one?\n> \n> Also, maybe increasing the jpg quality from 80 might help. Higher quality means less compression means less cpu to decompress. But larger file size. [@jaroslawjanas](https://github.com/jaroslawjanas)\n\n@axu2 \nOkay so the filenames ain't it. I tried, made it to `0001-a.jpg, 0001-b.jpg` and it still happened.\n\nBut then, on top of that, I added the change in image quality from `85` to `95` for **JPEG** and **mozJPEG** and it seems to have made a difference (I tested with a `JPEG`)\n\nI still get cut pages, but only a half or more like a third, of the `-below` image is cut off.\nThere are blank pages too but I was flipping through the file quite aggressively, might not come up in normal reading.\n\n---\n\nI think it might be worthwhile to add a small input next to `JPEG/PNG/mozJpeg` (or a slider similar to Cropping Power) where you can modify the image quality. We could keep the default for all devices at `85` but make it `90` or `95` for Scribe or something like that.\n\nEven if it doesn't fix the issue it's not a bad feature to have.\nFor now I'll test it some more with `mozJPEG`.\n\n---\n\nQuestion, why is there such a significant difference in file size between the **EPUBs** and the **MOBIs** ?\n\n<img width=\"606\" height=\"129\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/6512c284-bf01-43ed-996e-544aebdc8832\" />\n> I added the change in image quality from 85 to 95 for JPEG and mozJPEG and it seems to have made a difference\n\nThe small decrease in decoding time makes a difference? That's crazy.\n\n> There are blank pages too but I was flipping through the file quite aggressively, might not come up in normal reading.\n\nIt happens to me only when aggressively flipping. Doesn't happen otherwise. Maybe my Scribe's cpu is slightly faster than yours.\n\n\n\n> We could keep the default for all devices at 85 but make it 90 or 95 for Scribe or something like that.\n\nChanging the default for Scribe sounds fine.  Adjustable jpg quality could be useful but that's a different feature.\n\n> For now I'll test it some more with mozJPEG.\n\nSince moz is more compressed(?), I suspect it will perform worse, but who knows.\n\n> Question, why is there such a significant difference in file size between the EPUBs and the MOBIs ?\n\nNo idea...\n\n\nMoreover, I wonder if this idea can help these other issues:\n\n- #665\n- #768 \nI tried `quality=90` no issues so far.\nIt's also quite an optimal compression spot to be in.\n\n<img width=\"515\" height=\"351\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/37526ec0-680e-41f1-8002-ace3ceaf9cf9\" />\n\nI'll make a PR for it sometime this weekend if I find the time.\n@Mkilbride Please try this build where jpg quality was changed from 85 to 90: \n\nhttps://github.com/axu2/kcc/releases/tag/v9.3.7-jpg90\n\nThis creates files that take less cpu time to decode but are larger. I suspect a blank page occurs when the cpu times out during image decode. I also suspect only some scribe's have slow enough cpus where this is a problem. Please use jpg unchecked.\nI'll try it when I get a chance. Thanks for looking into this. Besides that is there anyway to make larger files? Even without the 200mb limit they seem to stop around 800mb. It really only matters when doing omnibus manga.\n\n I also noticed weird behavior where converting the same volume with the same settings winds up with drastically different file sizes. Like 200mb vs 600mb.\nThe kindlegen limit is somewhere around there.\n\nCould you describe the other issue in more detail? Which settings?\nSorry to say. I just tested this out and it's a no go. Still get the same problem. \n> Sorry to say. I just tested this out and it's a no go. Still get the same problem.\n\nAre you flipping through the manga really fast?\nIs it less frequent or about the same as before?\nSame as before. Also define fast? Some pages are just images, no text, so yeah you don't need to be on them long.\n\nIt was not an issue on older versions. \n> Same as before. Also define fast? Some pages are just images, no text, so yeah you don't need to be on them long.\n\nFaster than when you are reading normally.\n\n\n> It was not an issue on older versions.\n\nYes we know.\n\nSo there is no difference whatsoever for you?\nNo difference. \n@Mkilbride \n\nWell... if you are comfortable running things from the source you can try running the code from [my fork](https://github.com/jaroslawjanas/kcc.git) from the `jpeg-quality`.\n\nSelect the JPEG and set the quality to 100, let's see if it helps.\n\nThat or @axu2 can make you another executable if he's around.\nI really don't want to be sharing binary files for people to run, it's sketchy.\n\n---\n\nIf it doesn't work... well we'll see what then.\nIt did seem to help me a lot but maybe I didn't test it enough.\nCould vary between manga and whatnot.\nI haven't had a chance to try that yet, but of note is the fact I made some . Mobi files and instead of using send to Kindle as epuba, I transferred over USB. I just read an entire volume without it happening. I wonder if it's related. \n> I haven't had a chance to try that yet, but of note is the fact I made some . Mobi files and instead of using send to Kindle as epuba, I transferred over USB. I just read an entire volume without it happening. I wonder if it's related.\n\n@Mkilbride \nAre you using the SendToKindle service? Like through Amazon?\nYou shouldn't, they process the epubs. Kindles have no native epub support.\nI am willing to bet that was it.\n\n@axu2 \nWe really need to add `(recommended)` next to the MOBI option.\nI mean it was fine before and that's what the whole 200mb option was for right? Something changed between the old 6.0 version and now that makes send to Kindle processing bug it up. \n> I mean it was fine before and that's what the whole 200mb option was for right? Something changed between the old 6.0 version and now that makes send to Kindle processing bug it up.\n\nCan you check the file size of the original **epub** that you got out of the KCC and the one on your device that you uploaded through Amazon? Is it smaller?\n\n", "all_hints_text": "That's concerning. Maybe the colorsoft has a bug? Blank pages happen on scribe with PNG and turning pages too fast. \n\nTry normal jpg. \n\n\nTry no upscale. \n\nTry PNG too, though this will convert slowly due to bug I can fix later. \nI have tried JPG, no upscale and PNG. Unfortunately, this problem also occurs here. \r\n\r\nHowever, if I turn the pages very slowly, it seems to occur only rarely.\nIdeas: uncheck color mode \n\nOr\n\nUse scribe profile with color checked. \n> Ideas: uncheck color mode\n> \n> Or\n> \n> Use scribe profile with color checked.\n\nI am also having this issue I will try these suggestions.\n@utopiafallen Do you have any insight into this issue?\n> However, if I turn the pages very slowly, it seems to occur only rarely.\n\nThis has been my experience as well. Other than that, sorry, I don't have much to add.\nJumping on here to say that I am also experiencing this issue. Normally, I turn the Kindle off and back on to be able to see the pages or I get out of the book and get back in. I\u2019ve been using KCC for a long time now with my paper white and just recently got my color soft and started to experience this blank page issue\nCan anyone test if issue happens with humble bundle epubs sent via Send to Kindle?\n\nIf it doesn't happen something is wrong with kcc epub formatting. \n\nIf it does then it's a colorsoft bug that amazon is unlikely to fix since kcc uses the old kf8 comic format. \n\nI do not have a colorsoft so I cannot debug \n> Can anyone test if issue happens with humble bundle epubs sent via Send to Kindle?\n> \n> If it doesn't happen something is wrong with kcc epub formatting.\n> \n> If it does then it's a colorsoft bug that amazon is unlikely to fix since kcc uses the old kf8 comic format.\n> \n> I do not have a colorsoft so I cannot debug\n\nJust tried it. My settings for KCC were:\n\n- Manga Mode\n- Spread Splitter\n- Stretch/Upscale\n- Color Mode\n- Cropping Mode\n\nI used the Colorsoft 12 option and EPUB format. Once it converted the .cbz, I used the Send to Kindle option in the browser. I had to scroll through 40 pages quickly, but it did eventually show a blank page that would not display the correct images until I left the book and went back in. Interestingly enough, I did briefly have a blank page earlier, but it loaded up after going back and forth a page. \nI meant sending an EPUB from humble bundle directly via Send to Kindle, not using KCC at all.\nExperiencing this bug as well. I'm giving up on tweaking with KCC settings, none of them seem to work. As last resort, I slide from the bottom to the center of the screen to correctly view the page (opening chapter view) though it's disturbing.\nThe other option is using EPUB -> AZW3 but then I get wide margins and don't know how to reduce them.\nCan confirm that sending EPUB trough Send To Kindle also has this issue.\nI have a suspicion about this issue. \n\nCould you please tell me the general file size of the final problematic KCC output? I'm specifically looking for the filesizes of the individyal images inside the epub that KCC generates. \n\nA screenshot of the unzipped epub images folder is fine if i can see individual filesizes.\n\nPotentially related: \n\n- #932 \nHere you go, if you need anything more feel free to ask :)\nSettings used, sent with \"Send To Kindle\"\n\n![Image](https://github.com/user-attachments/assets/fcfc7c9a-d10c-4f03-a342-3a1feff06932)\n![Image](https://github.com/user-attachments/assets/88204135-1886-43e0-ae4f-74d5583dbcc7)\n![Image](https://github.com/user-attachments/assets/9fa89e6b-6bb5-4b97-a4ba-31e245003c83)\n![Image](https://github.com/user-attachments/assets/b891b9e6-670c-421f-bd05-38b8a842689c)\n\nI wonder if switching to 8 bit color instead of 24 bit color would help. \n\n\nI have bad news, even with color mode off (the images seem to be grayscale 8 bit now) the blank page issue its still here.\n@JuanPardos \n\nI have another thing you can try.\n\nDo:\n\n1) use kcc 7.5.0 (just released)\n2) scribe profile\n3) try both color mode and non color\n3) jpg unchecked\n4) use a source file >1920 pixels in height so it triggers special rendering mode\n\nAnd tell me if problem still exists\nMake sure Embeded Style is ON in the footer settings. And set T/B margins to as small as possible. May need to set L/R margins smaller also.\nI am back. Some tests I did:\n\nSource images were 800x11130, KCC 7.5.0. \n\n1. Scribe profile, jpeg unchecked, color **ON**, MOBI/AZW3 output, side loaded with USB Calibre -> Blank page issue still here.\n2. Scribe profile, jpeg unchecked, color **OFF**, MOBI/AZW3 output, side loaded with USB Calibre -> Blank page also.\n3. Scribe profile, jpeg unchecked, color **ON**, EPUB (200MB limit) output, sent with Send to Kindle Web-> No blank page issue (hurray!). However something weird happened. Note not all pages looks the same, don't know if this is the special rendering in action but it looks like 1 image on top left, two if there is enough space for second. In pages with only 1 image there is wide right and bottom margin, the first image starts at top left always.\n\nExcept for the special rendering mode this is almost perfect, it has no blank page issue, color and no (top left) fixed margins.\nWill try more setups and configs once I have some spare free time.\n\n\nDidn't try to set margins or Embedded Style. Last time I did some Calibre CSS tweaks the books become unreadable.\n\nOutput of 3.\n![Image](https://github.com/user-attachments/assets/acea4f91-91f9-4a10-bd9f-9ca5e48038e8)\n\nSettings used in 3.\n![Image](https://github.com/user-attachments/assets/00088b96-cc0d-4812-a153-4e55089aacb9)\nOk don't convert or edit with calibre, that will break formatting. \n\nUSB load by dropping the mobi directly into kindle documents folder. Don't involve calibre at all. \n\nMay be worth going back to colorsoft profile to test if you used calibre previously. \nUPDATE: With these settings (note: colorsoft profile) and the same source I was able to skip 50~ pages with no blank pages.\nNo calibre this time, sideloaded to documents folder.\n\nCan't tell if this time was the source used, new KCC version, some settings, no calibre...\nNeed to do more testing but this looks promising.\n\n![Image](https://github.com/user-attachments/assets/1a9c56a9-d256-4b40-91cf-6e9785b45ec1)\nOh no, the blank page is back.\nI don't know what to say... this looks random.\nIn general, it seems to be a problem if you turn pages too fast on colorsoft\n@JuanPardos feel free to try 7.5.1, it should be available in a few minutes with the fix for \n\n> However something weird happened. Note not all pages looks the same, don't know if this is the special rendering in action but it looks like 1 image on top left, two if there is enough space for second. In pages with only 1 image there is wide right and bottom margin, the first image starts at top left always.\n\nIf the scribe special rendering mode fixes the colorsoft issue I'll add it to colorsoft. \nThis is the result of 7.5.1 Kindle Scribe profile + Color + Epub with Send To Kindle:\n\nNot fully fixed as I still get wide margins, though now only 1 image per page which is nice. And still not blank pages with this format (Calibre reports as .kfx). Even when turning pages very fast.\n\nSame pages as the other day plus one random, but all seem to have this huge margin.\nI mean... if there is any way to reduce or delete these huge margins would be better than Colorsoft profile + MOBI which still has the blank page issue with the new version.\n\nStarting to think if .kfx format would be better than MOBI, because at the end is the format I am getting after using Send To Kindle.\n\n![Image](https://github.com/user-attachments/assets/5a414016-b837-4ede-ae4d-536a98c374fe)\n![Image](https://github.com/user-attachments/assets/a8536ad9-6800-408d-9300-98e95260e569)\n![Image](https://github.com/user-attachments/assets/e075cefb-19c3-4a62-a6a6-295d6b6361a3)\nUPDATE: This is the same configuration but Colorsoft profile:\n\nAt this point the only problem I find is the align. And the slowness of Send To Kindle of course...\n\n![Image](https://github.com/user-attachments/assets/df486ccf-2aa7-4e66-8565-98a994fbf5f7)\n![Image](https://github.com/user-attachments/assets/1f181698-b715-4cf8-9b84-37f03a41ba91)\nI have the same problem with colorsoft, tried diferent settings and the blank page allways came back. but i found the following you can export your file with whattever setting from kcc in mobi/azw3 or epub then import it to calibre and in calibre reformat to KFX then errase the other format from calibre and send the KFX file to kindle, this method errased the blank page issue and reading was normal the only issue is no matter what changes you make in the calibre KFX formating it adds a small margin to the top and bottom if it doesnt bother you then stick with this method its super simple and it works. \n\nBut to me i find it a little bit distracting so i continued the search for a way to delete the margins and luckily i found this method.\nBasically you use Kindle create to create a kpf file and use CLI to convert  to kfx. by doing this the margins are set correcly and the blanc page issue is resolved.\n\nHere you can find the detailed process: https://innocen.at/2022/02/creating-kfx-manga-for-kindle-side-loading/\n\nBy the way i start the process from step 2 converting to CBZ with KCC this is done so all the images files have a sequential name so they follow the chapter order.\n\n\n> I have the same problem with colorsoft, tried diferent settings and the blank page allways came back. but i found the following you can export your file with whattever setting from kcc in mobi/azw3 or epub then import it to calibre and in calibre reformat to KFX then errase the other format from calibre and send the KFX file to kindle, this method errased the blank page issue and reading was normal the only issue is no matter what changes you make in the calibre KFX formating it adds a small margin to the top and bottom if it doesnt bother you then stick with this method its super simple and it works.\n> \n> But to me i find it a little bit distracting so i continued the search for a way to delete the margins and luckily i found this method. Basically you use Kindle create to create a kpf file and use CLI to convert to kfx. by doing this the margins are set correcly and the blanc page issue is resolved.\n> \n> Here you can find the detailed process: https://innocen.at/2022/02/creating-kfx-manga-for-kindle-side-loading/\n> \n> By the way i start the process from step 2 converting to CBZ with KCC this is done so all the images files have a sequential name so they follow the chapter order.\n\nYup, this is what we've already been doing and discussed over at the discord. \nOk, I copied some of the special scribe code to the colorsoft code path, MAYBE it works. Please test, I don't have a colorsoft myself. From past experience, JPG/PNG is likely the only setting that makes a difference.\n\nAnd don't turn your pages TOO fast. Kindles always freak out if its too fast, but as long as a good reading pace doesn't blank out.\n\nhttps://github.com/axu2/kcc/releases/tag/v8.0.4-colorsoft\n\n@BastiGit @Antheology @dusk-exhale-paging @JuanPardos @tailune \n\nWhile you are at it, this also includes a new sharper rainbow eraser algorithm and enhanced pdf support including humble/fanatical that I'd love to hear your thoughts on.\n\n\n> Ok, I copied some of the special scribe code to the colorsoft code path, MAYBE it works. Please test, I don't have a colorsoft myself. From past experience, JPG/PNG is likely the only setting that makes a difference.\n> \n> And don't turn your pages TOO fast. Kindles always freak out if its too fast, but as long as a good reading pace doesn't blank out.\n> \n> https://github.com/axu2/kcc/releases/tag/v8.0.4-colorsoft\n> \n> [@BastiGit](https://github.com/BastiGit) [@Antheology](https://github.com/Antheology) [@dusk-exhale-paging](https://github.com/dusk-exhale-paging) [@JuanPardos](https://github.com/JuanPardos) [@tailune](https://github.com/tailune)\n> \n> While you are at it, this also includes a new sharper rainbow eraser algorithm and enhanced pdf support including humble/fanatical that I'd love to hear your thoughts on.\n\nI tested with the new build you sugested: if you leave upscaling unchecked and read at a slow pace the blank page almost never happens, it mostly happens with double spread pages and some times its not a completely blank page but it only renders de bottom 1/4 page, closing at a fully rendered page and re opening renders the blank pages and semi rendered pages correctly.\nI also noticed a slight decrease on blank pages with the new build for Colorsoft. Didn't test a lot of configs though.\nMake sure you try both jpg/png. That makes the difference on scribe at least.\n\nThe upscale unchecked might matter...\n\nWe want to solve the problem of blank pages when reading at a normal pace. Faster than that will always blank out.\n\nBut feedback so far seems that the change doens't make much of a difference...\nJust got a colorsoft and transferred over Humble Bundle manga that I'd converted using KCC and I'm also getting this issue.  It's worth mentioning that on my Kindle Voyage the very same files do not have this issue.  I haven't reconverted them at all.\nGot my kindle colorsoft recently and I'm having the same issue with the converted comics, any updates on a future fix update or something?\nIt doesn't seem to have a pattern on fast page turning or different settings of conversion, it seems really random for me. \nUnfortunately I don't think Amazon will ever fix this.\n\nKey points are\n\n1) Colorsoft never supported the Download & Transfer feature, which enabled you to download and usb transfer manga AZW3 directly from the Kindle store. So this means that the AZW3 manga renderer was never tested on Colorsoft in Amazon internally and that they don't care it's currently broken.\n\nI'd suggest just getting the 7\" Kobo Libra Colour\nYeah, make sense, but the comics that are bought and downloaded directly from Amazon are not the same format? Couldn't be that KCC just hadn't figure it out what is the issue with the format that is converted?\nComics directly downloaded are KFX. KCC is kf8. \n\nThe x is basically 10\nGotcha! Then I believe is not that easy to update the KCC to convert to KFX instead of KF8.\n (I'm not a coder, just a curious user by the way :)\nNo idea about Colorsoft but older Kindles had the same issue and it was caused by page structure and incorrect size of output images.\nSo yeah, I was wondering if it was a KCC or a Kindle issue. Looks like is maybe both? Cause Amazon wouldn't fix a bug of a format that they don't use anymore and for the KCC could be hard to update to the newest format that Amazon uses.\n\nI can live with this bug, just exit the comic and go back solves it. BUT i hope this gets fixed someday.\n\nThanks guys \nThere is no way currently to automate kfx creation of comic style books. \nPlease try this build where jpg quality was changed from 85 to 90:\n\nhttps://github.com/axu2/kcc/releases/tag/v9.3.7-jpg90\n\nThis creates files that take less cpu time to decode but are larger. I suspect that a blank page occurs when the cpu times out during image decoding. Please use jpg unchecked.\n\n@BastiGit @Antheology @utopiafallen @dusk-exhale-paging @JuanPardos @tailune @ValadAmoleo @RaiBoeira \nYou may be right. Tested this build a bit and got a blank after 44 pages. That is while turning pages pretty fast.\nDon't remember exactly but I think I was getting them more often. Can't tell for sure though, haven't been using my kindle lately...\n@JuanPardos turning pages rapidly puts a lot of cpu strain, it will always happen that way. This hopefully prevents it from happening at normal reading pace\nI messed around with the settings in the 9.1.0 version a few months ago and with a simple configuration I got the blank screen issue gone, in a comic of 130 pages using panel view all the time I didnt have the issue once. Using this settings I reconverted comics that previously had the issue and seems to work 99%. In another 130 page comic I had 1 blank screen in page 3 and never again, and it was on page view, when it zoom in with panel view it was visible.\n\nIm using the Kindle Colorsoft, probably wont work in every device that had the issue but is worth the try. the settings are pretty simple , thats may be the reason that worked\n\n(I also had a few comics with pages with no dialogs that resulted in fast page turning and had no issue)\n\n<img width=\"1110\" height=\"549\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/bbf67877-158c-4d43-815e-a37c06c3d2a0\" />\nPour moi le probl\u00e8me n'est pas r\u00e9solu. Si j'utilise la derni\u00e8re pre-release j'ai encore des pages blanches ou pire encore des demi pages. J'ai h\u00e2te que vous trouviez une solution\n@neontheboss Unfortunate, so you are saying that 9.3.8 before the jpg quality change is better?\nIl y en a moins mais malheureusement il y en a encore \nNot sure if it's the right place to post, as I'm using the first Scribe version, not the color one.\n\nEven with the latest version, I have blank pages, or sometimes half-ones...\n\nEven reverting to older versions, the problem is still present. Is it a bug in the Kindle software ?\n\nIs there an older KCC version that could work ?\n\nThanks a lot for your great software anyway !\n@FlorentMartinPilot \n\nPlease make a new thread with your kcc settings. Png will cause blanks. \n![Image](https://github.com/user-attachments/assets/48bdeee5-e628-4a71-8d0f-898b8cbb489b)\nAvec  derni\u00e8re version j\u2019ai des pages comme \u00e7a en plus des pages blanches. \nJ\u2019ai m\u00eame essay\u00e9 avec la qualit\u00e9 des jpg \u00e0 95% mais \u00e7a n\u2019a rien chang\u00e9. \nAuriez-vous une id\u00e9e?\n@neontheboss \n\nWhat settings are you currently using?\n\nMaybe try JPG, 85 quality, and disable cropping.\n<img width=\"1817\" height=\"1103\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/06d80ada-9069-48d1-ad38-578ff539b46f\" />\nVoici mes r\u00e9glages. Et j'ai les pages blanches en 85% et 95%.\nOh you are using Scribe Colorsoft. Yea that's not compatible at this time. Maybe disable cropping fixes it or just use pdf output @neontheboss \n<img width=\"1794\" height=\"519\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/1198def5-99a6-495a-9fcd-feac8937ed63\" />\nVoici les meilleurs r\u00e9glages que j'ai pour le moment. En pdf les marges sont trop grandes donc l'image est trop petite et les textes sont illisible mais par contre il n'y a plus de pages blanches. En mobi j'ai encore pas mal de pages blanche...\nI\u2019ve heard that converting it to KFX format might improve things. Has anyone tried it? Currently, KCC doesn\u2019t support KFX conversion, only EPUB.\n@crow1943 You can use KCC to convert to PDF and usb transfer it, the latest firmware apparently supports fullscreen color for usb loading. If the update isn't activated for you yet, you can use Send to Kindle with the PDF.\n> [@crow1943](https://github.com/crow1943) You can use KCC to convert to PDF and usb transfer it, the latest firmware apparently supports fullscreen color for usb loading. If the update isn't activated for you yet, you can use Send to Kindle with the PDF.\n\nThanks for the heads-up! I tried what you suggested, and converting to PDF actually works on the latest version. The color looks great, and there are no more blank pages.\n\nI also just tried converting to KFX format, and that works perfectly as well. I haven't run into any issues, and even the layout is working exactly as it should.\nI recently learned that KCC had the wrong resolution for the Paperwhite 12th.\n\nIs it wrong for colorsoft too? Having a wrong resolution might cause blank problems...\n\n- #1299 \n\ndouble tap any opposite corners to take a screenshot you can see via usb. you need to tap the very deep into the corners. then look at screenshot and tell me resolution.\n\n\nYup, it's confirmed to be wrong too. Will make a new release shortly.\nIf anyone here wants to confirm i released hotfix in 9.7.2\nYou can also use PDF output for Scribe 2025 series and colorsoft, latest update makes USB PDF fullscreen color.\n\n\n\nThat's unusual.\n\nI would uncheck upscale, uncheck panel view. In fact, why are you using 2 panel? Scribe is big enough that you don't need to zoom.\n\nUsually those problems only occur for me if I turn pages unreasonably fast.\n\nThat problem never occurs for me when I'm just reading normally.\n\nI really doubt the crop options affect anything.\n\nMaybe it's cause I use an old version of kindlegen from Kindle Comic Creator?\nI think I figured it out, it seems to be the `Cropping mode`.\n\n<img width=\"490\" height=\"642\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/daaf0250-9e92-4120-a8b8-83653f9b6943\" />\n\nHere is the funny thing. I switched the output to **CBZ** to investigate the output directly rather than through my kindle and surprise surprise not a single image was badly cropped.\n\nIt could be something to do with **kindlegen**.\n\nSo I re-generated the MOBI that I generated before (the exact same settings that reproduced the issue).\nAnd this time completely different pages were affected.\n\nI think it's **kindlegen**.\n\nKCC cuts Scribe images into two sections to get around the 1920 limit of kindlegen and then reassembles it on kindle:\n\n<img width=\"1123\" height=\"630\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/3f70bba0-10d7-4ce3-ad84-6f136e7e0b70\" />\n\nhttps://www.youtube.com/watch?v=OhrEWBmvhx8&t=104s\n> That's unusual.\n> \n> I would uncheck upscale, uncheck panel view. In fact, why are you using 2 panel? Scribe is big enough that you don't need to zoom.\n> \n> Usually those problems only occur for me if I turn pages unreasonably fast.\n> \n> That problem never occurs for me when I'm just reading normally.\n> \n> I really doubt the crop options affect anything.\n> \n> Maybe it's cause I use an old version of kindlegen from Kindle Comic Creator?\n\n\nCould be **kindlegen**.\nI downloaded and installed the **Kindle Previewer 3** from the [link ](https://www.amazon.com/Kindle-Previewer/b?ie=UTF8&node=21381691011) in the README. It says it's version `3.99.0`.\n\nI did recently re-install **W10**\nHonestly I feel like I had issues with the kindlegen included in Previewer in the past, but currently it's the only officially distributed version.\n> KCC cuts Scribe images into two sections to get around the 1920 limit of kindlegen and then reassembles it on kindle:\n> \n> <img alt=\"Image\" width=\"1123\" height=\"630\" src=\"https://private-user-images.githubusercontent.com/20757319/514958725-3f70bba0-10d7-4ce3-ad84-6f136e7e0b70.png?jwt=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..i5bCkxmqiSRY7iy2oBDL1qwp2MaUvmTB8pIyVjElR6M\">\n> https://www.youtube.com/watch?v=OhrEWBmvhx8&t=104s\n\nIt seems to match roughly what I am getting, but why only some images?\nThey are all the same res. Perhaps a bit smaller with KCC's cropping.\nThe problem is intermittent and won't occur on same pages if you close and re-open book.\n\nI think it's the panel view setting honestly. I never tested the special panel view options on scribe. They are probably broken.\n\nAnd the box's only have three states, so had to pick 3 of the options.\nYou can try finding an old version of kindlegen to see if that helps.\n\nAlso, how did you even check upscale? That should be disabled on scribe.\n\nAlso, 9.2.2 is out. Kind of surprised it doesn't tell you.\n> The problem is intermittent and won't occur on same pages if you close and re-open book.\n\nActually, for me it persists. I even did a full device restart. It's still in the same spot.\nIt only changes between generations.\n\n> I think it's the panel view setting honestly. And the box's only have three states, so had to pick 3 of the options.\n\nCould be, I am not disputing that but as I mentioned before it seems to be only happening with `Cropping Mode` enabled (any level).\nAnd these settings still produce the issue.\n\n<img width=\"489\" height=\"642\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/c3f5c868-851d-43b0-ba34-627f5635025a\" />\n\n> You can try finding an old version of kindlegen to see if that helps.\n\nCould. Probably would work. But... isn't this debt?\n\n> Also, how did you even check upscale? That should be disabled on scribe.\n> Also, 9.2.2 is out. Kind of surprised it doesn't tell you.\n\nI am running from source. Need to make a PR to phase out the conda env file (since it's not maintained and bit of a hassle to update) and replace it with a command recommendation in the README. I can bump the version but I doubt it will fix the issues. Will update the issue if it does.\n\n\nOkay so bumping the version up did nothing.\nBut... this works\n\n<img width=\"570\" height=\"644\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/8c8e588c-5706-49cf-90c8-b229e5fabf13\" />\n\nNow that I have a baseline I'll try to narrow down which setting, or combination of settings is responsible for this behaviour.\nI am almost sure it's one of the **cropping settings**. I'll try adjusting `cropping power` too see how that affects it (though default should be fine from what I understand), not even sure what `cropping power` does. Might dig into the code a bit.\n\nAnd since the CBZ output is fine the damn **kindlegen** is almost definitely a factor too. Will try an older version of it.\n>> The problem is intermittent and won't occur on same pages if you close and re-open book. \n>\n>Actually, for me it persists. I even did a full device restart. It's still in the same spot.\n\nInteresting. So this is a different issue.\n\n>Actually, for me it persists. I even did a full device restart. It's still in the same spot.\nIt only changes between generations.\n\nSo it's a constant issue?! So easily replicated? Hmmmm\n\nMaybe examine the epub that kcc feeds to kindlegen to see if there's anything weird happening there.\n\n\n> They are all the same res. Perhaps a bit smaller with KCC's cropping.\n\n\nMaybe Kindle Scribe doesn't like high res images that change resolution page to page. Since cropping mode makes each image slightly different res.\n\nOkay so it also happens on **kindlegen 2.9**.\n\nAlso **either** of the **crop settings**, that is\n`Cropping mode` (level 1 and presumably 2 too)\n`Inter-panel crop` (level 2 and presumably 1 too)\ntrigger it.\n\nCould it be that cropping is somehow interfering with https://github.com/ciromattia/kcc/issues/1163#issuecomment-3539704396 ?\nIt seems too much of a coincidence for the missing part of the image to almost exactly match that stitched bottom part of it.\n\nIt would be nice if someone with a Scribe could reproduce it.\nMaybe it's just me.\n\n---\n\n> Maybe examine the epub that kcc feeds to kindlegen to see if there's anything weird happening there.\n\nWill do that, but after I have slept.\nI assume I can just change the output to EPUB?\n\n> Maybe Kindle Scribe doesn't like high res images that change resolution page to page. Since cropping mode makes each image slightly different res.\n\nNever had issues before, and I've been using KCC with cropping enabled for quite a while now.\nIf push comes to shove I will step back through the versions until I find the change that presumably broke it - if such change exists.\n> Never had issues before, and I've been using KCC with cropping enabled for quite a while now.\n\nMaybe kindle firmware change?\n\n> It would be nice if someone with a Scribe could reproduce it.\n\nI guess I can try\n\n> I assume I can just change the output to EPUB?\n\nYes\nI just used these settings with a humble bundle pdf:\n\n<img width=\"621\" height=\"382\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/f452b232-6b1e-4b91-939a-5bf36001402e\" />\n\ncould not replicate. The spread splitter option shouldn't matter since pdf is only split pages.\n\nHave you tried restarting your Kindle? Sometimes weird bugs go away after restart.\n\nAnd splitting happens after cropping, it shouldn't matter...\n> Have you tried restarting your Kindle? Sometimes weird bugs go away after restart.\n\nI have\n\n---\n\nI am going to do a proper investigation and see if I can figure something out.\n\nTried again with these settings: \n\n<img width=\"627\" height=\"323\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/70000a6a-ba09-4094-b4ee-8f486fa5a155\" />\n\nCould not replicate your issue. The blank page/blank bottom third only occured if I turned pages EXTREMELY fast. And went away if I paged back to a good page, exited book, and re-entered book.\nAlso, sometimes weird bugs occur when you have books transferred via Calibre, maybe delete any calibre transferred books via file explorer and usb transfer manually.\n> Also, sometimes weird bugs occur when you have books transferred via Calibre, maybe delete any calibre transferred books via file explorer and usb transfer manually.\n\nWell... the original book and whatever metadata was surrounding it was transferred via Calibre.\nBut this entire investigation I have been dragging the `.mobi` manually - it's faster.\n\nI remove all Calibre stuff and dragged and dropped the `.mobi`.\nIt still has the issue.\n\nSo we can rule out Calibre being a factor.\n>Usually those problems only occur for me if I turn pages unreasonably fast.\n>\n>That problem never occurs for me when I'm just reading normally.\n\nRight... I just noticed that if I go back a page, go out of the book, go back to the book it seems to fix itself.\nI think before I wasn't going back a page.\n\nI'll keep an eye on it, see if that's the issue (turning to fast), though when I usually read manga I don't turn mages very quickly so I am not sure how I run into the issue in the first place.\n\nAnyway, will keep an eye on it. Any idea if it's a kindle thing or of it's because of the page split #962 or whatever else?\n## So Far\n\nOkay, so here is what I know so far:\n- **Blank pages** tend to appear but going back a page, leaving the book and entering it again seems to fix the missing page\n- The above _\"fix\"_ also seems to work for **cut pages** that I showed https://github.com/ciromattia/kcc/issues/1163#issue-3631415022\n- **Blank pages** happen regardless of setting as far as I noticed, but **cut pages** only happen when either `Cropping mode` or/and `Inter-panel crop` is enabled. I tried to force a cut page with the two disabled but it just didn't happen (seems I was wrong about it - read more)\n- It happens with `JPEG` and `mozJPEG`, I didn't test PNGs\n\n\n## Experiment\n\nI decided to do a little experiment, I created a **Test.cbz** from [this file](https://images-wixmp-ed30a86b8c4ca887773594c2.wixmp.com/f/6ef22233-f677-44ed-a031-fe0484d55813/dey43yt-215e4bdc-e74d-4d82-8c1d-5eb1e33bc26b.png/v1/fill/w_1192,h_670,q_70,strp/wallpaper_16_borderless___test_card_by_hexandcube_dey43yt-pre.jpg?token=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..uZYryo3x3bFA2Gh46P29RFiAbiv85k2s3K3qFs2UUl0) and made it into the exact same resolution as the Berserk manga I was using to test before. I created three versions of it,  **Test - nc**, **Test**, and **Test - mod**.\n\n**Test - nc** \nIt's the file as is with cropping disabled. I could not trigger either of the issues and I tried very hard.\n\n**Test**\nIt's the same file as above but with `Cropping mode` and `Inter-panel crop` checked to level 2.\nIn practice no cropping is taking place because there is nothing to crop in the image so visually it's the same at **Test - nc**.\n\nI flipped through it a lot. One time I managed to replicate the **cut page** but haven't managed to repeat it since then. I tried \nhundreds of times but nothing. \n\n**Test - mod**\nI modified every odd page so that there it something to crop, both margins and internally.\n\nI managed to trigger a **cut page** on this several of times. But it's still not as easily achievable as in manga.\n\n\n## Thoughts and more\nOverall I found it much more difficult to trigger a **cut page** on the test files and not once did I encounter a blank page. Why? Could it be that file size matters? The test pages are the same resolution as the Berserk manga but are only `248 KB` rather than `2-3MB`.\n\nThis makes it somewhat interesting and could be related to #665. It could be firmware but I wouldn't be surprised if it's some form of silicon degradation - could be the storage, could even be the CPU (if it's slower). I wonder if anyone with a 2nd gen Scribe or a brand new 1st gen Scribe has encountered this issue.\n\nBut even if that's the case why can't I replicate it with manga when `Cropping mode` and `Inter-panel crop` are turned off.\nSo I tried again, I converted **Berserk Vol.1** (I own a physical copy) and after flipping through it very furiously three times I encountered one **cut page** that fixed itself once I flipped back and forward and two **blank pages** which required me to re-open the manga.\n\n\n## Conclusion\nWhatever it is, seems to be significantly worse (at least for me) when `Cropping mode` and `Inter-panel crop` are enabled but it also happened with the two cropping settings disabled. So I am lost.\n\nThere seems to be some sort of relation between the settings and the issue but at this stage I can't pinpoint with certainty what might be the cause of such behaviour.\n\nMaybe someone more knowledgeable about inner workings of KCC and Kindles can figure it out.\nBut that someone isn't me. I did my best.\n> I wouldn't be surprised if it's some form of silicon degradation - could be the storage, could even be the CPU (if it's slower). I wonder if anyone with a 2nd gen Scribe or a brand new 1st gen Scribe has encountered this issue.\n\nThis is some weird stuff, I haven't seen this issue on my Scribe. I purchased the 64 GB model in early 2023. I feel like a small number of users have this issue even on jpg. Maybe it's a hardware difference, maybe newer Scribe's are slower,  maybe you you lost the CPU speed silicon lottery, perhaps the Scribe is just failing to load the image in time for an arbitrary time limit hardcoded in kindle os. Maybe a factory reset might help but doubtful.\n\nMaybe a video of the issue might help.\n\ncropping literally just crops the image, there's nothing special happening, \n\nwhen did you get your scribe? what gb?\n> Maybe a video of the issue might help.\n\nI mean... I just flip through the manga rapidly to get a **cut page**. But it also happens when I flip through it normally just less frequently. This and my previous investigation is what makes me think it can be something hardware of firmware related.\nAnyway, a video won't be of much help but I'll see if I can do something for my next comment.\n\n> cropping literally just crops the image, there's nothing special happening.\n\nI am well aware. But maybe it somehow changes how #962 behaves.\nOr some weird interaction within the Kindle's firmware?\nMaybe it preloads the next page or something?\nI really don't know. The issue just refuses to play by any rules and all testing is a mix of results as shown by all the messages above.\nOverall the issue is not too bad.\n\n> When did you get your scribe? What GB?\n\nAbout the same time and the same spec as you, though I had it replaced 3 months later because of a dead pixel and then again 3 months after that because of uneven backlight.\n\n---\nI think silicone degradation fits.\nI just wish I understood how the cropping settings factors into all of this.\n\nWhen I find the time I'll jump to just before and right after #962 and see if changes anything to rule that out. \n>> cropping literally just crops the image, there's nothing special happening.\n\n> I am well aware. But maybe it somehow changes how https://github.com/ciromattia/kcc/pull/962 behaves.\n\nIn theory, using the cropping option in KCC is identical to using pre-cropped images into KCC with cropping disabled.\n\nTo be explicit, say 1860x2480 images were cropped to 1600x2480 by KCC with cropping enabled.\n\nIf I instead fed 1600x2480 images into KCC directly with cropping disabled, the output would be identical.\n\n\n> > > cropping literally just crops the image, there's nothing special happening.\n> \n> > I am well aware. But maybe it somehow changes how [#962](https://github.com/ciromattia/kcc/pull/962) behaves.\n> \n> In theory, using the cropping option in KCC is identical to using pre-cropped images into KCC with cropping disabled.\n> \n> To be explicit, say 1860x2480 images were cropped to 1600x2480 by KCC with cropping enabled.\n> \n> If I instead fed 1600x2480 images into KCC directly with cropping disabled, the output would be identical.\n\nOf course, but you are overlooking one crucial aspect of this puzzle, or at least I think so.\nThe outputs are different because each image is unique and requires different cropping.\n\nSay I have a set of images with a resolution of `1860x2480`, as you described.\nSome images will be cropped to `1600x2480` while other will be cropped to `1700x2300` etc etc.\nSo the outputs will differ, yes?\n\nI wonder if I run the conversion with the cropping settings enabled but output a `.cbz` format and then run that with cropping setting disabled, will it still result in the same issue?\n\nEither way, further testing is required. \nMaybe uninstalling Kindle Previewer and using this old version of kindlegen helps? I personally use this version for Mac\n\nhttps://kc2.s3.amazonaws.com/KindleComicCreatorInstall.exe\nhttps://kc2.s3.amazonaws.com/KindleComicCreatorInstall.dmg\nHaving this issue as well with my Scribe.\n\nMy solution was to go back to KCC 6.0 \n> Maybe uninstalling Kindle Previewer and using this old version of kindlegen helps? I personally use this version for Mac\n> \n> https://kc2.s3.amazonaws.com/KindleComicCreatorInstall.exe https://kc2.s3.amazonaws.com/KindleComicCreatorInstall.dmg\n\n@axu2 \nWhat version is this?\n\n> Okay so it also happens on kindlegen 2.9.\n> Having this issue as well with my Scribe.\n> \n> My solution was to go back to KCC 6.0\n\n@Mkilbride \nNice, that's at least something.\nWhat kindlegen version are you on?\n\nAny chance you could check if `7.4.1` also works?\nOK, looks like I've been running the version in the Mac Kindle Previewer version actually. I don't think amazon ever changed the version number at some point.\n\nThe one in Kindle Comic Creator has a slightly different filesize. But since I wasn't actually using it, I don't think it makes any difference. Unless there's a difference between windows and Mac...\n\nKCC 7.5 was a big change in Scribe support, adding 2480 support.\n\nAt this point, I suspect only some Kindle Scribe's have the issue. @Mkilbride Which Scribe do you have? Maybe you just lost a silicon lottery and your scribe is too slow to handle large images.\nHmmm maybe making a shorter image filename might help, wild guess. \n> Hmmm maybe making a shorter image filename might help, wild guess.\n\nThat's not it. I used `Test1.cbz` and still had the same issue.\nMy best guess is it is something to do whit how images are loaded.\n\nThe scribe has to fetch two images right?\nWhat if upon getting just one image it renders it without waiting for the other or something like that, also a wild guess.\nLike... what if it's to do with timing?\nI was referring to the image filename, like `kcc-0001-kcc-a-above.jpg`\n\n> The scribe has to fetch two images right?\n\nYes\n\n> What if upon getting just one image it renders it without waiting for the other or something like that, also a wild guess.\nLike... what if it's to do with timing?\n\nMaybe there's a maximum time to load an image and if it exceeds it just doesn't load.\n> I was referring to the image filename, like `kcc-0001-kcc-a-above.jpg`\n\nWell then my `Test.cbz` -> `Test.mobi` had double digits filenames (`1.jpg, 2.jpg ... 3.jpg`)\n> Well then my Test.cbz -> Test.mobi had double digits filenames (1.jpg, 2.jpg ... 3.jpg)\n\nI'm not talking about the input filenames, I'm talking about the final output filenames that kcc creates. You can see them if you unzip the final epub.\n> > Well then my Test.cbz -> Test.mobi had double digits filenames (1.jpg, 2.jpg ... 3.jpg)\n> \n> I'm not talking about the input filenames, I'm talking about the final output filenames that kcc creates. You can see them if you unzip the final epub.\n\nAh I get ya now.\nIt makes sense to me now.\n\n<img width=\"638\" height=\"386\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/e50b62ea-ba10-416f-a98b-21b5297db211\" />\n\nWell... at this stage anything is worth a try.\nI'll shorten them and see if it changes anything, will tag you when I have something.\n> OK, looks like I've been running the version in the Mac Kindle Previewer version actually. I don't think amazon ever changed the version number at some point.\n> \n> The one in Kindle Comic Creator has a slightly different filesize. But since I wasn't actually using it, I don't think it makes any difference. Unless there's a difference between windows and Mac...\n> \n> KCC 7.5 was a big change in Scribe support, adding 2480 support.\n> \n> At this point, I suspect only some Kindle Scribe's have the issue. [@Mkilbride](https://github.com/Mkilbride) Which Scribe do you have? Maybe you just lost a silicon lottery and your scribe is too slow to handle large images.\n\n32GB Kindle Scribe, got it in 2024.  \nWhich kindle scribe? The 2022 model or the newer one?\n\nAlso, maybe increasing the jpg quality from 80 might help.  Higher quality means less compression means less cpu to decompress. But larger file size. @jaroslawjanas \n> Which kindle scribe? The 2022 model or the newer one?\n> \n> Also, maybe increasing the jpg quality from 80 might help. Higher quality means less compression means less cpu to decompress. But larger file size. [@jaroslawjanas](https://github.com/jaroslawjanas)\n\n@axu2 \nOkay so the filenames ain't it. I tried, made it to `0001-a.jpg, 0001-b.jpg` and it still happened.\n\nBut then, on top of that, I added the change in image quality from `85` to `95` for **JPEG** and **mozJPEG** and it seems to have made a difference (I tested with a `JPEG`)\n\nI still get cut pages, but only a half or more like a third, of the `-below` image is cut off.\nThere are blank pages too but I was flipping through the file quite aggressively, might not come up in normal reading.\n\n---\n\nI think it might be worthwhile to add a small input next to `JPEG/PNG/mozJpeg` (or a slider similar to Cropping Power) where you can modify the image quality. We could keep the default for all devices at `85` but make it `90` or `95` for Scribe or something like that.\n\nEven if it doesn't fix the issue it's not a bad feature to have.\nFor now I'll test it some more with `mozJPEG`.\n\n---\n\nQuestion, why is there such a significant difference in file size between the **EPUBs** and the **MOBIs** ?\n\n<img width=\"606\" height=\"129\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/6512c284-bf01-43ed-996e-544aebdc8832\" />\n> I added the change in image quality from 85 to 95 for JPEG and mozJPEG and it seems to have made a difference\n\nThe small decrease in decoding time makes a difference? That's crazy.\n\n> There are blank pages too but I was flipping through the file quite aggressively, might not come up in normal reading.\n\nIt happens to me only when aggressively flipping. Doesn't happen otherwise. Maybe my Scribe's cpu is slightly faster than yours.\n\n\n\n> We could keep the default for all devices at 85 but make it 90 or 95 for Scribe or something like that.\n\nChanging the default for Scribe sounds fine.  Adjustable jpg quality could be useful but that's a different feature.\n\n> For now I'll test it some more with mozJPEG.\n\nSince moz is more compressed(?), I suspect it will perform worse, but who knows.\n\n> Question, why is there such a significant difference in file size between the EPUBs and the MOBIs ?\n\nNo idea...\n\n\nMoreover, I wonder if this idea can help these other issues:\n\n- #665\n- #768 \nI tried `quality=90` no issues so far.\nIt's also quite an optimal compression spot to be in.\n\n<img width=\"515\" height=\"351\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/37526ec0-680e-41f1-8002-ace3ceaf9cf9\" />\n\nI'll make a PR for it sometime this weekend if I find the time.\n@Mkilbride Please try this build where jpg quality was changed from 85 to 90: \n\nhttps://github.com/axu2/kcc/releases/tag/v9.3.7-jpg90\n\nThis creates files that take less cpu time to decode but are larger. I suspect a blank page occurs when the cpu times out during image decode. I also suspect only some scribe's have slow enough cpus where this is a problem. Please use jpg unchecked.\nI'll try it when I get a chance. Thanks for looking into this. Besides that is there anyway to make larger files? Even without the 200mb limit they seem to stop around 800mb. It really only matters when doing omnibus manga.\n\n I also noticed weird behavior where converting the same volume with the same settings winds up with drastically different file sizes. Like 200mb vs 600mb.\nThe kindlegen limit is somewhere around there.\n\nCould you describe the other issue in more detail? Which settings?\nSorry to say. I just tested this out and it's a no go. Still get the same problem. \n> Sorry to say. I just tested this out and it's a no go. Still get the same problem.\n\nAre you flipping through the manga really fast?\nIs it less frequent or about the same as before?\nSame as before. Also define fast? Some pages are just images, no text, so yeah you don't need to be on them long.\n\nIt was not an issue on older versions. \n> Same as before. Also define fast? Some pages are just images, no text, so yeah you don't need to be on them long.\n\nFaster than when you are reading normally.\n\n\n> It was not an issue on older versions.\n\nYes we know.\n\nSo there is no difference whatsoever for you?\nNo difference. \n@Mkilbride \n\nWell... if you are comfortable running things from the source you can try running the code from [my fork](https://github.com/jaroslawjanas/kcc.git) from the `jpeg-quality`.\n\nSelect the JPEG and set the quality to 100, let's see if it helps.\n\nThat or @axu2 can make you another executable if he's around.\nI really don't want to be sharing binary files for people to run, it's sketchy.\n\n---\n\nIf it doesn't work... well we'll see what then.\nIt did seem to help me a lot but maybe I didn't test it enough.\nCould vary between manga and whatnot.\nI haven't had a chance to try that yet, but of note is the fact I made some . Mobi files and instead of using send to Kindle as epuba, I transferred over USB. I just read an entire volume without it happening. I wonder if it's related. \n> I haven't had a chance to try that yet, but of note is the fact I made some . Mobi files and instead of using send to Kindle as epuba, I transferred over USB. I just read an entire volume without it happening. I wonder if it's related.\n\n@Mkilbride \nAre you using the SendToKindle service? Like through Amazon?\nYou shouldn't, they process the epubs. Kindles have no native epub support.\nI am willing to bet that was it.\n\n@axu2 \nWe really need to add `(recommended)` next to the MOBI option.\nI mean it was fine before and that's what the whole 200mb option was for right? Something changed between the old 6.0 version and now that makes send to Kindle processing bug it up. \n> I mean it was fine before and that's what the whole 200mb option was for right? Something changed between the old 6.0 version and now that makes send to Kindle processing bug it up.\n\nCan you check the file size of the original **epub** that you got out of the KCC and the one on your device that you uploaded through Amazon? Is it smaller?\n\n", "commit_urls": ["https://github.com/ciromattia/kcc/commit/47fc745e5a1212b9546bcd9dd10e4720592e5fab"], "created_at": "2025-12-28T22:53:51Z"}
{"repo": "ciromattia/kcc", "pull_number": 1299, "instance_id": "ciromattia__kcc-1299", "issue_numbers": [768], "base_commit": "c5744117e32e69cd1536a7cebd9e05a58253c79e", "patch": "diff --git a/kindlecomicconverter/KCC_gui.py b/kindlecomicconverter/KCC_gui.py\nindex 11b797bb..78314fec 100644\n--- a/kindlecomicconverter/KCC_gui.py\n+++ b/kindlecomicconverter/KCC_gui.py\n@@ -1272,7 +1272,7 @@ def __init__(self, kccapp, kccwindow):\n                 'PVOptions': True, 'ForceExpert': False, 'DefaultFormat': 0, 'DefaultUpscale': True, 'ForceColor': False, 'Label': 'KPW5',\n             },\n             \"Kindle Paperwhite 12\": {\n-                'PVOptions': True, 'ForceExpert': False, 'DefaultFormat': 0, 'DefaultUpscale': True, 'ForceColor': False, 'Label': 'KO',\n+                'PVOptions': True, 'ForceExpert': False, 'DefaultFormat': 0, 'DefaultUpscale': True, 'ForceColor': False, 'Label': 'KPW6',\n             },\n             \"Kindle Colorsoft\": {\n                 'PVOptions': True, 'ForceExpert': False, 'DefaultFormat': 0, 'DefaultUpscale': True, 'ForceColor': True, 'Label': 'KCS',\ndiff --git a/kindlecomicconverter/image.py b/kindlecomicconverter/image.py\nindex 98ec5de8..9ebde0fe 100755\n--- a/kindlecomicconverter/image.py\n+++ b/kindlecomicconverter/image.py\n@@ -98,14 +98,15 @@ def __init__(self):\n         'KV': (\"Kindle Voyage\", (1072, 1448), Palette16, 1.0),\n         'KPW34': (\"Kindle Paperwhite 3/4/Oasis\", (1072, 1448), Palette16, 1.0),\n         'K810': (\"Kindle 8/10\", (600, 800), Palette16, 1.0),\n-        'KO': (\"Kindle Oasis 2/3/Paperwhite 12\", (1264, 1680), Palette16, 1.0),\n+        'KO': (\"Kindle Oasis 2/3\", (1264, 1680), Palette16, 1.0),\n         'K11': (\"Kindle 11\", (1072, 1448), Palette16, 1.0),\n         'KPW5': (\"Kindle Paperwhite 5/Signature Edition\", (1236, 1648), Palette16, 1.0),\n+        'KPW6': (\"Kindle Paperwhite 6\", (1272, 1696), Palette16, 1.0),\n         'KS1860': (\"Kindle 1860\", (1860, 1920), Palette16, 1.0),\n         'KS1920': (\"Kindle 1920\", (1920, 1920), Palette16, 1.0),\n         'KS1240': (\"Kindle 1240\", (1240, 1860), Palette16, 1.0),\n         'KS': (\"Kindle Scribe 1/2\", (1860, 2480), Palette16, 1.0),\n-        'KCS': (\"Kindle Colorsoft\", (1264, 1680), Palette16, 1.0),\n+        'KCS': (\"Kindle Colorsoft\", (1272, 1696), Palette16, 1.0),\n         'KS3': (\"Kindle Scribe 3\", (1986, 2648), Palette16, 1.0),\n         'KSCS': (\"Kindle Scribe Colorsoft\", (1986, 2648), Palette16, 1.0),\n     }\n", "test_patch": "", "problem_statement": "Blank Page Issues on Kindle Colorsoft\nHello,\r\n\r\nI have had the new Kindle Colorsoft e-reader for 2 days. When I try to convert mangas with KCC using the CS12 profile, I get a white blank page every few pages. When I go back to the main menu and reopen the manga, the page then loads correctly instead of being blank.\r\n\r\nHowever, this is very annoying as I have to repeat this every few pages. I didn't have this problem with my previous Kindle Paperwhite 7. Is there a workaround for this?\r\n\r\nThank you in advance for the response!\r\n\r\n![grafik](https://github.com/user-attachments/assets/2ee68e61-247f-4211-90d0-e48ff872e521)\r\n\n", "hints_text": "That's concerning. Maybe the colorsoft has a bug? Blank pages happen on scribe with PNG and turning pages too fast. \n\nTry normal jpg. \n\n\nTry no upscale. \n\nTry PNG too, though this will convert slowly due to bug I can fix later. \nI have tried JPG, no upscale and PNG. Unfortunately, this problem also occurs here. \r\n\r\nHowever, if I turn the pages very slowly, it seems to occur only rarely.\nIdeas: uncheck color mode \n\nOr\n\nUse scribe profile with color checked. \n> Ideas: uncheck color mode\n> \n> Or\n> \n> Use scribe profile with color checked.\n\nI am also having this issue I will try these suggestions.\n@utopiafallen Do you have any insight into this issue?\n> However, if I turn the pages very slowly, it seems to occur only rarely.\n\nThis has been my experience as well. Other than that, sorry, I don't have much to add.\nJumping on here to say that I am also experiencing this issue. Normally, I turn the Kindle off and back on to be able to see the pages or I get out of the book and get back in. I\u2019ve been using KCC for a long time now with my paper white and just recently got my color soft and started to experience this blank page issue\nCan anyone test if issue happens with humble bundle epubs sent via Send to Kindle?\n\nIf it doesn't happen something is wrong with kcc epub formatting. \n\nIf it does then it's a colorsoft bug that amazon is unlikely to fix since kcc uses the old kf8 comic format. \n\nI do not have a colorsoft so I cannot debug \n> Can anyone test if issue happens with humble bundle epubs sent via Send to Kindle?\n> \n> If it doesn't happen something is wrong with kcc epub formatting.\n> \n> If it does then it's a colorsoft bug that amazon is unlikely to fix since kcc uses the old kf8 comic format.\n> \n> I do not have a colorsoft so I cannot debug\n\nJust tried it. My settings for KCC were:\n\n- Manga Mode\n- Spread Splitter\n- Stretch/Upscale\n- Color Mode\n- Cropping Mode\n\nI used the Colorsoft 12 option and EPUB format. Once it converted the .cbz, I used the Send to Kindle option in the browser. I had to scroll through 40 pages quickly, but it did eventually show a blank page that would not display the correct images until I left the book and went back in. Interestingly enough, I did briefly have a blank page earlier, but it loaded up after going back and forth a page. \nI meant sending an EPUB from humble bundle directly via Send to Kindle, not using KCC at all.\nExperiencing this bug as well. I'm giving up on tweaking with KCC settings, none of them seem to work. As last resort, I slide from the bottom to the center of the screen to correctly view the page (opening chapter view) though it's disturbing.\nThe other option is using EPUB -> AZW3 but then I get wide margins and don't know how to reduce them.\nCan confirm that sending EPUB trough Send To Kindle also has this issue.\nI have a suspicion about this issue. \n\nCould you please tell me the general file size of the final problematic KCC output? I'm specifically looking for the filesizes of the individyal images inside the epub that KCC generates. \n\nA screenshot of the unzipped epub images folder is fine if i can see individual filesizes.\n\nPotentially related: \n\n- #932 \nHere you go, if you need anything more feel free to ask :)\nSettings used, sent with \"Send To Kindle\"\n\n![Image](https://github.com/user-attachments/assets/fcfc7c9a-d10c-4f03-a342-3a1feff06932)\n![Image](https://github.com/user-attachments/assets/88204135-1886-43e0-ae4f-74d5583dbcc7)\n![Image](https://github.com/user-attachments/assets/9fa89e6b-6bb5-4b97-a4ba-31e245003c83)\n![Image](https://github.com/user-attachments/assets/b891b9e6-670c-421f-bd05-38b8a842689c)\n\nI wonder if switching to 8 bit color instead of 24 bit color would help. \n\n\nI have bad news, even with color mode off (the images seem to be grayscale 8 bit now) the blank page issue its still here.\n@JuanPardos \n\nI have another thing you can try.\n\nDo:\n\n1) use kcc 7.5.0 (just released)\n2) scribe profile\n3) try both color mode and non color\n3) jpg unchecked\n4) use a source file >1920 pixels in height so it triggers special rendering mode\n\nAnd tell me if problem still exists\nMake sure Embeded Style is ON in the footer settings. And set T/B margins to as small as possible. May need to set L/R margins smaller also.\nI am back. Some tests I did:\n\nSource images were 800x11130, KCC 7.5.0. \n\n1. Scribe profile, jpeg unchecked, color **ON**, MOBI/AZW3 output, side loaded with USB Calibre -> Blank page issue still here.\n2. Scribe profile, jpeg unchecked, color **OFF**, MOBI/AZW3 output, side loaded with USB Calibre -> Blank page also.\n3. Scribe profile, jpeg unchecked, color **ON**, EPUB (200MB limit) output, sent with Send to Kindle Web-> No blank page issue (hurray!). However something weird happened. Note not all pages looks the same, don't know if this is the special rendering in action but it looks like 1 image on top left, two if there is enough space for second. In pages with only 1 image there is wide right and bottom margin, the first image starts at top left always.\n\nExcept for the special rendering mode this is almost perfect, it has no blank page issue, color and no (top left) fixed margins.\nWill try more setups and configs once I have some spare free time.\n\n\nDidn't try to set margins or Embedded Style. Last time I did some Calibre CSS tweaks the books become unreadable.\n\nOutput of 3.\n![Image](https://github.com/user-attachments/assets/acea4f91-91f9-4a10-bd9f-9ca5e48038e8)\n\nSettings used in 3.\n![Image](https://github.com/user-attachments/assets/00088b96-cc0d-4812-a153-4e55089aacb9)\nOk don't convert or edit with calibre, that will break formatting. \n\nUSB load by dropping the mobi directly into kindle documents folder. Don't involve calibre at all. \n\nMay be worth going back to colorsoft profile to test if you used calibre previously. \nUPDATE: With these settings (note: colorsoft profile) and the same source I was able to skip 50~ pages with no blank pages.\nNo calibre this time, sideloaded to documents folder.\n\nCan't tell if this time was the source used, new KCC version, some settings, no calibre...\nNeed to do more testing but this looks promising.\n\n![Image](https://github.com/user-attachments/assets/1a9c56a9-d256-4b40-91cf-6e9785b45ec1)\nOh no, the blank page is back.\nI don't know what to say... this looks random.\nIn general, it seems to be a problem if you turn pages too fast on colorsoft\n@JuanPardos feel free to try 7.5.1, it should be available in a few minutes with the fix for \n\n> However something weird happened. Note not all pages looks the same, don't know if this is the special rendering in action but it looks like 1 image on top left, two if there is enough space for second. In pages with only 1 image there is wide right and bottom margin, the first image starts at top left always.\n\nIf the scribe special rendering mode fixes the colorsoft issue I'll add it to colorsoft. \nThis is the result of 7.5.1 Kindle Scribe profile + Color + Epub with Send To Kindle:\n\nNot fully fixed as I still get wide margins, though now only 1 image per page which is nice. And still not blank pages with this format (Calibre reports as .kfx). Even when turning pages very fast.\n\nSame pages as the other day plus one random, but all seem to have this huge margin.\nI mean... if there is any way to reduce or delete these huge margins would be better than Colorsoft profile + MOBI which still has the blank page issue with the new version.\n\nStarting to think if .kfx format would be better than MOBI, because at the end is the format I am getting after using Send To Kindle.\n\n![Image](https://github.com/user-attachments/assets/5a414016-b837-4ede-ae4d-536a98c374fe)\n![Image](https://github.com/user-attachments/assets/a8536ad9-6800-408d-9300-98e95260e569)\n![Image](https://github.com/user-attachments/assets/e075cefb-19c3-4a62-a6a6-295d6b6361a3)\nUPDATE: This is the same configuration but Colorsoft profile:\n\nAt this point the only problem I find is the align. And the slowness of Send To Kindle of course...\n\n![Image](https://github.com/user-attachments/assets/df486ccf-2aa7-4e66-8565-98a994fbf5f7)\n![Image](https://github.com/user-attachments/assets/1f181698-b715-4cf8-9b84-37f03a41ba91)\nI have the same problem with colorsoft, tried diferent settings and the blank page allways came back. but i found the following you can export your file with whattever setting from kcc in mobi/azw3 or epub then import it to calibre and in calibre reformat to KFX then errase the other format from calibre and send the KFX file to kindle, this method errased the blank page issue and reading was normal the only issue is no matter what changes you make in the calibre KFX formating it adds a small margin to the top and bottom if it doesnt bother you then stick with this method its super simple and it works. \n\nBut to me i find it a little bit distracting so i continued the search for a way to delete the margins and luckily i found this method.\nBasically you use Kindle create to create a kpf file and use CLI to convert  to kfx. by doing this the margins are set correcly and the blanc page issue is resolved.\n\nHere you can find the detailed process: https://innocen.at/2022/02/creating-kfx-manga-for-kindle-side-loading/\n\nBy the way i start the process from step 2 converting to CBZ with KCC this is done so all the images files have a sequential name so they follow the chapter order.\n\n\n> I have the same problem with colorsoft, tried diferent settings and the blank page allways came back. but i found the following you can export your file with whattever setting from kcc in mobi/azw3 or epub then import it to calibre and in calibre reformat to KFX then errase the other format from calibre and send the KFX file to kindle, this method errased the blank page issue and reading was normal the only issue is no matter what changes you make in the calibre KFX formating it adds a small margin to the top and bottom if it doesnt bother you then stick with this method its super simple and it works.\n> \n> But to me i find it a little bit distracting so i continued the search for a way to delete the margins and luckily i found this method. Basically you use Kindle create to create a kpf file and use CLI to convert to kfx. by doing this the margins are set correcly and the blanc page issue is resolved.\n> \n> Here you can find the detailed process: https://innocen.at/2022/02/creating-kfx-manga-for-kindle-side-loading/\n> \n> By the way i start the process from step 2 converting to CBZ with KCC this is done so all the images files have a sequential name so they follow the chapter order.\n\nYup, this is what we've already been doing and discussed over at the discord. \nOk, I copied some of the special scribe code to the colorsoft code path, MAYBE it works. Please test, I don't have a colorsoft myself. From past experience, JPG/PNG is likely the only setting that makes a difference.\n\nAnd don't turn your pages TOO fast. Kindles always freak out if its too fast, but as long as a good reading pace doesn't blank out.\n\nhttps://github.com/axu2/kcc/releases/tag/v8.0.4-colorsoft\n\n@BastiGit @Antheology @dusk-exhale-paging @JuanPardos @tailune \n\nWhile you are at it, this also includes a new sharper rainbow eraser algorithm and enhanced pdf support including humble/fanatical that I'd love to hear your thoughts on.\n\n\n> Ok, I copied some of the special scribe code to the colorsoft code path, MAYBE it works. Please test, I don't have a colorsoft myself. From past experience, JPG/PNG is likely the only setting that makes a difference.\n> \n> And don't turn your pages TOO fast. Kindles always freak out if its too fast, but as long as a good reading pace doesn't blank out.\n> \n> https://github.com/axu2/kcc/releases/tag/v8.0.4-colorsoft\n> \n> [@BastiGit](https://github.com/BastiGit) [@Antheology](https://github.com/Antheology) [@dusk-exhale-paging](https://github.com/dusk-exhale-paging) [@JuanPardos](https://github.com/JuanPardos) [@tailune](https://github.com/tailune)\n> \n> While you are at it, this also includes a new sharper rainbow eraser algorithm and enhanced pdf support including humble/fanatical that I'd love to hear your thoughts on.\n\nI tested with the new build you sugested: if you leave upscaling unchecked and read at a slow pace the blank page almost never happens, it mostly happens with double spread pages and some times its not a completely blank page but it only renders de bottom 1/4 page, closing at a fully rendered page and re opening renders the blank pages and semi rendered pages correctly.\nI also noticed a slight decrease on blank pages with the new build for Colorsoft. Didn't test a lot of configs though.\nMake sure you try both jpg/png. That makes the difference on scribe at least.\n\nThe upscale unchecked might matter...\n\nWe want to solve the problem of blank pages when reading at a normal pace. Faster than that will always blank out.\n\nBut feedback so far seems that the change doens't make much of a difference...\nJust got a colorsoft and transferred over Humble Bundle manga that I'd converted using KCC and I'm also getting this issue.  It's worth mentioning that on my Kindle Voyage the very same files do not have this issue.  I haven't reconverted them at all.\nGot my kindle colorsoft recently and I'm having the same issue with the converted comics, any updates on a future fix update or something?\nIt doesn't seem to have a pattern on fast page turning or different settings of conversion, it seems really random for me. \nUnfortunately I don't think Amazon will ever fix this.\n\nKey points are\n\n1) Colorsoft never supported the Download & Transfer feature, which enabled you to download and usb transfer manga AZW3 directly from the Kindle store. So this means that the AZW3 manga renderer was never tested on Colorsoft in Amazon internally and that they don't care it's currently broken.\n\nI'd suggest just getting the 7\" Kobo Libra Colour\nYeah, make sense, but the comics that are bought and downloaded directly from Amazon are not the same format? Couldn't be that KCC just hadn't figure it out what is the issue with the format that is converted?\nComics directly downloaded are KFX. KCC is kf8. \n\nThe x is basically 10\nGotcha! Then I believe is not that easy to update the KCC to convert to KFX instead of KF8.\n (I'm not a coder, just a curious user by the way :)\nNo idea about Colorsoft but older Kindles had the same issue and it was caused by page structure and incorrect size of output images.\nSo yeah, I was wondering if it was a KCC or a Kindle issue. Looks like is maybe both? Cause Amazon wouldn't fix a bug of a format that they don't use anymore and for the KCC could be hard to update to the newest format that Amazon uses.\n\nI can live with this bug, just exit the comic and go back solves it. BUT i hope this gets fixed someday.\n\nThanks guys \nThere is no way currently to automate kfx creation of comic style books. \nPlease try this build where jpg quality was changed from 85 to 90:\n\nhttps://github.com/axu2/kcc/releases/tag/v9.3.7-jpg90\n\nThis creates files that take less cpu time to decode but are larger. I suspect that a blank page occurs when the cpu times out during image decoding. Please use jpg unchecked.\n\n@BastiGit @Antheology @utopiafallen @dusk-exhale-paging @JuanPardos @tailune @ValadAmoleo @RaiBoeira \nYou may be right. Tested this build a bit and got a blank after 44 pages. That is while turning pages pretty fast.\nDon't remember exactly but I think I was getting them more often. Can't tell for sure though, haven't been using my kindle lately...\n@JuanPardos turning pages rapidly puts a lot of cpu strain, it will always happen that way. This hopefully prevents it from happening at normal reading pace\nI messed around with the settings in the 9.1.0 version a few months ago and with a simple configuration I got the blank screen issue gone, in a comic of 130 pages using panel view all the time I didnt have the issue once. Using this settings I reconverted comics that previously had the issue and seems to work 99%. In another 130 page comic I had 1 blank screen in page 3 and never again, and it was on page view, when it zoom in with panel view it was visible.\n\nIm using the Kindle Colorsoft, probably wont work in every device that had the issue but is worth the try. the settings are pretty simple , thats may be the reason that worked\n\n(I also had a few comics with pages with no dialogs that resulted in fast page turning and had no issue)\n\n<img width=\"1110\" height=\"549\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/bbf67877-158c-4d43-815e-a37c06c3d2a0\" />\nPour moi le probl\u00e8me n'est pas r\u00e9solu. Si j'utilise la derni\u00e8re pre-release j'ai encore des pages blanches ou pire encore des demi pages. J'ai h\u00e2te que vous trouviez une solution\n@neontheboss Unfortunate, so you are saying that 9.3.8 before the jpg quality change is better?\nIl y en a moins mais malheureusement il y en a encore \nNot sure if it's the right place to post, as I'm using the first Scribe version, not the color one.\n\nEven with the latest version, I have blank pages, or sometimes half-ones...\n\nEven reverting to older versions, the problem is still present. Is it a bug in the Kindle software ?\n\nIs there an older KCC version that could work ?\n\nThanks a lot for your great software anyway !\n@FlorentMartinPilot \n\nPlease make a new thread with your kcc settings. Png will cause blanks. \n![Image](https://github.com/user-attachments/assets/48bdeee5-e628-4a71-8d0f-898b8cbb489b)\nAvec  derni\u00e8re version j\u2019ai des pages comme \u00e7a en plus des pages blanches. \nJ\u2019ai m\u00eame essay\u00e9 avec la qualit\u00e9 des jpg \u00e0 95% mais \u00e7a n\u2019a rien chang\u00e9. \nAuriez-vous une id\u00e9e?\n@neontheboss \n\nWhat settings are you currently using?\n\nMaybe try JPG, 85 quality, and disable cropping.\n<img width=\"1817\" height=\"1103\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/06d80ada-9069-48d1-ad38-578ff539b46f\" />\nVoici mes r\u00e9glages. Et j'ai les pages blanches en 85% et 95%.\nOh you are using Scribe Colorsoft. Yea that's not compatible at this time. Maybe disable cropping fixes it or just use pdf output @neontheboss \n<img width=\"1794\" height=\"519\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/1198def5-99a6-495a-9fcd-feac8937ed63\" />\nVoici les meilleurs r\u00e9glages que j'ai pour le moment. En pdf les marges sont trop grandes donc l'image est trop petite et les textes sont illisible mais par contre il n'y a plus de pages blanches. En mobi j'ai encore pas mal de pages blanche...\nI\u2019ve heard that converting it to KFX format might improve things. Has anyone tried it? Currently, KCC doesn\u2019t support KFX conversion, only EPUB.\n@crow1943 You can use KCC to convert to PDF and usb transfer it, the latest firmware apparently supports fullscreen color for usb loading. If the update isn't activated for you yet, you can use Send to Kindle with the PDF.\n> [@crow1943](https://github.com/crow1943) You can use KCC to convert to PDF and usb transfer it, the latest firmware apparently supports fullscreen color for usb loading. If the update isn't activated for you yet, you can use Send to Kindle with the PDF.\n\nThanks for the heads-up! I tried what you suggested, and converting to PDF actually works on the latest version. The color looks great, and there are no more blank pages.\n\nI also just tried converting to KFX format, and that works perfectly as well. I haven't run into any issues, and even the layout is working exactly as it should.\n\n", "all_hints_text": "That's concerning. Maybe the colorsoft has a bug? Blank pages happen on scribe with PNG and turning pages too fast. \n\nTry normal jpg. \n\n\nTry no upscale. \n\nTry PNG too, though this will convert slowly due to bug I can fix later. \nI have tried JPG, no upscale and PNG. Unfortunately, this problem also occurs here. \r\n\r\nHowever, if I turn the pages very slowly, it seems to occur only rarely.\nIdeas: uncheck color mode \n\nOr\n\nUse scribe profile with color checked. \n> Ideas: uncheck color mode\n> \n> Or\n> \n> Use scribe profile with color checked.\n\nI am also having this issue I will try these suggestions.\n@utopiafallen Do you have any insight into this issue?\n> However, if I turn the pages very slowly, it seems to occur only rarely.\n\nThis has been my experience as well. Other than that, sorry, I don't have much to add.\nJumping on here to say that I am also experiencing this issue. Normally, I turn the Kindle off and back on to be able to see the pages or I get out of the book and get back in. I\u2019ve been using KCC for a long time now with my paper white and just recently got my color soft and started to experience this blank page issue\nCan anyone test if issue happens with humble bundle epubs sent via Send to Kindle?\n\nIf it doesn't happen something is wrong with kcc epub formatting. \n\nIf it does then it's a colorsoft bug that amazon is unlikely to fix since kcc uses the old kf8 comic format. \n\nI do not have a colorsoft so I cannot debug \n> Can anyone test if issue happens with humble bundle epubs sent via Send to Kindle?\n> \n> If it doesn't happen something is wrong with kcc epub formatting.\n> \n> If it does then it's a colorsoft bug that amazon is unlikely to fix since kcc uses the old kf8 comic format.\n> \n> I do not have a colorsoft so I cannot debug\n\nJust tried it. My settings for KCC were:\n\n- Manga Mode\n- Spread Splitter\n- Stretch/Upscale\n- Color Mode\n- Cropping Mode\n\nI used the Colorsoft 12 option and EPUB format. Once it converted the .cbz, I used the Send to Kindle option in the browser. I had to scroll through 40 pages quickly, but it did eventually show a blank page that would not display the correct images until I left the book and went back in. Interestingly enough, I did briefly have a blank page earlier, but it loaded up after going back and forth a page. \nI meant sending an EPUB from humble bundle directly via Send to Kindle, not using KCC at all.\nExperiencing this bug as well. I'm giving up on tweaking with KCC settings, none of them seem to work. As last resort, I slide from the bottom to the center of the screen to correctly view the page (opening chapter view) though it's disturbing.\nThe other option is using EPUB -> AZW3 but then I get wide margins and don't know how to reduce them.\nCan confirm that sending EPUB trough Send To Kindle also has this issue.\nI have a suspicion about this issue. \n\nCould you please tell me the general file size of the final problematic KCC output? I'm specifically looking for the filesizes of the individyal images inside the epub that KCC generates. \n\nA screenshot of the unzipped epub images folder is fine if i can see individual filesizes.\n\nPotentially related: \n\n- #932 \nHere you go, if you need anything more feel free to ask :)\nSettings used, sent with \"Send To Kindle\"\n\n![Image](https://github.com/user-attachments/assets/fcfc7c9a-d10c-4f03-a342-3a1feff06932)\n![Image](https://github.com/user-attachments/assets/88204135-1886-43e0-ae4f-74d5583dbcc7)\n![Image](https://github.com/user-attachments/assets/9fa89e6b-6bb5-4b97-a4ba-31e245003c83)\n![Image](https://github.com/user-attachments/assets/b891b9e6-670c-421f-bd05-38b8a842689c)\n\nI wonder if switching to 8 bit color instead of 24 bit color would help. \n\n\nI have bad news, even with color mode off (the images seem to be grayscale 8 bit now) the blank page issue its still here.\n@JuanPardos \n\nI have another thing you can try.\n\nDo:\n\n1) use kcc 7.5.0 (just released)\n2) scribe profile\n3) try both color mode and non color\n3) jpg unchecked\n4) use a source file >1920 pixels in height so it triggers special rendering mode\n\nAnd tell me if problem still exists\nMake sure Embeded Style is ON in the footer settings. And set T/B margins to as small as possible. May need to set L/R margins smaller also.\nI am back. Some tests I did:\n\nSource images were 800x11130, KCC 7.5.0. \n\n1. Scribe profile, jpeg unchecked, color **ON**, MOBI/AZW3 output, side loaded with USB Calibre -> Blank page issue still here.\n2. Scribe profile, jpeg unchecked, color **OFF**, MOBI/AZW3 output, side loaded with USB Calibre -> Blank page also.\n3. Scribe profile, jpeg unchecked, color **ON**, EPUB (200MB limit) output, sent with Send to Kindle Web-> No blank page issue (hurray!). However something weird happened. Note not all pages looks the same, don't know if this is the special rendering in action but it looks like 1 image on top left, two if there is enough space for second. In pages with only 1 image there is wide right and bottom margin, the first image starts at top left always.\n\nExcept for the special rendering mode this is almost perfect, it has no blank page issue, color and no (top left) fixed margins.\nWill try more setups and configs once I have some spare free time.\n\n\nDidn't try to set margins or Embedded Style. Last time I did some Calibre CSS tweaks the books become unreadable.\n\nOutput of 3.\n![Image](https://github.com/user-attachments/assets/acea4f91-91f9-4a10-bd9f-9ca5e48038e8)\n\nSettings used in 3.\n![Image](https://github.com/user-attachments/assets/00088b96-cc0d-4812-a153-4e55089aacb9)\nOk don't convert or edit with calibre, that will break formatting. \n\nUSB load by dropping the mobi directly into kindle documents folder. Don't involve calibre at all. \n\nMay be worth going back to colorsoft profile to test if you used calibre previously. \nUPDATE: With these settings (note: colorsoft profile) and the same source I was able to skip 50~ pages with no blank pages.\nNo calibre this time, sideloaded to documents folder.\n\nCan't tell if this time was the source used, new KCC version, some settings, no calibre...\nNeed to do more testing but this looks promising.\n\n![Image](https://github.com/user-attachments/assets/1a9c56a9-d256-4b40-91cf-6e9785b45ec1)\nOh no, the blank page is back.\nI don't know what to say... this looks random.\nIn general, it seems to be a problem if you turn pages too fast on colorsoft\n@JuanPardos feel free to try 7.5.1, it should be available in a few minutes with the fix for \n\n> However something weird happened. Note not all pages looks the same, don't know if this is the special rendering in action but it looks like 1 image on top left, two if there is enough space for second. In pages with only 1 image there is wide right and bottom margin, the first image starts at top left always.\n\nIf the scribe special rendering mode fixes the colorsoft issue I'll add it to colorsoft. \nThis is the result of 7.5.1 Kindle Scribe profile + Color + Epub with Send To Kindle:\n\nNot fully fixed as I still get wide margins, though now only 1 image per page which is nice. And still not blank pages with this format (Calibre reports as .kfx). Even when turning pages very fast.\n\nSame pages as the other day plus one random, but all seem to have this huge margin.\nI mean... if there is any way to reduce or delete these huge margins would be better than Colorsoft profile + MOBI which still has the blank page issue with the new version.\n\nStarting to think if .kfx format would be better than MOBI, because at the end is the format I am getting after using Send To Kindle.\n\n![Image](https://github.com/user-attachments/assets/5a414016-b837-4ede-ae4d-536a98c374fe)\n![Image](https://github.com/user-attachments/assets/a8536ad9-6800-408d-9300-98e95260e569)\n![Image](https://github.com/user-attachments/assets/e075cefb-19c3-4a62-a6a6-295d6b6361a3)\nUPDATE: This is the same configuration but Colorsoft profile:\n\nAt this point the only problem I find is the align. And the slowness of Send To Kindle of course...\n\n![Image](https://github.com/user-attachments/assets/df486ccf-2aa7-4e66-8565-98a994fbf5f7)\n![Image](https://github.com/user-attachments/assets/1f181698-b715-4cf8-9b84-37f03a41ba91)\nI have the same problem with colorsoft, tried diferent settings and the blank page allways came back. but i found the following you can export your file with whattever setting from kcc in mobi/azw3 or epub then import it to calibre and in calibre reformat to KFX then errase the other format from calibre and send the KFX file to kindle, this method errased the blank page issue and reading was normal the only issue is no matter what changes you make in the calibre KFX formating it adds a small margin to the top and bottom if it doesnt bother you then stick with this method its super simple and it works. \n\nBut to me i find it a little bit distracting so i continued the search for a way to delete the margins and luckily i found this method.\nBasically you use Kindle create to create a kpf file and use CLI to convert  to kfx. by doing this the margins are set correcly and the blanc page issue is resolved.\n\nHere you can find the detailed process: https://innocen.at/2022/02/creating-kfx-manga-for-kindle-side-loading/\n\nBy the way i start the process from step 2 converting to CBZ with KCC this is done so all the images files have a sequential name so they follow the chapter order.\n\n\n> I have the same problem with colorsoft, tried diferent settings and the blank page allways came back. but i found the following you can export your file with whattever setting from kcc in mobi/azw3 or epub then import it to calibre and in calibre reformat to KFX then errase the other format from calibre and send the KFX file to kindle, this method errased the blank page issue and reading was normal the only issue is no matter what changes you make in the calibre KFX formating it adds a small margin to the top and bottom if it doesnt bother you then stick with this method its super simple and it works.\n> \n> But to me i find it a little bit distracting so i continued the search for a way to delete the margins and luckily i found this method. Basically you use Kindle create to create a kpf file and use CLI to convert to kfx. by doing this the margins are set correcly and the blanc page issue is resolved.\n> \n> Here you can find the detailed process: https://innocen.at/2022/02/creating-kfx-manga-for-kindle-side-loading/\n> \n> By the way i start the process from step 2 converting to CBZ with KCC this is done so all the images files have a sequential name so they follow the chapter order.\n\nYup, this is what we've already been doing and discussed over at the discord. \nOk, I copied some of the special scribe code to the colorsoft code path, MAYBE it works. Please test, I don't have a colorsoft myself. From past experience, JPG/PNG is likely the only setting that makes a difference.\n\nAnd don't turn your pages TOO fast. Kindles always freak out if its too fast, but as long as a good reading pace doesn't blank out.\n\nhttps://github.com/axu2/kcc/releases/tag/v8.0.4-colorsoft\n\n@BastiGit @Antheology @dusk-exhale-paging @JuanPardos @tailune \n\nWhile you are at it, this also includes a new sharper rainbow eraser algorithm and enhanced pdf support including humble/fanatical that I'd love to hear your thoughts on.\n\n\n> Ok, I copied some of the special scribe code to the colorsoft code path, MAYBE it works. Please test, I don't have a colorsoft myself. From past experience, JPG/PNG is likely the only setting that makes a difference.\n> \n> And don't turn your pages TOO fast. Kindles always freak out if its too fast, but as long as a good reading pace doesn't blank out.\n> \n> https://github.com/axu2/kcc/releases/tag/v8.0.4-colorsoft\n> \n> [@BastiGit](https://github.com/BastiGit) [@Antheology](https://github.com/Antheology) [@dusk-exhale-paging](https://github.com/dusk-exhale-paging) [@JuanPardos](https://github.com/JuanPardos) [@tailune](https://github.com/tailune)\n> \n> While you are at it, this also includes a new sharper rainbow eraser algorithm and enhanced pdf support including humble/fanatical that I'd love to hear your thoughts on.\n\nI tested with the new build you sugested: if you leave upscaling unchecked and read at a slow pace the blank page almost never happens, it mostly happens with double spread pages and some times its not a completely blank page but it only renders de bottom 1/4 page, closing at a fully rendered page and re opening renders the blank pages and semi rendered pages correctly.\nI also noticed a slight decrease on blank pages with the new build for Colorsoft. Didn't test a lot of configs though.\nMake sure you try both jpg/png. That makes the difference on scribe at least.\n\nThe upscale unchecked might matter...\n\nWe want to solve the problem of blank pages when reading at a normal pace. Faster than that will always blank out.\n\nBut feedback so far seems that the change doens't make much of a difference...\nJust got a colorsoft and transferred over Humble Bundle manga that I'd converted using KCC and I'm also getting this issue.  It's worth mentioning that on my Kindle Voyage the very same files do not have this issue.  I haven't reconverted them at all.\nGot my kindle colorsoft recently and I'm having the same issue with the converted comics, any updates on a future fix update or something?\nIt doesn't seem to have a pattern on fast page turning or different settings of conversion, it seems really random for me. \nUnfortunately I don't think Amazon will ever fix this.\n\nKey points are\n\n1) Colorsoft never supported the Download & Transfer feature, which enabled you to download and usb transfer manga AZW3 directly from the Kindle store. So this means that the AZW3 manga renderer was never tested on Colorsoft in Amazon internally and that they don't care it's currently broken.\n\nI'd suggest just getting the 7\" Kobo Libra Colour\nYeah, make sense, but the comics that are bought and downloaded directly from Amazon are not the same format? Couldn't be that KCC just hadn't figure it out what is the issue with the format that is converted?\nComics directly downloaded are KFX. KCC is kf8. \n\nThe x is basically 10\nGotcha! Then I believe is not that easy to update the KCC to convert to KFX instead of KF8.\n (I'm not a coder, just a curious user by the way :)\nNo idea about Colorsoft but older Kindles had the same issue and it was caused by page structure and incorrect size of output images.\nSo yeah, I was wondering if it was a KCC or a Kindle issue. Looks like is maybe both? Cause Amazon wouldn't fix a bug of a format that they don't use anymore and for the KCC could be hard to update to the newest format that Amazon uses.\n\nI can live with this bug, just exit the comic and go back solves it. BUT i hope this gets fixed someday.\n\nThanks guys \nThere is no way currently to automate kfx creation of comic style books. \nPlease try this build where jpg quality was changed from 85 to 90:\n\nhttps://github.com/axu2/kcc/releases/tag/v9.3.7-jpg90\n\nThis creates files that take less cpu time to decode but are larger. I suspect that a blank page occurs when the cpu times out during image decoding. Please use jpg unchecked.\n\n@BastiGit @Antheology @utopiafallen @dusk-exhale-paging @JuanPardos @tailune @ValadAmoleo @RaiBoeira \nYou may be right. Tested this build a bit and got a blank after 44 pages. That is while turning pages pretty fast.\nDon't remember exactly but I think I was getting them more often. Can't tell for sure though, haven't been using my kindle lately...\n@JuanPardos turning pages rapidly puts a lot of cpu strain, it will always happen that way. This hopefully prevents it from happening at normal reading pace\nI messed around with the settings in the 9.1.0 version a few months ago and with a simple configuration I got the blank screen issue gone, in a comic of 130 pages using panel view all the time I didnt have the issue once. Using this settings I reconverted comics that previously had the issue and seems to work 99%. In another 130 page comic I had 1 blank screen in page 3 and never again, and it was on page view, when it zoom in with panel view it was visible.\n\nIm using the Kindle Colorsoft, probably wont work in every device that had the issue but is worth the try. the settings are pretty simple , thats may be the reason that worked\n\n(I also had a few comics with pages with no dialogs that resulted in fast page turning and had no issue)\n\n<img width=\"1110\" height=\"549\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/bbf67877-158c-4d43-815e-a37c06c3d2a0\" />\nPour moi le probl\u00e8me n'est pas r\u00e9solu. Si j'utilise la derni\u00e8re pre-release j'ai encore des pages blanches ou pire encore des demi pages. J'ai h\u00e2te que vous trouviez une solution\n@neontheboss Unfortunate, so you are saying that 9.3.8 before the jpg quality change is better?\nIl y en a moins mais malheureusement il y en a encore \nNot sure if it's the right place to post, as I'm using the first Scribe version, not the color one.\n\nEven with the latest version, I have blank pages, or sometimes half-ones...\n\nEven reverting to older versions, the problem is still present. Is it a bug in the Kindle software ?\n\nIs there an older KCC version that could work ?\n\nThanks a lot for your great software anyway !\n@FlorentMartinPilot \n\nPlease make a new thread with your kcc settings. Png will cause blanks. \n![Image](https://github.com/user-attachments/assets/48bdeee5-e628-4a71-8d0f-898b8cbb489b)\nAvec  derni\u00e8re version j\u2019ai des pages comme \u00e7a en plus des pages blanches. \nJ\u2019ai m\u00eame essay\u00e9 avec la qualit\u00e9 des jpg \u00e0 95% mais \u00e7a n\u2019a rien chang\u00e9. \nAuriez-vous une id\u00e9e?\n@neontheboss \n\nWhat settings are you currently using?\n\nMaybe try JPG, 85 quality, and disable cropping.\n<img width=\"1817\" height=\"1103\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/06d80ada-9069-48d1-ad38-578ff539b46f\" />\nVoici mes r\u00e9glages. Et j'ai les pages blanches en 85% et 95%.\nOh you are using Scribe Colorsoft. Yea that's not compatible at this time. Maybe disable cropping fixes it or just use pdf output @neontheboss \n<img width=\"1794\" height=\"519\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/1198def5-99a6-495a-9fcd-feac8937ed63\" />\nVoici les meilleurs r\u00e9glages que j'ai pour le moment. En pdf les marges sont trop grandes donc l'image est trop petite et les textes sont illisible mais par contre il n'y a plus de pages blanches. En mobi j'ai encore pas mal de pages blanche...\nI\u2019ve heard that converting it to KFX format might improve things. Has anyone tried it? Currently, KCC doesn\u2019t support KFX conversion, only EPUB.\n@crow1943 You can use KCC to convert to PDF and usb transfer it, the latest firmware apparently supports fullscreen color for usb loading. If the update isn't activated for you yet, you can use Send to Kindle with the PDF.\n> [@crow1943](https://github.com/crow1943) You can use KCC to convert to PDF and usb transfer it, the latest firmware apparently supports fullscreen color for usb loading. If the update isn't activated for you yet, you can use Send to Kindle with the PDF.\n\nThanks for the heads-up! I tried what you suggested, and converting to PDF actually works on the latest version. The color looks great, and there are no more blank pages.\n\nI also just tried converting to KFX format, and that works perfectly as well. I haven't run into any issues, and even the layout is working exactly as it should.\nI recently learned that KCC had the wrong resolution for the Paperwhite 12th.\n\nIs it wrong for colorsoft too? Having a wrong resolution might cause blank problems...\n\n- #1299 \n\ndouble tap any opposite corners to take a screenshot you can see via usb. you need to tap the very deep into the corners. then look at screenshot and tell me resolution.\n\n\nYup, it's confirmed to be wrong too. Will make a new release shortly.\nIf anyone here wants to confirm i released hotfix in 9.7.2\nYou can also use PDF output for Scribe 2025 series and colorsoft, latest update makes USB PDF fullscreen color.\n\n\n\n", "commit_urls": ["https://github.com/ciromattia/kcc/commit/fcd76406019e1adf6de149b0c7fcf9509dee9a17", "https://github.com/ciromattia/kcc/commit/b7618dfa1379523789a0f8c04de0098480859820"], "created_at": "2026-04-16T18:18:46Z"}
{"repo": "ciromattia/kcc", "pull_number": 953, "instance_id": "ciromattia__kcc-953", "issue_numbers": [769, 915], "base_commit": "06ae4ec25f11dc6652d4df1a1c1edfb3246be8b1", "patch": "diff --git a/kindlecomicconverter/comic2ebook.py b/kindlecomicconverter/comic2ebook.py\nindex 8c8dd83f..caff636e 100755\n--- a/kindlecomicconverter/comic2ebook.py\n+++ b/kindlecomicconverter/comic2ebook.py\n@@ -314,12 +314,8 @@ def buildOPF(dstdir, title, filelist, cover=None):\n                   \"<item id=\\\"nav\\\" href=\\\"nav.xhtml\\\" \",\n                   \"properties=\\\"nav\\\" media-type=\\\"application/xhtml+xml\\\"/>\\n\"])\n     if cover is not None:\n-        filename = getImageFileName(cover.replace(os.path.join(dstdir, 'OEBPS'), '').lstrip('/').lstrip('\\\\\\\\'))\n-        if '.png' == filename[1]:\n-            mt = 'image/png'\n-        else:\n-            mt = 'image/jpeg'\n-        f.write(\"<item id=\\\"cover\\\" href=\\\"Images/cover\" + filename[1] + \"\\\" media-type=\\\"\" + mt +\n+        mt = 'image/jpeg'\n+        f.write(\"<item id=\\\"cover\\\" href=\\\"Images/cover.jpg\" + \"\\\" media-type=\\\"\" + mt +\n                 \"\\\" properties=\\\"cover-image\\\"/>\\n\")\n     reflist = []\n     for path in filelist:\n@@ -427,10 +423,9 @@ def pageSpreadProperty(pageside):\n                   \"</container>\"])\n     f.close()\n \n-def buildEPUB(path, chapternames, tomenumber, ischunked):\n+def buildEPUB(path, chapternames, tomenumber, ischunked, cover: image.Cover):\n     filelist = []\n     chapterlist = []\n-    cover = None\n     os.mkdir(os.path.join(path, 'OEBPS', 'Text'))\n     f = open(os.path.join(path, 'OEBPS', 'Text', 'style.css'), 'w', encoding='UTF-8')\n     f.writelines([\"@page {\\n\",\n@@ -508,18 +503,14 @@ def buildEPUB(path, chapternames, tomenumber, ischunked):\n                       \"}\\n\"])\n     f.close()\n     build_html_start = perf_counter()\n+    cover.save_to_epub(os.path.join(path, 'OEBPS', 'Images', 'cover.jpg'), tomenumber)\n+    options.covers.append((cover, options.uuid))\n     for dirpath, dirnames, filenames in os.walk(os.path.join(path, 'OEBPS', 'Images')):\n         chapter = False\n         dirnames, filenames = walkSort(dirnames, filenames)\n         for afile in filenames:\n-            if cover is None:\n-                try:\n-                    cover = os.path.join(os.path.join(path, 'OEBPS', 'Images'),\n-                                        'cover' + getImageFileName(afile)[1])\n-                except Exception as e:\n-                    raise UserWarning(f\"{afile}: {e}\")\n-                options.covers.append((image.Cover(os.path.join(dirpath, afile), cover, options,\n-                                                   tomenumber), options.uuid))\n+            if afile == 'cover.jpg':\n+                continue\n             if not chapter:\n                 chapterlist.append((dirpath.replace('Images', 'Text'), afile))\n                 chapter = True\n@@ -801,6 +792,7 @@ def getPanelViewSize(deviceres, size):\n def sanitizeTree(filetree):\n     chapterNames = {}\n     page = 1\n+    cover_path = None\n     for root, dirs, files in os.walk(filetree):\n         dirs.sort(key=OS_SORT_KEY)\n         files.sort(key=OS_SORT_KEY)\n@@ -815,6 +807,8 @@ def sanitizeTree(filetree):\n             key = os.path.join(root, name)\n             if key != newKey:\n                 os.replace(key, newKey)\n+            if not cover_path:\n+                cover_path = newKey\n         for i, name in enumerate(dirs):\n             tmpName = name\n             slugified = slugify(name)\n@@ -826,7 +820,7 @@ def sanitizeTree(filetree):\n             if key != newKey:\n                 os.replace(key, newKey)\n                 dirs[i] = newKey\n-    return chapterNames\n+    return chapterNames, cover_path\n \n \n def flattenTree(filetree):\n@@ -1242,7 +1236,9 @@ def makeBook(source, qtgui=None):\n     print(\"Checking images...\")\n     getComicInfo(os.path.join(path, \"OEBPS\", \"Images\"), source)\n     detectSuboptimalProcessing(os.path.join(path, \"OEBPS\", \"Images\"), source)\n-    chapterNames = sanitizeTree(os.path.join(path, 'OEBPS', 'Images'))\n+    chapterNames, cover_path = sanitizeTree(os.path.join(path, 'OEBPS', 'Images'))\n+    cover = image.Cover(cover_path, options)\n+\n     if options.webtoon:\n         y = image.ProfileData.Profiles[options.profile][1][1]\n         comic2panel.main(['-y ' + str(y), '-i', '-m', path], qtgui)\n@@ -1288,10 +1284,10 @@ def makeBook(source, qtgui=None):\n         else:\n             print(\"Creating EPUB file...\")\n             if len(tomes) > 1:\n-                buildEPUB(tome, chapterNames, tomeNumber, True)\n+                buildEPUB(tome, chapterNames, tomeNumber, True, cover)\n                 filepath.append(getOutputFilename(source, options.output, '.epub', ' ' + str(tomeNumber)))\n             else:\n-                buildEPUB(tome, chapterNames, tomeNumber, False)\n+                buildEPUB(tome, chapterNames, tomeNumber, False, cover)\n                 filepath.append(getOutputFilename(source, options.output, '.epub', ''))\n             makeZIP(tome + '_comic', tome, True)\n         copyfile(tome + '_comic.zip', filepath[-1])\ndiff --git a/kindlecomicconverter/image.py b/kindlecomicconverter/image.py\nindex f30fd006..e3763e7d 100755\n--- a/kindlecomicconverter/image.py\n+++ b/kindlecomicconverter/image.py\n@@ -414,14 +414,9 @@ def cropInterPanelEmptySections(self, direction):\n         self.image = crop_empty_inter_panel(self.image, direction, background_color=self.fill)\n \n class Cover:\n-    def __init__(self, source, target, opt, tomeid):\n+    def __init__(self, source, opt):\n         self.options = opt\n         self.source = source\n-        self.target = target\n-        if tomeid == 0:\n-            self.tomeid = 1\n-        else:\n-            self.tomeid = tomeid\n         self.image = Image.open(source)\n         # backwards compatibility for Pillow >9.1.0\n         if not hasattr(Image, 'Resampling'):\n@@ -433,6 +428,15 @@ def process(self):\n         self.image = ImageOps.autocontrast(self.image)\n         if not self.options.forcecolor:\n             self.image = self.image.convert('L')\n+        self.crop_main_cover()\n+\n+        size = list(self.options.profileData[1])\n+        if self.options.profile == 'KS':\n+            if 'MOBI' in self.options.format or 'EPUB' in self.options.format:\n+                size[1] = min(size[1], 1920)\n+        self.image.thumbnail(tuple(size), Image.Resampling.LANCZOS)\n+\n+    def crop_main_cover(self):\n         w, h = self.image.size\n         if w / h > 2:\n             if self.options.righttoleft:\n@@ -444,12 +448,14 @@ def process(self):\n                 self.image = self.image.crop((0, 0, w/2 - w * 0.03, h))\n             else:\n                 self.image = self.image.crop((w/2 + w * 0.03, 0, w, h))\n-        self.image.thumbnail(self.options.profileData[1], Image.Resampling.LANCZOS)\n-        self.save()\n \n-    def save(self):\n+    def save_to_epub(self, target, tomeid):\n+        if tomeid == 0:\n+            self.tomeid = 1\n+        else:\n+            self.tomeid = tomeid\n         try:\n-            self.image.save(self.target, \"JPEG\", optimize=1, quality=85)\n+            self.image.save(target, \"JPEG\", optimize=1, quality=85)\n         except IOError:\n             raise RuntimeError('Failed to save cover.')\n \n", "test_patch": "", "problem_statement": "[FEATURE REQUEST] : option to not crop the covers\nIt would be useful to add an option to exclude the covers from the cropping process, as they are most of the time artworks that people would most likely want to preserve.\r\n\nEPUB 200MB limit cover\nAdd an option to have the same cover on all the EPUBs.\n", "hints_text": "In the same idea, it would be nice to have the option to exclude the cover from all the processing. For example stretch/upscale can be desirable for all the pages, but not for the cover as it adds borders to it.\nI will work on this.\n\nI'm going to work on this. Might be generous and even add a counter to the cover image like 1/2 2/2 etc.\n\n", "all_hints_text": "In the same idea, it would be nice to have the option to exclude the cover from all the processing. For example stretch/upscale can be desirable for all the pages, but not for the cover as it adds borders to it.\nI will work on this.\n@projectorphones @atagulalan\n\nImplemented in above PR, test builds linked.\n\nI'm going to work on this. Might be generous and even add a counter to the cover image like 1/2 2/2 etc.\n@Felixer123456 I've implemented it in the above PR, test builds linked.\n@Felixer123456 Do you like how it adds tome count to the covers?\n\n", "commit_urls": ["https://github.com/ciromattia/kcc/commit/fd473169f4ec938b126073b447ecaa16cd7329d1", "https://github.com/ciromattia/kcc/commit/c7c8dd861ec23f3fb004192afc5c4ec47e16070b", "https://github.com/ciromattia/kcc/commit/14c21b7cb5592d119a6a5418be3fcab57889139e", "https://github.com/ciromattia/kcc/commit/1d443d5eae747eaa9e56c792842294311250b4bd", "https://github.com/ciromattia/kcc/commit/55479c6b22d55e9c269c135999edfa79308ef6f6", "https://github.com/ciromattia/kcc/commit/6ef4832785039fc44e1e53603697c20cc4371929", "https://github.com/ciromattia/kcc/commit/70e58dc56e0c208e0dfe89e9a1a9761d3c77203d"], "created_at": "2025-06-08T00:25:06Z"}
{"repo": "ciromattia/kcc", "pull_number": 1027, "instance_id": "ciromattia__kcc-1027", "issue_numbers": [771], "base_commit": "9c8a1759cfc8cb7e9402ed22f080fcd40a2a3ea1", "patch": "diff --git a/kindlecomicconverter/image.py b/kindlecomicconverter/image.py\nindex 73ee63a4..207123ef 100755\n--- a/kindlecomicconverter/image.py\n+++ b/kindlecomicconverter/image.py\n@@ -25,6 +25,8 @@\n from functools import cached_property\n import mozjpeg_lossless_optimization\n from PIL import Image, ImageOps, ImageStat, ImageChops, ImageFilter, ImageDraw\n+\n+from .rainbow_artifacts_eraser import erase_rainbow_artifacts\n from .page_number_crop_alg import get_bbox_crop_margin_page_number, get_bbox_crop_margin\n from .inter_panel_crop_alg import crop_empty_inter_panel\n \n@@ -368,12 +370,9 @@ def quantizeImage(self):\n         self.image = self.image.quantize(palette=palImg)\n \n     def optimizeForDisplay(self, reducerainbow):\n-        # Reduce rainbow artifacts for grayscale images by breaking up dither patterns that cause Moire interference with color filter array\n+        # Reduce rainbow artifacts for grayscale images by removing spectral frequencies that cause Moire interference with color filter array\n         if reducerainbow and not self.color:\n-            unsharpFilter = ImageFilter.UnsharpMask(radius=1, percent=100)\n-            self.image = self.image.filter(unsharpFilter)\n-            self.image = self.image.filter(ImageFilter.BoxBlur(1.0))\n-            self.image = self.image.filter(unsharpFilter)\n+            self.image = erase_rainbow_artifacts(self.image)\n \n     def resizeImage(self):\n         ratio_device = float(self.size[1]) / float(self.size[0])\ndiff --git a/kindlecomicconverter/rainbow_artifacts_eraser.py b/kindlecomicconverter/rainbow_artifacts_eraser.py\nnew file mode 100644\nindex 00000000..0814084e\n--- /dev/null\n+++ b/kindlecomicconverter/rainbow_artifacts_eraser.py\n@@ -0,0 +1,127 @@\n+import numpy as np\r\n+from PIL import Image\r\n+       \r\n+def fourier_transform_image(img):\r\n+    \"\"\"\r\n+    Memory-optimized version that modifies the array in place when possible.\r\n+    \"\"\"\r\n+    # Convert with minimal copy\r\n+    img_array = np.asarray(img, dtype=np.float32)\r\n+    \r\n+    # Use rfft2 if the image is real to save memory\r\n+    # and computation time (approximately 2x faster)\r\n+    fft_result = np.fft.rfft2(img_array)\r\n+    \r\n+    return fft_result\r\n+     \r\n+def attenuate_diagonal_frequencies(fft_spectrum, freq_threshold=0.30, target_angle=135, \r\n+                                     angle_tolerance=10, attenuation_factor=0.15):\r\n+    \"\"\"\r\n+    Attenuates specific frequencies in the Fourier domain (optimized version for rfft2).\r\n+    \r\n+    Args:\r\n+        fft_spectrum: Result of 2D real Fourier transform (from rfft2)\r\n+        freq_threshold: Frequency threshold in cycles/pixel (default: 0.3, theoretical max: 0.5)\r\n+        target_angle: Target angle in degrees (default: 135)\r\n+        angle_tolerance: Angular tolerance in degrees (default: 15)\r\n+        attenuation_factor: Attenuation factor (0.1 = 90% attenuation)\r\n+    \r\n+    Returns:\r\n+        np.ndarray: Modified FFT with applied attenuation (same format as input)\r\n+    \"\"\"\r\n+    \r\n+    # Get dimensions of the rfft2 result\r\n+    height, width_rfft = fft_spectrum.shape\r\n+    # For rfft2, the original width is (width_rfft - 1) * 2\r\n+    width_original = (width_rfft - 1) * 2\r\n+    \r\n+    # Create frequency grids for rfft2 format\r\n+    freq_y = np.fft.fftfreq(height, d=1.0)\r\n+    freq_x = np.fft.rfftfreq(width_original, d=1.0)  # Use rfftfreq for the X dimension\r\n+    \r\n+    # Use broadcasting to create grids without meshgrid (more efficient)\r\n+    freq_y_grid = freq_y.reshape(-1, 1)  # Column\r\n+    freq_x_grid = freq_x.reshape(1, -1)   # Row\r\n+    \r\n+    # Calculate squared radial frequencies (avoid sqrt)\r\n+    freq_radial_sq = freq_x_grid**2 + freq_y_grid**2\r\n+    freq_threshold_sq = freq_threshold**2\r\n+    \r\n+    # Frequency condition\r\n+    freq_condition = freq_radial_sq >= freq_threshold_sq\r\n+    \r\n+    # Early exit if no frequency satisfies the condition\r\n+    if not np.any(freq_condition):\r\n+        return fft_spectrum\r\n+    \r\n+    # Calculate angles only where necessary\r\n+    # Use atan2 directly with broadcasting\r\n+    angles_rad = np.arctan2(freq_y_grid, freq_x_grid)\r\n+    \r\n+    # Convert to degrees and normalize in a single operation\r\n+    angles_deg = np.rad2deg(angles_rad) % 360\r\n+    \r\n+    # Calculation of complementary angle\r\n+    target_angle_2 = (target_angle + 180) % 360\r\n+\r\n+    # Calulation of perpendicular angles (CFA is sometimes orientated at 135\u00b0, sometimes at 45\u00b0)\r\n+    target_angle_3 = (target_angle + 90) % 360\r\n+    target_angle_4 = (target_angle_3 + 180) % 360\r\n+    \r\n+    # Create angular conditions in a vectorized way\r\n+    angle_condition = np.zeros_like(angles_deg, dtype=bool)\r\n+    \r\n+    # Process both angles simultaneously\r\n+    for angle in [target_angle, target_angle_2, target_angle_3, target_angle_4]:\r\n+        min_angle = (angle - angle_tolerance) % 360\r\n+        max_angle = (angle + angle_tolerance) % 360\r\n+        \r\n+        if min_angle > max_angle:  # Interval crosses 0\u00b0\r\n+            angle_condition |= (angles_deg >= min_angle) | (angles_deg <= max_angle)\r\n+        else:  # Normal interval\r\n+            angle_condition |= (angles_deg >= min_angle) & (angles_deg <= max_angle)\r\n+    \r\n+    # Combine conditions\r\n+    combined_condition = freq_condition & angle_condition\r\n+    \r\n+    # Apply attenuation directly (avoid creating a full mask)\r\n+    if attenuation_factor == 0:\r\n+        # Special case: complete suppression\r\n+        fft_spectrum[combined_condition] = 0\r\n+        return fft_spectrum\r\n+    elif attenuation_factor == 1:\r\n+        # Special case: no attenuation\r\n+        return fft_spectrum\r\n+    else:\r\n+        # General case: partial attenuation\r\n+        fft_spectrum[combined_condition] *= attenuation_factor\r\n+        return fft_spectrum\r\n+    \r\n+def inverse_fourier_transform_image(fft_spectrum):\r\n+    \"\"\"\r\n+    Performs an optimized inverse Fourier transform to reconstruct a PIL image.\r\n+    \r\n+    Args:\r\n+        fft_spectrum: Fourier transform result (complex array from rfft2)\r\n+        original_shape: Original image shape (height, width) for proper cropping\r\n+    \r\n+    Returns:\r\n+        PIL.Image: Reconstructed image\r\n+    \"\"\"    \r\n+    # Perform inverse Fourier transform       \r\n+    img_reconstructed = np.fft.irfft2(fft_spectrum)\r\n+    \r\n+    # Normalize values between 0 and 255\r\n+    img_reconstructed = np.clip(img_reconstructed, 0, 255)\r\n+    img_reconstructed = img_reconstructed.astype(np.uint8)\r\n+    \r\n+    # Convert to PIL image\r\n+    pil_image = Image.fromarray(img_reconstructed, mode='L')\r\n+    \r\n+    return pil_image\r\n+    \r\n+def erase_rainbow_artifacts(img):\r\n+    fft_spectrum = fourier_transform_image(img)\r\n+    clean_spectrum = attenuate_diagonal_frequencies(fft_spectrum)    \r\n+    clean_image = inverse_fourier_transform_image(clean_spectrum)\r\n+    return clean_image\r\n", "test_patch": "", "problem_statement": "Rainbow effect on grays on Kindle Colorsoft after converting with KCC\nI've noticed that some grays have a rainbow effect on the Kindle Colorsoft. This doesn't ruin the experience, but it can be distracting.\n\nI compared the same frame to a version from Amazon's official release and the rainbow effect on the Amazon version isn't as prominent. This issue happens with all compression settings (JPEG/PNG/mozJpeg)\n\nIs there something wrong with my settings, or is this caused by something in the conversion process?\n\n| KCC version      | Amazon version |\n| ----------- | ----------- |\n| ![IMG_8841](https://github.com/user-attachments/assets/c607c818-1a6b-4441-8cf4-25328f3f6718)      | ![IMG_8843](https://github.com/user-attachments/assets/db0d84d4-0682-442f-9489-f3dd6b0647c5)       |\n\n\n\n\nPictures taken with iPhone 16 Pro.\n\nThanks again.\n", "hints_text": "It's pretty much a property of color eink. \n\n- https://github.com/koreader/koreader/issues/11877\n\nInteresting solutions discussed their. Blurring the image, using a profile with a smaller resolution, etc. I wonder if pw11 or scribe profile fixes it. @oncpnda \n\nMaybe png would help? But png has a bug where it converts really slow rn. \n\n- #533\nIt is not a bug but another kindlegen limitation. If image file is too big or use format not supported by it then it is converted again and in general break everything KCC do.\r\n\r\nThere are good reasons why JPEG is default output. Every time when kindlegen is working too long on EPUB created by KCC mean that input was faulty.\n@utopiafallen looks like koreader from above post found a solution better than blurring using Fourier transform in case you are interested \n> [@utopiafallen](https://github.com/utopiafallen) looks like koreader from above post found a solution better than blurring using Fourier transform in case you are interested\n\nHi, thanks for quoting my work :).\n\nSadly I do not have the knowledge nor the time to port my C code to python, but I'm sure it is doable with pyFFTW.\nI prefer an \"on-the-fly\" fix for the rainbow effect but for those who don't use Koreader and prefer fixing it when converting through KCC, this could be a starting point: https://github.com/Its-my-right/pocketbook_cfa_interference_breaker\n@axu2 Transforming into frequency domain and removing peaks would be low-pass filtering, and in the spatial domain, that would be a blur. The referenced method is equivalent to blurring the whole image in a way that reduces global and local contrast (the Pantheon article eliminates the peaks along the center horizontal and vertical axis which correspond to average image contrast in the horizontal and vertical axes), and you can see commenters explicitly having to fix that global contrast reduction by \u201cre-normalizing\u201d the resulting image.\n\nAll of this strikes me as a bit odd because the proposed solution to avoid blurring the image is\u2026.to the blur the image. If someone wants to implement this alternative blur, have at it, but I\u2019d rather not pay the extra processing time in KCC that I already spent a significant effort in improving \ud83d\ude02\n> [@axu2](https://github.com/axu2) Transforming into frequency domain and removing peaks would be low-pass filtering, and in the spatial domain, that would be a blur. The referenced method is equivalent to blurring the whole image in a way that reduces global and local contrast (the Pantheon article eliminates the peaks along the center horizontal and vertical axis which correspond to average image contrast in the horizontal and vertical axes), and you can see commenters explicitly having to fix that global contrast reduction by \u201cre-normalizing\u201d the resulting image.\n> \n> All of this strikes me as a bit odd because the proposed solution to avoid blurring the image is\u2026.to the blur the image. If someone wants to implement this alternative blur, have at it, but I\u2019d rather not pay the extra processing time in KCC that I already spent a significant effort in improving \ud83d\ude02\n\nPlease see for yourself:\n\n**Vanilla Picture**\n![Image](https://github.com/user-attachments/assets/75535f9d-94c4-47bc-9638-2eeb27d0bebc)\n\n**KCC 7.6.0 Blurred picture:**\n![Image](https://github.com/user-attachments/assets/41adf283-d1fe-4aed-8adb-fe55efe4937d)\n\n**Fourier Picture:**\n![Image](https://github.com/user-attachments/assets/9caf5d7e-23a2-4ac3-90d9-0b1f7c142f0c)\n\nBoth methods involve some form of blur, yes.\n\nBut the drawings and text are sharper with the Fourier transform method.\nFurthermore, in this example, the settings are particularly aggressive (pushed to cover more than just rainbow effect removal: they also include the \"smoothing\" of certain patterns). With settings limited to rainbow effect removal, the image would have a sharpness closer to the original image.\n\nI completely understand that you don't want to rewrite a feature that you consider sufficient as it stands. I myself don't really have the time or the expertise to contribute to an open-source project.\nBut I wanted to share my work here because I thought it might be of interest to some users bothered by blur.\n\nHowever, I remain convinced that \"fixing\" the rainbow effect by altering the image isn't the best option: source images shouldn't suffer a loss of quality just to compensate for a hardware problem due to the screen. I prefer the on-the-fly patch method that doesn't alter the original images, which is why I also presented this work on the koreader GitHub. But I imagine that some users use their e-reader's internal reader and not koreader, and for them, altering the source images is the only option.\nAt the risk of overfitting for a specific test case, you can more or less recreate the Fourier transform results by tweaking the parameters currently used by KCC to apply the rainbow reduction:\n``` python\ndef optimizeForDisplay(self):\n        # Reduce rainbow artifacts for grayscale images by breaking up dither patterns that cause Moire interference with color filter array\n        if (self.opt.displayType == DisplayType.KALEIDO3_COLOR and not self.color):\n            unsharpFilter = ImageFilter.UnsharpMask(radius=1, percent=25)\n            self.image = self.image.filter(unsharpFilter)\n            self.image = self.image.filter(ImageFilter.BoxBlur(0.25))\n            self.image = self.image.filter(unsharpFilter)\n````\nAnd here is the result:\n![Image](https://github.com/user-attachments/assets/b487910c-e625-49f8-bb51-e6f23f4895d5)\n(I disabled resizing and auto-contrast in KCC since that makes the visual comparison more difficult.)\n\nAs a bonus, this avoids some of the aliasing artifacts introduced by the Fourier transform (you can see it as noise inside the white text) that I'm guessing is happening because globally rejecting frequency peaks means that some signals will be undersampled and can't be correctly represented anymore when transformed back (e.g. clean vertical and horizontal edges). This aliasing noise still ends up being aesthetically pleasing because it's perceived as detail, similar to film grain, which also enhances the perception of sharpness. \n\nAnyway, this was mostly an academic exercise to prove to myself my own intuition that there isn't something inherently unique to blurring in the frequency domain that couldn't be represented in the spatial domain. I'm happy there are multiple solutions out there for hiding the rainbow artifacts on these Kaleido 3 screens.\n> At the risk of overfitting for a specific test case, you can more or less recreate the Fourier transform results by tweaking the parameters currently used by KCC to apply the rainbow reduction:\n> \n> def optimizeForDisplay(self):\n>         # Reduce rainbow artifacts for grayscale images by breaking up dither patterns that cause Moire interference with color filter array\n>         if (self.opt.displayType == DisplayType.KALEIDO3_COLOR and not self.color):\n>             unsharpFilter = ImageFilter.UnsharpMask(radius=1, percent=25)\n>             self.image = self.image.filter(unsharpFilter)\n>             self.image = self.image.filter(ImageFilter.BoxBlur(0.25))\n>             self.image = self.image.filter(unsharpFilter)\n> And here is the result: ![Image](https://github.com/user-attachments/assets/b487910c-e625-49f8-bb51-e6f23f4895d5) (I disabled resizing and auto-contrast in KCC since that makes the visual comparison more difficult.)\n> \n> As a bonus, this avoids some of the aliasing artifacts introduced by the Fourier transform (you can see it as noise inside the white text) that I'm guessing is happening because globally rejecting frequency peaks means that some signals will be undersampled and can't be correctly represented anymore when transformed back (e.g. clean vertical and horizontal edges). This aliasing noise still ends up being aesthetically pleasing because it's perceived as detail, similar to film grain, which also enhances the perception of sharpness.\n> \n> Anyway, this was mostly an academic exercise to prove to myself my own intuition that there isn't something inherently unique to blurring in the frequency domain that couldn't be represented in the spatial domain. I'm happy there are multiple solutions out there for hiding the rainbow artifacts on these Kaleido 3 screens.\n\nWhich color e-reader do you have? And have you tried displaying your latest image on it?\nBecause when I display that image on my InkPad Color 3, which has the same resolution as the image, the rainbow effect is still visible (less than in the original image, of course, but still distracting).\n\nRegarding the comparison of methods, you're right when you say that everything that can be done in the frequency domain can also be done in the spatial domain.\nThis is mathematically true according to the convolution theorem.\n\nHowever, for this specific use case, since the interferences causing the rainbow effect appear as localized peaks in the Fourier domain, acting precisely on those peaks is a more \"surgical\" and less \"global\" way to remove the root cause\u2014and only that.\nIn theory, this makes it possible to eliminate only the unwanted frequencies while preserving the rest of the image.\nIt's easier to isolate frequency peaks in the frequency domain than in the spatial domain.\n\nThat said, my localized frequency suppression algorithm is far from optimal and could be significantly improved.\nIt works in its current state and produces results that I find very satisfying, but there is still plenty of room for improvement.\n\nThanks to our exchanges, I\u2019ve decided to modify my frequency suppression algorithm to specifically match the spatial frequency of the Kaleido 3 CFA.\nSince this frequency may vary slightly from one unit to another, it will require a preliminary test: displaying calibration patterns tuned to different frequencies to determine at which cycles-per-pixel value the patterns cause rainbow artifacts.\nThat value could then be entered as a parameter in the algorithm, which will then target that specific frequency range for attenuation, instead of simply removing all frequency \"peaks\".\nThe result should be precise and tailored to each individual screen\u2014suppressing only the problematic parts specific to that display while keeping the rest of the image untouched.\n\nI'm also glad that there are several ways to tackle this problem.\nI always find it cool when users work to fix issues that manufacturers haven\u2019t managed to solve.\nI hope someone will eventually find an even better way to eliminate the rainbow effect\u2014whether in the spatial or frequency domain :)\nJust to jump in with my own anecdote: I implemented the modified `optimizeForDisplay` function and while there was still some rainbow effect on grays when viewed on my Colorsoft, compared to the function that ships in the compiled version it was a much better compromise in regards to how blurry the text gets. Thank you @utopiafallen.\nSure, happy to help! And I would suggest keep playing with different strengths for the\nunsharp mask and different radius value for the box blur since you're still\ngetting the rainbow artifacts. I suspect that the box blur radius probably\nneeds to go up to 0.5 or 0.75, in which case you'll want to make the second\nunsharp stronger to restore some of the sharpness.\n\nOn Tue, Jul 1, 2025 at 4:59\u202fPM Michael Gardiner ***@***.***>\nwrote:\n\n> *gardinermichael* left a comment (ciromattia/kcc#771)\n> <https://github.com/ciromattia/kcc/issues/771#issuecomment-3025878271>\n>\n> Just to jump in with my own anecdote: I implemented the modified\n> optimizeForDisplay function and while there was still some rainbow effect\n> on grays when viewed on my Colorsoft, compared to the function that ships\n> in compiled version it was a much better compromise in regards to how\n> blurry the text gets. Thank you @utopiafallen\n> <https://github.com/utopiafallen>.\n>\n> \u2014\n> Reply to this email directly, view it on GitHub\n> <https://github.com/ciromattia/kcc/issues/771#issuecomment-3025878271>,\n> or unsubscribe\n> <https://github.com/notifications/unsubscribe-auth/ABOT7JKOASIKZDRAABT46UT3GMOHPAVCNFSM6AAAAABRFTJBPSVHI2DSMVQWIX3LMV43OSLTON2WKQ3PNVWWK3TUHMZTAMRVHA3TQMRXGE>\n> .\n> You are receiving this because you were mentioned.Message ID:\n> ***@***.***>\n>\n\nOK, I've finished refining my rainbow effect frequency removal algorithm!\nBy displaying many different patterns on Kaleido 3, it appears that the CFA is oriented at approximately 135\u00b0 and that several frequencies, particularly around 0.16, 0.32, and 0.40->0.50 cycles/pixel, interfere with the CFA, creating rainbow effect artifacts.\n\nRather than removing high frequencies in all directions, I modified the algorithm to strongly attenuate the magnitude of key frequencies (within a tolerance interval), oriented around 135\u00b0 (also within a tolerance interval), leaving all other frequencies/directions untouched.\n\nThe result is images without rainbow artifacts, and with much better sharpness than in my first version.\n\nAdditionally, I've also adapted my code so that it no longer reconstructs the Hermitian symmetry of the spectrum after the FFT, which improves processing time to around 300 ms :)\n\nHere's the result for the same image after applying this new method:\n\n<img width=\"1404\" height=\"1872\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/251d8ce6-0e2a-4d59-939f-07101e6ad137\" />\nAwesome, now that actually sounds like an improvement over a global blur!\r\n\r\nOn Sun, Jul 6, 2025, 2:17\u202fAM Its-my-right ***@***.***> wrote:\r\n\r\n> *Its-my-right* left a comment (ciromattia/kcc#771)\r\n> <https://github.com/ciromattia/kcc/issues/771#issuecomment-3041236260>\r\n>\r\n> OK, I've finished refining my rainbow effect frequency removal algorithm!\r\n> By displaying many different patterns on Kaleido 3, it appears that the\r\n> CFA is oriented at approximately 135\u00b0 and that several frequencies,\r\n> particularly around 0.16, 0.32, and 0.40->0.50 cycles/pixel, interfere with\r\n> the CFA, creating rainbow effect artifacts.\r\n>\r\n> Rather than removing high frequencies in all directions, I modified the\r\n> algorithm to strongly attenuate the magnitude of key frequencies (within a\r\n> tolerance interval), oriented around 135\u00b0 (also within a tolerance\r\n> interval).\r\n>\r\n> The result is images without rainbow artifacts, and with much better\r\n> sharpness than in my first version.\r\n>\r\n> Additionally, I've also adapted my code so that it no longer reconstructs\r\n> the Hermitian symmetry of the spectrum after the FFT, which improves\r\n> processing time to around 300 ms :)\r\n>\r\n> Here's the result for the same image after applying this new method:\r\n> 04.-.fourier_new_2.png (view on web)\r\n> <https://github.com/user-attachments/assets/251d8ce6-0e2a-4d59-939f-07101e6ad137>\r\n>\r\n> \u2014\r\n> Reply to this email directly, view it on GitHub\r\n> <https://github.com/ciromattia/kcc/issues/771#issuecomment-3041236260>,\r\n> or unsubscribe\r\n> <https://github.com/notifications/unsubscribe-auth/ABOT7JPDGMMSLHZ5ZRP3UYD3HDSSFAVCNFSM6AAAAABRFTJBPSVHI2DSMVQWIX3LMV43OSLTON2WKQ3PNVWWK3TUHMZTANBRGIZTMMRWGA>\r\n> .\r\n> You are receiving this because you were mentioned.Message ID:\r\n> ***@***.***>\r\n>\r\n\n\n", "all_hints_text": "You may want to bring this up in a forum where more people can comment like MobileRead or Reddit since I don't have a CS12.\r\n\r\nBut it could be anything. Color eink has limitations with grayscales and screentones.\r\n\r\nI've also heard that kindle cs12 has different color modes like \"vivid\" that I'm unsure are available for mobi manga. Amazon manga is KFX.\nwhat does it look like if you deactivate color mode in the kcc settings?\nEven with color mode deactivated, the grays have the rainbow effect. It is possibly just a limitation of the CS? Maybe I got one of the bad ones...\n@oncpnda is there a rendering mode toggle for vivid mode anywhere in the menu or Aa menu or control center via swipe from top of screen in book?\n\nRainbow sheen happens since color eink is just a normal bw panel behind a bunch of small red/blue/green stickers. \nYes, I forgot to mention in the initial post that it happens with both vivid and standard mode on low and high brightness.\nIt's pretty much a property of color eink. \n\n- https://github.com/koreader/koreader/issues/11877\n\nInteresting solutions discussed their. Blurring the image, using a profile with a smaller resolution, etc. I wonder if pw11 or scribe profile fixes it. @oncpnda \n\nMaybe png would help? But png has a bug where it converts really slow rn. \n\n- #533\nIt is not a bug but another kindlegen limitation. If image file is too big or use format not supported by it then it is converted again and in general break everything KCC do.\r\n\r\nThere are good reasons why JPEG is default output. Every time when kindlegen is working too long on EPUB created by KCC mean that input was faulty.\n@utopiafallen looks like koreader from above post found a solution better than blurring using Fourier transform in case you are interested \n> [@utopiafallen](https://github.com/utopiafallen) looks like koreader from above post found a solution better than blurring using Fourier transform in case you are interested\n\nHi, thanks for quoting my work :).\n\nSadly I do not have the knowledge nor the time to port my C code to python, but I'm sure it is doable with pyFFTW.\nI prefer an \"on-the-fly\" fix for the rainbow effect but for those who don't use Koreader and prefer fixing it when converting through KCC, this could be a starting point: https://github.com/Its-my-right/pocketbook_cfa_interference_breaker\n@axu2 Transforming into frequency domain and removing peaks would be low-pass filtering, and in the spatial domain, that would be a blur. The referenced method is equivalent to blurring the whole image in a way that reduces global and local contrast (the Pantheon article eliminates the peaks along the center horizontal and vertical axis which correspond to average image contrast in the horizontal and vertical axes), and you can see commenters explicitly having to fix that global contrast reduction by \u201cre-normalizing\u201d the resulting image.\n\nAll of this strikes me as a bit odd because the proposed solution to avoid blurring the image is\u2026.to the blur the image. If someone wants to implement this alternative blur, have at it, but I\u2019d rather not pay the extra processing time in KCC that I already spent a significant effort in improving \ud83d\ude02\n> [@axu2](https://github.com/axu2) Transforming into frequency domain and removing peaks would be low-pass filtering, and in the spatial domain, that would be a blur. The referenced method is equivalent to blurring the whole image in a way that reduces global and local contrast (the Pantheon article eliminates the peaks along the center horizontal and vertical axis which correspond to average image contrast in the horizontal and vertical axes), and you can see commenters explicitly having to fix that global contrast reduction by \u201cre-normalizing\u201d the resulting image.\n> \n> All of this strikes me as a bit odd because the proposed solution to avoid blurring the image is\u2026.to the blur the image. If someone wants to implement this alternative blur, have at it, but I\u2019d rather not pay the extra processing time in KCC that I already spent a significant effort in improving \ud83d\ude02\n\nPlease see for yourself:\n\n**Vanilla Picture**\n![Image](https://github.com/user-attachments/assets/75535f9d-94c4-47bc-9638-2eeb27d0bebc)\n\n**KCC 7.6.0 Blurred picture:**\n![Image](https://github.com/user-attachments/assets/41adf283-d1fe-4aed-8adb-fe55efe4937d)\n\n**Fourier Picture:**\n![Image](https://github.com/user-attachments/assets/9caf5d7e-23a2-4ac3-90d9-0b1f7c142f0c)\n\nBoth methods involve some form of blur, yes.\n\nBut the drawings and text are sharper with the Fourier transform method.\nFurthermore, in this example, the settings are particularly aggressive (pushed to cover more than just rainbow effect removal: they also include the \"smoothing\" of certain patterns). With settings limited to rainbow effect removal, the image would have a sharpness closer to the original image.\n\nI completely understand that you don't want to rewrite a feature that you consider sufficient as it stands. I myself don't really have the time or the expertise to contribute to an open-source project.\nBut I wanted to share my work here because I thought it might be of interest to some users bothered by blur.\n\nHowever, I remain convinced that \"fixing\" the rainbow effect by altering the image isn't the best option: source images shouldn't suffer a loss of quality just to compensate for a hardware problem due to the screen. I prefer the on-the-fly patch method that doesn't alter the original images, which is why I also presented this work on the koreader GitHub. But I imagine that some users use their e-reader's internal reader and not koreader, and for them, altering the source images is the only option.\nAt the risk of overfitting for a specific test case, you can more or less recreate the Fourier transform results by tweaking the parameters currently used by KCC to apply the rainbow reduction:\n``` python\ndef optimizeForDisplay(self):\n        # Reduce rainbow artifacts for grayscale images by breaking up dither patterns that cause Moire interference with color filter array\n        if (self.opt.displayType == DisplayType.KALEIDO3_COLOR and not self.color):\n            unsharpFilter = ImageFilter.UnsharpMask(radius=1, percent=25)\n            self.image = self.image.filter(unsharpFilter)\n            self.image = self.image.filter(ImageFilter.BoxBlur(0.25))\n            self.image = self.image.filter(unsharpFilter)\n````\nAnd here is the result:\n![Image](https://github.com/user-attachments/assets/b487910c-e625-49f8-bb51-e6f23f4895d5)\n(I disabled resizing and auto-contrast in KCC since that makes the visual comparison more difficult.)\n\nAs a bonus, this avoids some of the aliasing artifacts introduced by the Fourier transform (you can see it as noise inside the white text) that I'm guessing is happening because globally rejecting frequency peaks means that some signals will be undersampled and can't be correctly represented anymore when transformed back (e.g. clean vertical and horizontal edges). This aliasing noise still ends up being aesthetically pleasing because it's perceived as detail, similar to film grain, which also enhances the perception of sharpness. \n\nAnyway, this was mostly an academic exercise to prove to myself my own intuition that there isn't something inherently unique to blurring in the frequency domain that couldn't be represented in the spatial domain. I'm happy there are multiple solutions out there for hiding the rainbow artifacts on these Kaleido 3 screens.\n> At the risk of overfitting for a specific test case, you can more or less recreate the Fourier transform results by tweaking the parameters currently used by KCC to apply the rainbow reduction:\n> \n> def optimizeForDisplay(self):\n>         # Reduce rainbow artifacts for grayscale images by breaking up dither patterns that cause Moire interference with color filter array\n>         if (self.opt.displayType == DisplayType.KALEIDO3_COLOR and not self.color):\n>             unsharpFilter = ImageFilter.UnsharpMask(radius=1, percent=25)\n>             self.image = self.image.filter(unsharpFilter)\n>             self.image = self.image.filter(ImageFilter.BoxBlur(0.25))\n>             self.image = self.image.filter(unsharpFilter)\n> And here is the result: ![Image](https://github.com/user-attachments/assets/b487910c-e625-49f8-bb51-e6f23f4895d5) (I disabled resizing and auto-contrast in KCC since that makes the visual comparison more difficult.)\n> \n> As a bonus, this avoids some of the aliasing artifacts introduced by the Fourier transform (you can see it as noise inside the white text) that I'm guessing is happening because globally rejecting frequency peaks means that some signals will be undersampled and can't be correctly represented anymore when transformed back (e.g. clean vertical and horizontal edges). This aliasing noise still ends up being aesthetically pleasing because it's perceived as detail, similar to film grain, which also enhances the perception of sharpness.\n> \n> Anyway, this was mostly an academic exercise to prove to myself my own intuition that there isn't something inherently unique to blurring in the frequency domain that couldn't be represented in the spatial domain. I'm happy there are multiple solutions out there for hiding the rainbow artifacts on these Kaleido 3 screens.\n\nWhich color e-reader do you have? And have you tried displaying your latest image on it?\nBecause when I display that image on my InkPad Color 3, which has the same resolution as the image, the rainbow effect is still visible (less than in the original image, of course, but still distracting).\n\nRegarding the comparison of methods, you're right when you say that everything that can be done in the frequency domain can also be done in the spatial domain.\nThis is mathematically true according to the convolution theorem.\n\nHowever, for this specific use case, since the interferences causing the rainbow effect appear as localized peaks in the Fourier domain, acting precisely on those peaks is a more \"surgical\" and less \"global\" way to remove the root cause\u2014and only that.\nIn theory, this makes it possible to eliminate only the unwanted frequencies while preserving the rest of the image.\nIt's easier to isolate frequency peaks in the frequency domain than in the spatial domain.\n\nThat said, my localized frequency suppression algorithm is far from optimal and could be significantly improved.\nIt works in its current state and produces results that I find very satisfying, but there is still plenty of room for improvement.\n\nThanks to our exchanges, I\u2019ve decided to modify my frequency suppression algorithm to specifically match the spatial frequency of the Kaleido 3 CFA.\nSince this frequency may vary slightly from one unit to another, it will require a preliminary test: displaying calibration patterns tuned to different frequencies to determine at which cycles-per-pixel value the patterns cause rainbow artifacts.\nThat value could then be entered as a parameter in the algorithm, which will then target that specific frequency range for attenuation, instead of simply removing all frequency \"peaks\".\nThe result should be precise and tailored to each individual screen\u2014suppressing only the problematic parts specific to that display while keeping the rest of the image untouched.\n\nI'm also glad that there are several ways to tackle this problem.\nI always find it cool when users work to fix issues that manufacturers haven\u2019t managed to solve.\nI hope someone will eventually find an even better way to eliminate the rainbow effect\u2014whether in the spatial or frequency domain :)\nJust to jump in with my own anecdote: I implemented the modified `optimizeForDisplay` function and while there was still some rainbow effect on grays when viewed on my Colorsoft, compared to the function that ships in the compiled version it was a much better compromise in regards to how blurry the text gets. Thank you @utopiafallen.\nSure, happy to help! And I would suggest keep playing with different strengths for the\nunsharp mask and different radius value for the box blur since you're still\ngetting the rainbow artifacts. I suspect that the box blur radius probably\nneeds to go up to 0.5 or 0.75, in which case you'll want to make the second\nunsharp stronger to restore some of the sharpness.\n\nOn Tue, Jul 1, 2025 at 4:59\u202fPM Michael Gardiner ***@***.***>\nwrote:\n\n> *gardinermichael* left a comment (ciromattia/kcc#771)\n> <https://github.com/ciromattia/kcc/issues/771#issuecomment-3025878271>\n>\n> Just to jump in with my own anecdote: I implemented the modified\n> optimizeForDisplay function and while there was still some rainbow effect\n> on grays when viewed on my Colorsoft, compared to the function that ships\n> in compiled version it was a much better compromise in regards to how\n> blurry the text gets. Thank you @utopiafallen\n> <https://github.com/utopiafallen>.\n>\n> \u2014\n> Reply to this email directly, view it on GitHub\n> <https://github.com/ciromattia/kcc/issues/771#issuecomment-3025878271>,\n> or unsubscribe\n> <https://github.com/notifications/unsubscribe-auth/ABOT7JKOASIKZDRAABT46UT3GMOHPAVCNFSM6AAAAABRFTJBPSVHI2DSMVQWIX3LMV43OSLTON2WKQ3PNVWWK3TUHMZTAMRVHA3TQMRXGE>\n> .\n> You are receiving this because you were mentioned.Message ID:\n> ***@***.***>\n>\n\nOK, I've finished refining my rainbow effect frequency removal algorithm!\nBy displaying many different patterns on Kaleido 3, it appears that the CFA is oriented at approximately 135\u00b0 and that several frequencies, particularly around 0.16, 0.32, and 0.40->0.50 cycles/pixel, interfere with the CFA, creating rainbow effect artifacts.\n\nRather than removing high frequencies in all directions, I modified the algorithm to strongly attenuate the magnitude of key frequencies (within a tolerance interval), oriented around 135\u00b0 (also within a tolerance interval), leaving all other frequencies/directions untouched.\n\nThe result is images without rainbow artifacts, and with much better sharpness than in my first version.\n\nAdditionally, I've also adapted my code so that it no longer reconstructs the Hermitian symmetry of the spectrum after the FFT, which improves processing time to around 300 ms :)\n\nHere's the result for the same image after applying this new method:\n\n<img width=\"1404\" height=\"1872\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/251d8ce6-0e2a-4d59-939f-07101e6ad137\" />\nAwesome, now that actually sounds like an improvement over a global blur!\r\n\r\nOn Sun, Jul 6, 2025, 2:17\u202fAM Its-my-right ***@***.***> wrote:\r\n\r\n> *Its-my-right* left a comment (ciromattia/kcc#771)\r\n> <https://github.com/ciromattia/kcc/issues/771#issuecomment-3041236260>\r\n>\r\n> OK, I've finished refining my rainbow effect frequency removal algorithm!\r\n> By displaying many different patterns on Kaleido 3, it appears that the\r\n> CFA is oriented at approximately 135\u00b0 and that several frequencies,\r\n> particularly around 0.16, 0.32, and 0.40->0.50 cycles/pixel, interfere with\r\n> the CFA, creating rainbow effect artifacts.\r\n>\r\n> Rather than removing high frequencies in all directions, I modified the\r\n> algorithm to strongly attenuate the magnitude of key frequencies (within a\r\n> tolerance interval), oriented around 135\u00b0 (also within a tolerance\r\n> interval).\r\n>\r\n> The result is images without rainbow artifacts, and with much better\r\n> sharpness than in my first version.\r\n>\r\n> Additionally, I've also adapted my code so that it no longer reconstructs\r\n> the Hermitian symmetry of the spectrum after the FFT, which improves\r\n> processing time to around 300 ms :)\r\n>\r\n> Here's the result for the same image after applying this new method:\r\n> 04.-.fourier_new_2.png (view on web)\r\n> <https://github.com/user-attachments/assets/251d8ce6-0e2a-4d59-939f-07101e6ad137>\r\n>\r\n> \u2014\r\n> Reply to this email directly, view it on GitHub\r\n> <https://github.com/ciromattia/kcc/issues/771#issuecomment-3041236260>,\r\n> or unsubscribe\r\n> <https://github.com/notifications/unsubscribe-auth/ABOT7JPDGMMSLHZ5ZRP3UYD3HDSSFAVCNFSM6AAAAABRFTJBPSVHI2DSMVQWIX3LMV43OSLTON2WKQ3PNVWWK3TUHMZTANBRGIZTMMRWGA>\r\n> .\r\n> You are receiving this because you were mentioned.Message ID:\r\n> ***@***.***>\r\n>\r\n\nI made my first ever pull request, covering this :) https://github.com/ciromattia/kcc/pull/1027\n@Its-my-right now that's cool. Btw, is this algorithm modifiable to handle normal b/w moire on bw eink?\n> [@Its-my-right](https://github.com/Its-my-right) now that's cool. Btw, is this algorithm modifiable to handle normal b/w moire on bw eink?\n\nI think it could be.\nFor B/W moir\u00e9 the solution would probably be to attenuate high frequencies as well (>= 0.3 cycles/pixel).\nFor the rainbow effect, targeting high frequencies in the 135\u00b0 direction (with a margin) is effective because the CFA is oriented at 135\u00b0 on Kaleido 3.\nNow for the B/W moir\u00e9, we would need to check if it occurs more often in particular directions (I don't know manga tones well) and target those directions. If no particular direction is identifiable, we can still attenuate high frequencies in all directions, but this would be roughly equivalent to utopiafallen's solution (with a slightly longer processing time).\nJust in case it's useful, I found this paper on moire reduction: \n\nhttp://hdl.handle.net/10919/30304\n\nI may need to open a new issue since b/w moire is separate but related issue.\n\nI think the important part is:\n\n> Chapter 9 Prevention of Moire Patterns When Sampling a Halftone\n\n>  An aliasing moire pattern in a sampled halftone image is due to insu\ufb03cient low-pass\nfiltering prior to sampling. If we can perform proper low-pass filtering, we can prevent\naliasing moire altogether.\n\n> The partial inverse Fourier transform method converts an image of M \u00d7N pixels to a\nlower resolution image of m\u00d7n pixels, m\u2264M, n\u2264N.\n\n> By inverse transforming only the center portion of the Fourier transform of the input image,\na uniform subsampling preceded by an ideal low-pass filtering is implicitly performed on the\ninput image. No aliasing occurs in the output image.\n\n> Just in case it's useful, I found this paper on moire reduction:\n> \n> http://hdl.handle.net/10919/30304\n> \n> I may need to open a new issue since b/w moire is separate but related issue.\n> \n> I think the important part is:\n> \n> > Chapter 9 Prevention of Moire Patterns When Sampling a Halftone\n> \n> > An aliasing moire pattern in a sampled halftone image is due to insu\ufb03cient low-pass\n> > filtering prior to sampling. If we can perform proper low-pass filtering, we can prevent\n> > aliasing moire altogether.\n> \n> > The partial inverse Fourier transform method converts an image of M \u00d7N pixels to a\n> > lower resolution image of m\u00d7n pixels, m\u2264M, n\u2264N.\n> \n> > By inverse transforming only the center portion of the Fourier transform of the input image,\n> > a uniform subsampling preceded by an ideal low-pass filtering is implicitly performed on the\n> > input image. No aliasing occurs in the output image.\n\nThat seems to be indeed an (old but) interesting source.\nAs you said I think moire pattern reduction is indeed a related but distinct issue.\nDo you have source files and pictures of how they display on a reader ? I may dig into this sometime, could be a good starting point\nI am looking for volunteers to test the new rainbow effect removing algorithm on their e-reader.\n\nI have noticed at least two different CFA orientations on two e-reader models (135\u00b0 on Pocketbook Inkpad Color 3 with Kaleido 3 7.8\" screen and 45\u00b0 on Kobo Libra Color with Kaleido 3 7\" screen).\n\nThe idea is to gather data to determine the precise CFA orientation depending on the e-reader model (it is possible that all Kaleido 3 of the same size have the same CFA orientation because they are all produced by the same company, but production methods may have changed over time or according to which e-reader manufacturers it goes).\n\nThis would then make the algorithm more accurate.\n\nTwo test builds are available in my repo:\n\n(Edited - axu2)\nhttps://github.com/axu2/kcc/releases/tag/v8.0.4-major\nhttps://github.com/axu2/kcc/releases/tag/v8.0.4-minor\n\n**Testing is simple:** Choose a manga that displays a rainbow effect on your e-reader after being converted with KCC, and convert it with the 8.0.4+ build.\nIf the converted manga still displays a rainbow effect on your e-reader, follow the same process but with the 8.0.4+**b** build.\n\n**Then, please just share your results here:**\n- Which of the two builds removes the rainbow effect (don't bother the angle thing, the name of the build 8.0.4+ / 8.0.4+**b** is enough ;))\n- Which e-reader you tested this on\n\n\nThank you!\n> I am looking for volunteers to test the new rainbow effect removing algorithm on their e-reader.\n>\n> Then, please share your results here:\n> - Which of the two builds removes the rainbow effect\n> - Your e-reader's reference\n> \n> Thank you!\n\nI would be happy to help with a Kindle Colorsoft, but how I would be able to find the CFA degree/reference?\n\n\nYou just tell us which build fixes the problem and that will tell us the angle. @gardinermichael \n\nI think by reference he just means tell us which device model you have.\nYeah sorry my English is rusty ! I updated my comment, it should be clearer\nTurns out those test builds don't run, I rebuilt them with fixed imports\n\nhttps://github.com/axu2/kcc/releases/tag/v8.0.4-major\nhttps://github.com/axu2/kcc/releases/tag/v8.0.4-minor\nDisabled:\n<img width=\"818\" height=\"695\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/372f09f7-7b22-4f77-b679-cc1dec30a79a\" />\nNew method:\n<img width=\"888\" height=\"669\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/1e48d246-6e1f-478e-9b1f-9451355885a5\" />\nOld method:\n<img width=\"896\" height=\"691\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/48bae8e7-8093-44cb-996d-f64d6c23c569\" />\n**Kindle Colorsoft running 5.18.3**\n\nNo Rainbow Blur\n![image](https://github.com/user-attachments/assets/100b75df-23a2-415e-afb5-ef427c9a047a)\n\n\nOld Rainbow Blur\n![image](https://github.com/user-attachments/assets/32d67b40-8486-44dd-a9e0-222cb1aa77dd)\n\nMajor\n![image](https://github.com/user-attachments/assets/d2d599ad-1887-4278-a2a7-8912860ed890)\n\nMinor\n![image](https://github.com/user-attachments/assets/d210df5c-df58-4fd5-b10e-f4a0bd19c4f2)\n\n\nApologies for the warm tone, forgot to turn that off, but it's made a huge difference! Great work \ud83d\udc4f! I'm not sure how easy it is to tell from the pictures but the Major/8.0.4+ branch has got rid of the rainbow effect entirely while maintaining most of the text crispness. The Minor/8.0.4+b branch seems to still have the rainbow effect. I would be happy to take more zoomed in pictures or retake the pictures without the warm tone if you would like.\n@oncpnda @KeePach @lovesewerrats @SUM1-UNO @nodscrim @Treishpel @\n\nIn case you want to test the new sharper rainbow eraser algorithm.\nKobo Libra Colour  4.42.23\n\nNormal\n\n![Image](https://github.com/user-attachments/assets/84555827-a5c8-4400-b311-9501e7e7e385)\n\nmajor\n\n![Image](https://github.com/user-attachments/assets/0c064c74-9bfb-4fa3-b155-3050b95a015b)\n\nminor\n\n![Image](https://github.com/user-attachments/assets/42ebc55c-16e7-4ecc-867a-759f14435489)\n\nunfortunately both  of them failed to reduce rainbow on cover, even old one, so I don't know if the algorithm doesn't even touch the first page\n\n![Image](https://github.com/user-attachments/assets/0ee60e1d-e6f5-415a-89e1-4ffba4e9fd26)\n\n\n\n\n\n> Kobo Libra Colour 4.42.23\n> \n> Normal\n> \n> ![Image](https://github.com/user-attachments/assets/84555827-a5c8-4400-b311-9501e7e7e385)\n> \n> major\n> \n> ![Image](https://github.com/user-attachments/assets/0c064c74-9bfb-4fa3-b155-3050b95a015b)\n> \n> minor\n> \n> ![Image](https://github.com/user-attachments/assets/42ebc55c-16e7-4ecc-867a-759f14435489)\n> \n> unfortunately both of them failed to reduce rainbow on cover, even old one, so I don't know if the algorithm doesn't even touch the first page\n> \n> ![Image](https://github.com/user-attachments/assets/0ee60e1d-e6f5-415a-89e1-4ffba4e9fd26)\n\nThanks for your input.\nYeah, this does not apply on color image for now, only bw (like the current blur KCC method)\nHad a little bit of time to play around more with the existing blur/sharpen combo to get a better balance of rainbow artifact reduction and sharpness:\n\n```python\ndef optimizeForDisplay(self):\n        # Reduce rainbow artifacts for grayscale images by breaking up dither patterns that cause Moire interference with color filter array\n        if (self.opt.displayType == DisplayType.KALEIDO3_COLOR and not self.color):\n            self.image = self.image.filter(ImageFilter.UnsharpMask(radius=1, percent=33))\n            self.image = self.image.filter(ImageFilter.BoxBlur(0.67))\n            self.image = self.image.filter(ImageFilter.UnsharpMask(radius=1.5, percent=150))\n````\n\nI also recommend swapping the order of image processing steps in `imgFileProcessing` so that the blur/sharpen is running on the source resolution instead of the rescaled image (I originally put it after rescaling because I was concerned about performance, but that was before I realized image processing was not the dominant performance bottleneck at the time I was working on this):\n\n```diff\ndef imgFileProcessing(work):\n    try:\n        ...\n        for i in workImg.payload:\n            ...\n            img.autocontrastImage()\n+           img.optimizeForDisplay()\n            img.resizeImage()\n-           img.optimizeForDisplay()\n```\n\nThis was tested on my Colorsoft so if other Kaleido screens have different interference frequencies (which this thread seems to indicate to be the case), the blur radius may need to be enlarged further with the corresponding increases in sharpening parameters.\n@utopiafallen did you compare this with the selective frequency attenuation (viewing images at 100% on your PC) ? The sharpness is better than before but still not quite the same as with the selective frequency attenuation. And afterall, it still also destroys data that does not interfer with the CFA.\nFurthermore with the current settings you provided, the rainbow effect is still very visible on an Inkpad Color 3. Tweaking the parameters untill it displays OK on it would mean more global blur.\n\nThe advantage of the existing method of unsharp->blur->unsharp (with release parameters or these new parameters) is in the processing time.\nThe advantage of the selective frequency attenuation is in the sharpness of output image.\n\nSo maybe the unsharp->blur->unsharp could become some sort of fallback method for low configurations or something ?\n\n@KeePach could you please provide the source of the latest pictures you showed ? I will try to adapt the code to make it work also on color images\n\nNo, I was just tweaking the blur and sharpening parameters to suit my tastes since I had a little bit of free time. \n\nI'm looking forward to whenever you land on the correct settings for the various displays you plan on supporting with your code, hopefully it'll include the display on the colorsoft \ud83d\ude04\n> No, I was just tweaking the blur and sharpening parameters to suit my tastes since I had a little bit of free time.\n> \n> I'm looking forward to whenever you land on the correct settings for the various displays you plan on supporting with your code, hopefully it'll include the display on the colorsoft \ud83d\ude04\n\nYes from @gardinermichael post (https://github.com/ciromattia/kcc/issues/771#issuecomment-3072196524) it should work well on colorsoft too !\n\nThe question is now wether to always filter at 135\u00b0 + 45\u00b0, default to 135\u00b0 and let the user chose 45\u00b0, or let the user chose between 45\u00b0 and 135\u00b0. More testing is needed to help take a decision\nCan any colorsoft users comment on how sharp the algorithm is compared to kindle store content?\n> [@utopiafallen](https://github.com/utopiafallen) did you compare this with the selective frequency attenuation (viewing images at 100% on your PC) ? The sharpness is better than before but still not quite the same as with the selective frequency attenuation. And afterall, it still also destroys data that does not interfer with the CFA. Furthermore with the current settings you provided, the rainbow effect is still very visible on an Inkpad Color 3. Tweaking the parameters untill it displays OK on it would mean more global blur.\n> \n> The advantage of the existing method of unsharp->blur->unsharp (with release parameters or these new parameters) is in the processing time. The advantage of the selective frequency attenuation is in the sharpness of output image.\n> \n> So maybe the unsharp->blur->unsharp could become some sort of fallback method for low configurations or something ?\n> \n> [@KeePach](https://github.com/KeePach) could you please provide the source of the latest pictures you showed ? I will try to adapt the code to make it work also on color images\n\n\nsure, here it is\n[pages.zip](https://github.com/user-attachments/files/21305192/Ankoku.Delta.-.Ch.015.zip)\n> > [@utopiafallen](https://github.com/utopiafallen) did you compare this with the selective frequency attenuation (viewing images at 100% on your PC) ? The sharpness is better than before but still not quite the same as with the selective frequency attenuation. And afterall, it still also destroys data that does not interfer with the CFA. Furthermore with the current settings you provided, the rainbow effect is still very visible on an Inkpad Color 3. Tweaking the parameters untill it displays OK on it would mean more global blur.\n> > The advantage of the existing method of unsharp->blur->unsharp (with release parameters or these new parameters) is in the processing time. The advantage of the selective frequency attenuation is in the sharpness of output image.\n> > So maybe the unsharp->blur->unsharp could become some sort of fallback method for low configurations or something ?\n> > [@KeePach](https://github.com/KeePach) could you please provide the source of the latest pictures you showed ? I will try to adapt the code to make it work also on color images\n> \n> sure, here it is [pages.zip](https://github.com/user-attachments/files/21305192/Ankoku.Delta.-.Ch.015.zip)\n\nPlease test this one, should correct the rainbow effect even on color pages (rename the .zip to .cbz before transfering to your Libra, Github doesn't allow to upload cbz directly)\n[Ankoku.Delta.-.Ch.015_erase-rainbow-45deg.zip](https://github.com/user-attachments/files/21305608/Ankoku.Delta.-.Ch.015_erase-rainbow-45deg.zip)\n> Please test this one, should correct the rainbow effect even on color pages (rename the .zip to .cbz before transfering to your Libra, Github doesn't allow to upload cbz directly) [Ankoku.Delta.-.Ch.015_erase-rainbow-45deg.zip](https://github.com/user-attachments/files/21305608/Ankoku.Delta.-.Ch.015_erase-rainbow-45deg.zip)\n\nsorry for taking so long, it worked!\n\n![Image](https://github.com/user-attachments/assets/3d73f51f-6c13-4287-8656-9fa8f7ff4186)\n\nit seems that for the libra colour the one that works is the 45\u00b0 one\nJust wanted to chip in with my findings for my *Kobo Libra Colour* here. Sometimes it's a bit hard to capture the rainbow / sharpness of the images with my phone camera so I will try to explain how it looks in person as well.\n\n### Settings I used for all conversions\n![settings](https://github.com/user-attachments/assets/50046392-cde5-45bd-8741-54fb6a0ce44e)\n\n### Original manga page\n![original](https://github.com/user-attachments/assets/04a35e4d-d29e-41f8-af52-e722f6327afb)\nOriginal manga page from Frieren chapter 1. Rainbow effect is very noticeable on a lot of pages. For showcase purposes I just picked one page to show pictures of but a lot of pages have this rainbow effect. All pages are very sharp\n\n### Old conversion (8.0.4)\n![old conversion](https://github.com/user-attachments/assets/00a4e6ab-151e-4170-9f50-0deeb925b378)\nOld conversion using KCC. Rainbow effect is removed completely. The images are slightly more blurry but still very readable. This is more noticeable for some images than others. Especially text or very intricate drawings can look a bit more blurry if you really focus on it\n\n### New conversion MAJOR\n![major](https://github.com/user-attachments/assets/96425a83-b0d7-47cc-91c9-7da5823090d6)\nThis rainbow blur effect did nothing for me and even made some panels have more rainbows. The images are very sharp\n\n### New conversion MINOR\n![minor](https://github.com/user-attachments/assets/e98a61fb-ebc9-4bf1-bf4e-28103bbda289)\nI had the best results with this version. The text and images are very sharp and the rainbow effect is removed completely. Besides sharper text and images, some panels with intricate patterns also look much better on this version.\n\n### Summary\nEven though the old conversion was good enough for me, the minor version is a definite improvement over the original on my Kobo Libra Colour. To me the difference is most notable in the sharpness of the text, I will be using this version from now on (until a new stable version is released). \n\nOne thing I did notice is the file size is a bit larger 76mb -> 93mb. To me this difference does not really matter though, as I delete the books from my ereader after reading them.\nThank you for feedback! I'm feeling confident that minor method for KLC and major method for all other devices is likely, maybe with a minor/major custom profiles for Pocketbooks etc.\n\nAlso, you can probably cut down the filesize with png.\n\nJPG: for primarily color content, or kindle scribe\npng: for primarily bw content\n\n@axu2 I'm currently working on a new version of the rainbow eraser (yes, already!), which should be even better than the version added in the 9.0.0 pre-release.\n\nThe idea this time is no longer to attenuate all high frequencies in an angular band, but to specifically search for peaks (and their area of action) within these bands. We will no longer attenuate them with a fixed factor (which means the final magnitude depends on several factors: resolution, saving format, etc.), but with a factor of 0, which will be much more universal.\n\nThe attenuation will therefore be stronger, but also much more precise. I will provide comparison images as well as frequency views of these images to clearly illustrate the improvements.\n\nRegarding the \"minor\"/\"major\" versions: I suggest keeping the attenuation on both diagonals. I've noticed that on images that don't cause rainbow effect, but have a texture that still interferes with the CFA, acting solely on the CFA diagonal isn't enough: breaking the frequency in the \"complementary\" angle solves the problem. I'll also provide comparison images for this, as well as a comparison with a black and white e-reader.\n\nMy rework is nearly ready and looks very promising at the moment, but I now need to work on improving performance because I'm at X2 compared to the 9.0.0 pre-release.\n\nI hope to be able to submit a pull request with the new version of the code and comparison images during the next weekend if I manage to improve performance by then.\n\nAlso, question: what is KCC's philosophy regarding adding dependencies? I'm trying to stick with PIL + numpy, but I'd like to have an idea of my room for maneuver for performance improvement\nI see, that's a strong reason to keep it in both directions.\n\nAre you thinking of adding OpenCV2? If it's neccessary we can add it, how large does it increase the final binary with `python setup.py build_binary`? How much performance improvement is it? We recently added pymupdf anyways.\n\nAlso, is it possible to emulate the other orientation screen by flipping the source image?\nI wasn't specifically thinking about OpenCV, but rather multiprocessing options.\nBut it probably won't be necessary; I'm already managing to improve performance little by little. I'll take the time this week to clean things up and document them, and I'll provide updates this weekend.\n\nAbout emulating the other orientation by flipping the image: let's assume an image with high-frequency patterns only at 45\u00b0. On a screen with a CFA oriented at 45\u00b0 (Kobo Libra Colour, for example), the rainbow effect will be very visible, but it would not be visible on a screen with a CFA oriented at 135\u00b0 (Kindle Colorsoft, for example).\nIf we flip this image, the patterns will be oriented at 135\u00b0, so we should see the rainbow effect on the Colorsoft and it should not appear on the Libra Color.\n\nIn this example, it should work well because both e-readers have the same screen size and resolution.\nBy changing the image resolution to display on an e-reader with a different resolution, things might change slightly.\n\nBut most of the time an image that shows rainbow on a 45\u00b0 CFA screen will also show it on a 135\u00b0 CFA screen, because most of the time it will not only have high frequencies at 45\u00b0 but also at 135\u00b0 (common for halftones, patterns are not only in one of those two directions but probably the two).\n@Its-my-right \n\nI just wanted to make sure I understood the theory of the rainbow eraser.\n\nSo basically you removed high frequencies above 0.3, which when looking at the spectrum where low frequencies are in the center, you basically create an initial circular mask trying to remove the outer ring. (Removing the entirely of this outer ring is a low pass filter/global blur)\n\nAnd overlay that mask with a mask along the diagonals with some tolerance. (solid colors on color eink are just solid diagonal edges perpendicular to the bright area on the spectrum)\n\nSo basically you are squashing/attentuating the Fourier coefficients in the 4 corners of the spectrum?\n\nAnd the frequencies you want to remove? 3 cycles and 2 cycles per pixel (.33 and .5) and obviously problematic in horizontal/vertical directions, and removing everything above 0.3 is tolerance for all the other color mixtures in the rainbow and diagonals?,\n\n(If my wording or terms is wrong I only recently learned about Fourier and honestly I think my knowledge is still shaky so if you have any particular learning resources lmk)\n> [@Its-my-right](https://github.com/Its-my-right)\n> \n> I just wanted to make sure I understood the theory of the rainbow eraser.\n> \n> So basically you removed high frequencies above 0.3, which when looking at the spectrum where low frequencies are in the center, you basically create an initial circular mask trying to remove the outer ring. (Removing the entirely of this outer ring is a low pass filter/global blur)\n> \n> And overlay that mask with a mask along the diagonals with some tolerance. (solid colors on color eink are just solid diagonal edges perpendicular to the bright area on the spectrum)\n> \n> So basically you are squashing/attentuating the Fourier coefficients in the 4 corners of the spectrum?\n> \n> And the frequencies you want to remove? 3 cycles and 2 cycles per pixel (.33 and .5) and obviously problematic in horizontal/vertical directions, and removing everything above 0.3 is tolerance for all the other color mixtures in the rainbow and diagonals?,\n> \n> (If my wording or terms is wrong I only recently learned about Fourier and honestly I think my knowledge is still shaky so if you have any particular learning resources lmk)\n\nOn Kaleido 3 displays, there is a CFA (Color Filter Array) layer placed on top of the black-and-white e-ink layer.\nAbove each e-ink cell there is an R, G, or B filter on this CFA.\n\nThe CFA consists of successive R, G, B filters, offset by one index on each line. As a result, the CFA exhibits diagonal red, green, and blue lines. The exact RGB pattern may vary depending on the screen size and the specific e-reader model, so the color diagonals are either top-left to bottom-right (135\u00b0) or bottom-left to top-right (45\u00b0).\n\nIf the e-ink cells beneath a group of RGB filters are all white, the human eye perceives white (similar to an LCD pixel: when its three RGB subpixels are turned on, the eye sees white). On the other hand, if only the cell under the \u201cR\u201d filter is white and the cells under the adjacent G and B filters are black, the eye perceives red.\n\nThe difference compared to an LCD pixel is that an LCD pixel has three RGB subpixels. Here, it\u2019s the combination of three e-ink cells + three filters above that forms a \u201cKaleido super-pixel.\u201d Three e-ink cells are required to reproduce a single color, and the filters are arranged in groups of 2x2 (1 R, 1 G, 1 B + 1 either R, G, or B) which is why the color display resolution is effectively halved compared to pure black-and-white resolution.\n\nAnother difference is that, in an LCD pixel, the three subpixels are usually aligned (either vertically or horizontally). On a Kaleido 3 screen, each RGB filter group can be perceived as a single color by the eye, and these groups can be arranged horizontally, vertically, or in \u201cL\u201d shapes.\n\nTherefore, if a black-and-white image contains patterns that cause groups of RGB filters to show colored combinations (e.g. R = white, G = black, B = black \u2192 perceived red), the eye can perceive colors.\nThis is the root cause of the \u201crainbow effect\u201d: patterns in the black-and-white image create edge effects on the CFA layer, and the eye can see colors.\n\n(I\u2019ve deliberately simplified the explanation by using only black and white, but in reality, e-ink cells can display 16 levels of gray, resulting in a range of color shades).\n\nIf the black-and-white patterns that produce colors are spaced far enough apart (low frequency), the eye perceives little or no color. But if they\u2019re very close together (high frequency), the rainbow effect becomes prominent.\n\nThis leads to the idea of applying a frequency-domain (Fourier) filter, because the frequency (low/high) of these patterns is the key factor.\n\nBy the way, if the CFA\u2019s RGB pattern is oriented at 45\u00b0, then frequencies should be attenuated along the 135\u00b0 axis, and vice versa. (It\u2019s just geometry, but I don\u2019t have a diagramming tool handy to illustrate this.)\n\nThrough experimentation, I found that frequencies below 0.3 cycles/pixel generally aren\u2019t problematic (not visible as color by the eye). These low frequencies correspond to spatial patterns that are sufficiently spaced out or simply don\u2019t exist (broad halftones, flat areas, contours, etc.).\nIn contrast, frequencies above 0.3 cycles/pixel tend to cause issues (visible as color by the eye) \u2014 but only along certain axes, depending on the CFA\u2019s RGB orientation.\n\nSo, instead of attenuating frequencies uniformly across all 360\u00b0 of the Fourier spectrum, the algorithm attenuates them within cones around those specific axes. This preserves high frequencies in areas where they don\u2019t trigger the rainbow effect.\n\nAttenuating frequencies in the Fourier domain causes blurring in the spatial domain, but this method allows for more precise control over where the image is blurred.\nMoreover, it\u2019s better to attenuate frequencies rather than set their magnitude to zero, to avoid introducing uncontrolled artifacts in the spatial domain.\n\nThe rainbow effect doesn\u2019t disappear 100% of the time for several reasons: frequencies are attenuated rather than fully removed; CFA alignments may vary slightly across displays; certain specific patterns (e.g. grids) may require attenuating frequencies just below 0.3 cycles/pixel and widening the filtering cones, etc.\nHowever, the results are convincing in the vast majority of cases.\n\nIn fact, there are two distinct concepts to understand here:\n- How color reproduction works on a Kaleido 3 screen. (If you use Photoshop, I created a PSD project that simulates a Kaleido 3 display: by toggling a CFA layer on top of a \u201cB&W e-ink\u201d layer, you can see how the image switches between black-and-white and color. i can provide it if you want)\n- How frequency-domain image processing works. (For this, I don\u2019t have specific references to share \u2014 I didn\u2019t keep notes on the sources I used during my research \u2014 but I remember finding good explanations online quite easily.)\nIn case it's interesting, I made a quick overview video about the math theory behind rainbow erasing on Kaleido 3 color eink (if I made any technical mistakes let me know, I only recently learned about the math):\n\nFix rainbows on color eink with the Discrete Fourier Transform!\nhttps://youtu.be/Dw2HTJCGMhw?si=A-vSylmROPHznsZl\n\n", "commit_urls": ["https://github.com/ciromattia/kcc/commit/43c18e5a54d7a01d430946b144832537cba1545b", "https://github.com/ciromattia/kcc/commit/71b99c79f651ddad6a5cd4ce7237add2d0fcb213", "https://github.com/ciromattia/kcc/commit/9917f4aa30c2dbf91c7dc163a283d983306cdb8f", "https://github.com/ciromattia/kcc/commit/3d24deeb7725ad3fff4f5ddf54e523c08f469adf", "https://github.com/ciromattia/kcc/commit/37c80573d13cc3d10a484aa43335140ed65ff282", "https://github.com/ciromattia/kcc/commit/626b61b29c4ca7b30a34e73c4891d4302b1136ce", "https://github.com/ciromattia/kcc/commit/c53dc76b3ef76a2668f4cb345480923feab08d65"], "created_at": "2025-07-12T13:02:33Z"}
{"repo": "ciromattia/kcc", "pull_number": 1019, "instance_id": "ciromattia__kcc-1019", "issue_numbers": [802], "base_commit": "07ef11013a0b00bfe25cf0263f7b2ac71ad4419f", "patch": "diff --git a/environment.yml b/environment.yml\nindex 24b702aa..0a9ba527 100644\n--- a/environment.yml\n+++ b/environment.yml\n@@ -4,7 +4,7 @@ channels:\n   - defaults\n dependencies:\n   - python=3.11\n-  - Pillow>=5.2.0\n+  - Pillow>=11.3.0\n   - psutil>=5.9.5\n   - python-slugify>=1.2.1\n   - raven>=6.0.0\ndiff --git a/kindlecomicconverter/comic2ebook.py b/kindlecomicconverter/comic2ebook.py\nindex 1b9dc839..eaf2074a 100755\n--- a/kindlecomicconverter/comic2ebook.py\n+++ b/kindlecomicconverter/comic2ebook.py\n@@ -820,7 +820,7 @@ def removeNonImages(filetree):\n     for root, dirs, files in os.walk(filetree):\n         for name in files:\n             _, ext = getImageFileName(name)\n-            if ext not in ('.png', '.jpg', '.jpeg', '.gif', '.webp', '.jp2'):\n+            if ext not in ('.png', '.jpg', '.jpeg', '.gif', '.webp', '.jp2', '.avif'):\n                 if os.path.exists(os.path.join(root, name)):\n                     os.remove(os.path.join(root, name))\n     # remove empty nested folders\ndiff --git a/kindlecomicconverter/shared.py b/kindlecomicconverter/shared.py\nindex 3993391e..1a4c1b38 100644\n--- a/kindlecomicconverter/shared.py\n+++ b/kindlecomicconverter/shared.py\n@@ -116,10 +116,10 @@ def dependencyCheck(level):\n             missing.append('python-slugify 1.2.1+')\n     try:\n         from PIL import __version__ as pillowVersion\n-        if Version('5.2.0') > Version(pillowVersion):\n-            missing.append('Pillow 5.2.0+')\n+        if Version('11.3.0') > Version(pillowVersion):\n+            missing.append('Pillow 11.3.0+')\n     except ImportError:\n-        missing.append('Pillow 5.2.0+')\n+        missing.append('Pillow 11.3.0+')\n     if len(missing) > 0:\n         print('ERROR: ' + ', '.join(missing) + ' is not installed!')\n         sys.exit(1)\ndiff --git a/requirements.txt b/requirements.txt\nindex 8d0e11a9..edee66af 100644\n--- a/requirements.txt\n+++ b/requirements.txt\n@@ -1,5 +1,5 @@\n PySide6>=6.5.1\n-Pillow>=5.2.0\n+Pillow>=11.3.0\n psutil>=5.9.5\n requests>=2.31.0\n python-slugify>=1.2.1\ndiff --git a/setup.py b/setup.py\nindex 13a36b06..b2cc1edf 100644\n--- a/setup.py\n+++ b/setup.py\n@@ -75,7 +75,7 @@ def run(self):\n     packages=['kindlecomicconverter'],\n     install_requires=[\n         'pyside6>=6.5.1',\n-        'Pillow>=5.2.0',\n+        'Pillow>=11.3.0',\n         'psutil>=5.9.5',\n         'python-slugify>=1.2.1,<9.0.0',\n         'raven>=6.0.0',\n@@ -83,7 +83,7 @@ def run(self):\n         'mozjpeg-lossless-optimization>=1.1.2',\n         'natsort>=8.4.0',\n         'distro',\n-        'numpy>=1.22.4,<2.0.0'\n+        'numpy>=1.22.4'\n     ],\n     classifiers=[],\n     zip_safe=False,\n", "test_patch": "", "problem_statement": "[Feature Request] Support for .avif image files\nAll my comics are formatted as AVIF inside a CBZ with metadata.\r\nCurrently, I have to extract the files and convert them to jpg using another program, before recompressing them back into a CBZ.\r\nCould you add support for AVIF conversion inside the program please? Alternatively if EPUB natively supports AVIF then no conversion is needed, just a way for the program to recognize it.\r\n\r\nI can provide a sample file if needed.\n", "hints_text": "You don't need to recompress to cbz. Kcc accepts a folder of images with the comic info.xml inside. \n\nThis will have to wait until pillow adds avif support. \nThanks for tell me, that saves the hassle of recompressing everything.\r\n\r\nCould this unofficial plugin be used until its officially supported?\r\nhttps://github.com/fdintino/pillow-avif-plugin\npillow 11.2.1 has been add avif support.\nhttps://pillow.readthedocs.io/en/stable/releasenotes/11.2.1.html#reading-and-writing-avif-images\nMight be as easy as changing this line:\n\nhttps://github.com/ciromattia/kcc/blob/cb0520dcab24a88a8311872b6b5cf5d08442c815/kindlecomicconverter/shared.py#L57\n\n@PoisonPyte @yaqinking \nTried use pillow 11.2.1 but raised exception, it seems not ready for avif support.\nSounds like you need to\n\n> Pillow can now read and write AVIF images when built from source with libavif 1.0.0 or later.\nLooks like it's ready in 11.3.0 https://pillow.readthedocs.io/en/stable/releasenotes/11.3.0.html#avif-support-in-wheels\n\n", "all_hints_text": "You don't need to recompress to cbz. Kcc accepts a folder of images with the comic info.xml inside. \n\nThis will have to wait until pillow adds avif support. \nThanks for tell me, that saves the hassle of recompressing everything.\r\n\r\nCould this unofficial plugin be used until its officially supported?\r\nhttps://github.com/fdintino/pillow-avif-plugin\npillow 11.2.1 has been add avif support.\nhttps://pillow.readthedocs.io/en/stable/releasenotes/11.2.1.html#reading-and-writing-avif-images\nMight be as easy as changing this line:\n\nhttps://github.com/ciromattia/kcc/blob/cb0520dcab24a88a8311872b6b5cf5d08442c815/kindlecomicconverter/shared.py#L57\n\n@PoisonPyte @yaqinking \nTried use pillow 11.2.1 but raised exception, it seems not ready for avif support.\nSounds like you need to\n\n> Pillow can now read and write AVIF images when built from source with libavif 1.0.0 or later.\nLooks like it's ready in 11.3.0 https://pillow.readthedocs.io/en/stable/releasenotes/11.3.0.html#avif-support-in-wheels\n@PoisonPyte @yaqinking I've added AVIF input support in 8.0.3\n\nIf you feel generous, feel free to donate on ko-fi! https://ko-fi.com/eink_dude\n\n", "commit_urls": ["https://github.com/ciromattia/kcc/commit/bb0c7e382c23fc8bb3a8770ebbe4ea8ec7bbbc21", "https://github.com/ciromattia/kcc/commit/1452d5a5b6bad3bdd892fd48fba563e032efefe1"], "created_at": "2025-07-09T18:26:22Z"}
{"repo": "ciromattia/kcc", "pull_number": 966, "instance_id": "ciromattia__kcc-966", "issue_numbers": [807], "base_commit": "eef5a85fa65bf0b8633fad555835d9c27fdf61ec", "patch": "diff --git a/gui/KCC.ui b/gui/KCC.ui\nindex 3ab19723..96b205a8 100644\n--- a/gui/KCC.ui\n+++ b/gui/KCC.ui\n@@ -446,7 +446,7 @@\n        <item row=\"1\" column=\"1\">\n         <widget class=\"QCheckBox\" name=\"rotateBox\">\n          <property name=\"toolTip\">\n-          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Unchecked - Split&lt;br/&gt;&lt;/span&gt;Double page spreads will be cut into two separate pages.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Indeterminate - Rotate and split&lt;br/&gt;&lt;/span&gt;Double page spreads will be displayed twice. First rotated and then split. &lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Checked - Rotate&lt;br/&gt;&lt;/span&gt;Double page spreads will be rotated.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n+          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Unchecked - Split&lt;br/&gt;&lt;/span&gt;Double page spreads will be cut into two separate pages.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Indeterminate - Rotate and split&lt;br/&gt;&lt;/span&gt;Double page spreads will be displayed twice. First split and then rotated. &lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Checked - Rotate&lt;br/&gt;&lt;/span&gt;Double page spreads will be rotated.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n          </property>\n          <property name=\"text\">\n           <string>Spread splitter</string>\ndiff --git a/kindlecomicconverter/KCC_ui.py b/kindlecomicconverter/KCC_ui.py\nindex 6f3a1e2e..b08d3bbf 100644\n--- a/kindlecomicconverter/KCC_ui.py\n+++ b/kindlecomicconverter/KCC_ui.py\n@@ -518,7 +518,7 @@ def retranslateUi(self, mainWindow):\n #endif // QT_CONFIG(tooltip)\n         self.webtoonBox.setText(QCoreApplication.translate(\"mainWindow\", u\"Webtoon mode\", None))\n #if QT_CONFIG(tooltip)\n-        self.rotateBox.setToolTip(QCoreApplication.translate(\"mainWindow\", u\"<html><head/><body><p><span style=\\\" font-weight:600; text-decoration: underline;\\\">Unchecked - Split<br/></span>Double page spreads will be cut into two separate pages.</p><p><span style=\\\" font-weight:600; text-decoration: underline;\\\">Indeterminate - Rotate and split<br/></span>Double page spreads will be displayed twice. First rotated and then split. </p><p><span style=\\\" font-weight:600; text-decoration: underline;\\\">Checked - Rotate<br/></span>Double page spreads will be rotated.</p></body></html>\", None))\n+        self.rotateBox.setToolTip(QCoreApplication.translate(\"mainWindow\", u\"<html><head/><body><p><span style=\\\" font-weight:600; text-decoration: underline;\\\">Unchecked - Split<br/></span>Double page spreads will be cut into two separate pages.</p><p><span style=\\\" font-weight:600; text-decoration: underline;\\\">Indeterminate - Rotate and split<br/></span>Double page spreads will be displayed twice. First split and then rotated. </p><p><span style=\\\" font-weight:600; text-decoration: underline;\\\">Checked - Rotate<br/></span>Double page spreads will be rotated.</p></body></html>\", None))\n #endif // QT_CONFIG(tooltip)\n         self.rotateBox.setText(QCoreApplication.translate(\"mainWindow\", u\"Spread splitter\", None))\n #if QT_CONFIG(tooltip)\ndiff --git a/kindlecomicconverter/comic2ebook.py b/kindlecomicconverter/comic2ebook.py\nindex 302624e4..ba1e1ab6 100755\n--- a/kindlecomicconverter/comic2ebook.py\n+++ b/kindlecomicconverter/comic2ebook.py\n@@ -371,7 +371,7 @@ def pageSpreadProperty(pageside):\n     page_spread_property_list = []\n     for entry in reflist:\n         if options.righttoleft:\n-            if \"-kcc-a\" in entry:\n+            if \"-kcc-a\" in entry or \"-kcc-d\" in entry:\n                 page_spread_property_list.append(\"center\")\n                 pageside = \"right\"\n             elif \"-kcc-b\" in entry:\n@@ -387,7 +387,7 @@ def pageSpreadProperty(pageside):\n                 else:\n                     pageside = \"right\"\n         else:\n-            if \"-kcc-a\" in entry:\n+            if \"-kcc-a\" in entry or \"-kcc-d\" in entry:\n                 page_spread_property_list.append(\"center\")\n                 pageside = \"left\"\n             elif \"-kcc-b\" in entry:\ndiff --git a/kindlecomicconverter/image.py b/kindlecomicconverter/image.py\nindex 86f1815d..8c758ec9 100755\n--- a/kindlecomicconverter/image.py\n+++ b/kindlecomicconverter/image.py\n@@ -290,7 +290,7 @@ def __init__(self, options, mode, path, image, color, fill):\n         if 'N' in mode:\n             self.targetPathOrder = '-kcc-x'\n         elif 'R' in mode:\n-            self.targetPathOrder = '-kcc-a'\n+            self.targetPathOrder = '-kcc-d'\n             if not options.norotate:\n                 self.rotated = True\n         elif 'S1' in mode:\n", "test_patch": "", "problem_statement": "[Feature Request] Don't split spreads if another spread immediately after\nThis way, if reading multiple spreads in a row its uninterrupted. can be ui toggle\n", "hints_text": "I could take this on. Do you have a good test file for this? Checked some my downloaded manga and didn't find any multi-spread pages.\nJust use any image that's wider than tall. \nOn further thought, no need to make a gui option. Just order the full spreads first. Then the split spreads. \n\n", "all_hints_text": "I could take this on. Do you have a good test file for this? Checked some my downloaded manga and didn't find any multi-spread pages.\nJust use any image that's wider than tall. \nOn further thought, no need to make a gui option. Just order the full spreads first. Then the split spreads. \nI actually have a different solution that I think works even better for reading immersion.\n\n", "commit_urls": ["https://github.com/ciromattia/kcc/commit/a0c62f35df23d0969d8d7682a0617d5c38e3c928"], "created_at": "2025-06-16T21:46:49Z"}
{"repo": "ciromattia/kcc", "pull_number": 1268, "instance_id": "ciromattia__kcc-1268", "issue_numbers": [814], "base_commit": "472fdc97b5ea2556319e9978c7628e5989d3e641", "patch": "diff --git a/README.md b/README.md\nindex 72e6609a..52fbf64c 100644\n--- a/README.md\n+++ b/README.md\n@@ -292,6 +292,7 @@ OUTPUT SETTINGS:\n                         Split output into multiple files. 0: Don't split 1: Automatic mode 2: Consider every subdirectory as separate volume [Default=0]\n   --spreadshift         Shift first page to opposite side in landscape for two page spread alignment\n   --norotate            Do not rotate double page spreads in spread splitter option.\n+  --rotateright         Rotate double page spreads in opposite direction.\n   --rotatefirst         Put rotated spread first in spread splitter option.\n   --filefusion          Combines all input files into a single file.\n   --eraserainbow       Erase rainbow effect on color eink screen by attenuating interfering frequencies\ndiff --git a/gui/KCC.ui b/gui/KCC.ui\nindex 2ce5f4af..fcc5f070 100644\n--- a/gui/KCC.ui\n+++ b/gui/KCC.ui\n@@ -514,98 +514,166 @@\n        <property name=\"bottomMargin\">\n         <number>0</number>\n        </property>\n-       <item row=\"0\" column=\"0\">\n-        <widget class=\"QLineEdit\" name=\"titleEdit\">\n-         <property name=\"sizePolicy\">\n-          <sizepolicy hsizetype=\"Minimum\" vsizetype=\"Fixed\">\n-           <horstretch>0</horstretch>\n-           <verstretch>0</verstretch>\n-          </sizepolicy>\n+       <item row=\"7\" column=\"1\">\n+        <widget class=\"QCheckBox\" name=\"chunkSizeCheckBox\">\n+         <property name=\"toolTip\">\n+          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700; text-decoration: underline;&quot;&gt;Unchecked&lt;br/&gt;&lt;/span&gt;Maximal output file size is 100 MB for Webtoon, 400 MB for others before split occurs.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700; text-decoration: underline;&quot;&gt;Checked&lt;/span&gt;&lt;br/&gt;Output file size specified in &amp;quot;Chunk size MB&amp;quot; before split occurs.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n          </property>\n-         <property name=\"focusPolicy\">\n-          <enum>Qt::FocusPolicy::ClickFocus</enum>\n+         <property name=\"text\">\n+          <string>Chunk size</string>\n          </property>\n+        </widget>\n+       </item>\n+       <item row=\"1\" column=\"2\">\n+        <widget class=\"QCheckBox\" name=\"qualityBox\">\n          <property name=\"toolTip\">\n-          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Default Title&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n+          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p style='white-space:pre'&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Unchecked - 4 panels&lt;br/&gt;&lt;/span&gt;Zoom each corner separately.&lt;/p&gt;&lt;p style='white-space:pre'&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Indeterminate - 2 panels&lt;br/&gt;&lt;/span&gt;Zoom only the top and bottom of the page.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Checked - 4 high-quality panels&lt;br/&gt;&lt;/span&gt;Zoom each corner separately. Try to increase the quality of magnification. Check wiki for more details.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n          </property>\n-         <property name=\"placeholderText\">\n-          <string>Default Title</string>\n+         <property name=\"text\">\n+          <string>Panel View 4/2/HQ</string>\n          </property>\n-         <property name=\"clearButtonEnabled\">\n-          <bool>false</bool>\n+         <property name=\"tristate\">\n+          <bool>true</bool>\n          </property>\n         </widget>\n        </item>\n-       <item row=\"1\" column=\"0\">\n-        <widget class=\"QCheckBox\" name=\"mangaBox\">\n+       <item row=\"0\" column=\"2\">\n+        <widget class=\"QWidget\" name=\"outputFolderWidget\" native=\"true\">\n+         <layout class=\"QHBoxLayout\" name=\"horizontalLayout_3\">\n+          <property name=\"leftMargin\">\n+           <number>0</number>\n+          </property>\n+          <property name=\"topMargin\">\n+           <number>0</number>\n+          </property>\n+          <property name=\"rightMargin\">\n+           <number>0</number>\n+          </property>\n+          <property name=\"bottomMargin\">\n+           <number>0</number>\n+          </property>\n+          <item>\n+           <widget class=\"QCheckBox\" name=\"defaultOutputFolderBox\">\n+            <property name=\"sizePolicy\">\n+             <sizepolicy hsizetype=\"Fixed\" vsizetype=\"Fixed\">\n+              <horstretch>0</horstretch>\n+              <verstretch>0</verstretch>\n+             </sizepolicy>\n+            </property>\n+            <property name=\"toolTip\">\n+             <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Unchecked - next to source&lt;br/&gt;&lt;/span&gt;Place output files next to source files&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Indeterminate - folder next to source&lt;br/&gt;&lt;/span&gt;Place output files in a folder next to source files&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Checked - Custom&lt;br/&gt;&lt;/span&gt;Place output files in custom directory specified by right button&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n+            </property>\n+            <property name=\"text\">\n+             <string>Output Folder</string>\n+            </property>\n+            <property name=\"tristate\">\n+             <bool>true</bool>\n+            </property>\n+           </widget>\n+          </item>\n+          <item>\n+           <widget class=\"QPushButton\" name=\"defaultOutputFolderButton\">\n+            <property name=\"minimumSize\">\n+             <size>\n+              <width>0</width>\n+              <height>30</height>\n+             </size>\n+            </property>\n+            <property name=\"toolTip\">\n+             <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Use this to select the default output directory.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n+            </property>\n+            <property name=\"text\">\n+             <string/>\n+            </property>\n+            <property name=\"icon\">\n+             <iconset resource=\"KCC.qrc\">\n+              <normaloff>:/Other/icons/folder_new.png</normaloff>:/Other/icons/folder_new.png</iconset>\n+            </property>\n+           </widget>\n+          </item>\n+         </layout>\n+        </widget>\n+       </item>\n+       <item row=\"5\" column=\"1\">\n+        <widget class=\"QCheckBox\" name=\"deleteBox\">\n          <property name=\"toolTip\">\n-          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p style='white-space:pre'&gt;Enable right-to-left reading.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n+          <string>Delete input file(s) or directory. It's not recoverable!</string>\n          </property>\n          <property name=\"text\">\n-          <string>Right-to-left (manga)</string>\n+          <string>Delete input</string>\n          </property>\n         </widget>\n        </item>\n-       <item row=\"2\" column=\"0\">\n-        <widget class=\"QCheckBox\" name=\"webtoonBox\">\n+       <item row=\"7\" column=\"0\">\n+        <widget class=\"QCheckBox\" name=\"metadataTitleBox\">\n          <property name=\"toolTip\">\n-          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p style='white-space:pre'&gt;Enable special parsing mode for Korean Webtoons.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n+          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Unchecked - Don't use metadata Title&lt;br/&gt;&lt;/span&gt;Write default title.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Indeterminate - Add metadata Title to the default schema&lt;br/&gt;&lt;/span&gt;Write default title with Title from ComicInfo.xml or other embedded metadata.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Checked - Use metadata Title only&lt;br/&gt;&lt;/span&gt;Write Title from ComicInfo.xml or other embedded metadata.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n          </property>\n          <property name=\"text\">\n-          <string>Webtoon mode</string>\n+          <string>Metadata Title</string>\n+         </property>\n+         <property name=\"tristate\">\n+          <bool>true</bool>\n          </property>\n         </widget>\n        </item>\n-       <item row=\"4\" column=\"2\">\n-        <widget class=\"QCheckBox\" name=\"croppingBox\">\n+       <item row=\"4\" column=\"0\">\n+        <widget class=\"QCheckBox\" name=\"mozJpegBox\">\n          <property name=\"toolTip\">\n-          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Unchecked - Disabled&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Disabled&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Indeterminate - Margins&lt;br/&gt;&lt;/span&gt;Margins&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Checked - Margins + page numbers&lt;br/&gt;&lt;/span&gt;Margins +page numbers&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n+          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Unchecked - JPEG&lt;br/&gt;&lt;/span&gt;Use JPEG files&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Indeterminate - force PNG&lt;br/&gt;&lt;/span&gt;Create PNG files instead JPEG&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Checked - mozJpeg&lt;br/&gt;&lt;/span&gt;10-20% smaller JPEG file, with the same image quality, but processing time multiplied by 2&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n          </property>\n          <property name=\"text\">\n-          <string>Cropping mode</string>\n+          <string>JPEG/PNG/mozJpeg</string>\n          </property>\n          <property name=\"tristate\">\n           <bool>true</bool>\n          </property>\n         </widget>\n        </item>\n-       <item row=\"4\" column=\"1\">\n-        <widget class=\"QCheckBox\" name=\"maximizeStrips\">\n+       <item row=\"6\" column=\"2\">\n+        <widget class=\"QCheckBox\" name=\"interPanelCropBox\">\n          <property name=\"toolTip\">\n-          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Unchecked - 1x4&lt;br/&gt;&lt;/span&gt;Keep format 1x4 panels strips.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Checked - 2x2&lt;br/&gt;&lt;/span&gt;Turn 1x4 strips to 2x2 to maximize screen usage.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n+          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Unchecked - Disabled&lt;br/&gt;&lt;/span&gt;Disabled&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Indeterminate - Horizontal&lt;br/&gt;&lt;/span&gt;Crop empty horizontal lines.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Checked - Both&lt;br/&gt;&lt;/span&gt;Crop empty horizontal and vertical lines.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n          </property>\n          <property name=\"text\">\n-          <string>1x4 to 2x2 strips</string>\n+          <string>Inter-panel crop</string>\n+         </property>\n+         <property name=\"tristate\">\n+          <bool>true</bool>\n          </property>\n         </widget>\n        </item>\n-       <item row=\"5\" column=\"1\">\n-        <widget class=\"QCheckBox\" name=\"deleteBox\">\n+       <item row=\"9\" column=\"2\">\n+        <widget class=\"QCheckBox\" name=\"autocontrastBox\">\n          <property name=\"toolTip\">\n-          <string>Delete input file(s) or directory. It's not recoverable!</string>\n+          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Unchecked - BW only&lt;br/&gt;&lt;/span&gt;Only autocontrast bw pages. Ignored for pages where near blacks or whites don't exist.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Indeterminate - Disabled&lt;br/&gt;&lt;/span&gt;Disable autocontrast&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Checked - BW and Color&lt;br/&gt;&lt;/span&gt;BW and color images will be autocontrasted. Ignored for pages where near blacks or whites don't exist.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n          </property>\n          <property name=\"text\">\n-          <string>Delete input</string>\n+          <string>Autocontrast</string>\n+         </property>\n+         <property name=\"tristate\">\n+          <bool>true</bool>\n          </property>\n         </widget>\n        </item>\n-       <item row=\"8\" column=\"1\">\n-        <widget class=\"QCheckBox\" name=\"rotateFirstBox\">\n+       <item row=\"6\" column=\"1\">\n+        <widget class=\"QCheckBox\" name=\"noRotateBox\">\n          <property name=\"toolTip\">\n-          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;When the spread splitter option is partially checked,&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Unchecked - Rotate Last&lt;br/&gt;&lt;/span&gt;Put the rotated 2 page spread after the split spreads.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Checked - Rotate First&lt;br/&gt;&lt;/span&gt;Put the rotated 2 page spread before the split spreads.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n+          <string>Do not rotate double page spreads in spread splitter option.</string>\n          </property>\n          <property name=\"text\">\n-          <string>Rotate First</string>\n+          <string>No rotate</string>\n          </property>\n         </widget>\n        </item>\n-       <item row=\"3\" column=\"1\">\n-        <widget class=\"QCheckBox\" name=\"outputSplit\">\n+       <item row=\"9\" column=\"1\">\n+        <widget class=\"QCheckBox\" name=\"coverFillBox\">\n          <property name=\"toolTip\">\n-          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p style='white-space:pre'&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Unchecked - Automatic mode&lt;br/&gt;&lt;/span&gt;The output will be split automatically.&lt;/p&gt;&lt;p style='white-space:pre'&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Checked - Volume mode&lt;br/&gt;&lt;/span&gt;Every subdirectory will be considered as a separate volume.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n+          <string>Resize cover to exact device resolution by center-cropping to aspect ratio first.\n+May crop top/bottom or left/right depending on source aspect ratio. Not implemented for Kindle Scribe.</string>\n          </property>\n          <property name=\"text\">\n-          <string>Output split</string>\n+          <string>Cover Fill</string>\n          </property>\n         </widget>\n        </item>\n@@ -622,46 +690,35 @@\n          </property>\n         </widget>\n        </item>\n-       <item row=\"2\" column=\"2\">\n-        <widget class=\"QCheckBox\" name=\"gammaBox\">\n+       <item row=\"7\" column=\"2\">\n+        <widget class=\"QCheckBox\" name=\"eraseRainbowBox\">\n          <property name=\"toolTip\">\n-          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Set a custom gamma correction.&lt;/p&gt;&lt;p&gt;1.0 is default (disabled).&lt;br/&gt;&amp;lt; 1.0 makes the image brighter.&lt;br/&gt;&amp;gt; 1.0 makes the image darker. &lt;/p&gt;&lt;p&gt;1.8 was the default in KCC 9.1.0 and earlier.&lt;/p&gt;&lt;p&gt;Use if you want to make midtones darker.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n+          <string>Erase rainbow effect on color eink screen by attenuating interfering frequencies</string>\n          </property>\n          <property name=\"text\">\n-          <string>Custom gamma</string>\n+          <string>Rainbow eraser</string>\n          </property>\n         </widget>\n        </item>\n-       <item row=\"2\" column=\"1\">\n-        <widget class=\"QCheckBox\" name=\"upscaleBox\">\n-         <property name=\"toolTip\">\n-          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Unchecked - Nothing&lt;br/&gt;&lt;/span&gt;Images smaller than device resolution will not be resized.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Indeterminate - Stretching&lt;br/&gt;&lt;/span&gt;Images smaller than device resolution will be resized. Aspect ratio will be not preserved.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600; text-decoration: underline;&quot;&gt;Checked - Upscaling&lt;br/&gt;&lt;/span&gt;Images smaller than device resolution will be resized. Aspect ratio will be preserved.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>\n-         </property>\n-         <property name=\"text\">\n-          <string>Stretch/Upscale</string>\n+       <item row=\"0\" column=\"0\">\n+        <widget class=\"QLineEdit\" name=\"titleEdit\">\n+         <property name=\"sizePolicy\