lica\"\n     ]\n-  }\n+  },\n+  \"secondary_address_fmt\": [\n+    \"Byt #\",\n+    \"Byt ##\",\n+    \"Byt ###\",\n+    \"Poschodie #\",\n+    \"Vchod @\"\n+  ]\n }\ndiff --git a/mimesis/datasets/sv/address.json b/mimesis/datasets/sv/address.json\nindex 78971c29c..dae387331 100644\n--- a/mimesis/datasets/sv/address.json\n+++ b/mimesis/datasets/sv/address.json\n@@ -6452,5 +6452,12 @@\n       \"\u00d6vre \u00d6rserydsv\u00e4gen\"\n     ]\n   },\n-  \"postal_code_fmt\": \"### ##\"\n+  \"postal_code_fmt\": \"### ##\",\n+  \"secondary_address_fmt\": [\n+    \"Lgh #\",\n+    \"Lgh ##\",\n+    \"Lgh ###\",\n+    \"V\u00e5ning #\",\n+    \"Trappa @\"\n+  ]\n }\ndiff --git a/mimesis/datasets/tr/address.json b/mimesis/datasets/tr/address.json\nindex 56b3952fd..823384df5 100644\n--- a/mimesis/datasets/tr/address.json\n+++ b/mimesis/datasets/tr/address.json\n@@ -1185,5 +1185,12 @@\n       \"\u015e\u0131rnak\"\n     ]\n   },\n-  \"postal_code_fmt\": \"#####\"\n+  \"postal_code_fmt\": \"#####\",\n+  \"secondary_address_fmt\": [\n+    \"Daire #\",\n+    \"Daire ##\",\n+    \"Daire ###\",\n+    \"Kat #\",\n+    \"Blok @\"\n+  ]\n }\ndiff --git a/mimesis/datasets/uk/address.json b/mimesis/datasets/uk/address.json\nindex c95fc2b3f..72cbdaba8 100644\n--- a/mimesis/datasets/uk/address.json\n+++ b/mimesis/datasets/uk/address.json\n@@ -2383,5 +2383,13 @@\n       \"\u0410\u043b\u043b\u0435\u044f\",\n       \"\u0432\u0443\u043b.\"\n     ]\n-  }\n+  },\n+  \"secondary_address_fmt\": [\n+    \"\u041a\u0432. #\",\n+    \"\u041a\u0432. ##\",\n+    \"\u041a\u0432. ###\",\n+    \"\u041a\u043e\u0440\u043f\u0443\u0441 #\",\n+    \"\u041f\u043e\u0432\u0435\u0440\u0445 #\",\n+    \"\u041e\u0444\u0456\u0441 ###\"\n+  ]\n }\ndiff --git a/mimesis/datasets/zh/address.json b/mimesis/datasets/zh/address.json\nindex 51820a829..09093cee4 100644\n--- a/mimesis/datasets/zh/address.json\n+++ b/mimesis/datasets/zh/address.json\n@@ -840,5 +840,12 @@\n       \"\u8def\"\n     ]\n   },\n-  \"postal_code_fmt\": \"######\"\n+  \"postal_code_fmt\": \"######\",\n+  \"secondary_address_fmt\": [\n+    \"###\u5ba4\",\n+    \"####\u5ba4\",\n+    \"#\u697c\",\n+    \"##\u697c\",\n+    \"@\u680b###\u5ba4\"\n+  ]\n }\ndiff --git a/mimesis/providers/address.py b/mimesis/providers/address.py\nindex 6b5eee47c..66e80b5db 100644\n--- a/mimesis/providers/address.py\n+++ b/mimesis/providers/address.py\n@@ -78,6 +78,34 @@ def street_suffix(self) -> str:\n         suffixes: list[str] = self._extract([\"street\", \"suffix\"])\n         return self.random.choice(suffixes)\n \n+    def secondary_address(self) -> str:\n+        \"\"\"Generates a random secondary address.\n+\n+        Secondary addresses are used for apartments, suites, units, etc.\n+\n+        :return: Secondary address.\n+\n+        :Example:\n+            Apt. 42\n+            Suite 1200\n+            Unit B\n+        \"\"\"\n+        default_patterns = [\n+            \"Apt. #\",\n+            \"Apt. ##\",\n+            \"Apt. ###\",\n+            \"Apt. @\",\n+            \"Suite ###\",\n+            \"Suite ####\",\n+            \"Unit #\",\n+            \"Unit @\",\n+        ]\n+        patterns: list[str] = self._extract(\n+            [\"secondary_address_fmt\"], default=default_patterns\n+        )\n+        pattern = self.random.choice(patterns)\n+        return self.random.generate_string_by_mask(mask=pattern, digit=\"#\", char=\"@\")\n+\n     def address(self) -> str:\n         \"\"\"Generates a random full address.\n \n", "test_patch": "diff --git a/tests/test_providers/test_localized/test_address.py b/tests/test_providers/test_localized/test_address.py\nindex c3adb0e9a..96d427700 100644\n--- a/tests/test_providers/test_localized/test_address.py\n+++ b/tests/test_providers/test_localized/test_address.py\n@@ -84,6 +84,16 @@ def test_address(self, address):\n         assert isinstance(result, str)\n         assert result is not None\n \n+    def test_secondary_address(self, _address):\n+        result = _address.secondary_address()\n+        assert isinstance(result, str)\n+        assert len(result) > 0\n+        valid_prefixes = (\"Apt.\", \"Suite\", \"Unit\", \"PO Box\")\n+        has_valid_format = any(\n+            result.startswith(p) for p in valid_prefixes\n+        ) or re.match(r\"^\\d+\\s[A-Z]$\", result)\n+        assert has_valid_format, f\"Invalid secondary address format: {result}\"\n+\n     @pytest.mark.parametrize(\n         \"abbr, key\",\n         [\n@@ -237,6 +247,9 @@ def test_street_suffix(self, a1, a2):\n     def test_address(self, a1, a2):\n         assert a1.address() == a2.address()\n \n+    def test_secondary_address(self, a1, a2):\n+        assert a1.secondary_address() == a2.secondary_address()\n+\n     def test_state(self, a1, a2):\n         assert a1.state() == a2.state()\n         assert a1.state(abbr=True) == a2.state(abbr=True)\n", "problem_statement": "Support for secondary addresses\n# Feature request\r\n\r\n<!-- Thanks for coming up with a proposal! -->\r\n\r\n## Thesis\r\n\r\nIt would be marvelous if secondary addresses were supported.\r\n\r\nExamples:\r\n\r\n- 123 Sesame Street, PO Box 789\r\n- 123 Sesame Street, Apt. C\r\n- 123 Sesame Street, Suite 69\r\n- 123 Sesame Street, Hall B Room 123\r\n\r\n<!-- What exactly do you propose? Please, provide code examples. -->\r\n\r\n## Reasoning\r\nSome applications break up the address into two fields.\r\n<!--\r\nWhy do you think this is a good idea?\r\n\r\nPlease, include some strong points and considerations.\r\n-->\r\n\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/lk-geimfari/mimesis/commit/a6f6b5276d14a8cd1ae901e5f5ebd26176153761", "https://github.com/lk-geimfari/mimesis/commit/2c67b11126e1964feb86bb138a36ae248362c838"], "created_at": "2026-01-10T03:00:23Z"}
{"repo": "lk-geimfari/mimesis", "pull_number": 1690, "instance_id": "lk-geimfari__mimesis-1690", "issue_numbers": [1635], "base_commit": "64923e66a458c61b9e645953e3e66597012c2666", "patch": "diff --git a/CONTRIBUTORS.rst b/CONTRIBUTORS.rst\nindex 43232a95a..b96785962 100644\n--- a/CONTRIBUTORS.rst\n+++ b/CONTRIBUTORS.rst\n@@ -98,6 +98,7 @@ Patches and Suggestions\n - Watheq Alshowaiter `(watheqAlshowaiter)`_\n - Zayed Alsaidi `(zayedalsaidi)`_\n - Muayyad AlSadi `(muayyadalsadi)`_\n+- Rodrigo Nogueira `(rodrigobnogueira)`_\n \n \n .. _(lk-geimfari): https://github.com/lk-geimfari\n@@ -174,4 +175,5 @@ Patches and Suggestions\n .. _(watheqAlshowaiter): https://github.com/watheqAlshowaiter\n .. _(yah04dev): https://github.com/yah04dev\n .. _(muayyadalsadi): https://github.com/muayyad-alsadi\n+.. _(rodrigobnogueira): https://github.com/rodrigobnogueira\n \ndiff --git a/mimesis/providers/person.py b/mimesis/providers/person.py\nindex 763253a50..0168c3bd8 100644\n--- a/mimesis/providers/person.py\n+++ b/mimesis/providers/person.py\n@@ -480,15 +480,22 @@ def language(self) -> str:\n         languages: list[str] = self._extract([\"language\"])\n         return self.random.choice(languages)\n \n-    def phone_number(self, mask: str = \"\", placeholder: str = \"#\") -> str:\n+    def phone_number(\n+        self,\n+        mask: str = \"\",\n+        placeholder: str = \"#\",\n+        e164: bool = False,\n+    ) -> str:\n         \"\"\"Generates a random phone number.\n \n         :param mask: Mask for formatting number.\n         :param placeholder: A placeholder for a mask (default is #).\n+        :param e164: If True, returns phone number in E.164 format (e.g., +14155552671).\n         :return: Phone number.\n \n         :Example:\n-            +7-(963)-409-11-22.\n+            Default: +7-(963)-409-11-22\n+            E.164: +79634091122\n         \"\"\"\n         if not mask:\n             code = self.random.choice(CALLING_CODES)\n@@ -496,7 +503,10 @@ def phone_number(self, mask: str = \"\", placeholder: str = \"#\") -> str:\n             masks = self._extract([\"telephone_fmt\"], default=[default])\n             mask = self.random.choice(masks)\n \n-        return self.random.generate_string_by_mask(mask=mask, digit=placeholder)\n+        result = self.random.generate_string_by_mask(mask=mask, digit=placeholder)\n+        if e164:\n+            return \"+\" + \"\".join(c for c in result if c.isdigit())\n+        return result\n \n     def telephone(self, *args: t.Any, **kwargs: t.Any) -> str:\n         \"\"\"An alias for :meth:`~.phone_number`.\"\"\"\n", "test_patch": "diff --git a/tests/test_providers/test_localized/test_person.py b/tests/test_providers/test_localized/test_person.py\nindex 502ea8867..35149026b 100644\n--- a/tests/test_providers/test_localized/test_person.py\n+++ b/tests/test_providers/test_localized/test_person.py\n@@ -206,6 +206,27 @@ def test_telephone(self, person):\n         head = result.split(\" \")[0]\n         assert head == \"+5\"\n \n+    def test_telephone_e164(self, _person):\n+        result = _person.telephone(e164=True)\n+        assert re.match(\n+            r\"^\\+\\d+$\", result\n+        ), f\"E.164 format should be +digits, got: {result}\"\n+        assert len(result) >= 8, \"E.164 number should have at least 7 digits plus +\"\n+\n+        mask = \"+1 (555)-123-4567\"\n+        result = _person.telephone(mask=mask, e164=True)\n+        assert result == \"+15551234567\"\n+\n+        mask_with_separators = \"+1-(###)-###-####\"\n+        result_e164 = _person.telephone(mask=mask_with_separators, e164=True)\n+        assert re.match(\n+            r\"^\\+\\d+$\", result_e164\n+        ), f\"Should be E.164 format, got: {result_e164}\"\n+        result_default = _person.telephone(mask=mask_with_separators, e164=False)\n+        assert (\n+            \"-\" in result_default or \"(\" in result_default\n+        ), f\"Default should have separators: {result_default}\"\n+\n     @pytest.mark.parametrize(\n         \"gender\",\n         [\n@@ -407,6 +428,7 @@ def test_telephone(self, p1, p2):\n         assert p1.telephone(mask=\"(x)-xx-xxx\", placeholder=\"x\") == p2.telephone(\n             mask=\"(x)-xx-xxx\", placeholder=\"x\"\n         )\n+        assert p1.telephone(e164=True) == p2.telephone(e164=True)\n \n     def test_surname(self, p1, p2):\n         assert p1.surname() == p2.surname()\n", "problem_statement": "add a phone number output in E164 format\n# Feature request\r\n\r\nadd a parameter to the function 'phone_number' that will return the result in the e164 format\r\n\r\n## Thesis\r\n\r\nCurrently, when executing the 'person.phone_number()' without param 'mask', the results are displayed in different national formats from execution to execution.\r\nExample for  Locale AR_DZ: \r\n0578549188 or (+213) 0621880931\r\nExample for  Locale EN:\r\n+1-909-131-2931 vs +15071035764\r\n\r\n## Reasoning\r\n\r\nIf some project used Google's common  library  [libphonenumber](https://github.com/google/libphonenumber) to validate the entered phone numbers then, most likely, they store phones in the E164 format in the database. It will be more convenient to insert the generated phone numbers into the database or use them in autotests if they are immediately in the e164 format.\r\n\n", "hints_text": "This issue has been automatically marked as stale because it has not had activity. It will be closed if no further activity occurs. Thank you for your contributions.\n\n\n", "all_hints_text": "This issue has been automatically marked as stale because it has not had activity. It will be closed if no further activity occurs. Thank you for your contributions.\n\n\n", "commit_urls": ["https://github.com/lk-geimfari/mimesis/commit/9923dec06c0d931b38ecad4ba212d5e6f18e4091"], "created_at": "2026-01-10T01:57:30Z"}
