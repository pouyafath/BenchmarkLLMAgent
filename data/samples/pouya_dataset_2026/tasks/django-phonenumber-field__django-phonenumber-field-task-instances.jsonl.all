{"repo": "django-phonenumber-field/django-phonenumber-field", "pull_number": 672, "instance_id": "django-phonenumber-field__django-phonenumber-field-672", "issue_numbers": [668], "base_commit": "f5066b1daef1341b36cf8b56ff47f522eb53e0df", "patch": "diff --git a/pyproject.toml b/pyproject.toml\nindex 7d12709..0b8d64b 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -36,6 +36,7 @@ dynamic = [\"version\"]\n dependencies = [\"Django>=4.2\"]\n \n [project.optional-dependencies]\n+babel = [\"Babel\"]\n phonenumbers = [\"phonenumbers >= 7.0.2\"]\n phonenumberslite = [\"phonenumberslite >= 7.0.2\"]\n \n", "test_patch": "", "problem_statement": "Add `babel` as `optional-dependencies` group\nCould you declare `babel` as an `optional-dependencies` group, so I can remove it from my direct dependencies?\n", "hints_text": "\n\n", "all_hints_text": "Many thanks!\n\n", "commit_urls": ["https://github.com/django-phonenumber-field/django-phonenumber-field/commit/b0063674f9ebcaf73fb1f63a30c1bfdf3799dffc"], "created_at": "2026-03-16T12:13:15Z"}
