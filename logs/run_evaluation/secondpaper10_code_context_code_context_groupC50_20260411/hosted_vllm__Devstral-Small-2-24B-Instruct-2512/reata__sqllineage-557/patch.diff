+    def _populate_write_columns_from_metadata(self, holder: SubQueryLineageHolder) -> None:
+        """
+        Populate write_columns from target table metadata when no explicit column list is provided.
+        """
+        if not self.metadata_provider:
+            return
+
+        # Get the target table (should be only one)
+        write_tables = list(holder.write)
+        if not write_tables:
+            return
+
+        # Only handle Table objects (not Path or SubQuery)
+        target_table = write_tables[0]
+        if not isinstance(target_table, Table):
+            return
+
+        # Get columns from metadata provider
+        try:
+            columns = self.metadata_provider.get_table_columns(target_table)
+            if columns:
+                holder.add_write_column(*columns)
+        except Exception:
+            # If metadata provider fails, just continue without write_columns
+            pass
