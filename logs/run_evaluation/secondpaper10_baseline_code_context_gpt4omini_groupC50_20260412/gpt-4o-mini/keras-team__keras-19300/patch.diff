+import keras
+from keras.layers import Softmax
+
+class SoftmaxLayer(keras.layers.Layer):
+  def call(self, x):
+    return Softmax()(x)
+
+model = keras.models.Sequential([SoftmaxLayer()])
+model.build((None, 10))
+print('SoftmaxLayer works!')
