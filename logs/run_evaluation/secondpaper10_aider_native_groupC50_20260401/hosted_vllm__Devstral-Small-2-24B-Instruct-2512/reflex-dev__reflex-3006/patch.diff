diff --git a/reflex/custom_lazy_loader.py b/reflex/custom_lazy_loader.py
new file mode 100644
index 00000000..3117d93a
--- /dev/null
+++ b/reflex/custom_lazy_loader.py
@@ -0,0 +1,93 @@
+"""Custom lazy loader for reflex that handles missing modules gracefully."""
+
+from __future__ import annotations
+
+import importlib
+import sys
+from typing import Any, Optional
+
+def attach(
+    package_name: str,
+    submodules: Optional[set[str]] = None,
+    submod_attrs: Optional[dict[str, list[str]]] = None,
+    **extra_mappings: str,
+):
+    """Custom lazy loader that handles missing modules gracefully.
+
+    Args:
+        package_name: name of the package.
+        submodules: List of submodules to attach.
+        submod_attrs: Dictionary of submodule -> list of attributes / functions.
+        extra_mappings: Additional mappings to resolve lazily.
+
+    Returns:
+        __getattr__, __dir__, __all__
+    """
+    submodules = set(submodules) if submodules is not None else set()
+    submod_attrs = submod_attrs or {}
+
+    # Build attribute to module mapping
+    attr_to_modules = {
+        attr: mod for mod, attrs in submod_attrs.items() for attr in attrs
+    }
+
+    __all__ = sorted([*(submodules | attr_to_modules.keys()), *(extra_mappings or [])])
+
+    def __getattr__(name: str):  # noqa: N807
+        try:
+            if name in extra_mappings:
+                path = extra_mappings[name]
+                if "." not in path:
+                    return importlib.import_module(path)
+                submod_path, attr = path.rsplit(".", 1)
+                submod = importlib.import_module(submod_path)
+                return getattr(submod, attr)
+            if name in submodules:
+                return importlib.import_module(f"{package_name}.{name}")
+            if name in attr_to_modules:
+                submod_path = f"{package_name}.{attr_to_modules[name]}"
+                submod = importlib.import_module(submod_path)
+                attr = getattr(submod, name)
+
+                # If the attribute lives in a file (module) with the same
+                # name as the attribute, ensure that the attribute and *not*
+                # the module is accessible on the package.
+                if name == attr_to_modules[name]:
+                    pkg = sys.modules[package_name]
+                    pkg.__dict__[name] = attr
+
+                return attr
+            msg = f"No {package_name} attribute {name}"
+            raise AttributeError(msg)
+        except ModuleNotFoundError as e:
+            # Check if this is a missing component package
+            if "reflex_components" in str(e):
+                missing_package = e.name
+                # Provide helpful error message
+                error_msg = (
+                    f"Component '{name}' requires the '{missing_package}' package. "
+                    f"This package is not available in the current environment.\n\n"
+                    f"To use this component, you need to install the full Reflex package "
+                    f"with all its dependencies. Please visit https://reflex.dev/docs/getting-started/installation "
+                    f"for installation instructions.\n\n"
+                    f"If you're working with the source code, you may need to install the "
+                    f"workspace packages using the appropriate package manager."
+                )
+                raise ModuleNotFoundError(error_msg) from e
+            # Re-raise other ModuleNotFoundError
+            raise
+        except ImportError as e:
+            # Handle other import errors
+            raise ImportError(
+                f"Failed to import '{name}': {e}"
+            ) from e
+
+    def __dir__():  # noqa: N807
+        return __all__
+
+    # Disable eager loading in this environment
+    if False:
+        for attr in set(attr_to_modules.keys()) | submodules:
+            __getattr__(attr)
+
+    return __getattr__, __dir__, list(__all__)
