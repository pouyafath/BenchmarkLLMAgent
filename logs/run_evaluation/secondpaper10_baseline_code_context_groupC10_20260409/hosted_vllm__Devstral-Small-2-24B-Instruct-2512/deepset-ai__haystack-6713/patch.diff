"""Utility functions for handling PyTorch-related operations."""

import torch
from typing import Any, Dict

def resolve_torch_dtype(dtype_str: str) -> torch.dtype:
    """
    Convert a string representation of a torch dtype to the actual torch.dtype.

    This function handles string representations of torch dtypes that might be
    used in serialization/deserialization scenarios.

    :param dtype_str: String representation of a torch dtype (e.g., "torch.float16", "float32", "auto")
    :return: The corresponding torch.dtype
    :raises ValueError: If the string cannot be resolved to a valid torch dtype
    """
    if dtype_str == "auto":
        return "auto"

    # Handle direct torch dtype strings like "torch.float16"
    if dtype_str.startswith("torch."):
        dtype_str = dtype_str[6:]  # Remove "torch." prefix

    # Handle simple dtype names like "float16", "float32", etc.
    try:
        return getattr(torch, dtype_str)
    except AttributeError:
        pass

    # Handle special cases
    if dtype_str == "float16":
        return torch.float16
    elif dtype_str == "float32":
        return torch.float32
    elif dtype_str == "float64":
        return torch.float64
    elif dtype_str == "bfloat16":
        return torch.bfloat16
    elif dtype_str == "uint8":
        return torch.uint8
    elif dtype_str == "int8":
        return torch.int8
    elif dtype_str == "int16":
        return torch.int16
    elif dtype_str == "int32":
        return torch.int32
    elif dtype_str == "int64":
        return torch.int64
    elif dtype_str == "bool":
        return torch.bool

    raise ValueError(f"Cannot resolve torch dtype from string: {dtype_str}")

def serialize_torch_dtype(dtype: torch.dtype) -> str:
    """
    Convert a torch.dtype to its string representation for serialization.

    :param dtype: The torch.dtype to serialize
    :return: String representation of the dtype
    """
    return str(dtype)

def serialize_model_kwargs(model_kwargs: Dict[str, Any]) -> Dict[str, Any]:
    """
    Serialize model_kwargs dictionary by converting non-serializable values to strings.

    This function specifically handles torch.dtype values by converting them to strings.

    :param model_kwargs: Dictionary of model kwargs that may contain non-serializable values
    :return: Serialized dictionary with non-serializable values converted to strings
    """
    if not model_kwargs:
        return model_kwargs

    serialized_kwargs = {}
    for key, value in model_kwargs.items():
        if isinstance(value, torch.dtype):
            serialized_kwargs[key] = serialize_torch_dtype(value)
        else:
            serialized_kwargs[key] = value
    return serialized_kwargs

def deserialize_model_kwargs(model_kwargs: Dict[str, Any]) -> Dict[str, Any]:
    """
    Deserialize model_kwargs dictionary by converting string representations back to objects.

    This function specifically handles torch.dtype string representations by converting them back to torch.dtype.

    :param model_kwargs: Dictionary of model kwargs that may contain string representations
    :return: Deserialized dictionary with string representations converted back to objects
    """
    if not model_kwargs:
        return model_kwargs

    deserialized_kwargs = {}
    for key, value in model_kwargs.items():
        if isinstance(value, str) and value.startswith("torch."):
            try:
                deserialized_kwargs[key] = resolve_torch_dtype(value)
            except ValueError:
                # If we can't resolve it, keep it as a string
                deserialized_kwargs[key] = value
        else:
            deserialized_kwargs[key] = value
    return deserialized_kwargs

