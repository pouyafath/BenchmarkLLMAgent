9b\\xc7\\xed\\xc7}|t\\xd4\\x1c:\\xc5\\x81\\xf9\\xf3\\xac\\x9c\\xb5\\xe5\\xa2\\\\y\\x17\\xd4\\xa2\\x9cxF\\xa3s\\x8eS\\xc9\\xf7\\xec-\\x86(\\xd98O]\\xb0\\xcb\\x98\\xdc\\xccF\\xc4\\xe7(\\xffcZ\\x15\\xd0'\nException in thread video-decoder:\nTraceback (most recent call last):\n  File \"/usr/lib/python3.12/threading.py\", line 1073, in _bootstrap_inner\n    self.run()\n  File \"/usr/lib/python3.12/threading.py\", line 1010, in run\n    self._target(*self._args, **self._kwargs)\n  File \"/home/<redacted>venv/lib/python3.12/site-packages/aiortc/rtcrtpreceiver.py\", line 75, in decoder_worker\n    raise err\n  File \"/home/<redacted>/venv/lib/python3.12/site-packages/aiortc/rtcrtpreceiver.py\", line 70, in decoder_worker\n    for frame in decoder.decode(encoded_frame):\n                 ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"/home/<redacted>/venv/lib/python3.12/site-packages/aiortc/codecs/vpx.py\", line 163, in decode\n    return cast(list[Frame], self.codec.decode(packet))\n                             ^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"av/codec/context.pyx\", line 433, in av.codec.context.CodecContext.decode\n  File \"av/codec/context.pyx\", line 448, in av.codec.context.CodecContext.decode\n  File \"av/codec/context.pyx\", line 340, in av.codec.context.CodecContext._send_packet_and_recv\n  File \"av/error.pyx\", line 424, in av.error.err_check\nav.error.InvalidDataError: [Errno 1094995529] Invalid data found when processing input: 'avcodec_send_packet()'\n```\n\nAlso the error seems to appear randomly (maybe a keyframe is not received as first packet?), sometimes it works flawlessly.\nHm looking into it, our previous code did silently discard errors:\n\n```python\n        result = lib.vpx_codec_decode(\n            self.codec,\n            encoded_frame.data,\n            len(encoded_frame.data),\n            ffi.NULL,\n            lib.VPX_DL_REALTIME,\n        )\n        if result == lib.VPX_CODEC_OK:\n            ...\n``\n\n", "commit_urls": ["https://github.com/aiortc/aiortc/commit/ac86275eeb34931f17f41d26c4072f04c734c9aa"], "created_at": "2025-05-24T08:23:55Z"}
{"repo": "aiortc/aiortc", "pull_number": 1334, "instance_id": "aiortc__aiortc-1334", "issue_numbers": [1332], "base_commit": "c3f6b41b3e654204e032cf2e77b1a11a5f308042", "patch": "diff --git a/src/aiortc/rtcpeerconnection.py b/src/aiortc/rtcpeerconnection.py\nindex debe352c1..9c90b02e2 100644\n--- a/src/aiortc/rtcpeerconnection.py\n+++ b/src/aiortc/rtcpeerconnection.py\n@@ -433,16 +433,23 @@ async def addIceCandidate(self, candidate: Optional[RTCIceCandidate]) -> None:\n             iceTransport = self.__sctp.transport.transport\n             await iceTransport.addRemoteCandidate(candidate)\n \n-        # Update the remote description.\n-        media = self.__remoteDescription().media\n-        for sdp_m_line_index in range(0, len(media)):\n-            if candidate is None:\n-                media[sdp_m_line_index].ice_candidates_complete = True\n-            elif (\n-                candidate.sdpMLineIndex == sdp_m_line_index\n-                or candidate.sdpMid == media[sdp_m_line_index].rtp.muxId\n-            ):\n-                media[sdp_m_line_index].ice_candidates.append(candidate)\n+        # Update the remote description if it exists.\n+        # The spec forbids adding candidates prior to setRemoteDescription\n+        # but this used to work in previous versions.\n+        if remote_description := self.__remoteDescription():\n+            media = remote_description.media\n+            for sdp_m_line_index in range(0, len(media)):\n+                if candidate is None:\n+                    media[sdp_m_line_index].ice_candidates_complete = True\n+                elif (\n+                    candidate.sdpMLineIndex == sdp_m_line_index\n+                    or candidate.sdpMid == media[sdp_m_line_index].rtp.muxId\n+                ):\n+                    media[sdp_m_line_index].ice_candidates.append(candidate)\n+        else:\n+            logger.warning(\n+                \"RTCPeerConnection addIceCandidate called without remote description\"\n+            )\n \n     def addTrack(self, track: MediaStreamTrack) -> RTCRtpSender:\n         \"\"\"\n", "test_patch": "diff --git a/tests/test_rtcpeerconnection.py b/tests/test_rtcpeerconnection.py\nindex b32995b24..e07c35fa0 100644\n--- a/tests/test_rtcpeerconnection.py\n+++ b/tests/test_rtcpeerconnection.py\n@@ -639,6 +639,32 @@ async def test_addIceCandidate_null(self) -> None:\n         await pc.addIceCandidate(None)\n         self.assertTrue(\"a=end-of-candidates\" in pc.remoteDescription.sdp)\n \n+    @asynctest\n+    async def test_addIceCandidate_before_setremotedescription(self) -> None:\n+        pc = RTCPeerConnection()\n+        pc.createDataChannel(\"test\")\n+        offer = await pc.createOffer()\n+        await pc.setLocalDescription(offer)\n+        candidate_with_index = RTCIceCandidate(\n+            component=1,\n+            foundation=\"0\",\n+            ip=\"192.168.99.7\",\n+            port=33543,\n+            priority=2122252543,\n+            protocol=\"UDP\",\n+            type=\"host\",\n+            sdpMLineIndex=0,\n+        )\n+        with self.assertLogs(\"aiortc.rtcpeerconnection\", level=\"WARN\") as logger:\n+            await pc.addIceCandidate(candidate_with_index)\n+            self.assertEqual(\n+                logger.output,\n+                [\n+                    \"WARNING:aiortc.rtcpeerconnection:RTCPeerConnection \"\n+                    \"addIceCandidate called without remote description\"\n+                ],\n+            )\n+\n     @asynctest\n     async def test_addTrack_audio(self) -> None:\n         pc = RTCPeerConnection()\n", "problem_statement": "addIceCandidate raises AttributeError: 'NoneType' object has no attribute 'media'\nThis happens since 1.13.0, in my code I add ice candidates before receiving the remote description,\n\n```python\nTraceback (most recent call last):\n  File \".venv/lib/python3.12/site-packages/aiortc/rtcpeerconnection.py\", line 437, in addIceCandidate\n    media = self.__remoteDescription().media\n            ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\nAttributeError: 'NoneType' object has no attribute 'media'\n```\n", "hints_text": "@fippo looks like we have a regression\nadding candidates before the remote description should be an error but I can see how that worked before. Will take a look!\n\n", "all_hints_text": "@fippo looks like we have a regression\nadding candidates before the remote description should be an error but I can see how that worked before. Will take a look!\nThis issue has been automatically marked as stale because it has not had recent activity. It will be closed if no further activity occurs. Thank you for your contributions.\n\n", "commit_urls": ["https://github.com/aiortc/aiortc/commit/b74d898287212a836e733253a2e18bc65aea66c3"], "created_at": "2025-06-03T14:33:30Z"}
{"repo": "aiortc/aiortc", "pull_number": 1386, "instance_id": "aiortc__aiortc-1386", "issue_numbers": [1368], "base_commit": "9a7139334a40bca0d2eb7de1d9f9882583665b4b", "patch": "diff --git a/src/aiortc/sdp.py b/src/aiortc/sdp.py\nindex 55df19db7..fac346013 100644\n--- a/src/aiortc/sdp.py\n+++ b/src/aiortc/sdp.py\n@@ -301,8 +301,11 @@ def __str__(self) -> str:\n         if self.msid:\n             lines.append(f\"a=msid:{self.msid}\")\n \n-        if self.rtcp_port is not None and self.rtcp_host is not None:\n-            lines.append(f\"a=rtcp:{self.rtcp_port} {ipaddress_to_sdp(self.rtcp_host)}\")\n+        if self.rtcp_port is not None:\n+            line = f\"a=rtcp:{self.rtcp_port}\"\n+            if self.rtcp_host is not None:\n+                line += f\" {ipaddress_to_sdp(self.rtcp_host)}\"\n+            lines.append(line)\n             if self.rtcp_mux:\n                 lines.append(\"a=rtcp-mux\")\n \n@@ -487,9 +490,10 @@ def find_codec(pt: int) -> RTCRtpCodecParameters:\n                     elif attr == \"msid\":\n                         current_media.msid = value\n                     elif attr == \"rtcp\":\n-                        port, rest = value.split(\" \", 1)\n-                        current_media.rtcp_port = int(port)\n-                        current_media.rtcp_host = ipaddress_from_sdp(rest)\n+                        bits = value.split(\" \", 1)\n+                        current_media.rtcp_port = int(bits[0])\n+                        if len(bits) > 1:\n+                            current_media.rtcp_host = ipaddress_from_sdp(bits[1])\n                     elif attr == \"rtcp-mux\":\n                         current_media.rtcp_mux = True\n                     elif attr == \"setup\":\n", "test_patch": "diff --git a/tests/test_sdp.py b/tests/test_sdp.py\nindex fc06b632f..6b8bb55c3 100644\n--- a/tests/test_sdp.py\n+++ b/tests/test_sdp.py\n@@ -1035,6 +1035,82 @@ def test_audio_ice_session_level_credentials(self) -> None:\n a=ice-pwd:uK8IlylxzDMUhrkVzdmj0M+v\n a=fingerprint:sha-256 6B:8B:5D:EA:59:04:20:23:29:C8:87:1C:CC:87:32:BE:DD:8C:66:A5:8E:50:55:EA:8C:D3:B6:5C:09:5E:D6:BC\n a=setup:actpass\n+\"\"\"\n+            ),\n+        )\n+\n+    def test_audio_rtcp_without_port(self) -> None:\n+        d = SessionDescription.parse(\n+            lf2crlf(\n+                \"\"\"v=0\n+o=- 863426017819471768 2 IN IP4 127.0.0.1\n+s=-\n+t=0 0\n+m=audio 43580 RTP/AVP 0\n+c=IN IP4 192.168.99.58\n+a=sendrecv\n+a=rtcp:9\n+a=rtpmap:0 PCMU/8000\n+\"\"\"\n+            )\n+        )\n+\n+        self.assertEqual(d.group, [])\n+        self.assertEqual(d.msid_semantic, [])\n+        self.assertEqual(d.host, None)\n+        self.assertEqual(d.name, \"-\")\n+        self.assertEqual(d.origin, \"- 863426017819471768 2 IN IP4 127.0.0.1\")\n+        self.assertEqual(d.time, \"0 0\")\n+        self.assertEqual(d.version, 0)\n+\n+        self.assertEqual(len(d.media), 1)\n+        self.assertEqual(d.media[0].kind, \"audio\")\n+        self.assertEqual(d.media[0].host, \"192.168.99.58\")\n+        self.assertEqual(d.media[0].port, 43580)\n+        self.assertEqual(d.media[0].profile, \"RTP/AVP\")\n+        self.assertEqual(d.media[0].direction, \"sendrecv\")\n+        self.assertEqual(d.media[0].msid, None)\n+        self.assertEqual(\n+            d.media[0].rtp.codecs,\n+            [\n+                RTCRtpCodecParameters(\n+                    mimeType=\"audio/PCMU\", clockRate=8000, channels=1, payloadType=0\n+                ),\n+            ],\n+        )\n+        self.assertEqual(d.media[0].rtp.headerExtensions, [])\n+        self.assertEqual(d.media[0].rtp.muxId, \"\")\n+        self.assertEqual(d.media[0].rtcp_host, None)\n+        self.assertEqual(d.media[0].rtcp_port, 9)\n+        self.assertEqual(d.media[0].rtcp_mux, False)\n+\n+        # ssrc\n+        self.assertEqual(d.media[0].ssrc, [])\n+        self.assertEqual(d.media[0].ssrc_group, [])\n+\n+        # formats\n+        self.assertEqual(d.media[0].fmt, [0])\n+        self.assertEqual(d.media[0].sctpmap, {})\n+        self.assertEqual(d.media[0].sctp_port, None)\n+\n+        # ice\n+        self.assertEqual(len(d.media[0].ice_candidates), 0)\n+\n+        # dtls\n+        self.assertEqual(d.media[0].dtls, None)\n+\n+        self.assertEqual(\n+            str(d),\n+            lf2crlf(\n+                \"\"\"v=0\n+o=- 863426017819471768 2 IN IP4 127.0.0.1\n+s=-\n+t=0 0\n+m=audio 43580 RTP/AVP 0\n+c=IN IP4 192.168.99.58\n+a=sendrecv\n+a=rtcp:9\n+a=rtpmap:0 PCMU/8000\n \"\"\"\n             ),\n         )\n", "problem_statement": "a=rtcp raises exception when value is a port without an address\nsdp.py line 489 expects the rtcp attribute to contain both a port and an address\n\n```\n                    elif attr == \"rtcp\":\n                        port, rest = value.split(\" \", 1)\n                        current_media.rtcp_port = int(port)\n                        current_media.rtcp_host = ipaddress_from_sdp(rest)\n```\n\nHowever while the port is required, the address is only optional. Parsing an attribute that only contains a port eg `a=rtcp:16845` will raise an exception:\n\n```\nFile \"/usr/local/lib/python3.13/dist-packages/aiortc/sdp.py\", line 489, in parse\n  port, rest = value.split(\" \", 1)\n  ^^^^^^^^^^\nValueError: not enough values to unpack (expected 2, got 1)\n```\n\nNote the ABNF definition and first example from RFC3605.\n\n```\n   The formal description of the attribute is defined by the following\n   ABNF [RFC2234] syntax:\n\n   rtcp-attribute =  \"a=rtcp:\" port  [nettype space addrtype space\n                         connection-address] CRLF\n\n   In this description, the \"port\", \"nettype\", \"addrtype\" and\n   \"connection-address\" tokens are defined as specified in \"Appendix A:\n   SDP Grammar\" of [RFC2327].\n\n   Example encodings could be:\n\n    m=audio 49170 RTP/AVP 0\n    a=rtcp:53020\n\n    m=audio 49170 RTP/AVP 0\n    a=rtcp:53020 IN IP4 126.16.64.4\n\n    m=audio 49170 RTP/AVP 0\n    a=rtcp:53020 IN IP6 2001:2345:6789:ABCD:EF01:2345:6789:ABCD\n```\n", "hints_text": "This does indeed look legitimate. What's the agent on the other end of the conversation?\n\n", "all_hints_text": "This does indeed look legitimate. What's the agent on the other end of the conversation?\n\n", "commit_urls": ["https://github.com/aiortc/aiortc/commit/7067987e870ed36ebb921977659e36da522c0794"], "created_at": "2025-10-13T12:05:53Z"}
