+SEMANTIC_VERSION_PATTERN = re.compile(r"^\d+(?:\.\d+)?(?:\.\d+)?(?:-[a-zA-Z0-9]+(?:.[a-zA-Z0-9]+)*)?(?:\+\S+)?$")
 
 
