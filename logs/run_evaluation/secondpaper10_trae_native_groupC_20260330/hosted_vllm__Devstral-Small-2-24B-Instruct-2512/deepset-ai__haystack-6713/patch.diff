+# SPDX-FileCopyrightText: 2022-present deepset GmbH <info@deepset.ai>
+#
+# SPDX-License-Identifier: Apache-2.0
+"""Utility functions for handling torch types in serialization."""
+from typing import Any, Dict
+
+from haystack.lazy_imports import LazyImport
+
+with LazyImport(message="Run 'pip install torch'") as torch_import:
+    import torch
+
+
+def serialize_torch_dtype(value: Any) -> Any:
+    """
+    Convert torch.dtype objects to strings for serialization.
+
+    Args:
+        value: The value to potentially convert. Can be a torch.dtype or any other value.
+
+    Returns:
+        The value with torch.dtype objects converted to strings, or the original value if not a torch.dtype.
+    """
+    if isinstance(value, torch.dtype):
+        return str(value)
+    return value
+
+
+def deserialize_torch_dtype(value: Any) -> Any:
+    """
+    Convert string representations of torch.dtype back to torch.dtype objects.
+
+    Args:
+        value: The value to potentially convert. Can be a string representation of a torch.dtype or any other value.
+
+    Returns:
+        The value with string representations of torch.dtype converted back to torch.dtype objects,
+        or the original value if not a string representation of a torch.dtype.
+    """
+    if isinstance(value, str):
+        # Check if the string represents a torch.dtype
+        try:
+            # Remove 'torch.' prefix if present
+            dtype_str = value
+            if dtype_str.startswith("torch."):
+                dtype_str = dtype_str[6:]
+            return getattr(torch, dtype_str)
+        except AttributeError:
+            # Not a torch.dtype string, return as-is
+            return value
+    return value
+
+
+def serialize_model_kwargs(model_kwargs: Dict[str, Any]) -> Dict[str, Any]:
+    """
+    Serialize model_kwargs by converting torch.dtype objects to strings.
+
+    Args:
+        model_kwargs: Dictionary of model kwargs that may contain torch.dtype objects.
+
+    Returns:
+        A new dictionary with torch.dtype objects converted to strings.
+    """
+    if not model_kwargs:
+        return model_kwargs
+
+    serialized = {}
+    for key, value in model_kwargs.items():
+        if isinstance(value, dict):
+            # Recursively serialize nested dictionaries
+            serialized[key] = serialize_model_kwargs(value)
+        else:
+            serialized[key] = serialize_torch_dtype(value)
+    return serialized
+
+
+def deserialize_model_kwargs(model_kwargs: Dict[str, Any]) -> Dict[str, Any]:
+    """
+    Deserialize model_kwargs by converting string representations of torch.dtype back to torch.dtype objects.
+
+    Args:
+        model_kwargs: Dictionary of model kwargs that may contain string representations of torch.dtype.
+
+    Returns:
+        A new dictionary with string representations of torch.dtype converted back to torch.dtype objects.
+    """
+    if not model_kwargs:
+        return model_kwargs
+
+    deserialized = {}
+    for key, value in model_kwargs.items():
+        if isinstance(value, dict):
+            # Recursively deserialize nested dictionaries
+            deserialized[key] = deserialize_model_kwargs(value)
+        else:
+            deserialized[key] = deserialize_torch_dtype(value)
+    return deserialized
