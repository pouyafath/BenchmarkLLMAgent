ux_2_17_aarch64.manylinux_2_28_aarch64.whl\", hash = \"sha256:dc4a8d2b25efb6681ecacad42fca8859f88092d8732b170de6a5dddd80a1c8fa\", size = 87963, upload-time = \"2025-08-12T05:52:20.326Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/df/61/515ad6caca68995da2fac7a6af97faab8f78ebe3bf4f761e1b77efbc47b5/wrapt-1.17.3-cp314-cp314-musllinux_1_2_aarch64.whl\", hash = \"sha256:373342dd05b1d07d752cecbec0c41817231f29f3a89aa8b8843f7b95992ed0c7\", size = 86945, upload-time = \"2025-08-12T05:52:21.581Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/d3/bd/4e70162ce398462a467bc09e768bee112f1412e563620adc353de9055d33/wrapt-1.17.3-cp314-cp314-musllinux_1_2_x86_64.whl\", hash = \"sha256:d40770d7c0fd5cbed9d84b2c3f2e156431a12c9a37dc6284060fb4bec0b7ffd4\", size = 86857, upload-time = \"2025-08-12T05:52:43.043Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/2b/b8/da8560695e9284810b8d3df8a19396a6e40e7518059584a1a394a2b35e0a/wrapt-1.17.3-cp314-cp314-win32.whl\", hash = \"sha256:fbd3c8319de8e1dc79d346929cd71d523622da527cca14e0c1d257e31c2b8b10\", size = 37178, upload-time = \"2025-08-12T05:53:12.605Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/db/c8/b71eeb192c440d67a5a0449aaee2310a1a1e8eca41676046f99ed2487e9f/wrapt-1.17.3-cp314-cp314-win_amd64.whl\", hash = \"sha256:e1a4120ae5705f673727d3253de3ed0e016f7cd78dc463db1b31e2463e1f3cf6\", size = 39310, upload-time = \"2025-08-12T05:53:11.106Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/45/20/2cda20fd4865fa40f86f6c46ed37a2a8356a7a2fde0773269311f2af56c7/wrapt-1.17.3-cp314-cp314-win_arm64.whl\", hash = \"sha256:507553480670cab08a800b9463bdb881b2edeed77dc677b0a5915e6106e91a58\", size = 37266, upload-time = \"2025-08-12T05:52:56.531Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/77/ed/dd5cf21aec36c80443c6f900449260b80e2a65cf963668eaef3b9accce36/wrapt-1.17.3-cp314-cp314t-macosx_10_13_universal2.whl\", hash = \"sha256:ed7c635ae45cfbc1a7371f708727bf74690daedc49b4dba310590ca0bd28aa8a\", size = 56544, upload-time = \"2025-08-12T05:51:51.109Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/8d/96/450c651cc753877ad100c7949ab4d2e2ecc4d97157e00fa8f45df682456a/wrapt-1.17.3-cp314-cp314t-macosx_10_13_x86_64.whl\", hash = \"sha256:249f88ed15503f6492a71f01442abddd73856a0032ae860de6d75ca62eed8067\", size = 40283, upload-time = \"2025-08-12T05:51:39.912Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/d1/86/2fcad95994d9b572db57632acb6f900695a648c3e063f2cd344b3f5c5a37/wrapt-1.17.3-cp314-cp314t-macosx_11_0_arm64.whl\", hash = \"sha256:5a03a38adec8066d5a37bea22f2ba6bbf39fcdefbe2d91419ab864c3fb515454\", size = 40366, upload-time = \"2025-08-12T05:52:00.693Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/64/0e/f4472f2fdde2d4617975144311f8800ef73677a159be7fe61fa50997d6c0/wrapt-1.17.3-cp314-cp314t-manylinux1_x86_64.manylinux_2_28_x86_64.manylinux_2_5_x86_64.whl\", hash = \"sha256:5d4478d72eb61c36e5b446e375bbc49ed002430d17cdec3cecb36993398e1a9e\", size = 108571, upload-time = \"2025-08-12T05:52:44.521Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/cc/01/9b85a99996b0a97c8a17484684f206cbb6ba73c1ce6890ac668bcf3838fb/wrapt-1.17.3-cp314-cp314t-manylinux2014_aarch64.manylinux_2_17_aarch64.manylinux_2_28_aarch64.whl\", hash = \"sha256:223db574bb38637e8230eb14b185565023ab624474df94d2af18f1cdb625216f\", size = 113094, upload-time = \"2025-08-12T05:52:22.618Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/25/02/78926c1efddcc7b3aa0bc3d6b33a822f7d898059f7cd9ace8c8318e559ef/wrapt-1.17.3-cp314-cp314t-musllinux_1_2_aarch64.whl\", hash = \"sha256:e405adefb53a435f01efa7ccdec012c016b5a1d3f35459990afc39b6be4d5056\", size = 110659, upload-time = \"2025-08-12T05:52:24.057Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/dc/ee/c414501ad518ac3e6fe184753632fe5e5ecacdcf0effc23f31c1e4f7bfcf/wrapt-1.17.3-cp314-cp314t-musllinux_1_2_x86_64.whl\", hash = \"sha256:88547535b787a6c9ce4086917b6e1d291aa8ed914fdd3a838b3539dc95c12804\", size = 106946, upload-time = \"2025-08-12T05:52:45.976Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/be/44/a1bd64b723d13bb151d6cc91b986146a1952385e0392a78567e12149c7b4/wrapt-1.17.3-cp314-cp314t-win32.whl\", hash = \"sha256:41b1d2bc74c2cac6f9074df52b2efbef2b30bdfe5f40cb78f8ca22963bc62977\", size = 38717, upload-time = \"2025-08-12T05:53:15.214Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/79/d9/7cfd5a312760ac4dd8bf0184a6ee9e43c33e47f3dadc303032ce012b8fa3/wrapt-1.17.3-cp314-cp314t-win_amd64.whl\", hash = \"sha256:73d496de46cd2cdbdbcce4ae4bcdb4afb6a11234a1df9c085249d55166b95116\", size = 41334, upload-time = \"2025-08-12T05:53:14.178Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/46/78/10ad9781128ed2f99dbc474f43283b13fea8ba58723e98844367531c18e9/wrapt-1.17.3-cp314-cp314t-win_arm64.whl\", hash = \"sha256:f38e60678850c42461d4202739f9bf1e3a737c7ad283638251e79cc49effb6b6\", size = 38471, upload-time = \"2025-08-12T05:52:57.784Z\" },\n-    { url = \"https://files.pythonhosted.org/packages/1f/f6/a933bd70f98e9cf3e08167fc5cd7aaaca49147e48411c0bd5ae701bb2194/wrapt-1.17.3-py3-none-any.whl\", hash = \"sha256:7171ae35d2c33d326ac19dd8facb1e82e5fd04ef8c6c0e394d7af55a55051c22\", size = 23591, upload-time = \"2025-08-12T05:53:20.674Z\" },\n-]\n-\n [[package]]\n name = \"zipp\"\n version = \"3.23.0\"\n", "test_patch": "", "problem_statement": "Multi-account: session binding causes all API calls to use first-authenticated account\n## Bug Description\n\nWhen using multiple Google accounts with workspace-mcp in stdio mode (e.g., via Claude Code), all API calls use the credentials of whichever Google account authenticated first in the session, regardless of the `user_google_email` parameter passed to each tool.\n\nFor example, if I have three accounts configured (`kartbala@gmail.com`, `karthik@balasubramanian.us`, `karthik@hub3.us`), and the first API call in a session happens to use `karthik@balasubramanian.us`, then all subsequent calls \u2014 even those explicitly specifying `user_google_email=\"kartbala@gmail.com\"` \u2014 will send/read/act as `karthik@balasubramanian.us`.\n\n## Steps to Reproduce\n\n1. Configure workspace-mcp with credentials for 2+ Google accounts (files in `~/.google_workspace_mcp/credentials/`)\n2. Start an MCP session (e.g., via Claude Code in stdio mode)\n3. Make a Gmail API call for Account A (e.g., `search_gmail_messages(user_google_email=\"account-a@gmail.com\", ...)`)\n4. Make a Gmail API call for Account B (e.g., `send_gmail_message(user_google_email=\"account-b@gmail.com\", ...)`)\n5. The second call silently uses Account A's credentials\n\n## Root Cause\n\nIn `auth/google_auth.py`, the `get_credentials()` function (around line 567) checks the OAuth 2.1 session store **first** using only the MCP `session_id`:\n\n```python\nif session_id:\n    store = get_oauth21_session_store()\n    credentials = store.get_credentials_by_mcp_session(session_id)\n    if credentials:\n        # Returns immediately \u2014 never checks if these match user_google_email\n        if credentials.valid:\n            return credentials\n```\n\nThe `get_credentials_by_mcp_session()` method looks up `_mcp_session_mapping[session_id]`, which maps to whichever user email was first stored for that session. The `user_google_email` parameter is only consulted in the fallback file-based credential lookup, which is never reached because the session store always returns credentials.\n\nAdditionally, the session binding in `oauth21_session_store.py` is explicitly immutable:\n\n```python\nif mcp_session_id not in self._session_auth_binding:\n    self._session_auth_binding[mcp_session_id] = user_email  # First binding wins\nelif self._session_auth_binding[mcp_session_id] != user_email:\n    raise ValueError(f\"Session {mcp_session_id} is already bound to a different user\")\n```\n\n## Suggested Fix\n\nIn `get_credentials()`, compare the session-mapped user with the requested `user_google_email` before returning session credentials. If they don't match, skip the session store and fall through to the file-based credential store:\n\n```python\ncredentials = store.get_credentials_by_mcp_session(session_id)\nif credentials:\n    session_user = store.get_user_by_mcp_session(session_id)\n    if user_google_email and session_user and session_user != user_google_email:\n        logger.info(\n            f\"Session user {session_user} doesn't match requested {user_google_email}, \"\n            \"skipping session store\"\n        )\n        credentials = None  # Fall through to file-based credential lookup\n    else:\n        # ... existing scope check / refresh / return logic\n```\n\n## Environment\n\n- workspace-mcp version: 1.9.0\n- Transport: stdio (via Claude Code CLI)\n- Python: 3.11\n- OS: macOS (Darwin 24.6.0)\n- 3 Google accounts configured with valid credential files\n\n## Workaround\n\nI've applied the patch above locally to the cached source at `~/.cache/uv/archive-v0/.../auth/google_auth.py`. This is fragile (lost on cache clean or version update) but confirms the fix works.\n", "hints_text": "\n\n", "all_hints_text": "Looks like this got introduced when the session management was centralized.  I will add a user\u2011mismatch check in get_credentials() and skip session cache in that case (both the early OAuth21 lookup and then later load_credentials_from_session). We won't re\u2011cache into the session if it\u2019s mismatched. This keeps behavior unchanged for single\u2011user sessions but honors user_google_email for multi\u2011account calls.\nWill be fixed in next release, live in main now. Thanks!\n\n", "commit_urls": ["https://github.com/taylorwilsdon/google_workspace_mcp/commit/75eb8fa1826d704463fa14c35df82db3557cebb2", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/b7d8f61cf7a05be25efaf74474c479b7eadc9ac8", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/1877d70077e7eaf73cfe3c7fa6bda6c48d04a5c5", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/b0743ec923d539f3bed1932accf55933378e4fb0", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/b30fc1c83d74a74ee8901771e86b1d6304d02428", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/ece2ee12d7eb658c683c513f23c5e333372a3fa1", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/fab19d69e0cea005d071ceb9010d928bdf958a29", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/88542afe31e2d9cbc958a6f5625aa7918930c597", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/bae425f754aa607a55fccab5ede03b092937b301", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/dbab29d35668da12ca98e2ead7845c38df8e8388", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/24dca1342586645ea1a14dc1b05c206645def82c", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/72f06d585309b3d7cc309328396aedeec454d7cc"], "created_at": "2026-02-06T19:34:46Z"}
{"repo": "taylorwilsdon/google_workspace_mcp", "pull_number": 459, "instance_id": "taylorwilsdon__google_workspace_mcp-459", "issue_numbers": [440], "base_commit": "ad53debf2f002207a2723b45504e6d0736ebc190", "patch": "diff --git a/.beads/issues.jsonl b/.beads/issues.jsonl\nindex 596d633db..e319d184b 100644\n--- a/.beads/issues.jsonl\n+++ b/.beads/issues.jsonl\n@@ -8,6 +8,7 @@\n {\"id\":\"google_workspace_mcp-bt4\",\"title\":\"fix: align MCP publish workflow with official mcp-publisher install flow\",\"description\":\"Replace unsupported uvx mcp-publisher usage and custom action reference with official mcp-publisher binary install + login github-oidc + publish steps from modelcontextprotocol.io docs.\",\"status\":\"closed\",\"priority\":1,\"issue_type\":\"bug\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T20:09:02.835985-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T20:25:11.414425-05:00\",\"closed_at\":\"2026-02-08T20:25:11.414425-05:00\",\"close_reason\":\"Closed\"}\n {\"id\":\"google_workspace_mcp-cdj\",\"title\":\"enh: return hyperlinks in read_sheet_values\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T17:39:12.213492-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T17:42:05.487691-05:00\",\"closed_at\":\"2026-02-08T17:42:05.487691-05:00\",\"close_reason\":\"Added unit tests covering hyperlink extraction and formatting used by read_sheet_values.\"}\n {\"id\":\"google_workspace_mcp-cla\",\"title\":\"address PR feedback on Sheets hyperlink range + Docs field/docstring comments\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T18:58:02.386849-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T18:59:37.960634-05:00\",\"closed_at\":\"2026-02-08T18:59:37.960634-05:00\",\"close_reason\":\"Closed\"}\n+{\"id\":\"google_workspace_mcp-dfz\",\"title\":\"fix: CLI mode fails on Gmail label modify defaults\",\"status\":\"closed\",\"priority\":1,\"issue_type\":\"bug\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-11T11:54:16.680388-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-11T11:55:32.346866-05:00\",\"closed_at\":\"2026-02-11T11:55:32.346866-05:00\",\"close_reason\":\"Closed\"}\n {\"id\":\"google_workspace_mcp-gpb\",\"title\":\"Address PR feedback for docs list nesting and sheets hyperlink fetch\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T17:48:48.31354-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T17:51:53.608353-05:00\",\"closed_at\":\"2026-02-08T17:51:53.608353-05:00\",\"close_reason\":\"Closed\"}\n {\"id\":\"google_workspace_mcp-ic8\",\"title\":\"enh: support writing hyperlink URLs in modify_sheet_values\",\"description\":\"Issue #434 also requested hyperlink creation/writes. Current implementation reads hyperlinks in read_sheet_values but modify_sheet_values does not expose first-class hyperlink writes.\",\"status\":\"open\",\"priority\":3,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T17:42:10.590658-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T17:42:10.590658-05:00\"}\n {\"id\":\"google_workspace_mcp-jf2\",\"title\":\"ci: make PyPI publish step rerun-safe with skip-existing\",\"description\":\"GitHub Actions reruns on same tag fail because PyPI rejects duplicate file uploads. Add skip-existing=true to pypa/gh-action-pypi-publish so reruns proceed to MCP publish.\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"bug\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T20:59:58.461102-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T21:00:32.121469-05:00\",\"closed_at\":\"2026-02-08T21:00:32.121469-05:00\",\"close_reason\":\"Closed\"}\ndiff --git a/gmail/gmail_tools.py b/gmail/gmail_tools.py\nindex 22f275020..3ce915b03 100644\n--- a/gmail/gmail_tools.py\n+++ b/gmail/gmail_tools.py\n@@ -1829,12 +1829,8 @@ async def modify_gmail_message_labels(\n     service,\n     user_google_email: str,\n     message_id: str,\n-    add_label_ids: List[str] = Field(\n-        default=[], description=\"Label IDs to add to the message.\"\n-    ),\n-    remove_label_ids: List[str] = Field(\n-        default=[], description=\"Label IDs to remove from the message.\"\n-    ),\n+    add_label_ids: Optional[List[str]] = None,\n+    remove_label_ids: Optional[List[str]] = None,\n ) -> str:\n     \"\"\"\n     Adds or removes labels from a Gmail message.\n@@ -1885,12 +1881,8 @@ async def batch_modify_gmail_message_labels(\n     service,\n     user_google_email: str,\n     message_ids: List[str],\n-    add_label_ids: List[str] = Field(\n-        default=[], description=\"Label IDs to add to messages.\"\n-    ),\n-    remove_label_ids: List[str] = Field(\n-        default=[], description=\"Label IDs to remove from messages.\"\n-    ),\n+    add_label_ids: Optional[List[str]] = None,\n+    remove_label_ids: Optional[List[str]] = None,\n ) -> str:\n     \"\"\"\n     Adds or removes labels from multiple Gmail messages in a single batch request.\n", "test_patch": "", "problem_statement": "Bug: FieldInfo is not JSON serializable in CLI mode for modify_gmail_message_labels\n## Describe the bug\n\nWhen invoking `modify_gmail_message_labels` or `batch_modify_gmail_message_labels` via `--cli` mode, the call fails with:\n\n```\nError: Exception: An unexpected error occurred in modify_gmail_message_labels: Object of type FieldInfo is not JSON serializable\n```\n\nThe same call works correctly via the native MCP server protocol.\n\n## To Reproduce\n\n```bash\nworkspace-mcp --cli modify_gmail_message_labels --args '{\n  \"message_id\": \"19bdbee2b1f60be2\",\n  \"remove_label_ids\": [\"STARRED\"]\n}'\n```\n\n**Result:** `Object of type FieldInfo is not JSON serializable`\n\n**Expected:** `Message labels updated successfully!`\n\n## Root Cause\n\nIn `gmail/gmail_tools.py`, the functions `modify_gmail_message_labels` (line ~1820) and `batch_modify_gmail_message_labels` (line ~1876) use Pydantic `Field()` as default values for optional list parameters:\n\n```python\nasync def modify_gmail_message_labels(\n    service,\n    user_google_email: str,\n    message_id: str,\n    add_label_ids: List[str] = Field(\n        default=[], description=\"Label IDs to add to the message.\"\n    ),\n    remove_label_ids: List[str] = Field(\n        default=[], description=\"Label IDs to remove from the message.\"\n    ),\n) -> str:\n```\n\n`Field()` returns a `FieldInfo` metadata object, not `[]`. When FastMCP serves this tool via the MCP protocol, Pydantic's model validation resolves `FieldInfo` into the actual default value \u2014 so the MCP server works fine. But when the CLI handler in `core/cli_handler.py` calls `fn(**args)` directly (line 241), Python uses the raw `FieldInfo` object as the default. This `FieldInfo` object then propagates until something tries to serialize or iterate over it, causing the crash.\n\n## Proposed Fix\n\nReplace `Field(default=[], description=\"...\")` with plain `[]` defaults. The parameter descriptions are already documented in the docstring, which FastMCP uses for schema generation.\n\n```diff\n--- a/gmail/gmail_tools.py\n+++ b/gmail/gmail_tools.py\n@@ modify_gmail_message_labels\n     service,\n     user_google_email: str,\n     message_id: str,\n-    add_label_ids: List[str] = Field(\n-        default=[], description=\"Label IDs to add to the message.\"\n-    ),\n-    remove_label_ids: List[str] = Field(\n-        default=[], description=\"Label IDs to remove from the message.\"\n-    ),\n+    add_label_ids: List[str] = [],\n+    remove_label_ids: List[str] = [],\n ) -> str:\n```\n\nSame change for `batch_modify_gmail_message_labels`.\n\n**Note:** `Field(...)` (required marker, line ~1780) is unaffected \u2014 only `Field(default=...)` with optional defaults causes the issue.\n\n## Affected Functions\n\n| Function | File | Line |\n|----------|------|------|\n| `modify_gmail_message_labels` | `gmail/gmail_tools.py` | ~1820 |\n| `batch_modify_gmail_message_labels` | `gmail/gmail_tools.py` | ~1876 |\n\nHappy to submit a PR for this if you'd like.\n", "hints_text": "Love seeing folks using the CLI! Fix will be there shortly. \n\n", "all_hints_text": "Love seeing folks using the CLI! Fix will be there shortly. \n\n", "commit_urls": ["https://github.com/taylorwilsdon/google_workspace_mcp/commit/f6aaf75b4fc91c35c6227508a1efed887686e93e", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/d31e2816a400522a8134e2f4850aaa322324e6af", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/22320946161e5bbb5bcd374caf4c368247af4d30", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/a24804771afe3d576bdf9b470d43e3d15e148e82"], "created_at": "2026-02-11T16:58:45Z"}
{"repo": "taylorwilsdon/google_workspace_mcp", "pull_number": 442, "instance_id": "taylorwilsdon__google_workspace_mcp-442", "issue_numbers": [441], "base_commit": "53de23263939db254d78d084e1d96d5b0966c27e", "patch": "diff --git a/gappsscript/apps_script_tools.py b/gappsscript/apps_script_tools.py\nindex 39244c0be..20cba1088 100644\n--- a/gappsscript/apps_script_tools.py\n+++ b/gappsscript/apps_script_tools.py\n@@ -105,8 +105,10 @@ async def _get_script_project_impl(\n     \"\"\"Internal implementation for get_script_project.\"\"\"\n     logger.info(f\"[get_script_project] Email: {user_google_email}, ID: {script_id}\")\n \n-    project = await asyncio.to_thread(\n-        service.projects().get(scriptId=script_id).execute\n+    # Get project metadata and content concurrently (independent requests)\n+    project, content = await asyncio.gather(\n+        asyncio.to_thread(service.projects().get(scriptId=script_id).execute),\n+        asyncio.to_thread(service.projects().getContent(scriptId=script_id).execute),\n     )\n \n     title = project.get(\"title\", \"Untitled\")\n@@ -124,7 +126,7 @@ async def _get_script_project_impl(\n         \"Files:\",\n     ]\n \n-    files = project.get(\"files\", [])\n+    files = content.get(\"files\", [])\n     for i, file in enumerate(files, 1):\n         file_name = file.get(\"name\", \"Untitled\")\n         file_type = file.get(\"type\", \"Unknown\")\n@@ -172,11 +174,12 @@ async def _get_script_content_impl(\n         f\"[get_script_content] Email: {user_google_email}, ID: {script_id}, File: {file_name}\"\n     )\n \n-    project = await asyncio.to_thread(\n-        service.projects().get(scriptId=script_id).execute\n+    # Must use getContent() to retrieve files, not get() which only returns metadata\n+    content = await asyncio.to_thread(\n+        service.projects().getContent(scriptId=script_id).execute\n     )\n \n-    files = project.get(\"files\", [])\n+    files = content.get(\"files\", [])\n     target_file = None\n \n     for file in files:\n", "test_patch": "diff --git a/tests/gappsscript/test_apps_script_tools.py b/tests/gappsscript/test_apps_script_tools.py\nindex 57047620a..461a32279 100644\n--- a/tests/gappsscript/test_apps_script_tools.py\n+++ b/tests/gappsscript/test_apps_script_tools.py\n@@ -62,12 +62,19 @@ async def test_list_script_projects():\n async def test_get_script_project():\n     \"\"\"Test retrieving complete project details\"\"\"\n     mock_service = Mock()\n-    mock_response = {\n+\n+    # projects().get() returns metadata only (no files)\n+    mock_metadata_response = {\n         \"scriptId\": \"test123\",\n         \"title\": \"Test Project\",\n         \"creator\": {\"email\": \"creator@example.com\"},\n         \"createTime\": \"2025-01-10T10:00:00Z\",\n         \"updateTime\": \"2026-01-12T15:30:00Z\",\n+    }\n+\n+    # projects().getContent() returns files with source code\n+    mock_content_response = {\n+        \"scriptId\": \"test123\",\n         \"files\": [\n             {\n                 \"name\": \"Code\",\n@@ -77,7 +84,8 @@ async def test_get_script_project():\n         ],\n     }\n \n-    mock_service.projects().get().execute.return_value = mock_response\n+    mock_service.projects().get().execute.return_value = mock_metadata_response\n+    mock_service.projects().getContent().execute.return_value = mock_content_response\n \n     result = await _get_script_project_impl(\n         service=mock_service, user_google_email=\"test@example.com\", script_id=\"test123\"\n", "problem_statement": "get_script_project and get_script_content return empty files for container-bound scripts\n## Bug Description\n\nget_script_project returns project metadata but the files list is always empty for container-bound Apps Script projects. Similarly, get_script_content returns File not found for all files.\n\n## Steps to Reproduce\n\n1. Have a Google Sheets spreadsheet with a container-bound Apps Script project\n2. Get the script ID from the Apps Script editor URL\n3. Call get_script_project with the script ID - metadata returned but Files section empty\n4. Call get_script_content with any file name - File not found\n\n## Workaround\n\nCalling the API directly works: GET /v1/projects/{scriptId}/content returns all files with source code (HTTP 200).\n\n## Root Cause\n\nIn gappsscript/apps_script_tools.py, both _get_script_project_impl and _get_script_content_impl call service.projects().get() which only returns metadata, NOT file contents. The correct method is service.projects().getContent().\n\n- projects().get() -> GET /v1/projects/{scriptId} (metadata only)\n- projects().getContent() -> GET /v1/projects/{scriptId}/content (includes files)\n\n## Proposed Fix\n\nReplace projects().get() with projects().getContent() in both functions. The existing .get(\"files\", []) parsing will work once the API actually returns the files array.\n\nNote: unit tests mock projects().get() with a files array, masking this bug since the real API never returns files with get().\n\n## Environment\n\n- workspace-mcp v1.10.7 via uvx\n- Transport: stdio\n- Scopes: script.projects, script.projects.readonly\n- FastMCP 2.14.5, Linux\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/taylorwilsdon/google_workspace_mcp/commit/2af9ced64ddb974bee6f6f80cb60bc3f882ef6c6", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/ee2bf4b89384b0dc60bc00e6b483f8cf3bfe8e0b", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/9bd3bedec6fa71f705faa3f54df6d04b47fe8864"], "created_at": "2026-02-09T16:49:43Z"}
{"repo": "taylorwilsdon/google_workspace_mcp", "pull_number": 444, "instance_id": "taylorwilsdon__google_workspace_mcp-444", "issue_numbers": [443], "base_commit": "6c32126796f990888fe0844b8725ca37048b55f9", "patch": "diff --git a/.beads/issues.jsonl b/.beads/issues.jsonl\nindex b2bde9a02..a6d0c921b 100644\n--- a/.beads/issues.jsonl\n+++ b/.beads/issues.jsonl\n@@ -1,6 +1,7 @@\n {\"id\":\"google_workspace_mcp-016\",\"title\":\"fix: correct MCP registry PyPI ownership metadata\",\"description\":\"Twine/PyPI rejects project.urls mcp-name because URL values must be valid URLs. For MCP registry PyPI verification, use README marker mcp-name: \\u003cserver-name\\u003e and ensure server.json name uses io.github.\\u003cuser\\u003e/\\u003cserver\\u003e format.\",\"status\":\"closed\",\"priority\":1,\"issue_type\":\"bug\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T20:04:06.49156-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T20:05:35.18854-05:00\",\"closed_at\":\"2026-02-08T20:05:35.18854-05:00\",\"close_reason\":\"Closed\"}\n {\"id\":\"google_workspace_mcp-0fl\",\"title\":\"enh: add MCP registry publish to local release.py flow\",\"description\":\"Extend scripts/release.py to sync server.json version and publish to MCP Registry via mcp-publisher during local release process, so publishing does not depend on GitHub Actions.\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T21:03:51.388408-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T21:06:05.334395-05:00\",\"closed_at\":\"2026-02-08T21:06:05.334395-05:00\",\"close_reason\":\"Closed\"}\n {\"id\":\"google_workspace_mcp-2mc\",\"title\":\"release: cut next PyPI version and publish MCP registry entry\",\"description\":\"Run local release flow: uv run python scripts/release.py to publish PyPI + MCP Registry via mcp-publisher. Verify package version on PyPI and server listing in registry search endpoint.\",\"status\":\"open\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T20:00:39.779476-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T21:06:15.613447-05:00\"}\n+{\"id\":\"google_workspace_mcp-3bn\",\"title\":\"Fix AppScript run_script_function schema for Gemini API\",\"description\":\"The run_script_function tool has a 'parameters' parameter defined as Optional[List[Any]] which causes schema generation issues with the Gemini API. The error is: 'GenerateContentRequest.tools[0].function_declarations[125].parameters.properties[parameters].items: missing field'. Need to fix the type annotation to generate proper JSON schema with items field.\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"bug\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-09T14:16:48.857746-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-09T14:21:43.5927-05:00\",\"closed_at\":\"2026-02-09T14:21:43.5927-05:00\",\"close_reason\":\"Fixed by changing parameters type from Optional[List[Any]] to Optional[list] in run_script_function. This ensures proper JSON schema generation with items field for Gemini API compatibility.\"}\n {\"id\":\"google_workspace_mcp-631\",\"title\":\"Address copilot feedback for docs/sheets hyperlink range and extraction\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T18:36:22.330879-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T18:38:04.356856-05:00\",\"closed_at\":\"2026-02-08T18:38:04.356856-05:00\",\"close_reason\":\"Closed\"}\n {\"id\":\"google_workspace_mcp-6u3\",\"title\":\"Add paragraph-level list formatting support\",\"description\":\"Enhance update_paragraph_style to support creating bulleted/numbered lists with nested indentation levels for existing text. This enables agents to create well-structured documents that match professional document styles.\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"feature\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T15:39:00.54521-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T15:42:43.907629-05:00\",\"closed_at\":\"2026-02-08T15:42:43.907629-05:00\",\"close_reason\":\"Successfully implemented paragraph-level list formatting support. Enhanced update_paragraph_style tool to support creating bulleted/numbered lists with nested indentation levels (0-8). Updated helper function create_bullet_list_request to accept nesting_level parameter. Updated documentation in README.md, docs/README.md, and docs/README_NEW.md.\"}\n {\"id\":\"google_workspace_mcp-a37\",\"title\":\"docs: guide for automated MCP registry publishing workflow\",\"description\":\"Document how .github/workflows/publish-mcp-registry.yml works, required one-time setup (PyPI Trusted Publisher, GitHub Actions permissions), release tagging flow, validation behavior, and troubleshooting.\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T20:32:32.510532-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T20:34:21.318493-05:00\",\"closed_at\":\"2026-02-08T20:34:21.318493-05:00\",\"close_reason\":\"Closed\"}\ndiff --git a/.gitignore b/.gitignore\nindex 3f5804fd1..16c5d7bff 100644\n--- a/.gitignore\n+++ b/.gitignore\n@@ -4,6 +4,7 @@ __pycache__/\n *.so\n .mcp.json\n claude.md\n+.beads/*\n \n # ---- Packaging ---------------------------------------------------------\n *.egg-info/\ndiff --git a/gappsscript/apps_script_tools.py b/gappsscript/apps_script_tools.py\nindex 0b4104442..39244c0be 100644\n--- a/gappsscript/apps_script_tools.py\n+++ b/gappsscript/apps_script_tools.py\n@@ -338,7 +338,7 @@ async def _run_script_function_impl(\n     user_google_email: str,\n     script_id: str,\n     function_name: str,\n-    parameters: Optional[List[Any]] = None,\n+    parameters: Optional[list[object]] = None,\n     dev_mode: bool = False,\n ) -> str:\n     \"\"\"Internal implementation for run_script_function.\"\"\"\n@@ -386,7 +386,7 @@ async def run_script_function(\n     user_google_email: str,\n     script_id: str,\n     function_name: str,\n-    parameters: Optional[List[Any]] = None,\n+    parameters: Optional[list[object]] = None,\n     dev_mode: bool = False,\n ) -> str:\n     \"\"\"\ndiff --git a/uv.lock b/uv.lock\nindex 6bb555f1d..95286bc2f 100644\n--- a/uv.lock\n+++ b/uv.lock\n@@ -2195,7 +2195,7 @@ wheels = [\n \n [[package]]\n name = \"workspace-mcp\"\n-version = \"1.10.6\"\n+version = \"1.10.7\"\n source = { editable = \".\" }\n dependencies = [\n     { name = \"cryptography\" },\n", "test_patch": "", "problem_statement": "Bug: INVALID_ARGUMENT Schema Error in AppScript Tools when using langchain-google-genai\n**Describe the bug**\nWhen using the Google Workspace MCP server with langchain-google-genai and ChatGoogleGenerativeAI, the initialization fails with a 400 INVALID_ARGUMENT error.\n\nThe error message specifically points to a missing field in the tool definitions: GenerateContentRequest.tools[0].function_declarations[125].parameters.properties[parameters].items: missing field.\n\nAfter iterating through the loaded tools, I identified that the error originates specifically from the AppScript tools (index 125). Excluding the AppScript module allows the client to initialize successfully.\n\n**Startup Logs**\n```plaintext\n\ud83d\udd27 Google Workspace MCP Server\n===================================\n\ud83d\udccb Server Information:\n   \ud83d\udce6 Version: 1.10.7\n   \ud83c\udf10 Transport: streamable-http\n   \ud83d\udd17 URL: http://localhost:8000\n   \ud83d\udc64 Mode: Multi-user\n   \ud83d\udc0d Python: 3.11.14\n\n\u2699\ufe0f Active Configuration:\n   - MCP_SINGLE_USER_MODE: false\n   - MCP_ENABLE_OAUTH21: true\n   - WORKSPACE_MCP_STATELESS_MODE: true\n\n[AUTH] Scope management configured for tools: ['gmail', 'drive', 'calendar', 'docs', 'sheets', 'chat', 'forms', 'slides', 'tasks', 'contacts', 'search', 'appscript']\n\ud83d\udee0\ufe0f  Loading 12 tool modules:\n   ...\n   \ud83d\udcdc Appscript - Google Appscript API integration\n```\n\n**To Reproduce**\nSteps to reproduce the behavior:\n1. Start the MCP server with the AppScript tool enabled (default behavior): `uv run main.py --transport streamable-http`\n2. Initialize a client using langchain-google-genai and MultiServerMCPClient.\n3. Fetch tools and attempt to bind them to the Gemini model:\n```python\nllm = ChatGoogleGenerativeAI(model=\"gemini-3-flash-preview\n\") # or any gemini 2.5 up models\nllm_with_tools = llm.bind_tools(mcp_tools)\nawait llm_with_tools.ainvoke(\"...\")\n```\nSee error: \n`langchain_google_genai.chat_models.ChatGoogleGenerativeAIError: Error calling model 'gemini-3-flash-preview' (INVALID_ARGUMENT): 400 INVALID_ARGUMENT. {'error': {'code': 400, 'message': '* GenerateContentRequest.tools[0].function_declarations[125].parameters.properties[parameters].items: missing field.\\n', 'status': 'INVALID_ARGUMENT'}}`\n\n**Expected behavior**\nThe `ChatGoogleGenerativeAI` model should accept the tool schema generated by the AppScript module without throwing a validation error, similar to how it handles the Gmail or Drive tools.\n**Screenshots**\n\n<img width=\"267\" height=\"448\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/65309e57-a0ff-48ee-b5a1-9131da469f21\" />\n\n<img width=\"721\" height=\"173\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/5f385684-3242-4689-bae3-6f640e8a4193\" />\n\n**Platform (please complete the following information):**\n - OS: [e.g. macOS, Ubuntu, Windows]\n - Version: v1.10.7 (MCP Server)\n - Python: 3.11.14\n\n**Additional context**\nThe specific error indicates that the Gemini API requires strict schema definitions for array items, which seems to be missing in one of the AppScript function parameters.\n\n**Relevant Environment Deps:**\n```plaintext\nlangchain-google-genai==4.2.0\nlangchain-mcp-adapters==0.2.1\nmcp==1.26.0\n```\n", "hints_text": "Excellent bug report, thank you! Will get this sorted out. \n\n", "all_hints_text": "Excellent bug report, thank you! Will get this sorted out. \n\n", "commit_urls": ["https://github.com/taylorwilsdon/google_workspace_mcp/commit/8eac9c05750398aa49add07bf1ef81917afa0606", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/a89735343546c9d7a97a87762dd441c481da3202", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/ce9d4190e104f9cd1a7ee9eebb20db4bd82edb19", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/4c09a35c0f76b825bb303355d82ae97b3baec5e8"], "created_at": "2026-02-09T19:22:21Z"}
{"repo": "taylorwilsdon/google_workspace_mcp", "pull_number": 450, "instance_id": "taylorwilsdon__google_workspace_mcp-450", "issue_numbers": [448], "base_commit": "58a730f735b7ff96fd815187ea8502c573360314", "patch": "diff --git a/.beads/issues.jsonl b/.beads/issues.jsonl\nindex a6d0c921b..1df032f04 100644\n--- a/.beads/issues.jsonl\n+++ b/.beads/issues.jsonl\n@@ -12,6 +12,7 @@\n {\"id\":\"google_workspace_mcp-ic8\",\"title\":\"enh: support writing hyperlink URLs in modify_sheet_values\",\"description\":\"Issue #434 also requested hyperlink creation/writes. Current implementation reads hyperlinks in read_sheet_values but modify_sheet_values does not expose first-class hyperlink writes.\",\"status\":\"open\",\"priority\":3,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T17:42:10.590658-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T17:42:10.590658-05:00\"}\n {\"id\":\"google_workspace_mcp-jf2\",\"title\":\"ci: make PyPI publish step rerun-safe with skip-existing\",\"description\":\"GitHub Actions reruns on same tag fail because PyPI rejects duplicate file uploads. Add skip-existing=true to pypa/gh-action-pypi-publish so reruns proceed to MCP publish.\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"bug\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T20:59:58.461102-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T21:00:32.121469-05:00\",\"closed_at\":\"2026-02-08T21:00:32.121469-05:00\",\"close_reason\":\"Closed\"}\n {\"id\":\"google_workspace_mcp-qfl\",\"title\":\"Fix stdio multi-account session binding\",\"status\":\"in_progress\",\"priority\":1,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-07T13:27:09.466282-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-07T13:27:22.857227-05:00\"}\n+{\"id\":\"google_workspace_mcp-xia\",\"title\":\"fix: CLI should unwrap FastAPI Body defaults when invoking tools\",\"description\":\"CLI mode invokes tool functions directly and currently passes FastAPI Body marker objects as defaults for omitted args. This breaks gmail send/draft with errors like Body has no attribute lower/len. Update CLI invocation to normalize Param defaults and return clear missing-required errors.\",\"status\":\"closed\",\"priority\":1,\"issue_type\":\"bug\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-10T12:33:06.83139-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-10T12:36:35.051947-05:00\",\"closed_at\":\"2026-02-10T12:36:35.051947-05:00\",\"close_reason\":\"Implemented CLI FastAPI default normalization + regression tests\",\"labels\":[\"cli\",\"gmail\"]}\n {\"id\":\"google_workspace_mcp-xt2\",\"title\":\"Implement CLI mode for Workspace MCP\",\"description\":\"Create a CLI mode for the Workspace MCP server, activated via --cli flag, that allows all tools to be used directly from the command line without running as an MCP server.\\n\\n**Goals:**\\n- Add --cli startup flag to enable CLI mode\\n- Expose all existing tools as CLI subcommands\\n- No changes to individual tool implementations - reuse existing code\\n- Lightweight and flexible design\\n- Enable usage by coding agents (Codex, Claude Code) without MCP server overhead\\n\\n**Requirements:**\\n- Parse tool name and arguments from command line\\n- Route to existing tool handlers\\n- Output results to stdout (JSON or human-readable)\\n- Maintain same authentication/credential flow\\n- Support all current tools without modification\",\"status\":\"in_progress\",\"priority\":0,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-01T10:57:29.920078-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-01T11:02:26.818109-05:00\"}\n {\"id\":\"google_workspace_mcp-y3j\",\"title\":\"docs: add MCP registry publishing guidance for this server\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T19:56:42.74673-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T20:00:56.253918-05:00\",\"closed_at\":\"2026-02-08T20:00:56.253918-05:00\",\"close_reason\":\"Closed\"}\n {\"id\":\"google_workspace_mcp-z0a\",\"title\":\"Remove deprecated create_list alias from update_paragraph_style\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T18:12:22.714628-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T18:13:12.931513-05:00\",\"closed_at\":\"2026-02-08T18:13:12.931513-05:00\",\"close_reason\":\"Closed\"}\ndiff --git a/core/cli_handler.py b/core/cli_handler.py\nindex a5113155c..f54b90eb2 100644\n--- a/core/cli_handler.py\n+++ b/core/cli_handler.py\n@@ -14,15 +14,110 @@\n \"\"\"\n \n import asyncio\n+import inspect\n import json\n import logging\n import sys\n from typing import Any, Dict, List, Optional\n \n from auth.oauth_config import set_transport_mode\n+from pydantic_core import PydanticUndefined as _PYDANTIC_UNDEFINED\n \n logger = logging.getLogger(__name__)\n \n+_PYDANTIC_UNDEFINED_TYPE = type(_PYDANTIC_UNDEFINED)\n+\n+\n+def _is_fastapi_param_marker(default: Any) -> bool:\n+    \"\"\"\n+    Check if a default value is a FastAPI parameter marker (Body, Query, etc.).\n+\n+    These markers are metadata for HTTP request parsing and should not be passed\n+    directly to tool functions in CLI mode.\n+    \"\"\"\n+    default_type = type(default)\n+    return default_type.__module__ == \"fastapi.params\" and hasattr(\n+        default, \"get_default\"\n+    )\n+\n+\n+def _is_required_marker_default(value: Any) -> bool:\n+    \"\"\"Check whether a FastAPI/Pydantic default represents a required field.\"\"\"\n+    if value is Ellipsis or value is inspect.Parameter.empty:\n+        return True\n+\n+    return value is _PYDANTIC_UNDEFINED or isinstance(value, _PYDANTIC_UNDEFINED_TYPE)\n+\n+\n+def _extract_fastapi_default(default_marker: Any) -> tuple[bool, Any]:\n+    \"\"\"\n+    Resolve the runtime default from a FastAPI marker.\n+\n+    Returns:\n+        Tuple of (is_required, resolved_default)\n+    \"\"\"\n+    try:\n+        resolved_default = default_marker.get_default(call_default_factory=True)\n+    except TypeError:\n+        # Compatibility path for implementations without call_default_factory kwarg\n+        resolved_default = default_marker.get_default()\n+    except Exception:\n+        resolved_default = getattr(default_marker, \"default\", inspect.Parameter.empty)\n+\n+    return _is_required_marker_default(resolved_default), resolved_default\n+\n+\n+def _normalize_cli_args_for_tool(fn, args: Dict[str, Any]) -> Dict[str, Any]:\n+    \"\"\"\n+    Fill omitted CLI args for FastAPI markers with their real defaults.\n+\n+    When tools are invoked via HTTP, FastAPI resolves Body/Query/... defaults.\n+    In CLI mode we invoke functions directly, so we need to do that resolution.\n+    \"\"\"\n+    normalized_args = dict(args)\n+    signature = inspect.signature(fn)\n+    missing_required = []\n+\n+    for param in signature.parameters.values():\n+        if param.kind in (\n+            inspect.Parameter.VAR_POSITIONAL,\n+            inspect.Parameter.VAR_KEYWORD,\n+        ):\n+            continue\n+\n+        if param.name in normalized_args:\n+            continue\n+\n+        if param.default is inspect.Parameter.empty:\n+            continue\n+\n+        if not _is_fastapi_param_marker(param.default):\n+            continue\n+\n+        is_required, resolved_default = _extract_fastapi_default(param.default)\n+        if is_required or resolved_default is inspect.Parameter.empty:\n+            missing_required.append(param.name)\n+        else:\n+            normalized_args[param.name] = resolved_default\n+\n+    if missing_required:\n+        if len(missing_required) == 1:\n+            missing = missing_required[0]\n+            raise TypeError(\n+                f\"{fn.__name__}() missing 1 required positional argument: '{missing}'\"\n+            )\n+\n+        missing_names = [f\"'{name}'\" for name in missing_required]\n+        if len(missing_names) == 2:\n+            missing = \" and \".join(missing_names)\n+        else:\n+            missing = \", \".join(missing_names[:-1]) + f\" and {missing_names[-1]}\"\n+        raise TypeError(\n+            f\"{fn.__name__}() missing {len(missing_required)} required positional arguments: {missing}\"\n+        )\n+\n+    return normalized_args\n+\n \n def get_registered_tools(server) -> Dict[str, Any]:\n     \"\"\"\n@@ -233,14 +328,19 @@ async def run_tool(server, tool_name: str, args: Dict[str, Any]) -> str:\n     if fn is None:\n         raise ValueError(f\"Tool '{tool_name}' has no callable function\")\n \n-    logger.debug(f\"[CLI] Executing tool: {tool_name} with args: {list(args.keys())}\")\n+    call_args = dict(args)\n \n     try:\n+        call_args = _normalize_cli_args_for_tool(fn, args)\n+        logger.debug(\n+            f\"[CLI] Executing tool: {tool_name} with args: {list(call_args.keys())}\"\n+        )\n+\n         # Call the tool function\n         if asyncio.iscoroutinefunction(fn):\n-            result = await fn(**args)\n+            result = await fn(**call_args)\n         else:\n-            result = fn(**args)\n+            result = fn(**call_args)\n \n         # Convert result to string if needed\n         if isinstance(result, str):\n@@ -257,7 +357,7 @@ async def run_tool(server, tool_name: str, args: Dict[str, Any]) -> str:\n         return (\n             f\"Error calling {tool_name}: {error_msg}\\n\\n\"\n             f\"Required parameters: {required}\\n\"\n-            f\"Provided parameters: {list(args.keys())}\"\n+            f\"Provided parameters: {list(call_args.keys())}\"\n         )\n     except Exception as e:\n         logger.error(f\"[CLI] Error executing {tool_name}: {e}\", exc_info=True)\ndiff --git a/gmail/gmail_tools.py b/gmail/gmail_tools.py\nindex 2edc796fe..1c74a9e02 100644\n--- a/gmail/gmail_tools.py\n+++ b/gmail/gmail_tools.py\n@@ -19,7 +19,7 @@\n from email import encoders\n from email.utils import formataddr\n \n-from fastapi import Body\n+from fastapi import Body as BodyParam\n from pydantic import Field\n \n from auth.service_decorator import require_google_service\n@@ -989,33 +989,33 @@ async def get_gmail_attachment_content(\n async def send_gmail_message(\n     service,\n     user_google_email: str,\n-    to: str = Body(..., description=\"Recipient email address.\"),\n-    subject: str = Body(..., description=\"Email subject.\"),\n-    body: str = Body(..., description=\"Email body content (plain text or HTML).\"),\n-    body_format: Literal[\"plain\", \"html\"] = Body(\n+    to: str = BodyParam(..., description=\"Recipient email address.\"),\n+    subject: str = BodyParam(..., description=\"Email subject.\"),\n+    body: str = BodyParam(..., description=\"Email body content (plain text or HTML).\"),\n+    body_format: Literal[\"plain\", \"html\"] = BodyParam(\n         \"plain\",\n         description=\"Email body format. Use 'plain' for plaintext or 'html' for HTML content.\",\n     ),\n-    cc: Optional[str] = Body(None, description=\"Optional CC email address.\"),\n-    bcc: Optional[str] = Body(None, description=\"Optional BCC email address.\"),\n-    from_name: Optional[str] = Body(\n+    cc: Optional[str] = BodyParam(None, description=\"Optional CC email address.\"),\n+    bcc: Optional[str] = BodyParam(None, description=\"Optional BCC email address.\"),\n+    from_name: Optional[str] = BodyParam(\n         None,\n         description=\"Optional sender display name (e.g., 'Peter Hartree'). If provided, the From header will be formatted as 'Name <email>'.\",\n     ),\n-    from_email: Optional[str] = Body(\n+    from_email: Optional[str] = BodyParam(\n         None,\n         description=\"Optional 'Send As' alias email address. Must be configured in Gmail settings (Settings > Accounts > Send mail as). If not provided, uses the authenticated user's email.\",\n     ),\n-    thread_id: Optional[str] = Body(\n+    thread_id: Optional[str] = BodyParam(\n         None, description=\"Optional Gmail thread ID to reply within.\"\n     ),\n-    in_reply_to: Optional[str] = Body(\n+    in_reply_to: Optional[str] = BodyParam(\n         None, description=\"Optional Message-ID of the message being replied to.\"\n     ),\n-    references: Optional[str] = Body(\n+    references: Optional[str] = BodyParam(\n         None, description=\"Optional chain of Message-IDs for proper threading.\"\n     ),\n-    attachments: Optional[List[Dict[str, str]]] = Body(\n+    attachments: Optional[List[Dict[str, str]]] = BodyParam(\n         None,\n         description='Optional list of attachments. Each can have: \"path\" (file path, auto-encodes), OR \"content\" (standard base64, not urlsafe) + \"filename\". Optional \"mime_type\". Example: [{\"path\": \"/path/to/file.pdf\"}] or [{\"filename\": \"doc.pdf\", \"content\": \"base64data\", \"mime_type\": \"application/pdf\"}]',\n     ),\n@@ -1161,33 +1161,35 @@ async def send_gmail_message(\n async def draft_gmail_message(\n     service,\n     user_google_email: str,\n-    subject: str = Body(..., description=\"Email subject.\"),\n-    body: str = Body(..., description=\"Email body (plain text).\"),\n-    body_format: Literal[\"plain\", \"html\"] = Body(\n+    subject: str = BodyParam(..., description=\"Email subject.\"),\n+    body: str = BodyParam(..., description=\"Email body (plain text).\"),\n+    body_format: Literal[\"plain\", \"html\"] = BodyParam(\n         \"plain\",\n         description=\"Email body format. Use 'plain' for plaintext or 'html' for HTML content.\",\n     ),\n-    to: Optional[str] = Body(None, description=\"Optional recipient email address.\"),\n-    cc: Optional[str] = Body(None, description=\"Optional CC email address.\"),\n-    bcc: Optional[str] = Body(None, description=\"Optional BCC email address.\"),\n-    from_name: Optional[str] = Body(\n+    to: Optional[str] = BodyParam(\n+        None, description=\"Optional recipient email address.\"\n+    ),\n+    cc: Optional[str] = BodyParam(None, description=\"Optional CC email address.\"),\n+    bcc: Optional[str] = BodyParam(None, description=\"Optional BCC email address.\"),\n+    from_name: Optional[str] = BodyParam(\n         None,\n         description=\"Optional sender display name (e.g., 'Peter Hartree'). If provided, the From header will be formatted as 'Name <email>'.\",\n     ),\n-    from_email: Optional[str] = Body(\n+    from_email: Optional[str] = BodyParam(\n         None,\n         description=\"Optional 'Send As' alias email address. Must be configured in Gmail settings (Settings > Accounts > Send mail as). If not provided, uses the authenticated user's email.\",\n     ),\n-    thread_id: Optional[str] = Body(\n+    thread_id: Optional[str] = BodyParam(\n         None, description=\"Optional Gmail thread ID to reply within.\"\n     ),\n-    in_reply_to: Optional[str] = Body(\n+    in_reply_to: Optional[str] = BodyParam(\n         None, description=\"Optional Message-ID of the message being replied to.\"\n     ),\n-    references: Optional[str] = Body(\n+    references: Optional[str] = BodyParam(\n         None, description=\"Optional chain of Message-IDs for proper threading.\"\n     ),\n-    attachments: Optional[List[Dict[str, str]]] = Body(\n+    attachments: Optional[List[Dict[str, str]]] = BodyParam(\n         None,\n         description=\"Optional list of attachments. Each can have: 'path' (file path, auto-encodes), OR 'content' (standard base64, not urlsafe) + 'filename'. Optional 'mime_type' (auto-detected from path if not provided).\",\n     ),\n@@ -1737,10 +1739,10 @@ async def list_gmail_filters(service, user_google_email: str) -> str:\n async def create_gmail_filter(\n     service,\n     user_google_email: str,\n-    criteria: Dict[str, Any] = Body(\n+    criteria: Dict[str, Any] = BodyParam(\n         ..., description=\"Filter criteria object as defined in the Gmail API.\"\n     ),\n-    action: Dict[str, Any] = Body(\n+    action: Dict[str, Any] = BodyParam(\n         ..., description=\"Filter action object as defined in the Gmail API.\"\n     ),\n ) -> str:\n", "test_patch": "", "problem_statement": "draft_gmail_message fails: 'Body' object has no attribute 'lower'\n## Bug\n\n`draft_gmail_message` fails with `'Body' object has no attribute 'lower'` on v1.10.7 (latest) when invoked via CLI.\n\n## Reproduction\n\n```bash\necho '{\"user_google_email\": \"user@example.com\", \"to\": \"recipient@example.com\", \"subject\": \"Test\", \"body\": \"Test\"}'   | workspace-mcp --single-user --cli draft_gmail_message\n```\n\n## Output\n\n```\n[UTILS] An unexpected error occurred in draft_gmail_message: 'Body' object has no attribute 'lower'\n[ERROR] [CLI] Error executing draft_gmail_message: ...\nError: Exception: An unexpected error occurred in draft_gmail_message: 'Body' object has no attribute 'lower'\n```\n\n## Environment\n\n- workspace-mcp v1.10.7 (installed via `uv tool install`)\n- macOS, Python 3.x\n\n## Analysis\n\nLooks like the `body` string parameter is being deserialized into an internal `Body` object somewhere before the code calls `.lower()` on it (likely for format detection). The string gets wrapped in a `Body` instance that lacks a `.lower()` method.\n", "hints_text": "`send_gmail_message` is also affected \u2014 same root cause, slightly different symptom:\n\n```bash\nworkspace-mcp --single-user --cli send_gmail_message --args '{\"user_google_email\": \"user@example.com\", \"to\": \"recipient@example.com\", \"subject\": \"Test\", \"body\": \"Test\"}'\n```\n\n```\n[UTILS] An unexpected error occurred in send_gmail_message: object of type 'Body' has no len()\n```\n\nSo both draft and send paths are wrapping the `body` string in a `Body` object. Likely a shared deserialization issue upstream of both tools.\nGreat catch, thanks - appreciate the detailed bug report, will have something for you asap \n\n", "all_hints_text": "`send_gmail_message` is also affected \u2014 same root cause, slightly different symptom:\n\n```bash\nworkspace-mcp --single-user --cli send_gmail_message --args '{\"user_google_email\": \"user@example.com\", \"to\": \"recipient@example.com\", \"subject\": \"Test\", \"body\": \"Test\"}'\n```\n\n```\n[UTILS] An unexpected error occurred in send_gmail_message: object of type 'Body' has no len()\n```\n\nSo both draft and send paths are wrapping the `body` string in a `Body` object. Likely a shared deserialization issue upstream of both tools.\nGreat catch, thanks - appreciate the detailed bug report, will have something for you asap \n\n", "commit_urls": ["https://github.com/taylorwilsdon/google_workspace_mcp/commit/2bef6d0c0b47ae336aa9478296d5ec45e0b69075", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/b0991018ff5266ffa7ed22bd4727aa17f0866d17", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/a4a3bdb5c9962dea8e73a7d7eeb5ee200b46c2ae", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/487db5c84975151959e740b7f9df9c722ef43b54", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/dd248f5af60342257964dcf1419ac6a76d2a2302"], "created_at": "2026-02-10T19:06:48Z"}
{"repo": "taylorwilsdon/google_workspace_mcp", "pull_number": 451, "instance_id": "taylorwilsdon__google_workspace_mcp-451", "issue_numbers": [449], "base_commit": "bc2279bc1022dfeb245c194ec465a3c9c735c830", "patch": "diff --git a/auth/auth_info_middleware.py b/auth/auth_info_middleware.py\nindex ac030d5f6..cc7ebc98e 100644\n--- a/auth/auth_info_middleware.py\n+++ b/auth/auth_info_middleware.py\n@@ -81,7 +81,7 @@ async def _process_request_for_auth(self, context: MiddlewareContext):\n                     auth_header = headers.get(\"authorization\", \"\")\n                     if auth_header.startswith(\"Bearer \"):\n                         token_str = auth_header[7:]  # Remove \"Bearer \" prefix\n-                        logger.info(f\"Found Bearer token: {token_str[:20]}...\")\n+                        logger.info(\"Found Bearer token in request\")\n \n                         # For Google OAuth tokens (ya29.*), we need to verify them differently\n                         if token_str.startswith(\"ya29.\"):\ndiff --git a/auth/google_auth.py b/auth/google_auth.py\nindex 3f3e4c647..872e4701e 100644\n--- a/auth/google_auth.py\n+++ b/auth/google_auth.py\n@@ -392,7 +392,7 @@ async def start_auth_flow(\n         store.store_oauth_state(oauth_state, session_id=session_id)\n \n         logger.info(\n-            f\"Auth flow started for {user_display_name}. State: {oauth_state[:8]}... Advise user to visit: {auth_url}\"\n+            f\"Auth flow started for {user_display_name}. Advise user to visit: {auth_url}\"\n         )\n \n         message_lines = [\n@@ -616,6 +616,17 @@ def get_credentials(\n                                     expiry=credentials.expiry,\n                                     mcp_session_id=session_id,\n                                 )\n+                                # Persist to file so rotated refresh tokens survive restarts\n+                                if not is_stateless_mode():\n+                                    try:\n+                                        credential_store = get_credential_store()\n+                                        credential_store.store_credential(\n+                                            user_email, credentials\n+                                        )\n+                                    except Exception as persist_error:\n+                                        logger.warning(\n+                                            f\"[get_credentials] Failed to persist refreshed OAuth 2.1 credentials for user {user_email}: {persist_error}\"\n+                                        )\n                             return credentials\n                         except Exception as e:\n                             logger.error(\ndiff --git a/auth/oauth_callback_server.py b/auth/oauth_callback_server.py\nindex 7e190c591..a009d4cdb 100644\n--- a/auth/oauth_callback_server.py\n+++ b/auth/oauth_callback_server.py\n@@ -54,12 +54,13 @@ def _setup_callback_route(self):\n         @self.app.get(\"/oauth2callback\")\n         async def oauth_callback(request: Request):\n             \"\"\"Handle OAuth callback - same logic as in core/server.py\"\"\"\n-            state = request.query_params.get(\"state\")\n             code = request.query_params.get(\"code\")\n             error = request.query_params.get(\"error\")\n \n             if error:\n-                error_message = f\"Authentication failed: Google returned an error: {error}. State: {state}.\"\n+                error_message = (\n+                    f\"Authentication failed: Google returned an error: {error}.\"\n+                )\n                 logger.error(error_message)\n                 return create_error_response(error_message)\n \n@@ -77,7 +78,7 @@ async def oauth_callback(request: Request):\n                     return create_server_error_response(error_message)\n \n                 logger.info(\n-                    f\"OAuth callback: Received code (state: {state}). Attempting to exchange for tokens.\"\n+                    \"OAuth callback: Received authorization code. Attempting to exchange for tokens.\"\n                 )\n \n                 # Session ID tracking removed - not needed\n@@ -92,16 +93,14 @@ async def oauth_callback(request: Request):\n                 )\n \n                 logger.info(\n-                    f\"OAuth callback: Successfully authenticated user: {verified_user_id} (state: {state}).\"\n+                    f\"OAuth callback: Successfully authenticated user: {verified_user_id}.\"\n                 )\n \n                 # Return success page using shared template\n                 return create_success_response(verified_user_id)\n \n             except Exception as e:\n-                error_message_detail = (\n-                    f\"Error processing OAuth callback (state: {state}): {str(e)}\"\n-                )\n+                error_message_detail = f\"Error processing OAuth callback: {str(e)}\"\n                 logger.error(error_message_detail, exc_info=True)\n                 return create_server_error_response(str(e))\n \ndiff --git a/core/server.py b/core/server.py\nindex dcfa82c92..afea069ce 100644\n--- a/core/server.py\n+++ b/core/server.py\n@@ -483,7 +483,7 @@ async def legacy_oauth2_callback(request: Request) -> HTMLResponse:\n         if error_message:\n             return create_server_error_response(error_message)\n \n-        logger.info(f\"OAuth callback: Received code (state: {state}).\")\n+        logger.info(\"OAuth callback: Received authorization code.\")\n \n         mcp_session_id = None\n         if hasattr(request, \"state\") and hasattr(request.state, \"session_id\"):\ndiff --git a/fastmcp_server.py b/fastmcp_server.py\nindex 421a37a9f..a1f15f64c 100644\n--- a/fastmcp_server.py\n+++ b/fastmcp_server.py\n@@ -58,6 +58,11 @@ def enforce_fastmcp_cloud_defaults():\n # Suppress googleapiclient discovery cache warning\n logging.getLogger(\"googleapiclient.discovery_cache\").setLevel(logging.ERROR)\n \n+# Suppress httpx/httpcore INFO logs that leak access tokens in URLs\n+# (e.g. tokeninfo?access_token=ya29.xxx)\n+logging.getLogger(\"httpx\").setLevel(logging.WARNING)\n+logging.getLogger(\"httpcore\").setLevel(logging.WARNING)\n+\n # Reload OAuth configuration after env vars loaded\n reload_oauth_config()\n \ndiff --git a/main.py b/main.py\nindex 9c43146c2..64cc46519 100644\n--- a/main.py\n+++ b/main.py\n@@ -30,6 +30,11 @@\n # Suppress googleapiclient discovery cache warning\n logging.getLogger(\"googleapiclient.discovery_cache\").setLevel(logging.ERROR)\n \n+# Suppress httpx/httpcore INFO logs that leak access tokens in URLs\n+# (e.g. tokeninfo?access_token=ya29.xxx)\n+logging.getLogger(\"httpx\").setLevel(logging.WARNING)\n+logging.getLogger(\"httpcore\").setLevel(logging.WARNING)\n+\n reload_oauth_config()\n \n logging.basicConfig(\n", "test_patch": "", "problem_statement": "Session store refresh path doesn't persist rotated refresh tokens to file store\n## Bug Description\n\nWhen credentials are refreshed through the OAuth21SessionStore path in `get_credentials()` (auth/google_auth.py lines ~601-619), the refreshed credentials are only saved back to the in-memory session store via `store.store_session()`. They are NOT persisted to the file-based credential store.\n\nIf Google rotates the refresh token during this refresh (which web clients may do), the new token exists only in memory. When the process restarts (e.g., new Claude Code session via stdio transport), the file still has the old, now-revoked refresh token. The next refresh attempt fails with `RefreshError`, forcing reauthentication.\n\n## Steps to Reproduce\n\n1. Configure workspace-mcp with stdio transport and multiple Google accounts\n2. Use a tool (first call loads from file \u2192 Path B, which saves to both file and session store)\n3. Wait ~1 hour for the access token to expire\n4. Use another tool in the same session (goes through Path A \u2014 the session store refresh path)\n5. End the session (process dies, in-memory session store is lost)\n6. Start a new session and use a tool \u2192 reauth required\n\n## Root Cause\n\nIn `get_credentials()`, there are two refresh paths:\n\n**Path A (session store, ~line 601-619):** Only saves to `store.store_session()` (in-memory)\n```python\ncredentials.refresh(Request())\nuser_email = store.get_user_by_mcp_session(session_id)\nif user_email:\n    store.store_session(...)  # in-memory only\nreturn credentials\n```\n\n**Path B (file-based, ~line 713-753):** Saves to BOTH file store and session store\n```python\ncredentials.refresh(Request())\nif user_google_email:\n    credential_store = get_credential_store()\n    credential_store.store_credential(user_google_email, credentials)  # file\n    store = get_oauth21_session_store()\n    store.store_session(...)  # in-memory\n```\n\nPath A is missing the `credential_store.store_credential()` call.\n\n## Suggested Fix\n\nAdd file persistence to Path A, mirroring Path B:\n\n```python\nuser_email = store.get_user_by_mcp_session(session_id)\nif user_email:\n    store.store_session(\n        user_email=user_email,\n        access_token=credentials.token,\n        refresh_token=credentials.refresh_token,\n        scopes=credentials.scopes,\n        expiry=credentials.expiry,\n        mcp_session_id=session_id,\n    )\n    # Persist refreshed credentials to file store\n    # so rotated refresh tokens survive process restarts\n    if not is_stateless_mode():\n        credential_store = get_credential_store()\n        credential_store.store_credential(user_email, credentials)\n```\n\n## Environment\n\n- workspace-mcp v1.10.7\n- stdio transport\n- Multiple Google accounts (two credential files in ~/.google_workspace_mcp/credentials/)\n- OAuth 2.0 mode (OAuth 2.1 not enabled)\n- macOS, Claude Code CLI\n\n## Impact\n\nUsers with multi-account stdio setups need to reauthenticate every few hours. The pattern alternates between accounts depending on which one had its token refreshed through the session store path.\n", "hints_text": "Claude Code supports OAuth 2.1 natively, imo there is no reason to use it with legacy/fallback mode - that's only there to facilitate basic usability with clients that don't support the MCP spec properly. If you just run oauth mode, it'll gracefully handle reauth and account switching. \n\nPath A is the OAuth 2.1 session store path. This path is specifically for clients that support proper OAuth 2.1 (like Claude Code's native OAuth mode). In OAuth 2.1 mode with HTTP/SSE transport, the server stays running and manages sessions in-memory by design. If you want to persist the store to disk, valkey and traditional disk are both supported. Re-authentication is expected when the server restarts because the client can initiate a new OAuth 2.1 flow.\n\nWith that said, I could see a world where a legacy client wants to switch between accounts so there may still be something to address here. Will assign and take a look. \n\n", "all_hints_text": "Claude Code supports OAuth 2.1 natively, imo there is no reason to use it with legacy/fallback mode - that's only there to facilitate basic usability with clients that don't support the MCP spec properly. If you just run oauth mode, it'll gracefully handle reauth and account switching. \n\nPath A is the OAuth 2.1 session store path. This path is specifically for clients that support proper OAuth 2.1 (like Claude Code's native OAuth mode). In OAuth 2.1 mode with HTTP/SSE transport, the server stays running and manages sessions in-memory by design. If you want to persist the store to disk, valkey and traditional disk are both supported. Re-authentication is expected when the server restarts because the client can initiate a new OAuth 2.1 flow.\n\nWith that said, I could see a world where a legacy client wants to switch between accounts so there may still be something to address here. Will assign and take a look. \n\n", "commit_urls": ["https://github.com/taylorwilsdon/google_workspace_mcp/commit/3b75ab11fb3aa8071f332e3027a465f2c9ad1404", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/b85b563cdc5422a9b974df5c88141440c363ef18", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/35fc66f3295d472c1a98927f2aece808315980ff", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/bbee795c160f454dce4412301237fc1107c5e475"], "created_at": "2026-02-10T22:01:36Z"}
{"repo": "taylorwilsdon/google_workspace_mcp", "pull_number": 453, "instance_id": "taylorwilsdon__google_workspace_mcp-453", "issue_numbers": [452], "base_commit": "78a0db215e542c8323f4d6b3ff7a7e0715d4f397", "patch": "diff --git a/gdrive/drive_tools.py b/gdrive/drive_tools.py\nindex 5bcbfb0e8..ac2d92c5d 100644\n--- a/gdrive/drive_tools.py\n+++ b/gdrive/drive_tools.py\n@@ -565,6 +565,9 @@ async def create_drive_file(\n             )\n         # Handle HTTP/HTTPS URLs\n         elif parsed_url.scheme in (\"http\", \"https\"):\n+            # SSRF protection: block internal/private network URLs\n+            _validate_url_not_internal(fileUrl)\n+\n             # when running in stateless mode, deployment may not have access to local file system\n             if is_stateless_mode():\n                 async with httpx.AsyncClient(follow_redirects=True) as client:\n", "test_patch": "", "problem_statement": "SSRF: create_drive_file missing _validate_url_not_internal() check\n## Summary\n\n`create_drive_file` in `gdrive/drive_tools.py` (around line 567) fetches arbitrary HTTP/HTTPS URLs via the `fileUrl` parameter without calling `_validate_url_not_internal()`.\n\nThe sister function `import_to_google_doc` correctly calls this validation at line 888, so this looks like it was unintentionally missed rather than a design choice.\n\n## Impact\n\nA caller could pass internal URLs (`http://169.254.169.254/`, `http://localhost:*`, RFC 1918 ranges) as `fileUrl`, causing the server to make requests to internal network resources (SSRF).\n\n## Suggested fix\n\nAdd the existing `_validate_url_not_internal(file_url)` call in `create_drive_file` before the `httpx` fetch, matching the pattern already used in `import_to_google_doc`.\n\n## Context\n\nFound during a local security review. The function and validation logic are already well-written \u2014 this just appears to be a gap in coverage. Great project, thanks for building it.\n", "hints_text": "\n\n", "all_hints_text": "Good call, thanks! \n\n", "commit_urls": ["https://github.com/taylorwilsdon/google_workspace_mcp/commit/eab0aa61e8dc7750897a701082e9fe686f6b54f2"], "created_at": "2026-02-11T02:56:44Z"}
{"repo": "taylorwilsdon/google_workspace_mcp", "pull_number": 458, "instance_id": "taylorwilsdon__google_workspace_mcp-458", "issue_numbers": [457], "base_commit": "670aca052219c5e953ca5e50a9fed5e9b12d05d9", "patch": "diff --git a/.beads/issues.jsonl b/.beads/issues.jsonl\nindex 1df032f04..596d633db 100644\n--- a/.beads/issues.jsonl\n+++ b/.beads/issues.jsonl\n@@ -12,6 +12,7 @@\n {\"id\":\"google_workspace_mcp-ic8\",\"title\":\"enh: support writing hyperlink URLs in modify_sheet_values\",\"description\":\"Issue #434 also requested hyperlink creation/writes. Current implementation reads hyperlinks in read_sheet_values but modify_sheet_values does not expose first-class hyperlink writes.\",\"status\":\"open\",\"priority\":3,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T17:42:10.590658-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T17:42:10.590658-05:00\"}\n {\"id\":\"google_workspace_mcp-jf2\",\"title\":\"ci: make PyPI publish step rerun-safe with skip-existing\",\"description\":\"GitHub Actions reruns on same tag fail because PyPI rejects duplicate file uploads. Add skip-existing=true to pypa/gh-action-pypi-publish so reruns proceed to MCP publish.\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"bug\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T20:59:58.461102-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T21:00:32.121469-05:00\",\"closed_at\":\"2026-02-08T21:00:32.121469-05:00\",\"close_reason\":\"Closed\"}\n {\"id\":\"google_workspace_mcp-qfl\",\"title\":\"Fix stdio multi-account session binding\",\"status\":\"in_progress\",\"priority\":1,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-07T13:27:09.466282-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-07T13:27:22.857227-05:00\"}\n+{\"id\":\"google_workspace_mcp-qr5\",\"title\":\"fix: include RFC Message-ID threading headers in thread content output\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"bug\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-11T11:44:41.966911-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-11T11:46:11.355237-05:00\",\"closed_at\":\"2026-02-11T11:46:11.355237-05:00\",\"close_reason\":\"Closed\"}\n {\"id\":\"google_workspace_mcp-xia\",\"title\":\"fix: CLI should unwrap FastAPI Body defaults when invoking tools\",\"description\":\"CLI mode invokes tool functions directly and currently passes FastAPI Body marker objects as defaults for omitted args. This breaks gmail send/draft with errors like Body has no attribute lower/len. Update CLI invocation to normalize Param defaults and return clear missing-required errors.\",\"status\":\"closed\",\"priority\":1,\"issue_type\":\"bug\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-10T12:33:06.83139-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-10T12:36:35.051947-05:00\",\"closed_at\":\"2026-02-10T12:36:35.051947-05:00\",\"close_reason\":\"Implemented CLI FastAPI default normalization + regression tests\",\"labels\":[\"cli\",\"gmail\"]}\n {\"id\":\"google_workspace_mcp-xt2\",\"title\":\"Implement CLI mode for Workspace MCP\",\"description\":\"Create a CLI mode for the Workspace MCP server, activated via --cli flag, that allows all tools to be used directly from the command line without running as an MCP server.\\n\\n**Goals:**\\n- Add --cli startup flag to enable CLI mode\\n- Expose all existing tools as CLI subcommands\\n- No changes to individual tool implementations - reuse existing code\\n- Lightweight and flexible design\\n- Enable usage by coding agents (Codex, Claude Code) without MCP server overhead\\n\\n**Requirements:**\\n- Parse tool name and arguments from command line\\n- Route to existing tool handlers\\n- Output results to stdout (JSON or human-readable)\\n- Maintain same authentication/credential flow\\n- Support all current tools without modification\",\"status\":\"in_progress\",\"priority\":0,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-01T10:57:29.920078-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-01T11:02:26.818109-05:00\"}\n {\"id\":\"google_workspace_mcp-y3j\",\"title\":\"docs: add MCP registry publishing guidance for this server\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"tbarrettwilsdon@gmail.com\",\"created_at\":\"2026-02-08T19:56:42.74673-05:00\",\"created_by\":\"Taylor Wilsdon\",\"updated_at\":\"2026-02-08T20:00:56.253918-05:00\",\"closed_at\":\"2026-02-08T20:00:56.253918-05:00\",\"close_reason\":\"Closed\"}\ndiff --git a/gmail/gmail_tools.py b/gmail/gmail_tools.py\nindex 1c74a9e02..22f275020 100644\n--- a/gmail/gmail_tools.py\n+++ b/gmail/gmail_tools.py\n@@ -1357,6 +1357,9 @@ def _format_thread_content(thread_data: dict, thread_id: str) -> str:\n         sender = headers.get(\"From\", \"(unknown sender)\")\n         date = headers.get(\"Date\", \"(unknown date)\")\n         subject = headers.get(\"Subject\", \"(no subject)\")\n+        rfc822_message_id = headers.get(\"Message-ID\", \"\")\n+        in_reply_to = headers.get(\"In-Reply-To\", \"\")\n+        references = headers.get(\"References\", \"\")\n \n         # Extract both text and HTML bodies\n         payload = message.get(\"payload\", {})\n@@ -1376,6 +1379,13 @@ def _format_thread_content(thread_data: dict, thread_id: str) -> str:\n             ]\n         )\n \n+        if rfc822_message_id:\n+            content_lines.append(f\"Message-ID: {rfc822_message_id}\")\n+        if in_reply_to:\n+            content_lines.append(f\"In-Reply-To: {in_reply_to}\")\n+        if references:\n+            content_lines.append(f\"References: {references}\")\n+\n         # Only show subject if it's different from thread subject\n         if subject != thread_subject:\n             content_lines.append(f\"Subject: {subject}\")\n", "test_patch": "", "problem_statement": "Reply to e-mails are not grouped properly in non gmail clients\nGoogle mail is relaying on thread ID when grouping e-mails. This is a proprietary standard. The standard is to use Message-ID in the References Header.\n\n**Is your feature request related to a problem? Please describe.**\nWhen using the MCP server to reply to an e-mail the model generally decided to keep the thread id which is good but does not insert the Message-ID in the References header. So the reply is not considered a reply in no gmail clients.\n\n**Describe the solution you'd like**\nThat the Language Model inserts the message ID. To achieve this when retrieving the e-mail via:\n\nhttps://github.com/taylorwilsdon/google_workspace_mcp/blob/main/gmail/gmail_tools.py#L545\n\ni would like to add the Message-ID as part of the response always here, not only in the metadata case:\n\nhttps://github.com/taylorwilsdon/google_workspace_mcp/blob/main/gmail/gmail_tools.py#L580.\n\n**Describe alternatives you've considered**\nNot sure how to do it differently.\n\n**Additional context**\n\nThere is something that i do not understand. The current message ID is the same as the thread. A number like:\n\nMessage ID: 19c47684b79805e4\n\nbut the Message ID in the raw e-mail is more something like:\n\n<img width=\"1400\" height=\"431\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/cb3ef7e5-f7de-4a36-a0f7-f53239d417ff\" />\n\nI tried, putting this ID in the send tool as a reference, actually makes the grouping work.\n\nI can make a pull request once the details are worked out. Should be easy.\n\n", "hints_text": "@taylorwilsdon: would love to hear your opinion on this one : )\n\n", "all_hints_text": "@taylorwilsdon: would love to hear your opinion on this one : )\nShould be in main now. Thanks! \nHi,\n\ni checked, unfortunately the message ID that is passed currently is not the right one. The message ID that is passed is the tread ID, i.e something like:\n\nMessage ID: 19c47684b79805e4\n\nBut the message ID that should be put in the References Header is a different one. \n\n<img width=\"1414\" height=\"736\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/810206e9-5b22-40f2-929d-5aea7f64cdc2\" />\n\nSee screenshot above. @taylorwilsdon could you give a second look?\nIt's pulling from that field, so I'm not sure what to tell ya. I use Gmail so I've never had this issue and not sure how I'd reproduce it. \n\n", "commit_urls": ["https://github.com/taylorwilsdon/google_workspace_mcp/commit/8c9239057646898e2b2a91cb9e18e17e5c1368bf"], "created_at": "2026-02-11T16:52:28Z"}
