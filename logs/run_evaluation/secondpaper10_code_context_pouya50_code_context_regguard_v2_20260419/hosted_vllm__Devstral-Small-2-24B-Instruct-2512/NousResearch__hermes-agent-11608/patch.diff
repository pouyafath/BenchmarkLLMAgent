+    async def _resolve_allowed_roles(self) -> None:
+        """
+        Resolve role names/IDs in DISCORD_ALLOWED_ROLES to Discord user IDs.
+
+        Fetches all guild members and checks if they have any of the allowed roles.
+        Resolved user IDs are cached in _allowed_role_members for authorization checks.
+        """
+        if not self._allowed_role_ids or not self._client:
+            return
+
+        resolved_members = set()
+
+        for entry in self._allowed_role_ids:
+            if not entry.isdigit():
+                logger.warning("Role ID '%s' is not numeric; role names are not supported yet", entry)
+                continue
+
+        print(f"[{self.name}] Resolving {len(self._allowed_role_ids)} role(s): {', '.join(self._allowed_role_ids)}")
+        resolved_count = 0
+
+        for guild in self._client.guilds:
+            # Fetch full member list (requires members intent)
+            try:
+                members = guild.members
+                if len(members) < guild.member_count:
+                    members = [m async for m in guild.fetch_members(limit=None)]
+            except Exception as e:
+                logger.warning("Failed to fetch members for guild %s: %s", guild.name, e)
+                continue
+
+            # Get all roles in the guild for name-to-ID mapping
+            try:
+                roles_by_name = {role.name.lower(): str(role.id) for role in guild.roles}
+                roles_by_id = {str(role.id): role for role in guild.roles}
+            except Exception as e:
+                logger.warning("Failed to fetch roles for guild %s: %s", guild.name, e)
+                continue
+
+            # Resolve role IDs (numeric entries)
+            role_ids_to_find = set()
+            for entry in self._allowed_role_ids:
+                if entry.isdigit():
+                    role_ids_to_find.add(entry)
+                else:
+                    # Try to resolve role name to ID
+                    if entry.lower() in roles_by_name:
+                        role_id = roles_by_name[entry.lower()]
+                        role_ids_to_find.add(role_id)
+                        print(f"[{self.name}] Resolved role name '{entry}' -> {role_id} in guild {guild.name}")
+
+            # Check each member for allowed roles
+            for member in members:
+                for role_id in role_ids_to_find:
+                    if guild.get_role(int(role_id)) in member.roles:
+                        uid = str(member.id)
+                        resolved_members.add(uid)
+                        resolved_count += 1
+                        break
+
+        if resolved_count:
+            print(f"[{self.name}] Resolved {resolved_count} member(s) with allowed role(s)")
+        else:
+            print(f"[{self.name}] No members found with allowed roles")
+
+        # Update cache
+        self._allowed_role_members = resolved_members
