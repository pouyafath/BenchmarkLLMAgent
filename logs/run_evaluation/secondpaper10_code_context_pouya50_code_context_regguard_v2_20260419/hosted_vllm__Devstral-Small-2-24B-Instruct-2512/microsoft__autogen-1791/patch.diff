+    def is_executor(self, agent: Agent, message_content: Optional[str] = None) -> bool:
+        """Check if an agent should be considered an executor based on registered triggers.
+
+        Args:
+            agent: The agent to check.
+            message_content: Optional message content to use for context.
+
+        Returns:
+            bool: True if the agent should be considered an executor.
+        """
+        if not hasattr(self, '_executor_triggers'):
+            return False
+
+        for trigger_info in self._executor_triggers:
+            trigger = trigger_info['trigger']
+            if self._match_trigger(trigger, agent, message_content):
+                return True
