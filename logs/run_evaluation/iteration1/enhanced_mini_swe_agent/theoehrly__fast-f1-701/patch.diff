+# ---------------------------------------------------------------------------
+# Helper to recursively replace the placeholder string "auto" with the driver
+# specific color.  This is used by ``get_driver_style`` to allow nested style
+# dictionaries (e.g. ``line={'color': 'auto'}``) to be resolved correctly.
+# ---------------------------------------------------------------------------
+def _replace_auto_recursive(value: Any, driver: str, session: Session) -> Any:
+    """
+    Recursively walk through *value* and replace any string equal to ``"auto"``
+    (case‑insensitive) with the colour associated with *driver*.
+
+    The function handles dictionaries, lists and tuples.  All other values are
+    returned unchanged.
+    """
+    if isinstance(value, dict):
+        return {k: _replace_auto_recursive(v, driver, session) for k, v in value.items()}
+    if isinstance(value, (list, tuple)):
+        # Preserve the original container type
+        replaced = [_replace_auto_recursive(v, driver, session) for v in value]
+        return type(value)(replaced)
+    if isinstance(value, str) and value.lower() == "auto":
+        # Resolve the driver colour using the existing helper
+        return _get_driver_color(driver, session)
+    return value
+
