+def _extract_image_path_from_tag(img_tag):
+    """Extract image path from img tag, handling both <img path> and <img src="path"> formats"""
+    # First try to match <img src="..."> or <img src='...'>
+    src_pattern = re.compile(r'<img\s+src=(["\'])(.*?)\1>', re.IGNORECASE)
+    match = src_pattern.search(img_tag)
+    if match:
+        return match.group(2)
+
+    # Then try to match <img src=...> without quotes (unquoted attribute)
+    src_unquoted_pattern = re.compile(r'<img\s+src=([^\s>]+)', re.IGNORECASE)
+    match = src_unquoted_pattern.search(img_tag)
+    if match:
+        return match.group(1)
+
+    # Then try to match <img ...> where the rest is the path
+    simple_pattern = re.compile(r'<img\s+([^>]+)>', re.IGNORECASE)
+    match = simple_pattern.search(img_tag)
+    if match:
+        return match.group(1).strip()
+
+    return None
 
