.whl\", hash = \"sha256:a418670a20291dacd2dddc80c377c5c3791378ee1e8d12bffc35420643d43f18\"},\n     {file = \"parso-0.8.4.tar.gz\", hash = \"sha256:eb3a7b58240fb99099a345571deecc0f9540ea5f4dd2fe14c2a99d6b281ab92d\"},\n@@ -4869,7 +4869,7 @@ files = [\n name = \"pexpect\"\n version = \"4.9.0\"\n summary = \"Pexpect allows easy control of interactive console applications.\"\n-groups = [\"dev\", \"doc\"]\n+groups = [\"default\", \"dev\", \"doc\"]\n marker = \"sys_platform != \\\"win32\\\"\"\n dependencies = [\n     \"ptyprocess>=0.5\",\n@@ -4883,7 +4883,7 @@ files = [\n name = \"pickleshare\"\n version = \"0.7.5\"\n summary = \"Tiny 'shelve'-like database with concurrency support\"\n-groups = [\"dev\", \"doc\"]\n+groups = [\"default\", \"dev\", \"doc\"]\n dependencies = [\n     \"pathlib2; python_version in \\\"2.6 2.7 3.2 3.3\\\"\",\n ]\n@@ -5084,7 +5084,7 @@ name = \"prompt-toolkit\"\n version = \"3.0.51\"\n requires_python = \">=3.8\"\n summary = \"Library for building powerful interactive command lines in Python\"\n-groups = [\"dev\", \"doc\", \"test\"]\n+groups = [\"default\", \"dev\", \"doc\", \"test\"]\n dependencies = [\n     \"wcwidth\",\n ]\n@@ -5232,7 +5232,7 @@ files = [\n name = \"ptyprocess\"\n version = \"0.7.0\"\n summary = \"Run a subprocess in a pseudo terminal\"\n-groups = [\"dev\", \"doc\"]\n+groups = [\"default\", \"dev\", \"doc\"]\n marker = \"os_name != \\\"nt\\\" or sys_platform != \\\"win32\\\"\"\n files = [\n     {file = \"ptyprocess-0.7.0-py2.py3-none-any.whl\", hash = \"sha256:4b41f3967fce3af57cc7e94b888626c18bf37a083e3651ca8feeb66d492fef35\"},\n@@ -5243,7 +5243,7 @@ files = [\n name = \"pure-eval\"\n version = \"0.2.3\"\n summary = \"Safely evaluate AST nodes without side effects\"\n-groups = [\"dev\", \"doc\"]\n+groups = [\"default\", \"dev\", \"doc\"]\n files = [\n     {file = \"pure_eval-0.2.3-py3-none-any.whl\", hash = \"sha256:1db8e35b67b3d218d818ae653e27f06c3aa420901fa7b081ca98cbedc874e0d0\"},\n     {file = \"pure_eval-0.2.3.tar.gz\", hash = \"sha256:5f4e983f40564c576c7c8635ae88db5956bb2229d7e9237d03b3c0b0190eaf42\"},\n@@ -5506,7 +5506,7 @@ name = \"pygments\"\n version = \"2.19.1\"\n requires_python = \">=3.8\"\n summary = \"Pygments is a syntax highlighting package written in Python.\"\n-groups = [\"dev\", \"doc\", \"tensorflow\", \"test\"]\n+groups = [\"default\", \"dev\", \"doc\", \"tensorflow\", \"test\"]\n files = [\n     {file = \"pygments-2.19.1-py3-none-any.whl\", hash = \"sha256:9ea1544ad55cecf4b8242fab6dd35a93bbce657034b0611ee383099054ab6d8c\"},\n     {file = \"pygments-2.19.1.tar.gz\", hash = \"sha256:61c16d2a8576dc0649d9f39e089b5f02bcd27fba10d8fb4dcc28173f7a45151f\"},\n@@ -7035,7 +7035,7 @@ files = [\n name = \"stack-data\"\n version = \"0.6.3\"\n summary = \"Extract data from python stack frames and tracebacks for informative displays\"\n-groups = [\"dev\", \"doc\"]\n+groups = [\"default\", \"dev\", \"doc\"]\n dependencies = [\n     \"asttokens>=2.1.0\",\n     \"executing>=1.2.0\",\n@@ -7707,7 +7707,7 @@ name = \"traitlets\"\n version = \"5.14.3\"\n requires_python = \">=3.8\"\n summary = \"Traitlets Python configuration system\"\n-groups = [\"dev\", \"doc\"]\n+groups = [\"default\", \"dev\", \"doc\"]\n files = [\n     {file = \"traitlets-5.14.3-py3-none-any.whl\", hash = \"sha256:b74e89e397b1ed28cc831db7aea759ba6640cb3de13090ca145426688ff1ac4f\"},\n     {file = \"traitlets-5.14.3.tar.gz\", hash = \"sha256:9ed0579d3502c94b4b3732ac120375cda96f923114522847de4b3bb98b96b6b7\"},\n@@ -8117,7 +8117,7 @@ files = [\n name = \"wcwidth\"\n version = \"0.2.13\"\n summary = \"Measures the displayed width of unicode strings in a terminal\"\n-groups = [\"dev\", \"doc\", \"test\"]\n+groups = [\"default\", \"dev\", \"doc\", \"test\"]\n dependencies = [\n     \"backports-functools-lru-cache>=1.2.1; python_version < \\\"3.2\\\"\",\n ]\ndiff --git a/pyproject.toml b/pyproject.toml\nindex ea4e510e8a..3282db1c52 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -174,6 +174,7 @@ dependencies = [\n     \"colorama\",                 # needed for the scan\n     \"num2words>=0.5.13\",\n     \"griffe>=1.0.0,<2.0.0\",\n+    \"ipython\",\n ]\n \n [project.optional-dependencies]\n", "test_patch": "diff --git a/tests/rag/test_report.py b/tests/rag/test_report.py\nindex 8c84e67b38..d826182fab 100644\n--- a/tests/rag/test_report.py\n+++ b/tests/rag/test_report.py\n@@ -2,6 +2,7 @@\n from unittest.mock import Mock, patch\n \n import numpy as np\n+import pytest\n from bokeh.plotting import figure\n \n from giskard.rag import QATestset, RAGReport\n@@ -98,6 +99,15 @@ def test_report_plots():\n     assert len(histograms[\"Question\"][\"simple\"]) == 4\n \n \n+@pytest.mark.parametrize(\"embed\", [False, True])\n+def test_report_to_html(embed):\n+    \"\"\"Test that to_html works correctly with different embed parameter values.\"\"\"\n+    testset, answers, metrics_results = _create_test_data()\n+\n+    report = RAGReport(testset, answers, metrics_results)\n+    report.to_html(embed=embed)\n+\n+\n def test_report_save_load(tmp_path):\n     testset, answers, metrics_results = _create_test_data(with_documents=True)\n     llm_client = Mock()\n", "problem_statement": "[bug] ModuleNotFoundError: No module named 'IPython'\n### Issue Type\n\nBug\n\n### Source\n\nsource\n\n### Giskard Library Version\n\n2.16.2\n\n### OS Platform and Distribution\n\n_No response_\n\n### Python version\n\n_No response_\n\n### Installed python packages\n\n```shell\n\n```\n\n### Current Behaviour?\n\n```shell\ngiskard/rag/report.py \n\nfrom IPython.core.display import HTML\nModuleNotFoundError: No module named 'IPython'\n```\n\n### Standalone code OR list down the steps to reproduce the issue\n\n```shell\nrun a report without havving ipython installed\n```\n\n### Relevant log output\n\n```shell\n\n```\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/Giskard-AI/giskard-oss/commit/e9b0fcd4353f55bc29ea97461540cf0960fa3841", "https://github.com/Giskard-AI/giskard-oss/commit/92832a0145b6f12b3b200440b586d9f25917948b", "https://github.com/Giskard-AI/giskard-oss/commit/7868cad98a1fa7a842d591694174df3c37074a6a", "https://github.com/Giskard-AI/giskard-oss/commit/55a857dda735c2a530569c3675199e27d18a0ed5", "https://github.com/Giskard-AI/giskard-oss/commit/4fad79bebceb5a784e6f364453ed4818a33f7ab2", "https://github.com/Giskard-AI/giskard-oss/commit/24d98db1888e0b1ed042869f0f4f39e2a8ba21d2"], "created_at": "2025-04-25T07:00:52Z"}
