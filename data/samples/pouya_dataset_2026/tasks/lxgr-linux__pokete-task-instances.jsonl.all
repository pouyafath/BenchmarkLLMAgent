 Path\n \n VERSION = \"0.10.0-rc4\"\n CODENAME = \"Grey Edition\"\n-SAVEPATH = Path(\n-    os.environ.get(\n-        \"XDG_DATA_HOME\",\n-        str(Path.home()) + \"/.local/share\"\n-    )\n-) / \"pokete\"\n+SAVEPATH = (\n+    Path(os.environ.get(\"XDG_DATA_HOME\", str(Path.home()) + \"/.local/share\"))\n+    / \"pokete\"\n+)\n FRAMETIME = 0.05\n \n # Speeds up all parts of the game by this factor (smaller is faster)\ndiff --git a/src/pokete/startup/command.py b/src/pokete/startup/command.py\nindex 8f2ca4aa1..b78427873 100644\n--- a/src/pokete/startup/command.py\n+++ b/src/pokete/startup/command.py\n@@ -1,24 +1,28 @@\n import logging\n-from pathlib import Path\n import sys\n-from pokete.release import CODENAME, SAVEPATH, VERSION, SAVEPATH\n+from pathlib import Path\n+\n+from pokete.release import CODENAME, SAVEPATH, VERSION\n from pokete.util.command.command import Flag, RootCommand\n \n+\n class PoketeCommand:\n     log_flag = Flag([\"--log\"], \"Enables logging\")\n     mods_flag = Flag([\"--no_mods\"], \"Disables mods\")\n     audio_flag = Flag([\"--no_audio\"], \"Disables audio\")\n-    save_dir_flag = Flag([\"--save_dir\"], f\"Sets the path for save-files and logs, default is: {SAVEPATH}\")\n+    save_dir_flag = Flag(\n+        [\"--save_dir\"],\n+        f\"Sets the path for save-files and logs, default is: {SAVEPATH}\",\n+    )\n \n     def __init__(self, audio):\n         self.do_logging = False\n         self.load_mods = True\n         audio.use_audio = True\n         self.audio = audio\n-        self.save_dir:Path = SAVEPATH\n+        self.save_dir: Path = SAVEPATH\n \n-    def root_fn(self, ex: str, options: list[str],\n-                flags: dict[str, list[str]]):\n+    def root_fn(self, ex: str, options: list[str], flags: dict[str, list[str]]):\n         for flag, values in flags.items():\n             if self.log_flag.is_flag(flag):\n                 self.do_logging = True\n@@ -34,14 +38,21 @@ def root_fn(self, ex: str, options: list[str],\n \n     def run(self) -> tuple[bool, bool, Path]:\n         c = RootCommand(\n-            \"Pokete\", f\"{CODENAME} v{VERSION}\", self.root_fn,\n-            flags=[self.log_flag, self.mods_flag, self.audio_flag, self.save_dir_flag],\n+            \"Pokete\",\n+            f\"{CODENAME} v{VERSION}\",\n+            self.root_fn,\n+            flags=[\n+                self.log_flag,\n+                self.mods_flag,\n+                self.audio_flag,\n+                self.save_dir_flag,\n+            ],\n             additional_info=f\"\"\"All save and logfiles are located in ~{SAVEPATH}/\n         Feel free to contribute.\n         See README.md for more information.\n         This software is licensed under the GPLv3, you should have gotten a\n         copy of it alongside this software.\"\"\",\n-            usage=\"\"\n+            usage=\"\",\n         )\n \n         c.exec()\ndiff --git a/src/pokete/startup/logging.py b/src/pokete/startup/logging.py\nindex 3e9d397dc..8456886ad 100644\n--- a/src/pokete/startup/logging.py\n+++ b/src/pokete/startup/logging.py\n@@ -2,10 +2,15 @@\n \n from pokete import release\n \n+\n def init_logger(do_logging: bool):\n     # logging config\n     log_file = (release.SAVEPATH / \"pokete.log\") if do_logging else None\n-    logging.basicConfig(filename=log_file,\n-                        format='[%(asctime)s][%(levelname)s]: %(message)s',\n-                        level=logging.DEBUG if do_logging else logging.ERROR)\n-    logging.info(\"=== Startup Pokete %s v%s ===\", release.CODENAME, release.VERSION)\n+    logging.basicConfig(\n+        filename=log_file,\n+        format=\"[%(asctime)s][%(levelname)s]: %(message)s\",\n+        level=logging.DEBUG if do_logging else logging.ERROR,\n+    )\n+    logging.info(\n+        \"=== Startup Pokete %s v%s ===\", release.CODENAME, release.VERSION\n+    )\n", "test_patch": "", "problem_statement": "Mouse tracking\n\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/lxgr-linux/pokete/commit/05edae4f59d6f20338bbe5d9d404b8797c567eae", "https://github.com/lxgr-linux/pokete/commit/8fe627b351f0d97273cf6bbf8bb109f9dbd75d71", "https://github.com/lxgr-linux/pokete/commit/bcdfd227c87dd7750c3eb16323f5d1860af8685a", "https://github.com/lxgr-linux/pokete/commit/a4c57dff517ffd67e70e8d04f6cf7ee5e8c8c388", "https://github.com/lxgr-linux/pokete/commit/2b7fa7a6c3105bca9ed034ba86f507ada0199246", "https://github.com/lxgr-linux/pokete/commit/7bca0c7313bb412785d0f8757626b8c9c1d15d6e", "https://github.com/lxgr-linux/pokete/commit/57b1247d443d69548c27c75f1d8d8146ade9e664", "https://github.com/lxgr-linux/pokete/commit/e800458f6d7e9c1387d9f41fb87c60185606717a", "https://github.com/lxgr-linux/pokete/commit/dc5bb634b3c26620a3b580dc513e66555dc3ad43", "https://github.com/lxgr-linux/pokete/commit/391e6588d4ae9176d677d42ef994447a79ae4964", "https://github.com/lxgr-linux/pokete/commit/bef1c8d92d328e8f8590d92ffe7a150ce1013aff", "https://github.com/lxgr-linux/pokete/commit/25ab803ab4897265e3c5483b0fed23489c534aa7", "https://github.com/lxgr-linux/pokete/commit/c998609a95868ac05f165d0360bd3c5440640b68", "https://github.com/lxgr-linux/pokete/commit/0585becab5015cb2144db76cfc18d89bfc61c8ff", "https://github.com/lxgr-linux/pokete/commit/2c694c409d9ca186998632055f2d6d43558a2851", "https://github.com/lxgr-linux/pokete/commit/fe8d3b9e48c0b4ca68a8acde1a83fc835ac53e8b", "https://github.com/lxgr-linux/pokete/commit/a9ac2d97008fb04bbaa350ae49539ca052e1a1c3", "https://github.com/lxgr-linux/pokete/commit/d3a3a61b33a92dc6cd2ebc8140413b522f7e754a", "https://github.com/lxgr-linux/pokete/commit/683699188cbda7615c9b7c3e06f30b1493eb4bd9", "https://github.com/lxgr-linux/pokete/commit/9dafa99a4ee0a9be1eb9f3ddd1ad571fb2756a3b", "https://github.com/lxgr-linux/pokete/commit/238312ccc01c337e97cadaa7f6514f768f18439e", "https://github.com/lxgr-linux/pokete/commit/2930a5304fdc4ea643c36e0333fce9487c8fb633", "https://github.com/lxgr-linux/pokete/commit/cc809c1bf403a2f3d313b0514a10f0f80e