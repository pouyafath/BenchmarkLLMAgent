+def _replace_auto(obj: Any, replacement: Any) -> Any:
+    """
+    Recursively replace any occurrence of the string ``\"auto\"`` in *obj*
+    with *replacement*. Handles dictionaries, lists, tuples and nested
+    structures. Non‑string values are returned unchanged.
+    """
+    if isinstance(obj, dict):
+        # Preserve the original dict type (normally a plain dict)
+        return {k: _replace_auto(v, replacement) for k, v in obj.items()}
+    if isinstance(obj, (list, tuple)):
+        # Preserve the original sequence type
+        return type(obj)(_replace_auto(v, replacement) for v in obj)
+    if isinstance(obj, str) and obj == "auto":
+        return replacement
+    return obj
