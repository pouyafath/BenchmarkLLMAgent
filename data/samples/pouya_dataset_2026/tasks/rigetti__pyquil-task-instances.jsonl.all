n_version == \\\"3.9\\\"\"\n files = [\n     {file = \"zipp-3.23.0-py3-none-any.whl\", hash = \"sha256:071652d6115ed432f5ce1d34c336c0adfd6a884660d1e9712a256d3d3bd4b14e\"},\n     {file = \"zipp-3.23.0.tar.gz\", hash = \"sha256:a07157588a12518c9d4034df3fbbee09c814741a33ff63c05fa29d26a2404166\"},\n ]\n \n [package.extras]\n-check = [\"pytest-checkdocs (>=2.4)\", \"pytest-ruff (>=0.2.1)\"]\n+check = [\"pytest-checkdocs (>=2.4)\", \"pytest-ruff (>=0.2.1) ; sys_platform != \\\"cygwin\\\"\"]\n cover = [\"pytest-cov\"]\n doc = [\"furo\", \"jaraco.packaging (>=9.3)\", \"jaraco.tidelift (>=1.4)\", \"rst.linker (>=1.9)\", \"sphinx (>=3.5)\", \"sphinx-lint\"]\n enabler = [\"pytest-enabler (>=2.2)\"]\n@@ -3661,6 +4530,6 @@ docs = [\"Sphinx\", \"matplotlib\", \"myst-parser\", \"nbsphinx\", \"pandoc\", \"seaborn\",\n latex = [\"ipython\"]\n \n [metadata]\n-lock-version = \"2.0\"\n-python-versions = \"^3.9,<4\"\n-content-hash = \"822afc186814f08d8abdac3479249f96f2a764e08a7268f5b7a1ea93485168c9\"\n+lock-version = \"2.1\"\n+python-versions = \"^3.9,<3.13\"\n+content-hash = \"7497c2e55515737cc5b451578890b87969f1899daf957fe71ffe1b1b9eac7974\"\ndiff --git a/pyproject.toml b/pyproject.toml\nindex 49f00c440..361be8bbc 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -21,13 +21,14 @@ packages = [{ include = \"pyquil\" }]\n exclude = [\"pyquil/conftest.py\"]\n \n [tool.poetry.dependencies]\n-python = \"^3.9,<4\"\n+# TODO(#1816): Loosen this bound once we've resolved support for Python 3.13+.\n+python = \"^3.9,<3.13\"\n numpy = \">=1.26,<3\"\n scipy = \"^1.11\"\n rpcq = \"^3.11.0\"\n networkx = \">=2.5\"\n-qcs-sdk-python = \">=0.20.1\"\n-quil = \">=0.15.3\"\n+qcs-sdk-python = \">=0.20.1,<0.22\"\n+quil = \">=0.15.3,<0.18\"\n packaging = \">=23.1\"\n deprecated = \"^1.2.14\"\n types-deprecated = \"^1.2.9.3\"\ndiff --git a/scripts/ci_install_deps b/scripts/ci_install_deps\nindex 360fa88c7..924ac079a 100755\n--- a/scripts/ci_install_deps\n+++ b/scripts/ci_install_deps\n@@ -1,7 +1,7 @@\n #!/usr/bin/env bash\n \n pip install --upgrade pip\n-curl -sSL https://install.python-poetry.org | POETRY_VERSION=1.8.5 python3 -\n+curl -sSL https://install.python-poetry.org | POETRY_VERSION=2.1.4 python3 -\n which poetry > /dev/null || export PATH=$PATH:$HOME/.local/bin\n poetry --version\n poetry config virtualenvs.in-project true\n", "test_patch": "", "problem_statement": "Dependency spec for pre-1.0 packages should be more restrictive\nThere are dependencies in the `pyproject.toml` with specifiers of just `>=0.X.Y` for projects that use semantic versioning. New installations and updates may pull in breaking changes. The version specifiers for those dependencies should be more restrictive to prevent this.\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/rigetti/pyquil/commit/1071f2e14805fc6296be57148a04eecbfc6315a4", "https://github.com/rigetti/pyquil/commit/2fc4b4778acfe1323069b69d55d9aa27c0e0a160", "https://github.com/rigetti/pyquil/commit/4bd6fbdf43ff9d467207a5fe3201837bfb2ca9e9"], "created_at": "2025-10-08T16:27:57Z"}
