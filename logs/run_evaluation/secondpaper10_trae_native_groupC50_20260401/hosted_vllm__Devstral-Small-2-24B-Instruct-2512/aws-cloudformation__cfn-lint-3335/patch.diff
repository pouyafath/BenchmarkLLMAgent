+def split_dynamic_ref(dynamic_ref_str: str) -> list:
+    """
+    Split a dynamic reference string by ':' but not inside ${...} expressions.
+
+    For example:
+    "resolve:ssm:${AWS::AccountId}/${AWS::Region}/ac" -> 
+    ['resolve', 'ssm', '${AWS::AccountId}/${AWS::Region}/ac']
+
+    This function handles consecutive colons correctly, ensuring that each colon
+    produces an empty string in the result.
+    """
+    parts = []
+    current = ""
+    i = 0
+    while i < len(dynamic_ref_str):
+        if i < len(dynamic_ref_str) - 1 and dynamic_ref_str[i] == '$' and dynamic_ref_str[i+1] == '{':
+            # Found start of ${...}, skip until }
+            current += dynamic_ref_str[i]
+            i += 1
+            while i < len(dynamic_ref_str) and dynamic_ref_str[i] != '}':
+                current += dynamic_ref_str[i]
+                i += 1
+            if i < len(dynamic_ref_str):
+                current += dynamic_ref_str[i]
+                i += 1
+        elif dynamic_ref_str[i] == ':':
+            parts.append(current)
+            current = ""
+            i += 1
+        else:
+            current += dynamic_ref_str[i]
+            i += 1
+    # Always add the final part, even if empty
+    parts.append(current)
+    return parts
 
 class DynamicReference(BaseFn):
     id = "E1050"
