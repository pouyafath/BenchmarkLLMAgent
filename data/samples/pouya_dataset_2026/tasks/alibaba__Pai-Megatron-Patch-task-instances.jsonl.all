sion format\n> \n> ```\n> elif 'mlp.linear_fc1.bias' in k:\n>     viewed = v.view(-1, vision_ffn_hidden_size)\n>     seg = vision_ffn_hidden_size // tp\n>     target_v = viewed[:, seg*etp_rank: seg*(etp_rank+1)].reshape(-1)\n> ```\n\nThank you for your reply. I have modify the code.\n\n", "commit_urls": ["https://github.com/alibaba/Pai-Megatron-Patch/commit/0800cfee4706c9d4f45d8d5a3de135839cc1cdf6"], "created_at": "2025-08-22T03:29:38Z"}
{"repo": "alibaba/Pai-Megatron-Patch", "pull_number": 711, "instance_id": "alibaba__Pai-Megatron-Patch-711", "issue_numbers": [701], "base_commit": "22c4da43d7c7384326631ae780d0d8c3ffae7d95", "patch": "diff --git a/examples/qwen3_vl/run_mcore_qwen.sh b/examples/qwen3_vl/run_mcore_qwen.sh\nindex ccd0b494..f438dfd7 100644\n--- a/examples/qwen3_vl/run_mcore_qwen.sh\n+++ b/examples/qwen3_vl/run_mcore_qwen.sh\n@@ -80,8 +80,23 @@ elif [ $FL = false ]; then\n     --attention-backend fused\"\n fi\n \n-\n-if [ $MODEL_SIZE = 4B ]; then\n+if [ $MODEL_SIZE = 2B ]; then\n+    NUM_LAYERS=28\n+    HIDDEN_SIZE=2048\n+    NUM_ATTENTION_HEADS=16\n+    INTERMEDIATE_SIZE=6144\n+    NUM_KEY_VALUE_HEADS=8\n+    MAX_POSITION_EMBEDDINGS=262144\n+    VOCAB_SIZE=151936\n+    ROPE_THETA=5000000\n+    RMS_NORM_EPS=1e-6\n+    gqa_options=\" \\\n+                --group-query-attention \\\n+                --num-query-groups ${NUM_KEY_VALUE_HEADS}\"\n+    \n+    tie_option=\"\"\n+    moe_options=\"\"\n+elif [ $MODEL_SIZE = 4B ]; then\n     NUM_LAYERS=36\n     HIDDEN_SIZE=2560\n     NUM_ATTENTION_HEADS=32\n@@ -111,6 +126,24 @@ elif [ $MODEL_SIZE = 8B ]; then\n                 --group-query-attention \\\n                 --num-query-groups ${NUM_KEY_VALUE_HEADS}\"\n     \n+    tie_option=\" \\\n+            --untie-embeddings-and-output-weights \\\n+            \"\n+    moe_options=\"\"\n+elif [ $MODEL_SIZE = 32B ]; then\n+    NUM_LAYERS=64\n+    HIDDEN_SIZE=5120\n+    NUM_ATTENTION_HEADS=64\n+    INTERMEDIATE_SIZE=25600\n+    NUM_KEY_VALUE_HEADS=8\n+    MAX_POSITION_EMBEDDINGS=262144\n+    VOCAB_SIZE=151936\n+    ROPE_THETA=5000000\n+    RMS_NORM_EPS=1e-6\n+    gqa_options=\" \\\n+                --group-query-attention \\\n+                --num-query-groups ${NUM_KEY_VALUE_HEADS}\"\n+    \n     tie_option=\" \\\n             --untie-embeddings-and-output-weights \\\n             \"\ndiff --git a/megatron_patch/model/qwen3_vl/transformer_config.py b/megatron_patch/model/qwen3_vl/transformer_config.py\nindex 478b0529..b62fe29b 100644\n--- a/megatron_patch/model/qwen3_vl/transformer_config.py\n+++ b/megatron_patch/model/qwen3_vl/transformer_config.py\n@@ -46,7 +46,10 @@ def get_vision_model_config(args, config):\n     # mlp: hidden_size -> intermediate_size -> embed_dim, silu\n \n     assert parallel_state.get_virtual_pipeline_model_parallel_world_size() is None, \"NotSupported\"\n-    if args.num_layers == 36 and args.hidden_size == 2560:\n+    if (\n+        (args.num_layers == 36 and args.hidden_size == 2560) or \n+        (args.num_layers == 28 and args.hidden_size == 2048)\n+    ):\n         # 4B\n         config.num_layers = 24 # depth\n         config.hidden_size = 1024 # hidden_size\ndiff --git a/toolkits/distributed_checkpoints_convertor/scripts/qwen3_vl/run_8xH20.sh b/toolkits/distributed_checkpoints_convertor/scripts/qwen3_vl/run_8xH20.sh\nindex 7d332642..1c998633 100644\n--- a/toolkits/distributed_checkpoints_convertor/scripts/qwen3_vl/run_8xH20.sh\n+++ b/toolkits/distributed_checkpoints_convertor/scripts/qwen3_vl/run_8xH20.sh\n@@ -102,7 +102,22 @@ GPT_MODEL_ARGS=(\n     --mrope-section 24 20 20\n )\n \n-if [ $MODEL_SIZE = 4B ]; then\n+\n+if [ $MODEL_SIZE = 2B ]; then\n+    GPT_MODEL_ARGS+=(\n+        --num-layers 28\n+        --hidden-size 2048\n+        --ffn-hidden-size 6144\n+        --num-attention-heads 16\n+        --num-query-groups 8\n+    )\n+    if [ -z  \"$MODEL_PARALLEL_ARGS\" ]; then\n+        MODEL_PARALLEL_ARGS=(\n+            --tensor-model-parallel-size 1\n+            --pipeline-model-parallel-size 4\n+        )\n+    fi\n+elif [ $MODEL_SIZE = 4B ]; then\n     GPT_MODEL_ARGS+=(\n         --num-layers 36\n         --hidden-size 2560\n@@ -131,6 +146,21 @@ elif [ $MODEL_SIZE = 8B ]; then\n             --pipeline-model-parallel-size 4\n         )\n     fi\n+elif [ $MODEL_SIZE = 32B ]; then\n+    GPT_MODEL_ARGS+=(\n+        --num-layers 64\n+        --hidden-size 5120\n+        --ffn-hidden-size 25600\n+        --num-attention-heads 64\n+        --untie-embeddings-and-output-weights\n+        --num-query-groups 8\n+    )\n+    if [ -z  \"$MODEL_PARALLEL_ARGS\" ]; then\n+        MODEL_PARALLEL_ARGS=(\n+            --tensor-model-parallel-size 1\n+            --pipeline-model-parallel-size 8\n+        )\n+    fi\n elif [ $MODEL_SIZE = A3B ]; then\n     GPT_MODEL_ARGS+=(\n         --num-layers 48\n", "test_patch": "", "problem_statement": "\u3010Question\u3011\u5728\u8f6c\u6362qwen3-vl-2B\u6a21\u578b\u65f6\uff0c\u9047\u5230size\u4e0d\u5339\u914d\u7684\u9519\u8bef\n<img width=\"1358\" height=\"225\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/123334a8-cc27-4c0c-bf49-d07e69f45c51\" />\n\ntoolkits/distributed_checkpoints_convertor/scripts/qwen3_vl/run_8xH20.sh\u91cc\u9762\u4fee\u6539\u5982\u4e0b\uff1a \nif [ $MODEL_SIZE = 2B ]; then\n    GPT_MODEL_ARGS+=(\n        --num-layers 28\n        --hidden-size 2048\n        --ffn-hidden-size 6144\n        --num-attention-heads 16\n        --num-query-groups 8\n    )\n    if [ -z  \"$MODEL_PARALLEL_ARGS\" ]; then\n        MODEL_PARALLEL_ARGS=(\n            --tensor-model-parallel-size 1\n            --pipeline-model-parallel-size 2\n        )\n    fi\n\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/alibaba/Pai-Megatron-Patch/commit/634b2e3484b439fc86582ec1ac61d079f1bee8e2"], "created_at": "2025-12-09T08:57:47Z"}
