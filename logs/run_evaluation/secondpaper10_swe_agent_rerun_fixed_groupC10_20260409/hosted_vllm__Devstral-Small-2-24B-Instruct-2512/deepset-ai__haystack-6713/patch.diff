+logger = logging.getLogger(__name__)
+
+class _CustomDumper(yaml.SafeDumper):
+    """
+    Custom YAML dumper that handles non-serializable types.
+    """
+    def represent_data(self, data):
+        # Handle torch dtypes (instances of torch.dtype)
+        if hasattr(data, '__module__') and data.__module__.startswith('torch'):
+            return self.represent_str(str(data))
+
+        # Handle numpy dtypes (instances of np.dtype)
+        if hasattr(data, 'dtype') and hasattr(data.dtype, '__module__') and data.dtype.__module__.startswith('numpy'):
+            return self.represent_str(str(data))
+
+        # Handle numpy type objects (like np.float32 which is a type)
+        if isinstance(data, type) and hasattr(data, '__module__') and data.__module__.startswith('numpy'):
+            return self.represent_str(str(data))
+
+        # Fall back to default representation
+        return super().represent_data(data)
+
+def _deserialize_value(value: str) -> Any:
+    """
+    Attempts to deserialize a string representation back to its original type.
+    Handles torch dtypes, numpy dtypes, and other common non-serializable types.
+    """
+    if not isinstance(value, str):
+        return value
+
+    # Handle torch dtypes
+    if value.startswith('torch.'):
+        try:
+            import torch
+            dtype_name = value.split('.')[-1]
+            return getattr(torch, dtype_name)
+        except (ImportError, AttributeError):
+            logger.warning(f"Could not import torch to deserialize {value}, returning string representation")
+            return value
 
+    # Handle numpy dtypes
+    if value.startswith('numpy.') or value.startswith('float') or value.startswith('int') or value.startswith('bool'):
+        try:
+            import numpy as np
+            # Handle cases like "float32", "int64", etc.
+            if hasattr(np, value):
+                return getattr(np, value)
+            # Handle cases like "numpy.float32"
+            elif value.startswith('numpy.'):
+                dtype_name = value.split('.')[-1]
+                if hasattr(np, dtype_name):
+                    return getattr(np, dtype_name)
+        except (ImportError, AttributeError):
+            logger.warning(f"Could not import numpy to deserialize {value}, returning string representation")
+            return value
+
+    # Handle other common types
+    if value == 'True':
+        return True
+    elif value == 'False':
+        return False
+    elif value == 'None':
+        return None
+
+    # Try to evaluate simple types like int, float
+    try:
+        if '.' in value:
+            return float(value)
+        else:
+            return int(value)
+    except ValueError:
+        pass
+
+    return value
 
 class YamlMarshaller:
