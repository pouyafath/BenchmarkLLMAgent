And warnings should be displayed\n+    assert \"WARNINGS\" in result.stdout\n+    assert \"Authentication failed\" in result.stdout\ndiff --git a/test/config/__snapshots__/test_config/test_configs[common.warnings-fail-on-all].raw b/test/config/__snapshots__/test_config/test_configs[common.warnings-fail-on-all].raw\nnew file mode 100644\nindex 0000000000..c952eda7f6\n--- /dev/null\n+++ b/test/config/__snapshots__/test_config/test_configs[common.warnings-fail-on-all].raw\n@@ -0,0 +1,1 @@\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=WarningsConfig(fail_on=[<SchemathesisWarning.MISSING_AUTH: 'missing_auth'>, <SchemathesisWarning.MISSING_TEST_DATA: 'missing_test_data'>, <SchemathesisWarning.VALIDATION_MISMATCH: 'validation_mismatch'>]))))\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_config/test_configs[common.warnings-fail-on-specific].raw b/test/config/__snapshots__/test_config/test_configs[common.warnings-fail-on-specific].raw\nnew file mode 100644\nindex 0000000000..aa3ddea7f6\n--- /dev/null\n+++ b/test/config/__snapshots__/test_config/test_configs[common.warnings-fail-on-specific].raw\n@@ -0,0 +1,1 @@\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=WarningsConfig(fail_on=[<SchemathesisWarning.VALIDATION_MISMATCH: 'validation_mismatch'>]))))\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_config/test_configs[common.warnings-object-complex].raw b/test/config/__snapshots__/test_config/test_configs[common.warnings-object-complex].raw\nnew file mode 100644\nindex 0000000000..e8b3bc054f\n--- /dev/null\n+++ b/test/config/__snapshots__/test_config/test_configs[common.warnings-object-complex].raw\n@@ -0,0 +1,1 @@\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=WarningsConfig(display=[<SchemathesisWarning.MISSING_AUTH: 'missing_auth'>, <SchemathesisWarning.VALIDATION_MISMATCH: 'validation_mismatch'>], fail_on=[<SchemathesisWarning.VALIDATION_MISMATCH: 'validation_mismatch'>]))))\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_config/test_configs[common.warnings-object-with-display].raw b/test/config/__snapshots__/test_config/test_configs[common.warnings-object-with-display].raw\nnew file mode 100644\nindex 0000000000..8dc46abac1\n--- /dev/null\n+++ b/test/config/__snapshots__/test_config/test_configs[common.warnings-object-with-display].raw\n@@ -0,0 +1,1 @@\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=WarningsConfig(display=[<SchemathesisWarning.MISSING_AUTH: 'missing_auth'>, <SchemathesisWarning.VALIDATION_MISMATCH: 'validation_mismatch'>]))))\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_config/test_configs[common.warnings-off].raw b/test/config/__snapshots__/test_config/test_configs[common.warnings-off].raw\nindex b10a3206a0..6147444c7e 100644\n--- a/test/config/__snapshots__/test_config/test_configs[common.warnings-off].raw\n+++ b/test/config/__snapshots__/test_config/test_configs[common.warnings-off].raw\n@@ -1,1 +1,1 @@\n-SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=[])))\n\\ No newline at end of file\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=WarningsConfig(display=[]))))\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_config/test_configs[common.warnings-on].raw b/test/config/__snapshots__/test_config/test_configs[common.warnings-on].raw\nindex fab67b1e4b..7ee582a6a8 100644\n--- a/test/config/__snapshots__/test_config/test_configs[common.warnings-on].raw\n+++ b/test/config/__snapshots__/test_config/test_configs[common.warnings-on].raw\n@@ -1,1 +1,1 @@\n-SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=[<SchemathesisWarning.MISSING_AUTH: 'missing_auth'>, <SchemathesisWarning.MISSING_TEST_DATA: 'missing_test_data'>, <SchemathesisWarning.VALIDATION_MISMATCH: 'validation_mismatch'>])))\n\\ No newline at end of file\n+SchemathesisConfig()\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_config/test_configs[common.warnings-selection].raw b/test/config/__snapshots__/test_config/test_configs[common.warnings-selection].raw\nindex 380b3774fd..9f0da29996 100644\n--- a/test/config/__snapshots__/test_config/test_configs[common.warnings-selection].raw\n+++ b/test/config/__snapshots__/test_config/test_configs[common.warnings-selection].raw\n@@ -1,1 +1,1 @@\n-SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=[<SchemathesisWarning.MISSING_AUTH: 'missing_auth'>])))\n\\ No newline at end of file\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=WarningsConfig(display=[<SchemathesisWarning.MISSING_AUTH: 'missing_auth'>]))))\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_config/test_configs[operations.warnings-off].raw b/test/config/__snapshots__/test_config/test_configs[operations.warnings-off].raw\nindex 4beee4830c..cd22a82b1b 100644\n--- a/test/config/__snapshots__/test_config/test_configs[operations.warnings-off].raw\n+++ b/test/config/__snapshots__/test_config/test_configs[operations.warnings-off].raw\n@@ -1,1 +1,1 @@\n-SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(operations=[OperationConfig(filter_set=FilterSet(_includes={<Filter: [label='GET /users/{user_id}']>}, _excludes=set()), warnings=[])])))\n\\ No newline at end of file\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(operations=[OperationConfig(filter_set=FilterSet(_includes={<Filter: [label='GET /users/{user_id}']>}, _excludes=set()), warnings=WarningsConfig(display=[]))])))\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_config/test_configs[operations.warnings-on].raw b/test/config/__snapshots__/test_config/test_configs[operations.warnings-on].raw\nindex 606f981495..2ed9f07af6 100644\n--- a/test/config/__snapshots__/test_config/test_configs[operations.warnings-on].raw\n+++ b/test/config/__snapshots__/test_config/test_configs[operations.warnings-on].raw\n@@ -1,1 +1,1 @@\n-SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(operations=[OperationConfig(filter_set=FilterSet(_includes={<Filter: [label='GET /users/{user_id}']>}, _excludes=set()), warnings=[<SchemathesisWarning.MISSING_AUTH: 'missing_auth'>, <SchemathesisWarning.MISSING_TEST_DATA: 'missing_test_data'>, <SchemathesisWarning.VALIDATION_MISMATCH: 'validation_mismatch'>])])))\n\\ No newline at end of file\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(operations=[OperationConfig(filter_set=FilterSet(_includes={<Filter: [label='GET /users/{user_id}']>}, _excludes=set()))])))\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_doc_examples/test_configs[disable_all_warnings_warnings].raw b/test/config/__snapshots__/test_doc_examples/test_configs[disable_all_warnings_warnings0].raw\nsimilarity index 62%\nrename from test/config/__snapshots__/test_doc_examples/test_configs[disable_all_warnings_warnings].raw\nrename to test/config/__snapshots__/test_doc_examples/test_configs[disable_all_warnings_warnings0].raw\nindex b10a3206a0..6147444c7e 100644\n--- a/test/config/__snapshots__/test_doc_examples/test_configs[disable_all_warnings_warnings].raw\n+++ b/test/config/__snapshots__/test_doc_examples/test_configs[disable_all_warnings_warnings0].raw\n@@ -1,1 +1,1 @@\n-SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=[])))\n\\ No newline at end of file\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=WarningsConfig(display=[]))))\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_doc_examples/test_configs[disable_all_warnings_warnings1].raw b/test/config/__snapshots__/test_doc_examples/test_configs[disable_all_warnings_warnings1].raw\nnew file mode 100644\nindex 0000000000..6147444c7e\n--- /dev/null\n+++ b/test/config/__snapshots__