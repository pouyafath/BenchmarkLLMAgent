diff --git a/gateway/run.py b/gateway/run.py
index eea7bf27..a1ecd0ce 100644
--- a/gateway/run.py
+++ b/gateway/run.py
@@ -2647,6 +2647,12 @@ class GatewayRunner:
 
         # Check pairing store (always checked, regardless of allowlists)
         platform_name = source.platform.value if source.platform else ""
+        # For Discord bots: check DISCORD_ALLOW_BOTS setting
+        if source.platform == Platform.DISCORD and source.is_bot:
+            allow_bots = os.getenv("DISCORD_ALLOW_BOTS", "none").lower().strip()
+            if allow_bots in ("all", "mentions"):
+                return True
+            # "none" falls through to normal allowlist check
         if self.pairing_store.is_approved(platform_name, user_id):
             return True
 
