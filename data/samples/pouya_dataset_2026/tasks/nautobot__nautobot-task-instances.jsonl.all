roup\",\n             \"tenant\",\n         )\n         default_columns = (\ndiff --git a/nautobot/vpn/views.py b/nautobot/vpn/views.py\nindex 760230a907a..5c2b0d93be8 100644\n--- a/nautobot/vpn/views.py\n+++ b/nautobot/vpn/views.py\n@@ -342,6 +342,7 @@ class VPNTunnelUIViewSet(NautobotUIViewSet):\n                     \"encapsulation\",\n                     \"role\",\n                     \"status\",\n+                    \"secrets_group\",\n                     \"tenant\",\n                 ],\n             ),\ndiff --git a/tasks.py b/tasks.py\nindex 33de1952e27..de0a2925df8 100644\n--- a/tasks.py\n+++ b/tasks.py\n@@ -1064,6 +1064,7 @@ def check_schema(context, api_version=None):\n     help={\n         \"append_coverage\": \"Append coverage data to .coverage, otherwise it starts clean each time.\",\n         \"buffer\": \"Discard output from passing tests.\",\n+        \"pdb\": \"Drop into the Python debugger on test failure. Should be used with `--no-buffer` to see output.\",\n         \"cache_test_fixtures\": \"Save test database to a json fixture file to re-use on subsequent tests.\",\n         \"config_file\": \"Specify an alternative nautobot_config.py file to use for tests\",\n         \"coverage\": \"Enable test code-coverage reporting. Off by default due to performance impact.\",\n@@ -1085,6 +1086,7 @@ def tests(\n     context,\n     append_coverage=False,\n     buffer=True,\n+    pdb=False,\n     cache_test_fixtures=True,\n     config_file=\"nautobot/core/tests/nautobot_config.py\",\n     coverage=False,\n@@ -1139,6 +1141,8 @@ def tests(\n         command += \" --buffer\"\n     if verbose:\n         command += \" --verbosity 2\"\n+    if pdb:\n+        command += \" --pdb\"\n     if parallel:\n         command += \" --parallel\"\n         if parallel_workers:\n", "test_patch": "", "problem_statement": "VPN - Add ability to attach a Secret Group to each VPN Tunnel\n### As ...\n\nNelly - Network Engineer\n\n### I want ...\n\nto be able to attach different secrets to each VPN tunnel\n\n### So that ...\n\nI don't have to duplicate profiles\n\n### I know this is done when...\n\nI can attach a secrets group directly to a VPN Tunnel\n\n### Optional - Feature groups this request pertains to.\n\n- [ ] Automation\n- [ ] Circuits\n- [ ] DCIM\n- [ ] IPAM\n- [ ] Misc (including Data Sources)\n- [ ] Organization\n- [ ] Apps (and other Extensibility)\n- [ ] Security (Secrets, etc)\n- [ ] Image Management\n- [ ] UI/UX\n- [ ] Documentation\n- [ ] Other (not directly a platform feature)\n\n### Database Changes\n\n_No response_\n\n### External Dependencies\n\n_No response_\nVPN filtering not working as expected\n### Environment\n* Nautobot version (Docker tag too if applicable): v3.0.x\n* Python version: N/A\n* Database platform, version: N/A\n* Middleware(s): N/A\n\n### Steps to Reproduce\n1. Navigate to `VPN > VPNs`\n2. Expand the filtering pane\n3. VPN-related filtering options are missing\n\n### Expected Behavior\n1. Navigate to `VPN > VPNs`\n2. Expand the filtering pane\n3. VPN-related filtering options present (e.g. VPN Profile)\n\n### Observed Behavior\nAs described above, the same is true for all VPN Models (i.e. VPN, VPNTunnel, VPNTunnelEndpoint, VPNProfile, VPNPhase1Policy, VPNPhase2Policy)\nAdd VPN, VPNTunnel to global searchable models\n### As ...\n\nOzzie - Operator\n\n### I want ...\n\nVPN and VPN Tunnels to be added to the globally searchable models.\n\n### So that ...\n\nI get VPN-related results when I'm using the global search.\n\n### I know this is done when...\n\nI perform a global search and I see VPN-related results returned.\n\n### Optional - Feature groups this request pertains to.\n\n- [ ] Automation\n- [ ] Circuits\n- [ ] DCIM\n- [ ] IPAM\n- [ ] Misc (including Data Sources)\n- [ ] Organization\n- [ ] Apps (and other Extensibility)\n- [ ] Security (Secrets, etc)\n- [ ] Image Management\n- [ ] UI/UX\n- [ ] Documentation\n- [ ] Other (not directly a platform feature)\n\n### Database Changes\n\nNone\n\n### External Dependencies\n\nNone\n", "hints_text": "\n\n\n\n\n\n", "all_hints_text": "\n\n\n\n\n\n", "commit_urls": ["https://github.com/nautobot/nautobot/commit/badc267b2568cad5a1fd4a46b870c59bb76d0802", "https://github.com/nautobot/nautobot/commit/ce19c31f33c2a26e5ca008bb32891f85166a51f7", "https://github.com/nautobot/nautobot/commit/1cb303aa283b69bbb98184d7b34df626dbc2203b", "https://github.com/nautobot/nautobot/commit/2ce8ee37ac54a156be71a96b206d6306547ead0e", "https://github.com/nautobot/nautobot/commit/7605ad19a57dacd0f13df1fe2468f1b69765a4b4", "https://github.com/nautobot/nautobot/commit/efe7958e8439e13faafa91c20bba1e39543274d0", "https://github.com/nautobot/nautobot/commit/a3b6ce21a723982f6e133bc6436b47edca89f241", "https://github.com/nautobot/nautobot/commit/8f042d79dada8e219b701699329f4e7342c437ff", "https://github.com/nautobot/nautobot/commit/831e141f633148f38ed12459fbfb848426800253", "https://github.com/nautobot/nautobot/commit/bbdf85c108cef311c8f0daf82803646633665d82", "https://github.com/nautobot/nautobot/commit/4740bfefb5de15561b94ec5db3e932cde22282b9"], "created_at": "2026-03-23T17:47:21Z"}
