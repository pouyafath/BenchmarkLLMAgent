-        return yaml.safe_load(data_)
+        if isinstance(data_, bytes):
+            data_ = data_.decode('utf-8')
+        elif isinstance(data_, bytearray):
+            data_ = bytes(data_).decode('utf-8')
+
+        result = yaml.safe_load(data_)
+        if result is None:
+            result = {}
+
+        # Recursively deserialize values in the result
+        return self._deserialize_dict(result)
