ll\n+++ b/test/config/__snapshots__/test_doc_examples/test_configs[operations_include_name_get_u].raw\n@@ -0,0 +1,1 @@\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(operations=[OperationConfig(filter_set=FilterSet(_includes={<Filter: [label='GET /users/{user_id}']>}, _excludes=set()), parameters={'user_id': 42})])))\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_doc_examples/test_configs[warnings_control_which_warnin0].raw b/test/config/__snapshots__/test_doc_examples/test_configs[warnings_control_which_warnin0].raw\nnew file mode 100644\nindex 0000000000..aa3ddea7f6\n--- /dev/null\n+++ b/test/config/__snapshots__/test_doc_examples/test_configs[warnings_control_which_warnin0].raw\n@@ -0,0 +1,1 @@\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=WarningsConfig(fail_on=[<SchemathesisWarning.VALIDATION_MISMATCH: 'validation_mismatch'>]))))\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_doc_examples/test_configs[warnings_control_which_warnin1].raw b/test/config/__snapshots__/test_doc_examples/test_configs[warnings_control_which_warnin1].raw\nnew file mode 100644\nindex 0000000000..aa3ddea7f6\n--- /dev/null\n+++ b/test/config/__snapshots__/test_doc_examples/test_configs[warnings_control_which_warnin1].raw\n@@ -0,0 +1,1 @@\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=WarningsConfig(fail_on=[<SchemathesisWarning.VALIDATION_MISMATCH: 'validation_mismatch'>]))))\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_doc_examples/test_configs[warnings_fail_on_all_displaye].raw b/test/config/__snapshots__/test_doc_examples/test_configs[warnings_fail_on_all_displaye].raw\nnew file mode 100644\nindex 0000000000..c952eda7f6\n--- /dev/null\n+++ b/test/config/__snapshots__/test_doc_examples/test_configs[warnings_fail_on_all_displaye].raw\n@@ -0,0 +1,1 @@\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=WarningsConfig(fail_on=[<SchemathesisWarning.MISSING_AUTH: 'missing_auth'>, <SchemathesisWarning.MISSING_TEST_DATA: 'missing_test_data'>, <SchemathesisWarning.VALIDATION_MISMATCH: 'validation_mismatch'>]))))\n\\ No newline at end of file\ndiff --git a/test/config/__snapshots__/test_doc_examples/test_configs[warnings_fail_on_true_fail_on].raw b/test/config/__snapshots__/test_doc_examples/test_configs[warnings_fail_on_true_fail_on].raw\nnew file mode 100644\nindex 0000000000..c952eda7f6\n--- /dev/null\n+++ b/test/config/__snapshots__/test_doc_examples/test_configs[warnings_fail_on_true_fail_on].raw\n@@ -0,0 +1,1 @@\n+SchemathesisConfig(projects=ProjectsConfig(default=ProjectConfig(warnings=WarningsConfig(fail_on=[<SchemathesisWarning.MISSING_AUTH: 'missing_auth'>, <SchemathesisWarning.MISSING_TEST_DATA: 'missing_test_data'>, <SchemathesisWarning.VALIDATION_MISMATCH: 'validation_mismatch'>]))))\n\\ No newline at end of file\ndiff --git a/test/config/configs/common/warnings-fail-on-all.toml b/test/config/configs/common/warnings-fail-on-all.toml\nnew file mode 100644\nindex 0000000000..eded4f1bac\n--- /dev/null\n+++ b/test/config/configs/common/warnings-fail-on-all.toml\n@@ -0,0 +1,2 @@\n+[warnings]\n+fail-on = true\ndiff --git a/test/config/configs/common/warnings-fail-on-specific.toml b/test/config/configs/common/warnings-fail-on-specific.toml\nnew file mode 100644\nindex 0000000000..0dd6b0111d\n--- /dev/null\n+++ b/test/config/configs/common/warnings-fail-on-specific.toml\n@@ -0,0 +1,2 @@\n+[warnings]\n+fail-on = [\"validation_mismatch\"]\ndiff --git a/test/config/configs/common/warnings-object-complex.toml b/test/config/configs/common/warnings-object-complex.toml\nnew file mode 100644\nindex 0000000000..41af226e60\n--- /dev/null\n+++ b/test/config/configs/common/warnings-object-complex.toml\n@@ -0,0 +1,3 @@\n+[warnings]\n+display = [\"missing_auth\", \"validation_mismatch\"]\n+fail-on = [\"validation_mismatch\"]\ndiff --git a/test/config/configs/common/warnings-object-with-display.toml b/test/config/configs/common/warnings-object-with-display.toml\nnew file mode 100644\nindex 0000000000..569fa56580\n--- /dev/null\n+++ b/test/config/configs/common/warnings-object-with-display.toml\n@@ -0,0 +1,2 @@\n+[warnings]\n+display = [\"missing_auth\", \"validation_mismatch\"]\ndiff --git a/test/config/test_config.py b/test/config/test_config.py\nindex cd7bc22044..1ff0d9bb66 100644\n--- a/test/config/test_config.py\n+++ b/test/config/test_config.py\n@@ -42,7 +42,7 @@ def test_configs(monkeypatch, path, snapshot_config):\n \n def test_warnings_for_without_operations():\n     config = SchemathesisConfig.from_dict({\"warnings\": False})\n-    assert config.projects.default.warnings_for(operation=None) == []\n+    assert config.projects.default.warnings_for(operation=None).display == []\n \n \n def test_project_key_config_sync():\ndiff --git a/test/config/test_doc_examples.py b/test/config/test_doc_examples.py\nindex e82db35d71..f9a1db5919 100644\n--- a/test/config/test_doc_examples.py\n+++ b/test/config/test_doc_examples.py\n@@ -27,7 +27,11 @@ def extract_examples(path: str, format: str = \"toml\") -> list:\n     return pattern.findall(markdown)\n \n \n-ALL_CONFIGS = extract_examples(\"reference/configuration.md\") + extract_examples(\"configuration.md\")\n+ALL_CONFIGS = (\n+    extract_examples(\"reference/configuration.md\")\n+    + extract_examples(\"reference/warnings.md\")\n+    + extract_examples(\"configuration.md\")\n+)\n DEFAULT_CONFIG = SchemathesisConfig()\n \n \ndiff --git a/test/specs/openapi/stateful/test_cli.py b/test/specs/openapi/stateful/test_cli.py\nindex f652d7b6f3..fc3b220f53 100644\n--- a/test/specs/openapi/stateful/test_cli.py\n+++ b/test/specs/openapi/stateful/test_cli.py\n@@ -272,7 +272,10 @@ def test_link_requestbody_extraction_fails_when_producer_missing_id(cli, app_run\n                             \"application/json\": {\n                                 \"schema\": {\n                                     \"type\": \"object\",\n-                                    \"properties\": {\"name\": {\"type\": \"string\"}, \"price\": {\"type\": \"number\"}},\n+                                    \"properties\": {\n+                                        \"name\": {\"type\": \"string\", \"enum\": [\"Product\"]},\n+                                        \"price\": {\"type\": \"number\", \"enum\": [9.99]},\n+                                    },\n                                     \"required\": [\"name\", \"price\"],\n                                 }\n                             }\n@@ -358,10 +361,14 @@ def create_product():\n         nonlocal next_id\n         data = request.get_json() or {}\n         if not isinstance(data, dict):\n-            return {\"error\": \"Invalid input\"}\n+            return {\"error\": \"Invalid input\"}, 400\n+\n+        name = data.get(\"name\", \"Product\")\n+        if not isinstance(name, str) or not name:\n+            return {\"error\": \"Invalid name\"}, 400\n \n         price = data.get(\"price\", 9.99)\n-        if not isinstance(price, float):\n+        if not isinstance(price, (int, float)):\n             return {\"error\": \"Invalid price\"}, 400\n \n         product_id = str(next_id)\n@@ -369,8 +376,8 @@ def create_product():\n \n         products[product_id] = {\n             \"id\": product_id,\n-            \"name\": str(data.get(\"name\", \"Product\")),\n-            \"price\": price,\n+            \"name\": name,\n+            \"price\": float(price),\n         }\n \n         return jsonify({\"name\": products[product_id][\"name\"], \"price\": products[product_id][\"price\"]}), 201\n", "problem_statement": "[FEATURE] Warnings should be configurable as errors\n### Is your feature request related to a problem? Please describe\n\nWhen I am trying to test an endpoint, I expect to see the response code statuses are met as specified. Currently, the 4xx status codes are treated as warnings (for example, improper authentication). Which essentially \"passes\" the test despite the authorisation not set up properly, for example.\n\nThe CLI test started failing silently and instead of notifying the user that there was something wrong, it caused them to be warnings and returned them as successful instead.\n\nWhile I'm trying to push this solution within the org for automated contract-testing, this happened on our team and would be a significant blocker in the adoption.\n\n### Describe the solution you'd like\n\nboolean configurable value of \"mark as passed when warnings reported\"? Allows a user to determine if the warnings should be treated as critical, or as warnings. \n \n### Describe alternatives you've considered\n\nAnother would be to allow warning checks to be passed as errors instead. Instead of all the warnings being errors, some are kept as warnings while the other are elevated to errors. However, this increases the overhead when determining what checks need to be added to the \"ever-growing\" list.\n\n\n", "hints_text": "Hi @Akshayanti \n\nThank you for opening this issue! I have a few comments and questions\n\n> Currently, the 4xx status codes are treated as warnings (for example, improper authentication)\n\nThe checks for status code & response payload conformance are separate from these warnings and will emit failures if the responses are not conformant to the schema. \n\nImproper authentication - if you mean that Schemathesis is not configured properly, then it is a warning intentionally; the API contract is fine, and the user may want to run tests without auth, which presumably will trigger code paths that are not covered when the provided auth is correct. There is no way for Schemathesis to know whether it is the case or not.\n\nIf you meant that the API does not have a correct auth setup, then the `ignored_auth` check deals with it and is separate from the warnings.\n\nCould you please elaborate on the auth here?\n\n> The CLI test started failing silently and instead of notifying the user that there was something wrong, it caused them to be warnings and returned them as successful instead.\n\nThere are legitimate scenarios where these warnings are expected. For example, testing codepaths for invalid/malformed auth. However, I agree that it may be too conservative behavior that aims to avoid false positives.\n\n> boolean configurable value of \"mark as passed when warnings reported\"? Allows a user to determine if the warnings should be treated as critical, or as warnings.\n\nSounds good to me! Right now, I'd keep the old behavior as default, and I'd be keen to gather more feedback on this and change it if such an expectation appears in the majority of the cases.\n\nI am thinking about extending this [config option](https://schemathesis.readthedocs.io/en/stable/reference/configuration/#warnings), so it could also provide control over individual warnings + a single option to treat all warnings as errors.\nThat makes the most amount of sense to me. It's easily extendible and doesn't break backward compatibility.\nWe were running schemathesis using an old token and it ran successfully. However, when the token expired, it showed no error and started producing a bunch of warnings without failing. It's important to note we didn't have 'ignored_auth' check enabled before.\n\nSo, while it makes sense to add that check. I also believe that warnings should be considered as soft failures with an option of marking them as hard failures.\nAgree! I am on vacation till next Friday, so I'll work on it at the end of next week. Meanwhile, I could review PRs if anybody is willing to contribute\nIn any event, I'll try to think a bit more about it and maybe also add some documentation notes to make this behavior more visible to the users.\n\n", "all_hints_text": "Hi @Akshayanti \n\nThank you for opening this issue! I have a few comments and questions\n\n> Currently, the 4xx status codes are treated as warnings (for example, improper authentication)\n\nThe checks for status code & response payload conformance are separate from these warnings and will emit failures if the responses are not conformant to the schema. \n\nImproper authentication - if you mean that Schemathesis is not configured properly, then it is a warning intentionally; the API contract is fine, and the user may want to run tests without auth, which presumably will trigger code paths that are not covered when the provided auth is correct. There is no way for Schemathesis to know whether it is the case or not.\n\nIf you meant that the API does not have a correct auth setup, then the `ignored_auth` check deals with it and is separate from the warnings.\n\nCould you please elaborate on the auth here?\n\n> The CLI test started failing silently and instead of notifying the user that there was something wrong, it caused them to be warnings and returned them as successful instead.\n\nThere are legitimate scenarios where these warnings are expected. For example, testing codepaths for invalid/malformed auth. However, I agree that it may be too conservative behavior that aims to avoid false positives.\n\n> boolean configurable value of \"mark as passed when warnings reported\"? Allows a user to determine if the warnings should be treated as critical, or as warnings.\n\nSounds good to me! Right now, I'd keep the old behavior as default, and I'd be keen to gather more feedback on this and change it if such an expectation appears in the majority of the cases.\n\nI am thinking about extending this [config option](https://schemathesis.readthedocs.io/en/stable/reference/configuration/#warnings), so it could also provide control over individual warnings + a single option to treat all warnings as errors.\nThat makes the most amount of sense to me. It's easily extendible and doesn't break backward compatibility.\nWe were running schemathesis using an old token and it ran successfully. However, when the token expired, it showed no error and started producing a bunch of warnings without failing. It's important to note we didn't have 'ignored_auth' check enabled before.\n\nSo, while it makes sense to add that check. I also believe that warnings should be considered as soft failures with an option of marking them as hard failures.\nAgree! I am on vacation till next Friday, so I'll work on it at the end of next week. Meanwhile, I could review PRs if anybody is willing to contribute\nIn any event, I'll try to think a bit more about it and maybe also add some documentation notes to make this behavior more visible to the users.\n\n", "commit_urls": ["https://github.com/schemathesis/schemathesis/commit/358dff4948289a9422b8e2d55512c6360f914c43"], "created_at": "2025-11-03T08:08:34Z"}
{"repo": "schemathesis/schemathesis", "pull_number": 2970, "instance_id": "schemathesis__schemathesis-2970", "issue_numbers": [2966], "base_commit": "a204360b430f8af4dfa9287256450a309487cf20", "patch": "diff --git a/CHANGELOG.md b/CHANGELOG.md\nindex 2e0569ce7d..cbc9ac95b8 100644\n--- a/CHANGELOG.md\n+++ b/CHANGELOG.md\n@@ -2,6 +2,10 @@\n \n ## [Unreleased](https://github.com/schemathesis/schemathesis/compare/v4.0.14...HEAD) - TBD\n \n+### :bug: Fixed\n+\n+- Incorrect serialization of parameters with nested structures during the coverage phase. [#2966](https://github.com/schemathesis/schemathesis/issues/2966)\n+\n ## [4.0.14](https://github.com/schemathesis/schemathesis/compare/v4.0.13...v4.0.14) - 2025-07-25\n \n ### :bug: Fixed\ndiff --git a/src/schemathesis/generation/hypothesis/builder.py b/src/schemathesis/generation/hypothesis/builder.py\nindex 8cb5f13655..a0f073c53a 100644\n--- a/src/schemathesis/generation/hypothesis/builder.py\n+++ b/src/schemathesis/generation/hypothesis/builder.py\n@@ -22,6 +22,7 @@\n from schemathesis.core import NOT_SET, NotSet, SpecificationFeature, media_types\n from schemathesis.core.errors import InvalidSchema, SerializationNotPossible\n from schemathesis.core.marks import Mark\n+from schemathesis.core.transforms import deepclone\n from schemathesis.core.transport import prepare_urlencoded\n from schemathesis.core.validation import has_invalid_characters, is_latin_1_encodable\n from schemathesis.generation import GenerationMode, coverage\n@@ -397,7 +398,7 @@ def _serialize(self, kwargs: dict[str, Any]) -> dict[str, Any]:\n         return output\n \n     def unmodified(self) -> TemplateValue:\n-        kwargs = self._template.copy()\n+        kwargs = deepclone(self._template)\n         kwargs = self._serialize(kwargs)\n         return TemplateValue(kwargs=kwargs, components=self._components.copy())\n \ndiff --git a/src/schemathesis/specs/openapi/schemas.py b/src/schemathesis/specs/openapi/schemas.py\nindex d573525d30..7365eb9ad4 100644\n--- a/src/schemathesis/specs/openapi/schemas.py\n+++ b/src/schemathesis/specs/openapi/schemas.py\n@@ -195,7 +195,7 @@ def _measure_statistic(self) -> ApiStatistic:\n                 self.resolver.push_scope(scope)\n                 try:\n                     for method, definition in path_item.items():\n-                        if method not in HTTP_METHODS:\n+                        if method not in HTTP_METHODS or not definition:\n                             continue\n                         statistic.operations.total += 1\n                         is_selected = not should_skip(path, method, definition)\n", "test_patch": "diff --git a/test/coverage/test_phase.py b/test/coverage/test_phase.py\nindex c83a9d85ae..6bc6d28c30 100644\n--- a/test/coverage/test_phase.py\n+++ b/test/coverage/test_phase.py\n@@ -183,6 +183,37 @@ def assert_negative_coverage(schema, expected, path=None):\n     return assert_coverage(schema, [GenerationMode.NEGATIVE], expected, path)\n \n \n+ALL_MODES = list(GenerationMode)\n+\n+\n+def run_test(operation, test, modes=ALL_MODES, generate_duplicate_query_parameters=None, unexpected_methods=None):\n+    config = ProjectConfig()\n+    config.generation.update(modes=modes)\n+    if generate_duplicate_query_parameters is not None:\n+        config.phases.coverage.generate_duplicate_query_parameters = generate_duplicate_query_parameters\n+    if unexpected_methods is not None:\n+        config.phases.coverage.unexpected_methods = unexpected_methods\n+    test_func = create_test(\n+        operation=operation,\n+        test_func=test,\n+        config=HypothesisTestConfig(\n+            modes=[HypothesisTestMode.COVERAGE],\n+            project=config,\n+            settings=settings(phases=[Phase.explicit]),\n+        ),\n+    )\n+\n+    test_func()\n+\n+\n+def run_positive_test(operation, test, **kwargs):\n+    return run_test(operation, test, [GenerationMode.POSITIVE], **kwargs)\n+\n+\n+def run_negative_test(operation, test, **kwargs):\n+    return run_test(operation, test, [GenerationMode.NEGATIVE], **kwargs)\n+\n+\n @pytest.mark.parametrize(\n     (\"methods\", \"expected\"),\n     [\n@@ -963,6 +994,12 @@ def test_path_parameter_dots(ctx):\n                 {\"path_parameters\": {\"name\": ANY}},\n                 {\"path_parameters\": {\"name\": \"null\"}},\n             ],\n+            [\n+                {\"path_parameters\": {\"name\": \"%2E%2E\"}},\n+                {\"path_parameters\": {\"name\": \"null%2Cnull\"}},\n+                {\"path_parameters\": {\"name\": ANY}},\n+                {\"path_parameters\": {\"name\": \"null\"}},\n+            ],\n             [\n                 {\"path_parameters\": {\"name\": \"%2E\"}},\n                 {\"path_parameters\": {\"name\": \"null%2Cnull\"}},\n@@ -1425,18 +1462,7 @@ def test_string_with_format(ctx):\n     def test(case):\n         uuid.UUID(case.path_parameters[\"foo_id\"], version=4)\n \n-    config = ProjectConfig()\n-    config.generation.update(modes=[GenerationMode.POSITIVE])\n-    test_func = create_test(\n-        operation=schema[\"/foo/{foo_id}\"][\"post\"],\n-        test_func=test,\n-        config=HypothesisTestConfig(\n-            modes=[HypothesisTestMode.COVERAGE],\n-            project=config,\n-        ),\n-    )\n-\n-    test_func()\n+    run_positive_test(schema[\"/foo/{foo_id}\"][\"post\"], test)\n \n \n def test_query_parameters_with_nested_enum(ctx):\n@@ -1572,12 +1598,19 @@ def foo_id(value):\n             {\n                 \"type\": \"integer\",\n             },\n-            [\n-                foo_id(\"null%2Cnull\"),\n-                foo_id(Pattern(\".\")),\n-                foo_id(\"null\"),\n-                foo_id(\"false\"),\n-            ],\n+            (\n+                [\n+                    foo_id(\"null%2Cnull\"),\n+                    foo_id(Pattern(\".\")),\n+                    foo_id(\"null\"),\n+                    foo_id(\"false\"),\n+                ],\n+                [\n+                    foo_id(\"null%2Cnull\"),\n+                    foo_id(Pattern(\".\")),\n+                    foo_id(\"false\"),\n+                ],\n+            ),\n         ),\n         (\n             {\"type\": \"string\", \"format\": \"date-time\"},\n@@ -1739,20 +1772,7 @@ def test(case):\n             assert \"?q=\" in request.url\n         urls.append(request.url)\n \n-    config = ProjectConfig()\n-    config.generation.update(modes=[GenerationMode.NEGATIVE])\n-    config.phases.coverage.generate_duplicate_query_parameters = True\n-    test_func = create_test(\n-        operation=operation,\n-        test_func=test,\n-        config=HypothesisTestConfig(\n-            modes=[HypothesisTestMode.COVERAGE],\n-            project=config,\n-            settings=settings(phases=[Phase.explicit]),\n-        ),\n-    )\n-\n-    test_func()\n+    run_negative_test(operation, test, generate_duplicate_query_parameters=True)\n \n     assert urls == expected\n \n@@ -1815,38 +1835,13 @@ def test(case):\n         methods.add(case.method)\n         assert f\"-X {case.method}\" in case.as_curl_command()\n \n-    config = ProjectConfig()\n-    config.generation.update(modes=[GenerationMode.NEGATIVE])\n-    test_func = create_test(\n-        operation=operation,\n-        test_func=test,\n-        config=HypothesisTestConfig(\n-            modes=[HypothesisTestMode.COVERAGE],\n-            project=config,\n-            settings=settings(phases=[Phase.explicit]),\n-        ),\n-    )\n-\n-    test_func()\n+    run_negative_test(operation, test)\n \n     assert methods == {\"PATCH\", \"TRACE\", \"DELETE\", \"OPTIONS\", \"PUT\"}\n \n     methods = set()\n \n-    config = ProjectConfig()\n-    config.generation.update(modes=[GenerationMode.NEGATIVE])\n-    config.phases.coverage.unexpected_methods = {\"DELETE\", \"PUT\"}\n-    test_func = create_test(\n-        operation=operation,\n-        test_func=test,\n-        config=HypothesisTestConfig(\n-            modes=[HypothesisTestMode.COVERAGE],\n-            project=config,\n-            settings=settings(phases=[Phase.explicit]),\n-        ),\n-    )\n-\n-    test_func()\n+    run_negative_test(operation, test, unexpected_methods={\"DELETE\", \"PUT\"})\n \n     assert methods == {\"DELETE\", \"PUT\"}\n \n@@ -1878,6 +1873,45 @@ def failed(ctx, response, case):\n         )\n \n \n+@pytest.mark.openapi_version(\"3.0\")\n+def test_nested_parameters(ctx):\n+    schema = ctx.openapi.build_schema(\n+        {\n+            \"/test\": {\n+                \"get\": {\n+                    \"parameters\": [\n+                        {\n+                            \"name\": \"range\",\n+                            \"in\": \"query\",\n+                            \"content\": {\n+                                \"application/json\": {\n+                                    \"schema\": {\"type\": \"null\"},\n+                                },\n+                            },\n+                        }\n+                    ]\n+                }\n+            }\n+        }\n+    )\n+\n+    schema = schemathesis.openapi.from_dict(schema)\n+\n+    ranges = set()\n+    operation = schema[\"/test\"][\"get\"]\n+\n+    def test(case):\n+        if case.meta.phase.name != TestPhase.COVERAGE:\n+            return\n+        if not case.meta.phase.data.description.startswith(\"Unspecified\"):\n+            return\n+        ranges.add(case.query[\"range\"])\n+\n+    run_negative_test(operation, test)\n+\n+    assert ranges == {\"0\"}\n+\n+\n def test_urlencoded_payloads_are_valid(ctx):\n     schema = build_schema(\n         ctx,\n@@ -1906,19 +1940,7 @@ def test(case):\n             return\n         assert_requests_call(case)\n \n-    config = ProjectConfig()\n-    config.generation.update(modes=list(GenerationMode))\n-    test_func = create_test(\n-        operation=operation,\n-        test_func=test,\n-        config=HypothesisTestConfig(\n-            modes=[HypothesisTestMode.COVERAGE],\n-            project=config,\n-            settings=settings(phases=[Phase.explicit]),\n-        ),\n-    )\n-\n-    test_func()\n+    run_test(operation, test)\n \n \n def test_no_missing_header_duplication(ctx):\n@@ -1940,19 +1962,7 @@ def test(case):\n             return\n         descriptions.append(case.meta.phase.data.description)\n \n-    config = ProjectConfig()\n-    config.generation.update(modes=list(GenerationMode))\n-    test_func = create_test(\n-        operation=operation,\n-        test_func=test,\n-        config=HypothesisTestConfig(\n-            modes=[HypothesisTestMode.COVERAGE],\n-            project=config,\n-            settings=settings(phases=[Phase.explicit]),\n-        ),\n-    )\n-\n-    test_func()\n+    run_test(operation, test)\n \n     assert \"Missing required property: X-Key-3\" not in descriptions\n     assert \"Missing `X-Key-3` at header\" in descriptions\n@@ -2011,20 +2021,7 @@ def test(case):\n                 output[container] = value\n         cases.append(output)\n \n-    config = ProjectConfig()\n-    config.generation.update(modes=modes)\n-    config.phases.coverage.generate_duplicate_query_parameters = True\n-    test_func = create_test(\n-        operation=operation,\n-        test_func=test,\n-        config=HypothesisTestConfig(\n-            modes=[HypothesisTestMode.COVERAGE],\n-            project=config,\n-            settings=settings(phases=[Phase.explicit]),\n-        ),\n-    )\n-\n-    test_func()\n+    run_test(operation, test, modes=modes, generate_duplicate_query_parameters=True)\n \n     if isinstance(expected, tuple):\n         assert cases in expected\n", "problem_statement": "[BUG] Reproduction curls cannot properly escape JSON encoded query parameters\n### Checklist\n\n- [x] I checked the [FAQ section](https://schemathesis.readthedocs.io/en/stable/faq/) of the documentation\n- [x] I looked for similar issues in the [issue tracker](https://github.com/schemathesis/schemathesis/issues)\n- [x] I am using the latest version of Schemathesis\n\n### Describe the bug\n\nThe `Reproduce with:` curls generated during failure minimization are facing issues for JSON encoded query parameters, resulting in long and indecipherable reproduction commands.\n\n### To Reproduce\n\n\ud83d\udea8 **Mandatory** \ud83d\udea8: Steps to reproduce the behavior:\n\n1. Use the API schema provided\n2. Run the command `schemathesis run {schema_path} --url={url} --checks all --continue-on-failure`\n3. See error below\n\nPlease include a minimal API schema causing this issue:\n\n```yaml\nopenapi: 3.1.0\ninfo:\n  title: Replace Me API\n  description: >\n    A starter specification for your API.\n  version: 0.1.0\nservers:\n- url: \"{scheme}://{host}:{port}\"\n  description: Development URL\n  variables:\n    scheme:\n      default: http\n    port:\n      default: '8888'\n    host:\n      default: 'localhost'\n  # noinspection YAMLSchemaValidation\n  x-environments:\n  - development\n  - testing\n\npaths:\n  /v1/botw/demos:\n    get:\n      operationId: DemosRootView.get\n      description: >\n        Fetch a paginated list of Demos.\n      parameters:\n      - $ref: '#/components/parameters/QueryPagination'\n      - $ref: '#/components/parameters/QueryOrder'\n      - $ref: '#/components/parameters/QueryDemos'\n      responses:\n        '200':\n          $ref: '#/components/responses/ListDemosResponse'\n        default:\n          $ref: '#/components/responses/HTTPErrorResponse'\n    post:\n      operationId: DemosRootView.post\n      description: >\n        Create a single Demo entity.\n      requestBody:\n        $ref: '#/components/requestBodies/DemoBody'\n      responses:\n        '200':\n          $ref: '#/components/responses/DemoResponse'\n        default:\n          $ref: '#/components/responses/HTTPErrorResponse'\ncomponents:\n  parameters:\n    PathID:\n      name: id\n      in: path\n      required: true\n      description: >\n        The Unique Identifier (UUID) of the associated resource.\n      schema:\n        $ref: '#/components/schemas/UniqueIdentifier'\n    QueryPagination:\n      name: range\n      in: query\n      required: false\n      description: The [startIndex, endIndex] for pagination.\n      content:\n        application/json:\n          schema:\n            $ref: '#/components/schemas/Range'\n    QueryOrder:\n      name: sort\n      in: query\n      description: >\n        How to sort the results, represented as [orderBy, orderDirection].\n        `orderBy` is the field to sort by, and `orderDirection` is either \"ASC\" or \"DESC\".\n      content:\n        application/json:\n          schema:\n            $ref: '#/components/schemas/Order'\n    QueryDemos:\n      name: filter\n      in: query\n      description: >\n        The supported filters for querying Demos.\n      content:\n        application/json:\n          schema:\n            $ref: '#/components/schemas/DemoFilter'\n  requestBodies:\n    DemoBody:\n      description: Request payload for managing a Demo entity.\n      required: true\n      content:\n        application/json:\n          schema:\n            $ref: '#/components/schemas/Demo'\n  responses:\n    HTTPErrorResponse:\n      description: An RFC-7807 compliant error response.\n      content:\n        application/problem+json:\n          schema:\n            $ref: '#/components/schemas/HTTPProblem'\n        text/plain:\n          schema:\n            type: string\n            description: >\n              In certain extreme circumstances, the server may respond with a plaintext\n              error.\n\n              This usually means the server refused to process the incoming request,\n              likely because the payload was too large, improperly encoded, or violated\n              a WAF rule.\n    ListDemosResponse:\n      description: Response body for a successful list operation.\n      headers:\n        Content-Range:\n          schema:\n            $ref: '#/components/schemas/ContentRange'\n      content:\n        application/json:\n          schema:\n            type: array\n            items:\n              $ref: '#/components/schemas/Demo'\n    DemoResponse:\n      description: Response body for a successful entity lookup.\n      content:\n        application/json:\n          schema:\n            $ref: '#/components/schemas/Demo'\n      links:\n        getDemo:\n          operationId: DemosEntityView.get\n          parameters:\n            id: '$response.body#/id'\n        deleteDemo:\n          operationId: DemosEntityView.delete\n          parameters:\n            id: '$response.body#/id'\n        putDemo:\n          operationId: DemosEntityView.put\n          parameters:\n            id: '$response.body#/id'\n          requestBody:\n            id: '$response.body#/id'\n      links:\n        getNextDemoPage:\n          operationId: DemosSearchView.post\n          requestBody:\n            cursor: '$response.body#/next'\n  schemas:\n    Range:\n      description: >\n        A tuple of integers representing an inclusive range.\n\n        Note:\n          - The expectation is `Range.left < Range.right`.\n          - `Range.left == Range.right` will result in zero items.\n          - The behavior for `Range.left > Range.right` is undefined.\n      type: array\n      prefixItems:\n      - $ref: '#/components/schemas/PositiveInteger'\n      - $ref: '#/components/schemas/PositiveInteger'\n      minItems: 2\n      maxItems: 2\n      additionalItems: false\n      default:\n      - 0\n      - 49\n      items:\n        $ref: '#/components/schemas/PositiveInteger'\n    Order:\n      type: array\n      prefixItems:\n      - $ref: '#/components/schemas/OrderField'\n      - $ref: '#/components/schemas/OrderDirection'\n      minItems: 2\n      maxItems: 2\n      additionalItems: false\n      default:\n      - created_at\n      - ASC\n    OrderField:\n      description: >\n        The field on the target resource by which to sort results.\n      allOf:\n      - $ref: '#/components/schemas/NonEmptyString'\n      default: created_at\n    OrderDirection:\n      description: >\n        The direction to sort the results of the query.\n      type: string\n      enum:\n      - ASC\n      - DESC\n      default: ASC\n    ContentRange:\n      description: >\n        The formatted content-range header for list operations.\n      type: string\n      pattern: '^\\d+-\\d+\\/\\d+$'\n    HTTPProblem:\n      type: object\n      description: An RFC-7807 compliant error.\n      example:\n        detail: The indicated resource could not be found.\n        title: Not Found\n        status: 404\n      properties:\n        detail:\n          type: string\n        title:\n          type: string\n        status:\n          type: integer\n        type:\n          type: string\n          format: uri-reference\n        instance:\n          type: string\n          format: uri-reference\n      required:\n      - detail\n      - title\n      - status\n    NonEmptyString:\n      description: >-\n        A string value which *must* have at least one character.\n      type: string\n      minLength: 1\n    OptionalString:\n      description: >-\n        An \"optional\" (e.g., _nullable_) NonEmptyString\n      oneOf:\n      - type: 'null'\n      - $ref: '#/components/schemas/NonEmptyString'\n    IntegerID:\n      type: integer\n      format: int64\n      minimum: 1\n      description: >-\n        A machined-generated, resource-unique identifier for the indicated resource.\n    PositiveInteger:\n      description: >-\n        An integer with a minimum value of `0`.\n      type: integer\n      format: int64\n      minimum: 0\n    OptionalIntegerID:\n      description: >-\n        An \"optional\" (e.g., _nullable_) IntegerID\n      oneOf:\n      - $ref: '#/components/schemas/IntegerID'\n      - type: 'null'\n    EntityID:\n      description: Read-only unique identifier.\n      readOnly: true\n      allOf:\n      - $ref: '#/components/schemas/UniqueIdentifier'\n    UniqueIdentifier:\n      type: string\n      format: uuid\n      description: >-\n        A machine-generated, globally-unique identifier for the indicated resource.\n    OptionalUniqueIdentifier:\n      oneOf:\n      - $ref: '#/components/schemas/UniqueIdentifier'\n      - type: 'null'\n    UniqueIdentifierList:\n      description: >\n        An array of unique identifiers, used for 1:Many references and list operations.\n      type: array\n      minItems: 1\n      uniqueItems: true\n      items:\n        $ref: '#/components/schemas/UniqueIdentifier'\n    IntegerString:\n      type: string\n      format: integer\n      description: >-\n        A machined-generated, resource-unique identifier for the indicated resource.\n        Used to work around client-side precision limits when values may be greater\n        than 64-bits.\n    OptionalIntegerString:\n      description: >-\n        An \"optional\" (e.g., _nullable_) IntegerString\n      oneOf:\n      - $ref: '#/components/schemas/IntegerString'\n      - type: 'null'\n    Date:\n      type: string\n      format: date\n      description: >\n        An [RFC-3329](https://datatracker.ietf.org/doc/html/rfc3339)-compliant date\n        string.\n    DateTime:\n      type: string\n      format: date-time\n      description: >\n        An [RFC-3329](https://datatracker.ietf.org/doc/html/rfc3339)-compliant date-time\n        string.\n    Timestamp:\n      type: string\n      format: date-time\n      readOnly: true\n      description: >-\n        A read-only, machine-generated,\n        [RFC-3329](https://datatracker.ietf.org/doc/html/rfc3339)-compliant date string.\n    FileName:\n      type: string\n      format: file-name\n      pattern: '(?P<stem>(?:\\w|\\d)+(?:\\w|\\d|[.-])*)(?P<suffix>\\.[a-zA-Z]{1,10})'\n      description: >\n        A uri-compatible file name, with no spaces or special characters.\n      example: demo-callout-v1.txt\n    Tag:\n      type: string\n      description: >\n        A short, non-empty string used for categorization.\n      minLength: 1\n      maxLength: 40\n      examples:\n      - \"super interesting\"\n      - \"super boring\"\n    Tags:\n      type: array\n      uniqueItems: true\n      descriptions: >-\n        A list of short, non-empty strings used to categorize an entity.\n      items:\n        $ref: '#/components/schemas/Tag'\n    QueryLimit:\n      type: integer\n      description: >-\n        The maximum number of results to return from a list or search operation.\n      minimum: 0\n      default: 50\n    DemoFilter:\n      description: >\n        The supported filters for any query operations on the Demos resource.\n      properties:\n        ids:\n          type: array\n          items:\n            $ref: '#/components/schemas/UniqueIdentifier'\n        start_date:\n          $ref: '#/components/schemas/Date'\n        end_date:\n          $ref: '#/components/schemas/Date'\n        file_name:\n          $ref: '#/components/schemas/FileName'\n        is_ready:\n          type: boolean\n        version:\n          $ref: '#/components/schemas/PositiveInteger'\n        tags:\n          $ref: '#/components/schemas/Tags'\n    Demo:\n      description: >\n        A data-model definition for a Demonstration.\n      type: object\n      unevaluatedProperties: false\n      properties:\n        id:\n          $ref: '#/components/schemas/EntityID'\n        created_at:\n          $ref: '#/components/schemas/Timestamp'\n        updated_at:\n          $ref: '#/components/schemas/Timestamp'\n        start_date:\n          $ref: '#/components/schemas/Date'\n        end_date:\n          $ref: '#/components/schemas/Date'\n        file_name:\n          $ref: '#/components/schemas/FileName'\n        is_ready:\n          type: boolean\n          default: false\n        version:\n          default: 0\n          allOf:\n          - $ref: '#/components/schemas/PositiveInteger'\n        tags:\n          $ref: '#/components/schemas/Tags'\n      required:\n      - start_date\n      - end_date\n      - file_name\n```\n\nWhen tested, these paths produce the following output for reproduction:\n\n```\n______________________________ GET /v1/botw/demos ______________________________\n1. Test Case ID: jEuKvi\n\n- Unsupported method incorrect response\n\n    Missing Allow header for unsupported method TRACE\n\n[405] Method Not Allowed:\n\n    <EMPTY>\n\nReproduce with: \n\n    curl -X TRACE 'http://localhost:4443/v1/botw/demos?range=%22%5C%22%5C%5C%5C%22%5C%5C%5C%5C%5C%5C%5C%22%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%5B0%2C+49%5D%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%5C%5C%5C%5C%5C%5C%5C%22%5C%5C%5C%22%5C%22%22&sort=%22%5C%22%5C%5C%5C%22%5C%5C%5C%5C%5C%5C%5C%22%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%5B%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22created_at%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22ASC%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%5D%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%5C%5C%5C%5C%5C%5C%5C%22%5C%5C%5C%22%5C%22%22&filter=%22%5C%22%5C%5C%5C%22%5C%5C%5C%5C%5C%5C%5C%22%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%7B%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22ids%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+%5B%5D%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22start_date%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%222000-01-01%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22end_date%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%222000-01-01%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22file_name%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22demo-callout-v1.txt%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22is_ready%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+false%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22version%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+0%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22tags%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+%5B%5D%7D%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%5C%5C%5C%5C%5C%5C%5C%22%5C%5C%5C%22%5C%22%22'\n\n2. Test Case ID: feGJFW\n\n- Unsupported method incorrect response\n\n    Wrong status for unsupported method PUT (got 404, expected 405)\n\n[404] Not Found:\n\n    `{\"error\":{\"code\":404,\"message\":\"Not Found\",\"errors\":[{\"domain\":\"global\",\"reason\":\"Not Found\",\"message\":\"Not Found\"}]}}`\n\nReproduce with: \n\n    curl -X PUT 'http://localhost:4443/v1/botw/demos?range=%22%5C%22%5C%5C%5C%22%5C%5C%5C%5C%5C%5C%5C%22%5B0%2C+49%5D%5C%5C%5C%5C%5C%5C%5C%22%5C%5C%5C%22%5C%22%22&sort=%22%5C%22%5C%5C%5C%22%5C%5C%5C%5C%5C%5C%5C%22%5B%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22created_at%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22ASC%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%5D%5C%5C%5C%5C%5C%5C%5C%22%5C%5C%5C%22%5C%22%22&filter=%22%5C%22%5C%5C%5C%22%5C%5C%5C%5C%5C%5C%5C%22%7B%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22ids%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+%5B%5D%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22start_date%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%222000-01-01%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22end_date%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%222000-01-01%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22file_name%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22demo-callout-v1.txt%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22is_ready%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+false%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22version%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+0%2C+%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22tags%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%5C%22%3A+%5B%5D%7D%5C%5C%5C%5C%5C%5C%5C%22%5C%5C%5C%22%5C%22%22'\n```\n\n### Expected behavior\n\nSchemathesis is able to correctly escape the JSON query parameters when converting to URL query parameters\n\n### Environment\n\n```\n- OS: MacOS Sequioa 15.5\n- Python version: 3.12.10\n- Schemathesis version: 4.0.12\n- Spec version: Open API 3.1.0\n```\n\n", "hints_text": "Hi @benjmountain\n\nThank you for opening this issue! What would be the expected output for those generated parameters? It looks like Schemathesis ignores the \u201ccontent\u201d field for query parameters, hence serialization is broken\n\n", "all_hints_text": "Hi @benjmountain\n\nThank you for opening this issue! What would be the expected output for those generated parameters? It looks like Schemathesis ignores the \u201ccontent\u201d field for query parameters, hence serialization is broken\nI found the root cause - will be fixed in 4.0.15.\n\nNow, the curl sample looks like this:\n\n```\ncurl -X TRACE 'http://127.0.0.1:8080/v1/botw/demos?range=0&sort=0&filter=%7B%22ids%22%3A+0%2C+%22start_date%22%3A+%222000-01-01%22%2C+%22end_date%22%3A+%222000-01-01%22%2C+%22file_name%22%3A+%22demo-callout-v1.txt%22%2C+%22is_ready%22%3A+false%2C+%22version%22%3A+0%2C+%22tags%22%3A+%5B%5D%7D'\n```\n\nSo, the `filter` value is correct JSON:\n\n```json\n{\"ids\": 0, \"start_date\": \"2000-01-01\", \"end_date\": \"2000-01-01\", \"file_name\": \"demo-callout-v1.txt\", \"is_ready\": false, \"version\": 0, \"tags\": []}\n```\n@Stranger6667 Sorry, I've been offline for the past few days so I wasn't able to provide more detail - thank you so much for including this fix in the 4.0.15!\n@benjmountain \n\nNo worries! Happy to help :)\n\n", "commit_urls": ["https://github.com/schemathesis/schemathesis/commit/1a96203dfc18eb4a48c6dd4bdaa897af45da5687"], "created_at": "2025-07-25T21:17:09Z"}
{"repo": "schemathesis/schemathesis", "pull_number": 2984, "instance_id": "schemathesis__schemathesis-2984", "issue_numbers": [2975], "base_commit": "c795b90bae9e54d526feb89c9c2c592cf4c11ef6", "patch": "diff --git a/CHANGELOG.md b/CHANGELOG.md\nindex 5b78b3436c..d514725811 100644\n--- a/CHANGELOG.md\n+++ b/CHANGELOG.md\n@@ -2,11 +2,15 @@\n \n ## [Unreleased](https://github.com/schemathesis/schemathesis/compare/v4.0.16...HEAD) - TBD\n \n+### :bug: Fixed\n+\n+- Generating negative test cases incorrectly marked as invalid if `anyOf` is present. [#2975](https://github.com/schemathesis/schemathesis/issues/2975)\n+\n ## [4.0.16](https://github.com/schemathesis/schemathesis/compare/v4.0.15...v4.0.16) - 2025-07-31\n \n ### :bug: Fixed\n \n-- Internal error if the stateful phase is used with `--generation-unique-inputs`. [#2977](https://github.com/schemathesis/schemathesis/issues/2977) \n+- Internal error if the stateful phase is used with `--generation-unique-inputs`. [#2977](https://github.com/schemathesis/schemathesis/issues/2977)\n - Do not show auth headers for cases when the test case was sent specifically without auth.\n - Do not show unnecessary auth warning if the only test that happened was for missing auth.\n \ndiff --git a/src/schemathesis/generation/coverage.py b/src/schemathesis/generation/coverage.py\nindex e07a35f6fb..cd94ce4471 100644\n--- a/src/schemathesis/generation/coverage.py\n+++ b/src/schemathesis/generation/coverage.py\n@@ -597,12 +597,49 @@ def cover_schema_iter(\n                         with _ignore_unfixable():\n                             canonical = canonicalish(schema)\n                             yield from cover_schema_iter(nctx, canonical, seen)\n-                elif key == \"anyOf\" or key == \"oneOf\":\n+                elif key == \"anyOf\":\n                     nctx = ctx.with_negative()\n-                    # NOTE: Other sub-schemas are not filtered out\n+                    validators = [jsonschema.validators.validator_for(sub_schema)(sub_schema) for sub_schema in value]\n                     for idx, sub_schema in enumerate(value):\n                         with nctx.at(idx):\n-                            yield from cover_schema_iter(nctx, sub_schema, seen)\n+                            for value in cover_schema_iter(nctx, sub_schema, seen):\n+                                # Negative value for this schema could be a positive value for another one\n+                                if is_valid_for_others(value.value, idx, validators):\n+                                    continue\n+                                yield value\n+                elif key == \"oneOf\":\n+                    nctx = ctx.with_negative()\n+                    validators = [jsonschema.validators.validator_for(sub_schema)(sub_schema) for sub_schema in value]\n+                    for idx, sub_schema in enumerate(value):\n+                        with nctx.at(idx):\n+                            for value in cover_schema_iter(nctx, sub_schema, seen):\n+                                if is_invalid_for_oneOf(value.value, idx, validators):\n+                                    yield value\n+\n+\n+def is_valid_for_others(value: Any, idx: int, validators: list[jsonschema.Validator]) -> bool:\n+    for vidx, validator in enumerate(validators):\n+        if idx == vidx:\n+            # This one is being negated\n+            continue\n+        if validator.is_valid(value):\n+            return True\n+    return False\n+\n+\n+def is_invalid_for_oneOf(value: Any, idx: int, validators: list[jsonschema.Validator]) -> bool:\n+    valid_count = 0\n+    for vidx, validator in enumerate(validators):\n+        if idx == vidx:\n+            # This one is being negated\n+            continue\n+        if validator.is_valid(value):\n+            valid_count += 1\n+            # Should circuit - no need to validate more, it is already invalid\n+            if valid_count > 1:\n+                return True\n+    # No matching at all - we successfully generated invalid value\n+    return valid_count == 0\n \n \n def _get_properties(schema: dict | bool) -> dict | bool:\n", "test_patch": "diff --git a/test/coverage/test_combinations.py b/test/coverage/test_combinations.py\nindex ecb83e5ac4..986444ebcc 100644\n--- a/test/coverage/test_combinations.py\n+++ b/test/coverage/test_combinations.py\n@@ -48,10 +48,10 @@ def assert_conform(values: list, schema: dict):\n \n \n def assert_not_conform(values: list, schema: dict):\n+    if schema.get(\"format\") == \"unknown\":\n+        # Can't validate the format\n+        return\n     for entry in values:\n-        if schema.get(\"format\") == \"unknown\":\n-            # Can't validate the format\n-            continue\n         try:\n             jsonschema.validate(\n                 entry,\n@@ -59,7 +59,7 @@ def assert_not_conform(values: list, schema: dict):\n                 cls=jsonschema.Draft7Validator,\n                 format_checker=jsonschema.Draft202012Validator.FORMAT_CHECKER,\n             )\n-            raise ValueError(f\"Value {entry} conforms to {schema}\")\n+            raise AssertionError(f\"Value {entry} conforms to {schema}\")\n         except (jsonschema.ValidationError, ValueError):\n             pass\n \n@@ -1048,7 +1048,7 @@ def test_positive_pattern(pctx):\n     covered = cover_schema(pctx, schema)\n     assert covered == [\"0000-0000\", \"00-0000\", \"00-00000\", \"0000-000000000000000\", \"000-000000000000000\"]\n     assert_unique(covered)\n-    assert_not_conform(covered, schema)\n+    assert_conform(covered, schema)\n \n \n def test_negative_pattern_with_incompatible_length(nctx):\n@@ -1099,7 +1099,11 @@ def test_negative_pattern_with_incompatible_length(nctx):\n                     {\"type\": \"string\", \"maxLength\": 5},\n                 ],\n             },\n-            [4, AnyNumber(), AnyNumber(), \"000000\"],\n+            (\n+                [4, AnyNumber(), AnyNumber()],\n+                [4, AnyNumber()],\n+                [4],\n+            ),\n         ),\n         (\n             {\n@@ -1116,7 +1120,7 @@ def test_negative_pattern_with_incompatible_length(nctx):\n                     },\n                 ]\n             },\n-            [ANY, \"00000000000\", AnyNumber(), AnyNumber()],\n+            [\"00000000000\", AnyNumber(), AnyNumber()],\n         ),\n         (\n             {\n@@ -1137,7 +1141,63 @@ def test_negative_combinators(nctx, schema, expected):\n             assert_not_conform(covered, schema)\n             break\n     else:\n-        pytest.fail(\"Expected value didn't match\")\n+        pytest.fail(f\"Expected value didn't match\\nGot: {covered!r}\\nExpected: {expected!r}\")\n+\n+\n+@pytest.mark.parametrize(\n+    [\"schema\", \"expected\"],\n+    [\n+        (\n+            {\n+                \"anyOf\": [\n+                    {\"type\": \"number\"},\n+                    {\"type\": \"null\"},\n+                ]\n+            },\n+            [\n+                False,\n+                \"\",\n+                [\n+                    None,\n+                    None,\n+                ],\n+                {},\n+            ],\n+        ),\n+        (\n+            {\n+                \"oneOf\": [\n+                    {\"type\": \"number\"},\n+                    {\"type\": \"integer\"},\n+                    {\"type\": \"null\"},\n+                ]\n+            },\n+            [\n+                False,\n+                \"\",\n+                [\n+                    None,\n+                    None,\n+                ],\n+                {},\n+                # Matching both, \"number\" and \"integer\", hence invalid\n+                0,\n+            ],\n+        ),\n+    ],\n+)\n+def test_negative_one_of(schema, expected):\n+    # See GH-2975\n+    nctx = CoverageContext(\n+        location=\"body\",\n+        generation_modes=[GenerationMode.NEGATIVE],\n+        is_required=True,\n+        custom_formats=get_default_format_strategies(),\n+        validator_cls=jsonschema.validators.Draft202012Validator,\n+    )\n+    covered = cover_schema(nctx, schema)\n+    assert_not_conform(covered, schema)\n+    assert covered == expected\n \n \n @pytest.mark.parametrize(\n", "problem_statement": "[BUG] JSON Schema validation issue for number property with a subschema that allows null value\n### Checklist\n\n- [ x] I checked the [FAQ section](https://schemathesis.readthedocs.io/en/stable/faq/) of the documentation\n- [ x] I looked for similar issues in the [issue tracker](https://github.com/schemathesis/schemathesis/issues)\n- [ x] I am using the latest version of Schemathesis\n\n### Describe the bug\n\nI think I've found an inconsistency between the latest version of Schemathesis (4.0.15) and the previous version I was using, 3.39.16. A valid positive test is now being flagged as a failed negative test.\n\nI have a simple Titanic test endpoint with a JSON Schema (using 2020-12 draft) and OAS 3.0.4 for the endpoint. The field `Cabin` is optional (i.e., not `required`) and can have `minLength` 0 and `maxLength` 15.  When passing an empty string in the JSON payload, Schemathesis considers the positive scoring response from the server a failed negative test (i.e., it was expecting a `4XX` response).\n\n### To Reproduce\n\n\ud83d\udea8 **Mandatory** \ud83d\udea8: Steps to reproduce the behavior:\n\n1. Run this command '...'  \n```{bash}\ncurl -X POST -H 'Content-Type: application/json' -d '{\"Age\": null, \"Cabin\": \"\", \"Embarked\": null, \"Fare\": 0, \"Name\": \"0\", \"Parch\": 0, \"PassengerId\": 1, \"Pclass\": 1, \"Sex\": \"male\", \"SibSp\": 0, \"Survived\": 0, \"Ticket\": \"000\"}' http://localhost:8080/invocations\n```\n2. See error\n```\n- API accepted schema-violating request\n\n    Invalid data should have been rejected\n    Expected: 400, 401, 403, 404, 406, 422, 428, 5xx\n```\nIn Schemathesis 3.39.16, this same `curl` command on the same test endpoint was not producing an error.\n\n\nPlease include a minimal API schema causing this issue:\n\n```json\n    \"Cabin\": {\n      \"description\": \"String cabin number (may be an empty string; however, not JSON null)\",\n      \"type\": \"string\",\n      \"minLength\": 0,\n      \"maxLength\": 15\n    },\n```\n\n### Expected behavior\n\nI believe this should be a positive test case and pass as an acceptable `curl` call. This would match results in Schemathesis 3.39.16.\n\n### Environment\n\n```\n- OS: Windows 11 / AlmaLinux 9.2\n- Python version: 3.11.8\n- Schemathesis version: 4.0.15\n- Spec version: 3.0.4\n```\n\n### Additional context\n\nDue to some environment issues, I'm not able to share screenshots or files at this time. But I would happily provide more information if needed to reproduce the issue. I really appreciate this tool and all of the hard work that goes into maintaining it. Thank you.\n", "hints_text": "Thank you for opening this @gangstR !\n\nThere were some issues for the \"coverage\" test phase, specifically. Could you, please, share your schema and CLI command you used to run Schemathesis? If it is not public, then would you consider sharing it with me privately?\nYes. Thank you, @Stranger6667 \n\nFirst, the CLI (for testing the endpoint running locally):\n\n```{bash}\nschemathesis run api.yaml --url http://localhost:8080 --checks all --mode=all --max-examples=500\n```\n\nI had to edit this a tiny bit to remove some proprietary stuff, but here are the contents of the OAS schema file followed by the contents of two referenced external files that contain the JSON schema for payload validation and the response standards/components.\n\n### OAS 3.0.4 `api.yaml` file contents\n\n```yaml\nopenapi: '3.0.4'\ninfo:\n  title: Titanic Survival - An API example\n  description: |\n    This is a simple scoring test endpoint that scores Titanic passengers and\n    returns the probability associated with class = 0 (perish) and class = 1\n    (survive).\n  version: 1.0.0\nservers:\n  - url: http://0.0.0.0:8080\npaths:\n  /ping:\n    $ref: './response_standards.yaml#/paths/~1ping'\n\n  /invocations:\n    post:\n      requestBody:\n        required: true\n        content:\n          application/json:\n            schema:\n              $ref: '../../json_schemata/titanic/titanic3_schema.json'\n      responses:\n        200:\n          $ref: './response_standards.yaml#/components/responses/serverResponseScore'\n        4XX:\n          $ref: './response_standards.yaml#/components/responses/clientRequestError'\n        5XX:\n          $ref: './response_standards.yaml#/components/responses/serverResponseError'\n```\n\n### Referenced JSON schema file, `titanic3_schema.json`\n\n```{js}\n{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"title\": \"Titanic Maiden Voyage\",\n  \"description\": \"Passenger records from the RMS Titanic (April 10-15, 1912)\",\n  \"type\": \"object\",\n\n  \"properties\": {\n\n    \"PassengerId\": {\n      \"description\": \"Integer unique identifier for a passenger (surrogate key)\",\n      \"type\": \"integer\",\n      \"minimum\": 1\n    },\n\n    \"Survived\": {\n      \"description\": \"Binary survival indicator (0 = perished; 1 = survived)\",\n      \"type\": \"integer\",\n      \"minimum\": 0,\n      \"maximum\": 1\n    },\n\n    \"Pclass\": {\n      \"description\": \"Integer passenger ticket class (1 = 1st; 2 = 2nd; 3 = 3rd)\",\n      \"type\": \"integer\",\n      \"minimum\": 1,\n      \"maximum\": 3\n    },\n\n    \"Name\": {\n      \"description\": \"String with title and family name of passenger\",\n      \"type\": \"string\",\n      \"minLength\": 1,\n      \"maxLength\": 150\n    },\n\n    \"Sex\": {\n      \"description\": \"String with dated gender enumeration (male / female)\",\n      \"enum\": [\n        \"male\",\n        \"female\"\n      ]\n    },\n\n    \"Age\": {\n      \"description\": \"Numeric age in years (0.00 - 80.00 when known, but may also be JSON null)\",\n      \"anyOf\": [\n        {\n          \"type\": \"number\",\n          \"minimum\": 0.00,\n          \"maximum\": 80.00\n        },\n        {\n          \"type\": \"null\"\n        }\n      ]\n    },\n\n    \"SibSp\": {\n      \"description\": \"Integer number of siblings / spouses aboard\",\n      \"type\": \"integer\",\n      \"minimum\": 0,\n      \"maximum\": 8\n    },\n\n    \"Parch\": {\n      \"description\": \"Integer number of parents / children aboard\",\n      \"type\": \"integer\",\n      \"minimum\": 0,\n      \"maximum\": 9\n    },\n\n    \"Ticket\": {\n      \"description\": \"String ticket number\",\n      \"type\": \"string\",\n      \"minLength\": 3,\n      \"maxLength\": 18\n    },\n\n    \"Fare\": {\n      \"description\": \"Numeric passenger fare (0.0 - 550.0 in British Pounds)\",\n      \"anyOf\": [\n        {\n          \"type\": \"number\",\n          \"minimum\": 0.0,\n          \"maximum\": 550.0\n        },\n        {\n          \"type\": \"null\"\n        }\n      ]\n    },\n\n    \"Cabin\": {\n      \"description\": \"String cabin number (may be an empty string; however, not JSON null)\",\n      \"type\": \"string\",\n      \"minLength\": 0,\n      \"maxLength\": 15\n    },\n\n    \"Embarked\": {\n      \"description\": \"String with port of embarkation enumeration (C = Cherbourg; Q = Queenstown; S = Southampton, null = Missing / R NA value)\",\n      \"enum\": [\n        \"C\",\n        \"Q\",\n        \"S\",\n        null\n      ]\n    }\n  },\n\n  \"additionalProperties\": false,\n\n  \"required\": [\n    \"PassengerId\",\n    \"Name\",\n    \"Pclass\",\n    \"Sex\",\n    \"Age\",\n    \"SibSp\",\n    \"Parch\",\n    \"Fare\",\n    \"Embarked\"\n    ]\n}\n```\n\n### Referenced `response_standards.yaml` OAS supplemental file\n```yaml\npaths:\n  /ping:\n    get:\n      description: Healthcheck endpoint\n      responses:\n        200:\n          description: Service is OKAY\n          content:\n            application/json:\n              schema:\n                type: object\n                required:\n                  - health\n                  - version_info\n                additionalProperties: false\n                properties:\n                  health:\n                    $ref: '#/components/schemas/healthCheck'\n                  version_info:\n                    $ref: '#/components/schemas/versionInfo'\n\ncomponents:\n  responses:\n\n    serverResponseScore:\n      description: Valid scoring result\n      content:\n        application/json:\n          schema:\n            type: object\n            required:\n              - score\n              - version_info\n            additionalProperties: false\n            properties:\n              score:\n                $ref: '#/components/schemas/anyValue'\n              version_info:\n                $ref: '#/components/schemas/versionInfo'\n\n    clientRequestError:\n      description: Invalid client request\n      content:\n        application/json:\n          schema:\n            $ref: '#/components/schemas/errorResponse'\n\n    serverResponseError:\n      description: Unexpected server error\n      content:\n        application/json:\n          schema:\n            $ref: '#/components/schemas/errorResponse'\n\n  schemas:\n\n    # anyValue -----------------------------------------------------------------\n    anyValue:\n      description: 'Can be anything: string, number, array, object, etc., including JSON `null`'\n\n    # healthCheck --------------------------------------------------------------\n    healthCheck:\n      description: A fixed good-health response string OKAY\n      type: string\n      example: OKAY\n\n    # versionInfo --------------------------------------------------------------\n    versionInfo:\n      description: Metadata describing the service\n      type: object\n      properties:\n        api_version:\n          description: Semantic Versioning (https://semver.org) compliant version number corresponding to the version of the service\n          type: string\n          example: 1.0.0\n        api_version_desc:\n          description: A description of the service\n          type: string\n          example: Titanic Survival - An API example\n        endpoint_timestamp:\n          description: ISO 8601 compliant datetime string per RFC 3339, section 5.6 (https://datatracker.ietf.org/doc/html/rfc3339#section-5.6)\n          type: string\n          format: date-time\n          example: 2025-06-01T18:22:17.239Z\n\n    # errorResponse ------------------------------------------------------------\n    errorResponse:\n      type: object\n      required:\n        - request_id\n        - server_response\n        - additional_details\n        - version_info\n      additionalProperties: false\n      properties:\n        request_id:\n          description: Universally unique identifier (UUID4) for the request\n          type: string\n          format: uuid\n        server_response:\n          description: Server condition message for the condition encountered\n          type: string\n        additional_details:\n          $ref: '#/components/schemas/anyValue'\n        version_info:\n          $ref: '#/components/schemas/versionInfo'\n```\n\nPlease let me know if you need more information. Thank you\nThanks! Was there any indication that the negative part is in the `Cabin` field? right now I can't reproduce it, but if you could share a VCR cassette (via `--report-vcr-path=vcr.yaml` CLI option) file, it would help a lot!\nI think the problem is with `Fare` - during the coverage phase, the mutation for incorrect type generates an integer for the following schema:\n\n```json\n{\n    \"description\": \"Numeric passenger fare (0.0 - 550.0 in British Pounds)\",\n    \"anyOf\": [\n        {\n          \"type\": \"number\",\n          \"minimum\": 0.0,\n          \"maximum\": 550.0\n        },\n        {\n          \"type\": \"null\"\n        }\n      ]\n}\n```\n\nbut it is valid as \"number\" includes \"integer\" as well. I'll re-check it in more details and will keep you updated regarding the fix\nSo, the mutation is for the second subschema - `{\"type\": \"null\"}`, so it changes its type to integer and generates `0` but does not account for the fact that this value is valid for another subschema\nYes, you're correct. My sincere apologies. Perhaps too many spinning plates yielded a false memory of the issue. So sorry. It is indeed the `Fare`. I can see that in the cassette file you requested (I had to figure out the CLI syntax changes, but that was pretty easy). Here are the full details (tiny manual edits to remove some stuff again). This same test worked under Schemathesis 3.39.15.\n\n```\n- id: '4RzaJZ'\n  status: 'FAILURE'\n  generation:\n    time: 0.00010629999451339245\n    mode: negative\n  components:\n    body:\n      mode: 'negative'\n  phase:\n    name: 'coverage'\n    data: \n      description: \"Object with invalid 'Fare' value: Incorrect type\"\n      location: \"/properties/Fare/anyOf/1/type\"\n      parameter: \"application/json\"\n      parameter_location: \"body\"\n  recorded_at: '2025-08-01T20:28:21.096896+00:00'\n  checks:\n    - name: 'not_a_server_error'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'status_code_conformance'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'content_type_conformance'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'response_headers_conformance'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'response_schema_conformance'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'negative_data_rejection'\n      status: 'FAILURE'\n      message: 'API accepted schema-violating request'\n    - name: 'positive_data_acceptance'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'missing_required_header'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'unsupported_method'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'use_after_free'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'ensure_resource_availability'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'ignored_auth'\n      status: 'SUCCESS'\n      message: ~\n  request:\n    uri: 'http://localhost:8080/invocations'\n    method: 'POST'\n    headers:\n      \"User-Agent\":\n      - \"schemathesis/4.0.15\"\n      \"Accept-Encoding\":\n      - \"gzip, deflate\"\n      \"Accept\":\n      - \"*/*\"\n      \"Connection\":\n      - \"keep-alive\"\n      \"X-Schemathesis-TestCaseId\":\n      - \"4RzaJZ\"\n      \"Content-Type\":\n      - \"application/json\"\n      \"Content-Length\":\n      - \"170\"\n    body:\n      encoding: 'utf-8'\n      string: \"{\\\"Age\\\": null, \\\"Cabin\\\": \\\"\\\", \\\"Embarked\\\": null, \\\"Fare\\\": 0, \\\"Name\\\": \\\"0\\\", \\\"Parch\\\": 0, \\\"PassengerId\\\": 1, \\\"Pclass\\\": 1, \\\"Sex\\\": \\\"male\\\", \\\"SibSp\\\": 0, \\\"Survived\\\": 0, \\\"Ticket\\\": \\\"000\\\"}\"\n  response:\n    status:\n      code: '200'\n      message: \"OK\"\n    elapsed: '0.064212'\n    headers:\n      \"date\":\n      - \"Fri, 01 Aug 2025 20:28:21 GMT\"\n      \"x_pid\":\n      - \"2964\"\n      \"x_pid_name\":\n      - \"Rgui.exe\"\n      \"x_proc_time\":\n      - \"0.019697300042\"\n      \"content-type\":\n      - \"application/json\"\n      \"content-encoding\":\n      - \"gzip\"\n      \"transfer-encoding\":\n      - \"chunked\"\n    body:\n      encoding: 'utf-8'\n      string: \"{\\\"score\\\":[{\\\"0\\\":0.864211100179457,\\\"1\\\":0.135788899820543}],\\\"version_info\\\":{\\\"api_version\\\":\\\"1.0.0\\\",\\\"endpoint_timestamp\\\":\\\"2025-08-01T20:28:21.055Z\\\"}}\"\n    http_version: '1.1'\n```\n\n", "all_hints_text": "Thank you for opening this @gangstR !\n\nThere were some issues for the \"coverage\" test phase, specifically. Could you, please, share your schema and CLI command you used to run Schemathesis? If it is not public, then would you consider sharing it with me privately?\nYes. Thank you, @Stranger6667 \n\nFirst, the CLI (for testing the endpoint running locally):\n\n```{bash}\nschemathesis run api.yaml --url http://localhost:8080 --checks all --mode=all --max-examples=500\n```\n\nI had to edit this a tiny bit to remove some proprietary stuff, but here are the contents of the OAS schema file followed by the contents of two referenced external files that contain the JSON schema for payload validation and the response standards/components.\n\n### OAS 3.0.4 `api.yaml` file contents\n\n```yaml\nopenapi: '3.0.4'\ninfo:\n  title: Titanic Survival - An API example\n  description: |\n    This is a simple scoring test endpoint that scores Titanic passengers and\n    returns the probability associated with class = 0 (perish) and class = 1\n    (survive).\n  version: 1.0.0\nservers:\n  - url: http://0.0.0.0:8080\npaths:\n  /ping:\n    $ref: './response_standards.yaml#/paths/~1ping'\n\n  /invocations:\n    post:\n      requestBody:\n        required: true\n        content:\n          application/json:\n            schema:\n              $ref: '../../json_schemata/titanic/titanic3_schema.json'\n      responses:\n        200:\n          $ref: './response_standards.yaml#/components/responses/serverResponseScore'\n        4XX:\n          $ref: './response_standards.yaml#/components/responses/clientRequestError'\n        5XX:\n          $ref: './response_standards.yaml#/components/responses/serverResponseError'\n```\n\n### Referenced JSON schema file, `titanic3_schema.json`\n\n```{js}\n{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"title\": \"Titanic Maiden Voyage\",\n  \"description\": \"Passenger records from the RMS Titanic (April 10-15, 1912)\",\n  \"type\": \"object\",\n\n  \"properties\": {\n\n    \"PassengerId\": {\n      \"description\": \"Integer unique identifier for a passenger (surrogate key)\",\n      \"type\": \"integer\",\n      \"minimum\": 1\n    },\n\n    \"Survived\": {\n      \"description\": \"Binary survival indicator (0 = perished; 1 = survived)\",\n      \"type\": \"integer\",\n      \"minimum\": 0,\n      \"maximum\": 1\n    },\n\n    \"Pclass\": {\n      \"description\": \"Integer passenger ticket class (1 = 1st; 2 = 2nd; 3 = 3rd)\",\n      \"type\": \"integer\",\n      \"minimum\": 1,\n      \"maximum\": 3\n    },\n\n    \"Name\": {\n      \"description\": \"String with title and family name of passenger\",\n      \"type\": \"string\",\n      \"minLength\": 1,\n      \"maxLength\": 150\n    },\n\n    \"Sex\": {\n      \"description\": \"String with dated gender enumeration (male / female)\",\n      \"enum\": [\n        \"male\",\n        \"female\"\n      ]\n    },\n\n    \"Age\": {\n      \"description\": \"Numeric age in years (0.00 - 80.00 when known, but may also be JSON null)\",\n      \"anyOf\": [\n        {\n          \"type\": \"number\",\n          \"minimum\": 0.00,\n          \"maximum\": 80.00\n        },\n        {\n          \"type\": \"null\"\n        }\n      ]\n    },\n\n    \"SibSp\": {\n      \"description\": \"Integer number of siblings / spouses aboard\",\n      \"type\": \"integer\",\n      \"minimum\": 0,\n      \"maximum\": 8\n    },\n\n    \"Parch\": {\n      \"description\": \"Integer number of parents / children aboard\",\n      \"type\": \"integer\",\n      \"minimum\": 0,\n      \"maximum\": 9\n    },\n\n    \"Ticket\": {\n      \"description\": \"String ticket number\",\n      \"type\": \"string\",\n      \"minLength\": 3,\n      \"maxLength\": 18\n    },\n\n    \"Fare\": {\n      \"description\": \"Numeric passenger fare (0.0 - 550.0 in British Pounds)\",\n      \"anyOf\": [\n        {\n          \"type\": \"number\",\n          \"minimum\": 0.0,\n          \"maximum\": 550.0\n        },\n        {\n          \"type\": \"null\"\n        }\n      ]\n    },\n\n    \"Cabin\": {\n      \"description\": \"String cabin number (may be an empty string; however, not JSON null)\",\n      \"type\": \"string\",\n      \"minLength\": 0,\n      \"maxLength\": 15\n    },\n\n    \"Embarked\": {\n      \"description\": \"String with port of embarkation enumeration (C = Cherbourg; Q = Queenstown; S = Southampton, null = Missing / R NA value)\",\n      \"enum\": [\n        \"C\",\n        \"Q\",\n        \"S\",\n        null\n      ]\n    }\n  },\n\n  \"additionalProperties\": false,\n\n  \"required\": [\n    \"PassengerId\",\n    \"Name\",\n    \"Pclass\",\n    \"Sex\",\n    \"Age\",\n    \"SibSp\",\n    \"Parch\",\n    \"Fare\",\n    \"Embarked\"\n    ]\n}\n```\n\n### Referenced `response_standards.yaml` OAS supplemental file\n```yaml\npaths:\n  /ping:\n    get:\n      description: Healthcheck endpoint\n      responses:\n        200:\n          description: Service is OKAY\n          content:\n            application/json:\n              schema:\n                type: object\n                required:\n                  - health\n                  - version_info\n                additionalProperties: false\n                properties:\n                  health:\n                    $ref: '#/components/schemas/healthCheck'\n                  version_info:\n                    $ref: '#/components/schemas/versionInfo'\n\ncomponents:\n  responses:\n\n    serverResponseScore:\n      description: Valid scoring result\n      content:\n        application/json:\n          schema:\n            type: object\n            required:\n              - score\n              - version_info\n            additionalProperties: false\n            properties:\n              score:\n                $ref: '#/components/schemas/anyValue'\n              version_info:\n                $ref: '#/components/schemas/versionInfo'\n\n    clientRequestError:\n      description: Invalid client request\n      content:\n        application/json:\n          schema:\n            $ref: '#/components/schemas/errorResponse'\n\n    serverResponseError:\n      description: Unexpected server error\n      content:\n        application/json:\n          schema:\n            $ref: '#/components/schemas/errorResponse'\n\n  schemas:\n\n    # anyValue -----------------------------------------------------------------\n    anyValue:\n      description: 'Can be anything: string, number, array, object, etc., including JSON `null`'\n\n    # healthCheck --------------------------------------------------------------\n    healthCheck:\n      description: A fixed good-health response string OKAY\n      type: string\n      example: OKAY\n\n    # versionInfo --------------------------------------------------------------\n    versionInfo:\n      description: Metadata describing the service\n      type: object\n      properties:\n        api_version:\n          description: Semantic Versioning (https://semver.org) compliant version number corresponding to the version of the service\n          type: string\n          example: 1.0.0\n        api_version_desc:\n          description: A description of the service\n          type: string\n          example: Titanic Survival - An API example\n        endpoint_timestamp:\n          description: ISO 8601 compliant datetime string per RFC 3339, section 5.6 (https://datatracker.ietf.org/doc/html/rfc3339#section-5.6)\n          type: string\n          format: date-time\n          example: 2025-06-01T18:22:17.239Z\n\n    # errorResponse ------------------------------------------------------------\n    errorResponse:\n      type: object\n      required:\n        - request_id\n        - server_response\n        - additional_details\n        - version_info\n      additionalProperties: false\n      properties:\n        request_id:\n          description: Universally unique identifier (UUID4) for the request\n          type: string\n          format: uuid\n        server_response:\n          description: Server condition message for the condition encountered\n          type: string\n        additional_details:\n          $ref: '#/components/schemas/anyValue'\n        version_info:\n          $ref: '#/components/schemas/versionInfo'\n```\n\nPlease let me know if you need more information. Thank you\nThanks! Was there any indication that the negative part is in the `Cabin` field? right now I can't reproduce it, but if you could share a VCR cassette (via `--report-vcr-path=vcr.yaml` CLI option) file, it would help a lot!\nI think the problem is with `Fare` - during the coverage phase, the mutation for incorrect type generates an integer for the following schema:\n\n```json\n{\n    \"description\": \"Numeric passenger fare (0.0 - 550.0 in British Pounds)\",\n    \"anyOf\": [\n        {\n          \"type\": \"number\",\n          \"minimum\": 0.0,\n          \"maximum\": 550.0\n        },\n        {\n          \"type\": \"null\"\n        }\n      ]\n}\n```\n\nbut it is valid as \"number\" includes \"integer\" as well. I'll re-check it in more details and will keep you updated regarding the fix\nSo, the mutation is for the second subschema - `{\"type\": \"null\"}`, so it changes its type to integer and generates `0` but does not account for the fact that this value is valid for another subschema\nYes, you're correct. My sincere apologies. Perhaps too many spinning plates yielded a false memory of the issue. So sorry. It is indeed the `Fare`. I can see that in the cassette file you requested (I had to figure out the CLI syntax changes, but that was pretty easy). Here are the full details (tiny manual edits to remove some stuff again). This same test worked under Schemathesis 3.39.15.\n\n```\n- id: '4RzaJZ'\n  status: 'FAILURE'\n  generation:\n    time: 0.00010629999451339245\n    mode: negative\n  components:\n    body:\n      mode: 'negative'\n  phase:\n    name: 'coverage'\n    data: \n      description: \"Object with invalid 'Fare' value: Incorrect type\"\n      location: \"/properties/Fare/anyOf/1/type\"\n      parameter: \"application/json\"\n      parameter_location: \"body\"\n  recorded_at: '2025-08-01T20:28:21.096896+00:00'\n  checks:\n    - name: 'not_a_server_error'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'status_code_conformance'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'content_type_conformance'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'response_headers_conformance'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'response_schema_conformance'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'negative_data_rejection'\n      status: 'FAILURE'\n      message: 'API accepted schema-violating request'\n    - name: 'positive_data_acceptance'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'missing_required_header'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'unsupported_method'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'use_after_free'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'ensure_resource_availability'\n      status: 'SUCCESS'\n      message: ~\n    - name: 'ignored_auth'\n      status: 'SUCCESS'\n      message: ~\n  request:\n    uri: 'http://localhost:8080/invocations'\n    method: 'POST'\n    headers:\n      \"User-Agent\":\n      - \"schemathesis/4.0.15\"\n      \"Accept-Encoding\":\n      - \"gzip, deflate\"\n      \"Accept\":\n      - \"*/*\"\n      \"Connection\":\n      - \"keep-alive\"\n      \"X-Schemathesis-TestCaseId\":\n      - \"4RzaJZ\"\n      \"Content-Type\":\n      - \"application/json\"\n      \"Content-Length\":\n      - \"170\"\n    body:\n      encoding: 'utf-8'\n      string: \"{\\\"Age\\\": null, \\\"Cabin\\\": \\\"\\\", \\\"Embarked\\\": null, \\\"Fare\\\": 0, \\\"Name\\\": \\\"0\\\", \\\"Parch\\\": 0, \\\"PassengerId\\\": 1, \\\"Pclass\\\": 1, \\\"Sex\\\": \\\"male\\\", \\\"SibSp\\\": 0, \\\"Survived\\\": 0, \\\"Ticket\\\": \\\"000\\\"}\"\n  response:\n    status:\n      code: '200'\n      message: \"OK\"\n    elapsed: '0.064212'\n    headers:\n      \"date\":\n      - \"Fri, 01 Aug 2025 20:28:21 GMT\"\n      \"x_pid\":\n      - \"2964\"\n      \"x_pid_name\":\n      - \"Rgui.exe\"\n      \"x_proc_time\":\n      - \"0.019697300042\"\n      \"content-type\":\n      - \"application/json\"\n      \"content-encoding\":\n      - \"gzip\"\n      \"transfer-encoding\":\n      - \"chunked\"\n    body:\n      encoding: 'utf-8'\n      string: \"{\\\"score\\\":[{\\\"0\\\":0.864211100179457,\\\"1\\\":0.135788899820543}],\\\"version_info\\\":{\\\"api_version\\\":\\\"1.0.0\\\",\\\"endpoint_timestamp\\\":\\\"2025-08-01T20:28:21.055Z\\\"}}\"\n    http_version: '1.1'\n```\nThank you for the confirmation! The issue will be fixed in #2984 and I'll make a bugfix release soon - I found a couple of more places that were not covered by tests and I am going to fix them too.\nFixed in 4.0.17!\n\n", "commit_urls": ["https://github.com/schemathesis/schemathesis/commit/3a37a03bb604c33abb8e1aca4bf4d97d6be057b7"], "created_at": "2025-08-01T21:04:53Z"}
{"repo": "schemathesis/schemathesis", "pull_number": 3472, "instance_id": "schemathesis__schemathesis-3472", "issue_numbers": [3471], "base_commit": "24168c3e184bda41c20fa85386f680320638e59c", "patch": "diff --git a/CHANGELOG.md b/CHANGELOG.md\nindex 948bfb771a..fdefebad2e 100644\n--- a/CHANGELOG.md\n+++ b/CHANGELOG.md\n@@ -2,14 +2,18 @@\n \n ## [Unreleased](https://github.com/schemathesis/schemathesis/compare/v4.9.3...HEAD) - TBD\n \n-## [4.9.3](https://github.com/schemathesis/schemathesis/compare/v4.9.2...v4.9.3) - 2026-01-21\n-\n ### :rocket: Added\n \n - Detect foreign key fields (e.g., `customer_id`, `order_ids`) in responses and request bodies to generate additional stateful links.\n \n ### :bug: Fixed\n \n+- `map_*`, `filter_*`, and `flatmap_*` hooks receiving `GeneratedValue` wrappers instead of raw `dict` values in negative generation mode. [#3471](https://github.com/schemathesis/schemathesis/issues/3471)\n+\n+## [4.9.3](https://github.com/schemathesis/schemathesis/compare/v4.9.2...v4.9.3) - 2026-01-21\n+\n+### :bug: Fixed\n+\n - Coverage phase hanging on endpoints with many optional parameters due to combinatorial explosion. [#3046](https://github.com/schemathesis/schemathesis/issues/3046)\n - Coverage phase crashing with `TypeError` when schema contains non-string `pattern` values (e.g., `\"pattern\": 0.0`).\n \ndiff --git a/src/schemathesis/hooks.py b/src/schemathesis/hooks.py\nindex 9e8ae342c2..0e0e3919dc 100644\n--- a/src/schemathesis/hooks.py\n+++ b/src/schemathesis/hooks.py\n@@ -228,16 +228,19 @@ def apply_to_container(\n             if _should_skip_hook(hook, context):\n                 continue\n             hook = partial(hook, context)\n+            hook = _wrap_hook_for_generated_value(hook)\n             strategy = strategy.filter(hook)\n         for hook in self.get_all_by_name(f\"map_{container}\"):\n             if _should_skip_hook(hook, context):\n                 continue\n             hook = partial(hook, context)\n+            hook = _wrap_hook_for_generated_value(hook)\n             strategy = strategy.map(hook)\n         for hook in self.get_all_by_name(f\"flatmap_{container}\"):\n             if _should_skip_hook(hook, context):\n                 continue\n             hook = partial(hook, context)\n+            hook = _wrap_hook_for_generated_value(hook)\n             strategy = strategy.flatmap(hook)\n         return strategy\n \n@@ -282,6 +285,24 @@ def _should_skip_hook(hook: Callable, ctx: HookContext) -> bool:\n     return filter_set is not None and ctx.operation is not None and not filter_set.match(ctx)\n \n \n+def _wrap_hook_for_generated_value(hook: Callable) -> Callable:\n+    \"\"\"Wrap hook to handle GeneratedValue transparently.\n+\n+    In NEGATIVE mode, strategies yield GeneratedValue wrappers instead of raw dicts.\n+    This wrapper ensures hooks always receive raw dict values and preserves the\n+    GeneratedValue wrapper with its metadata after the hook processes the value.\n+    \"\"\"\n+    from schemathesis.specs.openapi.negative import GeneratedValue\n+\n+    def wrapper(value: Any) -> Any:\n+        if isinstance(value, GeneratedValue):\n+            result = hook(value.value)\n+            return GeneratedValue(value=result, meta=value.meta)\n+        return hook(value)\n+\n+    return wrapper\n+\n+\n def apply_to_all_dispatchers(\n     operation: APIOperation,\n     context: HookContext,\n", "test_patch": "diff --git a/test/hooks/test_hooks.py b/test/hooks/test_hooks.py\nindex 8d989e0a4e..51cdcf3e4e 100644\n--- a/test/hooks/test_hooks.py\n+++ b/test/hooks/test_hooks.py\n@@ -127,6 +127,29 @@ def test(case):\n     test()\n \n \n+def test_map_hooks_receive_dict_in_negative_mode(testdir, simple_openapi):\n+    # Regression test for GH-3471\n+    # map_* hooks should receive raw dict values, not GeneratedValue wrappers\n+    testdir.make_test(\n+        \"\"\"\n+def replacement(context, query):\n+    # Should always receive a dict, never a GeneratedValue\n+    assert isinstance(query, dict), f\"Expected dict, got {type(query).__name__}\"\n+    return {\"id\": \"fixed\"}\n+\n+@schema.hooks.apply(replacement, name=\"map_query\")\n+@schema.parametrize()\n+@settings(max_examples=5)\n+def test_hook_receives_dict(case):\n+    pass\n+\"\"\",\n+        schema=simple_openapi,\n+        generation_modes=[GenerationMode.NEGATIVE],\n+    )\n+    result = testdir.runpytest()\n+    result.assert_outcomes(passed=1)\n+\n+\n def test_per_test_hooks(testdir, simple_openapi):\n     testdir.make_test(\n         \"\"\"\n", "problem_statement": "[BUG] Hooks documentation doesn't match actual behaviour\n### Checklist\n\n- [x] I checked the [FAQ section](https://schemathesis.readthedocs.io/en/stable/faq/) of the documentation\n- [x] I looked for similar issues in the [issue tracker](https://github.com/schemathesis/schemathesis/issues)\n- [x] I am using the latest version of Schemathesis\n\n### Describe the bug\n\nExamples like https://schemathesis.github.io/schemathesis/guides/extending/#using-real-database-values imply that the mapping hooks for query or path_parameters. Using st version 4.9.3, however, hooks are sometimes called with the value being a dictionary and other times an incompatible `GeneratedValue` subclass.\n\nCustomizing the `GeneratedValue` instance's `value` property does not appear to work. The code will show it being modified but the error message will show the unmodified path parameter in e.g. the curl reproduction. Since these appear to be negative cases, I can patch this to skip these cases without losing anything of value other than having to de-noise test failures caused by referencing non-existent record IDs.\n\n### To Reproduce\n\n```python\n@schemathesis.hook\ndef map_path_parameters(context, path_parameters):\n    if path_parameters and \"bard\" in context.operation.base_url:\n        print(f\"Path parameters: {path_parameters!r}\")\n\n        # Gracefully handle the two different ways Schemathesis passes values to\n        # this function (either dict or a dataclass containing a dict value):\n        if hasattr(path_parameters, \"value\"):\n            param_dict = path_parameters.value\n        else:\n            param_dict = path_parameters\n\n        override_dict_keys(param_dict, \"userId\", CUSTOM_USER_ID)\n        pprint(path_parameters)\n    return path_parameters\n```\n\n### Expected behavior\n\nThe documentation should explain why this happens and how to handle it gracefully.\n\n### Environment\n\n```\n- OS: macOS Tahoe\n- Python version: 3.13\n- Schemathesis version: 4.9.3\n- Spec version: Open API 3.0.3\n```\n\n### Additional context\n\n", "hints_text": "\n\n", "all_hints_text": "Thanks for reporting! It is an oversight on my end. Will be fixed soon in 4.9.4\nReleased!\nThanks for the rapid response! I just tested and confirmed that it's working as expected with 4.9.4.\n\n", "commit_urls": ["https://github.com/schemathesis/schemathesis/commit/7c44a70658a0f60790389fb134b9b5bc748464d4"], "created_at": "2026-01-21T23:01:52Z"}
{"repo": "schemathesis/schemathesis", "pull_number": 3483, "instance_id": "schemathesis__schemathesis-3483", "issue_numbers": [3480], "base_commit": "c213574d190637ac996092488a2687f48f6699ad", "patch": "diff --git a/CHANGELOG.md b/CHANGELOG.md\nindex 855331cade..373b0b759a 100644\n--- a/CHANGELOG.md\n+++ b/CHANGELOG.md\n@@ -2,6 +2,10 @@\n \n ## [Unreleased](https://github.com/schemathesis/schemathesis/compare/v4.9.5...HEAD) - TBD\n \n+### :bug: Fixed\n+\n+- False positive `negative_data_rejection` failures for `format: password` and other formats without validation semantics. [#3480](https://github.com/schemathesis/schemathesis/issues/3480)\n+\n ## [4.9.5](https://github.com/schemathesis/schemathesis/compare/v4.9.4...v4.9.5) - 2026-01-29\n \n ### :bug: Fixed\ndiff --git a/src/schemathesis/generation/coverage.py b/src/schemathesis/generation/coverage.py\nindex bef3cb10ac..7f1f8aa42c 100644\n--- a/src/schemathesis/generation/coverage.py\n+++ b/src/schemathesis/generation/coverage.py\n@@ -1501,6 +1501,12 @@ def _is_invalid_format(v: Any, format: str) -> bool:\n def _negative_format(\n     ctx: CoverageContext, schema: JsonSchemaObject, format: str\n ) -> Generator[GeneratedValue, None, None]:\n+    # Only generate negative format cases for formats that have validation semantics.\n+    # In OpenAPI 3.0, `format` is an annotation and does NOT impose validation constraints by itself.\n+    # Formats like \"password\" have no validation - any string is valid.\n+    # We can only generate truly invalid data for formats in FORMAT_CHECKER (e.g., \"email\", \"uri\", \"uuid\").\n+    if format not in jsonschema.Draft202012Validator.FORMAT_CHECKER.checkers:\n+        return\n     # Hypothesis-jsonschema does not canonicalise it properly right now, which leads to unsatisfiable schema\n     without_format = {k: v for k, v in schema.items() if k != \"format\"}\n     without_format.setdefault(\"type\", \"string\")\n@@ -1508,11 +1514,10 @@ def _negative_format(\n         # Empty path parameters are invalid\n         without_format[\"minLength\"] = 1\n     strategy = from_schema(without_format)\n-    if format in jsonschema.Draft202012Validator.FORMAT_CHECKER.checkers:\n-        if format == \"hostname\":\n-            strategy = strategy.filter(_is_invalid_hostname)\n-        else:\n-            strategy = strategy.filter(functools.partial(_is_invalid_format, format=format))\n+    if format == \"hostname\":\n+        strategy = strategy.filter(_is_invalid_hostname)\n+    else:\n+        strategy = strategy.filter(functools.partial(_is_invalid_format, format=format))\n     yield NegativeValue(\n         ctx.generate_from(strategy),\n         scenario=CoverageScenario.INVALID_FORMAT,\n", "test_patch": "diff --git a/test/cli/__snapshots__/test_negative_metadata/test_format_password_false_positive.raw b/test/cli/__snapshots__/test_negative_metadata/test_format_password_false_positive.raw\nnew file mode 100644\nindex 0000000000..5eadd45ead\n--- /dev/null\n+++ b/test/cli/__snapshots__/test_negative_metadata/test_format_password_false_positive.raw\n@@ -0,0 +1,40 @@\n+Exit code: 0\n+---\n+Stdout:\n+Schemathesis dev\n+\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n+\n+\n+ \u2705  Loaded specification from http://127.0.0.1/openapi.json (in 0.00s)\n+\n+     Base URL:         http://127.0.0.1/\n+     Specification:    Open API 3.0.2\n+     Operations:       1 selected / 1 total\n+\n+\n+ \u2705  API capabilities:\n+\n+     Supports NULL byte in headers:    \u2713\n+\n+ \u2705  Coverage (in 0.00s)\n+\n+     \u2705 1 passed\n+\n+=================================== SUMMARY ====================================\n+\n+API Operations:\n+  Selected: 1/1\n+  Tested: 1\n+\n+Test Phases:\n+  \u23ed  Examples (disabled)\n+  \u2705 Coverage\n+  \u23ed  Fuzzing (disabled)\n+  \u23ed  Stateful (disabled)\n+\n+Test cases:\n+  N generated, N passed, N skipped\n+\n+Seed: 42\n+\n+=========================== No issues found in 1.00s ===========================\ndiff --git a/test/cli/test_negative_metadata.py b/test/cli/test_negative_metadata.py\nindex 95332430f6..375e0dc014 100644\n--- a/test/cli/test_negative_metadata.py\n+++ b/test/cli/test_negative_metadata.py\n@@ -1,8 +1,73 @@\n+import json\n+\n import pytest\n from _pytest.main import ExitCode\n from flask import Flask, jsonify, request\n \n \n+@pytest.mark.snapshot(replace_reproduce_with=True)\n+def test_format_password_false_positive(ctx, app_runner, cli, snapshot_cli):\n+    # GH-3480: Schemathesis incorrectly reports data as invalid for format: password\n+    # In OpenAPI 3.0, `format` is an annotation and does NOT impose validation constraints by itself.\n+    # With only `type: string, format: password`, any string is valid.\n+    # Schemathesis incorrectly treats generated data as schema-violating and expects rejection.\n+    #\n+    # The coverage phase generates format-specific negative cases via _negative_format,\n+    # which incorrectly claims values don't match the 'password' format.\n+    raw_schema = ctx.openapi.build_schema(\n+        {\n+            \"/\": {\n+                \"post\": {\n+                    \"requestBody\": {\n+                        \"required\": True,\n+                        \"content\": {\n+                            \"application/json\": {\n+                                \"schema\": {\n+                                    \"type\": \"string\",\n+                                    \"format\": \"password\",\n+                                }\n+                            }\n+                        },\n+                    },\n+                    \"responses\": {\"200\": {\"description\": \"OK\"}},\n+                }\n+            }\n+        }\n+    )\n+\n+    app = Flask(__name__)\n+\n+    @app.route(\"/openapi.json\")\n+    def schema():\n+        return jsonify(raw_schema)\n+\n+    @app.route(\"/\", methods=[\"POST\"])\n+    def root():\n+        # Reject non-strings with 422 (proper validation behavior)\n+        # Accept all strings (including empty) since format:password has no validation semantics\n+        data = request.get_data()\n+        try:\n+            body = json.loads(data)\n+            if not isinstance(body, str):\n+                return jsonify({\"error\": \"expected string\"}), 422\n+        except (json.JSONDecodeError, ValueError):\n+            return jsonify({\"error\": \"invalid json\"}), 422\n+        return jsonify({\"result\": \"ok\"}), 200\n+\n+    port = app_runner.run_flask_app(app)\n+\n+    # No failure should be reported since any string is valid for format: password in OpenAPI 3.0\n+    assert (\n+        cli.run(\n+            f\"http://127.0.0.1:{port}/openapi.json\",\n+            \"--checks=negative_data_rejection\",\n+            \"--phases=coverage\",\n+            \"--continue-on-failure\",\n+        )\n+        == snapshot_cli\n+    )\n+\n+\n def test_negative_metadata_required_property(ctx, app_runner, cli):\n     raw_schema = ctx.openapi.build_schema(\n         {\ndiff --git a/test/coverage/test_combinations.py b/test/coverage/test_combinations.py\nindex bc5f5bcfc1..b8aaedb0c9 100644\n--- a/test/coverage/test_combinations.py\n+++ b/test/coverage/test_combinations.py\n@@ -153,7 +153,8 @@ def __eq__(self, value: object, /) -> bool:\n         ({\"multipleOf\": 2}, lambda x: x % 2 != 0),\n         ({\"format\": \"date-time\"}, [AnyString()]),\n         ({\"format\": \"hostname\"}, [AnyString()]),\n-        ({\"format\": \"unknown\"}, [AnyString()]),\n+        # Unknown formats have no validation semantics, so no negative cases can be generated\n+        ({\"format\": \"unknown\"}, []),\n         ({\"uniqueItems\": True}, [[\"null\", \"null\"]]),\n         ({\"maximum\": 5}, [6]),\n         ({\"minimum\": 5}, [4]),\n", "problem_statement": "[BUG] Schemathesis rejects empty string for format: password\n### Checklist\n\n* [x] I checked the [FAQ section](https://schemathesis.readthedocs.io/en/stable/faq/) of the documentation\n* [x] I looked for similar issues in the [issue tracker](https://github.com/schemathesis/schemathesis/issues)\n* [x] I am using the latest version of Schemathesis\n\n### Describe the bug\n\nSchemathesis reports `AcceptedNegativeData: API accepted schema-violating request`, but the request body is **not schema-violating**.\n\nThe failure claims that an empty string does not match the `password` format:\n\n```\nValue not matching the 'password' format\n```\n\nHowever, in OpenAPI 3.0, `format` is an annotation and does **not** impose validation constraints by itself. With the schema:\n\n```yaml\ntype: string\nformat: password\n```\n\nan empty string (`\"\"`) is valid unless additional constraints such as `minLength`, `pattern`, or `enum` are specified.\n\nSchemathesis appears to be incorrectly treating `format: password` as a validation assertion and rejecting empty strings, which leads to a false-positive `negative_data_rejection` failure.\n\n### To Reproduce\n\n\ud83d\udea8 **Mandatory** \ud83d\udea8: Steps to reproduce the behavior:\n\n1. Create `openapi.yaml` with the following contents:\n\n   ```yaml\n   openapi: 3.0.2\n   info:\n     title: Repro\n     version: \"1\"\n   paths:\n     /:\n       post:\n         requestBody:\n           required: true\n           content:\n             application/json:\n               schema:\n                 type: string\n                 format: password\n         responses:\n           \"200\":\n             description: OK\n   ```\n\n2. Start a minimal HTTP server that accepts any POST body and always returns `200 OK`:\n\n   ```python\n   # server.py\n   from http.server import BaseHTTPRequestHandler, HTTPServer\n\n   class Handler(BaseHTTPRequestHandler):\n       def do_POST(self):\n           self.send_response(200)\n           self.end_headers()\n\n   HTTPServer((\"localhost\", 8000), Handler).serve_forever()\n   ```\n\n   Run it:\n\n   ```bash\n   python server.py\n   ```\n\n3. Run Schemathesis with negative data rejection enabled:\n\n   ```bash\n   schemathesis run openapi.yaml --url http://localhost:8000 --checks negative_data_rejection\n   ```\n\n4. Observe the failure:\n\n   ```text\n    - API accepted schema-violating request\n\n    Invalid data should have been rejected\n    Expected: 400, 401, 403, 404, 406, 422, 428, 5xx\n    Invalid component: in body - value not matching the 'password' format\n   ```\n\n### Expected behavior\n\nSchemathesis should **not** treat an empty string as invalid solely because `format: password` is specified.\n\nThe payload `\"\"` is valid according to the OpenAPI schema and should **not** be classified as schema-violating input.\n\n### Environment\n\n```\n- Schemathesis version: 4.9.5\n- Spec version: OpenAPI 3.1.0\n```\n", "hints_text": "Thank you for opening this!\n\nyes, you're correct - some time ago I've enabled format validation for responses unconditionally (see #2481) but missed this behavior in the context of data generation & this specific check.\n\nEven though `format` is an annotation by default, it is up to implementation to enable that assertion vocabulary (as far as I remember the spec), hence I enabled it for responses (though it will be configurable in the future).\n\nI'll work on a fix in the next few days\n\n\n", "all_hints_text": "Thank you for opening this!\n\nyes, you're correct - some time ago I've enabled format validation for responses unconditionally (see #2481) but missed this behavior in the context of data generation & this specific check.\n\nEven though `format` is an annotation by default, it is up to implementation to enable that assertion vocabulary (as far as I remember the spec), hence I enabled it for responses (though it will be configurable in the future).\n\nI'll work on a fix in the next few days\n\n@Stranger6667 Do you know when you will make the next release?\n@schelv Closer to the end of the week. I've also switched a lot of logic from `jsonschema` to `jsonschema-rs` and want to add some more tests / new schemas to the test corpus\n\n", "commit_urls": ["https://github.com/schemathesis/schemathesis/commit/c6d8872d5145b37a53e88bbccc19b099ab09018c"], "created_at": "2026-01-30T12:00:25Z"}
{"repo": "schemathesis/schemathesis", "pull_number": 3523, "instance_id": "schemathesis__schemathesis-3523", "issue_numbers": [3520], "base_commit": "8fd7017aa45d89cd2d9069d399f6034517cd69d3", "patch": "diff --git a/CHANGELOG.md b/CHANGELOG.md\nindex a079c4a844..625880756f 100644\n--- a/CHANGELOG.md\n+++ b/CHANGELOG.md\n@@ -2,6 +2,10 @@\n \n ## [Unreleased](https://github.com/schemathesis/schemathesis/compare/v4.10.2...HEAD) - TBD\n \n+### :bug: Fixed\n+\n+- Coverage phase generating schema-invalid positive values for schemas with `anyOf`/`oneOf` and `required` constraints. [#3520](https://github.com/schemathesis/schemathesis/issues/3520)\n+\n ### :wrench: Changed\n \n - Avoid extra transitive dependencies from `jsonschema`.\ndiff --git a/src/schemathesis/generation/coverage.py b/src/schemathesis/generation/coverage.py\nindex be780b9700..285c75bd4d 100644\n--- a/src/schemathesis/generation/coverage.py\n+++ b/src/schemathesis/generation/coverage.py\n@@ -509,6 +509,44 @@ def clear(self) -> None:\n         self._data.clear()\n \n \n+_COMBINATOR_KEYS = frozenset({\"anyOf\", \"oneOf\", \"allOf\", \"not\", \"if\", \"then\", \"else\"})\n+\n+\n+def _with_effective_required(schema: JsonSchemaObject) -> JsonSchemaObject:\n+    existing_required: list[str] = schema.get(\"required\", [])\n+    properties = schema.get(\"properties\", {})\n+    if not properties:\n+        return schema\n+    for key in (\"anyOf\", \"oneOf\"):\n+        sub_schemas = schema.get(key)\n+        if sub_schemas:\n+            for sub_schema in sub_schemas:\n+                if isinstance(sub_schema, dict) and \"required\" in sub_schema:\n+                    extra = [f for f in sub_schema[\"required\"] if f not in existing_required and f in properties]\n+                    if extra:\n+                        return {**schema, \"required\": list(existing_required) + extra}\n+                    break\n+    return schema\n+\n+\n+def _merge_with_parent_context(parent: JsonSchemaObject, sub: JsonSchema) -> JsonSchema:\n+    if not isinstance(sub, dict):\n+        return sub\n+    result: dict[str, Any] = {\n+        k: (deepclone(v) if k == \"properties\" else v) for k, v in parent.items() if k not in _COMBINATOR_KEYS\n+    }\n+    for key, value in sub.items():\n+        if key == \"required\" and \"required\" in result:\n+            parent_req: list[str] = result[\"required\"] if isinstance(result[\"required\"], list) else [result[\"required\"]]\n+            sub_req: list[str] = value if isinstance(value, list) else [value]\n+            result[\"required\"] = list(dict.fromkeys(parent_req + sub_req))\n+        elif key == \"properties\" and \"properties\" in result:\n+            result[\"properties\"] = {**result[\"properties\"], **value}\n+        else:\n+            result[key] = value\n+    return result\n+\n+\n def _cover_positive_for_type(\n     ctx: CoverageContext, schema: JsonSchemaObject, ty: str | None, seen: HashSet | None = None\n ) -> Generator[GeneratedValue, None, None]:\n@@ -528,7 +566,7 @@ def _cover_positive_for_type(\n             sub_schemas = schema.get(key)\n             if sub_schemas is not None:\n                 for sub_schema in sub_schemas:\n-                    yield from cover_schema_iter(ctx, sub_schema)\n+                    yield from cover_schema_iter(ctx, _merge_with_parent_context(schema, sub_schema))\n         all_of = schema.get(\"allOf\")\n         if all_of is not None:\n             if len(all_of) == 1:\n@@ -558,9 +596,9 @@ def _cover_positive_for_type(\n             elif ty == \"array\":\n                 yield from _positive_array(ctx, schema, cast(list, template))\n             elif ty == \"object\":\n-                yield from _positive_object(ctx, schema, cast(dict, template))\n+                yield from _positive_object(ctx, _with_effective_required(schema), cast(dict, template))\n         elif \"properties\" in schema or \"required\" in schema:\n-            yield from _positive_object(ctx, schema, cast(dict, template))\n+            yield from _positive_object(ctx, _with_effective_required(schema), cast(dict, template))\n         elif \"not\" in schema and isinstance(schema[\"not\"], dict | bool):\n             # For 'not' schemas: generate negative cases of inner schema (violations)\n             # These violations are positive for the outer schema, so flip the mode\n", "test_patch": "diff --git a/test/coverage/test_combinations.py b/test/coverage/test_combinations.py\nindex 10fe167fb8..eb145dae5b 100644\n--- a/test/coverage/test_combinations.py\n+++ b/test/coverage/test_combinations.py\n@@ -1973,3 +1973,113 @@ def test_negative_binary_string_type_violation(ctx_factory):\n     ]\n     assert len(non_string_values) > 0, \"Should generate non-string type violations for binary format\"\n     assert_not_conform(covered, schema)\n+\n+\n+def test_anyof_with_required_constraints(pctx):\n+    # See GH-3520\n+    schema = {\n+        \"type\": \"object\",\n+        \"anyOf\": [\n+            {\"required\": [\"name\"]},\n+            {\"required\": [\"id\"]},\n+        ],\n+        \"properties\": {\n+            \"type\": {\"type\": \"string\"},\n+            \"id\": {\"type\": \"string\"},\n+            \"name\": {\"type\": \"string\"},\n+        },\n+    }\n+    covered = cover_schema(pctx, schema)\n+    assert covered == [\n+        {\"type\": \"\", \"id\": \"\", \"name\": \"\"},\n+        {\"id\": \"\", \"name\": \"\"},\n+        {\"type\": \"\", \"name\": \"\"},\n+        {\"name\": \"\"},\n+        {\"type\": \"\", \"id\": \"\", \"name\": \"\"},\n+        {\"id\": \"\", \"name\": \"\"},\n+        {\"type\": \"\", \"id\": \"\"},\n+        {\"id\": \"\"},\n+        {\"id\": \"\", \"name\": \"\", \"type\": \"\"},\n+        {\"id\": \"\", \"name\": \"\"},\n+        {\"name\": \"\", \"type\": \"\"},\n+        {\"name\": \"\"},\n+    ]\n+    assert_conform(covered, schema)\n+\n+\n+def test_merge_with_parent_context_bool_subschema(pctx):\n+    schema = {\n+        \"type\": \"object\",\n+        \"anyOf\": [\n+            True,\n+            {\"required\": [\"name\"]},\n+        ],\n+        \"properties\": {\n+            \"name\": {\"type\": \"string\"},\n+        },\n+    }\n+    covered = cover_schema(pctx, schema)\n+    object_values = [v for v in covered if isinstance(v, dict)]\n+    assert len(object_values) > 0\n+    assert_conform(object_values, schema)\n+\n+\n+def test_merge_with_parent_context_merges_required_lists(pctx):\n+    # Parent has `required` AND sub has `required` - the two lists get merged\n+    schema = {\n+        \"type\": \"object\",\n+        \"required\": [\"type\"],\n+        \"anyOf\": [\n+            {\"required\": [\"name\"]},\n+        ],\n+        \"properties\": {\n+            \"type\": {\"type\": \"string\"},\n+            \"name\": {\"type\": \"string\"},\n+        },\n+    }\n+    covered = cover_schema(pctx, schema)\n+    assert_conform(covered, schema)\n+    # The merged sub inherits \"type\" from parent and adds \"name\" from sub\n+    assert all(\"type\" in v and \"name\" in v for v in covered if isinstance(v, dict))\n+\n+\n+def test_merge_with_parent_context_merges_properties_dicts(pctx):\n+    # Parent has `properties` AND sub has `properties` - they get merged.\n+    schema = {\n+        \"type\": \"object\",\n+        \"properties\": {\n+            \"type\": {\"type\": \"string\"},\n+            \"name\": {\"type\": \"string\"},\n+        },\n+        \"anyOf\": [\n+            {\n+                \"properties\": {\"id\": {\"type\": \"integer\"}},\n+                \"required\": [\"name\"],\n+            },\n+        ],\n+    }\n+    covered = cover_schema(pctx, schema)\n+    assert_conform(covered, schema)\n+    # The merged sub has access to parent's properties + sub's \"id\" property\n+    assert any(\"id\" in v for v in covered if isinstance(v, dict))\n+\n+\n+def test_with_effective_required_break_when_no_extra_fields(pctx):\n+    # break fires when the first dict sub-schema with `required` contributes no extra fields\n+    # because all its required fields are already in the parent's required list\n+    schema = {\n+        \"type\": \"object\",\n+        \"required\": [\"name\"],\n+        \"anyOf\": [\n+            {\"required\": [\"name\"]},  # \"name\" already required by parent -> extra=[] -> break\n+            {\"required\": [\"id\"]},  # never reached due to break above\n+        ],\n+        \"properties\": {\n+            \"name\": {\"type\": \"string\"},\n+            \"id\": {\"type\": \"string\"},\n+        },\n+    }\n+    covered = cover_schema(pctx, schema)\n+    assert_conform(covered, schema)\n+    # All positive values must include \"name\" (always required by parent)\n+    assert all(\"name\" in v for v in covered if isinstance(v, dict))\n", "problem_statement": "[BUG] False positive when anyOf and required combined during coverage phase\n### Checklist\n\n- [x] I checked the [FAQ section](https://schemathesis.readthedocs.io/en/stable/faq/) of the documentation\n- [x] I looked for similar issues in the [issue tracker](https://github.com/schemathesis/schemathesis/issues)\n- [x] I am using the latest version of Schemathesis\n\n### Describe the bug\n\nWith the following schema\n\n```yaml\n components:\n   schemas:\n     Auth:\n       type: object\n       properties:\n         host:\n           type: string\n           format: hostname\n         port:\n           type: integer\n           default: 22\n         user:\n           type: string\n         password:\n           type: string\n         private-key:\n           type: string\n           format: byte\n       anyOf:\n         - required: [user, password]\n         - required: [user, private-key]\n```\n\nWhich means either password or private-key must be specified, while coverage reports that\n\n```\n1. Test Case ID: whAwq7\n\n- API rejected schema-compliant request\n\n    Valid data should have been accepted\n    Expected: 2xx, 401, 403, 404, 409, 5xx\n\n[400] Bad Request:\n\n    `{\"error\":\"Insufficient auth data\"}`\n\nReproduce with:\n\n    curl -X POST -H 'Content-Type: application/json' -d '{\"host\": \"A.COM\"}' http://localhost:8011/devices/probe\n```\n\n### To Reproduce\n\n\ud83d\udea8 **Mandatory** \ud83d\udea8: Steps to reproduce the behavior:\n\n1. Use auth schema to generate coverage test\n2. See error\n\nPlease include a minimal API schema causing this issue:\n\n```yaml\n{ \"openapi\": \"3.0.3\", ... }\n```\n\n### Expected behavior\n\nShould not considered schema-compliant\n\n### Environment\n\n```\n- Linux\n- Python version: 3.11.2\n- Schemathesis version: 4.10.2\n- Spec version: OpenAPI 3.0.3\n```\n\n### Additional context\n\nA similar issue #3404 exists, which only fixed example phase\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/schemathesis/schemathesis/commit/fdc46e783f396a9cda5c21f490dc1786388054fc"], "created_at": "2026-02-24T11:56:00Z"}
{"repo": "schemathesis/schemathesis", "pull_number": 3524, "instance_id": "schemathesis__schemathesis-3524", "issue_numbers": [3521], "base_commit": "7168692ec1fadc4029053866f99679df27d8ea63", "patch": "diff --git a/CHANGELOG.md b/CHANGELOG.md\nindex 748f7b3291..785340c619 100644\n--- a/CHANGELOG.md\n+++ b/CHANGELOG.md\n@@ -5,6 +5,7 @@\n ### :bug: Fixed\n \n - Coverage phase generating schema-invalid positive values for schemas with `anyOf`/`oneOf` and `required` constraints. [#3520](https://github.com/schemathesis/schemathesis/issues/3520)\n+- `missing_required_header` now accepts `400`, `401`, `403`, and `422` (in addition to `406`) for missing non-`Authorization` required headers. [#3521](https://github.com/schemathesis/schemathesis/issues/3521)\n \n ### :wrench: Changed\n \ndiff --git a/docs/reference/checks.md b/docs/reference/checks.md\nindex bc5bc3e62f..c1a0ec018b 100644\n--- a/docs/reference/checks.md\n+++ b/docs/reference/checks.md\n@@ -190,12 +190,14 @@ By default, `expected-statuses` includes `401/403/404/409/5xx` to account for au\n \n ### `missing_required_header`\n \n-Verifies the API rejects requests when required headers are missing. The API should respond with `406 Not Acceptable` (or `401 Unauthorized` for `Authorization` headers).\n+Verifies the API rejects requests when required headers are missing.\n+\n+By default, non-`Authorization` headers are considered correctly rejected with `400`, `401`, `403`, `406`, or `422`. `Authorization` is stricter and expects `401 Unauthorized`.\n \n ```text\n - Missing header not rejected\n \n-Got 200 when missing required 'X-API-Key' header, expected 406\n+Got 200 when missing required 'X-API-Key' header, expected 400, 401, 403, 406, 422\n ```\n \n !!! note \"Coverage phase\"\ndiff --git a/docs/reference/configuration.md b/docs/reference/configuration.md\nindex f498e6f2a3..1003264ad3 100644\n--- a/docs/reference/configuration.md\n+++ b/docs/reference/configuration.md\n@@ -733,7 +733,12 @@ These settings can only be applied at the project level.\n !!! note \"\"\n \n     **Type:** `Array[Integer | String]`  \n-    **Default:** `[200]`  \n+    **Default:** Depends on check:\n+\n+      - `not_a_server_error`: `[\"2xx\", \"3xx\", \"4xx\"]`\n+      - `positive_data_acceptance`: `[\"2xx\", \"401\", \"403\", \"404\", \"409\", \"5xx\"]`\n+      - `negative_data_rejection`: `[\"400\", \"401\", \"403\", \"404\", \"406\", \"422\", \"428\", \"5xx\"]`\n+      - `missing_required_header`: `[\"400\", \"401\", \"403\", \"406\", \"422\"]`\n \n     Defines the HTTP status codes expected from the API for specific checks. Different checks may interpret this setting differently:\n \ndiff --git a/src/schemathesis/config/_checks.py b/src/schemathesis/config/_checks.py\nindex b3b431544d..45192e41a6 100644\n--- a/src/schemathesis/config/_checks.py\n+++ b/src/schemathesis/config/_checks.py\n@@ -13,7 +13,7 @@\n NOT_A_SERVER_ERROR_EXPECTED_STATUSES = [\"2xx\", \"3xx\", \"4xx\"]\n NEGATIVE_DATA_REJECTION_EXPECTED_STATUSES = [\"400\", \"401\", \"403\", \"404\", \"406\", \"422\", \"428\", \"5xx\"]\n POSITIVE_DATA_ACCEPTANCE_EXPECTED_STATUSES = [\"2xx\", \"401\", \"403\", \"404\", \"409\", \"5xx\"]\n-MISSING_REQUIRED_HEADER_EXPECTED_STATUSES = [\"406\"]\n+MISSING_REQUIRED_HEADER_EXPECTED_STATUSES = [\"400\", \"401\", \"403\", \"406\", \"422\"]\n \n \n def validate_status_codes(value: Sequence[str] | None) -> Sequence[str] | None:\n", "test_patch": "diff --git a/test/specs/openapi/test_checks.py b/test/specs/openapi/test_checks.py\nindex e2d5940fcc..80fde617a2 100644\n--- a/test/specs/openapi/test_checks.py\n+++ b/test/specs/openapi/test_checks.py\n@@ -11,6 +11,7 @@\n from schemathesis.generation.meta import (\n     CaseMetadata,\n     ComponentInfo,\n+    CoveragePhaseData,\n     CoverageScenario,\n     FuzzingPhaseData,\n     GenerationInfo,\n@@ -22,6 +23,7 @@\n     _body_negation_becomes_valid_after_serialization,\n     _is_prefix_operation,\n     has_only_additional_properties_in_non_body_parameters,\n+    missing_required_header,\n     negative_data_rejection,\n     positive_data_acceptance,\n     response_schema_conformance,\n@@ -467,6 +469,37 @@ def verify_missing_required_header(cassette_path, header, expected_status):\n     assert missing_header_check[\"status\"] == expected_status\n \n \n+@pytest.mark.operations(\"basic\")\n+def test_missing_required_header_default_accepts_401(ctx, cli, openapi3_base_url, tmp_path):\n+    # Non-Authorization required headers may be rejected with 401 by auth-first middleware.\n+    cassette_path = tmp_path / \"missing_token_header.yaml\"\n+\n+    schema_path = ctx.openapi.write_schema(\n+        {\n+            \"/basic\": {\n+                \"get\": {\n+                    \"parameters\": [\n+                        {\"name\": \"X-API-Token\", \"in\": \"header\", \"required\": True, \"schema\": {\"type\": \"string\"}},\n+                    ],\n+                    \"responses\": {\"200\": {\"description\": \"OK\"}},\n+                }\n+            }\n+        }\n+    )\n+\n+    cli.run(\n+        str(schema_path),\n+        f\"--url={openapi3_base_url}\",\n+        f\"--report-vcr-path={cassette_path}\",\n+        \"--phases=coverage\",\n+        \"--mode=negative\",\n+        \"--checks=missing_required_header\",\n+        \"--max-examples=1\",\n+    )\n+\n+    verify_missing_required_header(cassette_path, \"X-API-Token\", \"SUCCESS\")\n+\n+\n @pytest.mark.operations(\"success\")\n def test_missing_required_accept_header(ctx, cli, openapi3_base_url, tmp_path):\n     cassette_path = tmp_path / \"missing_accept_header.yaml\"\n@@ -526,6 +559,64 @@ def test_missing_required_authorization_if_provided_explicitly(cli, openapi3_sch\n     verify_missing_required_header(cassette_path, \"Authorization\", \"SUCCESS\")\n \n \n+@pytest.mark.parametrize(\n+    (\"status_code\", \"should_raise\"),\n+    [\n+        (400, False),\n+        (401, False),\n+        (403, False),\n+        (406, False),\n+        (422, False),\n+        (200, True),\n+        (500, True),\n+    ],\n+)\n+def test_missing_required_header_default_statuses(ctx, response_factory, status_code, should_raise):\n+    raw_schema = ctx.openapi.build_schema(\n+        {\n+            \"/test\": {\n+                \"get\": {\n+                    \"parameters\": [\n+                        {\"name\": \"X-API-Token\", \"in\": \"header\", \"required\": True, \"schema\": {\"type\": \"string\"}},\n+                    ],\n+                    \"responses\": {\"200\": {\"description\": \"OK\"}},\n+                }\n+            }\n+        }\n+    )\n+    schema = schemathesis.openapi.from_dict(raw_schema)\n+    operation = schema[\"/test\"][\"GET\"]\n+    response = response_factory.requests(status_code=status_code)\n+    case = operation.Case(\n+        _meta=CaseMetadata(\n+            generation=GenerationInfo(time=0.1, mode=GenerationMode.NEGATIVE),\n+            components={},\n+            phase=PhaseInfo(\n+                name=TestPhase.COVERAGE,\n+                data=CoveragePhaseData(\n+                    scenario=CoverageScenario.MISSING_PARAMETER,\n+                    description=\"Missing `X-API-Token` at header\",\n+                    location=\"header\",\n+                    parameter=\"X-API-Token\",\n+                    parameter_location=ParameterLocation.HEADER,\n+                ),\n+            ),\n+        ),\n+    )\n+    check_ctx = CheckContext(\n+        override=None,\n+        auth=None,\n+        headers=None,\n+        config=ChecksConfig(),\n+        transport_kwargs=None,\n+    )\n+    if should_raise:\n+        with pytest.raises(Failure):\n+            missing_required_header(check_ctx, response, case)\n+    else:\n+        assert missing_required_header(check_ctx, response, case) is None\n+\n+\n @pytest.mark.parametrize(\"path, method\", [(\"/success\", \"get\"), (\"/basic\", \"post\")])\n @pytest.mark.operations(\"success\")\n def test_method_not_allowed(ctx, cli, openapi3_base_url, snapshot_cli, path, method):\n", "problem_statement": "[BUG] `missing_required_header` does not recognize 401\n### Checklist\n\n- [x] I checked the [FAQ section](https://schemathesis.readthedocs.io/en/stable/faq/) of the documentation\n- [x] I looked for similar issues in the [issue tracker](https://github.com/schemathesis/schemathesis/issues)\n- [x] I am using the latest version of Schemathesis\n\n### Describe the bug\n\nWe are trying to remove the last disabled check in `django-modern-rest` from `schemathesis`: https://github.com/wemake-services/django-modern-rest/blob/265e9158e17f2eed6a02f68e9c0eba6f6c6b68e9/schemathesis.toml#L12\n\nWhich is `missing_required_header.enabled = false` in our case.\nHowever, when I do that, I get a strange error. We have a view with a provided security schema, `missing_required_header` does not pass the required auth parameters and we fail with 401.\n\nBut, we are getting:\n\n```python\n  | schemathesis.core.failures.FailureGroup: Schemathesis found 1 distinct failure\n  | \n  | - Missing header not rejected\n  | \n  |     Got 401 when missing required 'X-API-Token' header, expected 406\n  | \n  | [401] Unauthorized:\n  | \n  |     `{\"detail\":[{\"msg\":\"Not authenticated\",\"type\":\"security\"}]}`\n  | \n  | Reproduce with:\n  | \n  |     curl -X POST -H 'Authorization: [Filtered]' --insecure http://localhost/api/controllers/async_headers\n  | \n  |  (1 sub-exception)\n  +-+---------------- 1 ----------------\n    | schemathesis.openapi.checks.MissingHeaderNotRejected: Missing header not rejected\n    | \n    | Got 401 when missing required 'X-API-Token' header, expected 406\n    +------------------------------------\n```\n\nIt seems strange, because it is quite logical to check auth first and not even parse anything if auth is not provided. Reversing the order might expose different security problems in users code.\n\n### To Reproduce\n\n\ud83d\udea8 **Mandatory** \ud83d\udea8: Steps to reproduce the behavior:\n\n1. Copy `https://github.com/wemake-services/django-modern-rest`\n2. `poetry install --all-groups --all-extras`\n3. Remove the `missing_required_header.enabled = false` line from `schemathesis.toml`\n4. Run `poetry run pytest tests/test_integration/test_openapi/test_schema.py`\n\nPlease include a minimal API schema causing this issue:\n\n```json\n{\n  \"openapi\": \"3.1.0\",\n  \"info\": {\n    \"title\": \"Test API\",\n    \"version\": \"1.0.0\",\n    \"summary\": \"Test Summary\",\n    \"description\": \"Test Description\",\n    \"termsOfService\": \"Test Terms of Service\",\n    \"contact\": {\n      \"name\": \"Test Contact\",\n      \"email\": \"test@test.com\"\n    },\n    \"license\": {\n      \"name\": \"Test License\",\n      \"identifier\": \"license\"\n    }\n  },\n  \"servers\": [\n    {\n      \"url\": \"http://127.0.0.1:8000/api/\"\n    }\n  ],\n  \"securitySchemes\": {\n    \"http_basic\": {\n      \"type\": \"http\",\n      \"description\": \"Http Basic auth\",\n      \"name\": \"Authorization\",\n      \"in\": \"header\",\n      \"scheme\": \"basic\"\n    }\n  },\n  \"components\": {\n    \"schemas\": {\n      \"_CustomHeaders\": {\n        \"properties\": {\n          \"token\": {\n            \"type\": \"string\"\n          }\n        },\n        \"type\": \"object\",\n        \"required\": [\n          \"token\"\n        ]\n      },\n      \"ErrorDetail\": {\n        \"properties\": {\n          \"msg\": {\n            \"type\": \"string\"\n          },\n          \"type\": {\n            \"type\": \"string\"\n          },\n          \"loc\": {\n            \"items\": {\n              \"oneOf\": [\n                {\n                  \"type\": \"integer\"\n                },\n                {\n                  \"type\": \"string\"\n                }\n              ]\n            },\n            \"type\": \"array\"\n          }\n        },\n        \"type\": \"object\",\n        \"required\": [\n          \"msg\"\n        ]\n      },\n      \"ErrorModel\": {\n        \"properties\": {\n          \"detail\": {\n            \"items\": {\n              \"$ref\": \"#/components/schemas/ErrorDetail\"\n            },\n            \"type\": \"array\"\n          }\n        },\n        \"type\": \"object\",\n        \"required\": [\n          \"detail\"\n        ]\n      }\n    }\n  },\n  \"paths\": {\n    \"/controllers/headers\": {\n      \"post\": {\n        \"operationId\": \"postControllersHeaders\",\n        \"parameters\": [\n          {\n            \"name\": \"X-API-Token\",\n            \"in\": \"header\",\n            \"schema\": {\n              \"type\": \"string\"\n            },\n            \"required\": true,\n            \"deprecated\": false\n          }\n        ],\n        \"responses\": {\n          \"201\": {\n            \"description\": \"Created\",\n            \"content\": {\n              \"application/json\": {\n                \"schema\": {\n                  \"$ref\": \"#/components/schemas/_CustomHeaders\"\n                }\n              }\n            }\n          },\n          \"400\": {\n            \"description\": \"Bad Request\",\n            \"content\": {\n              \"application/json\": {\n                \"schema\": {\n                  \"$ref\": \"#/components/schemas/ErrorModel\"\n                }\n              }\n            }\n          },\n          \"401\": {\n            \"description\": \"Unauthorized\",\n            \"content\": {\n              \"application/json\": {\n                \"schema\": {\n                  \"$ref\": \"#/components/schemas/ErrorModel\"\n                }\n              }\n            }\n          },\n          \"406\": {\n            \"description\": \"Not Acceptable\",\n            \"content\": {\n              \"application/json\": {\n                \"schema\": {\n                  \"$ref\": \"#/components/schemas/ErrorModel\"\n                }\n              }\n            }\n          },\n          \"422\": {\n            \"description\": \"Unprocessable Content\",\n            \"content\": {\n              \"application/json\": {\n                \"schema\": {\n                  \"$ref\": \"#/components/schemas/ErrorModel\"\n                }\n              }\n            }\n          }\n        },\n        \"deprecated\": false,\n        \"security\": [\n          {\n            \"http_basic\": []\n          }\n        ]\n      }\n    }\n  }\n}\n```\n\n### Expected behavior\n\nI expect that requests with invalid auth data will fail with 401 and will pass the test.\n\n### Environment\n\n- schemathesis: 4.10.2\n\n", "hints_text": "\n\n", "all_hints_text": "Thanks for opening this! I think 401 / 403 should be exempt from this check indeed similar to how its done in other checks. Will fix it soon\nThank you for the quick fix \u2764\ufe0f \n\n", "commit_urls": ["https://github.com/schemathesis/schemathesis/commit/b583df97386653855b897037bafd3d309d32f34f"], "created_at": "2026-02-24T13:12:24Z"}
{"repo": "schemathesis/schemathesis", "pull_number": 3528, "instance_id": "schemathesis__schemathesis-3528", "issue_numbers": [3522], "base_commit": "3fb0458955cc4e1958d6d5aab44f673506f1e923", "patch": "diff --git a/CHANGELOG.md b/CHANGELOG.md\nindex 785340c619..8d72808b98 100644\n--- a/CHANGELOG.md\n+++ b/CHANGELOG.md\n@@ -12,6 +12,7 @@\n - Avoid extra transitive dependencies from `jsonschema`.\n - Remove `colorama` from dependencies.\n - Support for `pyrate-limiter>=4.0`.\n+- Use pytest 9 native subtests and drop `pytest-subtests` dependency. [#3522](https://github.com/schemathesis/schemathesis/issues/3522)\n \n ## [4.10.2](https://github.com/schemathesis/schemathesis/compare/v4.10.1...v4.10.2) - 2026-02-15\n \ndiff --git a/pyproject.toml b/pyproject.toml\nindex 0f36a53f83..c656153f4d 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -42,8 +42,7 @@ dependencies = [\n   \"jsonschema_rs>=0.41.0\",\n   \"junit-xml>=1.9,<2.0\",\n   \"pyrate-limiter>=4.0,<5.0\",\n-  \"pytest-subtests>=0.11,<0.16.0\",\n-  \"pytest>=8,<10\",\n+  \"pytest>=9,<10\",\n   \"PyYAML>=5.1,<7.0\",\n   \"requests>=2.22,<3\",\n   \"rich>=13.9.4\",\n@@ -173,7 +172,6 @@ known-third-party = [\n   \"packaging\",\n   \"pydantic\",\n   \"pytest\",\n-  \"pytest_subtests\",\n   \"requests\",\n   \"urllib3\",\n   \"werkzeug\",\n", "test_patch": "diff --git a/docs/explanations/pytest.md b/docs/explanations/pytest.md\nindex 0dfd54605e..67234d59c2 100644\n--- a/docs/explanations/pytest.md\n+++ b/docs/explanations/pytest.md\n@@ -75,7 +75,7 @@ def test_api(case):\n **Key differences:**\n \n - **Schema loading:** Happens during test execution (not import time)\n-- **Test output:** Uses pytest-subtests instead of parametrization\n+- **Test output:** Uses pytest subtests instead of parametrization\n - **Fixture support:** Schema can depend on other pytest fixtures\n \n ## Error Handling and Reporting\ndiff --git a/src/schemathesis/pytest/lazy.py b/src/schemathesis/pytest/lazy.py\nindex b864151c9a..88afb55483 100644\n--- a/src/schemathesis/pytest/lazy.py\n+++ b/src/schemathesis/pytest/lazy.py\n@@ -9,7 +9,6 @@\n \n import pytest\n from hypothesis.core import HypothesisHandle\n-from pytest_subtests import SubTests\n \n from schemathesis.core.errors import InvalidSchema\n from schemathesis.core.result import Ok, Result\n@@ -259,15 +258,15 @@ def as_strategy_kwargs(_operation: APIOperation) -> dict[str, Any]:\n                     fail_on_no_matches(node_id)\n                 request.session.testscollected += len(tests)\n                 suspend_capture_ctx = _get_capturemanager(request)\n-                subtests = SubTests(request.node.ihook, suspend_capture_ctx, request)\n+                subtests = pytest.Subtests(request.node.ihook, suspend_capture_ctx, request, _ispytest=True)\n                 for result in tests:\n                     if isinstance(result, Ok):\n                         operation, sub_test = result.ok()\n-                        subtests.item._nodeid = f\"{node_id}[{operation.method.upper()} {operation.path}]\"\n+                        request.node._nodeid = f\"{node_id}[{operation.method.upper()} {operation.path}]\"\n                         run_subtest(operation, fixtures, sub_test, subtests)\n                     else:\n-                        _schema_error(subtests, result.err(), node_id)\n-                subtests.item._nodeid = node_id\n+                        _schema_error(subtests, result.err(), node_id, request.node)\n+                request.node._nodeid = node_id\n \n             sig = signature(test_func)\n             if \"self\" in sig.parameters:\n@@ -310,7 +309,9 @@ def _get_capturemanager(request: FixtureRequest) -> Generator | type[nullcontext\n     return nullcontext\n \n \n-def run_subtest(operation: APIOperation, fixtures: dict[str, Any], sub_test: Callable, subtests: SubTests) -> None:\n+def run_subtest(\n+    operation: APIOperation, fixtures: dict[str, Any], sub_test: Callable, subtests: pytest.Subtests\n+) -> None:\n     \"\"\"Run the given subtest with pytest fixtures.\"\"\"\n     __tracebackhide__ = True\n \n@@ -324,13 +325,14 @@ def run_subtest(operation: APIOperation, fixtures: dict[str, Any], sub_test: Cal\n SEPARATOR = \"\\n====================\"\n \n \n-def _schema_error(subtests: SubTests, error: InvalidSchema, node_id: str) -> None:\n+def _schema_error(subtests: pytest.Subtests, error: InvalidSchema, node_id: str, node: pytest.Function) -> None:\n     \"\"\"Run a failing test, that will show the underlying problem.\"\"\"\n     sub_test = error.as_failing_test_function()\n-    kwargs = {\"path\": error.path}\n+    kwargs: dict[str, Any] = {}\n     if error.method:\n         kwargs[\"method\"] = error.method.upper()\n-    subtests.item._nodeid = _get_partial_node_name(node_id, **kwargs)\n+    kwargs[\"path\"] = error.path\n+    node._nodeid = _get_partial_node_name(node_id, **kwargs)\n     __tracebackhide__ = True\n     with subtests.test(**kwargs):\n         sub_test()\ndiff --git a/src/schemathesis/pytest/plugin.py b/src/schemathesis/pytest/plugin.py\nindex 1b6a24a2e8..67b9ffdb77 100644\n--- a/src/schemathesis/pytest/plugin.py\n+++ b/src/schemathesis/pytest/plugin.py\n@@ -10,10 +10,10 @@\n from _pytest import nodes\n from _pytest.config import hookimpl\n from _pytest.python import Class, Function, FunctionDefinition, Metafunc, Module, PyCollector\n+from _pytest.subtests import SubtestReport\n from hypothesis.errors import FailedHealthCheck, InvalidArgument, Unsatisfiable\n from jsonschema.exceptions import SchemaError\n from pluggy import Result as PluggyResult\n-from pytest_subtests.plugin import SubTestReport\n \n from schemathesis.core.compat import BaseExceptionGroup\n from schemathesis.core.control import SkipTest\n@@ -271,7 +271,7 @@ def pytest_pycollect_makeitem(collector: nodes.Collector, name: str, obj: Any) -\n \n @hookimpl(tryfirst=True)  # type: ignore[untyped-decorator]\n def pytest_runtest_logreport(report: pytest.TestReport) -> None:\n-    if isinstance(report, SubTestReport) and report.passed:\n+    if isinstance(report, SubtestReport) and report.passed:\n         report._schemathesis_ignore_in_summary = True\n \n \n@@ -292,21 +292,17 @@ def pytest_report_teststatus(\n ) -> Generator[None, None, None]:\n     outcome = yield\n     result = cast(PluggyResult[tuple[str, str, str] | None], outcome)\n-    if not isinstance(report, SubTestReport):\n+    if not isinstance(report, SubtestReport):\n         return\n \n-    description = report.sub_test_description()\n-    shortletter = getattr(config.option, \"no_subtests_shortletter\", False)\n+    description = report._sub_test_description()\n \n     if report.passed:\n-        short = \"\" if shortletter else \",\"\n-        result.force_result((\"passed\", short, f\"{description} SUBPASS\"))\n+        result.force_result((\"passed\", \",\", f\"{description} SUBPASS\"))\n     elif report.skipped:\n-        short = \"\" if shortletter else \"-\"\n-        result.force_result((\"skipped\", short, f\"{description} SUBSKIP\"))\n+        result.force_result((\"skipped\", \"-\", f\"{description} SUBSKIP\"))\n     elif report.outcome == \"failed\":\n-        short = \"\" if shortletter else \"u\"\n-        result.force_result((\"failed\", short, f\"{description} SUBFAIL\"))\n+        result.force_result((\"failed\", \"u\", f\"{description} SUBFAIL\"))\n \n \n @pytest.hookimpl(tryfirst=True)  # type: ignore[untyped-decorator]\ndiff --git a/test/test_lazy.py b/test/test_lazy.py\nindex a38b575f08..668f2a9076 100644\n--- a/test/test_lazy.py\n+++ b/test/test_lazy.py\n@@ -877,7 +877,7 @@ def test_api(case):\n     result = testdir.runpytest(\"-v\")\n \n     # Then `POST /users` should be excluded, only `GET /users` and `GET /products` should be tested\n-    # With pytest-subtests, the main test passes once, with 2 subtests (not 3)\n+    # With pytest subtests, the main test passes once, with 2 subtests (not 3)\n     result.assert_outcomes(passed=1)\n \n     assert \"POST /users\" not in result.stdout.str()\n", "problem_statement": "[BUG] runtime dependency on no longer maintained pytest-subtests\nhttps://github.com/pytest-dev/pytest-subtests?tab=readme-ov-file#important\n\n> This plugin has been integrated directly into pytest 9.0, so the plugin itself will no longer be maintained and the repository will be archived.\n", "hints_text": "Thanks for reporting, I'll take a look\n\n", "all_hints_text": "Thanks for reporting, I'll take a look\n\n", "commit_urls": ["https://github.com/schemathesis/schemathesis/commit/d654396eb3737ee2b339a776dc870a50a3aee393"], "created_at": "2026-02-25T07:05:54Z"}
{"repo": "schemathesis/schemathesis", "pull_number": 3530, "instance_id": "schemathesis__schemathesis-3530", "issue_numbers": [3525], "base_commit": "f9c8148d0eb98d37d4a8712931208c510ab37325", "patch": "diff --git a/CHANGELOG.md b/CHANGELOG.md\nindex ecc8adf264..b5cd174fea 100644\n--- a/CHANGELOG.md\n+++ b/CHANGELOG.md\n@@ -4,6 +4,7 @@\n \n ### :bug: Fixed\n \n+- False positive `negative_data_rejection` for `application/xml` bodies in the coverage phase due to type mutations producing wire-identical bytes. [#3525](https://github.com/schemathesis/schemathesis/issues/3525)\n - Coverage phase generating schema-invalid positive values for schemas with `anyOf`/`oneOf` and `required` constraints. [#3520](https://github.com/schemathesis/schemathesis/issues/3520)\n - `missing_required_header` now accepts `400`, `401`, `403`, and `422` (in addition to `406`) for missing non-`Authorization` required headers. [#3521](https://github.com/schemathesis/schemathesis/issues/3521)\n - Coverage phase silently replacing path parameter values with `\"value\"` when a custom format (e.g., `ipv4-network`) generates strings containing `/`. [#3527](https://github.com/schemathesis/schemathesis/issues/3527)\ndiff --git a/src/schemathesis/core/media_types.py b/src/schemathesis/core/media_types.py\nindex a58f77ae95..3c6fcf0a86 100644\n--- a/src/schemathesis/core/media_types.py\n+++ b/src/schemathesis/core/media_types.py\n@@ -79,6 +79,12 @@ def is_xml(value: str) -> bool:\n     return sub == \"xml\" or sub.endswith(\"+xml\")\n \n \n+def is_xml_parts(media_type: tuple[str, str]) -> bool:\n+    \"\"\"Detect variations of the ``application/xml`` media type from a parsed tuple.\"\"\"\n+    _, sub = media_type\n+    return sub == \"xml\" or sub.endswith(\"+xml\")\n+\n+\n def matches_parts(expected: tuple[str, str], actual: tuple[str, str]) -> bool:\n     \"\"\"Check if two parsed media types match with wildcard support.\"\"\"\n     expected_main, expected_sub = expected\ndiff --git a/src/schemathesis/generation/coverage.py b/src/schemathesis/generation/coverage.py\nindex 34ef64d47b..3c5387c61e 100644\n--- a/src/schemathesis/generation/coverage.py\n+++ b/src/schemathesis/generation/coverage.py\n@@ -36,6 +36,7 @@\n from schemathesis.core import INTERNAL_BUFFER_SIZE, NOT_SET\n from schemathesis.core.compat import RefResolutionError, RefResolver\n from schemathesis.core.jsonschema.types import JsonSchema, JsonSchemaObject\n+from schemathesis.core.media_types import is_xml_parts\n from schemathesis.core.parameters import ParameterLocation\n from schemathesis.core.transforms import deepclone\n from schemathesis.core.validation import contains_unicode_surrogate_pair, has_invalid_characters, is_latin_1_encodable\n@@ -323,16 +324,14 @@ def leads_to_negative_test_case(self, value: Any) -> bool:\n         return True\n \n     def will_be_serialized_to_string(self) -> bool:\n-        return self.location in (\"query\", \"path\", \"header\", \"cookie\") or (\n-            self.location == \"body\"\n-            and self.media_type\n-            in frozenset(\n-                [\n-                    (\"multipart\", \"form-data\"),\n-                    (\"application\", \"x-www-form-urlencoded\"),\n-                ]\n-            )\n-        )\n+        if self.location in (\"query\", \"path\", \"header\", \"cookie\"):\n+            return True\n+        if self.location == \"body\" and self.media_type is not None:\n+            if self.media_type in frozenset([(\"multipart\", \"form-data\"), (\"application\", \"x-www-form-urlencoded\")]):\n+                return True\n+            if is_xml_parts(self.media_type):\n+                return True\n+        return False\n \n     def can_be_negated(self, schema: JsonSchemaObject) -> bool:\n         # Path, query, header, and cookie parameters will be stringified anyway\n@@ -1740,6 +1739,16 @@ def _negative_type(\n         strategies.pop(\"null\", None)\n         strategies.pop(\"array\", None)\n         strategies.pop(\"object\", None)\n+    # XML body: null and empty string both serialize to an empty element (<RootTag></RootTag>),\n+    # indistinguishable from an empty object {} at the wire level\n+    if (\n+        \"object\" in types\n+        and ctx.location == ParameterLocation.BODY\n+        and ctx.media_type is not None\n+        and is_xml_parts(ctx.media_type)\n+    ):\n+        strategies.pop(\"null\", None)\n+        strategies.pop(\"string\", None)\n     if filter_func is not None:\n         for ty, strategy in strategies.items():\n             strategies[ty] = strategy.filter(filter_func)\n@@ -1774,6 +1783,9 @@ def is_valid(x: object) -> bool:\n             return True\n \n     def _does_not_match_the_original_schema(value: Any) -> bool:\n+        # For XML, None serializes to \"\" (empty element content), not to \"None\"\n+        if ctx.media_type is not None and is_xml_parts(ctx.media_type) and value is None:\n+            return not is_valid(\"\")\n         return not is_valid(str(value))\n \n     if ctx.location == ParameterLocation.PATH:\n", "test_patch": "diff --git a/test/coverage/test_phase.py b/test/coverage/test_phase.py\nindex e3b6a97ffd..d88274cc40 100644\n--- a/test/coverage/test_phase.py\n+++ b/test/coverage/test_phase.py\n@@ -71,18 +71,7 @@ def __eq__(self, value: object, /) -> bool:\n     {\"query\": {\"q1\": ANY, \"q2\": \"0\"}, \"headers\": {\"h1\": \"null\", \"h2\": Pattern(\"-?[0-9]+\")}, \"body\": 0},\n     {\"query\": {\"q1\": ANY, \"q2\": \"0\"}, \"headers\": {\"h1\": \"false\", \"h2\": Pattern(\"-?[0-9]+\")}, \"body\": 0},\n     {\"query\": {\"q1\": ANY, \"q2\": \"0\"}, \"headers\": {\"h1\": ANY, \"h2\": Pattern(\"-?[0-9]+\")}, \"body\": {}},\n-    {\"query\": {\"q1\": ANY, \"q2\": \"0\"}, \"headers\": {\"h1\": ANY, \"h2\": Pattern(\"-?[0-9]+\")}, \"body\": {\"x-prop\": {}}},\n-    {\n-        \"query\": {\"q1\": ANY, \"q2\": \"0\"},\n-        \"headers\": {\"h1\": ANY, \"h2\": Pattern(\"-?[0-9]+\")},\n-        \"body\": {\"x-prop\": [None, None]},\n-    },\n-    {\"query\": {\"q1\": ANY, \"q2\": \"0\"}, \"headers\": {\"h1\": ANY, \"h2\": Pattern(\"-?[0-9]+\")}, \"body\": {\"x-prop\": None}},\n-    {\"query\": {\"q1\": ANY, \"q2\": \"0\"}, \"headers\": {\"h1\": ANY, \"h2\": Pattern(\"-?[0-9]+\")}, \"body\": {\"x-prop\": False}},\n-    {\"query\": {\"q1\": ANY, \"q2\": \"0\"}, \"headers\": {\"h1\": ANY, \"h2\": Pattern(\"-?[0-9]+\")}, \"body\": {\"x-prop\": 0}},\n     {\"query\": {\"q1\": ANY, \"q2\": \"0\"}, \"headers\": {\"h1\": ANY, \"h2\": Pattern(\"-?[0-9]+\")}, \"body\": [None, None]},\n-    {\"query\": {\"q1\": ANY, \"q2\": \"0\"}, \"headers\": {\"h1\": ANY, \"h2\": Pattern(\"-?[0-9]+\")}, \"body\": \"\"},\n-    {\"query\": {\"q1\": ANY, \"q2\": \"0\"}, \"headers\": {\"h1\": ANY, \"h2\": Pattern(\"-?[0-9]+\")}},\n     {\"query\": {\"q1\": ANY, \"q2\": \"0\"}, \"headers\": {\"h1\": ANY, \"h2\": Pattern(\"-?[0-9]+\")}, \"body\": False},\n     {\"query\": {\"q1\": ANY, \"q2\": \"0\"}, \"headers\": {\"h1\": ANY, \"h2\": Pattern(\"-?[0-9]+\")}, \"body\": 0},\n     {\"query\": {\"q1\": ANY, \"q2\": \"0\"}, \"headers\": {\"h1\": ANY, \"h2\": Pattern(\"-?[0-9]+\")}, \"body\": {}},\n@@ -136,14 +125,7 @@ def __eq__(self, value: object, /) -> bool:\n     {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": ANY, \"h2\": \"000\"}, \"body\": {\"j-prop\": 0}},\n     {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": \"4\", \"h2\": \"000\"}, \"body\": {\"j-prop\": 0}},\n     {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": \"5\", \"h2\": \"000\"}, \"body\": {}},\n-    {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": \"5\", \"h2\": \"000\"}, \"body\": {\"x-prop\": {}}},\n-    {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": \"5\", \"h2\": \"000\"}, \"body\": {\"x-prop\": [None, None]}},\n-    {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": \"5\", \"h2\": \"000\"}, \"body\": {\"x-prop\": None}},\n-    {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": \"5\", \"h2\": \"000\"}, \"body\": {\"x-prop\": False}},\n-    {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": \"5\", \"h2\": \"000\"}, \"body\": {\"x-prop\": 0}},\n     {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": \"5\", \"h2\": \"000\"}, \"body\": [None, None]},\n-    {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": \"5\", \"h2\": \"000\"}, \"body\": \"\"},\n-    {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": \"5\", \"h2\": \"000\"}},\n     {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": \"5\", \"h2\": \"000\"}, \"body\": False},\n     {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": \"5\", \"h2\": \"000\"}, \"body\": 0},\n     {\"query\": {\"q1\": \"5\", \"q2\": \"000\"}, \"headers\": {\"h1\": \"5\", \"h2\": \"000\"}, \"body\": {\"x-prop\": \"\"}},\n@@ -3093,3 +3075,85 @@ def collect(case):\n \n     assert path_values, \"No coverage cases generated\"\n     assert all(v == \"0.0.0.0%2F0\" for v in path_values), f\"Unexpected values: {path_values}\"\n+\n+\n+def _collect_xml_coverage_cases(ctx, body_schema):\n+    \"\"\"Build an XML-only schema, run in negative mode, and return coverage phase cases.\"\"\"\n+    schema = build_schema(\n+        ctx,\n+        request_body={\n+            \"required\": True,\n+            \"content\": {\"application/xml\": {\"schema\": body_schema}},\n+        },\n+    )\n+    loaded = schemathesis.openapi.from_dict(schema)\n+    operation = loaded[\"/foo\"][\"post\"]\n+\n+    cases = []\n+\n+    def collect(case):\n+        if case.meta.phase.name == TestPhase.COVERAGE:\n+            cases.append(case)\n+\n+    run_negative_test(operation, collect)\n+    return cases\n+\n+\n+def test_xml_string_field_no_type_mutations(ctx):\n+    # For {\"type\": \"string\"} XML fields, type mutations produce the same wire bytes as valid strings.\n+    # None -> \"\", False -> \"False\", 0 -> \"0\" all become valid string content in XML elements.\n+    cases = _collect_xml_coverage_cases(\n+        ctx,\n+        {\"type\": \"object\", \"properties\": {\"x-prop\": {\"type\": \"string\"}}, \"required\": [\"x-prop\"]},\n+    )\n+    type_mutation_bodies = [\n+        c.body\n+        for c in cases\n+        if isinstance(c.body, dict) and \"x-prop\" in c.body and not isinstance(c.body[\"x-prop\"], str)\n+    ]\n+    assert type_mutation_bodies == [], (\n+        f\"No type mutations should be generated for XML string fields, got: {type_mutation_bodies}\"\n+    )\n+\n+\n+def test_xml_constrained_string_field_generates_violations(ctx):\n+    # Constrained string schemas (e.g. minLength) should produce violations in negative mode.\n+    cases = _collect_xml_coverage_cases(\n+        ctx,\n+        {\"type\": \"object\", \"properties\": {\"x-prop\": {\"type\": \"string\", \"minLength\": 5}}, \"required\": [\"x-prop\"]},\n+    )\n+    violation_bodies = [\n+        c.body\n+        for c in cases\n+        if isinstance(c.body, dict) and isinstance(c.body.get(\"x-prop\"), str) and len(c.body[\"x-prop\"]) < 5\n+    ]\n+    assert violation_bodies, \"Constrained XML string fields should generate constraint violations\"\n+\n+\n+def test_xml_object_body_no_ambiguous_mutations(ctx):\n+    # For XML object bodies, both null and empty string serialize to <RootTag></RootTag>,\n+    # which is identical to an empty object {} at the wire level. Neither should be generated.\n+    cases = _collect_xml_coverage_cases(\n+        ctx,\n+        {\"type\": \"object\", \"properties\": {\"x-prop\": {\"type\": \"string\"}}},\n+    )\n+    ambiguous = [c for c in cases if c.body is None or c.body == \"\"]\n+    assert ambiguous == [], (\n+        f\"Null/empty-string body mutations should not be generated for XML object bodies, got: {ambiguous}\"\n+    )\n+\n+\n+def test_xml_none_property_mutation_filtered_when_schema_accepts_empty_string(ctx):\n+    # For XML string fields, _escape_xml(None) = \"\" (not \"None\").\n+    # Schema {\"type\": \"string\", \"maxLength\": 0} accepts only \"\" \u2014 None should NOT be generated\n+    # because it produces the same valid wire content.\n+    cases = _collect_xml_coverage_cases(\n+        ctx,\n+        {\"type\": \"object\", \"properties\": {\"x-prop\": {\"type\": \"string\", \"maxLength\": 0}}, \"required\": [\"x-prop\"]},\n+    )\n+    null_property_mutations = [\n+        c for c in cases if isinstance(c.body, dict) and \"x-prop\" in c.body and c.body[\"x-prop\"] is None\n+    ]\n+    assert null_property_mutations == [], (\n+        f\"None mutation for XML string field with maxLength:0 should be filtered, got: {null_property_mutations}\"\n+    )\n", "problem_statement": "[BUG] xml generation potential problem\nI am digging a problem in `django-modern-rest`, right now we don't enable `schemathesis` for xml endpoints, because there are open problems with that.\n\nI am trying to enable it. Here: https://github.com/wemake-services/django-modern-rest/blob/91b1be5bd57618223aec149963cd3ce2f3460d8c/tests/test_integration/test_openapi/test_schema.py#L24-L26\n\nWhat I get is kinda interesting.\n\nSo, here's my source code: https://github.com/wemake-services/django-modern-rest/blob/master/django_test_app/server/apps/negotiations/views.py\n\nModel:\n\n```python\n@final\nclass _RequestModel(pydantic.BaseModel):\n    payment_method_id: str\n    payment_amount: str\n```\n\nWhen I run the test case with `pytest tests/test_integration/test_openapi/test_schema.py` I get:\n\n```\n  | schemathesis.core.failures.FailureGroup: Schemathesis found 1 distinct failure\n  | \n  | - API rejected schema-compliant request\n  | \n  |     Valid data should have been accepted\n  |     Expected: 2xx, 401, 403, 404, 409, 5xx\n  | \n  | [400] Bad Request:\n  | \n  |     `{\"detail\":[{\"msg\":\"Input should be a valid string\",\"loc\":[\"parsed_body\",\"payment_method_id\"],\"type\":\"value_error\"},{\"msg\":\"Input should be a valid string\",\"loc\":[\"parsed_body\",\"payment_amount\"],\"type\":\"value_error\"}]}`\n  | \n  | Reproduce with:\n  | \n  |     curl -X POST -H 'Content-Type: application/xml' -d '<_RequestModel><payment_method_id></payment_method_id><payment_amount></payment_amount></_RequestModel>' --insecure http://localhost/api/negotiations/negotiation\n  | \n  |  (1 sub-exception)\n  +-+---------------- 1 ----------------\n    | schemathesis.openapi.checks.RejectedPositiveData: API rejected schema-compliant request\n    | \n    | Valid data should have been accepted\n    | Expected: 2xx, 401, 403, 404, 409, 5xx\n    +------------------------------------\n```\n\nOk, fair enough. `xmltodict` which I use for the test parser converts `<payment_method_id></payment_method_id>` to `{'payment_method_id': None}`. My model defines `payment_method_id` as `str`, I can postprocess this.\n\nChanging:\n\n```diff\ndiff --git django_test_app/server/apps/negotiations/views.py django_test_app/server/apps/negotiations/views.py\nindex 56464b9..5bb2833 100644\n--- django_test_app/server/apps/negotiations/views.py\n+++ django_test_app/server/apps/negotiations/views.py\n@@ -76,6 +76,8 @@ class XmlParser(Parser):\n         key: str,\n         xml_value: Any,\n     ) -> tuple[str, Any]:\n+        if xml_value is None:\n+            return key, ''\n         return key, xml_value\n```\n\n## The problem\n\nAnd now this happens:\n\n```\n  | schemathesis.core.failures.FailureGroup: Schemathesis found 1 distinct failure\n  | \n  | - API accepted schema-violating request\n  | \n  |     Invalid data should have been rejected\n  |     Expected: 400, 401, 403, 404, 406, 422, 428, 5xx\n  |     Invalid component: in body - object with invalid 'payment_amount' value: Incorrect type\n  | \n  | [201] Created:\n  | \n  |     `[\"\",\"\"]`\n  | \n  | Reproduce with:\n  | \n  |     curl -X POST -H 'Content-Type: application/xml' -d '<_RequestModel><payment_method_id></payment_method_id><payment_amount></payment_amount></_RequestModel>' --insecure http://localhost/api/negotiations/negotiation\n  | \n  |  (1 sub-exception)\n  +-+---------------- 1 ----------------\n    | schemathesis.core.failures.AcceptedNegativeData: API accepted schema-violating request\n    | \n    | Invalid data should have been rejected\n    | Expected: 400, 401, 403, 404, 406, 422, 428, 5xx\n    | Invalid component: in body - object with invalid 'payment_amount' value: Incorrect type\n    +------------------------------------\n```\n\nNotice that two `curl` commands from the first and the second cases are identical:\n1. `curl -X POST -H 'Content-Type: application/xml' -d '<_RequestModel><payment_method_id></payment_method_id><payment_amount></payment_amount></_RequestModel>' --insecure http://localhost/api/negotiations/negotiation`\n2. `curl -X POST -H 'Content-Type: application/xml' -d '<_RequestModel><payment_method_id></payment_method_id><payment_amount></payment_amount></_RequestModel>' --insecure http://localhost/api/negotiations/negotiation`\n\nSo, why the first data is expected to generate 20x by `RejectedPositiveData`, while the very same data is also expected to generate 401 by `AcceptedNegativeData` in the second case?\n\nIs it related to how XML works? Maybe it treats `''` and `None` the same way here? This is my wild guess :)\n", "hints_text": "Thanks for opening this and providing all the details! :)\n\nIt is conceptually very similar to earlier urlencoded serialization issues where different generated values have the same representation on the wire. There are some guards for urlencoded, but not for XML - I'll add them :)\n\nI.e. on the generator level `42` and `\"42\"` have different types, but then they are both serialized to `<el>42</el>` - but the metadata could say that one is positive and another one is negative (e.g. `type` is mutated). Metadata is correct and useful for e.g. JSON, but there are such ambiguities with other media types\n\n", "all_hints_text": "Thanks for opening this and providing all the details! :)\n\nIt is conceptually very similar to earlier urlencoded serialization issues where different generated values have the same representation on the wire. There are some guards for urlencoded, but not for XML - I'll add them :)\n\nI.e. on the generator level `42` and `\"42\"` have different types, but then they are both serialized to `<el>42</el>` - but the metadata could say that one is positive and another one is negative (e.g. `type` is mutated). Metadata is correct and useful for e.g. JSON, but there are such ambiguities with other media types\nThanks a lot for the quick fix. If you are up to release a new version, I will report back any new findings and double check the fixes :)\nYou are very welcome! :) I'll finish the SSE testing implementation and will make a new release :) likely in the next few days\nBtw, I also have SSE implementation ready, I will be ready to test that as well.\nFollow up:\n\n```\n[6](https://github.com/wemake-services/django-modern-rest/actions/runs/22673841869/job/65724856788?pr=595#step:6:457)\n  | - API accepted schema-violating request\n  | \n  |     Invalid data should have been rejected\n  |     Expected: 400, 401, 403, 404, 406, 422, 428, 5xx\n  |     Invalid component: in body - invalid type boolean (expected string)\n  | \n  | [201] Created:\n  | \n  |     `[\"\\\"\\u00cf\\udb8c\\udff3\\ud96a\\udd2c\\ud862\\udc97J\\u00cf\\u008b3\", \"False\"]`\n  | \n  | Reproduce with:\n  | \n  |     curl -X POST -H 'Content-Type: application/xml' -d '<_RequestModel><payment_amount>False</payment_amount><payment_method_id>&quot;\u00cf\udb8c\udff3\ud96a\udd2c\ud862\udc97J\u00cf\u008b3</payment_method_id><_>-4.958119827689552e+289</_><_></_><___o__U___C_2__N_>D\u00c8\u0092</___o__U___C_2__N_><_></_><_></_><_></_></_RequestModel>' --insecure http://localhost/api/negotiations/negotiation\n  | \n  |  (1 sub-exception)\n  +-+---------------- 1 ----------------\n    | schemathesis.core.failures.AcceptedNegativeData: API accepted schema-violating request\n    | \n    | Invalid data should have been rejected\n    | Expected: 400, 401, 403, 404, 406, 422, 428, 5xx\n    | Invalid component: in body - invalid type boolean (expected string)\n    +------------------------------------\n```\n\nI believe that this is a false-positive in `schemathesis`.\nMy API expects `payment_amount: str` and `payment_method_id: str`. https://github.com/wemake-services/django-modern-rest/blob/68751328289b671865ed133a7662bd2680ecaeae/django_test_app/server/apps/negotiations/views.py#L120-L123\nIt gets `payment_method_id=\"&quot;\u00cf\udb8c\udff3\ud96a\udd2c\ud862\udc97J\u00cf\u008b3\"` and `payment_amount=\"False\"`. These are two valid strings, one just happen to look like a `bool`.\n\nTest passes, `schemathesis` is not happy about it :(\nOh, I forgot the fuzzing phase - will fix soon\nThe fix is merged - I'll make a release today / tomorrow (want to include a few more fixes)\nReleased in 4.11.1\n\n", "commit_urls": ["https://github.com/schemathesis/schemathesis/commit/a3af51efb420b0fbf199ece376a8d168518a4f24"], "created_at": "2026-02-25T12:17:37Z"}
{"repo": "schemathesis/schemathesis", "pull_number": 3529, "instance_id": "schemathesis__schemathesis-3529", "issue_numbers": [3527], "base_commit": "a49aad8ecbf219b29feb45878e6c21c20318c5fe", "patch": "diff --git a/CHANGELOG.md b/CHANGELOG.md\nindex 8d72808b98..ecc8adf264 100644\n--- a/CHANGELOG.md\n+++ b/CHANGELOG.md\n@@ -6,6 +6,7 @@\n \n - Coverage phase generating schema-invalid positive values for schemas with `anyOf`/`oneOf` and `required` constraints. [#3520](https://github.com/schemathesis/schemathesis/issues/3520)\n - `missing_required_header` now accepts `400`, `401`, `403`, and `422` (in addition to `406`) for missing non-`Authorization` required headers. [#3521](https://github.com/schemathesis/schemathesis/issues/3521)\n+- Coverage phase silently replacing path parameter values with `\"value\"` when a custom format (e.g., `ipv4-network`) generates strings containing `/`. [#3527](https://github.com/schemathesis/schemathesis/issues/3527)\n \n ### :wrench: Changed\n \ndiff --git a/src/schemathesis/generation/coverage.py b/src/schemathesis/generation/coverage.py\nindex 285c75bd4d..34ef64d47b 100644\n--- a/src/schemathesis/generation/coverage.py\n+++ b/src/schemathesis/generation/coverage.py\n@@ -1067,7 +1067,7 @@ def _positive_string(ctx: CoverageContext, schema: JsonSchemaObject) -> Generato\n     if min_length == 0:\n         min_length = None\n     max_length = schema.get(\"maxLength\")\n-    if ctx.location == \"path\":\n+    if ctx.location == \"path\" and not (\"format\" in schema and schema[\"format\"] in ctx.custom_formats):\n         schema = _ensure_valid_path_parameter_schema(schema)\n     elif ctx.location in (\"header\", \"cookie\") and not (\"format\" in schema and schema[\"format\"] in FORMAT_STRATEGIES):\n         # Don't apply it for known formats - they will insure the correct format during generation\n", "test_patch": "diff --git a/test/conftest.py b/test/conftest.py\nindex 40c1437adb..6d80c20639 100644\n--- a/test/conftest.py\n+++ b/test/conftest.py\n@@ -39,6 +39,7 @@\n from schemathesis.core.transport import Response\n from schemathesis.core.version import SCHEMATHESIS_VERSION\n from schemathesis.specs.openapi import media_types\n+from schemathesis.specs.openapi.formats import STRING_FORMATS\n from schemathesis.transport.asgi import ASGI_TRANSPORT\n from schemathesis.transport.requests import REQUESTS_TRANSPORT\n from schemathesis.transport.wsgi import WSGI_TRANSPORT\n@@ -73,6 +74,7 @@\n def reset_hooks():\n     # Store built-in deserializers to restore after test\n     builtin_deserializers = deserialization.deserializers().copy()\n+    builtin_string_formats = set(STRING_FORMATS.keys())\n \n     CUSTOM_HANDLERS.clear()\n     hooks.unregister_all()\n@@ -92,6 +94,10 @@ def reset_hooks():\n     deserialization.unregister_deserializer(*current)\n     for media_type, func in builtin_deserializers.items():\n         deserialization.register_deserializer(func, media_type)\n+    # Remove any string formats registered during the test\n+    for name in list(STRING_FORMATS.keys()):\n+        if name not in builtin_string_formats:\n+            del STRING_FORMATS[name]\n \n \n @pytest.fixture(scope=\"session\")\ndiff --git a/test/coverage/test_phase.py b/test/coverage/test_phase.py\nindex 099f997d61..e3b6a97ffd 100644\n--- a/test/coverage/test_phase.py\n+++ b/test/coverage/test_phase.py\n@@ -8,6 +8,7 @@\n import pytest\n from flask import Flask, jsonify, request\n from hypothesis import Phase, settings\n+from hypothesis import strategies as st\n from requests import Request\n from requests.models import RequestEncodingMixin\n \n@@ -3061,3 +3062,34 @@ def find_case(case):\n     assert \"Content-Type\" not in request.headers, (\n         f\"Missing Content-Type test should not have Content-Type header, got: {dict(request.headers)}\"\n     )\n+\n+\n+def test_path_parameter_with_slash_in_custom_format(ctx):\n+    # See GH-3527\n+    schemathesis.openapi.format(\"ipv4-network\", st.sampled_from([\"0.0.0.0/0\"]))\n+    schema = build_schema(\n+        ctx,\n+        path=\"/blocks/{block}\",\n+        method=\"get\",\n+        parameters=[\n+            {\n+                \"name\": \"block\",\n+                \"in\": \"path\",\n+                \"required\": True,\n+                \"schema\": {\"type\": \"string\", \"format\": \"ipv4-network\"},\n+            }\n+        ],\n+    )\n+    loaded = schemathesis.openapi.from_dict(schema)\n+    operation = loaded[\"/blocks/{block}\"][\"get\"]\n+\n+    path_values = []\n+\n+    def collect(case):\n+        if case.meta.phase.name == TestPhase.COVERAGE:\n+            path_values.append(case.path_parameters.get(\"block\"))\n+\n+    run_positive_test(operation, collect)\n+\n+    assert path_values, \"No coverage cases generated\"\n+    assert all(v == \"0.0.0.0%2F0\" for v in path_values), f\"Unexpected values: {path_values}\"\n", "problem_statement": "[BUG] Path parameter containing slash been replaced with \"value\"\n### Checklist\n\n- [x] I checked the [FAQ section](https://schemathesis.readthedocs.io/en/stable/faq/) of the documentation\n- [x] I looked for similar issues in the [issue tracker](https://github.com/schemathesis/schemathesis/issues)\n- [x] I am using the latest version of Schemathesis\n\n### Describe the bug\n\nWith following schema\n\n```yaml\n   /blocks/{network}/{l3vpn}/{block}:\n     put:\n       parameters:\n         - name: network\n           in: path\n           required: true\n           schema:\n             type: string\n             default: default\n         - name: l3vpn\n           in: path\n           required: true\n           schema:\n             type: string\n         - name: block\n           in: path\n           required: true\n           schema:\n             type: string\n             format: ipv4-network\n```\n\nand hook\n\n```\nIPV4_NETWORKS = ['0.0.0.0/0']\nschemathesis.openapi.format('ipv4-network', st.sampled_from(IPV4_NETWORKS))\n```\n\nblock parameter supposed to be escaped `\"0.0.0.0%2F0\"`, while actually is `\"value\"`\n\n```\n- API rejected schema-compliant request\n\n    Valid data should have been accepted\n    Expected: 2xx, 401, 403, 404, 409, 5xx\n\n[400] Bad Request:\n\n    `{\"error\":\"invalid CIDR address: value\"}`\n```\n\nIf I manually escape path parameter with quote_plus\n\n```python\nschemathesis.openapi.format('ipv4-network', st.sampled_from(IPV4_NETWORKS).map(quote_plus))\n```\n\npath_parameter will be escaped again\n\n```\n- API rejected schema-compliant request\n\n    Valid data should have been accepted\n    Expected: 2xx, 401, 403, 404, 409, 5xx\n\n[400] Bad Request:\n\n    `{\"error\":\"invalid CIDR address: 0.0.0.0%252F0\"}`\n```\n\nSeems the problem is following:\n1. coverage.py reject path parameter containing slash with `is_invalid_path_parameter`\n2. If manually escaping path parameter, it will be escaped again, at coverage.py line 1781\n\n### To Reproduce\n\n\ud83d\udea8 **Mandatory** \ud83d\udea8: Steps to reproduce the behavior:\n\n1. Run this command '...'\n2. See error\n\nPlease include a minimal API schema causing this issue:\n\n```yaml\n{ \"openapi\": \"3.0.3\", ... }\n```\n\n### Expected behavior\n\nSince format is path unrelated, the only choise seems to be removing slash check from `is_invalid_path_parameter`\n\n### Environment\n\n```\n- OS: Linux\n- Python version: 3.11.2\n- Schemathesis version: 4.10.2\n- Spec version: OpenAPI 3.0.3\n```\n\n### Additional context\n\nInclude any other relevant details, like logs or screenshots.\n\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/schemathesis/schemathesis/commit/bdb3ccb31615317eb7ff1843926bffe7441716c9"], "created_at": "2026-02-25T09:59:54Z"}
{"repo": "schemathesis/schemathesis", "pull_number": 3534, "instance_id": "schemathesis__schemathesis-3534", "issue_numbers": [3533], "base_commit": "c229eef470c683e17e8166f67723a35fba56cf2b", "patch": "diff --git a/CHANGELOG.md b/CHANGELOG.md\nindex 7de82e8d36..396685ab06 100644\n--- a/CHANGELOG.md\n+++ b/CHANGELOG.md\n@@ -12,6 +12,7 @@\n - Coverage phase generating schema-invalid positive values for schemas with `anyOf`/`oneOf` and `required` constraints. [#3520](https://github.com/schemathesis/schemathesis/issues/3520)\n - `missing_required_header` now accepts `400`, `401`, `403`, and `422` (in addition to `406`) for missing non-`Authorization` required headers. [#3521](https://github.com/schemathesis/schemathesis/issues/3521)\n - Coverage phase silently replacing path parameter values with `\"value\"` when a custom format (e.g., `ipv4-network`) generates strings containing `/`. [#3527](https://github.com/schemathesis/schemathesis/issues/3527)\n+- Examples phase not escaping path examples containing `/` when some path parameters were generated from schema. [#3533](https://github.com/schemathesis/schemathesis/issues/3533)\n \n ### :wrench: Changed\n \ndiff --git a/src/schemathesis/openapi/generation/filters.py b/src/schemathesis/openapi/generation/filters.py\nindex c7d9fd44b5..b5d12918f0 100644\n--- a/src/schemathesis/openapi/generation/filters.py\n+++ b/src/schemathesis/openapi/generation/filters.py\n@@ -1,5 +1,6 @@\n from collections.abc import Mapping\n from typing import Any\n+from urllib.parse import unquote\n \n from schemathesis.core import NOT_SET\n from schemathesis.core.validation import contains_unicode_surrogate_pair, has_invalid_characters, is_latin_1_encodable\n@@ -35,7 +36,14 @@ def is_invalid_path_parameter(value: Any) -> bool:\n     # For non-strings (dicts, lists), their str() is what appears in the URL\n     str_value = value if isinstance(value, str) else str(value)\n \n-    if \"/\" in str_value or \"}\" in str_value or \"{\" in str_value:\n+    # `%2F` is decoded by many HTTP stacks before routing, effectively turning it into `/`.\n+    # Reject such values to avoid ambiguous path resolution.\n+    if (\n+        (isinstance(value, str) and \"/\" in unquote(str_value))\n+        or \"/\" in str_value\n+        or \"}\" in str_value\n+        or \"{\" in str_value\n+    ):\n         return True\n \n     # Avoid situations when the path parameter contains only NULL bytes.\ndiff --git a/src/schemathesis/specs/openapi/_hypothesis.py b/src/schemathesis/specs/openapi/_hypothesis.py\nindex fdbc87614c..461b8b8a9e 100644\n--- a/src/schemathesis/specs/openapi/_hypothesis.py\n+++ b/src/schemathesis/specs/openapi/_hypothesis.py\n@@ -4,7 +4,7 @@\n from collections.abc import Callable, Iterable\n from dataclasses import dataclass\n from typing import Any, cast\n-from urllib.parse import quote_plus\n+from urllib.parse import quote_plus, unquote\n \n import jsonschema_rs\n from hypothesis import event, note, reject\n@@ -690,12 +690,13 @@ def generate_parameter(\n         extra_data_source=extra_data_source,\n         mix_examples=mix_examples,\n     )\n+    if value is not None and location == ParameterLocation.PATH:\n+        value = quote_all(value)\n+\n     used_generator: GenerationMode | None = generator\n     if value == explicit:\n         # When we pass `explicit`, then its parts are excluded from generation of the final value\n         # If the final value is the same, then other parameters were generated at all\n-        if value is not None and location == ParameterLocation.PATH:\n-            value = quote_all(value)\n         used_generator = None\n     return ValueContainer(value=value, location=location, generator=used_generator, meta=metadata)\n \n@@ -860,12 +861,15 @@ def quote_all(parameters: dict[str, Any]) -> dict[str, Any]:\n \n     for key, value in parameters.items():\n         if isinstance(value, str):\n-            if value == \".\":\n+            # Unquote first to keep quoting idempotent for already-escaped inputs.\n+            # E.g. \"%2E\" should stay escaped and not become a raw \".\"\n+            decoded = unquote(value)\n+            if decoded == \".\":\n                 parameters[key] = \"%2E\"\n-            elif value == \"..\":\n+            elif decoded == \"..\":\n                 parameters[key] = \"%2E%2E\"\n             else:\n-                parameters[key] = quote_plus(value)\n+                parameters[key] = quote_plus(decoded)\n     return parameters\n \n \n", "test_patch": "diff --git a/test/openapi/test_filters.py b/test/openapi/test_filters.py\nindex 825e589c80..fe1610c4ad 100644\n--- a/test/openapi/test_filters.py\n+++ b/test/openapi/test_filters.py\n@@ -63,7 +63,7 @@ def test_invalid_query_fails_with_requests(invalid_params):\n         req.prepare()\n \n \n-@pytest.mark.parametrize(\"value\", [\"/\", \"\\udc9b\"])\n+@pytest.mark.parametrize(\"value\", [\"/\", \"%2F\", \"%2f\", \"foo%2Fbar\", \"\\udc9b\"])\n def test_filter_path_parameters(value):\n     assert not is_valid_path({\"foo\": value})\n \ndiff --git a/test/specs/openapi/test_examples.py b/test/specs/openapi/test_examples.py\nindex 6180ed1e7c..990dd4709f 100644\n--- a/test/specs/openapi/test_examples.py\n+++ b/test/specs/openapi/test_examples.py\n@@ -914,6 +914,52 @@ def test_partial_examples(ctx):\n     jsonschema_rs.validate(parameters_schema, example.path_parameters)\n \n \n+def test_partial_path_examples_are_escaped(ctx):\n+    # See GH-3533\n+    # When only some path parameters come from examples, example values should still be escaped.\n+    schema = ctx.openapi.build_schema(\n+        {\n+            \"/blocks/{network}/{l3vpn}/{block}\": {\n+                \"put\": {\n+                    \"parameters\": [\n+                        {\n+                            \"name\": \"network\",\n+                            \"in\": \"path\",\n+                            \"required\": True,\n+                            \"schema\": {\"type\": \"string\", \"enum\": [\"default\"]},\n+                        },\n+                        {\n+                            \"name\": \"l3vpn\",\n+                            \"in\": \"path\",\n+                            \"required\": True,\n+                            \"schema\": {\"type\": \"string\", \"enum\": [\"0\"]},\n+                        },\n+                        {\n+                            \"name\": \"block\",\n+                            \"in\": \"path\",\n+                            \"required\": True,\n+                            \"schema\": {\"type\": \"string\", \"format\": \"ipv4-network\"},\n+                            \"example\": \"192.168.1.0/24\",\n+                        },\n+                    ],\n+                    \"responses\": {\"200\": {\"description\": \"OK\"}},\n+                }\n+            }\n+        }\n+    )\n+    schema = schemathesis.openapi.from_dict(schema)\n+    operation = schema[\"/blocks/{network}/{l3vpn}/{block}\"][\"PUT\"]\n+    strategy = operation.get_strategies_from_examples()[0]\n+\n+    example = examples.generate_one(strategy)\n+\n+    assert example.path_parameters == {\n+        \"network\": \"default\",\n+        \"l3vpn\": \"0\",\n+        \"block\": \"192.168.1.0%2F24\",\n+    }\n+\n+\n def test_partial_examples_without_null_bytes_and_formats(ctx):\n     schemathesis.openapi.format(\"even_4_digits\", st.from_regex(r\"\\A[0-9]{4}\\Z\").filter(lambda x: int(x) % 2 == 0))\n     schema = ctx.openapi.build_schema(\ndiff --git a/test/test_hypothesis.py b/test/test_hypothesis.py\nindex 57c2a19550..42b0d0fbaa 100644\n--- a/test/test_hypothesis.py\n+++ b/test/test_hypothesis.py\n@@ -464,7 +464,18 @@ def inner(case):\n     inner()\n \n \n-@pytest.mark.parametrize((\"value\", \"expected\"), [(\".\", \"%2E\"), (\"..\", \"%2E%2E\"), (\".foo\", \".foo\")])\n+@pytest.mark.parametrize(\n+    (\"value\", \"expected\"),\n+    [\n+        (\".\", \"%2E\"),\n+        (\"..\", \"%2E%2E\"),\n+        (\".foo\", \".foo\"),\n+        (\"%2E\", \"%2E\"),\n+        (\"%2e\", \"%2E\"),\n+        (\"%2E%2E\", \"%2E%2E\"),\n+        (\"%2e%2e\", \"%2E%2E\"),\n+    ],\n+)\n def test_path_parameters_quotation(value, expected):\n     # See GH-1036\n     assert quote_all({\"foo\": value})[\"foo\"] == expected\n", "problem_statement": "[BUG] Example phase path parameter is not escaped\n### Checklist\n\n- [x] I checked the [FAQ section](https://schemathesis.readthedocs.io/en/stable/faq/) of the documentation\n- [x] I looked for similar issues in the [issue tracker](https://github.com/schemathesis/schemathesis/issues)\n- [x] I am using the latest version of Schemathesis\n\n### Describe the bug\n\nWith following schema\n\n```yaml\n   /blocks/{network}/{l3vpn}/{block}:\n     put:\n       parameters:\n         - name: network\n           in: path\n           required: true\n           schema:\n             type: string\n             default: default\n         - name: l3vpn\n           in: path\n           required: true\n           schema:\n             type: string\n         - name: block\n           in: path\n           required: true\n           schema:\n             type: string\n             format: ipv4-network\n           example: 192.168.1.0/24\n```\n\nFailure due to path not found:\n\n```\n- Undocumented HTTP status code\n\n    Received: 404\n    Documented: 200, 400\n\n[404] Not Found:\n\n    `404 page not found`\n\nReproduce with:\n\n    curl -X PUT -H 'Authorization: [Filtered]' -H 'Content-Type: application/json' -d '{\"purpose\": \"\"}' http://localhost:22118/blocks/0/0/192.168.1.0/24\n```\n\n### To Reproduce\n\n\ud83d\udea8 **Mandatory** \ud83d\udea8: Steps to reproduce the behavior:\n\n1. Run this command 'schemathesis run -u $(BASE_URL) -- build/apidoc.json'\n2. See error\n\nPlease include a minimal API schema causing this issue:\n\n```yaml\n{ \"openapi\": \"3.0.3\", ... }\n```\n\n### Expected behavior\nEscape path parameter\n\n### Environment\n\n```\n- OS: Linux\n- Python version: 3.11.2\n- Schemathesis version: 4.10.2\n- Spec version: 3.0.3\n```\n\n### Additional context\n\nSeems I created same issue quite a long time ago #3003 , but probably not really fixed ( I forgot to remove workaround hook either, after removal this issue happend again)\n\nBTW, I recommend changing existing path parameter escapes with safely escape by `quote_plus(unquote(param))`\n", "hints_text": "Thanks for opening! I'll check it today - I remember that there was a regression test case for #3003 - will check it too\n\n", "all_hints_text": "Thanks for opening! I'll check it today - I remember that there was a regression test case for #3003 - will check it too\n\n", "commit_urls": ["https://github.com/schemathesis/schemathesis/commit/f40b11f8bf2b03bb430d0a729170ea8647285428"], "created_at": "2026-02-28T11:13:46Z"}
