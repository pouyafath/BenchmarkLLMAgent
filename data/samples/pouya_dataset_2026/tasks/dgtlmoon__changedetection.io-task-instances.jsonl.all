oon/changedetection.io/commit/be4f0e0795c5dc5a456cc255f8aeb2b457eaa6d1", "https://github.com/dgtlmoon/changedetection.io/commit/7c3241dffc0c94635cec0c1aa05c763d77f8bc50", "https://github.com/dgtlmoon/changedetection.io/commit/bdb21021a6e6e5d8e43cdaaff9b0f3632af0d86e", "https://github.com/dgtlmoon/changedetection.io/commit/416869681e059992582f74ccaf9f05f3750893f8", "https://github.com/dgtlmoon/changedetection.io/commit/a7fd101efdc971245972854428771f4859ac6d3f", "https://github.com/dgtlmoon/changedetection.io/commit/c315021f6e3f8324d8a306da88523e9f7fac92fa", "https://github.com/dgtlmoon/changedetection.io/commit/3cfc97637a82715d33673f0bf3609d66bff5a91f", "https://github.com/dgtlmoon/changedetection.io/commit/cfa9c193098de3b0bd97a3c565e9d2d6d7cc4bae", "https://github.com/dgtlmoon/changedetection.io/commit/b22ed7ed8885302cd2e319f8f992c08db36ae5ec", "https://github.com/dgtlmoon/changedetection.io/commit/f7a9c29d938b394e1bcea7139336ce84a6833860", "https://github.com/dgtlmoon/changedetection.io/commit/2c0b5b65c1a53cc28563f1f140bdc85549b2c28f", "https://github.com/dgtlmoon/changedetection.io/commit/59e6be34652ffc914927810b49c3d8ccffef4e9c", "https://github.com/dgtlmoon/changedetection.io/commit/ebd7f7caa1c6a3f7cc7e3d89f530434c224f923b", "https://github.com/dgtlmoon/changedetection.io/commit/a8d1bf41e8a3f15ab1ae52a5ad8bc192ac3808d0", "https://github.com/dgtlmoon/changedetection.io/commit/5510cbc00c8450fc3459b44bfdf98622e14cb721", "https://github.com/dgtlmoon/changedetection.io/commit/6dc1f55f3f76ce832f3d610623aa7b1a6fa854b0", "https://github.com/dgtlmoon/changedetection.io/commit/c84171ac2d2036f81959b24252154bd2929b7a75", "https://github.com/dgtlmoon/changedetection.io/commit/a0f6a0b3867a80555e875a5533205b31a47db78f", "https://github.com/dgtlmoon/changedetection.io/commit/6bacc7b4573a68dac0c8995629caa556c503d70f", "https://github.com/dgtlmoon/changedetection.io/commit/eca2f9df59829d21d97f86cf49225b62b127fb46", "https://github.com/dgtlmoon/changedetection.io/commit/c1a88cb9ca