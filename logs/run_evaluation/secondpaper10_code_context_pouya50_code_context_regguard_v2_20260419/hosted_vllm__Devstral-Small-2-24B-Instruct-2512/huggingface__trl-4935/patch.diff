+from dataclasses import dataclass
+from typing import Any, Literal
+
+from transformers import TrainingArguments
+
+from ...trainer.base_config import _BaseConfig
+
+
+@dataclass
+class SDPOConfig(_BaseConfig):
+    r"""
+    Configuration class for SDPO (Self-Distillation with Preference Optimization) training.
+
+    Args:
+        beta (`float`, *optional*, defaults to `0.1`):
+            The beta parameter for the SDPO loss. Controls the trade-off between the policy and reference model.
+        gamma (`float`, *optional*, defaults to `1.0`):
+            The gamma parameter for the SDPO loss. Controls the temperature of the softmax.
+        label_smoothing (`float`, *optional*, defaults to `0.0`):
+            The label smoothing parameter for the SDPO loss.
+        loss_type (`Literal["sigmoid", "hinge", "ipo"]`, *optional*, defaults to `"sigmoid"`):
+            The type of loss to use for SDPO training.
+        model_init_pretrained_model_name_or_path (`str`, *optional*):
+            The path to a pretrained model to initialize the reference model. If not provided, the reference model
+            will be initialized from the same weights as the policy model.
+        model_init_pretrained_model_name_or_path_2 (`str`, *optional*):
+            The path to a pretrained model to initialize the policy model. If not provided, the policy model will be
+            initialized from the same weights as the reference model.
+        reference_free (`bool`, *optional*, defaults to `False`):
+            Whether to use a reference-free version of SDPO.
+        use_softmax (`bool`, *optional*, defaults to `False`):
+            Whether to use softmax instead of sigmoid for the preference model.
+        **kwargs:
+            Additional arguments to pass to the TrainingArguments.
+    """
+
+    beta: float = 0.1
+    gamma: float = 1.0
+    label_smoothing: float = 0.0
+    loss_type: Literal["sigmoid", "hinge", "ipo"] = "sigmoid"
+    model_init_pretrained_model_name_or_path: str | None = None
+    model_init_pretrained_model_name_or_path_2: str | None = None
+    reference_free: bool = False
+    use_softmax: bool = False
+    padding_free: bool = False
+
+    def to_trainer_kwargs(self) -> dict[str, Any]:
+        """
+        Convert the SDPO config to trainer kwargs.
+        """
+        return {
+            "beta": self.beta,
+            "gamma": self.gamma,
+            "label_smoothing": self.label_smoothing,
+            "loss_type": self.loss_type,
+            "model_init_pretrained_model_name_or_path": self.model_init_pretrained_model_name_or_path,
+            "model_init_pretrained_model_name_or_path_2": self.model_init_pretrained_model_name_or_path_2,
+            "reference_free": self.reference_free,
+            "use_softmax": self.use_softmax,
+        }
