+    try:
+        runner = Runner(config)
+        runner.cli()
+    except ValueError as e:
+        # Handle configuration errors (e.g., missing template files)
+        from cfnlint.rules.errors import ConfigError
+        from cfnlint.match import Match
+        config_error = ConfigError()
+        match = Match.create(str(e), None, config_error, 1, 1)
+        formatter = get_formatter(config)
+        # Create a dummy rules object for formatting
+        from cfnlint.rules import RulesCollection
+        rules = RulesCollection([config_error])
+        output = formatter.print_matches([match], rules, config=config)
+        if output:
+            print(output)
+        sys.exit(2)
 
 
