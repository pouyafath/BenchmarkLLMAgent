+"""
+Utility functions for handling PyTorch-related operations.
+"""
+
+from typing import Any, Dict
+
+from haystack.lazy_imports import LazyImport
+
+with LazyImport(message="Run 'pip install transformers[torch]'") as torch_import:
+    import torch
+
+
+def serialize_torch_dtype(value: Any) -> Any:
+    """
+    Convert torch.dtype objects to strings for serialization.
+
+    This function recursively processes dictionaries and lists to convert
+    torch.dtype objects to their string representations (e.g., torch.float16 -> "float16").
+
+    :param value: The value to serialize. Can be a torch.dtype, dict, list, or other type.
+    :return: The serialized value with torch.dtype objects converted to strings.
+    """
+    if isinstance(value, torch.dtype):
+        # Convert torch.dtype to string (e.g., torch.float16 -> "float16")
+        return str(value).split('.')[-1]
+    elif isinstance(value, dict):
+        # Recursively process dictionaries
+        return {k: serialize_torch_dtype(v) for k, v in value.items()}
+    elif isinstance(value, list):
+        # Recursively process lists
+        return [serialize_torch_dtype(item) for item in value]
+    else:
+        # Return other types as-is
+        return value
+
+
+def deserialize_torch_dtype(value: Any) -> Any:
+    """
+    Convert string representations of torch.dtype back to torch.dtype objects.
+
+    This function recursively processes dictionaries and lists to convert
+    string representations of torch.dtype back to actual torch.dtype objects.
+
+    :param value: The value to deserialize. Can be a string, dict, list, or other type.
+    :return: The deserialized value with string representations converted to torch.dtype objects.
+    """
+    if isinstance(value, str):
+        # Check if this is a torch dtype string (e.g., "float16")
+        try:
+            return getattr(torch, value)
+        except AttributeError:
+            # Not a torch dtype, return as-is
+            return value
+    elif isinstance(value, dict):
+        # Recursively process dictionaries
+        return {k: deserialize_torch_dtype(v) for k, v in value.items()}
+    elif isinstance(value, list):
+        # Recursively process lists
+        return [deserialize_torch_dtype(item) for item in value]
+    else:
+        # Return other types as-is
+        return value
+
+
+def serialize_model_kwargs(model_kwargs: Dict[str, Any]) -> Dict[str, Any]:
+    """
+    Serialize model_kwargs by converting torch.dtype objects to strings.
+
+    This is useful for YAML serialization where torch.dtype objects cannot be directly serialized.
+
+    :param model_kwargs: Dictionary of model kwargs that may contain torch.dtype objects.
+    :return: Dictionary with torch.dtype objects converted to strings.
+    """
+    return serialize_torch_dtype(model_kwargs)
+
+
+def deserialize_model_kwargs(model_kwargs: Dict[str, Any]) -> Dict[str, Any]:
+    """
+    Deserialize model_kwargs by converting string representations of torch.dtype back to torch.dtype objects.
+
+    :param model_kwargs: Dictionary of model kwargs that may contain string representations of torch.dtype.
+    :return: Dictionary with string representations converted to torch.dtype objects.
+    """
+    return deserialize_torch_dtype(model_kwargs)
