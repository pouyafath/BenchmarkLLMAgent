n\n\u4e3b\u7a0b\u5e8f\u8fd0\u884c\u95ee\u9898\n\n### \u95ee\u9898\u63cf\u8ff0\n\n\u8fd9\u4e2a\u9519\u8bef\u662f\u5728\u66f4\u65b0\u5230\u6700\u65b0\u76842.6.4\u540e\u7b2c\u4e00\u6b21\u53d1\u751f\uff0c\u4ee5\u524d\u4ece\u672a\u53d1\u751f\uff0c\u6211\u4e00\u76f4\u4fdd\u6301\u6211\u7684\u8bbe\u5b9a\u6ca1\u6709\u53d8\u52a8\u8fc7\u3002ps\u6211\u540c\u6837\u5b58\u5728\u4e0b\u62c9\u65e0\u6cd5\u62c9\u52a8\u9700\u8981\u5237\u65b0\u9875\u9762\u7684\u9519\u8bef\u3002\n## \u95ee\u9898\u8fc7\u7a0b\uff1a\n\u4e0b\u5348\u516d\u70b9\u65f6\uff0c\u914d\u7f6e\u597d\u7684/media/downloads/strm\u522e\u524a\u65b0\u589e\u4e86\u4e00\u6761 \u5938\u514b\u7f51\u76d8\u7684strm\uff0c\u7ed3\u679c\u4e0d\u77e5\u4e3a\u4f55\u542f\u52a8\u4e86\u5bf9/media\u4e0b\u5168\u90e8\u6587\u4ef6\u7684\u8bc6\u522b\u3002/media\u4e0b\u65b9\u6ca1\u6709\u914d\u7f6e\u76ee\u5f55\u76d1\u63a7\u7684\u6f2b\u753b\u6587\u4ef6\u5939\u540c\u6837\u88ab\u9519\u8bef\u522e\u524a\u3002/media\u4e0b\u65b9\u7684series\uff0cmovie\u7b49\u7b49\u6bcf\u4e2a\u53ef\u4ee5\u88ab\u8bc6\u522b\u7684\u6587\u4ef6\u5939\u4e0b\u65b9\u90fd\u88ab\u6dfb\u52a0\u4e86\u540c\u6837\u7684\u4e00\u4efd\u9009\u5e1d\u4faf\u5927\u8857\u7684tvshow.nfo\u4ee5\u53caposter.jpg\u3002\u4f46\u662f\u4e0d\u80fd\u88ab\u8bc6\u522b\u4e3a\u89c6\u9891\u7684\u6587\u4ef6\u5939\u6ca1\u6709\u88ab\u6dfb\u52a0\u3002\n## \u95ee\u9898\u68c0\u67e5\n\u68c0\u67e5\u65e5\u5fd7\u540e\u53d1\u73b0\uff0c\u7a81\u7136\u542f\u52a8\u4e86/ / \u76ee\u5f55\u4e0b\u7684\u589e\u91cf\u522e\u524a\u3002\u5e76\u4e14\u522e\u524a\u5b58\u5728\u5927\u91cf\u7684\u9519\u8beftmdb\u7f13\u5b58\u8bc6\u522b\u3002\n## \u65e5\u5fd7\u63d0\u793a\n\u5177\u4f53\u95ee\u9898\u5728\u4e0b\u9762\u7684\uff1a**\u76ee\u5f55 // \u5df2\u6709NFO\u6587\u4ef6\uff0c\u5f00\u59cb\u589e\u91cf\u522e\u524a...**\u542f\u52a8\uff0c\u671f\u95f4\u6211\u6ca1\u6709\u542f\u52a8\u4efb\u4f55\u63d2\u4ef6\u6216\u8005\u662f\u6309\u94ae\u3002\u542f\u52a8\u4ee5\u540e\uff0c\u5f00\u59cb\u9519\u8bef\u7684tmdb\u8bc6\u522b\u7f13\u5b58\u3002\u5177\u4f53\u65e5\u5fd7\u4e3a**themoviedb - \u8c1c\u63a2\u8def\u5fb7\u7ef4\u5e0c \u4f7f\u7528TMDB\u8bc6\u522b\u7f13\u5b58\uff1a\u7f8e\u4e3d\u7684\u4ed6**\uff0c\u7136\u540e\u5c31\u662f\u627e\u4e0d\u5230\u67d0\u4e2a\u6587\u4ef6\u5939\u76ee\u5f55\u7684\u9519\u8bef\u63d0\u793a\u3002\u63a5\u4e0b\u6765\u5c31\u662f\u5168\u90e8\u76ee\u5f55\u88ab\u9519\u8bef\u8bc6\u522b\u522e\u524a\u7684\u8bb0\u5f55\uff0c\u4e0a\u5343\u6761\u5f71\u89c6\u5747\u88ab\u8bc6\u522b\u4e3a\u9009\u5e1d\u4faf\u5927\u8857\u7684\u9519\u8bef\u522e\u524a\u3002\u8fd9\u91cc\u4ec5\u590d\u5236\u51e0\u4e2a\u3002\n\u5168\u90e8\u65e5\u5fd7\u5df2\u4e0a\u4f20\u3002\n\u5982\u679c\u662f\u6211\u4e2a\u4eba\u7684\u914d\u7f6e\u9519\u8bef\uff0c\u90a3\u6211\u5bf9\u803d\u8bef\u60a8\u7684\u65f6\u95f4\u8868\u793a\u9053\u6b49\u3002\n\u6211\u7684docker cli \ndocker run -itd \\\n    --name moviepilot-v2 \\\n    --hostname moviepilot-v2 \\\n    --memory=\"2g\" \\\n    --cpus=\"2.0\" \\\n    -p 3333:3000 \\\n    -p 3221:3003 \\\n    -v /mnt/user/Public/media:/media \\\n    -v /mnt/user/appdata/qb:/qb \\\n    -v /mnt/user/appdata/moviepilotV2/config:/config \\\n    -v /mnt/user/appdata/moviepilotV2/core:/moviepilot/.cache/ms-playwright \\\n    -v /var/run/docker.sock:/var/run/docker.sock:ro \\\n    -e 'PROXY_HOST=http://xxxxxx' \\\n    -e 'NGINX_PORT=3000' \\\n    -e 'PORT=3003' \\\n    -e 'PUID=0' \\\n    -e 'PGID=0' \\\n    -e 'UMASK=000' \\\n    -e 'TZ=Asia/Shanghai' \\\n    -e 'SUPERUSER=admin' \\\n    -e 'API_TOKEN=xxxxxx' \\\n    --label='net.unraid.docker.icon=http://192.168.50.45:50560/icons/HD-Icons/border-radius/Moviepilot_B.png' \\\n    --restart unless-stopped \\\n    jxxghp/moviepilot-v2:latest\n\n[moviepilot.log](https://github.com/user-attachments/files/21184043/moviepilot.log)\n\u53e6\u5916\u6709\u4e00\u4e2a\u7b2c\u4e00\u6b21\u770b\u5230\u7684warning\uff0c\u4e0d\u77e5\u9053\u662f\u5426\u76f8\u5173\uff1a\n\n<img width=\"884\" height=\"210\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/e9bf6f56-551c-48a6-b1cb-af43ca495ca2\" 