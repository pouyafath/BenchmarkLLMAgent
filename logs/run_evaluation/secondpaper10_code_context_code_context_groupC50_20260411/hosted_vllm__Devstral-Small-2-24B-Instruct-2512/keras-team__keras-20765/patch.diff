+
+    def test_with_mask_zero(self):
+        """Test TimeDistributed with mask_zero=True in Embedding layer.
+
+        This test verifies that TimeDistributed works correctly when used
+        with an Embedding layer that has mask_zero=True. The issue was that
+        when mask is a symbolic tensor, using it in a boolean context would
+        cause an OperatorNotAllowedInGraphError.
+        """
+        # Create dummy data
+        vocab_len = 100
+        tags_len = 10
+        batch_size = 32
+        seq_len = 20
+        embedding_dim = 50
+
+        # Create embedding matrix
+        embedding_matrix = np.random.randn(vocab_len, embedding_dim).astype("float32")
+
+        # Create model with mask_zero=True
+        model = models.Sequential([
+            layers.Input(shape=(seq_len,)),
+            layers.Embedding(
+                weights=[embedding_matrix],
+                input_dim=vocab_len,
+                output_dim=embedding_dim,
+                mask_zero=True
+            ),
+            layers.Bidirectional(layers.LSTM(units=50, return_sequences=True)),
+            layers.TimeDistributed(layers.Dense(units=tags_len, activation="softmax"))
+        ])
+
+        # Create test data with some zeros (padding)
+        X_test = np.random.randint(0, vocab_len, size=(batch_size, seq_len))
+        X_test[:, 0] = 0  # Set first position to 0 (padding)
+        Y_test = np.random.randint(0, tags_len, size=(batch_size, seq_len))
+
+        # Test with @tf.function to trigger graph mode where the issue occurs
+        @tf.function
+        def test_step(x, y):
+            with tf.GradientTape() as tape:
+                preds = model(x, training=True)
+                loss = tf.keras.losses.sparse_categorical_crossentropy(y, preds)
+                loss = tf.reduce_mean(loss)
+            grads = tape.gradient(loss, model.trainable_variables)
+            return loss
+
+        # This should not raise an OperatorNotAllowedInGraphError
+        loss = test_step(X_test, Y_test)
+        self.assertIsNotNone(loss)
