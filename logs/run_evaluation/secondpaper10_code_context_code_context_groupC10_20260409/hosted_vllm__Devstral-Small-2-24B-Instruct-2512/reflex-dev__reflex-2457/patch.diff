         assert getattr(c, key) == value
+
+@pytest.mark.parametrize(
+    "env_var_value, expected_dir",
+    [
+        ("/custom/reflex/path", "/custom/reflex/path"),
+        ("/another/custom/path", "/another/custom/path"),
+    ],
+)
+def test_reflex_dir_env_var(monkeypatch, env_var_value, expected_dir):
+    """Test that the REFLEX_DIR environment variable overrides the default directory.
+
+    Args:
+        monkeypatch: The pytest monkeypatch object.
+        env_var_value: The value to set for REFLEX_DIR.
+        expected_dir: The expected directory value.
+    """
+    # Store original value if it exists
+    original_value = os.environ.get("REFLEX_DIR")
+    try:
+        # Set the environment variable
+        monkeypatch.setenv("REFLEX_DIR", env_var_value)
+
+        # Import after setting the environment variable
+        from reflex.constants.base import Reflex
+
+        # Check that the DIR is set to the environment variable value
+        assert Reflex.DIR == expected_dir
+    finally:
+        # Restore original value if it existed
+        if original_value is not None:
+            monkeypatch.setenv("REFLEX_DIR", original_value)
+        elif "REFLEX_DIR" in os.environ:
+            monkeypatch.delenv("REFLEX_DIR")
+
+def test_reflex_dir_default():
+    """Test that Reflex.DIR uses the default PlatformDirs value when REFLEX_DIR is not set."""
+    from reflex.constants.base import Reflex
+    from platformdirs import PlatformDirs
+
+    # Make sure REFLEX_DIR is not set
+    import os
+    original_value = os.environ.get("REFLEX_DIR")
+    try:
+        if original_value:
+            del os.environ["REFLEX_DIR"]
+
+        expected_default = PlatformDirs("reflex", False).user_data_dir
+        assert Reflex.DIR == expected_default
+    finally:
+        if original_value is not None:
+            os.environ["REFLEX_DIR"] = original_value
