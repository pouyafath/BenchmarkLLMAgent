{"repo": "blueman-project/blueman", "pull_number": 2766, "instance_id": "blueman-project__blueman-2766", "issue_numbers": [2761], "base_commit": "829caadbb73db0d9520b39e4e2b49516fdae8229", "patch": "diff --git a/blueman/bluez/errors.py b/blueman/bluez/errors.py\nindex dfe3200a1..dbcea6dd8 100644\n--- a/blueman/bluez/errors.py\n+++ b/blueman/bluez/errors.py\n@@ -130,8 +130,6 @@ class BluezUnavailableAgentMethodError(BluezDBusException):\n \n \n def parse_dbus_error(exception: GLib.Error) -> BluezDBusException:\n-    global __DICT_ERROR__\n-\n     gerror, dbus_error, message = exception.message.split(':', 2)\n     try:\n         return __DICT_ERROR__[dbus_error](message)\ndiff --git a/blueman/plugins/applet/KillSwitch.py b/blueman/plugins/applet/KillSwitch.py\nindex 5446fac98..7508ba061 100644\n--- a/blueman/plugins/applet/KillSwitch.py\n+++ b/blueman/plugins/applet/KillSwitch.py\n@@ -2,6 +2,7 @@\n import os\n from typing import Any\n from collections.abc import Callable\n+from enum import IntEnum\n \n from gi.repository import GLib, Gio\n import struct\n@@ -13,16 +14,14 @@\n from blueman.plugins.applet.StatusIcon import StatusIconVisibilityHandler\n \n RFKILL_TYPE_BLUETOOTH = 2\n-\n-RFKILL_OP_ADD = 0\n-RFKILL_OP_DEL = 1\n-RFKILL_OP_CHANGE = 2\n-RFKILL_OP_CHANGE_ALL = 3\n-\n RFKILL_EVENT_SIZE_V1 = 8\n \n-if not os.path.exists('/dev/rfkill'):\n-    raise ImportError('Hardware kill switch not found')\n+\n+class RFKillOp(IntEnum):\n+    ADD = 0\n+    DEL = 1\n+    CHANGE = 2\n+    CHANGE_ALL = 3\n \n \n class Switch:\n@@ -50,28 +49,50 @@ class KillSwitch(AppletPlugin, PowerStateHandler, StatusIconVisibilityHandler):\n     }\n \n     _switches: dict[int, Switch] = {}\n-    _iom = None\n-    _enabled = True\n-    _hardblocked = False\n+    _iom: int | None = None\n+    _monitor: Gio.FileMonitor | None\n+    _rfkill: Gio.File | None\n+    _enabled: bool = True\n+    _hardblocked: bool = False\n \n     def on_load(self) -> None:\n+        self._rfkill = Gio.File.new_for_path(\"/dev/rfkill\")\n+        start_event = Gio.FileMonitorEvent.CREATED if self._rfkill.query_exists() else Gio.FileMonitorEvent.DELETED\n+\n+        self._monitor = self._rfkill.monitor(Gio.FileMonitorFlags.NONE, None)\n+        self._monitor.connect(\"changed\", self.__on_file_changed)\n+        self.__on_file_changed(self._monitor, self._rfkill, None, start_event)\n+\n         self._connman_proxy: Gio.DBusProxy | None = None\n         self._connman_watch_id = Gio.bus_watch_name(Gio.BusType.SYSTEM, \"net.connman\", Gio.BusNameWatcherFlags.NONE,\n                                                     self._on_connman_appeared, self._on_connman_vanished)\n \n-        channel = GLib.IOChannel.new_file(\"/dev/rfkill\", \"r\")\n-        if channel is None:\n-            raise ImportError('Could not access RF kill switch')\n-\n-        self._iom = GLib.io_add_watch(channel, GLib.IO_IN | GLib.IO_ERR | GLib.IO_HUP, self.io_event)\n-\n     def on_unload(self) -> None:\n         Gio.bus_unwatch_name(self._connman_watch_id)\n         self._connman_proxy = None\n+        self._monitor = None\n+        self._rfkill = None\n+\n         if self._iom:\n             GLib.source_remove(self._iom)\n+            self._iom = None\n \n-    def _on_connman_appeared(self, connection: Gio.DBusConnection, name: str, owner: str) -> None:\n+    def __on_file_changed(self, _monitor: Gio.FileMonitor, _gfile: Gio.File, _other: Gio.File | None,\n+                          _event: Gio.FileMonitorEvent) -> None:\n+        if self._iom:\n+            GLib.source_remove(self._iom)\n+            self._iom = None\n+\n+        try:\n+            channel = GLib.IOChannel.new_file(\"/dev/rfkill\", \"r\")\n+            self._iom = GLib.io_add_watch(channel, GLib.IO_IN | GLib.IO_ERR | GLib.IO_HUP, self.io_event)\n+        except GLib.Error as e:\n+            logging.debug(f\"Could not open rfkill device: {e.message}\")\n+            # At this point we have no idea if there even is a working killswitch\n+            self._enabled = False\n+            self._hardblocked = False\n+\n+    def _on_connman_appeared(self, _connection: Gio.DBusConnection, name: str, _owner: str) -> None:\n         logging.info(f\"{name} appeared\")\n         self._connman_proxy = Gio.DBusProxy.new_for_bus_sync(\n             Gio.BusType.SYSTEM,\n@@ -82,7 +103,7 @@ def _on_connman_appeared(self, connection: Gio.DBusConnection, name: str, owner:\n             'net.connman.Technology',\n             None)\n \n-    def _on_connman_vanished(self, connection: Gio.DBusConnection, name: str) -> None:\n+    def _on_connman_vanished(self, _connection: Gio.DBusConnection, name: str) -> None:\n         logging.info(f\"{name} vanished\")\n         self._connman_proxy = None\n \n@@ -102,17 +123,18 @@ def io_event(self, channel: GLib.IOChannel, condition: GLib.IOCondition) -> bool\n         if switch_type != RFKILL_TYPE_BLUETOOTH:\n             return True\n \n-        if op == RFKILL_OP_ADD:\n-            self._switches[idx] = Switch(idx, switch_type, soft, hard)\n-            logging.info(f\"killswitch registered {idx}\")\n-        elif op == RFKILL_OP_DEL:\n-            del self._switches[idx]\n-            logging.info(f\"killswitch removed {idx}\")\n-        elif op == RFKILL_OP_CHANGE and (self._switches[idx].soft != soft or self._switches[idx].hard != hard):\n-            self._switches[idx] = Switch(idx, switch_type, soft, hard)\n-            logging.info(f\"killswitch changed {idx}\")\n-        else:\n-            return True\n+        match RFKillOp(op):\n+            case RFKillOp.ADD:\n+                self._switches[idx] = Switch(idx, switch_type, soft, hard)\n+                logging.info(f\"killswitch registered {idx}\")\n+            case RFKillOp.DEL:\n+                del self._switches[idx]\n+                logging.info(f\"killswitch removed {idx}\")\n+            case RFKillOp.CHANGE:\n+                self._switches[idx] = Switch(idx, switch_type, soft, hard)\n+                logging.info(f\"killswitch changed {idx}\")\n+            case _:\n+                return True\n \n         self._enabled = True\n         self._hardblocked = False\ndiff --git a/blueman/plugins/mechanism/RfKill.py b/blueman/plugins/mechanism/RfKill.py\nindex 82098560e..0223076d9 100644\n--- a/blueman/plugins/mechanism/RfKill.py\n+++ b/blueman/plugins/mechanism/RfKill.py\n@@ -1,7 +1,7 @@\n import os\n import struct\n from blueman.plugins.MechanismPlugin import MechanismPlugin\n-from blueman.plugins.applet.KillSwitch import RFKILL_TYPE_BLUETOOTH, RFKILL_OP_CHANGE_ALL\n+from blueman.plugins.applet.KillSwitch import RFKILL_TYPE_BLUETOOTH, RFKillOp\n \n if not os.path.exists('/dev/rfkill'):\n     raise ImportError(\"Hardware kill switch not found\")\n@@ -14,4 +14,4 @@ def on_load(self) -> None:\n     def _set_rfkill_state(self, state: bool, caller: str) -> None:\n         self.confirm_authorization(caller, \"org.blueman.rfkill.setstate\")\n         with open('/dev/rfkill', 'r+b', buffering=0) as f:\n-            f.write(struct.pack(\"IBBBB\", 0, RFKILL_TYPE_BLUETOOTH, RFKILL_OP_CHANGE_ALL, (0 if state else 1), 0))\n+            f.write(struct.pack(\"IBBBB\", 0, RFKILL_TYPE_BLUETOOTH, RFKillOp.CHANGE_ALL, (0 if state else 1), 0))\n", "test_patch": "", "problem_statement": "blueman-applet crashes if rfkill module is not loaded\nWhen `rfkill` module is not loaded, the `/dev/rfkill` device file is present (at least on Fedora), but udev doesn't adjust its permissions for the user:\n```\ncrw-------. 1 root root 10, 242 Jun  7 19:28 /dev/rfkill\n```\n\nThis makes blueman-applet crash on startup:\n```\nblueman-applet 09.35.15 WARNING  PluginManager:153 __load_plugin: Not loading PPPSupport because its conflict has higher priority\nblueman-applet 09.35.15 WARNING  PluginManager:153 __load_plugin: Not loading DhcpClient because its conflict has higher priority\nblueman-applet 09.35.15 ERROR    BasePlugin:83 _load     : g-file-error-quark: Permission denied (2)\nTraceback (most recent call last):\n  File \"/usr/lib/python3.13/site-packages/blueman/plugins/BasePlugin.py\", line 77, in _load\n    self.on_load()\n    ~~~~~~~~~~~~^^\n  File \"/usr/lib/python3.13/site-packages/blueman/plugins/applet/KillSwitch.py\", line 61, in on_load\n    channel = GLib.IOChannel.new_file(\"/dev/rfkill\", \"r\")\ngi.repository.GLib.GError: g-file-error-quark: Permission denied (2)\nblueman-applet 09.35.15 ERROR    PluginManager:167 __load_plugin: Failed to load KillSwitch\nTraceback (most recent call last):\n  File \"/usr/lib/python3.13/site-packages/blueman/main/PluginManager.py\", line 165, in __load_plugin\n    inst._load()\n    ~~~~~~~~~~^^\n  File \"/usr/lib/python3.13/site-packages/blueman/plugins/AppletPlugin.py\", line 51, in _load\n    super()._load()\n    ~~~~~~~~~~~~~^^\n  File \"/usr/lib/python3.13/site-packages/blueman/plugins/BasePlugin.py\", line 77, in _load\n    self.on_load()\n    ~~~~~~~~~~~~^^\n  File \"/usr/lib/python3.13/site-packages/blueman/plugins/applet/KillSwitch.py\", line 61, in on_load\n    channel = GLib.IOChannel.new_file(\"/dev/rfkill\", \"r\")\ngi.repository.GLib.GError: g-file-error-quark: Permission denied (2)\nTraceback (most recent call last):\n  File \"/usr/bin/blueman-applet\", line 39, in <module>\n    app = BluemanApplet()\n  File \"/usr/lib/python3.13/site-packages/blueman/main/Applet.py\", line 53, in __init__\n    self.Plugins.load_plugin()\n    ~~~~~~~~~~~~~~~~~~~~~~~~^^\n  File \"/usr/lib/python3.13/site-packages/blueman/main/PluginManager.py\", line 125, in load_plugin\n    self.__load_plugin(cls)\n    ~~~~~~~~~~~~~~~~~~^^^^^\n  File \"/usr/lib/python3.13/site-packages/blueman/main/PluginManager.py\", line 165, in __load_plugin\n    inst._load()\n    ~~~~~~~~~~^^\n  File \"/usr/lib/python3.13/site-packages/blueman/plugins/AppletPlugin.py\", line 51, in _load\n    super()._load()\n    ~~~~~~~~~~~~~^^\n  File \"/usr/lib/python3.13/site-packages/blueman/plugins/BasePlugin.py\", line 77, in _load\n    self.on_load()\n    ~~~~~~~~~~~~^^\n  File \"/usr/lib/python3.13/site-packages/blueman/plugins/applet/KillSwitch.py\", line 61, in on_load\n    channel = GLib.IOChannel.new_file(\"/dev/rfkill\", \"r\")\ngi.repository.GLib.GError: g-file-error-quark: Permission denied (2)\n```\n\nJust loading the `rfkill` module (even if no device actually has any rfkill functionality) fixes the device permissions:\n```\ncrw-rw-r--+ 1 root root 10, 242 Jun 20 17:47 /dev/rfkill\n```\n\nThe practical issue, is a crash notification on Xfce startup (since blueman-applet is started there by default). And later, no bluetooth applet when you plug the bluetooth dongle...\nThe workaround is to unconditionally load the `rfkill` kernel module, but it sounds silly if most of the time (in my case) it isn't going to be used.\n", "hints_text": "Ah, right. If you are able can you try the below change and see if gracefully handles this?\n\nThx\n\n```patch\ndiff --git a/blueman/plugins/applet/KillSwitch.py b/blueman/plugins/applet/KillSwitch.py\nindex 5446fac98..3dc9a1873 100644\n--- a/blueman/plugins/applet/KillSwitch.py\n+++ b/blueman/plugins/applet/KillSwitch.py\n@@ -59,8 +59,9 @@ class KillSwitch(AppletPlugin, PowerStateHandler, StatusIconVisibilityHandler):\n         self._connman_watch_id = Gio.bus_watch_name(Gio.BusType.SYSTEM, \"net.connman\", Gio.BusNameWatcherFlags.NONE,\n                                                     self._on_connman_appeared, self._on_connman_vanished)\n \n-        channel = GLib.IOChannel.new_file(\"/dev/rfkill\", \"r\")\n-        if channel is None:\n+        try:\n+            channel = GLib.IOChannel.new_file(\"/dev/rfkill\", \"r\")\n+        except GLib.GError:\n             raise ImportError('Could not access RF kill switch')\n \n         self._iom = GLib.io_add_watch(channel, GLib.IO_IN | GLib.IO_ERR | GLib.IO_HUP, self.io_event)\n```\n> diff --git a/blueman/plugins/applet/KillSwitch.py b/blueman/plugins/applet/KillSwitch.py\n> index 5446fac98..3dc9a1873 100644\n> --- a/blueman/plugins/applet/KillSwitch.py\n> +++ b/blueman/plugins/applet/KillSwitch.py\n> @@ -59,8 +59,9 @@ class KillSwitch(AppletPlugin, PowerStateHandler, StatusIconVisibilityHandler):\n>          self._connman_watch_id = Gio.bus_watch_name(Gio.BusType.SYSTEM, \"net.connman\", Gio.BusNameWatcherFlags.NONE,\n>                                                      self._on_connman_appeared, self._on_connman_vanished)\n>  \n> -        channel = GLib.IOChannel.new_file(\"/dev/rfkill\", \"r\")\n> -        if channel is None:\n> +        try:\n> +            channel = GLib.IOChannel.new_file(\"/dev/rfkill\", \"r\")\n> +        except GLib.GError:\n>              raise ImportError('Could not access RF kill switch')\n>  \n>          self._iom = GLib.io_add_watch(channel, GLib.IO_IN | GLib.IO_ERR | GLib.IO_HUP, self.io_event)\n\nThis version does not prevent the crash - ImportError in this place seems to be not handled. But the earlier version of the patch (that added `or not os.access(...)`) did prevent the crash.\nThat said, I think none of those would allow handling rfkill if that module is later plugged in (for example if the bluetooth dongle is connected later).\n\nYeah, doing this properly is a bit more involved. Thanks for the testing and report \ud83d\udc4d .\n\n", "all_hints_text": "Ah, right. If you are able can you try the below change and see if gracefully handles this?\n\nThx\n\n```patch\ndiff --git a/blueman/plugins/applet/KillSwitch.py b/blueman/plugins/applet/KillSwitch.py\nindex 5446fac98..3dc9a1873 100644\n--- a/blueman/plugins/applet/KillSwitch.py\n+++ b/blueman/plugins/applet/KillSwitch.py\n@@ -59,8 +59,9 @@ class KillSwitch(AppletPlugin, PowerStateHandler, StatusIconVisibilityHandler):\n         self._connman_watch_id = Gio.bus_watch_name(Gio.BusType.SYSTEM, \"net.connman\", Gio.BusNameWatcherFlags.NONE,\n                                                     self._on_connman_appeared, self._on_connman_vanished)\n \n-        channel = GLib.IOChannel.new_file(\"/dev/rfkill\", \"r\")\n-        if channel is None:\n+        try:\n+            channel = GLib.IOChannel.new_file(\"/dev/rfkill\", \"r\")\n+        except GLib.GError:\n             raise ImportError('Could not access RF kill switch')\n \n         self._iom = GLib.io_add_watch(channel, GLib.IO_IN | GLib.IO_ERR | GLib.IO_HUP, self.io_event)\n```\n> diff --git a/blueman/plugins/applet/KillSwitch.py b/blueman/plugins/applet/KillSwitch.py\n> index 5446fac98..3dc9a1873 100644\n> --- a/blueman/plugins/applet/KillSwitch.py\n> +++ b/blueman/plugins/applet/KillSwitch.py\n> @@ -59,8 +59,9 @@ class KillSwitch(AppletPlugin, PowerStateHandler, StatusIconVisibilityHandler):\n>          self._connman_watch_id = Gio.bus_watch_name(Gio.BusType.SYSTEM, \"net.connman\", Gio.BusNameWatcherFlags.NONE,\n>                                                      self._on_connman_appeared, self._on_connman_vanished)\n>  \n> -        channel = GLib.IOChannel.new_file(\"/dev/rfkill\", \"r\")\n> -        if channel is None:\n> +        try:\n> +            channel = GLib.IOChannel.new_file(\"/dev/rfkill\", \"r\")\n> +        except GLib.GError:\n>              raise ImportError('Could not access RF kill switch')\n>  \n>          self._iom = GLib.io_add_watch(channel, GLib.IO_IN | GLib.IO_ERR | GLib.IO_HUP, self.io_event)\n\nThis version does not prevent the crash - ImportError in this place seems to be not handled. But the earlier version of the patch (that added `or not os.access(...)`) did prevent the crash.\nThat said, I think none of those would allow handling rfkill if that module is later plugged in (for example if the bluetooth dongle is connected later).\n\nYeah, doing this properly is a bit more involved. Thanks for the testing and report \ud83d\udc4d .\n\n", "commit_urls": ["https://github.com/blueman-project/blueman/commit/9559166687d71a27cb540f2b33c60488b64e0642", "https://github.com/blueman-project/blueman/commit/bbc7a387a9de9a704f1ae44b9a14decb1f10db19", "https://github.com/blueman-project/blueman/commit/a6de6b9789066d36e1207a2d2ce2238ca9c3a1d8", "https://github.com/blueman-project/blueman/commit/3b56206e0e004b8305b67df96e20a89f07ac19da"], "created_at": "2025-06-21T11:43:31Z"}
{"repo": "blueman-project/blueman", "pull_number": 2779, "instance_id": "blueman-project__blueman-2779", "issue_numbers": [2765], "base_commit": "0c9b506ddad42b97466077408d7e01a918b0e783", "patch": "diff --git a/blueman/main/indicators/StatusNotifierItem.py b/blueman/main/indicators/StatusNotifierItem.py\nindex 77c56a2ea..a78c7f05a 100644\n--- a/blueman/main/indicators/StatusNotifierItem.py\n+++ b/blueman/main/indicators/StatusNotifierItem.py\n@@ -155,7 +155,7 @@ def on_watcher_appeared(*args: Any) -> None:\n                 None, Gio.DBusCallFlags.NONE, -1)\n             watcher_expected = True\n         except GLib.Error as e:\n-            watcher_expected = not e.message.startswith(\"org.freedesktop.DBusError.ServiceUnknown\")\n+            watcher_expected = not e.message.startswith(\"GDBus.Error:org.freedesktop.DBusError.ServiceUnknown\")\n             raise IndicatorNotAvailable\n \n     def set_icon(self, icon_name: str) -> None:\n", "test_patch": "", "problem_statement": "Tray icon fails to appear on session start\nDebian sid, Hyprland, waybar, blueman-applet 2.4.4\nWhen XDG autostart entry starts as `app-blueman@autostart.service` service at session start, icon does not appear. Service logs warning:\n```\nblueman-tray[2831475]: gtk_widget_get_scale_factor: assertion 'GTK_IS_WIDGET (widget)' failed\n```\nBut continues running. Icon only appears after restarting service. Perhaps it does not wait for tray to become available and just gives up on showing icon.\n", "hints_text": "Also see #2282\n\nI assume that you're not affected by https://github.com/Alexays/Waybar/issues/3597, as that's only in Debian's 0.11.0-1, but 0.11.0-2, 0.11.0-3, and 0.12.0-1 are all fine.\n\nWhat should happen if waybar is not available early enough:\n\n`blueman-tray` detects that no `org.kde.StatusNotifierWatcher` is available. It keeps watching for one, but falls back to the `GtkStatusIcon` for now. The `GtkStatusIcon` cannot work on pure Wayland, so nothing shows up, but I would not expect it to crash `blueman-tray`. When `org.kde.StatusNotifierWatcher` shows up, `blueman-tray` will restart and register the `StatusNotifierItem`. You should thus see a new `blueman-tray` process (new PID), e.g., after starting waybar.\nThere seem to be a race condition during startup, I couldn't reproduce the problem for a couple of attempts, so I started `waybar.service` and `app-blueman@autostart.service` manually 0.5 seconds apart. `blueman-tray` does not attempt to use `org.kde.StatusNotifierWatcher` after `GtkStatusIcon` fails.\n\n```\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:86 load_plugin: ['AuthAgent', 'AutoConnect', 'ConnectionNotifier', 'DBusService', 'DhcpClient', 'DisconnectItems', 'DiscvManager', 'ExitItem', 'GameControllerWakelock', 'KillSwitch', 'Menu', 'NMDUNSupport', 'NMPANSupport', 'NetUsage', 'Networking', 'PPPSupport', 'PowerManager', 'PulseAudioProfile', 'RecentConns', 'SerialManager', 'ShowConnected', 'StandardItems', 'StatusIcon', 'StatusNotifierItem', 'TransferService']\nblueman-applet[3980112]: blueman-applet 13.00.57 WARNING  PluginManager:93 load_plugin: Failed to start plugin GameControllerWakelock: Only X11 platform is supported\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.DBusService.DBusService'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.Menu.Menu'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.StandardItems.StandardItems'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.StatusIcon.StatusIcon'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.PowerManager.PowerManager'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.RecentConns.RecentConns'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.AuthAgent.AuthAgent'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.AutoConnect.AutoConnect'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.ConnectionNotifier.ConnectionNotifier'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.DhcpClient.DhcpClient'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.DisconnectItems.DisconnectItems'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.DiscvManager.DiscvManager'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.ExitItem.ExitItem'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.KillSwitch.KillSwitch'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.PPPSupport.PPPSupport'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.PulseAudioProfile.AudioProfiles'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PulseAudioUtils:207 pa_context_event: 1\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.ShowConnected.ShowConnected'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.StatusNotifierItem.StatusNotifierItem'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.TransferService.TransferService'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PulseAudioUtils:207 pa_context_event: 2\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     KillSwitch:106 io_event  : killswitch registered 1\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     KillSwitch:122 io_event  : State: False\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PowerManager:161 update_power_state: off True | foff False | on True | current state True | new state False\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PowerManager:164 update_power_state: Signalling False\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     KillSwitch:85 _on_connman_vanished: net.connman vanished\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     KillSwitch:106 io_event  : killswitch registered 43\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     KillSwitch:122 io_event  : State: False\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PowerManager:161 update_power_state: off True | foff False | on True | current state False | new state False\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     Applet:81 _on_dbus_name_appeared: org.bluez :1.13\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     Functions:99 launch    : Gtk eventtime is 0, not using LaunchContext\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     BluezAgent:56 register_agent: Register Agent\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     RecentConns:113 notify    : <Device.Device object at 0x7f004be19580 (blueman+bluez+Device+Device at 0xc988810)> 00000000-0000-0000-0000-000000000000\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     TransferService:233 _on_dbus_name_appeared: org.bluez.obex :1.43\nblueman-applet[3980112]: blueman-applet 13.00.57 DEBUG    Base:67 _properties_changed: /org/bluez/hci0 {'Pairable': True} [] <Adapter.Adapter object at 0x7f004be33fc0 (blueman+bluez+Adapter+Adapter at 0xcb3e960)>\nblueman-applet[3980112]: blueman-applet 13.00.57 DEBUG    DiscvManager:95 on_adapter_property_changed: prop Pairable True\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     ShowConnected:55 enumerate_connections: Found 0 existing connections\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PulseAudioUtils:207 pa_context_event: 3\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     AgentManager:17 on_registered: /org/bluez/obex/agent/blueman\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PulseAudioUtils:207 pa_context_event: 4\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PulseAudioProfile:135 on_pa_ready: PulseAudio Ready\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PulseAudioUtils:213 <lambda>  : 1\nblueman-tray[3980206]: gtk_widget_get_scale_factor: assertion 'GTK_IS_WIDGET (widget)' failed\n```\nIt looks like the logic is broken. I'm puzzled if and how #2334 ever worked, as the message is actually prefixed with `GDBus.Error:`.\n\nCan you try the following change?\n\n```diff\n--- a/blueman/main/indicators/StatusNotifierItem.py\n+++ b/blueman/main/indicators/StatusNotifierItem.py\n@@ -155,7 +155,7 @@ class StatusNotifierItem(IndicatorInterface):\n                 None, Gio.DBusCallFlags.NONE, -1)\n             watcher_expected = True\n         except GLib.Error as e:\n-            watcher_expected = not e.message.startswith(\"org.freedesktop.DBusError.ServiceUnknown\")\n+            watcher_expected = not e.message.startswith(\"GDBus.Error:org.freedesktop.DBusError.ServiceUnknown\")\n             raise IndicatorNotAvailable\n \n     def set_icon(self, icon_name: str) -> None:\n```\n\nYou can just do that manually in the installed file.\nIt's `GDBus.Error:org.freedesktop.DBus.Error.ServiceUnknown` (a dot between `DBus` and `Error`). Yes, it fixes the problem.\n\n", "all_hints_text": "Also see #2282\n\nI assume that you're not affected by https://github.com/Alexays/Waybar/issues/3597, as that's only in Debian's 0.11.0-1, but 0.11.0-2, 0.11.0-3, and 0.12.0-1 are all fine.\n\nWhat should happen if waybar is not available early enough:\n\n`blueman-tray` detects that no `org.kde.StatusNotifierWatcher` is available. It keeps watching for one, but falls back to the `GtkStatusIcon` for now. The `GtkStatusIcon` cannot work on pure Wayland, so nothing shows up, but I would not expect it to crash `blueman-tray`. When `org.kde.StatusNotifierWatcher` shows up, `blueman-tray` will restart and register the `StatusNotifierItem`. You should thus see a new `blueman-tray` process (new PID), e.g., after starting waybar.\nThere seem to be a race condition during startup, I couldn't reproduce the problem for a couple of attempts, so I started `waybar.service` and `app-blueman@autostart.service` manually 0.5 seconds apart. `blueman-tray` does not attempt to use `org.kde.StatusNotifierWatcher` after `GtkStatusIcon` fails.\n\n```\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:86 load_plugin: ['AuthAgent', 'AutoConnect', 'ConnectionNotifier', 'DBusService', 'DhcpClient', 'DisconnectItems', 'DiscvManager', 'ExitItem', 'GameControllerWakelock', 'KillSwitch', 'Menu', 'NMDUNSupport', 'NMPANSupport', 'NetUsage', 'Networking', 'PPPSupport', 'PowerManager', 'PulseAudioProfile', 'RecentConns', 'SerialManager', 'ShowConnected', 'StandardItems', 'StatusIcon', 'StatusNotifierItem', 'TransferService']\nblueman-applet[3980112]: blueman-applet 13.00.57 WARNING  PluginManager:93 load_plugin: Failed to start plugin GameControllerWakelock: Only X11 platform is supported\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.DBusService.DBusService'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.Menu.Menu'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.StandardItems.StandardItems'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.StatusIcon.StatusIcon'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.PowerManager.PowerManager'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.RecentConns.RecentConns'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.AuthAgent.AuthAgent'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.AutoConnect.AutoConnect'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.ConnectionNotifier.ConnectionNotifier'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.DhcpClient.DhcpClient'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.DisconnectItems.DisconnectItems'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.DiscvManager.DiscvManager'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.ExitItem.ExitItem'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.KillSwitch.KillSwitch'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.PPPSupport.PPPSupport'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.PulseAudioProfile.AudioProfiles'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PulseAudioUtils:207 pa_context_event: 1\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.ShowConnected.ShowConnected'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.StatusNotifierItem.StatusNotifierItem'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PluginManager:162 __load_plugin: loading <class 'blueman.plugins.applet.TransferService.TransferService'>\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PulseAudioUtils:207 pa_context_event: 2\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     KillSwitch:106 io_event  : killswitch registered 1\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     KillSwitch:122 io_event  : State: False\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PowerManager:161 update_power_state: off True | foff False | on True | current state True | new state False\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PowerManager:164 update_power_state: Signalling False\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     KillSwitch:85 _on_connman_vanished: net.connman vanished\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     KillSwitch:106 io_event  : killswitch registered 43\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     KillSwitch:122 io_event  : State: False\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PowerManager:161 update_power_state: off True | foff False | on True | current state False | new state False\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     Applet:81 _on_dbus_name_appeared: org.bluez :1.13\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     Functions:99 launch    : Gtk eventtime is 0, not using LaunchContext\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     BluezAgent:56 register_agent: Register Agent\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     RecentConns:113 notify    : <Device.Device object at 0x7f004be19580 (blueman+bluez+Device+Device at 0xc988810)> 00000000-0000-0000-0000-000000000000\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     TransferService:233 _on_dbus_name_appeared: org.bluez.obex :1.43\nblueman-applet[3980112]: blueman-applet 13.00.57 DEBUG    Base:67 _properties_changed: /org/bluez/hci0 {'Pairable': True} [] <Adapter.Adapter object at 0x7f004be33fc0 (blueman+bluez+Adapter+Adapter at 0xcb3e960)>\nblueman-applet[3980112]: blueman-applet 13.00.57 DEBUG    DiscvManager:95 on_adapter_property_changed: prop Pairable True\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     ShowConnected:55 enumerate_connections: Found 0 existing connections\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PulseAudioUtils:207 pa_context_event: 3\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     AgentManager:17 on_registered: /org/bluez/obex/agent/blueman\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PulseAudioUtils:207 pa_context_event: 4\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PulseAudioProfile:135 on_pa_ready: PulseAudio Ready\nblueman-applet[3980112]: blueman-applet 13.00.57 INFO     PulseAudioUtils:213 <lambda>  : 1\nblueman-tray[3980206]: gtk_widget_get_scale_factor: assertion 'GTK_IS_WIDGET (widget)' failed\n```\nIt looks like the logic is broken. I'm puzzled if and how #2334 ever worked, as the message is actually prefixed with `GDBus.Error:`.\n\nCan you try the following change?\n\n```diff\n--- a/blueman/main/indicators/StatusNotifierItem.py\n+++ b/blueman/main/indicators/StatusNotifierItem.py\n@@ -155,7 +155,7 @@ class StatusNotifierItem(IndicatorInterface):\n                 None, Gio.DBusCallFlags.NONE, -1)\n             watcher_expected = True\n         except GLib.Error as e:\n-            watcher_expected = not e.message.startswith(\"org.freedesktop.DBusError.ServiceUnknown\")\n+            watcher_expected = not e.message.startswith(\"GDBus.Error:org.freedesktop.DBusError.ServiceUnknown\")\n             raise IndicatorNotAvailable\n \n     def set_icon(self, icon_name: str) -> None:\n```\n\nYou can just do that manually in the installed file.\nIt's `GDBus.Error:org.freedesktop.DBus.Error.ServiceUnknown` (a dot between `DBus` and `Error`). Yes, it fixes the problem.\nAll commits referencing this have `GDBus.Error:org.freedesktop.DBusError.ServiceUnknown` instead of `GDBus.Error:org.freedesktop.DBus.Error.ServiceUnknown`, not fixed yet.\n\n", "commit_urls": ["https://github.com/blueman-project/blueman/commit/c4a5d056660ffb9b17ce959355766cad6dff1774"], "created_at": "2025-07-01T07:40:20Z"}
{"repo": "blueman-project/blueman", "pull_number": 2967, "instance_id": "blueman-project__blueman-2967", "issue_numbers": [2960], "base_commit": "95e49bb3e831d05f8ae3840f6558a9a0a63da221", "patch": "diff --git a/blueman/gui/manager/ManagerDeviceMenu.py b/blueman/gui/manager/ManagerDeviceMenu.py\nindex 49e875bba..7e892e866 100644\n--- a/blueman/gui/manager/ManagerDeviceMenu.py\n+++ b/blueman/gui/manager/ManagerDeviceMenu.py\n@@ -427,15 +427,16 @@ def on_response(dialog: Gtk.Dialog, response_id: int) -> None:\n         self.append(item)\n         item.show()\n \n-        item = Gtk.SeparatorMenuItem()\n-        item.show()\n-        self.append(item)\n+        if powered:\n+            item = Gtk.SeparatorMenuItem()\n+            item.show()\n+            self.append(item)\n \n-        item = create_menuitem(_(\"_Remove\u2026\"), \"list-remove-symbolic\")\n-        item.connect(\"activate\", lambda x: self.Blueman.remove(self.SelectedDevice))\n-        self.append(item)\n-        item.show()\n-        item.props.tooltip_text = _(\"Remove this device from the known devices list\")\n+            item = create_menuitem(_(\"_Remove\u2026\"), \"list-remove-symbolic\")\n+            item.connect(\"activate\", lambda x: self.Blueman.remove(self.SelectedDevice))\n+            self.append(item)\n+            item.show()\n+            item.props.tooltip_text = _(\"Remove this device from the known devices list\")\n \n     @staticmethod\n     def _create_header(text: str) -> Gtk.MenuItem:\ndiff --git a/blueman/gui/manager/ManagerToolbar.py b/blueman/gui/manager/ManagerToolbar.py\nindex 0cefc3247..c3a79ed7c 100644\n--- a/blueman/gui/manager/ManagerToolbar.py\n+++ b/blueman/gui/manager/ManagerToolbar.py\n@@ -85,7 +85,8 @@ def _update_buttons(self, adapter: Adapter | None) -> None:\n             self.b_bond.props.sensitive = powered and not row[\"paired\"]\n             self.b_bond.props.opacity = 1.0 if powered and not row[\"paired\"] else opacity\n             self.b_trust.props.sensitive = True\n-            self.b_remove.props.sensitive = True\n+            self.b_remove.props.sensitive = True if powered else False\n+            self.b_remove.props.opacity = 1.0 if powered else opacity\n             self.b_send.props.sensitive = powered and row[\"objpush\"]\n             self.b_bluetooth_status.props.sensitive = True\n             self.b_send.props.opacity = 1.0 if powered and row[\"objpush\"] else opacity\n", "test_patch": "", "problem_statement": "\u201cRemove Device\u201d button does nothing when Bluetooth adapter is soft-blocked (rfkill)\n**Description:**\nWhen the Bluetooth adapter is soft-blocked (via `rfkill`), clicking **Remove** on a paired device in Blueman Manager has no effect. No error or feedback is shown, and the device remains listed.\n\nOnce the adapter is unblocked, the same **Remove** button works as expected and the device is deleted immediately.\n\nThis suggests that the D-Bus call to remove the device fails silently when the controller is not ready, and the GUI does not surface any error or notification.\n\n**Steps to Reproduce:**\n\n1. Ensure at least one device is paired and visible in Blueman.\n2. Run:\n\n   ```bash\n   sudo rfkill block bluetooth\n   ```\n3. In Blueman Manager, select the device and click **Remove**.\n   \u2192 Nothing happens.\n4. Run:\n\n   ```bash\n   sudo rfkill unblock bluetooth\n   ```\n5. Click **Remove** again.\n   \u2192 Device is removed successfully.\n\n**Expected Behavior:**\nBlueman should display an error message or notification when the adapter is powered off or blocked, instead of silently failing.\n\n**Environment:**\n\n* **Distro:** Linux Mint 22 (Ubuntu 24.04 base)\n", "hints_text": "That error is not listed in the possible errors for RemoveDevice. ~~I'll add that we prevent removal to #2821.~~ Wait I misread, this is rfkill blocking.\n\n```python\nblueman-manager 23.10.21 ERROR    Base:93 callback  : Unhandled error for org.bluez.Adapter1.RemoveDevice\nTraceback (most recent call last):\n  File \"/usr/lib/python3.13/site-packages/blueman/bluez/Base.py\", line 86, in callback\n    value = proxy.call_finish(result).unpack()\n            ~~~~~~~~~~~~~~~~~^^^^^^^^\ngi.repository.GLib.GError: g-io-error-quark: GDBus.Error:org.bluez.Error.NotReady: Resource Not Ready (36)\n\n```\n\n", "all_hints_text": "That error is not listed in the possible errors for RemoveDevice. ~~I'll add that we prevent removal to #2821.~~ Wait I misread, this is rfkill blocking.\n\n```python\nblueman-manager 23.10.21 ERROR    Base:93 callback  : Unhandled error for org.bluez.Adapter1.RemoveDevice\nTraceback (most recent call last):\n  File \"/usr/lib/python3.13/site-packages/blueman/bluez/Base.py\", line 86, in callback\n    value = proxy.call_finish(result).unpack()\n            ~~~~~~~~~~~~~~~~~^^^^^^^^\ngi.repository.GLib.GError: g-io-error-quark: GDBus.Error:org.bluez.Error.NotReady: Resource Not Ready (36)\n\n```\n\n", "commit_urls": ["https://github.com/blueman-project/blueman/commit/71eb716d514243b9b9518d0d05b1601d83d17306"], "created_at": "2025-11-12T22:32:46Z"}
{"repo": "blueman-project/blueman", "pull_number": 3142, "instance_id": "blueman-project__blueman-3142", "issue_numbers": [3101], "base_commit": "6d5df6e9748a134ef3ee850889c6d9d888051ab9", "patch": "diff --git a/blueman/main/DbusService.py b/blueman/main/DbusService.py\nindex 6b5e81d7a..f240a5931 100644\n--- a/blueman/main/DbusService.py\n+++ b/blueman/main/DbusService.py\n@@ -105,7 +105,10 @@ def register(self) -> None:\n \n         node_info = Gio.DBusNodeInfo.new_for_xml(node_xml)\n \n-        regid = self._bus.register_object(\n+        # register_object_with_closures2 requires GLib 2.84.0 (released 2025-03-06).\n+        # Keep a fallback for older runtimes that only provide register_object().\n+        register_object = getattr(self._bus, \"register_object_with_closures2\", self._bus.register_object)\n+        regid = register_object(\n             self._path,\n             node_info.interfaces[0],\n             self._handle_method_call,\n", "test_patch": "", "problem_statement": "Memory leak: 1.5GB/week\nOver the course of about a week, I see the bluman-applet memory consumption grow to about 1.5GB.\n\nI'd like to track down the cause, but I'm not really sure where to start. As far as I can tell, the Python memory profiling tools are intended to measure excessive allocations, not leaks. And I don't think there's anything like Java's VisualVM, that will all you to take memory snapshots and inspect them. Advice would be appreciated!\n", "hints_text": "Python comes with tracemalloc https://docs.python.org/3/library/tracemalloc.html. But I'll be honest I never used it and done much memory leak hunting in general. So hopefully @cschramm can correct me or give better guidance.\n\nHopefully the below is helpful.\n\nblueman-applet which is in the bin directory is a simple wrapper around the main Gtk.Application you find in the blueman/main directory. Which under the hood uses a GLib event loop.\n\nThe bulk of the moving parts I think are the proxies and objectmanagers you see in blueman/bluez. These are used all over the place. In the past we had issues with older versions of the proxies which went (mostly?) away when I turned them into singletons. Now I kinda regret this as it most likely just hid the issues, but it solved the issue we had at that moment so yeah.\n\nThe applet also creates a dbus service that handles some of the communication with BlueZ plus internal communication for other apps like the manager and tray.\n\nAnother point you might want to check are applet plugins you're using, like autoconnect. See if disabling them makes it go away of reduces the leaks.\n\nI will be experimenting with tracemalloc as I always wanted to see and understand better how blueman handles memory. So hopefully I can offer better assistance in these types of issues in the future.\nI will give tracemalloc a try, I didn't realize it had `tracemalloc.Snapshot.dump()` available. That's exactly what I wanted to be able to do, to compare heap dumps separated by a long time.\n\nI also noticed that kdeconnect is also leaking memory despite being a Qt app and not a GTK app like blueman. But I wonder if it could be a common component somehow. At one point, I remember installing some kind of theming system for both GTK and Qt, and while I'm not using it anymore, I wonder if some vestige remains and is causing problems.\n\nAnyway, I'll see. I don't expect this to be a rapid process given the rate of the leaks. I appreciate your through response and will dig into the code if this current approach doesn't work out.\nI instrumented blueman-tray, but the python heap didn't grow above a handful of megabytes.\n\nI then instrumented native memory allocations with `sudo heaptrack -p 470943`. Unfortunately, I didn't have required debug symbols active while tracing, but I was able to look these up after the fact [with quick script, resolve_symbols.py](https://github.com/user-attachments/files/25075996/resolve_symbols.py): `heaptrack_print -l -n 10 heaptrack.blueman-tray.1512568.zst | ./resolve_symbols.py --pid 470943 > resolved-leaks.txt`\n\n<details>\n\n```\nMEMORY LEAKS\n301.53M leaked over 451736470 calls from\ng_malloc\n  in /usr/lib/libglib-2.0.so.0\n76.25M leaked over 1079308 calls from:\n    g_variant_new_preallocated_trusted (:?)\n      in /usr/lib/libglib-2.0.so.0\n    g_variant_new_string\n      in /usr/lib/libglib-2.0.so.0\n    parse_value_from_blob.isra.0 (:?)\n      in /usr/lib/libgio-2.0.so.0\n    parse_value_from_blob.isra.0 (:?)\n      in /usr/lib/libgio-2.0.so.0\n    parse_value_from_blob.isra.0 (:?)\n      in /usr/lib/libgio-2.0.so.0\n    parse_value_from_blob.isra.0 (:?)\n      in /usr/lib/libgio-2.0.so.0\n    g_dbus_message_new_from_blob\n      in /usr/lib/libgio-2.0.so.0\n    _g_dbus_worker_do_read_cb (:?)\n      in /usr/lib/libgio-2.0.so.0\n    g_task_return_now (:?)\n      in /usr/lib/libgio-2.0.so.0\n    complete_in_idle_cb (:?)\n      in /usr/lib/libgio-2.0.so.0\n    g_main_dispatch (:?)\n      in /usr/lib/libglib-2.0.so.0\n    g_main_context_iterate_unlocked.isra.0 (:?)\n      in /usr/lib/libglib-2.0.so.0\n    g_main_loop_run\n      in /usr/lib/libglib-2.0.so.0\n    gdbus_shared_thread_func.lto_priv.0 (:?)\n      in /usr/lib/libgio-2.0.so.0\n    g_thread_proxy (:?)\n      in /usr/lib/libglib-2.0.so.0\n    start_thread (/usr/src/debug/glibc/glibc/nptl/pthread_create.c:448)\n      in /usr/lib/libc.so.6\n    __GI___clone3 (/usr/src/debug/glibc/glibc/misc/../sysdeps/unix/sysv/linux/x86_64/clone3.S:78)\n      in /usr/lib/libc.so.6\n55.05M leaked over 743880 calls from:\n    g_variant_new_preallocated_trusted (:?)\n      in /usr/lib/libglib-2.0.so.0\n    g_variant_new_string\n      in /usr/lib/libglib-2.0.so.0\n    parse_value_from_blob.isra.0 (:?)\n      in /usr/lib/libgio-2.0.so.0\n    parse_value_from_blob.isra.0 (:?)\n      in /usr/lib/libgio-2.0.so.0\n    parse_value_from_blob.isra.0 (:?)\n      in /usr/lib/libgio-2.0.so.0\n    g_dbus_message_new_from_blob\n      in /usr/lib/libgio-2.0.so.0\n 