+    def _get_vars(self) -> list[Var]:
+        """Walk all Vars used in this component, including from match cases.
+
+        Returns:
+            Each var referenced by the component and its children.
+        """
+        vars = super()._get_vars()
+
+        # Get vars from all components in match cases
+        for case in self.match_cases:
+            for element in case:
+                if isinstance(element, BaseComponent):
+                    # Recursively get vars from child components
+                    vars.extend(element._get_vars())
+
+        # Get vars from default case if it's a component
+        if isinstance(self.default, BaseComponent):
+            vars.extend(self.default._get_vars())
+
+        return vars
+
+    def _get_events_hooks(self) -> set[str]:
+        """Get the hooks required by events referenced in this component and its children.
+
+        Returns:
+            The hooks for the events.
+        """
+        hooks = super()._get_events_hooks()
+
+        # Check if any match case or default case has event triggers
+        for case in self.match_cases:
+            for element in case:
+                if isinstance(element, BaseComponent) and element.event_triggers:
+                    hooks.add(Hooks.EVENTS)
+                    break
+            if Hooks.EVENTS in hooks:
+                break
+
+        # Check default case
+        if Hooks.EVENTS not in hooks and isinstance(self.default, BaseComponent) and self.default.event_triggers:
+            hooks.add(Hooks.EVENTS)
+
+        return hooks
+
