# Metrics logger\n metrics_logging_options = metrics_logger.MetricsLoggerOptions(\n     log_dir=\"/tmp/tensorboard/grpo\", flush_every_n_steps=20\n@@ -1108,6 +1106,7 @@ def get_rollout_config(engine: str) -> base_rollout.RolloutConfig:\n     epsilon=EPSILON,\n )\n \n+\n # RL cluster\n rl_cluster = rl_cluster_lib.RLCluster(\n     actor=training_model,\n@@ -1130,6 +1129,7 @@ def get_rollout_config(engine: str) -> base_rollout.RolloutConfig:\n \n show_hbm_usage(\"After creating the learner\")\n \n+\n rollout_sampler = rl_cluster._rollout._sampler  # pylint: disable=protected-access\n (eval_corr, eval_total, eval_accuracy, eval_partial_accuracy, eval_format_accuracy) = evaluate(  # pylint: disable=unbalanced-tuple-unpacking\n     test_dataset,\ndiff --git a/tunix/rl/rl_cluster.py b/tunix/rl/rl_cluster.py\nindex a889715a5..ce91acdae 100644\n--- a/tunix/rl/rl_cluster.py\n+++ b/tunix/rl/rl_cluster.py\n@@ -397,6 +397,7 @@ def _init_cluster(self):\n       self._maybe_offload_model_to_cpu(self._rollout.model(), Role.ROLLOUT)\n     elif self.cluster_config.rollout_engine == \"vllm\":\n       from tunix.rl.rollout import vllm_rollout\n+\n       loaded_vllm_config = None\n       if isinstance(\n           self.cluster_config.rollout_config, base_rollout.RolloutConfig\n@@ -421,6 +422,7 @@ def _init_cluster(self):\n       )\n     elif self.cluster_config.rollout_engine == \"sglang_jax\":\n       from tunix.rl.rollout import sglang_jax_rollout\n+\n       if isinstance(\n           self.cluster_config.rollout_config, base_rollout.RolloutConfig\n       ):\n", "test_patch": "", "problem_statement": "[scripts] merge `grpo_demo_sglang_jax_rollout.py` into `grpo_demo_llama3_qwen2.py`\nFor the convenience of management, merge `grpo_demo_sglang_jax_rollout.py` into `grpo_demo_llama3_qwen2.py`.\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/google/tunix/commit/ad0ac1c131403a113f0feab33c90bcfbb90ebab8", "https://github.com/google/tunix/commit/c8738957