diff --git a/cfnlint/transforms/foreach.py b/cfnlint/transforms/foreach.py
--- a/cfnlint/transforms/foreach.py
+++ b/cfnlint/transforms/foreach.py
@@ -1,2 +1,7 @@
-    if not values:
-        raise TransformError("Fn::ForEach could not be resolved")
+    # If the values list is empty, the ForEach should produce no resources
+    # rather than raising an error. This matches CloudFormation behavior where
+    # an empty iteration results in no resources.
+    if isinstance(values, list) and len(values) == 0:
+        return {}
+    if not values:
+        raise TransformError("Fn::ForEach could not be resolved")