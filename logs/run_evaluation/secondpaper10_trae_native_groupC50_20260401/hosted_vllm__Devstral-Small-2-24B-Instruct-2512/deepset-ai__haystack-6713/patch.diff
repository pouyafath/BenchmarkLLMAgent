 from typing import Dict, Any, Union
 
 import yaml
 
+from haystack.lazy_imports import LazyImport
+from haystack.utils.torch_utils import serialize_torch_dtype
+
+with LazyImport(message="Run 'pip install torch'") as torch_import:
+    import torch
+
 
 class YamlMarshaller:
     def marshal(self, dict_: Dict[str, Any]) -> str:
-        return yaml.dump(dict_)
+        """
+        Marshal a dictionary to YAML string, handling non-serializable objects like torch dtypes.
+
+        :param dict_: Dictionary to marshal.
+        :return: YAML string representation.
+        """
+        # Create a custom representer for torch dtypes
+        class TorchDtypeRepresenter(yaml.Dumper):
+            pass
+
+        def represent_torch_dtype(dumper, dtype):
+            return dumper.represent_str(serialize_torch_dtype(dtype))
+
+        TorchDtypeRepresenter.add_representer(torch.dtype, represent_torch_dtype)
+
+        # Handle other common non-serializable types
+        def represent_object(dumper, data):
+            # Try to convert to string representation
+            if hasattr(data, '__name__'):
+                return dumper.represent_str(f"{type(data).__module__}.{data.__name__}")
+            return dumper.represent_str(str(data))
+
+        TorchDtypeRepresenter.add_representer(object, represent_object)
+
+        return yaml.dump(dict_, Dumper=TorchDtypeRepresenter)
 
     def unmarshal(self, data_: Union[str, bytes, bytearray]) -> Dict[str, Any]:
+        """
+        Unmarshal a YAML string to dictionary.
+
+        :param data_: YAML string or bytes to unmarshal.
+        :return: Dictionary representation.
+        """
         return yaml.safe_load(data_)
