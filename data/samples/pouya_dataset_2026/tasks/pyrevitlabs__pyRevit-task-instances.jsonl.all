{"repo": "pyrevitlabs/pyRevit", "pull_number": 3206, "instance_id": "pyrevitlabs__pyRevit-3206", "issue_numbers": [3204], "base_commit": "c72c0f57742fbdea74db77048d17a3d033e225d0", "patch": "diff --git a/extensions/pyRevitTools.extension/lib/match/match_utils.py b/extensions/pyRevitTools.extension/lib/match/match_utils.py\nindex 9e4d5cd97..8e97d21bf 100644\n--- a/extensions/pyRevitTools.extension/lib/match/match_utils.py\n+++ b/extensions/pyRevitTools.extension/lib/match/match_utils.py\n@@ -12,13 +12,36 @@ def safe_get_parameter(elem, param_id):\n     if not param_id:\n         return None\n \n-    # BuiltInParameter (negative ids)\n-    if get_elementid_value(param_id) < 0:\n-        bip = DB.BuiltInParameter(get_elementid_value(param_id))\n-        return elem.get_Parameter(bip)\n+    try:\n+        pid_val = get_elementid_value(param_id)\n+\n+        # BuiltInParameter (negative ids)\n+        if pid_val < 0:\n+            bip = DB.BuiltInParameter(pid_val)\n+            return elem.get_Parameter(bip)\n+\n+        # Shared / Project Parameter\n+        doc = elem.Document\n+        param_el = doc.GetElement(param_id)\n+\n+        if not param_el:\n+            return None\n+\n+        # Prefer GUID\n+        if hasattr(param_el, \"GuidValue\"):\n+            guid = param_el.GuidValue\n+            if guid:\n+                return elem.get_Parameter(guid)\n+\n+        # Fallback - this should not be entered, as this would mean a non-filterable parameter\n+        definition = (\n+            param_el.GetDefinition() if hasattr(param_el, \"GetDefinition\") else None\n+        )\n+        if definition:\n+            return param_el.get_Parameter(definition)\n \n-    # shared/project parameter\n-    return elem.Parameter[param_id]\n+    except Exception:\n+        return None\n \n \n class PickByCategorySelectionFilter(UI.Selection.ISelectionFilter):\n@@ -144,7 +167,6 @@ def paste_props(source_props, paste_mode, category_filter=False):\n     # Build category filter if the checkbox is ticked and categories are known\n     pick_filter = None\n     if category_filter:\n-        # if bool(self.categoryFilterCheck.IsChecked):\n         cat_ids = set()\n         for p in source_props:\n             for c in p.categories or []:\n@@ -172,10 +194,19 @@ def paste_props(source_props, paste_mode, category_filter=False):\n                     dest_elements = [elem]\n \n             elif paste_mode == \"rectangle\":\n-                dest_elements = revit.pick_rectangle(pick_filter=pick_filter)\n+                try:\n+                    dest_elements = revit.pick_rectangle(pick_filter=pick_filter)\n+                except Exception:\n+                    # To handle esc by user, this would throw a OperationCanceledException\n+                    pass\n \n             elif paste_mode == \"selection\":\n                 dest_elements = list(revit.get_selection())\n+                if category_filter:\n+                    dest_elements = [\n+                        el for el in dest_elements\n+                        if el.Category and el.Category.Id in cat_ids\n+                    ]\n \n             if not dest_elements:\n                 break  # user cancelled / nothing selected\ndiff --git a/extensions/pyRevitTools.extension/lib/match/panel.py b/extensions/pyRevitTools.extension/lib/match/panel.py\nindex c37be26ed..b0246c585 100644\n--- a/extensions/pyRevitTools.extension/lib/match/panel.py\n+++ b/extensions/pyRevitTools.extension/lib/match/panel.py\n@@ -212,7 +212,11 @@ def load_from_element(self, sender, args):\n         if not elem:\n             return\n         props = get_source_properties(elem)  # opens pyrevit parameter-picker dialog\n+        count = len(props)\n         self._add_to_history(props)\n+        for i in range(min(count, len(self._items))):\n+            self._items[i].IsSelected = True\n+        self._update_ui_state()\n \n     def load_from_view_filters(self, sender, args):\n         \"\"\"Read all equals-filter parameter values from the active view.\"\"\"\ndiff --git a/extensions/pyRevitTools.extension/pyRevit.tab/Modify.panel/edit1.stack/Match.splitpushbutton/Match History Clipboard.smartbutton/script.py b/extensions/pyRevitTools.extension/pyRevit.tab/Modify.panel/edit1.stack/Match.splitpushbutton/Match History Clipboard.smartbutton/script.py\nindex 5752c8abf..69bf32181 100644\n--- a/extensions/pyRevitTools.extension/pyRevit.tab/Modify.panel/edit1.stack/Match.splitpushbutton/Match History Clipboard.smartbutton/script.py\n+++ b/extensions/pyRevitTools.extension/pyRevit.tab/Modify.panel/edit1.stack/Match.splitpushbutton/Match History Clipboard.smartbutton/script.py\n@@ -5,13 +5,16 @@\n def __selfinit__(script_cmp, ui_button_cmp, __rvt__):\n     # TODO: This isn't working. No clue why.\n     is_shown = False\n-    try:\n-        if forms.is_registered_dockable_panel(panel.MatchHistoryClipboard):\n-            dockable_panel = forms.get_dockable_panel(panel.MatchHistoryClipboard)\n-            is_shown = dockable_panel.IsShown()\n-    except Exception:\n-        is_shown = False\n+    # try:\n+    #     if forms.is_registered_dockable_panel(panel.MatchHistoryClipboard):\n+    #         dockable_panel = forms.get_dockable_panel(panel.MatchHistoryClipboard)\n+    #         is_shown = dockable_panel.IsShown()\n+    # except Exception:\n+    #     pass\n+\n     script.toggle_icon(is_shown)\n+    # init must return true if successful\n+    return True\n \n \n if forms.is_registered_dockable_panel(panel.MatchHistoryClipboard):\n", "test_patch": "", "problem_statement": "[Bug]: Match History Clipboard minor bugs\n### \u2708 Pre-Flight checks\n\n- [x] I **don't have SentinelOne** antivirus installed (see above for the solution)\n- [x] I have **searched in the issues** (open and closed) but couldn't find a similar issue\n- [x] I have **searched in the [pyRevit Forum](https://discourse.pyrevitlabs.io)** for similar issues\n- [x] I already **followed the [installation troubleshooting guide](https://pyrevitlabs.notion.site/Installation-issues-f6495adb56254e9e8021f8a68e3b2ab7) thoroughly**\n- [x] I am using the **latest pyRevit Version**\n\n### \ud83d\udc1e Describe the bug\n\nreminder for myself  - will try to fix today\n- handle ESC of rectangle pick via exception\n- handle icon setting differently to avoid error message on startup\n- check get param safe - fails in some edge cases\n- paste selection does not respect element category flag\n- autoselect new additions via parameter selectfromlist\n\n### \u2328 Error/Debug Message\n\n```shell\nsee above\n```\n\n### \u267b\ufe0f To Reproduce\n\n_No response_\n\n### \u23f2\ufe0f Expected behavior\n\n_No response_\n\n### \ud83d\udda5\ufe0f Hardware and Software Setup (please complete the following information)\n\n```shell\nlatest WIP\n```\n\n### Additional context\n\n_No response_\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/pyrevitlabs/pyRevit/commit/221dcfac85f3a5ceb150d78abd92d1133f9b68c6", "https://github.com/pyrevitlabs/pyRevit/commit/4179908f41b07099e5ade1723bb023992d171dd1"], "created_at": "2026-03-30T19:52:40Z"}
