+                # so we don't need this function at unpickling time
+                parent_namespace = {k: v for k, v in parent_namespace.items() if k != "annotate_func"}
+                state["__pydantic_parent_namespace__"] = parent_namespace
+
+        return state
+
+    def __setstate__(self, state):
+        """Set state for unpickling."""
+        super().__setstate__(state)
