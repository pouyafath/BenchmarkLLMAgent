{"repository": {"pullRequest": {"number": 255, "title": "Add multi-transport support to MCP plugin", "body": "Enhanced MCP plugin to support stdio, SSE, and WebSocket transports for server connections and tool execution. Refactored ServerConfig to include transport-specific fields and improved environment/header handling. Added comprehensive test suite for MCP plugin covering configuration, server connection, tool execution, and plugin structure. Updated plugin loader tests to include MCP plugin.\r\n\r\nFixes #219 ", "baseRefName": "main", "baseRefOid": "509ffa630e465390ddc45ed0149d8be60481de8a", "baseRepository": {"nameWithOwner": "algorithmicsuperintelligence/optillm"}, "url": "https://github.com/algorithmicsuperintelligence/optillm/pull/255", "createdAt": "2025-09-29T10:04:05Z", "mergedAt": "2025-09-29T11:36:11Z"}}, "base": {"repo": {"full_name": "algorithmicsuperintelligence/optillm"}, "sha": "509ffa630e465390ddc45ed0149d8be60481de8a"}, "diff_url": "https://github.com/algorithmicsuperintelligence/optillm/pull/255.diff", "number": 255, "created_at": "2025-09-29T10:04:05Z", "merged_at": "2025-09-29T11:36:11Z", "resolved_issues": [219]}
