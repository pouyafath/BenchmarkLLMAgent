+def test_load_config_file_with_env_vars(data_path: Path) -> None:
+    """Test that environment variables are correctly parsed from YAML config."""
+    config = Config.from_yaml(data_path / "example_with_env.yaml")
+
+    # Basic config assertions
+    assert config.name == "MyDeploymentWithEnv"
+    assert config.control_plane.port == 8000
+    assert config.default_service == "myworkflow"
+
+    # Test myworkflow service with env variables
+    myworkflow = config.services["myworkflow"]
+    assert myworkflow.name == "My Python Workflow"
+    assert myworkflow.env is not None
+    assert myworkflow.env["OPENAI_API_KEY"] == "sk-test123"
+    assert myworkflow.env["ANOTHER_SECRET"] == "secret-value"
+    assert myworkflow.source.type == "git"
+    assert myworkflow.source.name == "git@github.com/myorg/myrepo"
+    assert myworkflow.path == "src/python/app"
+    assert myworkflow.port == 1313
+    assert myworkflow.python_dependencies is not None
+    assert len(myworkflow.python_dependencies) == 2
+
+    # Test another-workflow service with env variables
+    another_workflow = config.services["another-workflow"]
+    assert another_workflow.name == "My LITS Workflow"
+    assert another_workflow.env is not None
+    assert another_workflow.env["API_ENDPOINT"] == "https://api.example.com"
+    assert another_workflow.source.type == "git"
+    assert another_workflow.source.name == "git@github.com/myorg/myrepo"
+    assert another_workflow.path == "src/ts/app"
+    assert another_workflow.port == 1313
+    assert another_workflow.ts_dependencies is not None
+    assert len(another_workflow.ts_dependencies) == 2
+
+    # Test dockerservice without env variables
+    dockerservice = config.services["dockerservice"]
+    assert dockerservice.name == "My additional service"
+    assert dockerservice.env is None
+    assert dockerservice.source.type == "docker"
+    assert dockerservice.source.name == "myorg/myimage:latest"
+    assert dockerservice.port == 1313
+
+    # Test memory service without env variables
+    memory = config.services["memory"]
+    assert memory.name == "Chat Memory"
+    assert memory.env is None
