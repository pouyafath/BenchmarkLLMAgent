f\u3068\u601d\u308f\u308c\u308b\u3002\n\n\u53c2\u8003: https://github.com/VOICEVOX/voicevox_engine/actions/runs/19589861458/job/56106157976\n\n### \u671f\u5f85\u52d5\u4f5c\n\nlint\u304c\u901a\u308b\u3053\u3068\u3002\n\n## \u305d\u306e\u4ed6\n\n\u305d\u3082\u305d\u3082\u3053\u306e`if: true`\u3092\u66f8\u3044\u3066\u305f\u7406\u7531\u304c\u4eca\u308f\u304b\u3089\u306a\u304f\u306a\u3063\u3066\u3044\u3066\u3001\u305f\u3076\u3093\u306a\u304f\u3066\u826f\u3055\u305d\u3046\u306a\u306e\u3067\u3001\u6d88\u3059\u5f62\u304c\u826f\u3055\u305d\u3046\u3067\u3059\u3002\n\n#1678 \u3067latest\u30d3\u30eb\u30c9\u3092\u4e00\u6642\u505c\u6b62\u3057\u305f\u969b\u3001\u30c6\u30b9\u30c8\u3092\u5b9f\u884c\u3059\u308b\u304b\u3069\u3046\u304b\u306e\u6761\u4ef6\u3092\u5e38\u306b\u771f\u3068\u306a\u308b\u3088\u3046\u5909\u66f4\u3057\u3001FIXME\u30b3\u30e1\u30f3\u30c8\u304c\u8ffd\u52a0\u3055\u308c\u305f\u3002\u3053\u306eFIXME\u30b3\u30e1\u30f3\u30c8\u306b\u306f\u300cDocker Hub\u306bpush\u3057\u306a\u3044\u5834\u5408\u306ffalse\u306b\u300d\u3068\u3042\u308b\u304c\u3001\u30c6\u30b9\u30c8\u306fGitHub Container Registry\u3092\u4f7f\u7528\u3057\u3066\u3044\u308b\u305f\u3081\u95a2\u9023\u6027\u304c\u4e0d\u660e\u3002\n\n\u5143\u3005 #650 \u3067\u30ea\u30ea\u30fc\u30b9\u30c6\u30b9\u30c8\u304c\u8ffd\u52a0\u3055\u308c\u305f\u969b\u306f\u3001\u30d0\u30fc\u30b8\u30e7\u30f3\u6307\u5b9a\u30d3\u30eb\u30c9\u306e\u5834\u5408\u306e\u307f\u30c6\u30b9\u30c8\u3092\u5b9f\u884c\u3059\u308b\u6761\u4ef6\u3060\u3063\u305f\u304c\u3001\u306a\u305clatest\u30d3\u30eb\u30c9\u6642\u306b\u30c6\u30b9\u30c8\u3092\u30b9\u30ad\u30c3\u30d7\u3057\u3066\u3044\u305f\u306e\u304b\u660e\u78ba\u306a\u7406\u7531\u306f\u6587\u66f8\u5316\u3055\u308c\u3066\u3044\u306a\u3044\u3002\n\n\u3053\u306e\u6761\u4ef6\u5206\u5c90\u306f\u6280\u8853\u7684\u306a\u5236\u7d04\u304c\u898b\u5f53\u305f\u3089\u306a\u3044\u305f\u3081\u3001\u4e0d\u8981\u3067\u3042\u308b\u53ef\u80fd\u6027\u304c\u9ad8\u3044\u3002\n\u3068\u3044\u3046\u3053\u3068\u3067\u3001\u6761\u4e