+    def fetch(
+        self,
+        request_or_url: Request | str,
+        spider: Spider | None = None,
+        redirect: bool = True,
+        **kwargs: Any,
+    ) -> None:
+        if isinstance(request_or_url, Request):
+            request = request_or_url
+        else:
+            url = any_to_uri(request_or_url)
+            request = Request(url, dont_filter=True, **kwargs)
+            if redirect:
+                request.meta["handle_httpstatus_list"] = SequenceExclude(
+                    range(300, 400)
+                )
+            else:
+                request.meta["handle_httpstatus_all"] = True
+        response = None
+        if self.crawler.settings.getbool("TWISTED_REACTOR_ENABLED"):
+            # Use Twisted reactor
+            from twisted.internet import reactor
+            with contextlib.suppress(IgnoreRequest):
+                response, spider = threads.blockingCallFromThread(
+                    reactor, self._schedule, request, spider
+                )
+        else:
+            # Reactorless mode - use asyncio to schedule the request
+            import time
+            
+            async def _fetch_async() -> tuple[Response | None, Spider | None]:
+                if not self.spider:
+                    await self._open_spider(request, spider)
+                assert self.crawler.engine is not None
+                self.crawler.engine.crawl(request)
+                # Wait for the request to complete with timeout
+                start_time = time.time()
+                while time.time() - start_time < 30.0:  # 30 second timeout
+                    if hasattr(request, "_response") and request._response is not None:
+                        break
+                    await asyncio.sleep(0.1)
+                return request._response, spider
+            
+            # Try to run the async function
+            try:
+                response, spider = asyncio.run(_fetch_async())
+            except RuntimeError as e:
+                if "no running event loop" in str(e):
+                    # No event loop running, this is expected in some cases
+                    print("Warning: No asyncio event loop running. fetch() may not work properly in reactorless mode.")
+                else:
+                    raise
+        self.populate_vars(response, request, spider)
