+    def _is_terraform_registry_source(self, source_url: str) -> bool:
+        """Check if the source URL is from the Terraform Registry."""
+        # Terraform Registry sources don't start with git::, ./, ../, or http(s)://
+        # They typically look like: namespace/path or namespace/path//submodule
+        if source_url.startswith(("./", "../")):
+            return False
+
+        # Check if it's a git URL (starts with git::)
+        if source_url.startswith("git::"):
+            return False
+
+        # Check if it's a full URL (http:// or https://)
+        if source_url.startswith(("http://", "https://")):
+            return False
+
+        # If it doesn't match any of the above, it's likely a Terraform Registry source
+        return True
+
+    def _is_valid_semantic_version(self, version: str) -> bool:
+        """Check if the version string follows semantic versioning pattern."""
+        # Basic semantic version pattern: major.minor.patch (with optional pre-release/build)
+        semantic_version_pattern = re.compile(r'^\d+\.\d+\.\d+([+-].*)?$')
+        return bool(semantic_version_pattern.match(version))
 
 check = RevisionVersionTag()
