--- a/mcpgateway/config.py
+++ b/mcpgateway/config.py
@@ -247,6 +247,30 @@ class Settings(BaseSettings):
     federation_timeout: int = 30  # seconds
     federation_sync_interval: int = 300  # seconds
 
+    # Protocol for generated URLs
+    gateway_protocol: str = "auto"
+
+    @field_validator("gateway_protocol")
+    @classmethod
+    def _validate_gateway_protocol(cls, v):
+        """Validate gateway_protocol setting.
+
+        Must be one of: \'http\", \'https\", or \'auto\'.
+
+        Args:
+            v: Protocol value to validate
+
+        Returns:
+            str: Validated protocol value
+
+        Raises:
+            ValueError: If protocol is not valid
+        """
+        if v not in ("http", "https", "auto"):
+            raise ValueError(f"gateway_protocol must be \'http\", \'https\", or \'auto\", got \'{v}\'")
+        return v
+
+
     # Resources
     resource_cache_size: int = 1000
     resource_cache_ttl: int = 3600  # seconds
