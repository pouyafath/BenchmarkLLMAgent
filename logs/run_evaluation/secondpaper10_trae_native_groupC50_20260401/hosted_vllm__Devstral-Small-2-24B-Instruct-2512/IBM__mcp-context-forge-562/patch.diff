index 894f16f2..75d2f67b 100644
--- a/mcpgateway/federation/discovery.py
+++ b/mcpgateway/federation/discovery.py
@@ -79,9 +79,44 @@ from zeroconf.asyncio import AsyncServiceBrowser, AsyncZeroconf
 # First-Party
 from mcpgateway import __version__
 from mcpgateway.config import settings
+from mcpgateway.utils.protocol_detector import get_protocol_from_request
 from mcpgateway.models import ServerCapabilities
 
 logger = logging.getLogger(__name__)
+ 
+
+def _get_gateway_protocol() -> str:
+    """Get the protocol to use for gateway URLs.
+    
+    Determines the protocol based on configuration:
+    - If GATEWAY_PROTOCOL is set to "https", use HTTPS
+    - If GATEWAY_PROTOCOL is set to "http", use HTTP
+    - If GATEWAY_PROTOCOL is "auto" (default), try to detect from environment
+    - Falls back to HTTP for backward compatibility
+    
+    Returns:
+        str: "http" or "https"
+    """
+    protocol = settings.gateway_protocol.lower()
+    
+    if protocol == "https":
+        return "https"
+    elif protocol == "http":
+        return "http"
+    elif protocol == "auto":
+        # Try to detect from external_url if set
+        if settings.external_url:
+            from urllib.parse import urlparse
+            parsed = urlparse(settings.external_url)
+            return parsed.scheme or "http"
+        
+        # Default to http for backward compatibility
+        return "http"
+    else:
+        # Invalid value, default to http
+        logger.warning(f"Invalid GATEWAY_PROTOCOL value: {protocol}. Using http as default.")
+        return "http"
+
 
 PROTOCOL_VERSION = os.getenv("PROTOCOL_VERSION", "2025-03-26")
 
