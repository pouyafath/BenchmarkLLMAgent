l 65535 scanned ports on 192.168.56.100 are in ignored states.\nNot shown: 65535 filtered tcp ports (proto-unreach)\nMAC Address: 08:00:27:27:BF:0E (PCS Systemtechnik/Oracle VirtualBox virtual NIC)\n\nNmap done: 1 IP address (1 host up) scanned in 2.76 seconds\n```\n\nThe error doesn't happen when scanning other live hosts that doesn't have LDAP open.\n\n**Expected behavior**\nNo output.\n\n**NetExec info**\n - OS: Kali\n - Version of nxc: 1.4.0 - SmoothOperator - 8af4bfa6 - 816\n - Installed from: pipx\n\n", "hints_text": "This should definitely be caught and not thrown to the user like other protocols\nOkay, I see where the issue arose, we are missing a simple `return False` on an exception handling, thus returning True, signifying that the connection was established, when in reality, it wasn't.\n\n", "all_hints_text": "This should definitely be caught and not thrown to the user like other protocols\nOkay, I see where the issue arose, we are missing a simple `return False` on an exception handling, thus returning True, signifying that the connection was established, when in reality, it wasn't.\n\n", "commit_urls": ["https://github.com/Pennyw0rth/NetExec/commit/9b8e7534a81916e8acbd1f6fc99b081ba3389481", "https://github.com/Pennyw0rth/NetExec/commit/9f636c950414644c984d797cfccc8434b26c10dc", "https://github.com/Pennyw0rth/NetExec/commit/0b8b577421981080407e4ce74da62b814c6db9c9"], "created_at": "2025-08-20T18:29:11Z"}
{"repo": "Pennyw0rth/NetExec", "pull_number": 901, "instance_id": "Pennyw0rth__NetExec-901", "issue_numbers": [879], "base_commit": "ccac58164635adfea3827ffc24bf0acfb6d5ed45", "patch": "diff --git a/nxc/modules/pre2k.py b/nxc/modules/pre2k.py\nindex 343868b211..f01d594885 100644\n--- a/nxc/modules/pre2k.py\n+++ b/nxc/modules/pre2k.py\n@@ -18,77 +18,66 @@ class NXCModule:\n     supported_protocols = [\"ldap\"]\n \n     def options(self, context, module_options):\n-        pass\n+        \"\"\"No options available\"\"\"\n \n     def on_login(self, context, connection):\n-        try:\n-            ldap_connection = connection.ldap_connection\n-\n-            # Define the search filter for pre-created computer accounts\n-            search_filter = \"(&(objectClass=computer)(userAccountControl=4128))\"\n-            attributes = [\"sAMAccountName\", \"userAccountControl\", \"dNSHostName\"]\n-\n-            context.log.info(f\"Using search filter: {search_filter}\")\n-            context.log.info(f\"Attributes to retrieve: {attributes}\")\n-\n-            computers = []\n-\n-            try:\n-                # Use paged search to retrieve all computer accounts with specific flags\n-                search_results = connection.search(search_filter, attributes)\n-                results = parse_result_attributes(search_results)\n-                context.log.debug(f\"Search results: {results}\")\n-\n-                for computer in results:\n-                    context.log.debug(f\"Processing computer: {computer['sAMAccountName']}, UAC: {computer['userAccountControl']}\")\n-                    # Check if the account is a pre-created computer account\n-                    if int(computer[\"userAccountControl\"]) == 4128:  # 4096 | 32\n-                        computers.append(computer[\"sAMAccountName\"])\n-                        context.log.debug(f\"Added computer: {computer['sAMAccountName']}\")\n-\n-                # Save computers to file\n-                domain_dir = os.path.join(f\"{NXC_PATH}/modules/pre2k\", connection.domain)\n-                output_file = os.path.join(domain_dir, \"precreated_computers.txt\")\n+        # Define the search filter for pre-created computer accounts\n+        search_filter = \"(&(objectClass=computer)(userAccountControl=4128))\"\n+        attributes = [\"sAMAccountName\", \"userAccountControl\", \"dNSHostName\"]\n \n-                # Create directories if they do not exist\n-                os.makedirs(domain_dir, exist_ok=True)\n+        context.log.info(f\"Using search filter: {search_filter}\")\n+        context.log.info(f\"Attributes to retrieve: {attributes}\")\n \n-                with open(output_file, \"w\") as file:\n-                    for computer in computers:\n-                        file.write(f\"{computer}\\n\")\n+        computers = []\n \n-                # Print discovered pre-created computer accounts\n-                if computers:\n-                    for computer in computers:\n-                        context.log.highlight(f\"Pre-created computer account: {computer}\")\n-                    context.log.success(f\"Found {len(computers)} pre-created computer accounts. Saved to {output_file}\")\n-                else:\n-                    context.log.info(\"No pre-created computer accounts found.\")\n-\n-                # Obtain TGTs and save to ccache\n-                ccache_base_dir = f\"{NXC_PATH}/modules/pre2k/ccache\"\n-                os.makedirs(ccache_base_dir, exist_ok=True)\n-\n-                successful_tgts = 0\n+        try:\n+            # Use paged search to retrieve all computer accounts with specific flags\n+            search_results = connection.search(search_filter, attributes)\n+            results = parse_result_attributes(search_results)\n+            context.log.debug(f\"Search results: {results}\")\n+\n+            for computer in results:\n+                context.log.debug(f\"Processing computer: {computer['sAMAccountName']}, UAC: {computer['userAccountControl']}\")\n+                # Check if the account is a pre-created computer account\n+                if int(computer[\"userAccountControl\"]) == 4128:  # 4096 | 32\n+                    computers.append(computer[\"sAMAccountName\"])\n+                    context.log.debug(f\"Added computer: {computer['sAMAccountName']}\")\n+\n+            # Save computers to file\n+            domain_dir = os.path.join(f\"{NXC_PATH}/modules/pre2k\", connection.domain)\n+            output_file = os.path.join(domain_dir, \"precreated_computers.txt\")\n+\n+            # Create directories if they do not exist\n+            os.makedirs(domain_dir, exist_ok=True)\n+\n+            with open(output_file, \"w\") as file:\n+                for computer in computers:\n+                    file.write(f\"{computer}\\n\")\n \n+            # Print discovered pre-created computer accounts\n+            if computers:\n                 for computer in computers:\n-                    machine_name = computer[:-1].lower()  # Remove trailing '$' and convert to lowercase\n-                    if self.get_tgt(context, machine_name, connection.domain, connection.kdcHost, ccache_base_dir):\n-                        successful_tgts += 1\n+                    context.log.highlight(f\"Pre-created computer account: {computer}\")\n+                context.log.success(f\"Found {len(computers)} pre-created computer accounts. Saved to {output_file}\")\n+            else:\n+                context.log.info(\"No pre-created computer accounts found.\")\n \n-                # Summary of TGT results\n-                if successful_tgts > 0:\n-                    context.log.success(f\"Successfully obtained TGT for {successful_tgts} pre-created computer accounts. Saved to {ccache_base_dir}\")\n+            # Obtain TGTs and save to ccache\n+            ccache_base_dir = f\"{NXC_PATH}/modules/pre2k/ccache\"\n+            os.makedirs(ccache_base_dir, exist_ok=True)\n \n-            except Exception as e:\n-                context.log.fail(f\"Error occurred during search: {e}\")\n+            successful_tgts = 0\n \n-            ldap_connection.close()\n-            return True\n+            for computer in computers:\n+                machine_name = computer[:-1].lower()  # Remove trailing '$' and convert to lowercase\n+                if self.get_tgt(context, machine_name, connection.domain, connection.kdcHost, ccache_base_dir):\n+                    successful_tgts += 1\n \n+            # Summary of TGT results\n+            if successful_tgts > 0:\n+                context.log.success(f\"Successfully obtained TGT for {successful_tgts} pre-created computer accounts. Saved to {ccache_base_dir}\")\n         except Exception as e:\n-            context.log.fail(f\"Error occurred during LDAP connection: {e}\")\n-            return False\n+            context.log.fail(f\"Error occurred during search: {e}\")\n \n     def get_tgt(self, context, username, domain, kdcHost, ccache_base_dir):\n         try:\n", "test_patch": "", "problem_statement": "Specifying pre2k module before other modules causes next module to fail with \"Bad file descriptor\"\n**Describe the bug**\nRunning pre2k module before other modules in the same command causes the next module to error out with \"Bad file descriptor\". The order which modules are specified makes a difference: `-M pre2k -M adcs` crashes and `-M adcs -M pre2k` doesn't.\n\nIt doesn't matter which module is specified after pre2k for example `-M pre2k -M sccm` will also crash.\n\n**To Reproduce**\nThis command triggers the error:\n```\nnxc ldap meereen.essos.local -u 'khal.drogo' -p 'horse' -M pre2k -M adcs --debug\n[12:09:15] DEBUG    NXC VERSION: 1.4.0 - SmoothOperator - 8af4bfa6 - 816                                                                                                                                                                                                                               netexec.py:82\n          