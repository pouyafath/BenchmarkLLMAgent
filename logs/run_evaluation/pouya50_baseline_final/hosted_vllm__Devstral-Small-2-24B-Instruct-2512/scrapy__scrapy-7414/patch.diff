+    def _get_extension_from_url(self, url: str) -> str:
+        """Extract file extension from URL, handling both path and query parameters."""
+        from urllib.parse import urlparse, parse_qsl
+
+        SCRIPT_EXTENSIONS = {
+            ".php",
+            ".asp",
+            ".aspx",
+            ".jsp",
+            ".do",
+            ".action",
+            ".cgi",
+            ".pl",
+            ".py",
+        }
+
+        parsed = urlparse(url)
+        path_ext = Path(parsed.path).suffix
+
+        # If path has an extension, use it (unless it's a script extension)
+        if path_ext and path_ext.lower() not in SCRIPT_EXTENSIONS:
+            return path_ext
+
+        # For script extensions or no path extension, try to extract from query parameters
+        if parsed.query:
+            query_items = parse_qsl(parsed.query)
+            for key, value in query_items:
+                if isinstance(value, str):
+                    ext = Path(value).suffix
+                    if ext:
+                        return ext
+
+        return ""
+
