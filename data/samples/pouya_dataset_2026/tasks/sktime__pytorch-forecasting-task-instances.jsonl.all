hon3.10/site-packages/pytorch_lightning/trainer/trainer.py\", line 1274, in _run_train\r\n    self._run_sanity_check()\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/pytorch_lightning/trainer/trainer.py\", line 1343, in _run_sanity_check\r\n    val_loop.run()\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/pytorch_lightning/loops/loop.py\", line 200, in run\r\n    self.advance(*args, **kwargs)\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/pytorch_lightning/loops/dataloader/evaluation_loop.py\", line 155, in advance\r\n    dl_outputs = self.epoch_loop.run(self._data_fetcher, dl_max_batches, kwargs)\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/pytorch_lightning/loops/loop.py\", line 200, in run\r\n    self.advance(*args, **kwargs)\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/pytorch_lightning/loops/epoch/evaluation_epoch_loop.py\", line 143, in advance\r\n    output = self._evaluation_step(**kwargs)\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/pytorch_lightning/loops/epoch/evaluation_epoch_loop.py\", line 240, in _evaluation_step\r\n    output = self.trainer._call_strategy_hook(hook_name, *kwargs.values())\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/pytorch_lightning/trainer/trainer.py\", line 1704, in _call_strategy_hook\r\n    output = fn(*args, **kwargs)\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/pytorch_lightning/strategies/strategy.py\", line 370, in validation_step\r\n    return self.model.validation_step(*args, **kwargs)\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/pytorch_forecasting/models/base_model.py\", line 419, in validation_step\r\n    log, out = self.step(x, y, batch_idx)\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/pytorch_forecasting/models/base_model.py\", line 565, in step\r\n    loss = self.loss(prediction, y, **mase_kwargs)\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/torch/nn/modules/module.py\", line 1130, in _call_impl\r\n    return forward_call(*input, **kwargs)\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/pytorch_forecasting/metrics/base_metrics.py\", line 351, in forward\r\n    res = metric(y_pred[idx], (y_actual[0][idx], y_actual[1]))\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/torch/nn/modules/module.py\", line 1130, in _call_impl\r\n    return forward_call(*input, **kwargs)\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/torchmetrics/metric.py\", line 245, in forward\r\n    self._forward_cache = self._forward_reduce_state_update(*args, **kwargs)\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/torchmetrics/metric.py\", line 309, in _forward_reduce_state_update\r\n    self.update(*args, **kwargs)\r\n  File \"/home/arossi/anaconda3/envs/tsapt/lib/python3.10/site-packages/torchmetrics/metric.py\", line 398, in wrapped_func\r\n    raise RuntimeError(\r\nRuntimeError: Encountered different devices in metric calculation (see stacktrace for details). This could be due to the metric class not being on the same device as input. Instead of `metric=MQF2DistributionLoss(...)` try to do `metric=MQF2DistributionLoss(...).to(device)` where device corresponds to the device of the input.`\r\n```\r\n\r\n</details>\r\n\r\n### Code to reproduce the problem\r\n\r\nreproducible code by @mvrozanti:\r\n\r\n<details>\r\n\r\n```python\r\nimport torch\r\nimport pandas as pd\r\nimport numpy as np\r\n\r\nfrom pytorch_forecasting import TimeSeriesDataSet, TemporalFusionTransformer\r\nfrom pytorch_forecasting.data import NaNLabelEncoder\r\nfrom pytorch_lightning import Trainer, LightningModule\r\n\r\nrows = 15\r\ndf = pd.DataFrame({\r\n    \"time\": pd.date_range(\"2025-01-01\", periods=rows, freq=\"h\"),\r\n    \"label\": [\"test\"] * rows,\r\n    \"var1\": np.random.randn(rows).cumsum(),\r\n    \"var2\": np.random.randn(rows).cumsum(),\r\n})\r\ndf = df.sort_values(\"time\").reset_index(drop=True)\r\ndf[\"past_var1\"] = df[\"var1\"].shift(-1)\r\ndf.dropna(subset=[\"past_var1\"], inplace=True)\r\ndf[\"time_idx\"] = range(len(df))\r\n\r\ndataset = TimeSeriesDataSet(\r\n    df,\r\n    time_idx=\"time_idx\",\r\n    target=\"past_var1\",\r\n    group_ids=[\"label\"],\r\n    static_categoricals=[\"label\"],\r\n    time_varying_known_reals=[\"var1\", \"var2\"],\r\n    time_varying_unknown_reals=[\"past_var1\"],\r\n    max_encoder_length=5,\r\n    max_prediction_length=2,\r\n    categorical_encoders={\"label\": NaNLabelEncoder(add_nan=False)},\r\n)\r\n\r\nclass PatchedTFT(TemporalFusionTransformer):\r\n    def forward(self, x, *args, **kwargs):\r\n        device = next(self.parameters()).device\r\n        for key, value in x.items():\r\n            x[key] = value.to(device)\r\n        return super().forward(x, *args, **kwargs)\r\n\r\nclass TFTModule(LightningModule):\r\n    def __init__(self, tft):\r\n        super().__init__()\r\n        self.tft = tft\r\n\r\n    def forward(self, x):\r\n        return self.tft(x)\r\n\r\n    def training_step(self, batch, batch_idx):\r\n        x, y = batch\r\n        y = y[0]\r\n        y_hat = self(x)\r\n        y_hat = y_hat.prediction\r\n        loss = self.tft.loss(y_hat, y)\r\n        self.log(\"train_loss\", loss)\r\n        return loss\r\n\r\n    def configure_optimizers(self):\r\n        return torch.optim.Adam(self.parameters(), lr=1e-3)\r\n\r\nmodel_tft = PatchedTFT.from_dataset(dataset)\r\nmodel = TFTModule(model_tft)\r\n\r\ntrainer = Trainer(\r\n    accelerator=\"gpu\",  # 'cpu' works fine\r\n    devices=1,\r\n    max_epochs=2,\r\n    detect_anomaly=True,\r\n    limit_train_batches=1\r\n)\r\n\r\ndataloader = dataset.to_dataloader(train=True, batch_size=4, num_workers=0)\r\ntrainer.fit(model, dataloader)\r\n```\r\n\r\n</details>\r\n\r\n\r\n(original code)\r\n\r\n<details>\r\n\r\n```\r\n    def create_model(self):\r\n        \"\"\"\r\n        Create an instance of the model. This function contains the definition and the library of the model\r\n        :return: None\r\n        \"\"\"\r\n        # configure network and trainer\r\n        early_stop_callback = EarlyStopping(monitor=\"val_loss\", min_delta=1e-4, patience=50, verbose=False, mode=\"min\")\r\n        lr_logger = LearningRateMonitor()  # log the learning rate\r\n        logger = TensorBoardLogger(self.talos_path)  # logging results to a tensorboard\r\n        checkpoint_callback = ModelCheckpoint(monitor='val_loss',\r\n                                              dirpath=self.talos_path,\r\n                                              filename=self.name + '-{epoch:02d}-{val_loss:.2f}')\r\n\r\n        self.trainer = pl.Trainer(\r\n            max_epochs=self.p['epochs'],\r\n            accelerator=\"auto\",\r\n            enable_model_summary=True,\r\n            gradient_clip_val=self.p['gradient_clip_val'],\r\n            limit_train_batches=30,\r\n            callbacks=[lr_logger, early_stop_callback, checkpoint_callback],\r\n            logger=logger,\r\n            default_root_dir=self.talos_path\r\n        )\r\n\r\n        if len(self.ds.target_name) == 1:\r\n            self.model = TemporalFusionTransformer.from_dataset(\r\n                self.ds.X_train,\r\n                learning_rate=self.p['lr'],\r\n                hidden_size=self.p['hidden_size'],\r\n                attention_head_size=self.p['attention_head_size'],\r\n                dropout=self.p['dropout'],\r\n                hidden_continuous_size=self.p['hidden_continuous_size'],\r\n                output_size=7,  # 7 quantiles by default\r\n                loss=QuantileLoss(),\r\n                reduce_on_plateau_patience=4,\r\n            )\r\n        else:\r\n            loss = MQF2DistributionLoss(prediction_length=self.ds.output_window + self.ds.horizon)\r\n            loss.requires_grad = True\r\n\r\n            self.model = TemporalFusionTransformer.from_dataset(\r\n                self.ds.X_train,\r\n                learning_rate=self.p['lr'],\r\n                hidden_size=self.p['hidden_size'],\r\n                attention_head_size=self.p['attention_head_size'],\r\n                dropout=self.p['dropout'],\r\n                hidden_continuous_size=self.p['hidden_continuous_size'],\r\n                loss=loss,  # .to(torch.device('cuda')),\r\n                reduce_on_plateau_patience=4,\r\n            )\r\n```\r\n\r\n</details>\r\n\r\nThanks for your time.\n", "hints_text": "To add more details on this. On the CPU, it works perfectly. I also tried with other DistributionLoss, and there are not issues. So I guess there is some tensor instantiated by the MQF2 function that messes up everything.\nI have this same problem if TimeSeriesDataSet is multi target else target is single everything is ok\nI'm also having this problem even when TimeSeriesDataSet is single target. The same code works fine when the  Trainer's accelerator='cpu'\r\n\r\ntorch: 2.5.1+cu124\r\nlightning: 2.5.0.post0\r\nforecasting: 1.2.0\r\n3.12.7 (main, Oct  1 2024, 11:15:50) [GCC 14.2.1 20240910]\r\nLinux-6.12.4-arch1-1-x86_64-with-glibc2.40\r\n\n@andreareds, @jonkiszp, @mvrozanti, can you please add *fully reproducible code* for this bug?\r\n\r\nThis should include:\r\n\r\n* generation or loading of data, optimally using dummy data generated in-code\r\n* all imports of relevant objects\r\n\r\nWithout the above, we will be unable to reproduce or diagnose the issue - thanks a lot for your help.\n```python\r\nimport torch\r\nimport pandas as pd\r\nimport numpy as np\r\n\r\nfrom pytorch_forecasting import TimeSeriesDataSet, TemporalFusionTransformer\r\nfrom pytorch_forecasting.data import NaNLabelEncoder\r\nfrom pytorch_lightning import Trainer, LightningModule\r\n\r\nrows = 15\r\ndf = pd.DataFrame({\r\n    \"time\": pd.date_range(\"2025-01-01\", periods=rows, freq=\"h\"),\r\n    \"label\": [\"test\"] * rows,\r\n    \"var1\": np.random.randn(rows).cumsum(),\r\n    \"var2\": np.random.randn(rows).cumsum(),\r\n})\r\ndf = df.sort_values(\"time\").reset_index(drop=True)\r\ndf[\"past_var1\"] = df[\"var1\"].shift(-1)\r\ndf.dropna(subset=[\"past_var1\"], inplace=True)\r\ndf[\"time_idx\"] = range(len(df))\r\n\r\ndataset = TimeSeriesDataSet(\r\n    df,\r\n    time_idx=\"time_idx\",\r\n    target=\"past_var1\",\r\n    group_ids=[\"label\"],\r\n    static_categoricals=[\"label\"],\r\n    time_varying_known_reals=[\"var1\", \"var2\"],\r\n    time_varying_unknown_reals=[\"past_var1\"],\r\n    max_encoder_length=5,\r\n    max_prediction_length=2,\r\n    categorical_encoders={\"label\": NaNLabelEncoder(add_nan=False)},\r\n)\r\n\r\nclass PatchedTFT(TemporalFusionTransformer):\r\n    def forward(self, x, *args, **kwargs):\r\n        device = next(self.parameters()).device\r\n        for key, value in x.items():\r\n            x[key] = value.to(device)\r\n        return super().forward(x, *args, **kwargs)\r\n\r\nclass TFTModule(LightningModule):\r\n    def __init__(self, tft):\r\n        super().__init__()\r\n        self.tft = tft\r\n\r\n    def forward(self, x):\r\n        return self.tft(x)\r\n\r\n    def training_step(self, batch, batch_idx):\r\n        x, y = batch\r\n        y = y[0]\r\n        y_hat = self(x)\r\n        y_hat = y_hat.prediction\r\n        loss = self.tft.loss(y_hat, y)\r\n        self.log(\"train_loss\", loss)\r\n        return loss\r\n\r\n    def configure_optimizers(self):\r\n        return torch.optim.Adam(self.parameters(), lr=1e-3)\r\n\r\nmodel_tft = PatchedTFT.from_dataset(dataset)\r\nmodel = TFTModule(model_tft)\r\n\r\ntrainer = Trainer(\r\n    accelerator=\"gpu\",  # 'cpu' works fine\r\n    devices=1,\r\n    max_epochs=2,\r\n    detect_anomaly=True,\r\n    limit_train_batches=1\r\n)\r\n\r\ndataloader = dataset.to_dataloader(train=True, batch_size=4, num_workers=0)\r\ntrainer.fit(model, dataloader)\r\n```\r\n\r\nAm I using it correctly? The script [fails when the accelerator is gpu](http://0x0.st/8i_s.txt), but not cpu\nI think the issue is probably that you are using `pytorch-lightning`and not `lightning`. If you use `lightning` you also need not to wrap everything in an extra module:\r\n\r\nYou might try the following code:\r\n\r\n```python\r\nfrom lightning import LightningModule\r\nimport torch\r\nimport pandas as pd\r\nimport numpy as np\r\nimport lightning.pytorch as pl\r\n\r\nfrom pytorch_forecasting import TimeSeriesDataSet, TemporalFusionTransformer\r\nfrom pytorch_forecasting.data import NaNLabelEncoder\r\nfrom pytorch_forecasting.models.temporal_fusion_transformer import TemporalFusionTransformer\r\n\r\nrows = 15\r\ndf = pd.DataFrame({\r\n    \"time\": pd.date_range(\"2025-01-01\", periods=rows, freq=\"h\"),\r\n    \"label\": [\"test\"] * rows,\r\n    \"var1\": np.random.randn(rows).cumsum(),\r\n    \"var2\": np.random.randn(rows).cumsum(),\r\n})\r\ndf = df.sort_values(\"time\").reset_index(drop=True)\r\ndf[\"past_var1\"] = df[\"var1\"].shift(-1)\r\ndf.dropna(subset=[\"past_var1\"], inplace=True)\r\ndf[\"time_idx\"] = range(len(df))\r\n\r\ndataset = TimeSeriesDataSet(\r\n    df,\r\n    time_idx=\"time_idx\",\r\n    target=\"past_var1\",\r\n    group_ids=[\"label\"],\r\n    static_categoricals=[\"label\"],\r\n    time_varying_known_reals=[\"var1\", \"var2\"],\r\n    time_varying_unknown_reals=[\"past_var1\"],\r\n    max_encoder_length=5,\r\n    max_prediction_length=2,\r\n    categorical_encoders={\"label\": NaNLabelEncoder(add_nan=False)},\r\n)\r\n\r\nmodel_tft = TemporalFusionTransformer.from_dataset(dataset)\r\n\r\ntrainer = pl.Trainer(\r\n    max_epochs=10,\r\n    accelerator=\"gpu\",\r\n    devices=\"auto\",\r\n    gradient_clip_val=0.1,\r\n    limit_train_batches=30,\r\n    limit_val_batches=3,\r\n    # fast_dev_run=True,\r\n    # logger=logger,\r\n    # profiler=True,\r\n    #callbacks=[lr_logger, early_stop_callback],\r\n)\r\n\r\ndataloader = dataset.to_dataloader(train=True, batch_size=4, num_workers=0)\r\ntrainer.fit(model_tft, dataloader)\r\n\r\n```\nOops :smile: works fine for me now. Thanks!\nSo can we close this issue. Or is something else still open?\nActually the original question was about `MQF2DistributionLoss`, which is not used in the example above.\n\nThe code\n\n```python\nfrom lightning import LightningModule\nimport torch\nimport pandas as pd\nimport numpy as np\nimport lightning.pytorch as pl\n\nfrom pytorch_forecasting import TimeSeriesDataSet, TemporalFusionTransformer\nfrom pytorch_forecasting.data import NaNLabelEncoder\nfrom pytorch_forecasting.models.temporal_fusion_transformer import TemporalFusionTransformer\nfrom pytorch_forecasting.metrics import MQF2DistributionLoss, QuantileLoss\n\nrows = 15\ndf = pd.DataFrame({\n    \"time\": pd.date_range(\"2025-01-01\", periods=rows, freq=\"h\"),\n    \"label\": [\"test\"] * rows,\n    \"var1\": np.random.randn(rows).cumsum(),\n    \"var2\": np.random.randn(rows).cumsum(),\n})\ndf = df.sort_values(\"time\").reset_index(drop=True)\ndf[\"past_var1\"] = df[\"var1\"].shift(-1)\ndf.dropna(subset=[\"past_var1\"], inplace=True)\ndf[\"time_idx\"] = range(len(df))\n\ndataset = TimeSeriesDataSet(\n    df,\n    time_idx=\"time_idx\",\n    target=\"past_var1\",\n    group_ids=[\"label\"],\n    static_categoricals=[\"label\"],\n    time_varying_known_reals=[\"var1\", \"var2\"],\n    time_varying_unknown_reals=[\"past_var1\"],\n    max_encoder_length=5,\n    max_prediction_length=2,\n    categorical_encoders={\"label\": NaNLabelEncoder(add_nan=False)},\n)\n\n# model_tft = TemporalFusionTransformer.from_dataset(dataset, loss=QuantileLoss())\nmodel_tft = TemporalFusionTransformer.from_dataset(dataset, loss=MQF2DistributionLoss(prediction_length=2))\n\ntrainer = pl.Trainer(\n    max_epochs=10,\n    accelerator=\"gpu\",\n    devices=\"auto\",\n    gradient_clip_val=0.1,\n    limit_train_batches=30,\n    limit_val_batches=3,\n    # fast_dev_run=True,\n    # logger=logger,\n    # profiler=True,\n    #callbacks=[lr_logger, early_stop_callback],\n)\n\ndataloader = dataset.to_dataloader(train=True, batch_size=4, num_workers=0)\ntrainer.fit(model_tft, dataloader)\n\nraw_predictions = model_tft.predict(dataloader, mode=\"raw\", return_x=True, trainer_kwargs=dict(accelerator='cuda'))\nmodel_tft.plot_prediction(raw_predictions.x, raw_predictions.output, idx=0)\n```\n\nthrows the error:\n```\nRuntimeError: Expected all tensors to be on the same device, but found at least two devices, cpu and cuda:0! (when checking argument for argument mat1 in method wrapper_CUDA_addmm)\n```\n\nThe error doesn't appear with `accelerator='cuda'`. \nUsing the loss `QuantileLoss` would work both with `cuda` and `cpu`.\nThis is indeed a bug, it seems like the `MQF2DistributionLoss` class `picnn` isn't being moved to the same device as input tensors (it is being initialized on CPU during loss class construction)\n\nI will open a PR to fix this issue.\n\n", "all_hints_text": "To add more details on this. On the CPU, it works perfectly. I also tried with other DistributionLoss, and there are not issues. So I guess there is some tensor instantiated by the MQF2 function that messes up everything.\nI have this same problem if TimeSeriesDataSet is multi target else target is single everything is ok\nI'm also having this problem even when TimeSeriesDataSet is single target. The same code works fine when the  Trainer's accelerator='cpu'\r\n\r\ntorch: 2.5.1+cu124\r\nlightning: 2.5.0.post0\r\nforecasting: 1.2.0\r\n3.12.7 (main, Oct  1 2024, 11:15:50) [GCC 14.2.1 20240910]\r\nLinux-6.12.4-arch1-1-x86_64-with-glibc2.40\r\n\n@andreareds, @jonkiszp, @mvrozanti, can you please add *fully reproducible code* for this bug?\r\n\r\nThis should include:\r\n\r\n* generation or loading of data, optimally using dummy data generated in-code\r\n* all imports of relevant objects\r\n\r\nWithout the above, we will be unable to reproduce or diagnose the issue - thanks a lot for your help.\n```python\r\nimport torch\r\nimport pandas as pd\r\nimport numpy as np\r\n\r\nfrom pytorch_forecasting import TimeSeriesDataSet, TemporalFusionTransformer\r\nfrom pytorch_forecasting.data import NaNLabelEncoder\r\nfrom pytorch_lightning import Trainer, LightningModule\r\n\r\nrows = 15\r\ndf = pd.DataFrame({\r\n    \"time\": pd.date_range(\"2025-01-01\", periods=rows, freq=\"h\"),\r\n    \"label\": [\"test\"] * rows,\r\n    \"var1\": np.random.randn(rows).cumsum(),\r\n    \"var2\": np.random.randn(rows).cumsum(),\r\n})\r\ndf = df.sort_values(\"time\").reset_index(drop=True)\r\ndf[\"past_var1\"] = df[\"var1\"].shift(-1)\r\ndf.dropna(subset=[\"past_var1\"], inplace=True)\r\ndf[\"time_idx\"] = range(len(df))\r\n\r\ndataset = TimeSeriesDataSet(\r\n    df,\r\n    time_idx=\"time_idx\",\r\n    target=\"past_var1\",\r\n    group_ids=[\"label\"],\r\n    static_categoricals=[\"label\"],\r\n    time_varying_known_reals=[\"var1\", \"var2\"],\r\n    time_varying_unknown_reals=[\"past_var1\"],\r\n    max_encoder_length=5,\r\n    max_prediction_length=2,\r\n    categorical_encoders={\"label\": NaNLabelEncoder(add_nan=False)},\r\n)\r\n\r\nclass PatchedTFT(TemporalFusionTransformer):\r\n    def forward(self, x, *args, **kwargs):\r\n        device = next(self.parameters()).device\r\n        for key, value in x.items():\r\n            x[key] = value.to(device)\r\n        return super().forward(x, *args, **kwargs)\r\n\r\nclass TFTModule(LightningModule):\r\n    def __init__(self, tft):\r\n        super().__init__()\r\n        self.tft = tft\r\n\r\n    def forward(self, x):\r\n        return self.tft(x)\r\n\r\n    def training_step(self, batch, batch_idx):\r\n        x, y = batch\r\n        y = y[0]\r\n        y_hat = self(x)\r\n        y_hat = y_hat.prediction\r\n        loss = self.tft.loss(y_hat, y)\r\n        self.log(\"train_loss\", loss)\r\n        return loss\r\n\r\n    def configure_optimizers(self):\r\n        return torch.optim.Adam(self.parameters(), lr=1e-3)\r\n\r\nmodel_tft = PatchedTFT.from_dataset(dataset)\r\nmodel = TFTModule(model_tft)\r\n\r\ntrainer = Trainer(\r\n    accelerator=\"gpu\",  # 'cpu' works fine\r\n    devices=1,\r\n    max_epochs=2,\r\n    detect_anomaly=True,\r\n    limit_train_batches=1\r\n)\r\n\r\ndataloader = dataset.to_dataloader(train=True, batch_size=4, num_workers=0)\r\ntrainer.fit(model, dataloader)\r\n```\r\n\r\nAm I using it correctly? The script [fails when the accelerator is gpu](http://0x0.st/8i_s.txt), but not cpu\nI think the issue is probably that you are using `pytorch-lightning`and not `lightning`. If you use `lightning` you also need not to wrap everything in an extra module:\r\n\r\nYou might try the following code:\r\n\r\n```python\r\nfrom lightning import LightningModule\r\nimport torch\r\nimport pandas as pd\r\nimport numpy as np\r\nimport lightning.pytorch as pl\r\n\r\nfrom pytorch_forecasting import TimeSeriesDataSet, TemporalFusionTransformer\r\nfrom pytorch_forecasting.data import NaNLabelEncoder\r\nfrom pytorch_forecasting.models.temporal_fusion_transformer import TemporalFusionTransformer\r\n\r\nrows = 15\r\ndf = pd.DataFrame({\r\n    \"time\": pd.date_range(\"2025-01-01\", periods=rows, freq=\"h\"),\r\n    \"label\": [\"test\"] * rows,\r\n    \"var1\": np.random.randn(rows).cumsum(),\r\n    \"var2\": np.random.randn(rows).cumsum(),\r\n})\r\ndf = df.sort_values(\"time\").reset_index(drop=True)\r\ndf[\"past_var1\"] = df[\"var1\"].shift(-1)\r\ndf.dropna(subset=[\"past_var1\"], inplace=True)\r\ndf[\"time_idx\"] = range(len(df))\r\n\r\ndataset = TimeSeriesDataSet(\r\n    df,\r\n    time_idx=\"time_idx\",\r\n    target=\"past_var1\",\r\n    group_ids=[\"label\"],\r\n    static_categoricals=[\"label\"],\r\n    time_varying_known_reals=[\"var1\", \"var2\"],\r\n    time_varying_unknown_reals=[\"past_var1\"],\r\n    max_encoder_length=5,\r\n    max_prediction_length=2,\r\n    categorical_encoders={\"label\": NaNLabelEncoder(add_nan=False)},\r\n)\r\n\r\nmodel_tft = TemporalFusionTransformer.from_dataset(dataset)\r\n\r\ntrainer = pl.Trainer(\r\n    max_epochs=10,\r\n    accelerator=\"gpu\",\r\n    devices=\"auto\",\r\n    gradient_clip_val=0.1,\r\n    limit_train_batches=30,\r\n    limit_val_batches=3,\r\n    # fast_dev_run=True,\r\n    # logger=logger,\r\n    # profiler=True,\r\n    #callbacks=[lr_logger, early_stop_callback],\r\n)\r\n\r\ndataloader = dataset.to_dataloader(train=True, batch_size=4, num_workers=0)\r\ntrainer.fit(model_tft, dataloader)\r\n\r\n```\nOops :smile: works fine for me now. Thanks!\nSo can we close this issue. Or is something else still open?\nActually the original question was about `MQF2DistributionLoss`, which is not used in the example above.\n\nThe code\n\n```python\nfrom lightning import LightningModule\nimport torch\nimport pandas as pd\nimport numpy as np\nimport lightning.pytorch as pl\n\nfrom pytorch_forecasting import TimeSeriesDataSet, TemporalFusionTransformer\nfrom pytorch_forecasting.data import NaNLabelEncoder\nfrom pytorch_forecasting.models.temporal_fusion_transformer import TemporalFusionTransformer\nfrom pytorch_forecasting.metrics import MQF2DistributionLoss, QuantileLoss\n\nrows = 15\ndf = pd.DataFrame({\n    \"time\": pd.date_range(\"2025-01-01\", periods=rows, freq=\"h\"),\n    \"label\": [\"test\"] * rows,\n    \"var1\": np.random.randn(rows).cumsum(),\n    \"var2\": np.random.randn(rows).cumsum(),\n})\ndf = df.sort_values(\"time\").reset_index(drop=True)\ndf[\"past_var1\"] = df[\"var1\"].shift(-1)\ndf.dropna(subset=[\"past_var1\"], inplace=True)\ndf[\"time_idx\"] = range(len(df))\n\ndataset = TimeSeriesDataSet(\n    df,\n    time_idx=\"time_idx\",\n    target=\"past_var1\",\n    group_ids=[\"label\"],\n    static_categoricals=[\"label\"],\n    time_varying_known_reals=[\"var1\", \"var2\"],\n    time_varying_unknown_reals=[\"past_var1\"],\n    max_encoder_length=5,\n    max_prediction_length=2,\n    categorical_encoders={\"label\": NaNLabelEncoder(add_nan=False)},\n)\n\n# model_tft = TemporalFusionTransformer.from_dataset(dataset, loss=QuantileLoss())\nmodel_tft = TemporalFusionTransformer.from_dataset(dataset, loss=MQF2DistributionLoss(prediction_length=2))\n\ntrainer = pl.Trainer(\n    max_epochs=10,\n    accelerator=\"gpu\",\n    devices=\"auto\",\n    gradient_clip_val=0.1,\n    limit_train_batches=30,\n    limit_val_batches=3,\n    # fast_dev_run=True,\n    # logger=logger,\n    # profiler=True,\n    #callbacks=[lr_logger, early_stop_callback],\n)\n\ndataloader = dataset.to_dataloader(train=True, batch_size=4, num_workers=0)\ntrainer.fit(model_tft, dataloader)\n\nraw_predictions = model_tft.predict(dataloader, mode=\"raw\", return_x=True, trainer_kwargs=dict(accelerator='cuda'))\nmodel_tft.plot_prediction(raw_predictions.x, raw_predictions.output, idx=0)\n```\n\nthrows the error:\n```\nRuntimeError: Expected all tensors to be on the same device, but found at least two devices, cpu and cuda:0! (when checking argument for argument mat1 in method wrapper_CUDA_addmm)\n```\n\nThe error doesn't appear with `accelerator='cuda'`. \nUsing the loss `QuantileLoss` would work both with `cuda` and `cpu`.\nThis is indeed a bug, it seems like the `MQF2DistributionLoss` class `picnn` isn't being moved to the same device as input tensors (it is being initialized on CPU during loss class construction)\n\nI will open a PR to fix this issue.\n\n", "commit_urls": ["https://github.com/sktime/pytorch-forecasting/commit/24f051ccca378718769b1d4dbb409045fbd35451", "https://github.com/sktime/pytorch-forecasting/commit/e1cc9aa8ed7a77a355a3be6c95c291135004b6b3", "https://github.com/sktime/pytorch-forecasting/commit/e0faffce37d6a0747adaab7afa32cc63a935a5cf", "https://github.com/sktime/pytorch-forecasting/commit/c681afd01f08e3af795c8012078b3290d77a2bdd", "https://github.com/sktime/pytorch-forecasting/commit/d313b2f8202d1455461395afacff53b7ade3778a", "https://github.com/sktime/pytorch-forecasting/commit/5fea514393a54b1cf2b9f46d0dc64e45f00f5cd5"], "created_at": "2025-07-10T12:24:55Z"}
{"repo": "sktime/pytorch-forecasting", "pull_number": 2028, "instance_id": "sktime__pytorch-forecasting-2028", "issue_numbers": [1541], "base_commit": "670b8e48bcd8a1ba0b6ec039811101120f04ab89", "patch": "diff --git a/pytorch_forecasting/metrics/point.py b/pytorch_forecasting/metrics/point.py\nindex 3148e8c55..21f144a12 100644\n--- a/pytorch_forecasting/metrics/point.py\n+++ b/pytorch_forecasting/metrics/point.py\n@@ -149,9 +149,13 @@ def to_quantiles(\n \n class RMSE(MultiHorizonMetric):\n     \"\"\"\n-    Root mean square error\n+    Root mean square error.\n \n-    Defined as ``(y_pred - target)**2``\n+    Defined as `sqrt(mean((y_pred - target)**2))`.\n+\n+    Note: The square root is applied during the reduction step via\n+    the `sqrt-mean` strategy, while the `loss` method calculates\n+    the squared error.\n     \"\"\"\n \n     def __init__(self, reduction=\"sqrt-mean\", **kwargs):\n", "test_patch": "", "problem_statement": "[DOC] Clarify documentation of `RMSE` to avoid confusions regarding the implementation\nNoticed discrepancy related to metric definition. RMSE is actually MSE, which makes sense as RMSE tends to be very unstable.\r\n\r\nDefiniton: \r\n```python\r\nclass RMSE(MultiHorizonMetric):\r\n  \"\"\"\r\n  Root mean square error\r\n  \r\n  Defined as ``(y_pred - target)**2``\r\n  \"\"\"\r\n  \r\n  def __init__(self, reduction=\"sqrt-mean\", **kwargs):\r\n   super().__init__(reduction=reduction, **kwargs)\r\n  \r\n  def loss(self, y_pred: Dict[str, torch.Tensor], target):\r\n    loss = torch.pow(self.to_prediction(y_pred) - target, 2)\r\n    return loss\r\n```\r\nsource:\r\nhttps://github.com/jdb78/pytorch-forecasting/blob/68a0eb5f1701801142ce976fa50305b29507845a/pytorch_forecasting/metrics/point.py#L137C1-L149C20\n", "hints_text": "The documentation isn't very clear, but I believe the root is applied by the reduction function, thus making it RMSE. A bit risky since the reduction function doesn't have to be `\"sqrt-mean\"`...\nIt seems to be correctly implemented. The parent method of `RMSE` is `MultiHorizonMetric`. In its `compute` method first a reduction is performed by calling `reduce_loss`, which is also implemented in `MultiHorizonMetric`.  There the strategy `\"sqrt-mean\"` exist. \r\n\r\nHowever, I agree that the documentation should be improved here. \nCan you assign me the task to improve the documentation ?\n\n@benHeid \n\n", "all_hints_text": "The documentation isn't very clear, but I believe the root is applied by the reduction function, thus making it RMSE. A bit risky since the reduction function doesn't have to be `\"sqrt-mean\"`...\nIt seems to be correctly implemented. The parent method of `RMSE` is `MultiHorizonMetric`. In its `compute` method first a reduction is performed by calling `reduce_loss`, which is also implemented in `MultiHorizonMetric`.  There the strategy `\"sqrt-mean\"` exist. \r\n\r\nHowever, I agree that the documentation should be improved here. \nCan you assign me the task to improve the documentation ?\n\n@benHeid \n\n", "commit_urls": ["https://github.com/sktime/pytorch-forecasting/commit/570c0cab9a6547bcd2c6312bfaea959ccce4deee", "https://github.com/sktime/pytorch-forecasting/commit/8b4760764e9518d8073c6d58a57c3a51c73551c0"], "created_at": "2026-01-22T17:59:07Z"}
{"repo": "sktime/pytorch-forecasting", "pull_number": 1872, "instance_id": "sktime__pytorch-forecasting-1872", "issue_numbers": [1614], "base_commit": "7305d46530682df5548c0ac557bd379dde46c635", "patch": "diff --git a/pytorch_forecasting/metrics/base_metrics.py b/pytorch_forecasting/metrics/base_metrics.py\nindex 8b4ee141f..9396a897c 100644\n--- a/pytorch_forecasting/metrics/base_metrics.py\n+++ b/pytorch_forecasting/metrics/base_metrics.py\n@@ -817,15 +817,23 @@ class MultiHorizonMetric(Metric):\n \n     def __init__(self, reduction: str = \"mean\", **kwargs) -> None:\n         super().__init__(reduction=reduction, **kwargs)\n+        if reduction == \"none\":\n+            default_losses = default_lengths = []\n+            dist_reduce_fx = \"cat\"\n+        else:\n+            default_losses = 0.0\n+            default_lengths = 0\n+            dist_reduce_fx = \"sum\"\n+\n         self.add_state(\n             \"losses\",\n-            default=torch.tensor(0.0),\n-            dist_reduce_fx=\"sum\" if reduction != \"none\" else \"cat\",\n+            default=torch.tensor(default_losses, dtype=torch.float),\n+            dist_reduce_fx=dist_reduce_fx,\n         )\n         self.add_state(\n             \"lengths\",\n-            default=torch.tensor(0),\n-            dist_reduce_fx=\"sum\" if reduction != \"none\" else \"mean\",\n+            default=torch.tensor(default_lengths, dtype=torch.long),\n+            dist_reduce_fx=dist_reduce_fx,\n         )\n \n     def loss(\n", "test_patch": "diff --git a/tests/test_metrics.py b/tests/test_metrics.py\nindex 3c7031d31..ac9fc27c9 100644\n--- a/tests/test_metrics.py\n+++ b/tests/test_metrics.py\n@@ -74,7 +74,6 @@ def test_aggregation_metric(decoder_lengths, y):\n         assert torch.isclose(res, (y.mean(0) - y_pred.mean(0)).abs().mean())\n \n \n-@pytest.mark.xfail(reason=\"failing, to be fixed, bug #1614\")\n def test_none_reduction():\n     pred = torch.rand(20, 10)\n     target = torch.rand(20, 10)\n", "problem_statement": "[BUG] `test_none_reduction` fails on main\nThe `test_none_reduction` test fails on main, with \r\n\r\n```\r\n>                   reduced = torch.cat([global_state, local_state])\r\nE                   RuntimeError: zero-dimensional tensor (at position 0) cannot be concatenated\r\n```\r\n\r\nThis seems like change in upcasting, and is resolved in the case without distributed computation by setting `dist_reduce_fx=\"mean\"` instead of `\"cat\"`, which also seems to produce the correct result (but not conclusively since we need to deal with the distributed case)\n", "hints_text": "This is the `pip list`\r\n\r\n```\r\nPackage                                 Version\r\n--------------------------------------- -----------\r\nabsl-py                                 2.1.0\r\naccessible-pygments                     0.0.5\r\naiohappyeyeballs                        2.4.0\r\naiohttp                                 3.10.5\r\naiosignal                               1.3.1\r\nalabaster                               1.0.0\r\nalembic                                 1.13.2\r\nappnope                                 0.1.4\r\nastroid                                 3.2.4\r\nasttokens                               2.4.1\r\nasync-timeout                           4.0.3\r\nattrs                                   24.2.0\r\nbabel                                   2.16.0\r\nbackports.functools-lru-cache           2.0.0\r\nbeautifulsoup4                          4.12.3\r\nblack                                   24.8.0\r\nbleach                                  6.1.0\r\ncertifi                                 2024.7.4\r\ncfgv                                    3.4.0\r\ncharset-normalizer                      3.3.2\r\nclick                                   8.1.7\r\ncmaes                                   0.11.1\r\ncolorlog                                6.8.2\r\ncomm                                    0.2.2\r\ncommonmark                              0.9.1\r\ncontourpy                               1.2.1\r\ncoverage                                7.6.1\r\ncpflows                                 0.1.2\r\ncycler                                  0.12.1\r\ndebugpy                                 1.8.5\r\ndecorator                               5.1.1\r\ndefusedxml                              0.7.1\r\ndill                                    0.3.8\r\ndistlib                                 0.3.8\r\ndocutils                                0.21.2\r\nexceptiongroup                          1.2.2\r\nexecnet                                 2.1.1\r\nexecuting                               2.0.1\r\nfastjsonschema                          2.20.0\r\nfilelock                                3.15.4\r\nflake8                                  7.1.1\r\nfonttools                               4.53.1\r\nfrozenlist                              1.4.1\r\nfsspec                                  2024.6.1\r\nfuture                                  1.0.0\r\ngreenlet                                3.0.3\r\ngrpcio                                  1.66.0\r\nh5py                                    3.11.0\r\nidentify                                2.6.0\r\nidna                                    3.8\r\nimagesize                               1.4.1\r\niniconfig                               2.0.0\r\ninvoke                                  2.2.0\r\nipykernel                               6.29.5\r\nipython                                 8.26.0\r\nipywidgets                              8.1.5\r\nisort                                   5.13.2\r\njedi                                    0.19.1\r\nJinja2                                  3.1.4\r\njoblib                                  1.4.2\r\njsonschema                              4.23.0\r\njsonschema-specifications               2023.12.1\r\njupyter_client                          8.6.2\r\njupyter_core                            5.7.2\r\njupyterlab_pygments                     0.3.0\r\njupyterlab_widgets                      3.0.13\r\