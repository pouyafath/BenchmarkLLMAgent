+    @classmethod
+    def _collect_var_data_from_match_cases(cls, match_cases: List[List[BaseVar]], default: Optional[BaseVar]) -> List[VarData | None]:
+        """Recursively collect VarData from all components within match cases.
+
+        Args:
+            match_cases: The match cases.
+            default: The default case.
+
+        Returns:
+            List of VarData objects from all components and vars in the match cases.
+        """
+        var_data = []
+
+        # Collect VarData from all elements in match cases
+        for case in match_cases:
+            for element in case:
+                if isinstance(element, BaseVar):
+                    var_data.append(element._var_data)
+                elif isinstance(element, BaseComponent):
+                    # Recursively collect VarData from the component and its children
+                    var_data.extend(cls._collect_var_data_from_component(element))
+
+        # Collect VarData from default case
+        if isinstance(default, BaseVar):
+            var_data.append(default._var_data)
+        elif isinstance(default, BaseComponent):
+            var_data.extend(cls._collect_var_data_from_component(default))
+
+        return var_data
+
+    @classmethod
+    def _collect_var_data_from_component(cls, component: BaseComponent) -> List[VarData | None]:
+        """Recursively collect VarData from a component and its children.
+
+        Args:
+            component: The component to collect VarData from.
+
+        Returns:
+            List of VarData objects from the component and its children.
+        """
+        var_data = []
+
+        # Collect VarData from the component itself
+        if hasattr(component, '_var_data') and component._var_data is not None:
+            var_data.append(component._var_data)
+
+        # If the component has children, recursively collect VarData from them
+        if hasattr(component, 'children') and component.children:
+            for child in component.children:
+                if isinstance(child, BaseVar):
+                    var_data.append(child._var_data)
+                elif isinstance(child, BaseComponent):
+                    var_data.extend(cls._collect_var_data_from_component(child))
+
+        return var_data
