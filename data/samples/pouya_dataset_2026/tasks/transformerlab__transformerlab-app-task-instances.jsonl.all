{"repo": "transformerlab/transformerlab-app", "pull_number": 431, "instance_id": "transformerlab__transformerlab-app-431", "issue_numbers": [284, 329], "base_commit": "a3e4c005e27c7c2c87aa566ceb02ba9866be0bf3", "patch": "diff --git a/src/renderer/components/Experiment/Foundation/InferenceEngineModal.tsx b/src/renderer/components/Experiment/Foundation/InferenceEngineModal.tsx\nindex 925768222..c980be2d1 100644\n--- a/src/renderer/components/Experiment/Foundation/InferenceEngineModal.tsx\n+++ b/src/renderer/components/Experiment/Foundation/InferenceEngineModal.tsx\n@@ -29,9 +29,9 @@ function EngineSelect({\n       experimentInfo?.id,\n       'loader', // type\n       'model_architectures:' +\n-        experimentInfo?.config?.foundation_model_architecture //filter\n+        experimentInfo?.config?.foundation_model_architecture, //filter\n     ),\n-    fetcher\n+    fetcher,\n   );\n   return (\n     <Select\n@@ -91,7 +91,7 @@ export default function InferenceEngineModal({\n             // We don't want to go to the server to get the friendly name of the server\n             // so we dig into the DOM to get it\n             const engineFriendlyName = document.querySelector(\n-              `button[name='inferenceEngine']`\n+              `button[name='inferenceEngine']`,\n             )?.innerHTML;\n \n             const experimentId = experimentInfo?.id;\n@@ -103,14 +103,15 @@ export default function InferenceEngineModal({\n               inferenceEngineFriendlyName: engineFriendlyName,\n             };\n \n+            console.log('newInferenceSettings', newInferenceSettings);\n             setInferenceSettings(newInferenceSettings);\n \n             await fetch(\n               chatAPI.Endpoints.Experiment.UpdateConfig(\n                 experimentId,\n                 'inferenceParams',\n-                JSON.stringify(newInferenceSettings)\n-              )\n+                JSON.stringify(newInferenceSettings),\n+              ),\n             );\n             closeModal();\n           }}\ndiff --git a/src/renderer/components/Experiment/Foundation/ModelDetails.tsx b/src/renderer/components/Experiment/Foundation/ModelDetails.tsx\nindex 1fdde8ef5..0dca37adf 100644\n--- a/src/renderer/components/Experiment/Foundation/ModelDetails.tsx\n+++ b/src/renderer/components/Experiment/Foundation/ModelDetails.tsx\n@@ -251,9 +251,7 @@ export default function ModelDetails({\n                   chatAPI.Endpoints.Experiment.UpdateConfig(\n                     experimentInfo?.id,\n                     'inferenceParams',\n-                    JSON.stringify({\n-                      inferenceEngine: null,\n-                    }),\n+                    JSON.stringify({}),\n                   ),\n                 );\n               }}\ndiff --git a/src/renderer/components/Experiment/Foundation/RunModelButton.tsx b/src/renderer/components/Experiment/Foundation/RunModelButton.tsx\nindex f0398a8a8..008937673 100644\n--- a/src/renderer/components/Experiment/Foundation/RunModelButton.tsx\n+++ b/src/renderer/components/Experiment/Foundation/RunModelButton.tsx\n@@ -53,44 +53,54 @@ export default function RunModelButton({\n     );\n   }\n \n+  async function getDefaultinferenceEngines() {\n+    const inferenceEngines = await fetch(\n+      chatAPI.Endpoints.Experiment.ListScriptsOfType(\n+        experimentInfo?.id,\n+        'loader', // type\n+        'model_architectures:' +\n+          experimentInfo?.config?.foundation_model_architecture, //filter\n+      ),\n+    );\n+    const inferenceEnginesJSON = await inferenceEngines.json();\n+    const experimentId = experimentInfo?.id;\n+    const engine = inferenceEnginesJSON?.[0]?.uniqueId;\n+    const inferenceEngineFriendlyName = inferenceEnginesJSON?.[0]?.name || '';\n+\n+    await fetch(\n+      chatAPI.Endpoints.Experiment.UpdateConfig(\n+        experimentId,\n+        'inferenceParams',\n+        JSON.stringify({\n+          ...inferenceSettings,\n+          inferenceEngine: engine,\n+          inferenceEngineFriendlyName: inferenceEngineFriendlyName,\n+        }),\n+      ),\n+    );\n+\n+    return inferenceEnginesJSON?.[0]?.uniqueId;\n+  }\n+\n   // Set a default inference Engine if there is none\n   useEffect(() => {\n     // Update experiment inference parameters so the Run button shows correctly\n+    let objExperimentInfo = null;\n     if (experimentInfo?.config?.inferenceParams) {\n-      setInferenceSettings(JSON.parse(experimentInfo?.config?.inferenceParams));\n+      objExperimentInfo = JSON.parse(experimentInfo?.config?.inferenceParams);\n     }\n-\n-    // console.log('Searching for primary inference engine');\n-    // console.log(inferenceSettings);\n-    (async () => {\n-      if (inferenceSettings?.inferenceEngine == null) {\n-        const inferenceEngines = await fetch(\n-          chatAPI.Endpoints.Experiment.ListScriptsOfType(\n-            experimentInfo?.id,\n-            'loader', // type\n-            'model_architectures:' +\n-              experimentInfo?.config?.foundation_model_architecture, //filter\n-          ),\n-        );\n-        const inferenceEnginesJSON = await inferenceEngines.json();\n-        const experimentId = experimentInfo?.id;\n-        const engine = inferenceEnginesJSON?.[0]?.uniqueId;\n-\n-        await fetch(\n-          chatAPI.Endpoints.Experiment.UpdateConfig(\n-            experimentId,\n-            'inferenceParams',\n-            JSON.stringify({\n-              ...inferenceSettings,\n-              inferenceEngine: engine,\n-            }),\n-          ),\n-        );\n+    if (objExperimentInfo == null) {\n+      (async () => {\n+        const { inferenceEngine, inferenceEngineFriendlyName } =\n+          await getDefaultinferenceEngines();\n         setInferenceSettings({\n-          inferenceEngine: inferenceEnginesJSON?.[0]?.uniqueId,\n+          inferenceEngine: inferenceEngine,\n+          inferenceEngineFriendlyName: inferenceEngineFriendlyName,\n         });\n-      }\n-    })();\n+      })();\n+    } else {\n+      setInferenceSettings(objExperimentInfo);\n+    }\n   }, [experimentInfo]);\n \n   function Engine() {\ndiff --git a/src/renderer/components/Experiment/Foundation/SelectAModel.tsx b/src/renderer/components/Experiment/Foundation/SelectAModel.tsx\nindex dbdec79f8..8a390c72b 100644\n--- a/src/renderer/components/Experiment/Foundation/SelectAModel.tsx\n+++ b/src/renderer/components/Experiment/Foundation/SelectAModel.tsx\n@@ -62,6 +62,7 @@ export default function SelectAModel({\n         mutateModels={mutate}\n         setFoundation={setFoundation}\n         setAdaptor={setAdaptor}\n+        experimentInfo={experimentInfo}\n         pickAModelMode\n       />\n     </Sheet>\ndiff --git a/src/renderer/components/Experiment/SelectButton.tsx b/src/renderer/components/Experiment/SelectButton.tsx\nindex 1d5278c12..86592f6ba 100644\n--- a/src/renderer/components/Experiment/SelectButton.tsx\n+++ b/src/renderer/components/Experiment/SelectButton.tsx\n@@ -1,17 +1,79 @@\n /* eslint-disable jsx-a11y/anchor-is-valid */\n import * as React from 'react';\n-\n import { Button, CircularProgress } from '@mui/joy';\n+import * as chatAPI from '../../lib/transformerlab-api-sdk';\n+\n+interface SelectButtonProps {\n+  setFoundation: (model: any) => void;\n+  model: any;\n+  setAdaptor: (name: string) => void;\n+  setEmbedding?: (model: any) => void;\n+  experimentInfo?: any;\n+}\n \n export default function SelectButton({\n   setFoundation,\n   model,\n   setAdaptor,\n   setEmbedding,\n-}) {\n+  experimentInfo,\n+}: SelectButtonProps) {\n   const [selected, setSelected] = React.useState(false);\n \n-  const name = model.id;\n+  // Helper to get architecture from model object\n+  function getModelArchitecture(m: any) {\n+    return m?.json_data?.architecture || m?.architecture || '';\n+  }\n+\n+  // Helper to get experiment id\n+  function getExperimentId() {\n+    return experimentInfo?.id;\n+  }\n+\n+  async function handleSelect() {\n+    if (setEmbedding) {\n+      setEmbedding(model);\n+      return;\n+    }\n+    setSelected(true);\n+    setFoundation(model);\n+    setAdaptor('');\n+\n+    const experimentId = getExperimentId();\n+    const modelArchitecture = getModelArchitecture(model);\n+    if (!experimentId || !modelArchitecture) {\n+      setSelected(false);\n+      return;\n+    }\n+    try {\n+      // Fetch compatible inference engines\n+      const url = chatAPI.Endpoints.Experiment.ListScriptsOfType(\n+        experimentId,\n+        'loader',\n+        `model_architectures:${modelArchitecture}`,\n+      );\n+\n+      const resp = await fetch(url);\n+      const engines = await resp.json();\n+      if (engines && engines.length > 0) {\n+        const engine = engines[0];\n+        // Update inferenceParams in experiment config\n+        await fetch(\n+          chatAPI.Endpoints.Experiment.UpdateConfig(\n+            experimentId,\n+            'inferenceParams',\n+            JSON.stringify({\n+              inferenceEngine: engine.uniqueId,\n+              inferenceEngineFriendlyName: engine.name || '',\n+            }),\n+          ),\n+        );\n+      }\n+    } catch (e) {\n+      // fail silently, user can still set engine manually\n+    }\n+    setSelected(false);\n+  }\n \n   return selected ? (\n     <Button\n@@ -25,21 +87,13 @@ export default function SelectButton({\n       Loading Model\n     </Button>\n   ) : (\n-    <Button\n-      size=\"sm\"\n-      variant=\"soft\"\n-      color=\"success\"\n-      onClick={() => {\n-        if (setEmbedding) {\n-          setEmbedding(model);\n-        } else {\n-          setSelected(true);\n-          setFoundation(model);\n-          setAdaptor('');\n-        }\n-      }}\n-    >\n+    <Button size=\"sm\" variant=\"soft\" color=\"success\" onClick={handleSelect}>\n       Select\n     </Button>\n   );\n }\n+\n+SelectButton.defaultProps = {\n+  setEmbedding: undefined,\n+  experimentInfo: undefined,\n+};\ndiff --git a/src/renderer/components/ModelZoo/LocalModelsTable.tsx b/src/renderer/components/ModelZoo/LocalModelsTable.tsx\nindex b5dfeb244..598ebd7c6 100644\n--- a/src/renderer/components/ModelZoo/LocalModelsTable.tsx\n+++ b/src/renderer/components/ModelZoo/LocalModelsTable.tsx\n@@ -40,6 +40,7 @@ const LocalModelsTable = ({\n   pickAModelMode = false,\n   showOnlyGeneratedModels = false,\n   isEmbeddingMode = false,\n+  experimentInfo = null,\n }) => {\n   const [order, setOrder] = useState<Order>('desc');\n   const [searchText, setSearchText] = useState('');\n@@ -255,6 +256,7 @@ const LocalModelsTable = ({\n                           setAdaptor={setAdaptor}\n                           setEmbedding={setEmbedding}\n                           model={row}\n+                          experimentInfo={experimentInfo}\n                         />\n                       ) : (\n                         <>\n", "test_patch": "", "problem_statement": "Loading Ollama models fail to load a default server\nMacOS 15.3\nTransformer.Lab updated, running on the machine where the models are located\n\nWhen we load a Local Ollama model on Foundation, no server is loaded by default, resultan on error when running the model\n\nThe ollama model is working on ollama (macOS app) and with OpenWebUi or Perplexica running on Docker in the same machine\n\nSelecting manually ollama server vives a normal behaviour\nOrder inference servers so it defaults to the last one used\nCurrently when you go to the Foundation page, if there are multiple inference servers available it orders them in some unspecified way (possibly alphabetical).  This is annoying because the order never changes and it always defaults to the same server even if that's not a server you ever use.\n\nFor example, I have llama_cpp_server and ollama_server installed and it always selected llama_cpp_server even though I never use it. Every time I stop my model it switches back to llama_cpp_server.\n\n", "hints_text": "Hi @delfireinoso, \nSorry for completely missing this issue, we will test this out and get back on how we can solve this one. \nOh hmmm I thought this issue was the same as this one: https://github.com/transformerlab/transformerlab-app/issues/329\n\nBut htat is possibly not the case.  But I think fixing the other issue will also fix this one.\n\n\n\n\n\n", "all_hints_text": "Hi @delfireinoso, \nSorry for completely missing this issue, we will test this out and get back on how we can solve this one. \nOh hmmm I thought this issue was the same as this one: https://github.com/transformerlab/transformerlab-app/issues/329\n\nBut htat is possibly not the case.  But I think fixing the other issue will also fix this one.\n\n\n\n\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/b2eda588e47f00141f627023324b398741bc95f7", "https://github.com/transformerlab/transformerlab-app/commit/412b07908f30ad9f74b03fd2b40c993e1a0f1392", "https://github.com/transformerlab/transformerlab-app/commit/ab423fa1f8d15cc485d31c94fd6d7047c1444b3e", "https://github.com/transformerlab/transformerlab-app/commit/ae87ee910e1071502299a0fa6aae02e07d86fa28"], "created_at": "2025-05-02T21:22:44Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 849, "instance_id": "transformerlab__transformerlab-app-849", "issue_numbers": [294], "base_commit": "99890b954cf60fcd404a2b18b9bf16b52dcc88e7", "patch": "diff --git a/src/main/util.ts b/src/main/util.ts\nindex 104bb00d3..f96d88c82 100644\n--- a/src/main/util.ts\n+++ b/src/main/util.ts\n@@ -258,7 +258,8 @@ export function killLocalServer() {\n \n export async function checkIfCurlInstalled() {\n   try {\n-    const { stdout, stderr } = await awaitExec('curl --version');\n+    const cmd = isPlatformWindows() ? 'wsl curl --version' : 'curl --version';\n+    const { stdout, stderr } = await awaitExec(cmd);\n     if (stderr) {\n       console.error(`stderr: ${stderr}`);\n       return false;\n@@ -289,8 +290,12 @@ export async function installLocalServer() {\n   // First check if curl is installed on the client machine:\n   const curlInstalled = await checkIfCurlInstalled();\n   if (!curlInstalled) {\n+    const message = isPlatformWindows()\n+      ? 'Curl was not found inside WSL. On Windows the installer runs inside WSL \u2014 please install curl inside your WSL distro and try again.\\n\\nExample (Ubuntu WSL):\\n  sudo apt update && sudo apt install -y curl'\n+      : 'Curl is not installed. Please install curl and try again.\\n\\nExamples:\\n  macOS (Homebrew): brew install curl\\n  Ubuntu/Debian: sudo apt update && sudo apt install -y curl';\n     dialog.showMessageBox({\n-      message: 'Curl is not installed. Please install curl and try again.',\n+      type: 'error',\n+      message: message,\n     });\n     return;\n   }\n", "test_patch": "", "problem_statement": "Make Error more Clear when Curl not installed\nRight now, in windows, the app requires curl to download the installer. But we only check if curl is installed once the installer is run in the API install script. Show an error earlier (in the App)\n\n![Image](https://github.com/user-attachments/assets/0e27c9f0-364b-4494-a293-12c1884ba86c)\n", "hints_text": "This is a windows problem only. We do check if curl is installed on the client machine (but this is not right for Windows since the CURL call originates from within WSL on windows) https://github.com/transformerlab/transformerlab-app/blob/266fcc31440a2041bda76addb5936a506ddf158b/src/main/util.ts#L245\nHey @aliasaria, Can you assign me this issue ? \nSorry we missed this. Done!\nThanks\nHey @VineeTagarwaL-code, \nJust following up to see if you were still interested in working on this issue?\nYes\nHi @VineeTagarwaL-code, \nI am opening this issue up for others to work on since its been 2 months with no activity. \nPlease ping us back if you end up working on this!\n\n", "all_hints_text": "This is a windows problem only. We do check if curl is installed on the client machine (but this is not right for Windows since the CURL call originates from within WSL on windows) https://github.com/transformerlab/transformerlab-app/blob/266fcc31440a2041bda76addb5936a506ddf158b/src/main/util.ts#L245\nHey @aliasaria, Can you assign me this issue ? \nSorry we missed this. Done!\nThanks\nHey @VineeTagarwaL-code, \nJust following up to see if you were still interested in working on this issue?\nYes\nHi @VineeTagarwaL-code, \nI am opening this issue up for others to work on since its been 2 months with no activity. \nPlease ping us back if you end up working on this!\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/05d40f5ff9859501e6bf1073a1486c27a324c563", "https://github.com/transformerlab/transformerlab-app/commit/4b77f959f0ab3623f3966a2af209ca350bfe04a2", "https://github.com/transformerlab/transformerlab-app/commit/971ea9662c05daa8e99fd2cf5cd56068d33547c6", "https://github.com/transformerlab/transformerlab-app/commit/556b55f9e511ecc507c9352590028c9abbfbe862", "https://github.com/transformerlab/transformerlab-app/commit/c95ca9133ff62f3c4e1d5949e1646bdf236e1506"], "created_at": "2025-11-03T09:34:32Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 668, "instance_id": "transformerlab__transformerlab-app-668", "issue_numbers": [352], "base_commit": "d80892f3e265ded620060bb2dc9aa05073329211", "patch": "diff --git a/src/renderer/components/Experiment/Export/ViewOutputModalStreaming.tsx b/src/renderer/components/Experiment/Export/ViewOutputModalStreaming.tsx\nindex f5af6ce14..9ff5446bd 100644\n--- a/src/renderer/components/Experiment/Export/ViewOutputModalStreaming.tsx\n+++ b/src/renderer/components/Experiment/Export/ViewOutputModalStreaming.tsx\n@@ -36,15 +36,12 @@ export default function ViewOutputModalStreaming({\n     { refreshInterval: 2000 },\n   );\n \n-  // Create a custom endpoint for export job output\n-  const experimentId =\n-    jobDetails?.experiment_id || jobDetails?.job_data?.experiment_id;\n-  const outputEndpoint = experimentId\n-    ? `${API_URL()}experiment/${experimentId}/export/job/${jobId}/stream_output`\n-    : chatAPI.Endpoints.Experiment.StreamOutputFromJob(jobId);\n+  // // Create a custom endpoint for export job output\n+  const outputEndpoint =\n+    chatAPI.Endpoints.Experiment.StreamOutputFromJob(jobId);\n \n   return (\n-    <Modal open={jobId != -1} onClose={() => setJobId(-1)}>\n+    <Modal open={jobId !== -1} onClose={() => setJobId(-1)}>\n       <ModalDialog sx={{ width: '80vw', height: '80vh' }}>\n         <ModalClose />\n         <Typography level=\"title-lg\">Output from job: {jobId}</Typography>\ndiff --git a/src/renderer/components/Experiment/Train/ViewOutputModalStreaming.tsx b/src/renderer/components/Experiment/Train/ViewOutputModalStreaming.tsx\nindex 41fd6d84d..9d4b6aabb 100644\n--- a/src/renderer/components/Experiment/Train/ViewOutputModalStreaming.tsx\n+++ b/src/renderer/components/Experiment/Train/ViewOutputModalStreaming.tsx\n@@ -136,7 +136,7 @@ export default function ViewOutputModalStreaming({\n               }}\n             >\n               <OutputTerminal\n-                logEndpoint={chatAPI.Endpoints.Experiment.StreamOutputFromTrainingJob(\n+                logEndpoint={chatAPI.Endpoints.Experiment.StreamOutputFromJob(\n                   jobId,\n                   sweeps,\n                 )}\ndiff --git a/src/renderer/components/Experiment/Workflows/WorkflowRuns/JobDetails.tsx b/src/renderer/components/Experiment/Workflows/WorkflowRuns/JobDetails.tsx\nindex 424e566c5..33080c787 100644\n--- a/src/renderer/components/Experiment/Workflows/WorkflowRuns/JobDetails.tsx\n+++ b/src/renderer/components/Experiment/Workflows/WorkflowRuns/JobDetails.tsx\n@@ -1,5 +1,12 @@\n import { useState } from 'react';\n-import { Modal, Box, Typography, ModalDialog, ModalClose, Table } from '@mui/joy';\n+import {\n+  Modal,\n+  Box,\n+  Typography,\n+  ModalDialog,\n+  ModalClose,\n+  Table,\n+} from '@mui/joy';\n import * as chatAPI from '../../../../lib/transformerlab-api-sdk';\n \n import useSWR from 'swr';\n@@ -116,13 +123,9 @@ export default function JobDetails({ jobId, onClose }) {\n               }}\n             >\n               <OutputTerminal\n-                logEndpoint={\n-                  data?.type === 'TRAIN'\n-                    ? chatAPI.Endpoints.Experiment.StreamOutputFromTrainingJob(\n-                        data?.id,\n-                      )\n-                    : chatAPI.Endpoints.Experiment.StreamOutputFromJob(data?.id)\n-                }\n+                logEndpoint={chatAPI.Endpoints.Experiment.StreamOutputFromJob(\n+                  data?.id,\n+                )}\n                 lineAnimationDelay={1}\n               />\n             </Box>\ndiff --git a/src/renderer/lib/api-client/endpoints.ts b/src/renderer/lib/api-client/endpoints.ts\nindex 2d047ab8f..853256088 100644\n--- a/src/renderer/lib/api-client/endpoints.ts\n+++ b/src/renderer/lib/api-client/endpoints.ts\n@@ -346,12 +346,6 @@ Endpoints.Experiment = {\n       pluginName\n     }&plugin_architecture=${pluginArchitecture}&plugin_params=${pluginParams}`;\n   },\n-  GetExportJobs: (id: string) => {\n-    return `${API_URL()}experiment/${id}/export/jobs`;\n-  },\n-  GetExportJobDetails: (experimentId: string, jobId: string) => {\n-    return `${API_URL()}experiment/${experimentId}/export/job?jobId=${jobId}`;\n-  },\n   SaveConversation: (experimentId: String) =>\n     `${API_URL()}experiment/${experimentId}/conversations/save`,\n   GetConversations: (experimentId: string) =>\n@@ -413,10 +407,8 @@ Endpoints.Experiment = {\n       pluginId\n     }`,\n   GetOutputFromJob: (jobId: string) => `${API_URL()}train/job/${jobId}/output`,\n-  StreamOutputFromTrainingJob: (jobId: string, sweep: boolean = false) =>\n-    `${API_URL()}train/job/${jobId}/stream_output?sweeps=${sweep}`,\n-  StreamOutputFromJob: (jobId: string) =>\n-    `${API_URL()}jobs/${jobId}/stream_output`,\n+  StreamOutputFromJob: (jobId: string, sweep: boolean = false) =>\n+    `${API_URL()}jobs/${jobId}/stream_output?sweeps=${sweep}`,\n   StreamDetailedJSONReportFromJob: (jobId: string, fileName: string) =>\n     `${API_URL()}jobs/${jobId}/stream_detailed_json_report?file_name=${fileName}`,\n   GetAdditionalDetails: (jobId: string, task: string = 'view') =>\n", "test_patch": "", "problem_statement": "Terminal error if you try to import models and don't have Ollama installed\nThe app is trying to look for ollama models even if you don't have Ollama installed when you click on Import Models in the Model Zoo.\n\n```\nFailed to locate Ollama models library:\n[Errno 2] No such file or directory: 'Ollama models directory'\n```\n", "hints_text": "\n\n", "all_hints_text": "I will take this up and start looking into it\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/05d3e1bc7c9e16e09fe6407f07ec08d5baea7dba", "https://github.com/transformerlab/transformerlab-app/commit/7c6e709f46035d0ac44e899cb836894540cb1621", "https://github.com/transformerlab/transformerlab-app/commit/aff2a755a7f21ca4d74e63761d0e171730dea211"], "created_at": "2025-07-15T20:28:18Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 430, "instance_id": "transformerlab__transformerlab-app-430", "issue_numbers": [420], "base_commit": "283badb9a14b4eaf742d83308c907f557a8fd001", "patch": "diff --git a/src/renderer/components/MainAppPanel.tsx b/src/renderer/components/MainAppPanel.tsx\nindex 937109970..d342f5a9b 100644\n--- a/src/renderer/components/MainAppPanel.tsx\n+++ b/src/renderer/components/MainAppPanel.tsx\n@@ -472,7 +472,12 @@ export default function MainAppPanel({\n         />\n         <Route\n           path=\"/plugins\"\n-          element={<Plugins experimentInfo={experimentInfo} />}\n+          element={\n+            <Plugins\n+              experimentInfo={experimentInfo}\n+              setLogsDrawerOpen={setLogsDrawerOpen}\n+            />\n+          }\n         />\n         <Route\n           path=\"/plugins/:pluginName\"\ndiff --git a/src/renderer/components/Plugins/LocalPlugins.tsx b/src/renderer/components/Plugins/LocalPlugins.tsx\nindex bc07ea78d..aaf1b9eb5 100644\n--- a/src/renderer/components/Plugins/LocalPlugins.tsx\n+++ b/src/renderer/components/Plugins/LocalPlugins.tsx\n@@ -18,7 +18,10 @@ import NewPluginModal from './NewPluginModal';\n \n const fetcher = (url) => fetch(url).then((res) => res.json());\n \n-export default function LocalPlugins({ experimentInfo }) {\n+export default function LocalPlugins({\n+  experimentInfo,\n+  setLogsDrawerOpen = null,\n+}) {\n   const [newPluginModalOpen, setNewPluginModalOpen] = useState(false);\n \n   const { data, error, isLoading, mutate } = useSWR(\n@@ -77,6 +80,7 @@ export default function LocalPlugins({ experimentInfo }) {\n                 download={undefined}\n                 experimentInfo={experimentInfo}\n                 machineType={device}\n+                setLogsDrawerOpen={setLogsDrawerOpen}\n               />\n             </Grid>\n           ))}\ndiff --git a/src/renderer/components/Plugins/PluginCard.tsx b/src/renderer/components/Plugins/PluginCard.tsx\nindex c81a710f9..4b3732215 100644\n--- a/src/renderer/components/Plugins/PluginCard.tsx\n+++ b/src/renderer/components/Plugins/PluginCard.tsx\n@@ -83,6 +83,7 @@ export default function PluginCard({\n   parentMutate,\n   experimentInfo = {},\n   machineType,\n+  setLogsDrawerOpen = null,\n }) {\n   const [installing, setInstalling] = useState(null);\n \n@@ -239,7 +240,24 @@ export default function PluginCard({\n                   experimentInfo?.id,\n                   plugin.uniqueId,\n                 ),\n-              );\n+              ).then(async (response) => {\n+                if (response.ok) {\n+                  const responseBody = await response.json();\n+                  console.log('Response Body:', responseBody);\n+                  if (responseBody?.status == 'error') {\n+                    alert(\n+                      `Failed to install plugin:\\n${responseBody?.message}`,\n+                    );\n+                    if (setLogsDrawerOpen) {\n+                      setLogsDrawerOpen(true);\n+                    }\n+                  }\n+                } else {\n+                  alert(\n+                    'Error: The API did not return a response. Plugin installation failed.',\n+                  );\n+                }\n+              });\n               setInstalling(null);\n               parentMutate();\n             }}\ndiff --git a/src/renderer/components/Plugins/PluginGallery.tsx b/src/renderer/components/Plugins/PluginGallery.tsx\nindex fb5639fea..020213e8a 100644\n--- a/src/renderer/components/Plugins/PluginGallery.tsx\n+++ b/src/renderer/components/Plugins/PluginGallery.tsx\n@@ -22,7 +22,10 @@ import PluginCard from './PluginCard';\n \n const fetcher = (url) => fetch(url).then((res) => res.json());\n \n-export default function PluginGallery({ experimentInfo }) {\n+export default function PluginGallery({\n+  experimentInfo,\n+  setLogsDrawerOpen = null,\n+}) {\n   const { data, error, isLoading, mutate } = useSWR(\n     chatAPI.Endpoints.Plugins.Gallery(),\n     fetcher,\n@@ -187,6 +190,7 @@ export default function PluginGallery({ experimentInfo }) {\n                       experimentInfo={experimentInfo}\n                       parentMutate={mutate}\n                       machineType={device}\n+                      setLogsDrawerOpen={setLogsDrawerOpen}\n                     />\n                   </Grid>\n                 ))}\n@@ -220,6 +224,7 @@ export default function PluginGallery({ experimentInfo }) {\n                           experimentInfo={experimentInfo}\n                           parentMutate={mutate}\n                           machineType={device}\n+                          setLogsDrawerOpen={setLogsDrawerOpen}\n                         />\n                       </Box>\n                     </Grid>\ndiff --git a/src/renderer/components/Plugins/Plugins.tsx b/src/renderer/components/Plugins/Plugins.tsx\nindex 67e84502d..f31118f67 100644\n--- a/src/renderer/components/Plugins/Plugins.tsx\n+++ b/src/renderer/components/Plugins/Plugins.tsx\n@@ -18,7 +18,7 @@ import PluginGallery from './PluginGallery';\n import LocalPlugins from './LocalPlugins';\n import OneTimePopup from '../Shared/OneTimePopup';\n \n-export default function Plugins({ experimentInfo }) {\n+export default function Plugins({ experimentInfo, setLogsDrawerOpen = null }) {\n   const { data: outdatedPlugins, mutate: outdatePluginsMutate } =\n     usePluginStatus(experimentInfo);\n   const [installing, setInstalling] = useState(null);\n@@ -114,7 +114,10 @@ export default function Plugins({ experimentInfo }) {\n           <Sheet\n             sx={{ display: 'flex', flexDirection: 'column', height: '100%' }}\n           >\n-            <LocalPlugins experimentInfo={experimentInfo} />\n+            <LocalPlugins\n+              experimentInfo={experimentInfo}\n+              setLogsDrawerOpen={setLogsDrawerOpen}\n+            />\n           </Sheet>\n         </TabPanel>\n         <TabPanel\n@@ -128,7 +131,10 @@ export default function Plugins({ experimentInfo }) {\n           <Sheet\n             sx={{ display: 'flex', flexDirection: 'column', height: '100%' }}\n           >\n-            <PluginGallery experimentInfo={experimentInfo} />\n+            <PluginGallery\n+              experimentInfo={experimentInfo}\n+              setLogsDrawerOpen={setLogsDrawerOpen}\n+            />\n           </Sheet>\n         </TabPanel>\n       </Tabs>\n", "test_patch": "", "problem_statement": "Notify user if plugin installation fails\nCurrently when you install a plugin it just spins until the installer does and gives no feedback on whether it succeeded or not.\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/208f1d829cc343340a075d191aea371d9a44ad8b", "https://github.com/transformerlab/transformerlab-app/commit/e63d7c6d37a306d399116eac52afeb799c5bbcd1"], "created_at": "2025-05-02T21:19:40Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 263, "instance_id": "transformerlab__transformerlab-app-263", "issue_numbers": [422], "base_commit": "fcdaf03adffdd98c94cf251a70c03f70a239f292", "patch": "diff --git a/src/renderer/components/ModelZoo/ModelStore.tsx b/src/renderer/components/ModelZoo/ModelStore.tsx\nindex 184d379f8..f66ed7b27 100644\n--- a/src/renderer/components/ModelZoo/ModelStore.tsx\n+++ b/src/renderer/components/ModelZoo/ModelStore.tsx\n@@ -102,6 +102,7 @@ export default function ModelStore() {\n   // and it is -1 if a download has been initiated but it hasn't started yet\n   const [jobId, setJobId] = useState(null);\n   const [currentlyDownloading, setCurrentlyDownloading] = useState(null);\n+  const [canceling, setCanceling] = useState(false);\n   const [modelDetailsId, setModelDetailsId] = useState(null);\n   const [searchText, setSearchText] = useState('');\n   const [filters, setFilters] = useState({ archived: false });\n@@ -223,8 +224,51 @@ export default function ModelStore() {\n         flexDirection: 'column',\n         overflow: 'hidden',\n       }}\n-    >\n-      <DownloadProgressBox jobId={jobId} assetName={currentlyDownloading} />\n+      >\n+      <Box\n+        sx={{\n+          position: 'relative',\n+          margin: '0.5rem 0 1rem 0',\n+          width: '100%',\n+        }}\n+      >\n+        <DownloadProgressBox jobId={jobId} assetName={currentlyDownloading} />\n+        {jobId && (\n+          <Button\n+            variant=\"outlined\"\n+            size=\"sm\"\n+            color=\"danger\"\n+            disabled={canceling}\n+            onClick={async () => {\n+              setCanceling(true);\n+              try {\n+                let response = await fetch(chatAPI.Endpoints.Jobs.Stop(jobId));\n+                if (response.ok) {\n+                  setJobId(null);\n+                  setCurrentlyDownloading(null);\n+                } else {\n+                  console.error('Failed to cancel download:', response);\n+                  alert('Failed to cancel download');\n+                  setCanceling(false);\n+                }\n+              } catch (error) {\n+                console.error('Error canceling download:', error);\n+                alert('Error canceling download');\n+                setCanceling(false);\n+              }\n+            }}\n+            sx={{\n+              position: 'absolute',\n+              top: '1rem',\n+              right: '1rem',\n+              fontSize: '0.75rem',\n+              padding: '0.25rem 0.5rem',\n+            }}\n+          >\n+            {canceling ? 'Stopping..' : 'Cancel Download'}\n+          </Button>\n+        )}\n+      </Box>\n       <Box\n         className=\"SearchAndFilters-tabletUp\"\n         sx={{\n", "test_patch": "", "problem_statement": "NVIDIA GeForce RTX 5090 Support\nNVIDIA 5090's require an updated PyTorch to get CUDA 12.8. This issue is to track the work required to make sure we work on 5090's.\n\nTransformer Lab currently installs CUDA 12.1 using `conda` in install.sh https://github.com/transformerlab/transformerlab-api/blob/main/install.sh\n\nMore documentation:\n\nhttps://docs.salad.com/tutorials/pytorch-rtx5090\n\nhttps://github.com/pytorch/pytorch/issues/145949\n\nhttps://forums.developer.nvidia.com/t/software-migration-guide-for-nvidia-blackwell-rtx-gpus-a-guide-to-cuda-12-8-pytorch-tensorrt-and-llama-cpp/321330\n\nWe need to investigate:\n- Upgrading CUDA for everyone -- will any existing plugins break? Certain tools like vLLM, FlashAttention2 etc are known to be weird with specific CUDA versions\n- Upgrading CUDA to 12.1 just for 5090 users -- how would we do this? What will work and what wont?\n\n", "hints_text": "\n\n", "all_hints_text": "From vLLM docs:\n\nhttps://docs.vllm.ai/en/stable/getting_started/installation/gpu.html\n\nAs of now, vLLM\u2019s binaries are compiled with CUDA 12.4 and public PyTorch release versions by default. We also provide vLLM binaries compiled with CUDA 12.1, 11.8, and public PyTorch release versions\n\nvLLM is not a required part of our platform (it is only supported in a specific plugin) but it would be nice if we could still support it.\nFrom FlashAttention2\nhttps://github.com/Dao-AILab/flash-attention\n\nWe highly recommend CUDA 12.8 for best performance. (when discussing  H100 / H800 GPU but probably applies to all GPUs)\n\n\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/6f2e1e1f88510725647c9cd11170c29c561cb772", "https://github.com/transformerlab/transformerlab-app/commit/f186bcb7bd20aeca8c4495851a2314a4868ddb91"], "created_at": "2025-02-20T18:34:46Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 267, "instance_id": "transformerlab__transformerlab-app-267", "issue_numbers": [432], "base_commit": "b947ef47075c314b32ed42019a4e8da2d3387b7f", "patch": "diff --git a/src/renderer/components/Experiment/Rag/Documents.tsx b/src/renderer/components/Experiment/Rag/Documents.tsx\nindex 28cf6a116..6a84c3251 100644\n--- a/src/renderer/components/Experiment/Rag/Documents.tsx\n+++ b/src/renderer/components/Experiment/Rag/Documents.tsx\n@@ -140,6 +140,7 @@ export default function Documents({\n   experimentInfo,\n   fullPage = false,\n   additionalMessage = false,\n+  fixedFolder = '',\n }) {\n   const [doc, setDoc] = React.useState<Doc>('desc');\n   const [selected, setSelected] = React.useState<readonly string[]>([]);\n@@ -154,13 +155,7 @@ export default function Documents({\n \n   const [loading, setLoading] = React.useState(false);\n \n-  const [currentFolder, setCurrentFolder] = React.useState('');\n-\n-  React.useEffect(() => {\n-    if (!additionalMessage) {\n-      setCurrentFolder('rag');\n-    }\n-  }, [additionalMessage]);\n+  const [currentFolder, setCurrentFolder] = React.useState(fixedFolder);\n \n   const {\n     data: rows,\n@@ -405,6 +400,10 @@ export default function Documents({\n       </FormControl>\n     </React.Fragment>\n   );\n+\n+  /****\n+   * Main Documents Component is Here\n+   */\n   return (\n     <>\n       <Modal\n@@ -470,9 +469,9 @@ export default function Documents({\n           ) : (\n             <>\n               <Link\n+                disabled={fixedFolder !== ''}\n                 onClick={() => {\n-                  additionalMessage? setCurrentFolder('') :\n-                  setCurrentFolder('rag');\n+                  setCurrentFolder('');\n                 }}\n               >\n                 Documents /\n@@ -712,6 +711,11 @@ export default function Documents({\n                   </tr>\n                 </thead>\n                 <tbody>\n+                  {rows?.status == 'error' && (\n+                    <tr>\n+                      <td colSpan={2}>{/*rows?.message*/}</td>\n+                    </tr>\n+                  )}\n                   {rows?.length == 0 && (\n                     <tr>\n                       <td colSpan={2} style={{ padding: '2rem' }}>\n@@ -745,7 +749,8 @@ export default function Documents({\n       </Stack>\n       {additionalMessage && (\n         <Typography level=\"body-xs\" mt={1}>\n-          Documents for RAG should be uploaded in a folder called \"rag\" and only those will be indexed for RAG.\n+          Documents for RAG should be uploaded in a folder called \"rag\" and only\n+          those will be indexed for RAG.\n         </Typography>\n       )}\n     </>\ndiff --git a/src/renderer/components/Experiment/Rag/index.tsx b/src/renderer/components/Experiment/Rag/index.tsx\nindex e008b8d7c..06665de77 100644\n--- a/src/renderer/components/Experiment/Rag/index.tsx\n+++ b/src/renderer/components/Experiment/Rag/index.tsx\n@@ -117,7 +117,7 @@ export default function DocumentSearch({ experimentInfo, setRagEngine }) {\n             flexDirection: 'column',\n           }}\n         >\n-          <Documents experimentInfo={experimentInfo} />\n+          <Documents experimentInfo={experimentInfo} fixedFolder=\"rag\" />\n         </Box>\n         <Box sx={{ flex: 1, display: 'flex', flexDirection: 'column' }}>\n           <Query experimentInfo={experimentInfo} />\n", "test_patch": "", "problem_statement": "Llama CPP failures on CPU only machines\nLlama CPP Server fails to build on CPU-only machines. \nNote that the error comes out of torch, which might mean that we need requirements for a torch cpu only build\n\n![Image](https://github.com/user-attachments/assets/b7da40c4-3e45-41d8-8643-5f00a3eed540)\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/8ab60eec0ef2bc1a0a880f4cc0b2f9a1f5b1b06e", "https://github.com/transformerlab/transformerlab-app/commit/29ad72a6fd23fe2acea2a5b5b65b9e1107500d3a", "https://github.com/transformerlab/transformerlab-app/commit/faf55b47733804eb7dc97e73698b67a6476920b1", "https://github.com/transformerlab/transformerlab-app/commit/26b3578fcccb647e3f0b9d0e212b8e8981589a3d", "https://github.com/transformerlab/transformerlab-app/commit/85ffee036ad3972d5bb64efc2367192f33bb5588"], "created_at": "2025-02-21T20:52:03Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 1, "instance_id": "transformerlab__transformerlab-app-1", "issue_numbers": [436], "base_commit": "b474bf3e7d5e9ae14ceea761ebae3691a8bc08dc", "patch": "diff --git a/package-lock.json b/package-lock.json\nindex e55462eed..c447b08d1 100644\n--- a/package-lock.json\n+++ b/package-lock.json\n@@ -133,9 +133,9 @@\n       }\n     },\n     \"node_modules/@adobe/css-tools\": {\n-      \"version\": \"4.3.1\",\n-      \"resolved\": \"https://registry.npmjs.org/@adobe/css-tools/-/css-tools-4.3.1.tgz\",\n-      \"integrity\": \"sha512-/62yikz7NLScCGAAST5SHdnjaDJQBDq0M2muyRTpf2VQhw6StBg2ALiu73zSJQ4fMVLA+0uBhBHAle7Wg+2kSg==\",\n+      \"version\": \"4.3.2\",\n+      \"resolved\": \"https://registry.npmjs.org/@adobe/css-tools/-/css-tools-4.3.2.tgz\",\n+      \"integrity\": \"sha512-DA5a1C0gD/pLOvhv33YMrbf2FK3oUzwNl9oOJqE4XVjuEtt6XIakRcsd7eLiOSPkp1kTRQGICTA8cKra/vFbjw==\",\n       \"dev\": true\n     },\n     \"node_modules/@ampproject/remapping\": {\n", "test_patch": "", "problem_statement": "MLX Server plugin - how to modify the default context length of 2048\nI see that the MLX Server plugin by default uses 2048 context length if the same is not available in the huggingface config file of the corresponding model. What is the best way to change this value other than implementing a custom plugin? \n\nAlso wondering why do we even need to set this instead of letting the users control the context length as long as the model supports it even if not mentioned in the config file?\n", "hints_text": "\n\n", "all_hints_text": "Hi, \nThis is based on FastChat's original implementation. You're right that it might be beneficial to make the context-length part configurable to the users incase the model doesn't specify the context length. We'll discuss and try to add this. \nIn the meantime, was there a specific model that you were trying to use that is blocked by this? Maybe I can help provide a temporary fix for you in the meanwhile\nThanks, I did not get a chance to respond but looks like the issue is already fixed. I will check that out\nThe fix will be included in the next API release, so please be on the lookout for the version after v0.15.3 and you'll see the option in config now\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/05a922dfb7d0823ffc3eb439387689dec82d6210"], "created_at": "2024-01-10T20:51:04Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 444, "instance_id": "transformerlab__transformerlab-app-444", "issue_numbers": [439], "base_commit": "dfe9a10b58432074177a3303bdfa54474ab2eab3", "patch": "diff --git a/src/renderer/components/Data/DatasetCard.tsx b/src/renderer/components/Data/DatasetCard.tsx\nindex 127030e89..e05c5d5e1 100644\n--- a/src/renderer/components/Data/DatasetCard.tsx\n+++ b/src/renderer/components/Data/DatasetCard.tsx\n@@ -30,6 +30,7 @@ export default function DatasetCard({\n   location,\n   parentMutate,\n   local,\n+  friendlyName = null,\n }) {\n   const [installing, setInstalling] = useState(null);\n   const [previewDatasetModalOpen, setPreviewDatasetModalOpen] = useState(false);\n@@ -60,7 +61,7 @@ export default function DatasetCard({\n               sx={{ mb: 2, overflow: 'clip' }}\n               startDecorator={<FileTextIcon />}\n             >\n-              <b>{name}</b>&nbsp;\n+              <b>{friendlyName || name}</b>&nbsp;\n               {location === 'huggingfacehub' && ' \ud83e\udd17'}\n               {location === 'local' && ' '}\n             </Typography>\ndiff --git a/src/renderer/components/Data/LocalDatasets.tsx b/src/renderer/components/Data/LocalDatasets.tsx\nindex 30545bba4..12b3ec5b5 100644\n--- a/src/renderer/components/Data/LocalDatasets.tsx\n+++ b/src/renderer/components/Data/LocalDatasets.tsx\n@@ -111,7 +111,8 @@ export default function LocalDatasets() {\n             filterByFiltersDatasetID(data, searchText).map((row) => (\n               <Grid xs={4}>\n                 <DatasetCard\n-                  name={(() => {\n+                  name={row?.dataset_id}\n+                  friendlyName={(() => {\n                     try {\n                       return (\n                         (row?.json_data && JSON.parse(row.json_data)?.name) ||\n", "test_patch": "", "problem_statement": "Datasets: Local and Generated raise error\nA generic: \"An error has occured.\" message appears when Local Datasets ogr Generated window are opened.\nMoreover:\n\n-  how can we download datasets not included in Dataset Store?\n- Datasets download from Dataset Store fail with Error 500\nUsing latest version of Transformer Lab\n\n", "hints_text": "Hi @ivanfioravanti . First of all, sorry for the error.\n\nThis error that you're seeing usually occurs when the App calls to the API but gets an error back. See here for example: https://github.com/transformerlab/transformerlab-app/blob/723b49ed88d103c55c6adc16fa140cdd0affd2b7/src/renderer/components/Data/DataStore.tsx#L28\n\nSo to find the underlying issue, the best thing would be to look at the `~/.transformerlab/local_server.log` and see if you see any errors that look like an error in python / FastAPI -- this will help us figure out what in your Datastore endpoint is causing a failure. Happy to jump on a quick screenshare (or help live on Discord) if that helps too.\n\nFor how to add Datasets, in the bottom of the Local Datasets page there is a field to type the name of the Dataset and you can press Download. Or you can click on \"New +\" to drag and drop files directly\nAdding on this to answer your question about downloading datasets:\n- To download datasets not in the Dataset Store, you can just use the button at the bottom left of your screen when you're on the Local Datasets tab.\n\n![Image](https://github.com/user-attachments/assets/6634b313-3ae0-4190-8c0c-9cfa40b38329)\n\n\nThere is also an option to add your custom datasets (the `New +` button to the right of the huggingface download option), if you need that as well:\n\n![Image](https://github.com/user-attachments/assets/fce6b0df-0d0a-41ed-8db5-b170570c871e)\n\n\n\n- Looking at the errors happening, just wanted to confirm, does the Huggingface token show as it is set in the Settings of the app (the gear icon at the bottom of the side bar)\n\n", "all_hints_text": "Hi @ivanfioravanti . First of all, sorry for the error.\n\nThis error that you're seeing usually occurs when the App calls to the API but gets an error back. See here for example: https://github.com/transformerlab/transformerlab-app/blob/723b49ed88d103c55c6adc16fa140cdd0affd2b7/src/renderer/components/Data/DataStore.tsx#L28\n\nSo to find the underlying issue, the best thing would be to look at the `~/.transformerlab/local_server.log` and see if you see any errors that look like an error in python / FastAPI -- this will help us figure out what in your Datastore endpoint is causing a failure. Happy to jump on a quick screenshare (or help live on Discord) if that helps too.\n\nFor how to add Datasets, in the bottom of the Local Datasets page there is a field to type the name of the Dataset and you can press Download. Or you can click on \"New +\" to drag and drop files directly\nAdding on this to answer your question about downloading datasets:\n- To download datasets not in the Dataset Store, you can just use the button at the bottom left of your screen when you're on the Local Datasets tab.\n\n![Image](https://github.com/user-attachments/assets/6634b313-3ae0-4190-8c0c-9cfa40b38329)\n\n\nThere is also an option to add your custom datasets (the `New +` button to the right of the huggingface download option), if you need that as well:\n\n![Image](https://github.com/user-attachments/assets/fce6b0df-0d0a-41ed-8db5-b170570c871e)\n\n\n\n- Looking at the errors happening, just wanted to confirm, does the Huggingface token show as it is set in the Settings of the app (the gear icon at the bottom of the side bar)\nHey @ivanfioravanti, \nI found a case which might be causing this bug. Thanks for reporting this\nHey @ivanfioravanti, \nThis is fixed now. You should get this fix in the next app release. Thanks again for reporting this!\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/78453aa62e6de7d9753743cb5afd203f07703753", "https://github.com/transformerlab/transformerlab-app/commit/f3997e812baa246c95b581d836b51a603b17a5b2"], "created_at": "2025-05-06T21:35:41Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 445, "instance_id": "transformerlab__transformerlab-app-445", "issue_numbers": [443, 645], "base_commit": "dfe9a10b58432074177a3303bdfa54474ab2eab3", "patch": "diff --git a/src/renderer/components/Experiment/Train/TrainLoRA.tsx b/src/renderer/components/Experiment/Train/TrainLoRA.tsx\nindex 93bfd8c87..eb39eb1bf 100644\n--- a/src/renderer/components/Experiment/Train/TrainLoRA.tsx\n+++ b/src/renderer/components/Experiment/Train/TrainLoRA.tsx\n@@ -464,7 +464,12 @@ export default function TrainLoRA({ experimentInfo }) {\n \n                         <InfoIcon\n                           onClick={() => {\n-                            alert(job?.job_data?.config);\n+                            const jobDataConfig = job?.job_data?.config;\n+                            if (typeof jobDataConfig === 'object') {\n+                              alert(JSON.stringify(jobDataConfig));\n+                            } else {\n+                              alert(jobDataConfig);\n+                            }\n                           }}\n                           size=\"16px\"\n                           color=\"var(--joy-palette-neutral-500)\"\n", "test_patch": "", "problem_statement": "Popup Modal shows the string representation of a JavaScript object data type\n## Description\n\nInformation Modal Shows Object type `Obect object` as the message\n\nSteps:\n1. Go to Train Tab\n2. Put a dataset to training queue\n3. In the Queued Training Jobs table, find the job, There is a exclamation mark under the ID\n4. Click on the exclamation mark, and show a popup modal.\n5. Check the message show on the modal\n\n## Information\nOS: Linux 22.04.1-Ubuntu\n\n![Image](https://github.com/user-attachments/assets/80b9e324-a6ab-44b9-82f5-f319e8db475c)\nGEval Instructions can be more Clear\nProvide more detail on what to put for GEval evaluations.\n\nRight now it says:\n\nDefine custom evaluation tasks for generative model assessment\n\nBut I think GEval let's you write a task introduction and separate evaluation criteria, no? let's also provide an example or a link to the geval docs (or both)\n", "hints_text": "\n\n\n\n", "all_hints_text": "Thanks for reporting, opened a PR for the fix!\n\n\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/d38472db8dc10e1c5472082c9af44a961ade5658"], "created_at": "2025-05-06T21:43:43Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 285, "instance_id": "transformerlab__transformerlab-app-285", "issue_numbers": [448], "base_commit": "997066cc0ecaed0a274e5172bfda3e54e2e7a141", "patch": "diff --git a/src/renderer/components/Experiment/Eval/EvalJobsTable.tsx b/src/renderer/components/Experiment/Eval/EvalJobsTable.tsx\nindex 13e9e0a3b..ba8444faf 100644\n--- a/src/renderer/components/Experiment/Eval/EvalJobsTable.tsx\n+++ b/src/renderer/components/Experiment/Eval/EvalJobsTable.tsx\n@@ -16,11 +16,13 @@ import {\n   FileDigitIcon,\n   Grid3X3Icon,\n   Trash2Icon,\n+  LineChartIcon,\n   Type,\n } from 'lucide-react';\n import { useState, useEffect } from 'react';\n import useSWR from 'swr';\n import * as chatAPI from '../../../lib/transformerlab-api-sdk';\n+import TensorboardModal from '../Train/TensorboardModal';\n import ViewOutputModalStreaming from './ViewOutputModalStreaming';\n import ViewCSVModal from './ViewCSVModal';\n import ViewPlotModal from './ViewPlotModal';\n@@ -96,8 +98,8 @@ const EvalJobsTable = () => {\n   const [openPlotModal, setOpenPlotModal] = useState(false);\n   const [currentJobId, setCurrentJobId] = useState('');\n   const [currentScore, setCurrentScore] = useState('');\n-  const [fileNameForDetailedReport, setFileNameForDetailedReport] =\n-    useState('');\n+  const [currentTensorboardForModal, setCurrentTensorboardForModal] = useState(-1);\n+  const [fileNameForDetailedReport, setFileNameForDetailedReport] = useState('');\n \n   const fetchCSV = async (jobId) => {\n     const response = await fetch(\n@@ -152,6 +154,10 @@ const EvalJobsTable = () => {\n         setFileName={setFileNameForDetailedReport}\n         fileName={fileNameForDetailedReport}\n       />\n+         <TensorboardModal\n+              currentTensorboard={currentTensorboardForModal}\n+              setCurrentTensorboard={setCurrentTensorboardForModal}\n+            />\n       <Box\n         sx={{\n           display: 'flex',\n@@ -173,6 +179,7 @@ const EvalJobsTable = () => {\n           </Typography>\n         )}\n       </Box>\n+\n       <Sheet sx={{ overflowY: 'scroll' }}>\n         <Table stickyHeader>\n           <thead>\n@@ -286,6 +293,18 @@ const EvalJobsTable = () => {\n                     variant=\"soft\"\n                     sx={{ justifyContent: 'flex-end' }}\n                   >\n+                          {job?.job_data?.tensorboard_output_dir && (\n+                            <Button\n+                              size=\"sm\"\n+                              variant=\"plain\"\n+                              onClick={() => {\n+                                setCurrentTensorboardForModal(job?.id);\n+                              }}\n+                              startDecorator={<LineChartIcon />}\n+                            >\n+                              Tensorboard\n+                            </Button>\n+                          )}\n                     <Button\n                       onClick={() => {\n                         setViewOutputFromJob(job?.id);\ndiff --git a/src/renderer/components/Experiment/Eval/EvalModal.tsx b/src/renderer/components/Experiment/Eval/EvalModal.tsx\nindex 04dde6ec2..e005a54be 100644\n--- a/src/renderer/components/Experiment/Eval/EvalModal.tsx\n+++ b/src/renderer/components/Experiment/Eval/EvalModal.tsx\n@@ -287,7 +287,7 @@ export default function EvalModal({\n       } else {\n         console.log('formJson:', formJson);\n         const template_name = formJson.template_name;\n-        delete formJson.template_name;\n+        // delete formJson.template_name;\n         const result = await chatAPI.EXPERIMENT_ADD_EVALUATION(\n           experimentInfo?.id,\n           template_name,\ndiff --git a/src/renderer/components/Settings/TransformerLabSettings.tsx b/src/renderer/components/Settings/TransformerLabSettings.tsx\nindex 0e2654a2e..e845ec3c9 100644\n--- a/src/renderer/components/Settings/TransformerLabSettings.tsx\n+++ b/src/renderer/components/Settings/TransformerLabSettings.tsx\n@@ -206,6 +206,8 @@ export default function TransformerLabSettings() {\n           <Option value=\"DOWNLOAD_MODEL\">Download Model</Option>\n           <Option value=\"LOAD_MODEL\">Load Model</Option>\n           <Option value=\"TRAIN\">Train</Option>\n+          <Option value=\"GENERATE\">Generate</Option>\n+          <Option value=\"EVAL\">Evaluate</Option>\n         </Select>\n         {showJobsOfType !== 'NONE' && (\n           <Table sx={{ tableLayout: 'auto', overflow: 'scroll' }}>\n", "test_patch": "", "problem_statement": "Look at nvidia-ml-py3 requirement\nWe include nvidia-ml-py3 in requirements.in\n\nDo we need this for non-GPU machines?\n\nAnd the package itself says do not use it:\n\nhttps://github.com/nicolargo/nvidia-ml-py3?tab=readme-ov-file\n\nbut to use an alternative https://pypi.org/project/nvidia-ml-py/\n", "hints_text": "\n\n", "all_hints_text": "We need this for non-GPU devices just to keep track of other things. The way this works now is that it just provides \"n/a\" values for the gpu stuff and then the information about cpu is added for cpu-only devices or Mac. There might be a better way to deal with this to avoid installing the package itself. \n\nI will try the package switch and see if some performance is affected. If not we can just use the newer supported package then\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/c94738addc4e88dbad8f83ab3d24eac3b9e89a81", "https://github.com/transformerlab/transformerlab-app/commit/03bc294568b0e5d0b624d236b70bcc40b298bc19", "https://github.com/transformerlab/transformerlab-app/commit/daa83383d41f9ce8f6d6c1dad4f4d9b70750cddc", "https://github.com/transformerlab/transformerlab-app/commit/5e3d9a0988434f0bf7cbb35537550458d7129db4"], "created_at": "2025-02-26T22:49:22Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 298, "instance_id": "transformerlab__transformerlab-app-298", "issue_numbers": [449], "base_commit": "50200ec6282369d24208321cf4b64b4e0de6facb", "patch": "diff --git a/src/renderer/components/Experiment/Rag/Documents.tsx b/src/renderer/components/Experiment/Rag/Documents.tsx\nindex 550bb5141..beb29f851 100644\n--- a/src/renderer/components/Experiment/Rag/Documents.tsx\n+++ b/src/renderer/components/Experiment/Rag/Documents.tsx\n@@ -29,6 +29,7 @@ import {\n } from '@mui/joy';\n \n import {\n+  ChevronUpIcon,\n   EyeIcon,\n   FileTextIcon,\n   FileUpIcon,\n@@ -632,7 +633,7 @@ export default function Documents({\n                           setOrder(order === 'asc' ? 'desc' : 'asc')\n                         }\n                         fontWeight=\"lg\"\n-                        endDecorator={<ChevronDownIcon />}\n+                        endDecorator={<ChevronUpIcon />}\n                         sx={{\n                           '& svg': {\n                             transition: '0.2s',\ndiff --git a/src/renderer/components/ModelZoo/ModelStore.tsx b/src/renderer/components/ModelZoo/ModelStore.tsx\nindex 528aaa316..7fafa08ee 100644\n--- a/src/renderer/components/ModelZoo/ModelStore.tsx\n+++ b/src/renderer/components/ModelZoo/ModelStore.tsx\n@@ -20,7 +20,7 @@ import {\n import {\n   ArrowDownIcon,\n   CheckIcon,\n-  ChevronDownIcon,\n+  ChevronUpIcon,\n   CreativeCommonsIcon,\n   DownloadIcon,\n   ExternalLinkIcon,\n@@ -337,7 +337,7 @@ export default function ModelStore() {\n                     component=\"button\"\n                     onClick={() => setOrder(order === 'asc' ? 'desc' : 'asc')}\n                     fontWeight=\"lg\"\n-                    endDecorator={<ChevronDownIcon />}\n+                    endDecorator={<ChevronUpIcon />}\n                     sx={{\n                       '& svg': {\n                         transition: '0.2s',\n", "test_patch": "", "problem_statement": "Look at all requirements in requirements.in one by one\n\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/da4ce032399a9015a02224dc4fb1c1ab52d12503"], "created_at": "2025-03-05T16:47:59Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 455, "instance_id": "transformerlab__transformerlab-app-455", "issue_numbers": [452], "base_commit": "a631c292e5857dcc7290a0205c39119843deec1a", "patch": "diff --git a/src/renderer/components/Experiment/Eval/EvalModal.tsx b/src/renderer/components/Experiment/Eval/EvalModal.tsx\nindex 032cc344d..e06b82601 100644\n--- a/src/renderer/components/Experiment/Eval/EvalModal.tsx\n+++ b/src/renderer/components/Experiment/Eval/EvalModal.tsx\n@@ -46,11 +46,13 @@ function PluginIntroduction({ experimentInfo, pluginId }) {\n \n async function updateTask(\n   task_id: string,\n+  name: string,\n   inputs: string,\n   config: string,\n   outputs: string,\n ) {\n   const configBody = {\n+    name,\n     inputs,\n     config,\n     outputs,\n@@ -178,31 +180,25 @@ export default function EvalModal({\n         const evalConfig = JSON.parse(evalData.config);\n         if (evalConfig) {\n           setConfig(evalConfig);\n-          const datasetKeyExists = Object.keys(\n-            evalConfig,\n-          ).some((key) => key === 'dataset_name');\n+          const datasetKeyExists = Object.keys(evalConfig).some(\n+            (key) => key === 'dataset_name',\n+          );\n           setHasDatasetKey(datasetKeyExists);\n           if (\n             evalConfig._dataset_display_message &&\n             evalConfig._dataset_display_message.length > 0\n           ) {\n-            setDatasetDisplayMessage(\n-              evalConfig._dataset_display_message,\n-            );\n+            setDatasetDisplayMessage(evalConfig._dataset_display_message);\n           }\n-          const tasksKeyExists = Object.keys(evalConfig).some(\n-            (key) => key.toLowerCase().includes('tasks'),\n+          const tasksKeyExists = Object.keys(evalConfig).some((key) =>\n+            key.toLowerCase().includes('tasks'),\n           );\n           if (tasksKeyExists) {\n-            evalConfig.tasks =\n-              evalConfig.tasks.split(',');\n+            evalConfig.tasks = evalConfig.tasks.split(',');\n             setConfig(evalConfig);\n           }\n \n-          if (\n-            hasDatasetKey &&\n-            evalConfig.dataset_name.length > 0\n-          ) {\n+          if (hasDatasetKey && evalConfig.dataset_name.length > 0) {\n             setSelectedDataset(evalConfig.dataset_name);\n           }\n           if (!nameInput && evalConfig?.run_name.length > 0) {\n@@ -250,7 +246,7 @@ export default function EvalModal({\n         }\n       }\n     }\n-  }, [experimentInfo, pluginId, currentEvalId, nameInput, data]);\n+  }, [experimentInfo, pluginId, currentEvalId, evalData, data, nameInput]);\n \n   if (!experimentInfo?.id) {\n     return 'Select an Experiment';\n@@ -321,14 +317,24 @@ export default function EvalModal({\n         formJson.predefined_tasks = '';\n       }\n       formJson.script_parameters = JSON.parse(JSON.stringify(formJson));\n+      const template_name = formJson.template_name;\n \n       // Run when the currentEvalId is provided\n       if (currentEvalId && currentEvalId !== '') {\n-        await updateTask(currentEvalId, '{}', JSON.stringify(formJson), '{}');\n+        await updateTask(\n+          currentEvalId,\n+          template_name,\n+          '{}',\n+          JSON.stringify(formJson),\n+          '{}',\n+        );\n         setNameInput('');\n         setHasDatasetKey(false);\n+        setSelectedDataset(null);\n+        setDatasetDisplayMessage('');\n       } else {\n         const template_name = formJson.template_name;\n+\n         // delete formJson.template_name;\n         await createNewTask(\n           template_name,\n@@ -341,6 +347,8 @@ export default function EvalModal({\n         // alert(JSON.stringify(formJson, null, 2));\n         setNameInput(generateFriendlyName());\n         setHasDatasetKey(false);\n+        setSelectedDataset(null);\n+        setDatasetDisplayMessage('');\n       }\n       mutateTasks();\n       onClose();\ndiff --git a/src/renderer/components/Experiment/Generate/GenerateModal.tsx b/src/renderer/components/Experiment/Generate/GenerateModal.tsx\nindex 787e5f8a6..fa49ef59e 100644\n--- a/src/renderer/components/Experiment/Generate/GenerateModal.tsx\n+++ b/src/renderer/components/Experiment/Generate/GenerateModal.tsx\n@@ -75,11 +75,13 @@ function getGenerationFromGenerationsArray(generationsStr, generationName) {\n \n async function updateTask(\n   task_id: string,\n+  name: string,\n   inputs: string,\n   config: string,\n   outputs: string,\n ) {\n   const configBody = {\n+    name: name,\n     inputs: inputs,\n     config: config,\n     outputs: outputs,\n@@ -221,34 +223,27 @@ export default function GenerateModal({\n         if (generationConfig) {\n           setConfig(generationConfig.script_parameters);\n \n-          const datasetKeyExists = Object.keys(\n-            generationConfig,\n-          ).some((key) => key === 'dataset_name');\n+          const datasetKeyExists = Object.keys(generationConfig).some(\n+            (key) => key === 'dataset_name',\n+          );\n \n-          const docsKeyExists = Object.keys(\n-            generationConfig,\n-          ).some((key) => key === 'docs');\n+          const docsKeyExists = Object.keys(generationConfig).some(\n+            (key) => key === 'docs',\n+          );\n \n-          const contextKeyExists = Object.keys(\n-            generationConfig,\n-          ).some((key) => key === 'context');\n+          const contextKeyExists = Object.keys(generationConfig).some(\n+            (key) => key === 'context',\n+          );\n \n           setHasDatasetKey(datasetKeyExists);\n \n-          if (\n-            docsKeyExists &&\n-            generationConfig.docs.length > 0\n-          ) {\n+          if (docsKeyExists && generationConfig.docs.length > 0) {\n             setHasContextKey(false);\n             setHasDocumentsKey(true);\n-            generationConfig.docs =\n-              generationConfig.docs.split(',');\n+            generationConfig.docs = generationConfig.docs.split(',');\n             setConfig(generationConfig);\n             setSelectedDocs(generationConfig.docs);\n-          } else if (\n-            contextKeyExists &&\n-            generationConfig.context.length > 0\n-          ) {\n+          } else if (contextKeyExists && generationConfig.context.length > 0) {\n             setHasContextKey(true);\n             setHasDocumentsKey(false);\n             const context = generationConfig.context;\n@@ -277,52 +272,60 @@ export default function GenerateModal({\n           }\n         }\n       } else {\n-      // CREATE NEW GENERATION\n-      if (data) {\n-        let parsedData;\n-        try {\n-          parsedData = JSON.parse(data); //Parsing data for easy access to parameters}\n-          // Set config as a JSON object with keys of the parameters and values of the default values\n-          setSelectedDocs([]);\n-          let tempconfig: { [key: string]: any } = {};\n-          if (parsedData && parsedData.parameters) {\n-            tempconfig = Object.fromEntries(\n-              Object.entries(parsedData.parameters).map(([key, value]) => [\n-                key,\n-                value.default,\n-              ]),\n-            );\n-            // Logic to set dataset message\n-            if (parsedData && parsedData._dataset) {\n-              setHasDatasetKey(true);\n-              // Check if the dataset display message string length is greater than 0\n-              if (\n-                parsedData._dataset_display_message &&\n-                parsedData._dataset_display_message.length > 0\n-              ) {\n-                setDatasetDisplayMessage(parsedData._dataset_display_message);\n-                // Add dataset display message to the config parameters\n+        // CREATE NEW GENERATION\n+        if (data) {\n+          let parsedData;\n+          try {\n+            parsedData = JSON.parse(data); //Parsing data for easy access to parameters}\n+            // Set config as a JSON object with keys of the parameters and values of the default values\n+            setSelectedDocs([]);\n+            let tempconfig: { [key: string]: any } = {};\n+            if (parsedData && parsedData.parameters) {\n+              tempconfig = Object.fromEntries(\n+                Object.entries(parsedData.parameters).map(([key, value]) => [\n+                  key,\n+                  value.default,\n+                ]),\n+              );\n+              // Logic to set dataset message\n+              if (parsedData && parsedData._dataset) {\n+                setHasDatasetKey(true);\n+                // Check if the dataset display message string length is greater than 0\n+                if (\n+                  parsedData._dataset_display_message &&\n+                  parsedData._dataset_display_message.length > 0\n+                ) {\n+                  setDatasetDisplayMessage(parsedData._dataset_display_message);\n+                  // Add dataset display message to the config parameters\n+                }\n               }\n+              // Check if parsed data parameters has a key that includes 'docs'\n+              const docsKeyExists = Object.keys(parsedData.parameters).some(\n+                (key) => key.toLowerCase().includes('tflabcustomui_docs'),\n+              );\n+\n+              const contextKeyExists = Object.keys(parsedData.parameters).some(\n+                (key) => key.toLowerCase().includes('tflabcustomui_context'),\n+              );\n+              setHasContextKey(contextKeyExists);\n+              setHasDocumentsKey(docsKeyExists);\n             }\n-            // Check if parsed data parameters has a key that includes 'docs'\n-            const docsKeyExists = Object.keys(parsedData.parameters).some(\n-              (key) => key.toLowerCase().includes('tflabcustomui_docs'),\n-            );\n-\n-            const contextKeyExists = Object.keys(parsedData.parameters).some(\n-              (key) => key.toLowerCase().includes('tflabcustomui_context'),\n-            );\n-            setHasContextKey(contextKeyExists);\n-            setHasDocumentsKey(docsKeyExists);\n+            setConfig(tempconfig);\n+          } catch (e) {\n+            console.error('Error parsing data', e);\n+            parsedData = '';\n           }\n-          setConfig(tempconfig);\n-        } catch (e) {\n-          console.error('Error parsing data', e);\n-          parsedData = '';\n         }\n-      }}\n+      }\n     }\n-  }, [experimentInfo, pluginId, currentGenerationId, nameInput, data]);\n+  }, [\n+    experimentInfo,\n+    pluginId,\n+    currentGenerationId,\n+    generationData,\n+    data,\n+    nameInput,\n+  ]);\n \n   if (!experimentInfo?.id) {\n     return 'Select an Experiment';\n@@ -443,11 +446,12 @@ export default function GenerateModal({\n       formJson.script_parameters = JSON.parse(JSON.stringify(formJson));\n \n       console.log('formJson', formJson);\n-\n+      const template_name = formJson.template_name;\n       // Run when the currentGenerationId is provided\n       if (currentGenerationId && currentGenerationId !== '') {\n         await updateTask(\n           currentGenerationId,\n+          template_name,\n           '{}',\n           JSON.stringify(formJson),\n           '{}',\ndiff --git a/src/renderer/components/Experiment/Train/TrainingModalLoRA.tsx b/src/renderer/components/Experiment/Train/TrainingModalLoRA.tsx\nindex 1c8872c00..21871df8a 100644\n--- a/src/renderer/components/Experiment/Train/TrainingModalLoRA.tsx\n+++ b/src/renderer/components/Experiment/Train/TrainingModalLoRA.tsx\n@@ -109,11 +109,13 @@ export default function TrainingModalLoRA({\n \n   async function updateTask(\n     task_id: string,\n+    name: string,\n     inputs: string,\n     config: string,\n     outputs: string,\n   ) {\n     const configBody = {\n+      name: name,\n       inputs: inputs,\n       config: config,\n       outputs: outputs,\n@@ -337,6 +339,7 @@ export default function TrainingModalLoRA({\n               }\n               updateTask(\n                 task_id,\n+                formJson.template_name,\n                 JSON.stringify(templateDataInputs),\n                 JSON.stringify(formJson),\n                 JSON.stringify(templateDataOutputs),\n", "test_patch": "", "problem_statement": "Saving the 3rd party model in the eval doesn't save properly\nHere is a video showing the problem. To replicate, open an eval that has a 3rd party model. Change the model and press save. Now edit this task and the model will change.\n\nhttps://github.com/user-attachments/assets/eebbaf5c-cf39-4a3f-8480-9f897fd9f5f3\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/2adf96804f23582c71b82f509bf6952e1f1a35c2", "https://github.com/transformerlab/transformerlab-app/commit/ba597b6d9c57e3c0a1163416f763a209dfc59b44"], "created_at": "2025-05-09T21:36:38Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 282, "instance_id": "transformerlab__transformerlab-app-282", "issue_numbers": [454], "base_commit": "8f86009041d62b8977812da6aa8c49d9f2eca181", "patch": "diff --git a/src/renderer/components/Experiment/Eval/EvalJobsTable.tsx b/src/renderer/components/Experiment/Eval/EvalJobsTable.tsx\nindex 111fe2a74..13e9e0a3b 100644\n--- a/src/renderer/components/Experiment/Eval/EvalJobsTable.tsx\n+++ b/src/renderer/components/Experiment/Eval/EvalJobsTable.tsx\n@@ -114,6 +114,7 @@ const EvalJobsTable = () => {\n     mutate: jobsMutate,\n   } = useSWR(chatAPI.Endpoints.Jobs.GetJobsOfType('EVAL', ''), fetcher, {\n     refreshInterval: 2000,\n+    fallbackData: [],\n   });\n \n   const handleOpenCSVModal = (jobId) => {\n", "test_patch": "", "problem_statement": "Unsloth Gemma3 models not loading due to size mismatch\nSee image:\n\n![Image](https://github.com/user-attachments/assets/044805ed-e51d-4061-a4ef-6a4cb974dbfc)\n\nGetting this error:\n\n```\n2025-05-09 09:44:06 | ERROR | stderr |     raise RuntimeError(\n\n2025-05-09 09:44:06 | ERROR | stderr | RuntimeError: Error(s) in loading state_dict for Linear:\n\n2025-05-09 09:44:06 | ERROR | stderr |  size mismatch for weight: copying a param with shape torch.Size([1310720, 1]) from checkpoint, the shape in current model is torch.Size([1024, 2560]).\n```\n\nMay be related to this:\n\nhttps://github.com/vllm-project/vllm/issues/15959\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/7f23273acaa4306e011d3695a095fe7c71ec99b1"], "created_at": "2025-02-26T20:25:59Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 465, "instance_id": "transformerlab__transformerlab-app-465", "issue_numbers": [460], "base_commit": "a3e4c005e27c7c2c87aa566ceb02ba9866be0bf3", "patch": "diff --git a/src/renderer/components/Experiment/Interact/Interact.tsx b/src/renderer/components/Experiment/Interact/Interact.tsx\nindex 0a9f9264e..fe52e48c3 100644\n--- a/src/renderer/components/Experiment/Interact/Interact.tsx\n+++ b/src/renderer/components/Experiment/Interact/Interact.tsx\n@@ -125,7 +125,7 @@ export default function Chat({\n       }\n     }\n     scrollChatToBottom();\n-  }, [debouncedText, chats, mode]);\n+  }, [debouncedText, mode]);\n \n   // If the model changes, check the location of the inference service\n   // And reset the global pointer to the inference server\n", "test_patch": "", "problem_statement": "model_worker.log gets filled with redundant messages\nIf you run a model for a long time your model_worker.log gets really full with:\n\n```\n2025-05-13 10:14:56 | INFO | stdout | INFO:     ::1:55176 - \"POST /count_token HTTP/1.1\" 200 OK\n2025-05-13 10:14:56 | INFO | stdout | INFO:     ::1:55178 - \"POST /model_details HTTP/1.1\" 200 OK\n```\n", "hints_text": "This is caused by the following re-renders in frontend:\n```\nReact.useEffect(() => {\n    if (debouncedText) {\n      if (mode === 'chat' || mode === 'tools') {\n        countChatTokens();\n      } else {\n        countTokens();\n      }\n    }\n    scrollChatToBottom();\n  }, [debouncedText, chats, mode]);\n```\n\nThe useeffect was blank before but now it is re-rendered because of changes on either `[debouncedText, chats, mode]`  which causes this\n\n", "all_hints_text": "This is caused by the following re-renders in frontend:\n```\nReact.useEffect(() => {\n    if (debouncedText) {\n      if (mode === 'chat' || mode === 'tools') {\n        countChatTokens();\n      } else {\n        countTokens();\n      }\n    }\n    scrollChatToBottom();\n  }, [debouncedText, chats, mode]);\n```\n\nThe useeffect was blank before but now it is re-rendered because of changes on either `[debouncedText, chats, mode]`  which causes this\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/22c38cde112256215ba7e5211c613237e26dc7e4"], "created_at": "2025-05-13T22:20:58Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 59, "instance_id": "transformerlab__transformerlab-app-59", "issue_numbers": [466], "base_commit": "da9aeeb4b82247287517185e2d5a7749d664bb19", "patch": "diff --git a/package-lock.json b/package-lock.json\nindex bef9f4b43..b4fe2fb75 100644\n--- a/package-lock.json\n+++ b/package-lock.json\n@@ -5,7 +5,7 @@\n   \"requires\": true,\n   \"packages\": {\n     \"\": {\n-      \"version\": \"0.2.13\",\n+      \"version\": \"0.2.14\",\n       \"hasInstallScript\": true,\n       \"license\": \"MIT\",\n       \"dependencies\": {\n@@ -11345,9 +11345,9 @@\n       \"dev\": true\n     },\n     \"node_modules/follow-redirects\": {\n-      \"version\": \"1.15.4\",\n-      \"resolved\": \"https://registry.npmjs.org/follow-redirects/-/follow-redirects-1.15.4.tgz\",\n-      \"integrity\": \"sha512-Cr4D/5wlrb0z9dgERpUL3LrmPKVDsETIJhaCMeDfuFYcqa5bldGV6wBsAN6X/vxlXQtFBMrXdXxdL8CbDTGniw==\",\n+      \"version\": \"1.15.6\",\n+      \"resolved\": \"https://registry.npmjs.org/follow-redirects/-/follow-redirects-1.15.6.tgz\",\n+      \"integrity\": \"sha512-wWN62YITEaOpSK584EZXJafH1AGpO8RVgElfkuXbTOrPX4fIfOyEpW/CsiNd8JdYrAoOvafRTOEnvsO++qCqFA==\",\n       \"dev\": true,\n       \"funding\": [\n         {\n", "test_patch": "", "problem_statement": "Add documentation for Docker\nAdd official Docker documentation.\n\nIn the current github docs, mention that the GUI is accessible\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/3951e074272190153fe55b4de3c5acdabb8b1ba8"], "created_at": "2024-03-16T22:58:00Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 299, "instance_id": "transformerlab__transformerlab-app-299", "issue_numbers": [471], "base_commit": "09f8d45bff7549cbb5121f120b4bfb21149e7c53", "patch": "diff --git a/src/renderer/components/ModelZoo/ModelStore.tsx b/src/renderer/components/ModelZoo/ModelStore.tsx\nindex 7fafa08ee..5a2906e17 100644\n--- a/src/renderer/components/ModelZoo/ModelStore.tsx\n+++ b/src/renderer/components/ModelZoo/ModelStore.tsx\n@@ -99,6 +99,7 @@ const fetcher = (url) => fetch(url).then((res) => res.json());\n \n export default function ModelStore() {\n   const [order, setOrder] = useState<Order>('asc');\n+  const [orderBy, setOrderBy] = useState('name');\n   // jobId is null if there is no current download in progress,\n   // and it is -1 if a download has been initiated but it hasn't started yet\n   const [jobId, setJobId] = useState(null);\n@@ -335,9 +336,20 @@ export default function ModelStore() {\n                     underline=\"none\"\n                     color=\"primary\"\n                     component=\"button\"\n-                    onClick={() => setOrder(order === 'asc' ? 'desc' : 'asc')}\n+                    onClick={() => {\n+                      setOrder(order === 'asc' ? 'desc' : 'asc');\n+                      setOrderBy('name');\n+                    }}\n                     fontWeight=\"lg\"\n-                    endDecorator={<ChevronUpIcon />}\n+                    endDecorator={\n+                      <ChevronUpIcon\n+                        color={\n+                          orderBy == 'name'\n+                            ? 'var(--joy-palette-primary-plainColor)'\n+                            : 'var(--joy-palette-primary-plainDisabledColor)'\n+                        }\n+                      />\n+                    }\n                     sx={{\n                       '& svg': {\n                         transition: '0.2s',\n@@ -352,7 +364,37 @@ export default function ModelStore() {\n \n                 <th style={{ width: 100, padding: 12 }}>License</th>\n                 <th style={{ width: 100, padding: 12 }}>Engine</th>\n-                <th style={{ width: 60, padding: 12 }}>Size</th>\n+                <th style={{ width: 60, padding: 12 }}>\n+                  {' '}\n+                  <Link\n+                    underline=\"none\"\n+                    color=\"primary\"\n+                    component=\"button\"\n+                    onClick={() => {\n+                      setOrder(order === 'asc' ? 'desc' : 'asc');\n+                      setOrderBy('size_of_model_in_mb');\n+                    }}\n+                    fontWeight=\"lg\"\n+                    endDecorator={\n+                      <ChevronUpIcon\n+                        color={\n+                          orderBy == 'size_of_model_in_mb'\n+                            ? 'var(--joy-palette-primary-plainColor)'\n+                            : 'var(--joy-palette-primary-plainDisabledColor)'\n+                        }\n+                      />\n+                    }\n+                    sx={{\n+                      '& svg': {\n+                        transition: '0.2s',\n+                        transform:\n+                          order === 'desc' ? 'rotate(0deg)' : 'rotate(180deg)',\n+                      },\n+                    }}\n+                  >\n+                    Size\n+                  </Link>\n+                </th>\n                 <th style={{ width: 20, padding: 12 }}> </th>\n                 <th style={{ width: 80, padding: 12 }}> </th>\n               </tr>\n@@ -361,7 +403,7 @@ export default function ModelStore() {\n               {modelGalleryData &&\n                 stableSort(\n                   filterByFilters(modelGalleryData, searchText, filters),\n-                  getComparator(order, 'name'),\n+                  getComparator(order, orderBy),\n                 ).map((row) => (\n                   <tr key={row.uniqueID}>\n                     <td>\n", "test_patch": "", "problem_statement": "Show VRAM in Tensorboard\nCan we show things like VRAM and other important system details in Tensorboard, at least for our most important trainers\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/c74e402b310dc49ece82bcd66e6dba983bbdf73b"], "created_at": "2025-03-05T17:06:44Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 318, "instance_id": "transformerlab__transformerlab-app-318", "issue_numbers": [500], "base_commit": "7c66f1434acefc6d5f69c8474ab0ca74b84e4a67", "patch": "diff --git a/src/renderer/components/Experiment/Eval/ViewCSVModal.tsx b/src/renderer/components/Experiment/Eval/ViewCSVModal.tsx\nindex 56b7f9c7d..fdd50b2be 100644\n--- a/src/renderer/components/Experiment/Eval/ViewCSVModal.tsx\n+++ b/src/renderer/components/Experiment/Eval/ViewCSVModal.tsx\n@@ -62,7 +62,9 @@ function formatEvalData(data, compareEvals = false) {\n       const evaluatorName = row[3];\n       const metricName = row[4];\n       const scoreVal = row[5];\n-      const combinedScore = { [`${evaluatorName}-${jobId}-${metricName}`]: scoreVal };\n+      const combinedScore = {\n+        [`${evaluatorName}-${jobId}-${metricName}`]: scoreVal,\n+      };\n \n       // Append additional columns after the 6th column, if any\n       const extraColumns = row.slice(6);\n@@ -114,27 +116,45 @@ function formatEvalData(data, compareEvals = false) {\n   return { header: header, body: formattedData };\n }\n \n+function sameTask(metric1, metric2) {\n+  const metric1Split = metric1.split('-');\n+  const metric2Split = metric2.split('-');\n+  return (\n+    metric1Split[0] === metric2Split[0] && metric1Split[1] === metric2Split[1]\n+  );\n+}\n+\n function formatArrayOfScores(scores) {\n   const scoresArray = Array.isArray(scores) ? scores : [scores];\n-  const formattedScores = scoresArray.map((score) => {\n+  const formattedScores = [];\n+  let lastMetricName = '';\n+  for (let i = 0; i < scoresArray.length; i++) {\n+    const score = scoresArray[i];\n     const metricName = Object.keys(score)[0];\n     const value = Object.values(score)[0];\n-\n-    return (\n+    if (lastMetricName !== '' && !sameTask(lastMetricName, metricName)) {\n+      formattedScores.push(\n+        <div style={{ flexBasis: '100%', height: '4px' }} key={i + 0.5} />,\n+      );\n+    }\n+    formattedScores.push(\n       <Box\n         sx={{\n           backgroundColor: heatedColor(parseFloat(value)),\n           padding: '0 5px',\n           fontWeight: 'normal',\n-          flex: '1 0 0',\n+          flex: '1',\n           overflow: 'hidden',\n         }}\n+        key={i}\n       >\n         {metricName}:<br />\n         {parseFloat(value).toFixed(5)}\n-      </Box>\n+      </Box>,\n     );\n-  });\n+\n+    lastMetricName = metricName;\n+  }\n   return formattedScores;\n }\n \n@@ -154,6 +174,7 @@ function formatScore(score) {\n             flexDirection: 'row',\n             height: '100%',\n             overflow: 'hidden',\n+            flexWrap: 'wrap',\n           }}\n         >\n           {formatArrayOfScores(score)}\n@@ -170,82 +191,79 @@ const convertReportToCSV = (report: { header: any[]; body: any[] }) => {\n   const csvRows = [];\n   csvRows.push(report.header.join(','));\n   report.body.forEach((row) => {\n-      const csvRow = row\n-          .map((cell) => {\n-              let cellText = '';\n-              if (typeof cell === 'object') {\n-                  // Convert objects to a JSON string and escape inner quotes\n-                  cellText = JSON.stringify(cell).replace(/\"/g, '\"\"');\n-              } else {\n-                  cellText = cell;\n-              }\n-              return `\"${cellText}\"`;\n-          })\n-          .join(',');\n-      csvRows.push(csvRow);\n+    const csvRow = row\n+      .map((cell) => {\n+        let cellText = '';\n+        if (typeof cell === 'object') {\n+          // Convert objects to a JSON string and escape inner quotes\n+          cellText = JSON.stringify(cell).replace(/\"/g, '\"\"');\n+        } else {\n+          cellText = cell;\n+        }\n+        return `\"${cellText}\"`;\n+      })\n+      .join(',');\n+    csvRows.push(csvRow);\n   });\n   return csvRows.join('\\n');\n };\n \n-const ViewCSVModal = ({ open, onClose, jobId, fetchCSV, compareData = null }) => {\n+const ViewCSVModal = ({\n+  open,\n+  onClose,\n+  jobId,\n+  fetchCSV,\n+  compareData = null,\n+}) => {\n   const [report, setReport] = useState({});\n \n-\n   useEffect(() => {\n-\n     if (!compareData) {\n-\n-    if (open && jobId) {\n-      fetchCSV(jobId).then((data) => {\n-        try {\n-          setReport(formatEvalData(JSON.parse(data)));\n-        } catch (e) {\n-          setReport({ header: ['Error'], body: [[data]] });\n-        }\n-      });\n-    }\n-\n-  } else {\n-    try {\n-      setReport(formatEvalData(compareData, true));\n-    } catch (e) {\n-      setReport({ header: ['Error'], body: [[compareData]] });\n+      if (open && jobId) {\n+        fetchCSV(jobId).then((data) => {\n+          try {\n+            setReport(formatEvalData(JSON.parse(data)));\n+          } catch (e) {\n+            setReport({ header: ['Error'], body: [[data]] });\n+          }\n+        });\n+      }\n+    } else {\n+      try {\n+        setReport(formatEvalData(compareData, true));\n+      } catch (e) {\n+        setReport({ header: ['Error'], body: [[compareData]] });\n+      }\n     }\n-\n-  }\n-\n   }, [open, jobId, fetchCSV]);\n \n-\n   const handleDownload = async () => {\n-\n     if (!compareData) {\n-    const response = await fetch(\n-      chatAPI.Endpoints.Experiment.GetAdditionalDetails(jobId, 'download')\n-    );\n-    const blob = await response.blob();\n-    const url = URL.createObjectURL(blob);\n-    const link = document.createElement('a');\n-    link.href = url;\n-    link.download = `report_${jobId}.csv`; // Adjust extension if necessary\n-    document.body.appendChild(link);\n-    link.click();\n-    document.body.removeChild(link);\n-    URL.revokeObjectURL(url);\n-  } else {\n-    const csvContent = convertReportToCSV(report);\n-    const blob = new Blob([csvContent], { type: 'text/csv' });\n-    const url = URL.createObjectURL(blob);\n-    const link = document.createElement('a');\n-    link.href = url;\n-    link.download = `detailed_report.csv`; // Adjust extension if necessary\n-    document.body.appendChild(link);\n-    link.click();\n-    document.body.removeChild(link);\n-    URL.revokeObjectURL(url);\n-  }\n-\n-};\n+      const response = await fetch(\n+        chatAPI.Endpoints.Experiment.GetAdditionalDetails(jobId, 'download'),\n+      );\n+      const blob = await response.blob();\n+      const url = URL.createObjectURL(blob);\n+      const link = document.createElement('a');\n+      link.href = url;\n+      link.download = `report_${jobId}.csv`; // Adjust extension if necessary\n+      document.body.appendChild(link);\n+      link.click();\n+      document.body.removeChild(link);\n+      URL.revokeObjectURL(url);\n+    } else {\n+      const csvContent = convertReportToCSV(report);\n+      const blob = new Blob([csvContent], { type: 'text/csv' });\n+      const url = URL.createObjectURL(blob);\n+      const link = document.createElement('a');\n+      link.href = url;\n+      link.download = `detailed_report.csv`; // Adjust extension if necessary\n+      document.body.appendChild(link);\n+      link.click();\n+      document.body.removeChild(link);\n+      URL.revokeObjectURL(url);\n+    }\n+  };\n \n   return (\n     <Modal open={open} onClose={onClose}>\n@@ -260,8 +278,9 @@ const ViewCSVModal = ({ open, onClose, jobId, fetchCSV, compareData = null }) =>\n           }}\n         >\n           <Typography level=\"h4\" mb={2}>\n-          {compareData ? 'Detailed Comparison Report' :\n-            `Additional Output from Job: ${jobId}`}\n+            {compareData\n+              ? 'Detailed Comparison Report'\n+              : `Additional Output from Job: ${jobId}`}\n           </Typography>\n           <Button onClick={handleDownload} variant=\"outlined\">\n             Download Report\n", "test_patch": "", "problem_statement": "UI Enforces 4096 Token Limit Even for Models With Larger Context Windows\nCurrently, the UI has a hardcoded limit of 4096 tokens for input validation, even when using models that support significantly larger context lengths (e.g., Phi-3 with 128k)\n\n![Image](https://github.com/user-attachments/assets/7fe0c69e-1ac9-4433-926a-9aee9b8a40f3)\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/bc46d5f80f495f575cf6d8b9ca53a2a46f5426d1"], "created_at": "2025-03-13T16:48:05Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 331, "instance_id": "transformerlab__transformerlab-app-331", "issue_numbers": [504], "base_commit": "57a52424a2ffee911ed1b961a7b7bbf3f537b81d", "patch": "diff --git a/src/renderer/components/Nav/Sidebar.tsx b/src/renderer/components/Nav/Sidebar.tsx\nindex e2cb12859..f5d16a4e6 100644\n--- a/src/renderer/components/Nav/Sidebar.tsx\n+++ b/src/renderer/components/Nav/Sidebar.tsx\n@@ -8,7 +8,6 @@ import {\n   GraduationCapIcon,\n   LayersIcon,\n   MessageCircleIcon,\n-  SlidersIcon,\n   BoxesIcon,\n   FileTextIcon,\n   MonitorIcon,\n@@ -22,13 +21,11 @@ import {\n   FileIcon,\n   ChartColumnIncreasingIcon,\n   WorkflowIcon,\n-  User2Icon,\n   UserIcon,\n   LogOutIcon,\n } from 'lucide-react';\n \n import {\n-  Avatar,\n   Box,\n   ButtonGroup,\n   IconButton,\n@@ -47,18 +44,7 @@ import SelectExperimentMenu from '../Experiment/SelectExperimentMenu';\n import SubNavItem from './SubNavItem';\n import ColorSchemeToggle from './ColorSchemeToggle';\n \n-export default function Sidebar({\n-  experimentInfo,\n-  setExperimentId,\n-  logsDrawerOpen,\n-  setLogsDrawerOpen,\n-  themeSetter,\n-}) {\n-  const { models, isError, isLoading } = useModelStatus();\n-  const { outdatedPluginsCount } = usePluginStatus(experimentInfo);\n-\n-  const navigate = useNavigate();\n-\n+function ExperimentMenuItems({ DEV_MODE, experimentInfo, models }) {\n   function activeModelIsNotSameAsFoundation() {\n     if (models === null) {\n       return true;\n@@ -78,60 +64,16 @@ export default function Sidebar({\n     );\n   }\n \n-  const DEV_MODE = experimentInfo?.name === 'dev';\n-\n   return (\n-    <Sheet\n-      className=\"Sidebar\"\n-      sx={{\n-        gridArea: 'sidebar',\n-        borderRight: '1px solid',\n-        borderColor: 'divider',\n-        transition: 'transform 0.4s',\n-        zIndex: 100,\n-        height: '100%',\n-        overflow: 'auto',\n-        top: 0,\n-        p: 2,\n-        py: 1,\n-        pt: '0',\n-        flexShrink: 0,\n-        display: 'flex',\n-        flexDirection: 'column',\n-        gap: 1,\n-        userSelect: 'none',\n-        width: '100%',\n-        // opacity: 0.4,\n-        '& .lucide': {\n-          strokeWidth: '1.5px',\n-        },\n-        '& .MuiBadge-root': {},\n-      }}\n-    >\n-      <div\n-        style={{\n-          width: '100%',\n-          height: '52px',\n-          '-webkit-app-region': 'drag',\n-          display: 'flex',\n-          alignItems: 'flex-end',\n-          justifyContent: 'center',\n-          color: 'var(--joy-palette-neutral-plainDisabledColor)',\n-        }}\n-      >\n-        {DEV_MODE && <>Transformer Lab v{window.platform?.version}</>}\n-      </div>\n-      <SelectExperimentMenu\n-        experimentInfo={experimentInfo}\n-        setExperimentId={setExperimentId}\n-        models={models}\n-      />\n+    <>\n+      {' '}\n       <List\n         sx={{\n           '--ListItem-radius': '8px',\n           '--ListItem-minHeight': '32px',\n           '--List-gap': '4px',\n           overflowY: 'auto',\n+          flex: 1,\n         }}\n       >\n         <SubNavItem\n@@ -160,24 +102,6 @@ export default function Sidebar({\n             disabled={!experimentInfo?.name}\n           />\n         )}\n-        {/* <SubNavItem\n-          title=\"Query Docs\"\n-          path=\"/experiment/rag\"\n-          icon={<FolderSearch2Icon />}\n-          disabled={!experimentInfo?.name || activeModelIsNotSameAsFoundation()}\n-        /> */}\n-        {/* <SubNavItem\n-          title=\"Embeddings\"\n-          path=\"/experiment/embeddings\"\n-          icon={<FileDigitIcon />}\n-          disabled={activeModelIsNotSameAsFoundation()}\n-        />\n-        <SubNavItem\n-          title=\"Tokenize\"\n-          path=\"/experiment/tokenize\"\n-          icon={<RectangleEllipsisIcon />}\n-          disabled={activeModelIsNotSameAsFoundation()}\n-        /> */}\n         <SubNavItem\n           title=\"Train\"\n           path=\"/experiment/training\"\n@@ -218,14 +142,16 @@ export default function Sidebar({\n           icon={<FlaskConicalIcon />}\n           disabled={!experimentInfo?.name}\n         />\n-        {/* <SubNavItem\n-          title=\"Settings\"\n-          path=\"/experiment/settings\"\n-          icon={<SlidersIcon />}\n-          disabled={!experimentInfo?.name}\n-        /> */}\n       </List>\n-      <List sx={{ justifyContent: 'flex-end' }}>\n+    </>\n+  );\n+}\n+\n+function GlobalMenuItems({ DEV_MODE, experimentInfo, outdatedPluginsCount }) {\n+  return (\n+    <>\n+      {' '}\n+      <List sx={{ flex: 1, overflowY: 'auto' }}>\n         <Divider sx={{ marginBottom: 2 }} />\n \n         <SubNavItem title=\"Model Zoo\" path=\"/zoo\" icon={<BoxesIcon />} />\n@@ -244,97 +170,172 @@ export default function Sidebar({\n           counter={outdatedPluginsCount}\n         />\n         <SubNavItem title=\"Computer\" path=\"/computer\" icon={<MonitorIcon />} />\n+      </List>\n+    </>\n+  );\n+}\n \n-        {/* <ListItem>\n-          <ListItemButton\n-            onClick={() => {\n-              setDrawerOpen(true);\n+function BottomMenuItems({ DEV_MODE, navigate, themeSetter }) {\n+  return (\n+    <>\n+      {' '}\n+      <Divider sx={{ my: 2 }} />\n+      <Box\n+        sx={{\n+          display: DEV_MODE ? 'flex' : 'none',\n+          gap: 1,\n+          alignItems: 'center',\n+          mb: 1,\n+          maxWidth: '180px',\n+        }}\n+      >\n+        {/* <Avatar\n+variant=\"outlined\"\n+size=\"sm\"\n+src=\"https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=286\"\n+/> */}\n+        <UserIcon />\n+        <Box sx={{ minWidth: 0, flex: 1 }}>\n+          <Typography\n+            level=\"title-sm\"\n+            sx={{\n+              whiteSpace: 'nowrap',\n+              overflow: 'hidden',\n+              textOverflow: 'ellipsis',\n             }}\n-            sx={{ justifyContent: 'center' }}\n           >\n-            <ListItemDecorator>\n-              <TerminalSquareIcon strokeWidth={1.5} />\n-            </ListItemDecorator>\n-            <ListItemContent>Terminal</ListItemContent>\n-          </ListItemButton>\n-        </ListItem> */}\n-        <Divider sx={{ my: 2 }} />\n-        <Box\n-          sx={{\n-            display: DEV_MODE ? 'flex' : 'none',\n-            gap: 1,\n-            alignItems: 'center',\n-            mb: 1,\n-            maxWidth: '180px',\n-          }}\n-        >\n-          {/* <Avatar\n-            variant=\"outlined\"\n-            size=\"sm\"\n-            src=\"https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=286\"\n-          /> */}\n-          <UserIcon />\n-          <Box sx={{ minWidth: 0, flex: 1 }}>\n-            <Typography\n-              level=\"title-sm\"\n-              sx={{\n-                whiteSpace: 'nowrap',\n-                overflow: 'hidden',\n-                textOverflow: 'ellipsis',\n-              }}\n-            >\n-              User Name\n-            </Typography>\n-            <Typography\n-              level=\"body-xs\"\n-              sx={{\n-                whiteSpace: 'nowrap',\n-                overflow: 'hidden',\n-                textOverflow: 'ellipsis',\n-              }}\n-            >\n-              user@test.com\n-            </Typography>\n-          </Box>\n-          <IconButton size=\"sm\" variant=\"plain\" color=\"neutral\">\n-            <LogOutIcon size=\"18px\" />\n-          </IconButton>\n+            User Name\n+          </Typography>\n+          <Typography\n+            level=\"body-xs\"\n+            sx={{\n+              whiteSpace: 'nowrap',\n+              overflow: 'hidden',\n+              textOverflow: 'ellipsis',\n+            }}\n+          >\n+            user@test.com\n+          </Typography>\n         </Box>\n-        <ButtonGroup\n-          sx={{\n-            display: 'flex',\n-            justifyContent: 'space-between',\n-            alignItems: 'center',\n-          }}\n+        <IconButton size=\"sm\" variant=\"plain\" color=\"neutral\">\n+          <LogOutIcon size=\"18px\" />\n+        </IconButton>\n+      </Box>\n+      <ButtonGroup\n+        sx={{\n+          display: 'flex',\n+          justifyContent: 'space-between',\n+          alignItems: 'center',\n+        }}\n+      >\n+        <ColorSchemeToggle themeSetter={themeSetter} />\n+        <a\n+          href=\"https://github.com/transformerlab/transformerlab-app/\"\n+          target=\"_blank\"\n+          rel=\"noreferrer\"\n+          aria-label=\"Visit Transformer Lab on Github\"\n         >\n-          <ColorSchemeToggle themeSetter={themeSetter} />\n-          <a\n-            href=\"https://github.com/transformerlab/transformerlab-app/\"\n-            target=\"_blank\"\n+          <Tooltip\n+            title={\n+              <>\n+                Visit Transformer Lab on Github\n+                <br />\n+                to contribute to the project or\n+                <br />\n+                send a bug report.\n+              </>\n+            }\n           >\n-            <Tooltip\n-              title={\n-                <>\n-                  Visit Transformer Lab on Github\n-                  <br />\n-                  to contribute to the project or\n-                  <br />\n-                  send a bug report.\n-                </>\n-              }\n-            >\n-              <IconButton variant=\"plain\">\n-                <GithubIcon strokeWidth={1} />\n-              </IconButton>\n-            </Tooltip>\n-          </a>\n-          <Tooltip title=\"Settings\">\n-            <IconButton variant=\"plain\" onClick={() => navigate('/settings')}>\n-              <SettingsIcon strokeWidth={1} />\n+            <IconButton variant=\"plain\">\n+              <GithubIcon strokeWidth={1} />\n             </IconButton>\n           </Tooltip>\n-        </ButtonGroup>\n-      </List>\n+        </a>\n+        <Tooltip title=\"Settings\">\n+          <IconButton variant=\"plain\" onClick={() => navigate('/settings')}>\n+            <SettingsIcon strokeWidth={1} />\n+          </IconButton>\n+        </Tooltip>\n+      </ButtonGroup>\n+    </>\n+  );\n+}\n+\n+export default function Sidebar({\n+  experimentInfo,\n+  setExperimentId,\n+  logsDrawerOpen,\n+  setLogsDrawerOpen,\n+  themeSetter,\n+}) {\n+  const { models, isError, isLoading } = useModelStatus();\n+  const { outdatedPluginsCount } = usePluginStatus(experimentInfo);\n+\n+  const navigate = useNavigate();\n+\n+  const DEV_MODE = experimentInfo?.name === 'dev';\n+\n+  return (\n+    <Sheet\n+      className=\"Sidebar\"\n+      sx={{\n+        gridArea: 'sidebar',\n+        borderRight: '1px solid',\n+        borderColor: 'divider',\n+        transition: 'transform 0.4s',\n+        zIndex: 100,\n+        height: '100%',\n+        overflow: 'auto',\n+        top: 0,\n+        p: 2,\n+        py: 1,\n+        pt: '0',\n+        flexShrink: 0,\n+        display: 'flex',\n+        flexDirection: 'column',\n+        gap: 1,\n+        userSelect: 'none',\n+        width: '100%',\n+        // opacity: 0.4,\n+        '& .lucide': {\n+          strokeWidth: '1.5px',\n+        },\n+        '& .MuiBadge-root': {},\n+      }}\n+    >\n+      <div\n+        style={{\n+          width: '100%',\n+          height: '52px',\n+          '-webkit-app-region': 'drag',\n+          display: 'flex',\n+          alignItems: 'flex-end',\n+          justifyContent: 'center',\n+          color: 'var(--joy-palette-neutral-plainDisabledColor)',\n+        }}\n+      >\n+        {DEV_MODE && <>Transformer Lab v{window.platform?.version}</>}\n+      </div>\n+      <SelectExperimentMenu\n+        experimentInfo={experimentInfo}\n+        setExperimentId={setExperimentId}\n+        models={models}\n+      />\n+      <ExperimentMenuItems\n+        DEV_MODE={DEV_MODE}\n+        experimentInfo={experimentInfo}\n+        models={models}\n+      />\n+      <GlobalMenuItems\n+        DEV_MODE={DEV_MODE}\n+        experimentInfo={experimentInfo}\n+        outdatedPluginsCount={outdatedPluginsCount}\n+      />\n+      <BottomMenuItems\n+        DEV_MODE={DEV_MODE}\n+        navigate={navigate}\n+        themeSetter={themeSetter}\n+      />\n     </Sheet>\n   );\n }\n", "test_patch": "", "problem_statement": "First model downloaded doesn't have progress\nThe first HF model downloaded checks the hub dir, but it hasn't been created yet:\n\n>>     self._target(*self._args, **self._kwargs)\n  File \"/home/ali/workspace/transformerlab-api/transformerlab/shared/download_huggingface_model.py\", line 237, in check_disk_size\n    starting_size_of_huggingface_cache_in_mb = get_dir_size(cache_dir) / 1024 / 1024\n                                               ^^^^^^^^^^^^^^^^^^^^^^^\n  File \"/home/ali/workspace/transformerlab-api/transformerlab/shared/download_huggingface_model.py\", line 103, in get_dir_size\n\n>>     with os.scandir(path) as it:\n         ^^^^^^^^^^^^^^^^\nFileNotFoundError: [Errno 2] No such file or directory: '/home/ali/.cache/huggingface/hub'\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/26c49c8be809636a4d6bc27a1d025a4591c0a30a", "https://github.com/transformerlab/transformerlab-app/commit/1bf23ba142d03d4ed01f3eb49c2b344f6d0d2b43", "https://github.com/transformerlab/transformerlab-app/commit/515b34a92373faae07b0f3c11124e27332af68aa", "https://github.com/transformerlab/transformerlab-app/commit/554a9a735c4ea90dc15daabbb9b3cd3d7633fd9e", "https://github.com/transformerlab/transformerlab-app/commit/360ad712362bad186b64244cfb9c7cc0d0de93ad", "https://github.com/transformerlab/transformerlab-app/commit/a08e230f06ba93d5032c96a1c5cfa8b7d94fc36d"], "created_at": "2025-03-24T21:05:18Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 358, "instance_id": "transformerlab__transformerlab-app-358", "issue_numbers": [505], "base_commit": "5070903fb5caa2dc2865d0ed619a0e54c259c211", "patch": "diff --git a/src/renderer/components/Shared/Documents/index.tsx b/src/renderer/components/Shared/Documents/index.tsx\nindex ce9cba03a..b1cff4c83 100644\n--- a/src/renderer/components/Shared/Documents/index.tsx\n+++ b/src/renderer/components/Shared/Documents/index.tsx\n@@ -40,6 +40,7 @@ import {\n   SearchIcon,\n   FilterIcon as FilterAltIcon,\n   MoreVerticalIcon as MoreHorizRoundedIcon,\n+  LinkIcon,\n } from 'lucide-react';\n \n import useSWR from 'swr';\n@@ -323,11 +324,31 @@ export default function Documents({\n   const [dropzoneActive, setDropzoneActive] = React.useState(false);\n   const [previewFile, setPreviewFile] = React.useState<string | null>(null);\n   const [showFolderModal, setShowFolderModal] = React.useState(false);\n+  const [showWebpageModal, setShowWebpageModal] = React.useState(false);\n+  const [webpageUrls, setWebpageUrls] = React.useState(['']);\n   const [newFolderName, setNewFolderName] = React.useState('');\n   const [loading, setLoading] = React.useState(false);\n   const [currentFolder, setCurrentFolder] = React.useState(fixedFolder);\n   const [order, setOrder] = React.useState<Order>('asc');\n \n+  const addUrlField = () => {\n+    setWebpageUrls([...webpageUrls, '']);\n+  };\n+\n+  const removeUrlField = (index) => {\n+    if (webpageUrls.length > 1) {\n+      const newUrls = [...webpageUrls];\n+      newUrls.splice(index, 1);\n+      setWebpageUrls(newUrls);\n+    }\n+  };\n+\n+  const updateUrl = (index, value) => {\n+    const newUrls = [...webpageUrls];\n+    newUrls[index] = value;\n+    setWebpageUrls(newUrls);\n+  };\n+\n   const {\n     data: rows,\n     isLoading,\n@@ -449,6 +470,114 @@ export default function Documents({\n           </Box>\n         </ModalDialog>\n       </Modal>\n+      <Modal open={showWebpageModal} onClose={() => setShowWebpageModal(false)}>\n+        <ModalDialog sx={{ width: '450px', maxWidth: '90vw' }}>\n+          <ModalClose />\n+          <Typography level=\"title-lg\">Add Webpages</Typography>\n+          <Typography level=\"body-sm\" sx={{ mb: 2 }}>\n+            Enter webpage URLs you want to add to your documents\n+          </Typography>\n+\n+          <Box sx={{ mb: 2, maxHeight: '50vh', overflowY: 'auto' }}>\n+            {webpageUrls.map((url, index) => (\n+              <Box\n+                key={index}\n+                sx={{\n+                  display: 'flex',\n+                  alignItems: 'center',\n+                  mb: 1.5,\n+                  gap: 1,\n+                }}\n+              >\n+                <Input\n+                  size=\"sm\"\n+                  placeholder=\"https://example.com\"\n+                  value={url}\n+                  onChange={(e) => updateUrl(index, e.target.value)}\n+                  sx={{ flexGrow: 1 }}\n+                  error={url && !url.startsWith('http')}\n+                  endDecorator={\n+                    webpageUrls.length > 1 && (\n+                      <IconButton\n+                        size=\"sm\"\n+                        variant=\"plain\"\n+                        color=\"neutral\"\n+                        onClick={() => removeUrlField(index)}\n+                      >\n+                        <Typography fontSize=\"lg\">\u00d7</Typography>\n+                      </IconButton>\n+                    )\n+                  }\n+                />\n+              </Box>\n+            ))}\n+          </Box>\n+\n+          <Button\n+            variant=\"outlined\"\n+            color=\"neutral\"\n+            size=\"sm\"\n+            onClick={addUrlField}\n+            startDecorator={<PlusCircleIcon size=\"16px\" />}\n+            sx={{ mb: 2 }}\n+          >\n+            Add Another URL\n+          </Button>\n+\n+          <Box sx={{ display: 'flex', justifyContent: 'flex-end' }}>\n+            <Button\n+              color=\"primary\"\n+              onClick={() => {\n+                setLoading(true);\n+                const validUrls = webpageUrls\n+                  .map((url) => url.trim())\n+                  .filter((url) => url && url.includes('://'));\n+                if (validUrls.length > 0) {\n+                  fetch(\n+                    chatAPI.Endpoints.Documents.UploadLinks(\n+                      experimentInfo?.id,\n+                      currentFolder,\n+                    ),\n+                    {\n+                      method: 'POST',\n+                      headers: {\n+                        'Content-Type': 'application/json',\n+                      },\n+                      body: JSON.stringify({\n+                        urls: validUrls,\n+                      }),\n+                    },\n+                  )\n+                    .then((response) => {\n+                      if (!response.ok)\n+                        throw new Error('Failed to add webpages');\n+                      return response.json();\n+                    })\n+                    .then((data) => {\n+                      console.log('Webpages added:', data);\n+                      setWebpageUrls(['']);\n+                      setShowWebpageModal(false);\n+                      mutate();\n+                    })\n+                    .catch((error) => {\n+                      console.error('Error adding webpages:', error);\n+                    })\n+                    .finally(() => {\n+                      setLoading(false);\n+                    });\n+                } else {\n+                  setLoading(false);\n+                  // Could add a toast or alert here about no valid URLs\n+                }\n+              }}\n+              disabled={!webpageUrls.some((url) => url.trim())}\n+            >\n+              {loading ? <CircularProgress size=\"sm\" /> : 'Add Webpages'}\n+            </Button>\n+          </Box>\n+        </ModalDialog>\n+      </Modal>\n+\n       <Box\n         sx={{\n           display: 'flex',\n@@ -506,6 +635,17 @@ export default function Documents({\n               </ListItemDecorator>\n               Upload File\n             </MenuItem>\n+            <MenuItem\n+              onClick={() => {\n+                setWebpageUrls(['']);\n+                setShowWebpageModal(true);\n+              }}\n+            >\n+              <ListItemDecorator>\n+                <LinkIcon size=\"16px\" />\n+              </ListItemDecorator>\n+              Add Webpage\n+            </MenuItem>\n             <MenuItem\n               onClick={() => {\n                 setNewFolderName('');\ndiff --git a/src/renderer/lib/transformerlab-api-sdk.ts b/src/renderer/lib/transformerlab-api-sdk.ts\nindex 1c69ebaaa..11a9341c0 100644\n--- a/src/renderer/lib/transformerlab-api-sdk.ts\n+++ b/src/renderer/lib/transformerlab-api-sdk.ts\n@@ -1259,6 +1259,12 @@ Endpoints.Documents = {\n     experimentId +\n     '/documents/create_folder?name=' +\n     folderName,\n+  UploadLinks: (experimentId: string, folderName: string) =>\n+    API_URL() +\n+    'experiment/' +\n+    experimentId +\n+    '/documents/upload_links?folder=' +\n+    folderName,\n };\n \n Endpoints.Rag = {\n", "test_patch": "", "problem_statement": "I use Apple mlx lora tainer to fine-tune qwen3 8b. It will always output {{{{{{{{{{{{{{{{{{{ It seems that it does not match the end character.\n![Image](https://github.com/user-attachments/assets/a952388f-d20e-488e-b820-f24b349b8236)\n\n![Image](https://github.com/user-attachments/assets/30e42440-f610-4403-a34e-10168d50e6cd)\n\n![Image](https://github.com/user-attachments/assets/1255a74e-c8e4-430e-a11e-dfd898f15024)\n\n![Image](https://github.com/user-attachments/assets/f2066b63-fc08-4606-b3fe-18bfa3e4a551)\n\nI use Apple mlx lora tainer to fine-tune qwen3 8b. It will always output {{{{{{{{{{{{{{{{{{{ It seems that it does not match the end character.\n\n![Image](https://github.com/user-attachments/assets/2e5fe195-d047-4cf0-b04c-94d5bc5fe918)\n", "hints_text": "\n\n", "all_hints_text": "https://github.com/QwenLM/Qwen3/issues/198 \nHi, \nIt seems to me that since you wrote the template as {{messages}}, the adaptor somehow only learnt to predict the \"{\" character because that is the most prominent in each entry. Rather than this, if you could format your dataset into rows of system and user messages and provide a template after that on the new dataset, then the adaptor might train properly. We will still have a look and see if there is any other issues with the end character as you mentioned\nwhy , So I have a chat dataset. How should I write it? How should I make a chat dataset?\nThe MLX LoRA trainer plugin takes a very simple approach and essentially doesn't handle any formatting for you.  i.e. It does not convert your JSON into a chat template that the model was trained on.  Instead it is just passing that JSON object to the model directly and teaching it to respond like that.\n\nSo your options are essentially:\n1. Use the Transformer Lab template editor (which uses Jinja) to apply a chat template.\n2. Pre-process your dataset to make 1 easier\n3. Depending on what your dataset looks like, maybe the chat template is not important since Qwen 3 is already trained well to chat. For example, I have previously had success just supplying questions and answers as raw unformatted text.\n\nI realize this is not easy.  We have an issue to hopefully improve this in the future:\nhttps://github.com/transformerlab/transformerlab-app/issues/168\n\nSome additional conversation about the Qwen3 chat template to get an idea of what it looks like:\nhttps://www.reddit.com/r/LocalLLaMA/comments/1klltt4/the_qwen3_chat_template_is_still_bugged/\n\nthank you\ni use  ' mlx_lm.lora --model /Users/caozhihui/ai_model/Qwen/Qwen3-8B --train --data ./data' \ntry it again and see if there is no problem\n![Image](https://github.com/user-attachments/assets/fd30ca5c-7f35-46bc-a959-82fbac23ecd8)\n\nI used mlx_lm.lora command to fine-tune , and then imported the fused model into transformerLab , and it output what I wanted, but when I asked the same question for the second time, it would output <|endoftext|>\nHmmm that is peculiar.  <|endoftext\\> is the pad string on this model so it shouldn't display that.  But what's weirder is that you didn't get a response before that.  \n\nIt's hard for me to guess what's happening, especially since I can't read your chat unfortunately. Are you using a dataset that is publicly available?  Perhaps I could look at it and try to see if I can spot the issue.  \n\n<img width=\"890\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/e7bcefa5-7594-4562-a2d6-66674e89d551\" />\n\nhttps://github.com/ml-explore/mlx-lm\n\n\nIs this added?\nNo! I am not sure when they added that, but I will look into this and fix!  Thanks for finding this!\n\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/6dba3d37a3db7e0b5e5f7692add54c1afd139c04"], "created_at": "2025-04-08T18:53:23Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 332, "instance_id": "transformerlab__transformerlab-app-332", "issue_numbers": [506], "base_commit": "9aaebeaf250b16af371cf16432350f579c6cbb49", "patch": "diff --git a/src/renderer/components/Experiment/Widgets/CustomEvaluationWidget.tsx b/src/renderer/components/Experiment/Widgets/CustomEvaluationWidget.tsx\nindex 71b8f5a8a..26b4ef0a2 100644\n--- a/src/renderer/components/Experiment/Widgets/CustomEvaluationWidget.tsx\n+++ b/src/renderer/components/Experiment/Widgets/CustomEvaluationWidget.tsx\n@@ -107,6 +107,7 @@ const CustomEvaluationWidget = (props: WidgetProps<any>) => {\n             <Option value=\"number\">Number (Regex)</Option>\n             <Option value=\"contains\">Contains</Option>\n             <Option value=\"isequal\">IsEqual</Option>\n+            <Option value=\"code\">Code</Option>\n           </Select>\n           <Button\n             onClick={() => handleRemoveField(index)}\n", "test_patch": "", "problem_statement": "Hide output_###.txt files from Plugin Editor file list\nPlugins generate output in the plugin folder, which ends up showing up in the plugin editor. Change where output goes so that the plugin folder stays clean\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/9817648ec354de684c01620771ada97a8057bbb2"], "created_at": "2025-03-24T21:19:31Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 306, "instance_id": "transformerlab__transformerlab-app-306", "issue_numbers": [518], "base_commit": "4daa3bd952868a448e8397072688d76a83e888d2", "patch": "diff --git a/src/renderer/components/Experiment/Rag/Documents.tsx b/src/renderer/components/Experiment/Rag/Documents.tsx\nindex beb29f851..7465b117c 100644\n--- a/src/renderer/components/Experiment/Rag/Documents.tsx\n+++ b/src/renderer/components/Experiment/Rag/Documents.tsx\n@@ -98,7 +98,7 @@ function stableSort<T>(\n   return stabilizedThis?.map((el) => el[0]);\n }\n \n-function RowMenu({ experimentInfo, filename, mutate, row }) {\n+function RowMenu({ experimentInfo, filename, foldername, mutate, row }) {\n   return (\n     <Dropdown>\n       <MenuButton\n@@ -115,7 +115,7 @@ function RowMenu({ experimentInfo, filename, mutate, row }) {\n           color=\"danger\"\n           onClick={() => {\n             fetch(\n-              chatAPI.Endpoints.Documents.Delete(experimentInfo?.id, filename),\n+              chatAPI.Endpoints.Documents.Delete(experimentInfo?.id, filename, foldername),\n             ).then((response) => {\n               if (response.ok) {\n                 console.log(response);\n@@ -276,6 +276,7 @@ export default function Documents({\n             <RowMenu\n               experimentInfo={experimentInfo}\n               filename={row?.name}\n+              foldername={currentFolder}\n               mutate={mutate}\n               row={row}\n             />\n@@ -349,6 +350,7 @@ export default function Documents({\n             <RowMenu\n               experimentInfo={experimentInfo}\n               filename={row?.name}\n+              foldername={currentFolder}\n               mutate={mutate}\n               row={row}\n             />\ndiff --git a/src/renderer/lib/transformerlab-api-sdk.ts b/src/renderer/lib/transformerlab-api-sdk.ts\nindex 66b078d3d..7f58a0ad6 100644\n--- a/src/renderer/lib/transformerlab-api-sdk.ts\n+++ b/src/renderer/lib/transformerlab-api-sdk.ts\n@@ -1139,12 +1139,14 @@ Endpoints.Documents = {\n     experimentId +\n     '/documents/upload?folder=' +\n     currentFolder,\n-  Delete: (experimentId: string, document_name: string) =>\n+  Delete: (experimentId: string, document_name: string, folder: string) =>\n     API_URL() +\n     'experiment/' +\n     experimentId +\n-    '/documents/delete/' +\n-    document_name,\n+    '/documents/delete?document_name=' +\n+    document_name +\n+    '&folder=' +\n+    folder,\n   CreateFolder: (experimentId: string, folderName: string) =>\n     API_URL() +\n     'experiment/' +\n", "test_patch": "", "problem_statement": "Image history CORS issues\n\"Select Image from History\" doesn't work when you pick the image if you are running the server at a different location than the backend:\n```\nHistoryImageSelector.tsx:62 \n\n\n           GET http://100.110.254.112:8338/diffusion/history/4250dadb-b1df-4563-b1f9-9fce267e60cc?index=0 net::ERR_FAILED\nhandleConfirmSelection @ HistoryImageSelector.tsx:62\nhandleClick @ Button.js:251\ncallCallback @ react-dom.development.js:4164\ninvokeGuardedCallbackDev @ react-dom.development.js:4213\ninvokeGuardedCallback @ react-dom.development.js:4277\ninvokeGuardedCallbackAndCatchFirstError @ react-dom.development.js:4291\nexecuteDispatch @ react-dom.development.js:9041\nprocessDispatchQueueItemsInOrder @ react-dom.development.js:9073\nprocessDispatchQueue @ react-dom.development.js:9086\ndispatchEventsForPlugins @ react-dom.development.js:9097\n(anonymous) @ react-dom.development.js:9288\nbatchedUpdates$1 @ react-dom.development.js:26179\nbatchedUpdates @ react-dom.development.js:3991\ndispatchEventForPluginEventSystem @ react-dom.development.js:9287\ndispatchEventWithEnableCapturePhaseSelectiveHydrationWithoutDiscreteEventReplay @ react-dom.development.js:6465\ndispatchEvent @ react-dom.development.js:6457\ndispatchDiscreteEvent @ react-dom.development.js:6430Understand this error\n:1212/#/experiment/diffusion:1 Access to fetch at 'http://100.110.254.112:8338/diffusion/history/4250dadb-b1df-4563-b1f9-9fce267e60cc?index=0' from origin 'http://localhost:1212/' has been blocked by CORS policy: No 'Access-Control-Allow-Origin' header is present on the requested resource.Understand this error\nHistoryImageSelector.tsx:62 \n\n\n           GET http://100.110.254.112:8338/diffusion/history/4250dadb-b1df-4563-b1f9-9fce267e60cc?index=0 net::ERR_FAILED\n```\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/224b48fd588f265c8d78d380d88df8729f621d95"], "created_at": "2025-03-06T19:55:37Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 695, "instance_id": "transformerlab__transformerlab-app-695", "issue_numbers": [689], "base_commit": "5a650d5ddb3c13afc9f79fdc64e10f82a3d62f36", "patch": "diff --git a/src/renderer/components/Data/DatasetPreviewWithTemplate.tsx b/src/renderer/components/Data/DatasetPreviewWithTemplate.tsx\nindex 7708c8ba8..c84efaade 100644\n--- a/src/renderer/components/Data/DatasetPreviewWithTemplate.tsx\n+++ b/src/renderer/components/Data/DatasetPreviewWithTemplate.tsx\n@@ -15,6 +15,7 @@ import * as chatAPI from '../../lib/transformerlab-api-sdk';\n import { ChevronLeftIcon, ChevronRightIcon, Sheet } from 'lucide-react';\n import useSWR from 'swr';\n import { useAPI } from 'renderer/lib/transformerlab-api-sdk';\n+import { useNotification } from '../Shared/NotificationSystem';\n \n const fetcher = (url) =>\n   fetch(url)\n@@ -39,6 +40,7 @@ const DatasetTableWithTemplate = ({\n   };\n \n   const shouldUseChatTemplate = !!modelName && !!chatColumn;\n+  const { addNotification } = useNotification();\n \n   const {\n     data: result,\n@@ -73,6 +75,12 @@ const DatasetTableWithTemplate = ({\n     if (isLoading) {\n       return <LinearProgress />;\n     }\n+    if (result?.status === 'error') {\n+      addNotification({\n+        type: 'warning',\n+        message: result?.message,\n+      });\n+    }\n     return '';\n   }\n   return (\ndiff --git a/src/renderer/components/Experiment/Train/TrainingModalLoRA.tsx b/src/renderer/components/Experiment/Train/TrainingModalLoRA.tsx\nindex 1be6bb2ec..160f851bd 100644\n--- a/src/renderer/components/Experiment/Train/TrainingModalLoRA.tsx\n+++ b/src/renderer/components/Experiment/Train/TrainingModalLoRA.tsx\n@@ -32,6 +32,29 @@ import TrainingModalDataTemplatingTab from './TrainingModalDataTemplatingTab';\n import SafeJSONParse from 'renderer/components/Shared/SafeJSONParse';\n const fetcher = (url) => fetch(url).then((res) => res.json());\n \n+function isValidChatMessageList(input: any): boolean {\n+  try {\n+    const parsed = typeof input === 'string' ? JSON.parse(input) : input;\n+\n+    if (!Array.isArray(parsed)) return false;\n+\n+    for (const msg of parsed) {\n+      if (\n+        typeof msg !== 'object' ||\n+        msg === null ||\n+        typeof msg.role !== 'string' ||\n+        typeof msg.content !== 'string'\n+      ) {\n+        return false;\n+      }\n+    }\n+\n+    return true;\n+  } catch (e) {\n+    return false;\n+  }\n+}\n+\n function PluginIntroduction({ experimentInfo, pluginId }) {\n   const { data, error, isLoading } = useSWR(\n     chatAPI.Endpoints.Experiment.ScriptGetFile(\n@@ -593,9 +616,9 @@ export default function TrainingModalLoRA({\n             // If the form is not valid\n             if (!formEl.checkValidity()) {\n               // Get the first invalid element\n-              const firstInvalid = formEl.querySelector(':invalid') as\n-                | HTMLElement\n-                | null;\n+              const firstInvalid = formEl.querySelector(\n+                ':invalid',\n+              ) as HTMLElement | null;\n \n               if (firstInvalid) {\n                 // Get the tab containing the invalid element\n@@ -621,9 +644,9 @@ export default function TrainingModalLoRA({\n \n                 // Get invalid element again (after triggering browser validation)\n                 // reportValidity() can cause the browser to update validation state\n-                const invalidEl = formEl.querySelector(':invalid') as\n-                  | HTMLElement\n-                  | null;\n+                const invalidEl = formEl.querySelector(\n+                  ':invalid',\n+                ) as HTMLElement | null;\n \n                 if (invalidEl) {\n                   // Scroll to the element and focus it\n@@ -748,16 +771,30 @@ export default function TrainingModalLoRA({\n               <Tab>Plugin Config</Tab>\n               {runSweeps && <Tab>Sweep Config</Tab>}\n             </TabList>\n-            <TabPanel data-tab-index={0} value={0} sx={{ p: 2, overflow: 'auto' }}>\n+            <TabPanel\n+              data-tab-index={0}\n+              value={0}\n+              sx={{ p: 2, overflow: 'auto' }}\n+            >\n               <PluginIntroduction\n                 experimentInfo={experimentInfo}\n                 pluginId={pluginId}\n               />\n             </TabPanel>\n-            <TabPanel data-tab-index={1} value={1} sx={{ p: 2, overflow: 'auto' }} keepMounted>\n+            <TabPanel\n+              data-tab-index={1}\n+              value={1}\n+              sx={{ p: 2, overflow: 'auto' }}\n+              keepMounted\n+            >\n               <TrainingModalFirstTab />\n             </TabPanel>\n-            <TabPanel data-tab-index={3} value={3} sx={{ p: 2, overflow: 'auto' }} keepMounted>\n+            <TabPanel\n+              data-tab-index={3}\n+              value={3}\n+              sx={{ p: 2, overflow: 'auto' }}\n+              keepMounted\n+            >\n               <TrainingModalDataTemplatingTab\n                 selectedDataset={selectedDataset}\n                 currentDatasetInfo={currentDatasetInfo}\n@@ -775,7 +812,12 @@ export default function TrainingModalLoRA({\n                 setFormattingChatTemplate={setFormattingChatTemplate}\n               />\n             </TabPanel>\n-            <TabPanel data-tab-index={2} value={2} sx={{ p: 2, overflow: 'auto' }} keepMounted>\n+            <TabPanel\n+              data-tab-index={2}\n+              value={2}\n+              sx={{ p: 2, overflow: 'auto' }}\n+              keepMounted\n+            >\n               <>\n                 {currentTab === 2 && (\n                   <OneTimePopup title=\"How to Create a Training Template:\">\n@@ -813,7 +855,12 @@ export default function TrainingModalLoRA({\n                 />\n               </>\n             </TabPanel>\n-            <TabPanel data-tab-index={4} value={4} sx={{ p: 2, overflow: 'auto' }} keepMounted>\n+            <TabPanel\n+              data-tab-index={4}\n+              value={4}\n+              sx={{ p: 2, overflow: 'auto' }}\n+              keepMounted\n+            >\n               <DynamicPluginForm\n                 experimentInfo={experimentInfo}\n                 plugin={pluginId}\n@@ -821,7 +868,12 @@ export default function TrainingModalLoRA({\n               />\n             </TabPanel>\n             {runSweeps && (\n-              <TabPanel data-tab-index={5} value={5} sx={{ p: 2, overflow: 'auto' }} keepMounted>\n+              <TabPanel\n+                data-tab-index={5}\n+                value={5}\n+                sx={{ p: 2, overflow: 'auto' }}\n+                keepMounted\n+              >\n                 <SweepConfigTab\n                   trainingTypeData={trainingTypeData}\n                   sweepConfig={sweepConfig}\n@@ -839,7 +891,10 @@ export default function TrainingModalLoRA({\n               type=\"submit\"\n               color=\"success\"\n               disabled={\n-                applyChatTemplate && (!chatColumn || chatColumn.trim() === '')\n+                applyChatTemplate &&\n+                (!chatColumn ||\n+                  chatColumn.trim() === '' ||\n+                  !isValidChatMessageList(chatColumn))\n               }\n             >\n               Save Training Template\n", "test_patch": "", "problem_statement": "Apply chat template to non chat formatted doesn't show an error\nLoad the Touch Rugby recipe\nGo to training and turn on chat template while on the data tab\nNothing is shown but in the logs you can see that the template didn't work\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/9d79ba9128bcb2dfff98dbf73fb72a8b5450f27a", "https://github.com/transformerlab/transformerlab-app/commit/7e5380dfb388d2586739a85726aa2b5b182bd6e9", "https://github.com/transformerlab/transformerlab-app/commit/7e5e73ce2a23eda175e4b8e019cb2c003a3c24be", "https://github.com/transformerlab/transformerlab-app/commit/a8626b7a84718692c2648d1fd4e650908cb6f450"], "created_at": "2025-07-23T18:13:52Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 838, "instance_id": "transformerlab__transformerlab-app-838", "issue_numbers": [690, 698], "base_commit": "6a1fedde3c2263e70c76f75ba65556392bf4da4f", "patch": "diff --git a/src/renderer/components/Experiment/Interact/SystemMessageBox.tsx b/src/renderer/components/Experiment/Interact/SystemMessageBox.tsx\nindex 645bb1a44..d7f166725 100644\n--- a/src/renderer/components/Experiment/Interact/SystemMessageBox.tsx\n+++ b/src/renderer/components/Experiment/Interact/SystemMessageBox.tsx\n@@ -39,6 +39,12 @@ export default function SystemMessageBox({\n   const [isSaving, setIsSaving] = useState(false);\n   const [savingMessage, setSavingMessage] = useState('');\n \n+  // Cross-environment deep clone helper. Prefer structuredClone when available.\n+  const deepClone = (obj: any) =>\n+    typeof (globalThis as any).structuredClone === 'function'\n+      ? (globalThis as any).structuredClone(obj)\n+      : JSON.parse(JSON.stringify(obj));\n+\n   // Get the current system message to display\n   const getDisplayedSystemMessage = () => {\n     if (isOverrideEnabled) {\n@@ -110,17 +116,12 @@ export default function SystemMessageBox({\n   };\n \n   const handleOverrideToggle = (checked: boolean) => {\n-    let newPrompt = experimentInfo?.config?.prompt_template;\n-\n-    // If undefined, initialize it as an empty object\n-    if (newPrompt === undefined || newPrompt === null) {\n-      newPrompt = {};\n-    }\n+    let currentPrompt = SafeJSONParse(\n+      experimentInfo?.config?.prompt_template,\n+      {},\n+    );\n \n-    // Make new prompt as json\n-    if (typeof newPrompt === 'string') {\n-      newPrompt = JSON.parse(newPrompt);\n-    }\n+    let newPrompt = deepClone(currentPrompt);\n \n     if (checked) {\n       // Enable override - set flag and current custom message\n@@ -136,6 +137,17 @@ export default function SystemMessageBox({\n     }\n \n     // Update state only after server call to avoid timing issues\n+    experimentInfoMutate(\n+      {\n+        ...experimentInfo,\n+        config: {\n+          ...experimentInfo.config,\n+          prompt_template: newPrompt,\n+        },\n+      },\n+      false,\n+    );\n+\n     savePromptToServer(newPrompt);\n     // Note: setIsOverrideEnabled will be updated via useEffect when experimentInfoMutate triggers\n   };\n@@ -152,23 +164,28 @@ export default function SystemMessageBox({\n     // Store the message we're trying to save\n     setSavingMessage(customSystemMessage);\n \n-    let newPrompt = experimentInfo?.config?.prompt_template;\n-\n-    // If undefined, initialize it as an empty object\n-    if (newPrompt === undefined || newPrompt === null) {\n-      newPrompt = {};\n-    }\n+    let currentPrompt = SafeJSONParse(\n+      experimentInfo?.config?.prompt_template,\n+      {},\n+    );\n \n-    // Make new prompt as json\n-    if (typeof newPrompt === 'string') {\n-      newPrompt = JSON.parse(newPrompt);\n-    }\n+    let newPrompt = deepClone(currentPrompt);\n \n     // Preprocess system message to replace date placeholders\n     const processedMessage = preprocessSystemMessage(customSystemMessage);\n \n     newPrompt.system_message_override = true;\n     newPrompt.system_message = processedMessage;\n+    experimentInfoMutate(\n+      {\n+        ...experimentInfo,\n+        config: {\n+          ...experimentInfo.config,\n+          prompt_template: newPrompt,\n+        },\n+      },\n+      false,\n+    );\n \n     savePromptToServer(newPrompt);\n \n", "test_patch": "", "problem_statement": "Can't reset system prompt\nLoad a model and set the system prompt. Change it. Now to go to All Generation Settings and reset it -- it won't show the reset prompt\nCustom system prompt in \"All Generation Settings\" is not the same as the prompt I see during conversation\nRun a model and go to the Interact tab. Click All Generation Settings, then click the custom prompt box to use your own prompt. Save after adding your own prompt. Close the All Generation Settings. It doesn't show my custom prompt unless I click on the text box.\n\n<img width=\"1762\" height=\"887\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/7fe3de96-8dec-4925-84cf-f7fbdf7f84a7\" />\n<img width=\"1762\" height=\"887\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/ec6b1465-dad9-4749-9c02-2a689bcbe9fe\" />\n", "hints_text": "(tested on \nunsloth/Llama-3.2-1B-Instruct on nvidia using fastchat)\nChecking and unchecking the \"Use Custom System Message\" button should work, does it not work for you? \nI tried the same model and did checked and unchecked the custom message and it reset it back to the original one \n@ParamThakkar123 Can you try this out and see if it is fixed or not?\nSure @dadmobile !\n> [@ParamThakkar123](https://github.com/ParamThakkar123) Can you try this out and see if it is fixed or not?\n\nI tried the system prompt reset thing and it works but it doesn't directly get updated on the interact page if the system prompt is updated in the \"All generation settings\" tab. For ex, if I set the prompt to \"You are a fighting agent\" in the \"All generation settings\" tab, the change isn't directly visible on the interact page system message box unless you explicitly click somewhere around the box\nhttps://github.com/user-attachments/assets/3b0c5fd7-b631-4670-92d4-df7241e4b354\n\nI think this is an update issue. Does the prompt show correctly when you send your first message?\nHi, \nThis isn't occurring anymore for me, could you re-verify if its still the case on your end?\n> Hi, This isn't occurring anymore for me, could you re-verify if its still the case on your end?\n\nHi Deep, it still happens. I pulled from the repos and reran npm install and I still get the issue.\nSorry for the lag. Been very busy recently!\nI think this is same as the one I described here https://github.com/transformerlab/transformerlab-app/issues/690#issuecomment-3458018122. Will take a look at it\n\n", "all_hints_text": "(tested on \nunsloth/Llama-3.2-1B-Instruct on nvidia using fastchat)\nChecking and unchecking the \"Use Custom System Message\" button should work, does it not work for you? \nI tried the same model and did checked and unchecked the custom message and it reset it back to the original one \n@ParamThakkar123 Can you try this out and see if it is fixed or not?\nSure @dadmobile !\n> [@ParamThakkar123](https://github.com/ParamThakkar123) Can you try this out and see if it is fixed or not?\n\nI tried the system prompt reset thing and it works but it doesn't directly get updated on the interact page if the system prompt is updated in the \"All generation settings\" tab. For ex, if I set the prompt to \"You are a fighting agent\" in the \"All generation settings\" tab, the change isn't directly visible on the interact page system message box unless you explicitly click somewhere around the box\nhttps://github.com/user-attachments/assets/3b0c5fd7-b631-4670-92d4-df7241e4b354\n\nI think this is an update issue. Does the prompt show correctly when you send your first message?\nHi, \nThis isn't occurring anymore for me, could you re-verify if its still the case on your end?\n> Hi, This isn't occurring anymore for me, could you re-verify if its still the case on your end?\n\nHi Deep, it still happens. I pulled from the repos and reran npm install and I still get the issue.\nSorry for the lag. Been very busy recently!\nI think this is same as the one I described here https://github.com/transformerlab/transformerlab-app/issues/690#issuecomment-3458018122. Will take a look at it\nHi @michael-haroon, \nPlease let me know if this got fixed for you now, it should've gone out in the update yesterday\nHi Deep, I haven't been active and likely won't check if the fix worked. I will promptly reply if I do check!\nAlright thank you so much!\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/ba8f1c3a56b3b8126cfa492f5b40af0a4afc33b4", "https://github.com/transformerlab/transformerlab-app/commit/324743ac3c3beba984fe22fc69a7671a72124b4a", "https://github.com/transformerlab/transformerlab-app/commit/f664dfcbeb20187b80ef2fc7b80eace9144a4405", "https://github.com/transformerlab/transformerlab-app/commit/813f4e732dbcf4074805413f33e2ed890c8f5a94", "https://github.com/transformerlab/transformerlab-app/commit/79c78a587aa7da2a11111c171b836140b0876ba5", "https://github.com/transformerlab/transformerlab-app/commit/6618a12db0367406261116bfffa93a6231b39a7b", "https://github.com/transformerlab/transformerlab-app/commit/ca450b803798ca19cfdbb52f35da28e4822b8586", "https://github.com/transformerlab/transformerlab-app/commit/02a1dbcf8c91ad9576d7ae5a9aa5dab1d497f3c2", "https://github.com/transformerlab/transformerlab-app/commit/a53320066a18f004abc70d9ee95190bfb16da498", "https://github.com/transformerlab/transformerlab-app/commit/4cf890d60b98b75ba1852a075c6ff265e1ef814d", "https://github.com/transformerlab/transformerlab-app/commit/6f02c2ee45df0938b9224525b07291fc75ebced2", "https://github.com/transformerlab/transformerlab-app/commit/3de950a27d4e9eb49956668420e849c944f80c1b", "https://github.com/transformerlab/transformerlab-app/commit/8659445545aa6e3718cad7c8b08159cfbcd3c39c"], "created_at": "2025-10-29T16:50:18Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 656, "instance_id": "transformerlab__transformerlab-app-656", "issue_numbers": [693], "base_commit": "0707d30870291312c76e4f35d062d2b5089eb48e", "patch": "diff --git a/src/renderer/components/Experiment/Workflows/WorkflowRuns/WorkflowRunDisplay.tsx b/src/renderer/components/Experiment/Workflows/WorkflowRuns/WorkflowRunDisplay.tsx\nindex 646cb3c43..b2d0550bd 100644\n--- a/src/renderer/components/Experiment/Workflows/WorkflowRuns/WorkflowRunDisplay.tsx\n+++ b/src/renderer/components/Experiment/Workflows/WorkflowRuns/WorkflowRunDisplay.tsx\n@@ -14,9 +14,27 @@ import {\n } from '@mui/joy';\n import { SquareCheckIcon, Type } from 'lucide-react';\n import dayjs from 'dayjs';\n+import useSWR from 'swr';\n import JobDetails from './JobDetails';\n+import JobProgress from '../../Train/JobProgress';\n import * as chatAPI from '../../../../lib/transformerlab-api-sdk';\n \n+const fetcher = (url: string) => fetch(url).then((res) => res.json());\n+\n+function WorkflowJobProgress({ jobId }: { jobId: string }) {\n+  const { data: jobData } = useSWR(\n+    jobId ? chatAPI.Endpoints.Jobs.Get(jobId) : null,\n+    fetcher,\n+    { refreshInterval: 2000 },\n+  );\n+\n+  if (!jobData) {\n+    return null;\n+  }\n+\n+  return <JobProgress job={jobData} />;\n+}\n+\n export default function WorkflowRunDisplay({\n   selectedWorkflowRun,\n   experimentInfo,\n@@ -60,19 +78,6 @@ export default function WorkflowRunDisplay({\n     }\n   };\n \n-  const formatDuration = (start, end) => {\n-    if (!start || !end) {\n-      return null;\n-    }\n-\n-    const startTime = new Date(start);\n-    const endTime = new Date(end);\n-    const duration = (endTime - startTime) / 1000; // duration in seconds\n-    const minutes = Math.floor(duration / 60);\n-    const seconds = duration % 60;\n-    return `${minutes}m ${seconds}s`;\n-  };\n-\n   return (\n     <Card variant=\"outlined\" sx={{ padding: 2 }}>\n       <JobDetails\n@@ -129,6 +134,9 @@ export default function WorkflowRunDisplay({\n                 py: 1,\n                 borderBottom:\n                   '1px solid var(--joy-palette-neutral-outlinedBorder)',\n+                display: 'flex',\n+                alignItems: 'flex-start',\n+                gap: 2,\n               }}\n             >\n               {job.status === 'RUNNING' ? (\n@@ -138,34 +146,24 @@ export default function WorkflowRunDisplay({\n                     '--CircularProgress-trackThickness': '4px',\n                     '--CircularProgress-progressThickness': '3px',\n                     '--CircularProgress-size': '18px',\n+                    flexShrink: 0,\n                   }}\n                 />\n               ) : (\n-                <SquareCheckIcon />\n+                <SquareCheckIcon style={{ flexShrink: 0 }} />\n               )}\n-              <Box sx={{ width: '100%' }}>\n+              <Box sx={{ flex: '0 0 auto', minWidth: 0 }}>\n                 <Typography level=\"title-lg\">Job ID: {job.jobID}</Typography>\n-                <Typography level=\"title-md\">\n+                <Typography level=\"title-lg\">\n                   {`Task: ${job.task || job.taskName || job.metadata?.task_name || 'N/A'}`}\n                 </Typography>\n-                <Typography level=\"body-md\" sx={{ color: 'text.secondary' }}>\n-                  Status:{' '}\n-                  <Chip\n-                    color={job?.status === 'RUNNING' ? 'success' : 'warning'}\n-                  >\n-                    {job.status}\n-                  </Chip>\n-                </Typography>\n-                <Typography level=\"body-md\" sx={{ color: 'text.secondary' }}>\n-                  Start: {dayjs(job?.jobStartTime).fromNow()}\n-                  {/* | End: {dayjs(job?.jobEndTime).fromNow()} */}\n-                </Typography>\n-                <Typography level=\"body-md\" sx={{ color: 'text.secondary' }}>\n-                  Duration: {formatDuration(job.jobStartTime, job.jobEndTime)}\n-                </Typography>\n+              </Box>\n+              <Box sx={{ flex: 1, px: 2 }}>\n+                <WorkflowJobProgress jobId={job.jobID} />\n               </Box>\n               <Button\n                 variant=\"outlined\"\n+                sx={{ flexShrink: 0 }}\n                 onClick={() => {\n                   setViewJobDetails(job?.jobID);\n                 }}\n", "test_patch": "", "problem_statement": "Support pipeline_parallel_size param in vLLM\nAs discussed, we should add a pipeline_parallel_size param to the vLLM. We can compute \n`tensor_parallel_size = num_gpus // pipeline_parallel_size` when needed but needed to test it out cause it works `if num_gpus % pipeline_parallel_size == 0`\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/d920036b1139a381163a0f2a3dba0ba1d75b3b15", "https://github.com/transformerlab/transformerlab-app/commit/6226ba415225df2faf1ebfc1afdae001a69d6991"], "created_at": "2025-07-14T21:18:11Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 553, "instance_id": "transformerlab__transformerlab-app-553", "issue_numbers": [696], "base_commit": "0b7d6a166f9770917e3833373413af1814b08b6d", "patch": "diff --git a/src/renderer/components/Experiment/Workflows/WorkflowList/WorkflowList.tsx b/src/renderer/components/Experiment/Workflows/WorkflowList/WorkflowList.tsx\nindex a878dd33d..f062e437a 100644\n--- a/src/renderer/components/Experiment/Workflows/WorkflowList/WorkflowList.tsx\n+++ b/src/renderer/components/Experiment/Workflows/WorkflowList/WorkflowList.tsx\n@@ -94,7 +94,21 @@ export default function WorkflowList({ experimentInfo }) {\n   );\n \n   async function runWorkflow(workflowId: string) {\n-    await fetch(chatAPI.Endpoints.Workflows.RunWorkflow(workflowId, experimentInfo.id));\n+    try {\n+      const response = await fetch(\n+        chatAPI.Endpoints.Workflows.RunWorkflow(workflowId, experimentInfo.id),\n+      );\n+\n+      if (response.ok) {\n+        alert(\n+          'Your workflow has started! Navigate to the runs page to view its progress.',\n+        );\n+      } else {\n+        alert('Failed to start workflow. Please try again.');\n+      }\n+    } catch (error) {\n+      alert('Failed to start workflow with error: ' + error);\n+    }\n   }\n   return (\n     <>\n", "test_patch": "", "problem_statement": "Model workers aren't shutting down properly\nSomething changed recently and now when model workers are stopped they say:\n\n`ERROR: Worker Process ended with exit code -15.`\n\nI remember when this was happening with ollama earlier it meant that the server shutdown code wasn't getting called. Not sure if this is related but I'm finding occasionally when testing on azure that GPU memory isn't getting freed and I'm hitting OOM errors because processes continue to run.\n\n", "hints_text": "\n\n", "all_hints_text": "I can confirm that -15 means that the lifespan end thing isn't being called correctly. \n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/046df6e376fd2993d3ae051ca4ec2e2893fc9118", "https://github.com/transformerlab/transformerlab-app/commit/277280cc30cb3a23a094eb744d03af6f8b3fb228"], "created_at": "2025-06-18T21:32:55Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 554, "instance_id": "transformerlab__transformerlab-app-554", "issue_numbers": [722, 759], "base_commit": "0b7d6a166f9770917e3833373413af1814b08b6d", "patch": "diff --git a/src/renderer/components/Experiment/DynamicPluginForm.tsx b/src/renderer/components/Experiment/DynamicPluginForm.tsx\nindex 408895f35..84f519b65 100644\n--- a/src/renderer/components/Experiment/DynamicPluginForm.tsx\n+++ b/src/renderer/components/Experiment/DynamicPluginForm.tsx\n@@ -183,7 +183,7 @@ const CustomRange = function (props: WidgetProps) {\n function CustomSelect<\n   T = any,\n   S extends StrictRJSFSchema = RJSFSchema,\n-  F extends FormContextType = any\n+  F extends FormContextType = any,\n >({\n   schema,\n   id,\n@@ -227,7 +227,7 @@ function CustomSelect<\n   const selectedIndexes = enumOptionsIndexForValue<S>(\n     value,\n     enumOptions,\n-    multiple\n+    multiple,\n   );\n \n   // set a default value for the field if it's not multi-select and value is set\n@@ -305,7 +305,7 @@ This is more performant but less nice looking */\n function CustomSelectSimple<\n   T = any,\n   S extends StrictRJSFSchema = RJSFSchema,\n-  F extends FormContextType = any\n+  F extends FormContextType = any,\n >({\n   schema,\n   id,\n@@ -349,7 +349,7 @@ function CustomSelectSimple<\n   const selectedIndexes = enumOptionsIndexForValue<S>(\n     value,\n     enumOptions,\n-    multiple\n+    multiple,\n   );\n \n   // set a default value for the field if it's not multi-select and value is set\n@@ -390,10 +390,11 @@ function CustomSelectSimple<\n   );\n }\n \n-\n-function CustomAutocompleteWidget<T = any, S extends StrictRJSFSchema = RJSFSchema, F extends FormContextType = any>(\n-  props: WidgetProps<T, S, F>\n-) {\n+function CustomAutocompleteWidget<\n+  T = any,\n+  S extends StrictRJSFSchema = RJSFSchema,\n+  F extends FormContextType = any,\n+>(props: WidgetProps<T, S, F>) {\n   const {\n     id,\n     value,\n@@ -410,14 +411,14 @@ function CustomAutocompleteWidget<T = any, S extends StrictRJSFSchema = RJSFSche\n \n   // Default multiple is true.\n   // const _multiple = typeof multiple === 'undefined' ? true : !!multiple;\n-    // Check both multiple and options.multiple; default is true.\n-    // console.log(\"OPTIONS\", options);\n-    const _multiple =\n+  // Check both multiple and options.multiple; default is true.\n+  // console.log(\"OPTIONS\", options);\n+  const _multiple =\n     typeof multiple !== 'undefined'\n       ? Boolean(multiple)\n       : typeof options.multiple !== 'undefined'\n-      ? Boolean(options.multiple)\n-      : true;\n+        ? Boolean(options.multiple)\n+        : true;\n \n   // console.log(\"multiple\", _multiple);\n   // Determine default value.\n@@ -433,7 +434,7 @@ function CustomAutocompleteWidget<T = any, S extends StrictRJSFSchema = RJSFSche\n \n   // Map enumOptions into objects with label and value.\n   const processedOptionsValues = enumOptions.map((opt) =>\n-    typeof opt === 'object' ? opt.value : opt\n+    typeof opt === 'object' ? opt.value : opt,\n   );\n   // Create processedOptions array as an array of all values in enumOptions\n \n@@ -502,7 +503,7 @@ const widgets: RegistryWidgetsType = {\n   AutoCompleteWidget: CustomAutocompleteWidget,\n   EvaluationWidget: CustomEvaluationWidget,\n   ModelProviderWidget: ModelProviderWidget,\n-  GEvalTasksWidget: GEvalTasksWidget\n+  GEvalTasksWidget: GEvalTasksWidget,\n };\n \n const fetcher = (url) => fetch(url).then((res) => res.json());\n@@ -522,17 +523,20 @@ export default function DynamicPluginForm({\n       chatAPI.Endpoints.Experiment.ScriptGetFile(\n         experimentInfo?.id,\n         plugin,\n-        'index.json'\n+        'index.json',\n       ),\n-    fetcher\n+    fetcher,\n   );\n   const [configData, setConfigData] = React.useState<any>(null);\n   //Using use effect here to update the config data when the data or config changes\n+  // Check for 'FILE NOT FOUND' and set safeData accordingly\n+  const safeData = data === 'FILE NOT FOUND' ? null : data;\n+\n   React.useEffect(() => {\n-    if (config && data) {\n+    if (config && safeData) {\n       let parsedData;\n       try {\n-        parsedData = JSON.parse(data); //Parsing data for easy access to parameters}\n+        parsedData = JSON.parse(safeData); //Parsing data for easy access to parameters\n       } catch (e) {\n         console.error('Error parsing data', e);\n         parsedData = '';\n@@ -544,16 +548,16 @@ export default function DynamicPluginForm({\n           parsedData.parameters &&\n           key in parsedData.parameters\n         ) {\n-        //   if (parsedData.parameters[key].enum) {\n-        //   // Set the enum array such that config[key] is the first element\n-        //   const enumArray = parsedData.parameters[key].enum;\n-        //   let index = enumArray.indexOf(config[key]);\n-        //   if (index > 0) {\n-        //     enumArray.unshift(enumArray.splice(index, 1)[0]);\n-        //   }\n-        //   parsedData.parameters[key].enum = enumArray;\n-        // }\n-        parsedData.parameters[key].default = config[key];\n+          //   if (parsedData.parameters[key].enum) {\n+          //   // Set the enum array such that config[key] is the first element\n+          //   const enumArray = parsedData.parameters[key].enum;\n+          //   let index = enumArray.indexOf(config[key]);\n+          //   if (index > 0) {\n+          //     enumArray.unshift(enumArray.splice(index, 1)[0]);\n+          //   }\n+          //   parsedData.parameters[key].enum = enumArray;\n+          // }\n+          parsedData.parameters[key].default = config[key];\n         }\n       });\n       // Delete all keys in parsedData.parameters that start with tflabcustomui_\n@@ -565,10 +569,12 @@ export default function DynamicPluginForm({\n       // if key is in parsedData.parameters but not in config then delete the key from parsedData.parameters\n       //Schema takes in data as a JSON string\n       setConfigData(JSON.stringify(parsedData));\n-    } else if (data) {\n-      setConfigData(data); //Setting the config data to the data if there is no config\n+    } else if (safeData) {\n+      setConfigData(safeData); //Setting the config data to the data if there is no config\n+    } else {\n+      setConfigData(null);\n     }\n-  }, [plugin, experimentInfo, config, data]);\n+  }, [plugin, experimentInfo, config, safeData]);\n \n   const schema = useMemo(() => getSchema(configData), [configData]);\n   /* Below we wait for \"configData\" to be sure that defaults are set before rendering\ndiff --git a/src/renderer/components/Experiment/Foundation/InferenceEngineModal.tsx b/src/renderer/components/Experiment/Foundation/InferenceEngineModal.tsx\nindex fb01ca762..6c5c6fc64 100644\n--- a/src/renderer/components/Experiment/Foundation/InferenceEngineModal.tsx\n+++ b/src/renderer/components/Experiment/Foundation/InferenceEngineModal.tsx\n@@ -117,12 +117,23 @@ export default function InferenceEngineModal({\n \n             const experimentId = experimentInfo?.id;\n \n-            const newInferenceSettings = {\n-              ...inferenceSettings,\n-              ...formObject,\n-              inferenceEngine: engine,\n-              inferenceEngineFriendlyName: engineFriendlyName,\n-            };\n+            // We do this if else condition here because we have leftover parameters which aren't accepted by another engine also getting sent when we switch engines.\n+            // So we need to reset the inference settings to only include the parameters for the selected engine;\n+            let newInferenceSettings;\n+            if (inferenceSettings?.inferenceEngine === engine) {\n+              newInferenceSettings = {\n+                ...inferenceSettings,\n+                ...formObject,\n+                inferenceEngine: engine,\n+                inferenceEngineFriendlyName: engineFriendlyName,\n+              };\n+            } else {\n+              newInferenceSettings = {\n+                ...formObject,\n+                inferenceEngine: engine,\n+                inferenceEngineFriendlyName: engineFriendlyName,\n+              };\n+            }\n \n             setInferenceSettings(newInferenceSettings);\n \ndiff --git a/src/renderer/components/Experiment/Foundation/RunModelButton.tsx b/src/renderer/components/Experiment/Foundation/RunModelButton.tsx\nindex efdeb3770..16f326b67 100644\n--- a/src/renderer/components/Experiment/Foundation/RunModelButton.tsx\n+++ b/src/renderer/components/Experiment/Foundation/RunModelButton.tsx\n@@ -61,34 +61,38 @@ export default function RunModelButton({\n   const archTag = experimentInfo?.config?.foundation_model_architecture ?? '';\n \n   const supportedEngines = React.useMemo(() => {\n-    if (!data) return [];\n-    return data.filter(\n+    if (!data) {\n+      return [];\n+    }\n+    const filtered = data.filter(\n       (row) =>\n         Array.isArray(row.model_architectures) &&\n         row.model_architectures.some(\n           (arch) => arch.toLowerCase() === archTag.toLowerCase(),\n         ),\n     );\n+    return filtered;\n   }, [data, archTag]);\n \n   const unsupportedEngines = React.useMemo(() => {\n-    if (!data) return [];\n-    return data.filter(\n+    if (!data) {\n+      return [];\n+    }\n+    const filtered = data.filter(\n       (row) =>\n         !Array.isArray(row.model_architectures) ||\n         !row.model_architectures.some(\n           (arch) => arch.toLowerCase() === archTag.toLowerCase(),\n         ),\n     );\n+    return filtered;\n   }, [data, archTag]);\n+\n   const [isValidDiffusionModel, setIsValidDiffusionModel] = useState<\n     boolean | null\n   >(null);\n \n   function isPossibleToRunAModel() {\n-    console.log('Is Possible?');\n-    console.log(experimentInfo);\n-    console.log(inferenceSettings);\n     return (\n       experimentInfo != null &&\n       experimentInfo?.config?.foundation !== '' &&\n@@ -130,24 +134,36 @@ export default function RunModelButton({\n \n   // Set a default inference Engine if there is none\n   useEffect(() => {\n-    // Update experiment inference parameters so the Run button shows correctly\n     let objExperimentInfo = null;\n     if (experimentInfo?.config?.inferenceParams) {\n       objExperimentInfo = JSON.parse(experimentInfo?.config?.inferenceParams);\n     }\n-    if (objExperimentInfo == null) {\n-      (async () => {\n-        const { inferenceEngine, inferenceEngineFriendlyName } =\n-          await getDefaultinferenceEngines();\n+    if (\n+      objExperimentInfo == null ||\n+      objExperimentInfo?.inferenceEngine == null\n+    ) {\n+      // If there are supportedEngines, set the first one from supported engines as default\n+      if (supportedEngines.length > 0) {\n+        const firstEngine = supportedEngines[0];\n         setInferenceSettings({\n-          inferenceEngine: inferenceEngine || null,\n-          inferenceEngineFriendlyName: inferenceEngineFriendlyName || null,\n+          inferenceEngine: firstEngine.uniqueId || null,\n+          inferenceEngineFriendlyName: firstEngine.name || '',\n         });\n-      })();\n+      } else {\n+        // This preserves the older logic where we try to get the default inference engine for a blank experiment\n+        (async () => {\n+          const { inferenceEngine, inferenceEngineFriendlyName } =\n+            await getDefaultinferenceEngines();\n+          setInferenceSettings({\n+            inferenceEngine: inferenceEngine || null,\n+            inferenceEngineFriendlyName: inferenceEngineFriendlyName || null,\n+          });\n+        })();\n+      }\n     } else {\n       setInferenceSettings(objExperimentInfo);\n     }\n-  }, [experimentInfo]);\n+  }, [experimentInfo, supportedEngines]);\n \n   // Check if the current foundation model is a diffusion model\n   useEffect(() => {\n@@ -312,13 +328,14 @@ export default function RunModelButton({\n         <div>\n           <Alert startDecorator={<TriangleAlertIcon />} color=\"warning\">\n             <Typography level=\"body-sm\">\n-              None of the installed Engines currently support this model architecture.\n-               You can try a different engine in{' '}\n+              None of the installed Engines currently support this model\n+              architecture. You can try a different engine in{' '}\n               <Link to=\"/plugins\">\n                 <Plug2Icon size=\"15px\" />\n                 Plugins\n               </Link>{' '}\n-              , or you can try running it with an unsupported Engine by clicking <b>using Engine</b> below and check{' '}\n+              , or you can try running it with an unsupported Engine by clicking{' '}\n+              <b>using Engine</b> below and check{' '}\n               <b>Show unsupported engines</b>.\n             </Typography>\n           </Alert>\n", "test_patch": "", "problem_statement": "Diffusion models should work offline\nCurrently, the valid diffusion model check blocks diffusion models from working offline. We should find an alternative or use a parameter like we used to have for `local_files_only=True` to enable offline generation\nAdd pipeline tag to Foundation model info\nWe use this now to decide what kind of generation to show on the sidebar. It'd be really handy for debugging.\n", "hints_text": "\n\n\n\n", "all_hints_text": "\n\n\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/886e122e54cfd64d1b66dd01f36d7d1c683aae6d", "https://github.com/transformerlab/transformerlab-app/commit/f9e873c7c7e5cb4265225a61c3413e0c1ac32a57", "https://github.com/transformerlab/transformerlab-app/commit/5409e9d2603b6bcb919e9b349fa6486acdb7399e", "https://github.com/transformerlab/transformerlab-app/commit/d50aef989e7291d0ffbd9d871db767056ebc6c83", "https://github.com/transformerlab/transformerlab-app/commit/f61dc202c2ade799ebefc4e6b43361eb82b058e5"], "created_at": "2025-06-18T22:49:45Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 733, "instance_id": "transformerlab__transformerlab-app-733", "issue_numbers": [731], "base_commit": "e798c613faebec02b3c5ec2a29cc1e0081280f56", "patch": "diff --git a/src/renderer/components/Experiment/Foundation/RunModelButton.tsx b/src/renderer/components/Experiment/Foundation/RunModelButton.tsx\nindex 9770f5787..67e168b6d 100644\n--- a/src/renderer/components/Experiment/Foundation/RunModelButton.tsx\n+++ b/src/renderer/components/Experiment/Foundation/RunModelButton.tsx\n@@ -18,7 +18,7 @@ import InferenceEngineModal from './InferenceEngineModal';\n import * as chatAPI from 'renderer/lib/transformerlab-api-sdk';\n import OneTimePopup from 'renderer/components/Shared/OneTimePopup';\n import { useAPI } from 'renderer/lib/transformerlab-api-sdk';\n-import React, { useState } from 'react';\n+import React from 'react';\n \n import { Link } from 'react-router-dom';\n \n@@ -58,35 +58,60 @@ export default function RunModelButton({\n     },\n   );\n \n+  const { data: pipelineTagData, isLoading: pipelineTagLoading } = useAPI(\n+    'models',\n+    ['pipeline_tag'],\n+    {\n+      modelName: experimentInfo?.config?.foundation,\n+    },\n+    {\n+      skip: !experimentInfo?.config?.foundation,\n+    },\n+  );\n+\n+  const pipelineTag = pipelineTagData?.data || null;\n+\n   const archTag = experimentInfo?.config?.foundation_model_architecture ?? '';\n \n   const supportedEngines = React.useMemo(() => {\n-    if (!data) {\n-      return [];\n-    }\n-    const filtered = data.filter(\n-      (row) =>\n+    if (!data || pipelineTagLoading) return [];\n+\n+    return data.filter((row) => {\n+      const supportsArchitecture =\n         Array.isArray(row.model_architectures) &&\n         row.model_architectures.some(\n           (arch) => arch.toLowerCase() === archTag.toLowerCase(),\n-        ),\n-    );\n-    return filtered;\n-  }, [data, archTag]);\n+        );\n+\n+      if (!supportsArchitecture) return false;\n+\n+      const hasTextToSpeechSupport =\n+        Array.isArray(row.supports) &&\n+        row.supports.some(\n+          (support: string) => support.toLowerCase() === 'text-to-speech',\n+        );\n+\n+      // For text-to-speech models: must also have text-to-speech support\n+      if (pipelineTag === 'text-to-speech') {\n+        return hasTextToSpeechSupport;\n+      }\n+\n+      // For non-text-to-speech models: must NOT have text-to-speech support\n+      return !hasTextToSpeechSupport;\n+    });\n+  }, [data, pipelineTagLoading, pipelineTag, archTag]);\n \n   const unsupportedEngines = React.useMemo(() => {\n-    if (!data) {\n-      return [];\n-    }\n-    const filtered = data.filter(\n+    if (!data) return [];\n+\n+    // Simply return everything that's NOT in supportedEngines\n+    return data.filter(\n       (row) =>\n-        !Array.isArray(row.model_architectures) ||\n-        !row.model_architectures.some(\n-          (arch) => arch.toLowerCase() === archTag.toLowerCase(),\n+        !supportedEngines.some(\n+          (supported) => supported.uniqueId === row.uniqueId,\n         ),\n     );\n-    return filtered;\n-  }, [data, archTag]);\n+  }, [data, supportedEngines]);\n \n   const [isValidDiffusionModel, setIsValidDiffusionModel] = useState<\n     boolean | null\n@@ -134,13 +159,24 @@ export default function RunModelButton({\n \n   // Set a default inference Engine if there is none\n   useEffect(() => {\n+    // Add this single line to wait for pipeline tag loading\n+    if (!data || pipelineTagLoading) return;\n+\n     let objExperimentInfo = null;\n     if (experimentInfo?.config?.inferenceParams) {\n       objExperimentInfo = JSON.parse(experimentInfo?.config?.inferenceParams);\n     }\n+\n+    // Check if current engine is still supported after filtering\n+    const currentEngine = objExperimentInfo?.inferenceEngine;\n+    const currentEngineIsSupported = supportedEngines.some(\n+      (engine) => engine.uniqueId === currentEngine,\n+    );\n+\n     if (\n       objExperimentInfo == null ||\n-      objExperimentInfo?.inferenceEngine == null\n+      objExperimentInfo?.inferenceEngine == null ||\n+      !currentEngineIsSupported\n     ) {\n       // If there are supportedEngines, set the first one from supported engines as default\n       if (supportedEngines.length > 0) {\n@@ -179,7 +215,13 @@ export default function RunModelButton({\n     } else {\n       setInferenceSettings(objExperimentInfo);\n     }\n-  }, [experimentInfo, supportedEngines]);\n+  }, [\n+    data,\n+    pipelineTagLoading,\n+    supportedEngines,\n+    experimentInfo?.id,\n+    experimentInfo?.config?.inferenceParams,\n+  ]);\n \n   // Check if the current foundation model is a diffusion model\n   useEffect(() => {\n", "test_patch": "", "problem_statement": "Fix supported engine options for audio models on foundation page\nThe engine selection on the foundation page needs updating for audio models. Since some share architectures with LLMs, they can show incorrect engine options. The logic should be updated to handle audio models correctly\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/656916a185a4f935024cef1d4868c8703348ca8a", "https://github.com/transformerlab/transformerlab-app/commit/3a904048b935171653c4af503b4d17bb9e2402fd", "https://github.com/transformerlab/transformerlab-app/commit/79e62fc20fd30881c187b50d3abeec746f4a385e", "https://github.com/transformerlab/transformerlab-app/commit/ce97fd5913843565fc157de8a663e0e9be5c7f18", "https://github.com/transformerlab/transformerlab-app/commit/2935d18cdb65a4bcf67d2e49efe7e594c08a4be7", "https://github.com/transformerlab/transformerlab-app/commit/35172a32b37716a67297f0f4e17d5f9a0b90ff7a", "https://github.com/transformerlab/transformerlab-app/commit/0266579012d8dd1942373ce6dd4b952325c2718e", "https://github.com/transformerlab/transformerlab-app/commit/5e53d3bba5f8b86dad26e6407d9edd181509a891", "https://github.com/transformerlab/transformerlab-app/commit/0b566deab2b2969db142cdecc264e162164198cd", "https://github.com/transformerlab/transformerlab-app/commit/8e7c20e1210a3e723c89584ea1b62928cf2eaf30"], "created_at": "2025-08-19T22:13:51Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 748, "instance_id": "transformerlab__transformerlab-app-748", "issue_numbers": [744], "base_commit": "8af5bb744647c580ba91a931aeabe4a32019b1f2", "patch": "diff --git a/src/renderer/components/Data/AudioPlayer.tsx b/src/renderer/components/Data/AudioPlayer.tsx\nindex 46f5e6deb..57b626505 100644\n--- a/src/renderer/components/Data/AudioPlayer.tsx\n+++ b/src/renderer/components/Data/AudioPlayer.tsx\n@@ -36,6 +36,7 @@ const AudioPlayer: React.FC<AudioPlayerProps> = ({\n   const [currentTime, setCurrentTime] = React.useState<number>(0);\n   const waveformRef = React.useRef<HTMLDivElement>(null);\n   const audioRef = React.useRef<HTMLAudioElement>(null);\n+  const nativeAudioRef = React.useRef<HTMLAudioElement>(null);\n   const isDestroyedRef = React.useRef(false);\n \n   // Compact mode handlers\n@@ -69,6 +70,33 @@ const AudioPlayer: React.FC<AudioPlayerProps> = ({\n     setIsLoading(false);\n   };\n \n+  // Native audio handlers for syncing with WaveSurfer\n+  const handleNativePlay = () => {\n+    if (wavesurfer && !compact) {\n+      wavesurfer.play();\n+    }\n+    setIsPlaying(true);\n+  };\n+\n+  const handleNativePause = () => {\n+    if (wavesurfer && !compact) {\n+      wavesurfer.pause();\n+    }\n+    setIsPlaying(false);\n+  };\n+\n+  const handleNativeSeek = (event: React.SyntheticEvent<HTMLAudioElement>) => {\n+    if (wavesurfer && !compact) {\n+      const audio = event.currentTarget;\n+      const audioCurrentTime = audio.currentTime;\n+      const audioDuration = audio.duration;\n+      if (audioDuration > 0) {\n+        const progress = audioCurrentTime / audioDuration;\n+        wavesurfer.seekTo(progress);\n+      }\n+    }\n+  };\n+\n   const formatTime = (time: number) => {\n     const minutes = Math.floor(time / 60);\n     const seconds = Math.floor(time % 60);\n@@ -150,17 +178,6 @@ const AudioPlayer: React.FC<AudioPlayerProps> = ({\n     isDestroyedRef.current = false;\n   }, [audioData?.audio_data_url]);\n \n-  // Regular mode handlers\n-  const handlePlayPauseRegular = () => {\n-    if (wavesurfer) {\n-      if (isPlaying) {\n-        wavesurfer.pause();\n-      } else {\n-        wavesurfer.play();\n-      }\n-    }\n-  };\n-\n   // Compact mode render\n   if (compact) {\n     return (\n@@ -239,28 +256,17 @@ const AudioPlayer: React.FC<AudioPlayerProps> = ({\n     <Card sx={{ minWidth: '300px' }}>\n       <CardContent>\n         <Stack spacing={2}>\n-          {/* Controls */}\n-          <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>\n-            <IconButton\n-              size=\"sm\"\n-              variant=\"soft\"\n-              onClick={handlePlayPauseRegular}\n-              disabled={!wavesurfer || isLoading || !!error}\n-            >\n-              {isPlaying ? <Pause size={16} /> : <Play size={16} />}\n-            </IconButton>\n-            <Volume2 size={16} />\n-            {isLoading && (\n-              <Typography level=\"body-sm\" color=\"neutral\">\n-                Loading...\n-              </Typography>\n-            )}\n-            {error && (\n-              <Typography level=\"body-sm\" color=\"danger\">\n-                {error}\n-              </Typography>\n-            )}\n-          </Box>\n+          {/* Status Messages */}\n+          {isLoading && (\n+            <Typography level=\"body-sm\" color=\"neutral\">\n+              Loading...\n+            </Typography>\n+          )}\n+          {error && (\n+            <Typography level=\"body-sm\" color=\"danger\">\n+              {error}\n+            </Typography>\n+          )}\n \n           {/* Waveform */}\n           <Box\n@@ -276,6 +282,19 @@ const AudioPlayer: React.FC<AudioPlayerProps> = ({\n             }}\n           />\n \n+          {/* Native Audio Controls */}\n+          <audio\n+            ref={nativeAudioRef}\n+            src={audioData.audio_data_url}\n+            controls\n+            style={{ width: '100%' }}\n+            onPlay={handleNativePlay}\n+            onPause={handleNativePause}\n+            onSeeked={handleNativeSeek}\n+          >\n+            <track kind=\"captions\" />\n+          </audio>\n+\n           {/* Metadata */}\n           <Stack spacing={1}>\n             {metadata?.path && (\n", "test_patch": "", "problem_statement": "Downloaded generated audio is not playable\nI downloaded the audio files I generated in the app and they appears in my Downloads folder with the right size, but they are greyed out iin Finder and not playable.\n\n```\n(transformerlab) tony@Anthonys-MacBook-Pro ~ % ls -al ~/Downloads/*.mp3                                   \n-rw-r--r--  1 tony  staff  139308 26 Aug 11:16 /Users/tony/Downloads/2d798dd7-0162-45b1-9c60-ce227735d36b.mp3\n-rw-r--r--  1 tony  staff  139308 26 Aug 11:14 /Users/tony/Downloads/after train audio.mp3\n-rw-r--r--@ 1 tony  staff  155692 26 Aug 11:13 /Users/tony/Downloads/before train.mp3\n(transformerlab) tony@Anthonys-MacBook-Pro ~ % afplay ~/Downloads/2d798dd7-0162-45b1-9c60-ce227735d36b.mp3\nError: AudioFileOpen failed ('dta?')\n```\n\n", "hints_text": "\n\n", "all_hints_text": "It looks like the issue is literally just that it saved my files with an mp3 extension instead of wav.\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/312a6bc646f6fad55e31d551087eede1659c6f7c", "https://github.com/transformerlab/transformerlab-app/commit/47c6443241ce89da6097ca54c40dcfe0a88687ee"], "created_at": "2025-08-27T18:03:26Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 772, "instance_id": "transformerlab__transformerlab-app-772", "issue_numbers": [745], "base_commit": "095673cbaf5681dcdc96cc4d4c5d7461e648fc82", "patch": "diff --git a/src/renderer/components/Experiment/Eval/ViewOutputModalStreaming.tsx b/src/renderer/components/Experiment/Eval/ViewOutputModalStreaming.tsx\nindex 4b317a835..4c63f21d2 100644\n--- a/src/renderer/components/Experiment/Eval/ViewOutputModalStreaming.tsx\n+++ b/src/renderer/components/Experiment/Eval/ViewOutputModalStreaming.tsx\n@@ -29,6 +29,7 @@ export default function ViewOutputModalStreaming({\n   setFileName,\n }: ViewOutputModalStreamingProps) {\n   const { experimentInfo } = useExperimentInfo();\n+  if (!experimentInfo) return null;\n   const logEndpoint =\n     fileName !== ''\n       ? chatAPI.Endpoints.Experiment.StreamDetailedJSONReportFromJob(\n@@ -44,6 +45,7 @@ export default function ViewOutputModalStreaming({\n     fileName !== '' ? 'Detailed Report for Job' : 'Output from Job';\n \n   const handleDownload = async () => {\n+    if (!experimentInfo) return;\n     const response = await fetch(\n       chatAPI.Endpoints.Experiment.GetAdditionalDetails(\n         experimentInfo.id,\ndiff --git a/src/renderer/components/Experiment/Export/ViewOutputModalStreaming.tsx b/src/renderer/components/Experiment/Export/ViewOutputModalStreaming.tsx\nindex 80bee75ee..bfc05217a 100644\n--- a/src/renderer/components/Experiment/Export/ViewOutputModalStreaming.tsx\n+++ b/src/renderer/components/Experiment/Export/ViewOutputModalStreaming.tsx\n@@ -32,19 +32,22 @@ export default function ViewOutputModalStreaming({\n   setJobId,\n }: ViewOutputModalStreamingProps) {\n   const { experimentInfo } = useExperimentInfo();\n-  const { data: jobDetails } = useSWR<JobDetails>(\n-    jobId && jobId !== -1\n+\n+  const jobDetailsUrl =\n+    experimentInfo && jobId && jobId !== -1\n       ? chatAPI.Endpoints.Jobs.Get(experimentInfo.id, jobId)\n-      : null,\n-    fetcher,\n-    { refreshInterval: 2000 },\n-  );\n+      : null;\n+\n+  const { data: jobDetails } = useSWR<JobDetails>(jobDetailsUrl, fetcher, {\n+    refreshInterval: 2000,\n+  });\n \n   // // Create a custom endpoint for export job output\n-  const outputEndpoint = chatAPI.Endpoints.Experiment.StreamOutputFromJob(\n-    experimentInfo.id,\n-    jobId,\n-  );\n+  const outputEndpoint = experimentInfo\n+    ? chatAPI.Endpoints.Experiment.StreamOutputFromJob(experimentInfo.id, jobId)\n+    : null;\n+\n+  if (!experimentInfo) return null;\n \n   return (\n     <Modal open={jobId !== -1} onClose={() => setJobId(-1)}>\ndiff --git a/src/renderer/components/Experiment/Generate/ViewOutputModalStreaming.tsx b/src/renderer/components/Experiment/Generate/ViewOutputModalStreaming.tsx\nindex ac2b9fe00..fa073d73d 100644\n--- a/src/renderer/components/Experiment/Generate/ViewOutputModalStreaming.tsx\n+++ b/src/renderer/components/Experiment/Generate/ViewOutputModalStreaming.tsx\n@@ -10,6 +10,7 @@ const fetcher = (url) => fetch(url).then((res) => res.json());\n \n export default function ViewOutputModalStreaming({ jobId, setJobId }) {\n   const { experimentInfo } = useExperimentInfo();\n+  if (!experimentInfo) return null;\n   return (\n     <Modal open={jobId != -1} onClose={() => setJobId(-1)}>\n       <ModalDialog sx={{ width: '80vw', height: '80vh' }}>\ndiff --git a/src/renderer/components/Experiment/Train/ViewOutputModalStreaming.tsx b/src/renderer/components/Experiment/Train/ViewOutputModalStreaming.tsx\nindex efa56abf2..e43d5e5e8 100644\n--- a/src/renderer/components/Experiment/Train/ViewOutputModalStreaming.tsx\n+++ b/src/renderer/components/Experiment/Train/ViewOutputModalStreaming.tsx\n@@ -28,7 +28,7 @@ export default function ViewOutputModalStreaming({\n   setsweepJob,\n }) {\n   const { experimentInfo } = useExperimentInfo();\n-  if (jobId === -1) {\n+  if (jobId === -1 || !experimentInfo) {\n     return null;\n   }\n   const [tab, setTab] = useState(0);\n", "test_patch": "", "problem_statement": "Crash on diffusion screen if app loses connection to server\nIf the server goes down while you are on the Diffusion page I get this:\n\n<img width=\"1154\" height=\"1192\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/c69a0029-bf29-486d-b00b-8ec7d25b00de\" />\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/0f3c0d162b8c756f9da282896d01ff57e3b13810", "https://github.com/transformerlab/transformerlab-app/commit/99cda11392c7ff57416bf68c7e85167492339566"], "created_at": "2025-09-05T17:40:12Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 761, "instance_id": "transformerlab__transformerlab-app-761", "issue_numbers": [752], "base_commit": "94ff68bfc15bb60d54d4d8f7d63f500b3fa267f8", "patch": "diff --git a/src/renderer/components/Experiment/Audio/Audio.tsx b/src/renderer/components/Experiment/Audio/Audio.tsx\nindex 069a09381..77c7c36b0 100644\n--- a/src/renderer/components/Experiment/Audio/Audio.tsx\n+++ b/src/renderer/components/Experiment/Audio/Audio.tsx\n@@ -243,7 +243,14 @@ export default function Audio() {\n         }}\n       >\n         <Typography level=\"h2\">Text to Speech</Typography>\n-        <Typography level=\"body-sm\">{currentModel}</Typography>\n+        <Box sx={{ textAlign: 'right' }}>\n+          <Typography level=\"body-sm\">{currentModel}</Typography>\n+          {adaptor && (\n+            <Typography level=\"body-xs\" color=\"neutral\">\n+              {adaptor}\n+            </Typography>\n+          )}\n+        </Box>\n       </Box>\n \n       {/* Main content area, split into sidebar and main panel */}\n", "test_patch": "", "problem_statement": "TTS: Can generated audio show which adapter was used?\nIn this screenshot the audio at the top was generated using an adapter I trained, and the audio below it was generated with just the base model and no adapter.  But it jsut shows the base model name on both so there's no easy way to tell.\n\n<img width=\"1154\" height=\"779\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/6b25b8a1-5d2d-4655-965c-2508df58253b\" />\n", "hints_text": "\n\n", "all_hints_text": "Thanks for fixing the adapter name at the top...although the thing I was really hoping to update is the listed adapter on the individual files:\n\n<img width=\"1154\" height=\"779\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/b2b96615-5bca-4356-bd5c-b4190cb87de3\" />\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/44fd5191f04ba24ccb25f1bb9d4b51fc90a74808", "https://github.com/transformerlab/transformerlab-app/commit/c4eaa87d29affb987aa6f13d7beca81490e3d81f"], "created_at": "2025-09-03T19:46:07Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 762, "instance_id": "transformerlab__transformerlab-app-762", "issue_numbers": [752], "base_commit": "7449aeadd441fe2c6aa3b528bf194671c2b58e02", "patch": "diff --git a/src/renderer/components/Experiment/Audio/AudioHistory.tsx b/src/renderer/components/Experiment/Audio/AudioHistory.tsx\nindex 5ad7d0b8f..4ab9394aa 100644\n--- a/src/renderer/components/Experiment/Audio/AudioHistory.tsx\n+++ b/src/renderer/components/Experiment/Audio/AudioHistory.tsx\n@@ -18,6 +18,7 @@ interface AudioHistoryItem {\n   text: string;\n   filename: string;\n   model: string;\n+  adaptor?: string; // Add adaptor property\n   speed: number;\n   audio_format: string;\n   sample_rate: number;\n@@ -98,6 +99,9 @@ const AudioHistory = React.forwardRef<HTMLDivElement, AudioHistoryProps>(\n                 <Box sx={{ display: 'flex', flexWrap: 'wrap', gap: 1 }}>\n                   <Chip size=\"sm\" variant=\"soft\" color=\"primary\">\n                     {item.model.split('/').pop()}\n+                    {item.adaptor && item.adaptor.trim() !== '' && (\n+                      <> + {item.adaptor.split('/').pop()}</>\n+                    )}\n                   </Chip>\n                   <Chip size=\"sm\" variant=\"soft\" color=\"neutral\">\n                     {item.audio_format.toUpperCase()}\n", "test_patch": "", "problem_statement": "TTS: Can generated audio show which adapter was used?\nIn this screenshot the audio at the top was generated using an adapter I trained, and the audio below it was generated with just the base model and no adapter.  But it jsut shows the base model name on both so there's no easy way to tell.\n\n<img width=\"1154\" height=\"779\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/6b25b8a1-5d2d-4655-965c-2508df58253b\" />\n", "hints_text": "Thanks for fixing the adapter name at the top...although the thing I was really hoping to update is the listed adapter on the individual files:\n\n<img width=\"1154\" height=\"779\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/b2b96615-5bca-4356-bd5c-b4190cb87de3\" />\n\n", "all_hints_text": "Thanks for fixing the adapter name at the top...although the thing I was really hoping to update is the listed adapter on the individual files:\n\n<img width=\"1154\" height=\"779\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/b2b96615-5bca-4356-bd5c-b4190cb87de3\" />\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/9916ea4063ce12ed3c54da30383ab287a67e68d4"], "created_at": "2025-09-04T15:03:13Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 532, "instance_id": "transformerlab__transformerlab-app-532", "issue_numbers": [755], "base_commit": "dbceea9bd9bf3cbf371a9953151b805e5ae0b9d7", "patch": "diff --git a/src/renderer/components/Computer.tsx b/src/renderer/components/Computer.tsx\nindex 920b5aade..b5c63eefd 100644\n--- a/src/renderer/components/Computer.tsx\n+++ b/src/renderer/components/Computer.tsx\n@@ -145,7 +145,65 @@ export default function Computer() {\n                         title=\"Mac Monitoring Metrics\"\n                         sx={{ maxHeight: 'none', overflowY: 'visible' }}\n                       >\n-                        <Typography level=\"title-sm\" mb={1}>\n+                        {server.mac_metrics.soc && (\n+                          <>\n+                            <Typography level=\"title-sm\" mb={1}>\n+                              System on Chip (SoC)\n+                            </Typography>\n+                            <StatRow\n+                              title=\"Chip\"\n+                              value={server.mac_metrics.soc.chip_name}\n+                            />\n+                            <StatRow\n+                              title=\"Mac Model\"\n+                              value={server.mac_metrics.soc.mac_model}\n+                            />\n+                            <StatRow\n+                              title=\"Memory\"\n+                              value={`${server.mac_metrics.soc.memory_gb} GB`}\n+                            />\n+                            <StatRow\n+                              title=\"CPU Cores\"\n+                              value={`${server.mac_metrics.soc.ecpu_cores} E-cores, ${server.mac_metrics.soc.pcpu_cores} P-cores`}\n+                            />\n+                            <StatRow\n+                              title=\"GPU Cores\"\n+                              value={server.mac_metrics.soc.gpu_cores}\n+                            />\n+                            <StatRow\n+                              title=\"CPU Frequencies\"\n+                              value={`${Math.min(...server.mac_metrics.soc.ecpu_freqs)} - ${Math.max(...server.mac_metrics.soc.ecpu_freqs)} MHz (E), ${Math.min(...server.mac_metrics.soc.pcpu_freqs)} - ${Math.max(...server.mac_metrics.soc.pcpu_freqs)} MHz (P)`}\n+                            />\n+                            <StatRow\n+                              title=\"GPU Frequencies\"\n+                              value={`${Math.min(...server.mac_metrics.soc.gpu_freqs.filter((f: number) => f > 0))} - ${Math.max(...server.mac_metrics.soc.gpu_freqs)} MHz`}\n+                            />\n+                          </>\n+                        )}\n+\n+                        <Typography level=\"title-sm\" mt={2} mb={1}>\n+                          Usage\n+                        </Typography>\n+                        {server.mac_metrics.ecpu_usage && (\n+                          <StatRow\n+                            title=\"ECPU Usage\"\n+                            value={`${server.mac_metrics.ecpu_usage[0]} MHz, ${(server.mac_metrics.ecpu_usage[1] * 100).toFixed(2)}%`}\n+                          />\n+                        )}\n+                        {server.mac_metrics.pcpu_usage && (\n+                          <StatRow\n+                            title=\"PCPU Usage\"\n+                            value={`${server.mac_metrics.pcpu_usage[0]} MHz, ${(server.mac_metrics.pcpu_usage[1] * 100).toFixed(2)}%`}\n+                          />\n+                        )}\n+                        {server.mac_metrics.gpu_usage && (\n+                          <StatRow\n+                            title=\"GPU Usage\"\n+                            value={`${server.mac_metrics.gpu_usage[0]} MHz, ${(server.mac_metrics.gpu_usage[1] * 100).toFixed(2)}%`}\n+                          />\n+                        )}\n+\n+                        <Typography level=\"title-sm\" mt={2} mb={1}>\n                           Temperature\n                         </Typography>\n                         <StatRow\n@@ -180,28 +238,6 @@ export default function Computer() {\n                           title=\"System Power\"\n                           value={`${server.mac_metrics.sys_power.toFixed(2)} W`}\n                         />\n-\n-                        <Typography level=\"title-sm\" mt={2} mb={1}>\n-                          Usage\n-                        </Typography>\n-                        {server.mac_metrics.ecpu_usage && (\n-                          <StatRow\n-                            title=\"ECPU Usage\"\n-                            value={`${server.mac_metrics.ecpu_usage[0]} MHz, ${(server.mac_metrics.ecpu_usage[1] * 100).toFixed(2)}%`}\n-                          />\n-                        )}\n-                        {server.mac_metrics.pcpu_usage && (\n-                          <StatRow\n-                            title=\"PCPU Usage\"\n-                            value={`${server.mac_metrics.pcpu_usage[0]} MHz, ${(server.mac_metrics.pcpu_usage[1] * 100).toFixed(2)}%`}\n-                          />\n-                        )}\n-                        {server.mac_metrics.gpu_usage && (\n-                          <StatRow\n-                            title=\"GPU Usage\"\n-                            value={`${server.mac_metrics.gpu_usage[0]} MHz, ${(server.mac_metrics.gpu_usage[1] * 100).toFixed(2)}%`}\n-                          />\n-                        )}\n                       </ComputerCard>\n                     </Grid>\n                   ) : (\ndiff --git a/src/renderer/components/Header.tsx b/src/renderer/components/Header.tsx\nindex d7508f317..acbaf91eb 100644\n--- a/src/renderer/components/Header.tsx\n+++ b/src/renderer/components/Header.tsx\n@@ -257,20 +257,42 @@ function StatsBar({ connection, setConnection }) {\n                         <b>CPU: </b>\n                         {server?.cpu}\n                       </Typography>\n-                      {server?.gpu?.map((gpu, index) => (\n-                        <div key={index}>\n-                          <Typography>\n-                            <b>GPU {index + 1}: </b>\n-                            {gpu.name === 'cpu' ? 'N/A' : gpu.name}\n-                          </Typography>\n+\n+                      {/* Mac-specific metrics */}\n+                      {server?.mac_metrics ? (\n+                        <>\n                           <Typography>\n-                            <b>GPU Memory: </b>\n-                            {formatBytes(gpu.total_memory) === '0 Bytes'\n-                              ? 'N/A'\n-                              : formatBytes(gpu.total_memory)}\n+                            <b>GPU 1: </b>\n+                            {server.mac_metrics.soc?.chip_name ||\n+                              'Mac Silicon GPU'}\n                           </Typography>\n-                        </div>\n-                      ))}\n+                          {server.mac_metrics.gpu_usage && (\n+                            <Typography>\n+                              <b>GPU Usage: </b>\n+                              {(server.mac_metrics.gpu_usage[1] * 100).toFixed(\n+                                1,\n+                              )}\n+                              %\n+                            </Typography>\n+                          )}\n+                        </>\n+                      ) : (\n+                        // Regular GPU display for non-Mac systems\n+                        server?.gpu?.map((gpu, index) => (\n+                          <div key={index}>\n+                            <Typography>\n+                              <b>GPU {index + 1}: </b>\n+                              {gpu.name === 'cpu' ? 'N/A' : gpu.name}\n+                            </Typography>\n+                            <Typography>\n+                              <b>GPU Memory: </b>\n+                              {formatBytes(gpu.total_memory) === '0 Bytes'\n+                                ? 'N/A'\n+                                : formatBytes(gpu.total_memory)}\n+                            </Typography>\n+                          </div>\n+                        ))\n+                      )}\n                       <Typography p={1}>\n                         <ReactRouterLink to=\"/computer\">\n                           More about this computer\n@@ -280,7 +302,7 @@ function StatsBar({ connection, setConnection }) {\n                       <Button\n                         variant=\"solid\"\n                         color=\"danger\"\n-                        size=\"small\"\n+                        size=\"sm\"\n                         sx={{ m: 0, p: 1 }}\n                         onClick={() => {\n                           setConnection('');\n", "test_patch": "", "problem_statement": "Generation plugin fails if no foundation selected\nUse Sh1d0w started a new project and hadn't selected a foundation. Trying to run a generation plugin causes:\n\n```\n14:04:49.384 \u203a stderr: ERROR:asyncio:Task exception was never retrieved\nfuture: <Task finished name='Task-7' coro=<run_over_and_over() done, defined at /Users/user/.transformerlab/src/api.py:118> exception=KeyError('foundation')>\nTraceback (most recent call last):\n  File \"/Users/user/.transformerlab/src/api.py\", line 122, in run_over_and_over\n    await jobs.start_next_job()\n  File \"/Users/user/.transformerlab/src/transformerlab/routers/experiment/jobs.py\", line 84, in start_next_job\n    await shared.run_job(\n  File \"/Users/user/.transformerlab/src/transformerlab/shared/shared.py\", line 402, in run_job\n    await run_generation_script(experiment_id, plugin_name, generation_name, job_id)\n  File \"/Users/user/.transformerlab/src/transformerlab/routers/experiment/generations.py\", line 177, in run_generation_script\n    model_name = config[\"foundation\"]\n                 ~~^^^^^^^^^^^^^^\nKeyError: 'foundation'\n```\n\nNOTE: Easy fix to not crash here, but need to also deal with what happens if foundation isn't set and the plugin doesn't set? \n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/4567d09c689d459509c7f885909df934b1b0d63e", "https://github.com/transformerlab/transformerlab-app/commit/1a844b3e02f7c5bb1f439d5c9d3a81c0cd90d8b2", "https://github.com/transformerlab/transformerlab-app/commit/7768cd0171603c6682b7b96060187c83f066a07e"], "created_at": "2025-06-09T21:37:53Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 533, "instance_id": "transformerlab__transformerlab-app-533", "issue_numbers": [756], "base_commit": "9152f0bf4dbb16ac8cdda4b4dd177b3a4bf98b05", "patch": "diff --git a/src/renderer/components/Experiment/Generate/GenerateJobsTable.tsx b/src/renderer/components/Experiment/Generate/GenerateJobsTable.tsx\nindex c5df160e0..94167f6fa 100644\n--- a/src/renderer/components/Experiment/Generate/GenerateJobsTable.tsx\n+++ b/src/renderer/components/Experiment/Generate/GenerateJobsTable.tsx\n@@ -7,16 +7,24 @@ import {\n   Sheet,\n   Table,\n   Typography,\n-  Link\n+  Link,\n+  Modal,\n+  ModalDialog,\n+  ModalClose,\n } from '@mui/joy';\n-import { ChartColumnBigIcon, FileDigitIcon, Trash2Icon,  Grid3X3Icon,} from 'lucide-react';\n+import {\n+  ChartColumnBigIcon,\n+  FileDigitIcon,\n+  Trash2Icon,\n+  Grid3X3Icon,\n+} from 'lucide-react';\n import { useState, useEffect } from 'react';\n import useSWR from 'swr';\n import * as chatAPI from '../../../lib/transformerlab-api-sdk';\n import dayjs from 'dayjs';\n import ViewOutputModalStreaming from './ViewOutputModalStreaming';\n import ViewCSVModal from './ViewCSVModal';\n-\n+import DatasetTable from 'renderer/components/Data/DatasetTable';\n \n import dayjs from 'dayjs';\n import relativeTime from 'dayjs/plugin/relativeTime';\n@@ -67,12 +75,11 @@ function RenderScore({ score }) {\n   ));\n }\n \n-\n-\n const GenerateJobsTable = () => {\n   const [viewOutputFromJob, setViewOutputFromJob] = useState(-1);\n   const [openCSVModal, setOpenCSVModal] = useState(false);\n-  const [currentJobId, setCurrentJobId] = useState('');\n+  const [currentJob, setCurrentJob] = useState(null);\n+  const [currentJobId, setCurrentJobId] = useState(null);\n \n   const {\n     data: jobs,\n@@ -87,20 +94,20 @@ const GenerateJobsTable = () => {\n     // Component did mount logic here\n   }, []);\n \n-  const handleOpenCSVModal = (jobId) => {\n-    setCurrentJobId(jobId);\n+  const handleOpenCSVModal = (job) => {\n+    console.log('Dataset Preview clicked \u2013 job_data:', job.job_data);\n+    setCurrentJobId(job.id);\n+    setCurrentJob(job);\n     setOpenCSVModal(true);\n   };\n \n   const fetchGenerateCSV = async (jobId) => {\n-      const response = await fetch(\n-        chatAPI.Endpoints.Experiment.GetGeneratedDataset(jobId)\n-      );\n-      const text = await response.text();\n-      return text;\n-    };\n-\n-\n+    const response = await fetch(\n+      chatAPI.Endpoints.Experiment.GetGeneratedDataset(jobId),\n+    );\n+    const text = await response.text();\n+    return text;\n+  };\n \n   return (\n     <>\n@@ -108,12 +115,19 @@ const GenerateJobsTable = () => {\n         jobId={viewOutputFromJob}\n         setJobId={setViewOutputFromJob}\n       />\n-      <ViewCSVModal\n-        open={openCSVModal}\n-        onClose={() => setOpenCSVModal(false)}\n-        jobId={currentJobId}\n-        fetchCSV={fetchGenerateCSV}\n-      />\n+      {openCSVModal && currentJob && (\n+        <Modal open={openCSVModal} onClose={() => setOpenCSVModal(false)}>\n+          <ModalDialog sx={{ width: '90vw', height: '90vh' }}>\n+            <ModalClose />\n+            <Typography level=\"h4\" mb={2}>\n+              Dataset Preview \u2013 Job #{currentJob.id}\n+            </Typography>\n+            <Box sx={{ overflow: 'auto', height: '100%' }}>\n+              <DatasetTable datasetId={currentJob.job_data.dataset_id} />\n+            </Box>\n+          </ModalDialog>\n+        </Modal>\n+      )}\n       <Typography level=\"h3\">Executions</Typography>\n       <Sheet sx={{ overflowY: 'scroll' }}>\n         <Table stickyHeader>\n@@ -152,12 +166,12 @@ const GenerateJobsTable = () => {\n                 <td>\n                   {/* <RenderScore score={job?.job_data?.score} /> */}\n                   <Link\n-                      onClick={() => handleOpenCSVModal(job?.id)}\n-                      sx={{ mt: 1, ml: 1 }}\n-                      startDecorator={<Grid3X3Icon size=\"14px\" />}\n-                    >\n-                      Dataset Preview\n-                    </Link>\n+                    onClick={() => handleOpenCSVModal(job)}\n+                    sx={{ mt: 1, ml: 1 }}\n+                    startDecorator={<Grid3X3Icon size=\"14px\" />}\n+                  >\n+                    Dataset Preview\n+                  </Link>\n                 </td>\n \n                 <td>\n", "test_patch": "", "problem_statement": "RAG demo in blog throws an error when calling OpenAI\nAs reported by user sh1d0w in Discord:\n\nI am following the article about RAG training...when I try to generate the QA pairs with open AI is (I\u2019ve setup api key correctly):\n\n```\nError processing chunk: Error code: 400 - {'error': {'message': \"We could not parse the JSON body of your request. (HINT: This likely means you aren't using your HTTP library correctly. The OpenAI API expects a JSON payload, but what was sent was not valid JSON. If you have trouble figuring out how to fix this, please contact us through our help center at help.openai.com.)\", 'type': 'invalid_request_error', 'param': None, 'code': None}}\nError processing chunk: Error code: 400 - {'error': {'message': \"We could not parse the JSON body of your request. (HINT: This likely means you aren't using your HTTP library correctly. The OpenAI API expects a JSON payload, but what was sent was not valid JSON. If you have trouble figuring out how to fix this, please contact us through our help center at help.openai.com.)\", 'type': 'invalid_request_error', 'param': None, 'code': None}}\n```\n\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/transformerlab/transformerlab-app/commit/e37f6d851b412527ed8f1355bd9db0dbf13ec07e", "https://github.com/transformerlab/transformerlab-app/commit/560951b69c2953ec04d500f7cde94eeae441fd95", "https://github.com/transformerlab/transformerlab-app/commit/090987e905230fe9a6827c3da5915b9d15a015a6"], "created_at": "2025-06-10T22:10:26Z"}
{"repo": "transformerlab/transformerlab-app", "pull_number": 536, "instance_id": "transformerlab__transformerlab-app-536", "issue_numbers": [758], "base_commit": "b527148b50c9980c60580012c0c59be9c3ccf506", "patch": "diff --git a/src/renderer/components/Experiment/Diffusion/Diffusion.tsx b/src/renderer/components/Experiment/Diffusion/Diffusion.tsx\nindex 0b9da6055..29d3de6c7 100644\n--- a/src/renderer/components/Experiment/Diffusion/Diffusion.tsx\n+++ b/src/renderer/components/Experiment/Diffusion/Diffusion.tsx\n@@ -34,6 +34,7 @@ import {\n   useServerStats,\n } from 'renderer/lib/transformerlab-api-sdk';\n import SimpleTextArea from 'renderer/components/Shared/SimpleTextArea';\n+import { useAnalytics } from 'renderer/components/Shared/useAnalytics';\n import History from './History';\n import Inpainting from './Inpainting';\n import HistoryImageSelector from './HistoryImageSelector';\n@@ -72,6 +73,8 @@ const LabelWithTooltip = ({\n );\n \n export default function Diffusion({ experimentInfo }: DiffusionProps) {\n+  const analytics = useAnalytics();\n+\n   const initialModel = experimentInfo?.config?.foundation || '';\n   const adaptor = experimentInfo?.config?.adaptor || '';\n   const [model, setModel] = useState(initialModel);\n@@ -396,6 +399,10 @@ export default function Diffusion({ experimentInfo }: DiffusionProps) {\n         return;\n       }\n \n+      analytics.track('Diffusion Generated', {\n+        model,\n+      });\n+\n       // Build the request body with basic parameters\n       const requestBody: any = {\n         model,\n@@ -496,6 +503,9 @@ export default function Diffusion({ experimentInfo }: DiffusionProps) {\n     setCurrentGenerationData(null);\n     setCurrentImageIndex(0); // Reset to first image\n     try {\n+      analytics.track('Inpainting Generated', {\n+        model,\n+      });\n       // Build the request body with inpainting parameters\n       const requestBody: any = {\n         model,\ndiff --git a/src/renderer/components/Experiment/