+# limitations under the License.
+
+from dataclasses import dataclass
+from typing import Any, Literal
+
+from transformers import TrainingArguments
+
+from ...trainer.dpo_config import DPOConfig
+
+@dataclass
+class SDPOConfig(DPOConfig):
+    """
+    Configuration class for Self-Distillation Preference Optimization (SDPO) trainer.
+
+    This class extends DPOConfig with SDPO-specific parameters. SDPO is a reinforcement learning approach where one
+    model serves as both the teacher and student, eliminating the need for a separate reference model.
+
+    Args:
+        beta (`float`, *optional*, defaults to 0.1):
+            The beta parameter for the DPO loss. Controls the "temperature" of the policy update.
+        label_smoothing (`float`, *optional*, defaults to 0.0):
+            The label smoothing parameter for the DPO loss. Controls the amount of label smoothing applied to the
+            preference labels.
+        loss_type (`str` or `list[str]`, *optional*, defaults to "sigmoid"):
+            The type of loss to use. Can be one of "sigmoid", "hinge", "ipo", "simpo", "robust", "exo_pair", "aot",
+            "aot_unpaired", or "f_divergence". Multiple loss types can be specified as a list.
+        loss_weights (`list[float]`, *optional*):
+            The weights to use for each loss type when multiple loss types are specified. If not specified, all losses
+            are weighted equally.
+        ld_alpha (`float`, *optional*, defaults to 0.0):
+            The alpha parameter for the label smoothing loss. Controls the amount of label smoothing applied to the
+            preference labels.
+        f_divergence_type (`str`, *optional*, defaults to "kl"):
+            The type of f-divergence to use for the f-divergence loss. Can be one of "kl", "js", "chi2", "hellinger",
+            "tv", "wasserstein", "gaussian", "laplace", "cauchy", "logistic", "exponential", "gamma", "beta", or
+            "weibull".
+        f_alpha_divergence_coef (`float`, *optional*, defaults to 1.0):
+            The alpha parameter for the f-divergence loss. Controls the amount of f-divergence applied to the
+            preference labels.
+        use_weighting (`bool`, *optional*, defaults to False):
+            Whether to use WPO-style weighting for the DPO loss. This is not implemented for "aot" or "aot_unpaired"
+            loss types.
+        precompute_ref_log_probs (`bool`, *optional*, defaults to False):
+            Whether to precompute the reference log probabilities. This is not supported when using the Liger kernel.
+        sync_ref_model (`bool`, *optional*, defaults to False):
+            Whether to synchronize the reference model with the policy model. This is not supported when using PEFT.
+        use_liger_kernel (`bool`, *optional*, defaults to False):
+            Whether to use the Liger kernel for the DPO loss. This is not supported when using multiple loss types.
+        disable_dropout (`bool`, *optional*, defaults to True):
+            Whether to disable dropout in the models.
+        padding_free (`bool`, *optional*, defaults to False):
+            Whether to use padding-free training. This is temporarily unavailable after a refactor.
+        max_length (`int`, *optional*):
+            The maximum length of the sequences after concatenation. Sequences longer than `max_length` are truncated
+            before padding, which avoids allocating oversized tensors for batches containing very long sequences.
+        truncation_mode (`str`, *optional*, defaults to "keep_start"):
+            Truncation mode when a concatenated sequence exceeds `max_length`. Possible values are "keep_end" and
+            "keep_start".
+        pad_to_multiple_of (`int`, *optional*):
+            If set, the sequences will be padded to a multiple of this value.
+        pad_token (`str`, *optional*):
+            The token to use for padding. If not specified, the pad token from the tokenizer will be used.
+        model_init_kwargs (`dict[str, Any]`, *optional*):
+            Additional keyword arguments to pass to the model initialization.
+    """
+
+    def __init__(
+        self,
+        output_dir: str = "./sdpo-trainer",
+        beta: float = 0.1,
+        label_smoothing: float = 0.0,
+        loss_type: str | list[str] = "sigmoid",
+        loss_weights: list[float] | None = None,
+        ld_alpha: float = 0.0,
+        f_divergence_type: str = "kl",
+        f_alpha_divergence_coef: float = 1.0,
+        use_weighting: bool = False,
+        precompute_ref_log_probs: bool = False,
+        sync_ref_model: bool = False,
+        use_liger_kernel: bool = False,
+        disable_dropout: bool = True,
+        padding_free: bool = False,
+        max_length: int | None = None,
+        truncation_mode: str = "keep_start",
+        pad_to_multiple_of: int | None = None,
+        pad_token: str | None = None,
+        model_init_kwargs: dict[str, Any] | None = None,
+        **kwargs,
+    ):
+        # Call DPOConfig with only the parameters it accepts
+        super().__init__(
+            output_dir=output_dir,
+            beta=beta,
+            label_smoothing=label_smoothing,
+            loss_type=loss_type,
+            loss_weights=loss_weights,
+            ld_alpha=ld_alpha,
+            f_divergence_type=f_divergence_type,
+            f_alpha_divergence_coef=f_alpha_divergence_coef,
+            use_weighting=use_weighting,
+            precompute_ref_log_probs=precompute_ref_log_probs,
+            sync_ref_model=sync_ref_model,
+            use_liger_kernel=use_liger_kernel,
+            disable_dropout=disable_dropout,
+            padding_free=padding_free,
+            max_length=max_length,
+            truncation_mode=truncation_mode,
+            pad_to_multiple_of=pad_to_multiple_of,
+            pad_token=pad_token,
+            model_init_kwargs=model_init_kwargs,
+            **kwargs,
+        )
