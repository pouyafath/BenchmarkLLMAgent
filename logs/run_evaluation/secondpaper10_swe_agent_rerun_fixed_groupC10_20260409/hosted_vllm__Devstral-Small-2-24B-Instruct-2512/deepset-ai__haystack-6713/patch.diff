+    def _deserialize_dict(self, data: Any) -> Any:
+        """
+        Recursively deserialize values in a dictionary or list.
+        """
+        if isinstance(data, dict):
+            return {k: self._deserialize_dict(v) for k, v in data.items()}
+        elif isinstance(data, list):
+            return [self._deserialize_dict(item) for item in data]
