+
+    def setUp(self):
+        """Setup"""
+        super(TestCodeBuildProjectUniqueNames, self).setUp()
+        self.collection.register(CodeBuildProjectUniqueNames())
+        self.success_templates = [
+            "test/fixtures/templates/good/resources/codebuild_unique_names.yaml",
