          repr(counts),\n-            \"<AlignmentCounts object (score = 12.0; substitution score = 12.0; gap score = 0.0; 13 aligned letters; 12 identities; 1 mismatches; 4 gaps) at 0x%x>\"\n+            \"<AlignmentCounts object (score = 8.0; substitution score = 12.0; gap score = -4.0; 13 aligned letters; 12 identities; 1 mismatches; 4 gaps) at 0x%x>\"\n             % id(counts),\n         )\n         self.assertEqual(\n             str(counts),\n             \"\"\"\\\n AlignmentCounts object with\n-    score = 12.0:\n+    score = 8.0:\n         substitution_score = 12.0,\n-        gap_score = 0.0.\n+        gap_score = -4.0.\n     aligned = 13:\n         identities = 12,\n         mismatches = 1.\n@@ -21646,7 +21641,7 @@ def test_incomplete_nucleotide_sequence(self):\n         )\n         self.check_incomplete_nucleotide_sequence(counts)\n         self.assertIsNone(counts.positives)\n-        self.assertAlmostEqual(counts.score, 12.0)\n+        self.assertAlmostEqual(counts.score, 8.0)\n         counts = alignment.counts(aligner_blastn)\n         self.assertEqual(\n             repr(counts),\n@@ -21706,16 +21701,16 @@ def test_incomplete_nucleotide_sequence(self):\n         counts = alignment.counts(aligner)\n         self.assertEqual(\n             repr(counts),\n-            \"<AlignmentCounts object (score = 12.0; substitution score = 12.0; gap score = 0.0; 13 aligned letters; 12 identities; 1 mismatches; 4 gaps) at 0x%x>\"\n+            \"<AlignmentCounts object (score = 8.0; substitution score = 12.0; gap score = -4.0; 13 aligned letters; 12 identities; 1 mismatches; 4 gaps) at 0x%x>\"\n             % id(counts),\n         )\n         self.assertEqual(\n             str(counts),\n             \"\"\"\\\n AlignmentCounts object with\n-    score = 12.0:\n+    score = 8.0:\n         substitution_score = 12.0,\n-        gap_score = 0.0.\n+        gap_score = -4.0.\n     aligned = 13:\n         identities = 12,\n         mismatches = 1.\n@@ -21745,7 +21740,7 @@ def test_incomplete_nucleotide_sequence(self):\n         )\n         self.check_incomplete_nucleotide_sequence(counts)\n         self.assertIsNone(counts.positives)\n-        self.assertAlmostEqual(counts.score, 12.0)\n+        self.assertAlmostEqual(counts.score, 8.0)\n         counts = alignment.counts(aligner_blastn)\n         self.assertEqual(\n             repr(counts),\n@@ -21861,16 +21856,16 @@ def test_blastp(self):\n         counts = alignment.counts(aligner)\n         self.assertEqual(\n             repr(counts),\n-            \"<AlignmentCounts object (score = 237.0; substitution score = 237.0; gap score = 0.0; 444 aligned letters; 237 identities; 207 mismatches; 36 gaps) at 0x%x>\"\n+            \"<AlignmentCounts object (score = 201.0; substitution score = 237.0; gap score = -36.0; 444 aligned letters; 237 identities; 207 mismatches; 36 gaps) at 0x%x>\"\n             % id(counts),\n         )\n         self.assertEqual(\n             str(counts),\n             \"\"\"\\\n AlignmentCounts object with\n-    score = 237.0:\n+    score = 201.0:\n         substitution_score = 237.0,\n-        gap_score = 0.0.\n+        gap_score = -36.0.\n     aligned = 444:\n         identities = 237,\n         mismatches = 207.\n@@ -21900,7 +21895,7 @@ def test_blastp(self):\n         )\n         self.check_blastp(counts)\n         self.assertIsNone(counts.positives)\n-        self.assertAlmostEqual(counts.score, 237.0)\n+        self.assertAlmostEqual(counts.score, 201.0)\n         counts = alignment.counts(aligner_blastp)\n         self.assertEqual(\n             repr(counts),\n@@ -22187,6 +22182,7 @@ def test_string(self):\n \n     def test_greek(self):\n         aligner = Align.PairwiseAligner()\n+        aligner.gap_score = 0\n         seqA = \"\u03b1\u03b2\u03b3\u03b3\u03b2\u03b1\"\n         seqB = \"ABCBA\u03b1\u03b2\u03b3\"\n         alignments = aligner.align(seqA, seqB)\n", "problem_statement": "Bio.pairwise2, Bio.Align.PairwiseAligner default parameters\nThe simplest aligners in `Bio.pairwise2` (`globalxx` and `localxx`) use a match score of +1, a mismatch score of 0, and a gap score of 0. For consistency, `Bio.Align.PairwiseAligner` uses the same scores by default.\nHowever, this is almost never a good scoring scheme, as it assigns the same score to a mismatch and to two adjacent gaps, as in\n```\nX\n.\nA\n```\nand\n```\nX-\n--\n-A\n```\nThis then results in a large number of alignments with only trivial differences in the placement of gaps and mismatches.\nFor example,\n```python\n>>> from Bio.pairwise2 import align\n>>> alignments = align.globalxx(\"AAAAAACCCCAAAAAA\", \"AAAAAATTTTAAAAAA\")\n>>> for alignment in alignments:\n...     print(pairwise2.format_alignment(*alignment))\nAAAAAACCCC----AAAAAA\n||||||        ||||||\nAAAAAA----TTTTAAAAAA\n  Score=12\n\nAAAAAACCCC---AAAAAA\n||||||   .   ||||||\nAAAAAA---TTTTAAAAAA\n  Score=12\n\nAAAAAACCCC---AAAAAA\n||||||  .    ||||||\nAAAAAA--T-TTTAAAAAA\n  Score=12\n\nAAAAAACCCC---AAAAAA\n|||||| .     ||||||\nAAAAAA-T--TTTAAAAAA\n  Score=12\n\nAAAAAACCCC---AAAAAA\n||||||.      ||||||\nAAAAAAT---TTTAAAAAA\n  Score=12\n\nAAAAAACCC-C--AAAAAA\n||||||    .  ||||||\nAAAAAA---TTTTAAAAAA\n  Score=12\n\nAAAAAACCCC--AAAAAA\n||||||  ..  ||||||\nAAAAAA--TTTTAAAAAA\n  Score=12\n\nAAAAAACCCC--AAAAAA\n|||||| . .  ||||||\nAAAAAA-T-TTTAAAAAA\n  Score=12\n\nAAAAAACCCC--AAAAAA\n||||||.  .  ||||||\nAAAAAAT--TTTAAAAAA\n  Score=12\n\nAAAAAACC-CC--AAAAAA\n||||||   .   ||||||\nAAAAAA--TT-TTAAAAAA\n  Score=12\n\nAAAAAACCCC--AAAAAA\n|||||| ..   ||||||\nAAAAAA-TT-TTAAAAAA\n  Score=12\n\nAAAAAACCCC--AAAAAA\n||||||. .   ||||||\nAAAAAAT-T-TTAAAAAA\n  Score=12\n\nAAAAAAC-CCC--AAAAAA\n||||||  .    ||||||\nAAAAAA-TT--TTAAAAAA\n  Score=12\n\nAAAAAACCCC--AAAAAA\n||||||..    ||||||\nAAAAAATT--TTAAAAAA\n  Score=12\n\nAAAAAA-CCCC--AAAAAA\n|||||| .     ||||||\nAAAAAATT---TTAAAAAA\n  Score=12\n\nAAAAAACCC--C-AAAAAA\n||||||     . ||||||\nAAAAAA---TTTTAAAAAA\n  Score=12\n\nAAAAAACCC-C-AAAAAA\n||||||  . . ||||||\nAAAAAA--TTTTAAAAAA\n  Score=12\n\nAAAAAACCC-C-AAAAAA\n|||||| .  . ||||||\nAAAAAA-T-TTTAAAAAA\n  Score=12\n\nAAAAAACCC-C-AAAAAA\n||||||.   . ||||||\nAAAAAAT--TTTAAAAAA\n  Score=12\n\nAAAAAACC-CC-AAAAAA\n||||||   .. ||||||\nAAAAAA--TTTTAAAAAA\n  Score=12\n\nAAAAAACCCC-AAAAAA\n|||||| ... ||||||\nAAAAAA-TTTTAAAAAA\n  Score=12\n\nAAAAAACCCC-AAAAAA\n||||||. .. ||||||\nAAAAAAT-TTTAAAAAA\n  Score=12\n\nAAAAAAC-CCC-AAAAAA\n||||||  . . ||||||\nAAAAAA-TT-TTAAAAAA\n  Score=12\n\nAAAAAACCCC-AAAAAA\n||||||.. . ||||||\nAAAAAATT-TTAAAAAA\n  Score=12\n\nAAAAAA-CCCC-AAAAAA\n|||||| .  . ||||||\nAAAAAATT--TTAAAAAA\n  Score=12\n\nAAAAAACC--CC-AAAAAA\n||||||    .  ||||||\nAAAAAA--TTT-TAAAAAA\n  Score=12\n\nAAAAAACC-CC-AAAAAA\n|||||| . .  ||||||\nAAAAAA-TTT-TAAAAAA\n  Score=12\n\nAAAAAACC-CC-AAAAAA\n||||||.  .  ||||||\nAAAAAAT-TT-TAAAAAA\n  Score=12\n\nAAAAAAC-CCC-AAAAAA\n||||||  ..  ||||||\nAAAAAA-TTT-TAAAAAA\n  Score=12\n\nAAAAAACCCC-AAAAAA\n||||||...  ||||||\nAAAAAATTT-TAAAAAA\n  Score=12\n\nAAAAAA-CCCC-AAAAAA\n|||||| . .  ||||||\nAAAAAATT-T-TAAAAAA\n  Score=12\n\nAAAAAAC--CCC-AAAAAA\n||||||   .   ||||||\nAAAAAA-TTT--TAAAAAA\n  Score=12\n\nAAAAAAC-CCC-AAAAAA\n||||||. .   ||||||\nAAAAAATTT--TAAAAAA\n  Score=12\n\nAAAAAA-CCCC-AAAAAA\n|||||| ..   ||||||\nAAAAAATTT--TAAAAAA\n  Score=12\n\nAAAAAA--CCCC-AAAAAA\n||||||  .    ||||||\nAAAAAATTT---TAAAAAA\n  Score=12\n\nAAAAAACCC---CAAAAAA\n||||||      .||||||\nAAAAAA---TTTTAAAAAA\n  Score=12\n\nAAAAAACCC--CAAAAAA\n||||||  .  .||||||\nAAAAAA--TTTTAAAAAA\n  Score=12\n\nAAAAAACCC--CAAAAAA\n|||||| .   .||||||\nAAAAAA-T-TTTAAAAAA\n  Score=12\n\nAAAAAACCC--CAAAAAA\n||||||.    .||||||\nAAAAAAT--TTTAAAAAA\n  Score=12\n\nAAAAAACC-C-CAAAAAA\n||||||   . .||||||\nAAAAAA--TTTTAAAAAA\n  Score=12\n\nAAAAAACCC-CAAAAAA\n|||||| .. .||||||\nAAAAAA-TTTTAAAAAA\n  Score=12\n\nAAAAAACCC-CAAAAAA\n||||||. . .||||||\nAAAAAAT-TTTAAAAAA\n  Score=12\n\nAAAAAAC-CC-CAAAAAA\n||||||  .  .||||||\nAAAAAA-TT-TTAAAAAA\n  Score=12\n\nAAAAAACCC-CAAAAAA\n||||||..  .||||||\nAAAAAATT-TTAAAAAA\n  Score=12\n\nAAAAAA-CCC-CAAAAAA\n|||||| .   .||||||\nAAAAAATT--TTAAAAAA\n  Score=12\n\nAAAAAACC--CCAAAAAA\n||||||    ..||||||\nAAAAAA--TTTTAAAAAA\n  Score=12\n\nAAAAAACC-CCAAAAAA\n|||||| . ..||||||\nAAAAAA-TTTTAAAAAA\n  Score=12\n\nAAAAAACC-CCAAAAAA\n||||||.  ..||||||\nAAAAAAT-TTTAAAAAA\n  Score=12\n\nAAAAAAC-CCCAAAAAA\n||||||  ...||||||\nAAAAAA-TTTTAAAAAA\n  Score=12\n\nAAAAAACCCCAAAAAA\n||||||....||||||\nAAAAAATTTTAAAAAA\n  Score=12\n\nAAAAAA-CCCCAAAAAA\n|||||| . ..||||||\nAAAAAATT-TTAAAAAA\n  Score=12\n\nAAAAAAC--CCCAAAAAA\n||||||   . .||||||\nAAAAAA-TTT-TAAAAAA\n  Score=12\n\nAAAAAAC-CCCAAAAAA\n||||||. . .||||||\nAAAAAATTT-TAAAAAA\n  Score=12\n\nAAAAAA-CCCCAAAAAA\n|||||| .. .||||||\nAAAAAATTT-TAAAAAA\n  Score=12\n\nAAAAAA--CCCCAAAAAA\n||||||  .  .||||||\nAAAAAATTT--TAAAAAA\n  Score=12\n\nAAAAAACC---CCAAAAAA\n||||||     . ||||||\nAAAAAA--TTTT-AAAAAA\n  Score=12\n\nAAAAAACC--CCAAAAAA\n|||||| .  . ||||||\nAAAAAA-TTTT-AAAAAA\n  Score=12\n\nAAAAAACC--CCAAAAAA\n||||||.   . ||||||\nAAAAAAT-TTT-AAAAAA\n  Score=12\n\nAAAAAAC-C-CCAAAAAA\n||||||  . . ||||||\nAAAAAA-TTTT-AAAAAA\n  Score=12\n\nAAAAAACC-CCAAAAAA\n||||||.. . ||||||\nAAAAAATTTT-AAAAAA\n  Score=12\n\nAAAAAA-CC-CCAAAAAA\n|||||| .  . ||||||\nAAAAAATT-TT-AAAAAA\n  Score=12\n\nAAAAAAC--CCCAAAAAA\n||||||   .. ||||||\nAAAAAA-TTTT-AAAAAA\n  Score=12\n\nAAAAAAC-CCCAAAAAA\n||||||. .. ||||||\nAAAAAATTTT-AAAAAA\n  Score=12\n\nAAAAAA-CCCCAAAAAA\n|||||| ... ||||||\nAAAAAATTTT-AAAAAA\n  Score=12\n\nAAAAAA--CCCCAAAAAA\n||||||  . . ||||||\nAAAAAATTT-T-AAAAAA\n  Score=12\n\nAAAAAAC---CCCAAAAAA\n||||||    .  ||||||\nAAAAAA-TTTT--AAAAAA\n  Score=12\n\nAAAAAAC--CCCAAAAAA\n||||||.  .  ||||||\nAAAAAATTTT--AAAAAA\n  Score=12\n\nAAAAAA-C-CCCAAAAAA\n|||||| . .  ||||||\nAAAAAATTTT--AAAAAA\n  Score=12\n\nAAAAAA--CCCCAAAAAA\n||||||  ..  ||||||\nAAAAAATTTT--AAAAAA\n  Score=12\n\nAAAAAA---CCCCAAAAAA\n||||||   .   ||||||\nAAAAAATTTT---AAAAAA\n  Score=12\n\n>>> len(alignments)\n70\n```\nAn alternative simple scoring scheme could be match=1, mismatch=0, and gap=-1:\n```python\n>>> alignments = align.globalxs(\"AAAAAACCCCAAAAAA\", \"AAAAAATTTTAAAAAA\", -1, -1)\n>>> for alignment in alignments:\n...     print(pairwise2.format_alignment(*alignment))\n... \nAAAAAACCCCAAAAAA\n||||||....||||||\nAAAAAATTTTAAAAAA\n  Score=12\n\n```\n\nThe same applies to the `PairwiseAligner` in `Bio.Align.`\n", "hints_text": "Hi, I'm new to open-source contributions. Can I work on this issue?\n@uxritu I'm guessing this was intended more as a discussion than a request for code help - but do take a look at the issues labeled with help-wanted, or good-first-issue.\nI agree that match=1, mismatch=0, and gap=-1 would probably be a better default, and changing the default would be a pretty easy fix, but there would be *a lot* of tests that rely on those default and would have to be updated. Yes, we could change all those tests, but I'm not sure it'd be a worthwhile project because I'd imagine almost no one uses the defaults anyway.\n\nIf there's evidence that a enough people blindly use the defaults and get bad results, then it would be worthwhile to change, but I don't think this is a common occurrence (please correct me if I'm wrong).\n@michaelfm1211  Thank you for your comments.\n\nFor consistency, `Bio.Align.PairwiseAligner` uses the same default parameters as `Bio.pairwise2`, and there users sometimes get confused because of the huge number of alignments found with the current scoring scheme. See for example issue #2936 .\n\nI was also a bit worried about the number of tests to be fixed, but it turned out that there are not so many tests that use `globalxx` or `localxx`. So I think that this won't be too bad.\n\nAnother option is to change the default parameters for `Bio.Align.PairwiseAligner` only, and leave `Bio.pairwise2` as is.\n\n@cbrueffer , @MarkusPiotrowski , @peterjc  How do you think?\n\nGiven the deprecated status of `pairwise2` I would not change its defaults.\n\n", "all_hints_text": "Hi, I'm new to open-source contributions. Can I work on this issue?\n@uxritu I'm guessing this was intended more as a discussion than a request for code help - but do take a look at the issues labeled with help-wanted, or good-first-issue.\nI agree that match=1, mismatch=0, and gap=-1 would probably be a better default, and changing the default would be a pretty easy fix, but there would be *a lot* of tests that rely on those default and would have to be updated. Yes, we could change all those tests, but I'm not sure it'd be a worthwhile project because I'd imagine almost no one uses the defaults anyway.\n\nIf there's evidence that a enough people blindly use the defaults and get bad results, then it would be worthwhile to change, but I don't think this is a common occurrence (please correct me if I'm wrong).\n@michaelfm1211  Thank you for your comments.\n\nFor consistency, `Bio.Align.PairwiseAligner` uses the same default parameters as `Bio.pairwise2`, and there users sometimes get confused because of the huge number of alignments found with the current scoring scheme. See for example issue #2936 .\n\nI was also a bit worried about the number of tests to be fixed, but it turned out that there are not so many tests that use `globalxx` or `localxx`. So I think that this won't be too bad.\n\nAnother option is to change the default parameters for `Bio.Align.PairwiseAligner` only, and leave `Bio.pairwise2` as is.\n\n@cbrueffer , @MarkusPiotrowski , @peterjc  How do you think?\n\nGiven the deprecated status of `pairwise2` I would not change its defaults.\n\n", "commit_urls": ["https://github.com/biopython/biopython/commit/87b861f40017af2692f7c19e48777fc91bdb3788", "https://github.com/biopython/biopython/commit/615497d37bbc27b714ae1a918c871425aae76def", "https://github.com/biopython/biopython/commit/e2a1586fdfd4246a8cdfbeb18a0c9fe006e455c9", "https://github.com/biopython/biopython/commit/4f5bc85b44128ea317bba92c00300d366605753a", "https://github.com/biopython/biopython/commit/a606b04636d5823b40d62585f66953d65904cc9e", "https://github.com/biopython/biopython/commit/9c0c4918fd873973d51754fdbac8d842b3967874", "https://github.com/biopython/biopython/commit/21d98bc4c47cfd1d4c387802b4aa576df3b49f98", "https://github.com/biopython/biopython/commit/2dd12afde688b375296419a419fda99a3367ddce", "https://github.com/biopython/biopython/commit/b237a04d27ca73c97d49edccb8b609c3e57a2acb", "https://github.com/biopython/biopython/commit/412577572924f4fcf44e5325a875b6cb1fefbe08", "https://github.com/biopython/biopython/commit/c81e5c259f7446de3fc01c87a9ee67bc3ed013cc", "https://github.com/biopython/biopython/commit/f73c9d3810654f977ed3fb39b851fa0308e35c75", "https://github.com/biopython/biopython/commit/afb41f23bd38b2115623f2734c51c5f0a0aa0bae", "https://github.com/biopython/biopython/commit/53a725a1c0b83119ee29e17585d9a1e002c8a832", "https://github.com/biopython/biopython/commit/b33548d36da6d841c51b5ad5d7398f67dc6aa8e9", "https://github.com/biopython/biopython/commit/92c2ffd6b214ef5a9e89197e92b814e2a25b981e", "https://github.com/biopython/biopython/commit/393d6c1b51adf3aa66520e006e1f2fa107fa40a9", "https://github.com/biopython/biopython/commit/f0db2e410fd999976527e65f83a03b41d8375fde", "https://github.com/biopython/biopython/commit/7f08830e81521d88d77d30b004e3a2015d805d03", "https://github.com/biopython/biopython/commit/eb28a98ac235e0376da4219a3c2f47b21f000b4d", "https://github.com/biopython/biopython/commit/e55237aa439a029d1ac5144f06ca9d5dcd6201d8", "https://github.com/biopython/biopython/commit/3e8206f5238e72f8eb4b4809685c93364bfff1a9", "https://github.com/biopython/biopython/commit/f0d63ab6b57ea307f5312f50e3ad1416f9606725", "https://github.com/biopython/biopython/commit/671793c50b59ef77e4ab309cdf0a90c59dde6708", "https://github.com/biopython/biopython/commit/fa46fe62eed87bea8014b4c427f2b1fa558b6363", "https://github.com/biopython/biopython/commit/6d6d5e90e8c96298b22187ebe2621c4fd564dbbd", "https://github.com/biopython/biopython/commit/1a2e8c5278801ab7de306c4c7cd7d23a4c9d2a57", "https://github.com/biopython/biopython/commit/d526f0b61a3cde49bd6cadde889621d9083c211d", "https://github.com/biopython/biopython/commit/579451cb47ca3dc63d67cb9e4faa73e8f12fd81b", "https://github.com/biopython/biopython/commit/6d0e7a99026f3b5ffbb8c4d7127aab75b598e2ca", "https://github.com/biopython/biopython/commit/bf6150a1d45c795d67e5f29cdc9b8ca4292fe43c"], "created_at": "2025-07-16T00:03:38Z"}
{"repo": "biopython/biopython", "pull_number": 4998, "instance_id": "biopython__biopython-4998", "issue_numbers": [4996], "base_commit": "137dca3eb9023fbc44ca376ae1d843038d6487af", "patch": "diff --git a/Bio/PDB/PDBList.py b/Bio/PDB/PDBList.py\nindex 22579536bdc..8f659ea298d 100644\n--- a/Bio/PDB/PDBList.py\n+++ b/Bio/PDB/PDBList.py\n@@ -336,8 +336,12 @@ def retrieve_pdb_file(\n         try:\n             urlcleanup()\n             urlretrieve(url, filename)\n-        except OSError:\n-            print(\"Desired structure doesn't exist\")\n+        except OSError as e:\n+            print(\n+                \"Desired structure not found or download failed.\"\n+                f\" '{pdb_code}': {str(e)}\"\n+            )\n+            return None\n         else:\n             with gzip.open(filename, \"rb\") as gz:\n                 with open(final_file, \"wb\") as out:\ndiff --git a/CONTRIB.rst b/CONTRIB.rst\nindex b9f451ab005..581814bd9ca 100644\n--- a/CONTRIB.rst\n+++ b/CONTRIB.rst\n@@ -339,6 +339,7 @@ please open an issue on GitHub or mention it on the mailing list.\n - Tom Eulenfeld <https://github.com/trichter>\n - Tommy Carstensen <https://github.com/tommycarstensen>\n - Tyghe Vallard <https://github.com/necrolyte2>\n+- Tyrone Lee <https://github.com/lee-t>\n - Uri Laserson <https://github.com/laserson>\n - Uwe Schmitt <https://github.com/uweschmitt>\n - Valentin Vare\u0161ki\u0107 <https://github.com/valentin994>\n", "test_patch": "diff --git a/Tests/test_PDB_PDBList.py b/Tests/test_PDB_PDBList.py\nindex 4edc702f80f..d25262ec6cb 100644\n--- a/Tests/test_PDB_PDBList.py\n+++ b/Tests/test_PDB_PDBList.py\n@@ -159,6 +159,36 @@ def test_invalid_file_format(self):\n             str(context.exception),\n         )\n \n+    def test_retrieve_pdb_file_not_existing(self):\n+        \"\"\"Tests retrieving a non-existent molecule - returns None and prints error message.\"\"\"\n+        with self.make_temp_directory(os.getcwd()) as tmp:\n+            pdblist = PDBList(pdb=tmp)\n+            with unittest.patch(\"sys.stderr\") as mock_stderr:\n+                result = pdblist.retrieve_pdb_file(\"zzzz\", file_format=\"pdb\")\n+                self.assertIsNone(result)\n+                self.assertTrue(\n+                    any(\n+                        \"Desired structure not found or download failed.\" in str(call)\n+                        for call in mock_stderr.write.call_args_list\n+                    ),\n+                    \"Error message not printed for non-existent molecule\",\n+                )\n+\n+    def test_retrieve_pdb_file_bad_url(self):\n+        \"\"\"Tests retrieving with bad server URL - returns None and prints error message.\"\"\"\n+        with self.make_temp_directory(os.getcwd()) as tmp:\n+            pdblist = PDBList(server=\" http://something.wrong \", pdb=tmp)\n+            with unittest.patch(\"sys.stderr\") as mock_stderr:\n+                result = pdblist.retrieve_pdb_file(\"127d\", file_format=\"pdb\")\n+                self.assertIsNone(result)\n+                self.assertTrue(\n+                    any(\n+                        \"Desired structure not found or download failed.\" in str(call)\n+                        for call in mock_stderr.write.call_args_list\n+                    ),\n+                    \"Error message not printed for bad server URL\",\n+                )\n+\n \n class TestPDBListGetAssembly(unittest.TestCase):\n     \"\"\"Test methods responsible for getting assemblies.\"\"\"\n", "problem_statement": " BUG: retreive_pdb_file() shows misleading error message\nIf the user is in an environment where the firewall or SSL cert errors prevent `urlretrieve(url, filename)` from downloading the requested PDB file, the function prints \"Desired structure doesn't exist\" but still returns a filename without processing the error. This can be resolved by adding some error catching:\n\n```\n\n    # Retrieve the file(s)\n    if self._verbose:\n        print(f\"Downloading PDB structure '{pdb_code}'...\")\n    try:\n        urlcleanup()\n        urlretrieve(url, filename)\n    except urllib.error.HTTPError as e:\n        print(f\"Failed to download PDB structure: '{pdb_code}': HTTP Error {e.code} - {e.reason}\")\n        return None\n    except urllib.error.URLError as e:\n        print(f\"Failed to download PDB structure: '{pdb_code}': {e.reason}\")\n        return None\n    except OSError as e:\n        print(f\"Desired structure not found or doesn't exist: \" '{pdb_code}': {str(e)}\")\n        return None\n    else:\n        with gzip.open(filename, \"rb\") as gz:\n            with open(final_file, \"wb\") as out:\n                out.writelines(gz)\n        os.remove(filename)\n    return final_file\n```\n", "hints_text": "I wouldn't mind the raw exception, but a misleading message \"Desired structure doesn't exist\" sounds like a bug.\n\nDo you want to turn your suggested change into a pull request?\n\n", "all_hints_text": "I wouldn't mind the raw exception, but a misleading message \"Desired structure doesn't exist\" sounds like a bug.\n\nDo you want to turn your suggested change into a pull request?\n\n", "commit_urls": ["https://github.com/biopython/biopython/commit/df3133015c374d61bf492bdbb859d8567c771415", "https://github.com/biopython/biopython/commit/b4dde3b14e11d3e23dd4252c3eea4edc1fe7e5e0", "https://github.com/biopython/biopython/commit/8d5f417a11d96c08070d7001db9c1527ab213dfd", "https://github.com/biopython/biopython/commit/770809c277db586c05f534b02c35bd7e55cb9e97", "https://github.com/biopython/biopython/commit/72815c62391685c90c1ef4980aa69eeaf15942ab", "https://github.com/biopython/biopython/commit/ba01c91ab4976839fc6c2516f599cd555bf01d4a", "https://github.com/biopython/biopython/commit/2350403c12d4987836896608f38ba2a54bd0b4e6", "https://github.com/biopython/biopython/commit/b3571eb46d56fdd13f20c0aa76cef27e10c72c38", "https://github.com/biopython/biopython/commit/f9db07ceb325cb476fa7a7e6b1a7236a0bcdf31a", "https://github.com/biopython/biopython/commit/48a4136a5534cf56a173091705c8cca380c30fb1"], "created_at": "2025-05-19T01:05:46Z"}
{"repo": "biopython/biopython", "pull_number": 5001, "instance_id": "biopython__biopython-5001", "issue_numbers": [4997], "base_commit": "137dca3eb9023fbc44ca376ae1d843038d6487af", "patch": "diff --git a/Bio/SeqIO/UniprotIO.py b/Bio/SeqIO/UniprotIO.py\nindex 2f635fe1c41..38e6a649742 100644\n--- a/Bio/SeqIO/UniprotIO.py\n+++ b/Bio/SeqIO/UniprotIO.py\n@@ -16,19 +16,15 @@\n \n \"\"\"\n \n+import warnings\n from xml.etree import ElementTree\n from xml.parsers.expat import errors\n-import warnings\n \n-from Bio import SeqFeature\n+from Bio import BiopythonDeprecationWarning, SeqFeature\n from Bio.Seq import Seq\n from Bio.SeqRecord import SeqRecord\n \n-from Bio import BiopythonDeprecationWarning\n-\n-from .Interfaces import _BytesIOSource\n-from .Interfaces import SequenceIterator\n-\n+from .Interfaces import SequenceIterator, _BytesIOSource\n \n NS = \"{http://uniprot.org/uniprot}\"\n REFERENCE_JOURNAL = \"%(name)s %(volume)s:%(first)s-%(last)s(%(pub_date)s)\"\n@@ -472,6 +468,19 @@ def _parse_feature(self, element):\n                 feature.location = SeqFeature.SimpleLocation(\n                     start_position, end_position\n                 )\n+            elif feature_element.tag == NS + \"ligand\":\n+                # Support multiple ligand entries per feature\n+                name = None\n+                db_ref = None\n+                for child in feature_element:\n+                    if child.tag == NS + \"name\":\n+                        name = child.text.strip() if child.text else None\n+                    elif child.tag == NS + \"dbReference\":\n+                        db_ref = child.attrib.get(\"id\")\n+                # Append to a list of ligands in qualifiers\n+                lig_list = feature.qualifiers.setdefault(\"ligands\", [])\n+                lig_list.append({\"name\": name, \"db_ref\": db_ref})\n+                continue\n             else:\n                 try:\n                     feature.qualifiers[feature_element.tag.replace(NS, \"\")] = (\ndiff --git a/CONTRIB.rst b/CONTRIB.rst\nindex b9f451ab005..9f3caa5edf2 100644\n--- a/CONTRIB.rst\n+++ b/CONTRIB.rst\n@@ -155,6 +155,7 @@ please open an issue on GitHub or mention it on the mailing list.\n - Iddo Friedberg <https://github.com/idoerg>\n - Igor S. Gerasimov <https://github.com/foxtran>\n - Ilya Flyamer <https://github.com/Phlya>\n+- Ira Horecka <https://github.com/irahorecka>\n - Isaac Ellmen <https://github.com/Ellmen>\n - Ivan Antonov <https://github.com/vanya-antonov>\n - Jacek \u015amieta\u0144ski <https://github.com/dadoskawina>\ndiff --git a/Tests/SwissProt/P62330.xml b/Tests/SwissProt/P62330.xml\nnew file mode 100644\nindex 00000000000..d45ded2eb6f\n--- /dev/null\n+++ b/Tests/SwissProt/P62330.xml\n@@ -0,0 +1,2343 @@\n+<?xml version=\"1.0\" encoding=\"UTF-8\"  standalone=\"no\" ?>\n+<uniprot xmlns=\"http://uniprot.org/uniprot\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" xsi:schemaLocation=\"http://uniprot.org/uniprot http://www.uniprot.org/docs/uniprot.xsd\">\n+<entry dataset=\"Swiss-Prot\" created=\"2004-07-05\" modified=\"2025-04-09\" version=\"204\" xmlns=\"http://uniprot.org/uniprot\">\n+  <accession>P62330</accession>\n+  <accession>P26438</accession>\n+  <accession>Q6FGZ2</accession>\n+  <name>ARF6_HUMAN</name>\n+  <protein>\n+    <recommendedName>\n+      <fullName evidence=\"37\">ADP-ribosylation factor 6</fullName>\n+      <ecNumber evidence=\"31\">3.6.5.2</ecNumber>\n+    </recommendedName>\n+  </protein>\n+  <gene>\n+    <name evidence=\"37 39\" type=\"primary\">ARF6</name>\n+  </gene>\n+  <organism>\n+    <name type=\"scientific\">Homo sapiens</name>\n+    <name type=\"common\">Human</name>\n+    <dbReference type=\"NCBI Taxonomy\" id=\"9606\"/>\n+    <lineage>\n+      <taxon>Eukaryota</taxon>\n+      <taxon>Metazoa</taxon>\n+      <taxon>Chordata</taxon>\n+      <taxon>Craniata</taxon>\n+      <taxon>Vertebrata</taxon>\n+      <taxon>Euteleostomi</taxon>\n+      <taxon>Mammalia</taxon>\n+      <taxon>Eutheri