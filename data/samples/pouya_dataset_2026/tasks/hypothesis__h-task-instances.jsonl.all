{"repo": "hypothesis/h", "pull_number": 9509, "instance_id": "hypothesis__h-9509", "issue_numbers": [9508], "base_commit": "97041ab718703eecb6ab60575813c779d076eb5e", "patch": "diff --git a/h/services/jwt.py b/h/services/jwt.py\nnew file mode 100644\nindex 00000000000..3be58bcbb24\n--- /dev/null\n+++ b/h/services/jwt.py\n@@ -0,0 +1,57 @@\n+import datetime\n+from functools import lru_cache\n+from typing import Any\n+\n+import jwt\n+from jwt import PyJWKClient\n+from jwt.exceptions import PyJWTError\n+\n+from h.schemas import ValidationError\n+\n+JWK_CLIENT_TIMEOUT = 10\n+\n+\n+class JWTService:\n+    LEEWAY = datetime.timedelta(seconds=10)\n+\n+    @classmethod\n+    def decode_token(cls, token: str, key_set_url: str) -> dict[str, Any]:\n+        try:\n+            unverified_header = jwt.get_unverified_header(token)\n+            unverified_payload = jwt.decode(token, options={\"verify_signature\": False})\n+        except PyJWTError as err:\n+            msg = \"Invalid JWT {err}\"\n+            raise ValidationError(msg) from err\n+\n+        if not unverified_header.get(\"kid\"):\n+            msg = \"Missing 'kid' value in JWT header\"\n+            raise ValidationError(msg)\n+\n+        alg = unverified_header[\"alg\"]\n+        iss, aud = unverified_payload.get(\"iss\"), unverified_payload.get(\"aud\")\n+\n+        try:\n+            signing_key = cls._get_jwk_client(key_set_url).get_signing_key_from_jwt(\n+                token\n+            )\n+\n+            return jwt.decode(\n+                token,\n+                key=signing_key.key,\n+                audience=aud,\n+                algorithms=[alg],\n+                leeway=cls.LEEWAY,\n+            )\n+        except PyJWTError as err:\n+            msg = f\"Invalid JWT for: {iss}, {aud}. {err}\"\n+            raise ValidationError(msg) from err\n+\n+    @staticmethod\n+    @lru_cache(maxsize=256)\n+    def _get_jwk_client(jwk_url: str) -> PyJWKClient:\n+        \"\"\"Get a PyJWKClient for the given key set URL.\n+\n+        PyJWKClient maintains a cache of keys it has seen.\n+        We want to keep the clients around with `lru_cache` to reuse that internal cache.\n+        \"\"\"\n+        return PyJWKClient(jwk_url, cache_keys=True, timeout=JWK_CLIENT_TIMEOUT)\ndiff --git a/requirements/dev.txt b/requirements/dev.txt\nindex 1a4f3d86a6c..db0790b5f76 100644\n--- a/requirements/dev.txt\n+++ b/requirements/dev.txt\n@@ -34,7 +34,9 @@ certifi==2025.1.31\n     #   -r requirements/prod.txt\n     #   sentry-sdk\n cffi==1.17.1\n-    # via -r requirements/prod.txt\n+    # via\n+    #   -r requirements/prod.txt\n+    #   cryptography\n chameleon==4.6.0\n     # via\n     #   -r requirements/prod.txt\n@@ -63,6 +65,10 @@ colander==2.0\n     # via\n     #   -r requirements/prod.txt\n     #   deform\n+cryptography==44.0.2\n+    # via\n+    #   -r requirements/prod.txt\n+    #   pyjwt\n data-tasks==0.0.5\n     # via -r requirements/prod.txt\n decorator==5.1.1\n@@ -218,7 +224,7 @@ pycryptodomex==3.21.0\n     # via -r requirements/prod.txt\n pygments==2.17.2\n     # via ipython\n-pyjwt==2.10.1\n+pyjwt[crypto]==2.10.1\n     # via -r requirements/prod.txt\n pyparsing==3.2.1\n     # via -r requirements/prod.txt\ndiff --git a/requirements/lint.txt b/requirements/lint.txt\nindex 326e0f74707..3c9a13161c6 100644\n--- a/requirements/lint.txt\n+++ b/requirements/lint.txt\n@@ -55,6 +55,7 @@ cffi==1.17.1\n     # via\n     #   -r requirements/functests.txt\n     #   -r requirements/tests.txt\n+    #   cryptography\n chameleon==4.6.0\n     # via\n     #   -r requirements/functests.txt\n@@ -93,6 +94,11 @@ coverage[toml]==7.6.10\n     # via\n     #   -r requirements/tests.txt\n     #   pytest-cov\n+cryptography==44.0.2\n+    # via\n+    #   -r requirements/functests.txt\n+    #   -r requirements/tests.txt\n+    #   pyjwt\n data-tasks==0.0.5\n     # via\n     #   -r requirements/functests.txt\n@@ -323,7 +329,7 @@ pycryptodomex==3.21.0\n     # via\n     #   -r requirements/functests.txt\n     #   -r requirements/tests.txt\n-pyjwt==2.10.1\n+pyjwt[crypto]==2.10.1\n     # via\n     #   -r requirements/functests.txt\n     #   -r requirements/tests.txt\ndiff --git a/requirements/prod.in b/requirements/prod.in\nindex 83e65aee953..cab1d929b08 100644\n--- a/requirements/prod.in\n+++ b/requirements/prod.in\n@@ -13,7 +13,7 @@ h-api\n h-assets\n data_tasks\n pyramid-sanity\n-PyJWT\n+PyJWT[crypto]\n bcrypt\n bleach\n celery\ndiff --git a/requirements/prod.txt b/requirements/prod.txt\nindex 81098cbc2e5..00e47e372fa 100644\n--- a/requirements/prod.txt\n+++ b/requirements/prod.txt\n@@ -25,7 +25,9 @@ certifi==2025.1.31\n     #   -r requirements/prod.in\n     #   sentry-sdk\n cffi==1.17.1\n-    # via -r requirements/prod.in\n+    # via\n+    #   -r requirements/prod.in\n+    #   cryptography\n chameleon==4.6.0\n     # via deform\n click==8.1.8\n@@ -43,6 +45,8 @@ click-repl==0.3.0\n     # via celery\n colander==2.0\n     # via deform\n+cryptography==44.0.2\n+    # via pyjwt\n data-tasks==0.0.5\n     # via -r requirements/prod.in\n deform==2.0.15\n@@ -138,7 +142,7 @@ pycparser==2.22\n     # via cffi\n pycryptodomex==3.21.0\n     # via -r requirements/prod.in\n-pyjwt==2.10.1\n+pyjwt[crypto]==2.10.1\n     # via -r requirements/prod.in\n pyparsing==3.2.1\n     # via -r requirements/prod.in\ndiff --git a/requirements/typecheck.txt b/requirements/typecheck.txt\nindex e0409b8a89d..4ec56aac163 100644\n--- a/requirements/typecheck.txt\n+++ b/requirements/typecheck.txt\n@@ -32,7 +32,9 @@ certifi==2025.1.31\n     #   -r requirements/prod.txt\n     #   sentry-sdk\n cffi==1.17.1\n-    # via -r requirements/prod.txt\n+    # via\n+    #   -r requirements/prod.txt\n+    #   cryptography\n chameleon==4.6.0\n     # via\n     #   -r requirements/prod.txt\n@@ -61,6 +63,10 @@ colander==2.0\n     # via\n     #   -r requirements/prod.txt\n     #   deform\n+cryptography==44.0.2\n+    # via\n+    #   -r requirements/prod.txt\n+    #   pyjwt\n data-tasks==0.0.5\n     # via -r requirements/prod.txt\n deform==2.0.15\n@@ -189,7 +195,7 @@ pycparser==2.22\n     #   cffi\n pycryptodomex==3.21.0\n     # via -r requirements/prod.txt\n-pyjwt==2.10.1\n+pyjwt[crypto]==2.10.1\n     # via -r requirements/prod.txt\n pyparsing==3.2.1\n     # via -r requirements/prod.txt\n", "test_patch": "diff --git a/requirements/functests.txt b/requirements/functests.txt\nindex 97b2b31ecd3..ed53f1087f3 100644\n--- a/requirements/functests.txt\n+++ b/requirements/functests.txt\n@@ -34,7 +34,9 @@ certifi==2025.1.31\n     #   -r requirements/prod.txt\n     #   sentry-sdk\n cffi==1.17.1\n-    # via -r requirements/prod.txt\n+    # via\n+    #   -r requirements/prod.txt\n+    #   cryptography\n chameleon==4.6.0\n     # via\n     #   -r requirements/prod.txt\n@@ -63,6 +65,10 @@ colander==2.0\n     # via\n     #   -r requirements/prod.txt\n     #   deform\n+cryptography==44.0.2\n+    # via\n+    #   -r requirements/prod.txt\n+    #   pyjwt\n data-tasks==0.0.5\n     # via -r requirements/prod.txt\n deform==2.0.15\n@@ -207,7 +213,7 @@ pycparser==2.22\n     #   cffi\n pycryptodomex==3.21.0\n     # via -r requirements/prod.txt\n-pyjwt==2.10.1\n+pyjwt[crypto]==2.10.1\n     # via -r requirements/prod.txt\n pyparsing==3.2.1\n     # via -r requirements/prod.txt\ndiff --git a/requirements/tests.txt b/requirements/tests.txt\nindex 55cf16e7a88..b2bfd636f7a 100644\n--- a/requirements/tests.txt\n+++ b/requirements/tests.txt\n@@ -33,7 +33,9 @@ certifi==2025.1.31\n     #   -r requirements/prod.txt\n     #   sentry-sdk\n cffi==1.17.1\n-    # via -r requirements/prod.txt\n+    # via\n+    #   -r requirements/prod.txt\n+    #   cryptography\n chameleon==4.6.0\n     # via\n     #   -r requirements/prod.txt\n@@ -64,6 +66,10 @@ colander==2.0\n     #   deform\n coverage[toml]==7.6.10\n     # via pytest-cov\n+cryptography==44.0.2\n+    # via\n+    #   -r requirements/prod.txt\n+    #   pyjwt\n data-tasks==0.0.5\n     # via -r requirements/prod.txt\n deform==2.0.15\n@@ -216,7 +222,7 @@ pycparser==2.22\n     #   cffi\n pycryptodomex==3.21.0\n     # via -r requirements/prod.txt\n-pyjwt==2.10.1\n+pyjwt[crypto]==2.10.1\n     # via -r requirements/prod.txt\n pyparsing==3.2.1\n     # via -r requirements/prod.txt\ndiff --git a/tests/unit/h/conftest.py b/tests/unit/h/conftest.py\nindex 9c93fa4bc84..b45bbc999c3 100644\n--- a/tests/unit/h/conftest.py\n+++ b/tests/unit/h/conftest.py\n@@ -43,16 +43,6 @@ def __init__(self, errors):\n         self.errors = errors\n \n \n-def autopatcher(request, target, **kwargs):\n-    \"\"\"Patch and cleanup automatically. Wraps :py:func:`mock.patch`.\"\"\"\n-    options = {\"autospec\": True}\n-    options.update(kwargs)\n-    patcher = mock.patch(target, **options)\n-    obj = patcher.start()\n-    request.addfinalizer(patcher.stop)\n-    return obj\n-\n-\n @pytest.fixture\n def cli():\n     runner = click.testing.CliRunner()\n@@ -119,8 +109,8 @@ def notify(pyramid_config, request):\n \n \n @pytest.fixture\n-def patch(request):\n-    return functools.partial(autopatcher, request)\n+def patch(mocker):\n+    return functools.partial(mocker.patch, autospec=True)\n \n \n @pytest.fixture\ndiff --git a/tests/unit/h/services/jwt_test.py b/tests/unit/h/services/jwt_test.py\nnew file mode 100644\nindex 00000000000..46b9b24f087\n--- /dev/null\n+++ b/tests/unit/h/services/jwt_test.py\n@@ -0,0 +1,58 @@\n+from unittest.mock import sentinel\n+\n+import pytest\n+from jwt.exceptions import InvalidTokenError\n+\n+from h.schemas import ValidationError\n+from h.services.jwt import JWK_CLIENT_TIMEOUT, JWTService\n+\n+\n+class TestJWTService:\n+    def test_decode_token(self, jwt, PyJWKClient):\n+        jwt.decode.return_value = {\"aud\": \"AUD\", \"iss\": \"ISS\"}\n+        jwt.get_unverified_header.return_value = {\"kid\": \"KID\", \"alg\": \"RS256\"}\n+\n+        payload = JWTService.decode_token(sentinel.token, sentinel.key_set_url)\n+\n+        jwt.get_unverified_header.assert_called_once_with(sentinel.token)\n+        PyJWKClient.assert_called_once_with(\n+            sentinel.key_set_url, cache_keys=True, timeout=JWK_CLIENT_TIMEOUT\n+        )\n+        jwt.decode.assert_called_with(\n+            sentinel.token,\n+            key=PyJWKClient.return_value.get_signing_key_from_jwt.return_value.key,\n+            audience=\"AUD\",\n+            algorithms=[\"RS256\"],\n+            leeway=JWTService.LEEWAY,\n+        )\n+        assert payload == jwt.decode.return_value\n+\n+    def test_decode_token_with_no_kid(self, jwt):\n+        jwt.get_unverified_header.return_value = {\"alg\": \"RS256\"}\n+\n+        with pytest.raises(ValidationError, match=\"Missing 'kid' value in JWT header\"):\n+            JWTService.decode_token(sentinel.token, sentinel.key_set_url)\n+\n+    def test_decode_token_with_invalid_jwt_header(self, jwt):\n+        jwt.get_unverified_header.side_effect = InvalidTokenError()\n+\n+        with pytest.raises(ValidationError, match=\"Invalid JWT\"):\n+            JWTService.decode_token(sentinel.token, sentinel.key_set_url)\n+\n+    def test_decode_token_with_invalid_jwt(self, jwt):\n+        jwt.decode.side_effect = [{\"aud\": \"AUD\", \"iss\": \"ISS\"}, InvalidTokenError()]\n+\n+        with pytest.raises(ValidationError, match=\"Invalid JWT\"):\n+            JWTService.decode_token(sentinel.token, sentinel.key_set_url)\n+\n+    @pytest.fixture(autouse=True)\n+    def jwt(self, patch):\n+        return patch(\"h.services.jwt.jwt\")\n+\n+    @pytest.fixture(autouse=True)\n+    def PyJWKClient(self, patch):\n+        return patch(\"h.services.jwt.PyJWKClient\")\n+\n+    @pytest.fixture(autouse=True)\n+    def clear_jwk_cache(self):\n+        JWTService._get_jwk_client.cache_clear()  # noqa: SLF001\n", "problem_statement": "Add JWT service\nLike the [one in lms](https://github.com/hypothesis/lms/blob/6a3b4ffe20bfc426c27e9a02852ea70a3f036bb8/lms/services/jwt.py#L18-L17)\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/hypothesis/h/commit/8e7e768ae9835414cc30c1f75d25b278106affb7", "https://github.com/hypothesis/h/commit/c789bbc8280f5cbefd48545165537f9f014a127e"], "created_at": "2025-04-29T16:48:30Z"}
{"repo": "hypothesis/h", "pull_number": 9537, "instance_id": "hypothesis__h-9537", "issue_numbers": [9536], "base_commit": "cd4a8b3430744b4f55f4402196f81db9d425d533", "patch": "diff --git a/h/models/feature.py b/h/models/feature.py\nindex 87ed30e79c5..e7e2e009a91 100644\n--- a/h/models/feature.py\n+++ b/h/models/feature.py\n@@ -21,6 +21,7 @@\n     \"pdf_image_annotation\": \"Support image annotations in PDFs\",\n     \"styled_highlight_clusters\": \"Style different clusters of highlights in the client\",\n     \"at_mentions\": \"Allow mentioning other users in annotations\",\n+    \"log_in_with_orcid\": \"Allow users to log in with ORCID\",\n }\n \n \n", "test_patch": "", "problem_statement": "Add log_in_with_orcid feature flag\n\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/hypothesis/h/commit/b905fdc73764da700a331b271d5530bfe41096ba"], "created_at": "2025-05-05T16:40:36Z"}
{"repo": "hypothesis/h", "pull_number": 9539, "instance_id": "hypothesis__h-9539", "issue_numbers": [9538], "base_commit": "ba604f498d9c20f54b4b57ec7c0b61f379f44aa1", "patch": "diff --git a/h/services/http.py b/h/services/http.py\nnew file mode 100644\nindex 00000000000..7fe916b3a7d\n--- /dev/null\n+++ b/h/services/http.py\n@@ -0,0 +1,69 @@\n+from requests import RequestException, Response, Session  # noqa: A005\n+\n+from h.services.exceptions import ExternalRequestError\n+\n+HTTP_SERVICE_TIMEOUT = 10\n+\n+\n+class HTTPService:\n+    \"\"\"Send HTTP requests with `requests` and receive the responses.\"\"\"\n+\n+    def __init__(self) -> None:\n+        # A session is used so that cookies are persisted across\n+        # requests and urllib3 connection pooling is used (which means that\n+        # underlying TCP connections are re-used when making multiple requests\n+        # to the same host, e.g. pagination).\n+\n+        # See https://docs.python-requests.org/en/latest/user/advanced/#session-objects\n+        self._session = Session()\n+\n+    @property\n+    def session(self) -> Session:\n+        return self._session\n+\n+    def request(\n+        self,\n+        method: str,\n+        url: str,\n+        timeout: float | tuple[float, float] = HTTP_SERVICE_TIMEOUT,\n+        **kwargs,\n+    ) -> Response:\n+        \"\"\"\n+        Send a request with `requests` and return the response object.\n+\n+        This method accepts the same arguments as `requests.Session.request`\n+        with the same meaning which can be seen here:\n+\n+        https://requests.readthedocs.io/en/latest/api/#requests.Session.request\n+\n+        :raises ExternalRequestError: For any request-based failure or if the\n+            response is an error (4xx or 5xx response).\n+        \"\"\"\n+        response = None\n+\n+        try:\n+            response = self._session.request(method, url, timeout=timeout, **kwargs)\n+            response.raise_for_status()\n+        except RequestException as err:\n+            raise ExternalRequestError(request=err.request, response=response) from err\n+\n+        return response\n+\n+    def get(self, *args, **kwargs) -> Response:\n+        return self.request(\"GET\", *args, **kwargs)\n+\n+    def put(self, *args, **kwargs) -> Response:\n+        return self.request(\"PUT\", *args, **kwargs)\n+\n+    def post(self, *args, **kwargs) -> Response:\n+        return self.request(\"POST\", *args, **kwargs)\n+\n+    def patch(self, *args, **kwargs) -> Response:\n+        return self.request(\"PATCH\", *args, **kwargs)\n+\n+    def delete(self, *args, **kwargs) -> Response:\n+        return self.request(\"DELETE\", *args, **kwargs)\n+\n+\n+def factory(_context, _request) -> HTTPService:\n+    return HTTPService()\n", "test_patch": "diff --git a/tests/unit/h/services/http_test.py b/tests/unit/h/services/http_test.py\nnew file mode 100644\nindex 00000000000..9ce6f2f65b5\n--- /dev/null\n+++ b/tests/unit/h/services/http_test.py\n@@ -0,0 +1,90 @@\n+from unittest.mock import create_autospec, sentinel\n+\n+import pytest\n+import requests\n+from requests import RequestException\n+\n+from h.services.exceptions import ExternalRequestError\n+from h.services.http import (\n+    HTTP_SERVICE_TIMEOUT,\n+    HTTPService,\n+    factory,\n+)\n+\n+\n+class TestHTTPService:\n+    def test_request(self, svc, passed_args):\n+        response = svc.request(sentinel.method, sentinel.url, **passed_args)\n+\n+        svc.session.request.assert_called_once_with(\n+            sentinel.method, sentinel.url, **passed_args\n+        )\n+        assert response == svc.session.request.return_value\n+\n+    @pytest.mark.parametrize(\"method\", [\"get\", \"put\", \"post\", \"patch\", \"delete\"])\n+    def test_convenience_methods(self, svc, method, passed_args):\n+        response = getattr(svc, method.lower())(sentinel.url, **passed_args)\n+\n+        svc.session.request.assert_called_once_with(\n+            method.upper(), sentinel.url, **passed_args\n+        )\n+        assert response == svc.session.request.return_value\n+\n+    def test_request_defaults(self, svc):\n+        svc.request(sentinel.method, sentinel.url)\n+\n+        svc.session.request.assert_called_once_with(\n+            sentinel.method, sentinel.url, timeout=HTTP_SERVICE_TIMEOUT\n+        )\n+\n+    def test_it_raises_if_sending_the_request_fails(self, svc):\n+        svc.session.request.side_effect = RequestException(\n+            request=sentinel.err_request, response=sentinel.err_response\n+        )\n+\n+        with pytest.raises(ExternalRequestError) as exc_info:\n+            svc.request(\"GET\", \"https://example.com\")\n+\n+        assert exc_info.value.request == sentinel.err_request\n+        assert exc_info.value.response is None\n+\n+    def test_it_raises_if_the_response_is_an_error(self, svc):\n+        response = svc.session.request.return_value\n+        response.raise_for_status.side_effect = RequestException(\n+            request=sentinel.err_request, response=sentinel.err_response\n+        )\n+\n+        with pytest.raises(ExternalRequestError) as exc_info:\n+            svc.request(\"GET\", \"https://example.com\")\n+\n+        assert exc_info.value.request == sentinel.err_request\n+        assert exc_info.value.response == response\n+\n+    @pytest.fixture\n+    def passed_args(self):\n+        return {\n+            \"headers\": sentinel.headers,\n+            \"params\": sentinel.params,\n+            \"json\": sentinel.json,\n+            \"data\": sentinel.data,\n+            \"auth\": sentinel.auth,\n+            \"timeout\": sentinel.timeout,\n+        }\n+\n+    @pytest.fixture\n+    def svc(self):\n+        svc = HTTPService()\n+        svc._session = create_autospec(requests.Session, instance=True, spec_set=True)  # noqa: SLF001\n+        return svc\n+\n+\n+class TestFactory:\n+    def test_it(self, pyramid_request, HTTPService):\n+        svc = factory(sentinel.context, pyramid_request)\n+\n+        HTTPService.assert_called_once_with()\n+        assert svc == HTTPService.return_value\n+\n+    @pytest.fixture(autouse=True)\n+    def HTTPService(self, patch):\n+        return patch(\"h.services.http.HTTPService\")\n", "problem_statement": "Add HTTP service\nLike the [one in lms](https://github.com/hypothesis/lms/blob/a883b59f059df63038f032e6a49b757de366d51d/lms/services/http.py#L6)\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/hypothesis/h/commit/fe5bcd2068f7e89ddc426e69cbfc4cd991677327"], "created_at": "2025-05-05T17:02:32Z"}
{"repo": "hypothesis/h", "pull_number": 9960, "instance_id": "hypothesis__h-9960", "issue_numbers": [9958], "base_commit": "716ebf6118431c87d016207a27648bd3dcd54a61", "patch": "diff --git a/h/static/scripts/components/CreateEditGroupForm.tsx b/h/static/scripts/components/CreateEditGroupForm.tsx\nindex a41e36eaaa0..b78e7710172 100644\n--- a/h/static/scripts/components/CreateEditGroupForm.tsx\n+++ b/h/static/scripts/components/CreateEditGroupForm.tsx\n@@ -318,7 +318,7 @@ export default function CreateEditGroupForm({\n           </fieldset>\n         )}\n \n-        <div className=\"pt-2 border-t border-t-text-grey-6 flex items-center gap-x-4\">\n+        <div className=\"pt-2 mt-3 border-t border-t-text-grey-6 flex items-center gap-x-4\">\n           <span>\n             {/* These are in a child span to avoid a gap between them. */}\n             <Star />\n", "test_patch": "", "problem_statement": "Styling issue on group form when group types feature is disabled\nThe footer line of the group forms clips the character counter of the field above. I hadn't noticed this previously because I was in a feature cohort with the group types feature enabled, which adds some extra controls between the bottom input field and the footer line.\n\n<img width=\"657\" height=\"424\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/0733efe8-0bac-4dc9-9a7f-187bd79b0ffb\" />\n", "hints_text": "Thanks Rob! I'll address this.\n\n", "all_hints_text": "Thanks Rob! I'll address this.\n\n", "commit_urls": ["https://github.com/hypothesis/h/commit/972346fd88945a284f787fcaf696a3b4580d6965"], "created_at": "2025-10-27T10:22:13Z"}
