+    def __getstate__(self):
+        """Get state for pickling, handling unpicklable __pydantic_parent_namespace__."""
+        state = super().__getstate__()
+
+        # Handle __pydantic_parent_namespace__ which may contain unpicklable objects
+        # on Python 3.14+ due to PEP 749 (deferred evaluation of annotations)
+        if "__pydantic_parent_namespace__" in state:
+            parent_namespace = state["__pydantic_parent_namespace__"]
+            if isinstance(parent_namespace, dict) and "annotate_func" in parent_namespace:
+                # Remove the annotate_func as it contains closures with unpicklable _abc._abc_data objects
