oved\", amount, item)\ndiff --git a/src/pokete/util/__init__.py b/src/pokete/util/__init__.py\nindex 9f540a58..c760351f 100644\n--- a/src/pokete/util/__init__.py\n+++ b/src/pokete/util/__init__.py\n@@ -1,2 +1,4 @@\n-from .liner import liner, hard_liner\n+from .liner import hard_liner, liner\n from .versions import sort_vers\n+\n+__all__ = [\"liner\", \"hard_liner\", \"sort_vers\"]\ndiff --git a/src/pokete/util/command/__init__.py b/src/pokete/util/command/__init__.py\nindex 91526918..29c014cb 100644\n--- a/src/pokete/util/command/__init__.py\n+++ b/src/pokete/util/command/__init__.py\n@@ -1,2 +1,4 @@\n-from .command import Command, RootCommand, Flag\n+from .command import Command, Flag, RootCommand\n from .helpers import not_enough_args, not_found\n+\n+__all__ = [\"Command\", \"RootCommand\", \"Flag\", \"not_enough_args\", \"not_found\"]\ndiff --git a/src/pokete/util/command/command.py b/src/pokete/util/command/command.py\nindex 8f653c54..4bd50106 100644\n--- a/src/pokete/util/command/command.py\n+++ b/src/pokete/util/command/command.py\n@@ -36,7 +36,7 @@ def __init__(\n     @staticmethod\n     def __line_setter(lines: list[tuple[str, str]], line_spaces: int):\n         return \"\\n\".join(\n-            f\"\\t{line[0]}{\" \" * (line_spaces - len(line[0]))}{line[1]}\"\n+            f\"\\t{line[0]}{' ' * (line_spaces - len(line[0]))}{line[1]}\"\n             for line in lines\n         )\n \n@@ -54,14 +54,22 @@ def __print_help(self, ex: str):\n \n Usage:\n     {ex}{f\" {self.usage}\" if self.usage else \"\"} <flags>\n-{f\"\"\"\n+{\n+            f'''\n Options:\n {self.__line_setter(option_lines, line_spaces)}\n-\"\"\" if self.commands else \"\"}\n-{f\"\"\"\n+'''\n+            if self.commands\n+            else \"\"\n+        }\n+{\n+            f'''\n Flags:\n {self.__line_setter(flag_lines, line_spaces)}\n-\"\"\" if self.flags else \"\"}\n+'''\n+            if self.flags\n+            else \"\"\n+        }\n {f\"\\n{self.additional_info}\\n\" if self.additional_info else \"\"}\n Copyright (c) lxgr-linux <lxgr-linux@protonmail.com> 2025\"\"\")\n \n@@ -74,7 +82,7 @@ def run(self, ex: str, options: list[str], flags: dict[str, list[str]]):\n         all_flags = [i for f in self.flags for i in f.aliases]\n         for flag in flags:\n             if flag not in all_flags:\n-                print(f\":: Error: Unknown flag `{flag}`, \" f\"try `{ex} --help`\")\n+                print(f\":: Error: Unknown flag `{flag}`, try `{ex} --help`\")\n                 sys.exit(2)\n         if \"--help\" in flags or \"-h\" in flags:\n             self.__print_help(ex)\ndiff --git a/src/pokete/util/command/helpers.py b/src/pokete/util/command/helpers.py\nindex 10a7c123..10a58f79 100644\n--- a/src/pokete/util/command/helpers.py\n+++ b/src/pokete/util/command/helpers.py\n@@ -2,10 +2,10 @@\n \n \n def not_found(ex, option):\n-    print(f\":: Error: Command '{option}' not found, \" f\"try `{ex} --help`\")\n+    print(f\":: Error: Command '{option}' not found, try `{ex} --help`\")\n     sys.exit(2)\n \n \n def not_enough_args(ex):\n-    print(\":: Error: Not enough arguments, \" f\"try `{ex} --help`\")\n+    print(f\":: Error: Not enough arguments, try `{ex} --help`\")\n     sys.exit(2)\ndiff --git a/src/pokete/util/semantic_version.py b/src/pokete/util/semantic_version.py\nindex 2b613e82..0d953450 100644\n--- a/src/pokete/util/semantic_version.py\n+++ b/src/pokete/util/semantic_version.py\n@@ -26,7 +26,7 @@ def parse(cls, version_str: str) -> \"SemanticVersion\":\n \n     def __str__(self) -> str:\n         return f\"{self.major}.{self.minor}.{self.patch}{\n-            (\"-\"+self.suffix) if self.suffix is not None else \"\"\n+            ('-' + self.suffix) if self.suffix is not None else ''\n         }\"\n \n     def __eq__(self, value) -> bool:\ndiff --git a/src/pokete/util/utility/__init__.py b/src/pokete/util/utility/__init__.py\nindex db925538..3aa3d3cb 100644\n--- a/src/pokete/util/utility/__init__.py\n+++ b/src/pokete/util/utility/__init__.