SICR2 Sonoff relay switches that work okay.)\n```json\n{\n  \"home_assistant\": {\n    \"installation_type\": \"Home Assistant OS\",\n    \"version\": \"2026.3.0\",\n    \"dev\": false,\n    \"hassio\": true,\n    \"virtualenv\": false,\n    \"python_version\": \"3.14.2\",\n    \"docker\": true,\n    \"arch\": \"aarch64\",\n    \"timezone\": \"Africa/Johannesburg\",\n    \"os_name\": \"Linux\",\n    \"os_version\": \"6.12.47-haos-raspi\",\n    \"container_arch\": \"aarch64\",\n    \"supervisor\": \"2026.02.3\",\n    \"host_os\": \"Home Assistant OS 17.1\",\n    \"docker_version\": \"29.1.3\",\n    \"chassis\": \"embedded\",\n    \"run_as_root\": true\n  },\n  \"custom_components\": {\n    \"mikrotik_router\": {\n      \"documentation\": \"https://github.com/tomaae/homeassistant-mikrotik_router\",\n      \"version\": \"0.0.0\",\n      \"requirements\": [\n        \"librouteros>=3.4.1\",\n        \"mac-vendor-lookup>=0.1.12\"\n      ]\n    },\n    \"llmvision\": {\n      \"documentation\": \"https://llmvision.gitbook.io/getting-started/\",\n      \"version\": \"1.6.0\",\n      \"requirements\": [\n        \"boto3==1.37.1\",\n        \"aiosqlite==0.21.0\",\n        \"aiofile==3.9.0\"\n      ]\n    },\n    \"prometheus_sensor\": {\n      \"documentation\": \"https://github.com/mweinelt/ha-prometheus-sensor\",\n      \"version\": \"1.2.1\",\n      \"requirements\": []\n    },\n    \"alexa_media\": {\n      \"documentation\": \"https://github.com/alandtse/alexa_media_player/wiki\",\n      \"version\": \"5.14.0\",\n      \"requirements\": [\n        \"alexapy==1.29.17\",\n        \"packaging>=20.3\",\n        \"wrapt>=1.14.0\",\n        \"dictor>=0.1.12,<0.2\"\n      ]\n    },\n    \"hikconnect\": {\n      \"documentation\": \"https://github.com/tomasbedrich/home-assistant-hikconnect\",\n      \"version\": \"2.4.0\",\n      \"requirements\": [\n        \"hikconnect==1.2.1\"\n      ]\n    },\n    \"presence_simulation\": {\n      \"documentation\": \"https://github.com/slas