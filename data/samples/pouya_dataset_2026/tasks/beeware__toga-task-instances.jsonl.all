,\n+        (50.3, 50),\n+        (50.8, 51),\n+        (Decimal(\"1\"), 1),\n+        (Decimal(\"10.7\"), 11),\n+        (Fraction(2, 3), 1),\n+        (Fraction(1, 16), 0),\n+        (-1, 0),\n+        (-100, 0),\n+        (300, 255),\n     ],\n )\n-def test_hsl(value, expected):\n-    assert_equal_color(hsl(*value), rgb(*expected))\n+@pytest.mark.parametrize(\"band\", [\"r\", \"g\", \"b\"])\n+def test_rgb_normalization(value, expected, band):\n+    \"\"\"Values are clipped and/or converted appropriately.\"\"\"\n+    args = {\"r\": 10, \"g\": 10, \"b\": 10} | {band: value}\n+    color = rgb(**args)\n+    actual = getattr(color, band)\n+    assert isinstance(actual, int)\n+    assert actual == expected\n \n \n @pytest.mark.parametrize(\n     \"value, expected\",\n     [\n-        ((60, 0.0, 0.0, 0.3), (0x00, 0x00, 0x00, 0.3)),\n-        ((60, 0.0, 1.0, 0.3), (0xFF, 0xFF, 0xFF, 0.3)),\n-        ((60, 1.0, 0.5, 0.3), (0xFF, 0xFF, 0x00, 0.3)),\n-        ((60, 0.25, 0.25, 0.3), (0x50, 0x50, 0x30, 0.3)),\n-        ((60, 0.25, 0.75, 0.3), (0xCF, 0xCF, 0xAF, 0.3)),\n-        ((60, 0.75, 0.75, 0.3), (0xEF, 0xEF, 0x8F, 0.3)),\n-        ((60, 0.75, 0.25, 0.3), (0x70, 0x70, 0x10, 0.3)),\n+        (25, 25),\n+        (100.0, 100),\n+        (50.3, 50),\n+        (50.8, 51),\n+        (Decimal(\"1\"), 1),\n+        (Decimal(\"10.7\"), 11),\n+        (Fraction(2, 3), 1),\n+        (Fraction(1, 16), 0),\n+        (-1, 359),\n+        (-100, 260),\n+        (380, 20),\n+        (800, 80),\n     ],\n )\n-def test_hsl_alpha(value, expected):\n-    assert_equal_color(hsla(*value), rgba(*expected))\n+def test_hue_normalization(value, expected):\n+    \"\"\"Values are wrapped and/or converted appropriately.\"\"\"\n+    color = hsl(h=value, s=0.5, l=0.5)\n+    actual = color.h\n+    assert isinstance(actual, int)\n+    assert actual == expected\n \n \n @pytest.mark.parametrize(\n-    \"constructor, value, name, min, max, actual\",\n+    \"value, expected\",\n     [\n-        (rgb, (-1, 120, 10), \"red\", 0, 255, -1),\n-        (rgb, (256, 120, 10), \"red\", 0, 255, 256),\n-        (rgb, (120, -1, 10), \"green\", 0, 255, -1),\n-        (rgb, (120, 256, 10), \"green\", 0, 255, 256),\n-        (rgb, (120, 10, -1), \"blue\", 0, 255, -1),\n-        (rgb, (120, 10, 256), \"blue\", 0, 255, 256),\n-        #\n-        (rgba, (-1, 120, 10, 0.5), \"red\", 0, 255, -1),\n-        (rgba, (256, 120, 10, 0.5), \"red\", 0, 255, 256),\n-        (rgba, (120, -1, 10, 0.5), \"green\", 0, 255, -1),\n-        (rgba, (120, 256, 10, 0.5), \"green\", 0, 255, 256),\n-        (rgba, (120, 10, -1, 0.5), \"blue\", 0, 255, -1),\n-        (rgba, (120, 10, 256, 0.5), \"blue\", 0, 255, 256),\n-        (rgba, (120, 10, 60, -0.5), \"alpha\", 0, 1, -0.5),\n-        (rgba, (120, 10, 60, 1.1), \"alpha\", 0, 1, 1.1),\n-        #\n-        (hsl, (-1, 0.5, 0.8), \"hue\", 0, 360, -1),\n-        (hsl, (361, 0.5, 0.8), \"hue\", 0, 360, 361),\n-        (hsl, (120, -0.1, 0.8), \"saturation\", 0, 1, -0.1),\n-        (hsl, (120, 1.1, 0.8), \"saturation\", 0, 1, 1.1),\n-        (hsl, (120, 0.8, -0.1), \"lightness\", 0, 1, -0.1),\n-        (hsl, (120, 0.8, 1.1), \"lightness\", 0, 1, 1.1),\n-        #\n-        (hsla, (-1, 0.5, 0.8, 0.5), \"hue\", 0, 360, -1),\n-        (hsla, (361, 0.5, 0.8, 0.5), \"hue\", 0, 360, 361),\n-        (hsla, (120, -0.1, 0.8, 0.5), \"saturation\", 0, 1, -0.1),\n-        (hsla, (120, 1.1, 0.8, 0.5), \"saturation\", 0, 1, 1.1),\n-        (hsla, (120, 0.8, -0.1, 0.5), \"lightness\", 0, 1, -0.1),\n-        (hsla, (120, 0.8, 1.1, 0.5), \"lightness\", 0, 1, 1.1),\n-        (hsla, (120, 0.8, 0.5, -0.1), \"alpha\", 0, 1, -0.1),\n-        (hsla, (120, 0.8, 0.5, 1.1), \"alpha\", 0, 1, 1.1),\n+        (0.5, 0.5),\n+        (1.0, 1.0),\n+        (1, 1.0),\n+        (-1, 0.0),\n+        (-100, 0.0),\n+        (10, 1.0),\n+        (Decimal(\".2\"), 0.2),\n+        (Fraction(3, 16), 0.1875),\n     ],\n )\n-def test_invalid_color_constructor(constructor, value, name, min, max, actual):\n-    with pytest.raises(\n-        ValueError,\n-        match=rf\"^{name} value should be between {min}-{max}\\. Got {actual}$\",\n-    ):\n-        constructor(*value)\n+@pytest.mark.parametrize(\n+    \"constructor, attribute\",\n+    [\n+        (rgb, \"a\"),\n+        (hsl, \"s\"),\n+        (hsl, \"l\"),\n+        (hsl, \"a\"),\n+    ],\n+)\n+def test_zero_to_one_normalization(value, expected, constructor, attribute):\n+    \"\"\"Values are clipped and/or converted appropriately.\"\"\"\n+    if constructor is rgb:\n+        args = {\"r\": 10, \"g\": 10, \"b\": 10}\n+    else:\n+        args = {\"h\": 10, \"s\": 0.5, \"l\": 0.5}\n+\n+    args |= {attribute: value}\n+    color = constructor(**args)\n+    actual = getattr(color, attribute)\n+    assert isinstance(actual, float)\n+    assert actual == expected\n+\n+\n+@pytest.mark.parametrize(\n+    \"color, attributes\",\n+    [\n+        (rgb(10, 10, 10), (\"r\", \"g\", \"b\", \"a\")),\n+        (hsl(10, 1, 1), (\"h\", \"s\", \"l\", \"a\")),\n+    ],\n+)\n+def test_read_only(color, attributes):\n+    \"\"\"A color's attributes cannot be changed.\"\"\"\n+    for attribute in attributes:\n+        with pytest.raises(AttributeError):\n+            setattr(color, attribute, 0)\ndiff --git a/travertino/tests/colors/test_parsing.py b/travertino/tests/colors/test_parsing.py\nindex aff1b9f1df..e986b43ae7 100644\n--- a/travertino/tests/colors/test_parsing.py\n+++ b/travertino/tests/colors/test_parsing.py\n@@ -1,70 +1,30 @@\n import pytest\n \n-from travertino.colors import color, hsl, hsla, rgb, rgba\n+from travertino.colors import color, hsl, rgb, rgba\n \n+from ..utils import assert_equal_color\n \n-def assert_equal_hsl(value, expected):\n-    # Nothing fancy - a color is equal if the attributes are all the same\n-    actual = color(value)\n-    assert actual.h == expected.h\n-    assert actual.s == expected.s\n-    assert actual.l == expected.l\n-    assert actual.a == pytest.approx(expected.a, abs=0.001)\n \n-\n-def assert_equal_rgb(value, expected):\n-    # Nothing fancy - a color is equal if the attributes are all the same\n-    actual = color(value)\n-    assert actual.r == expected.r\n-    assert actual.g == expected.g\n-    assert actual.b == expected.b\n-    assert actual.a == pytest.approx(expected.a, abs=0.001)\n+def assert_parsed_equal_color(actual, expected):\n+    actual = color(actual)\n+    assert_equal_color(actual, expected, abs=0.001)\n \n \n def test_noop():\n-    assert_equal_rgb(rgba(1, 2, 3, 0.5), rgba(1, 2, 3, 0.5))\n-    assert_equal_hsl(hsl(1, 0.2, 0.3), hsl(1, 0.2, 0.3))\n+    assert_parsed_equal_color(rgba(1, 2, 3, 0.5), rgba(1, 2, 3, 0.5))\n+    assert_parsed_equal_color(hsl(1, 0.2, 0.3), hsl(1, 0.2, 0.3))\n \n \n @pytest.mark.parametrize(\n     \"value, expected\",\n     [\n-        (\"rgb(1,2,3)\", (1, 2, 3)),\n-        (\"rgb(1, 2, 3)\", (1, 2, 3)),\n-        (\"rgb( 1 , 2 , 3)\", (1, 2, 3)),\n         (\"#123\", (0x11, 0x22, 0x33)),\n         (\"#112233\", (0x11, 0x22, 0x33)),\n         (\"#abc\", (0xAA, 0xBB, 0xCC)),\n         (\"#ABC\", (0xAA, 0xBB, 0xCC)),\n         (\"#abcdef\", (0xAB, 0xCD, 0xEF)),\n         (\"#ABCDEF\", (0xAB, 0xCD, 0xEF)),\n-    ],\n-)\n-def test_rgb(value, expected):\n-    assert_equal_rgb(value, rgb(*expected))\n-\n-\n-@pytest.mark.parametrize(\n-    \"value\",\n-    [\n-        \"10, 20\",\n-        \"a, 10, 20\",\n-        \"10, b, 20\",\n-        \"10, 20, c\",\n-        \"10, 20, 30, 0.5\",\n-    ],\n-)\n-def test_rgb_invalid(value):\n-    with pytest.raises(ValueError):\n-        color(f\"rgb({value})\")\n-\n-\n-@pytest.mark.parametrize(\n-    \"value, expected\",\n-    [\n-        (\"rgba(1,2,3,0.5)\", (1, 2, 3, 0.5)),\n-        (\"rgba(1, 2, 3, 0.5)\", (1, 2, 3, 0.5)),\n-        (\"rgba( 1 , 2 , 3 , 0.5)\", (1, 2, 3, 0.5)),\n+        #\n         (\"#1234\", (0x11, 0x22, 0x33, 0.2666)),\n         (\"#11223344\", (0x11, 0x22, 0x33, 0.2666)),\n         (\"#abcd\", (0xAA, 0xBB, 0xCC, 0.8666)),\n@@ -73,79 +33,8 @@ def test_rgb_invalid(value):\n         (\"#ABCDEFBA\", (0xAB, 0xCD, 0xEF, 0.7294)),\n     ],\n )\n-def test_rgba(value, expected):\n-    assert_equal_rgb(value, rgba(*expected))\n-\n-\n-@pytest.mark.parametrize(\n-    \"value\",\n-    [\n-        \"10, 20, 30\",\n-        \"a, 10, 20, 0.5\",\n-        \"10, b, 20, 0.5\",\n-        \"10, 20, c, 0.5\",\n-        \"10, 20, 30, c\",\n-        \"10, 20, 30, 0.5, 5\",\n-    ],\n-)\n-def test_rgba_invalid(value):\n-    with pytest.raises(ValueError):\n-        color(f\"rgba({value})\")\n-\n-\n-@pytest.mark.parametrize(\n-    \"value\",\n-    [\n-        \"1,20%,30%\",\n-        \"1, 20%, 30%\",\n-        \"1, 20% , 30%\",\n-    ],\n-)\n-def test_hsl(value):\n-    assert_equal_hsl(f\"hsl({value})\", hsl(1, 0.2, 0.3))\n-\n-\n-@pytest.mark.parametrize(\n-    \"value\",\n-    [\n-        \"1, 20%\",\n-        \"a, 20%, 30%\",\n-        \"1, a, 30%\",\n-        \"1, 20%, a)\",\n-        \"1, 20%, 30%, 0.5)\",\n-    ],\n-)\n-def test_hsl_invalid(value):\n-    with pytest.raises(ValueError):\n-        color(f\"hsl({value}\")\n-\n-\n-@pytest.mark.parametrize(\n-    \"value\",\n-    [\n-        \"1,20%,30%,0.5\",\n-        \"1, 20%, 30%, 0.5\",\n-        \" 1, 20% , 30% , 0.5\",\n-    ],\n-)\n-def test_hsla(value):\n-    assert_equal_hsl(f\"hsla({value})\", hsla(1, 0.2, 0.3, 0.5))\n-\n-\n-@pytest.mark.parametrize(\n-    \"value\",\n-    [\n-        \"1, 20%, 30%\",\n-        \"a, 20%, 30%, 0.5\",\n-        \"1, a, 30%, 0.5\",\n-        \"1, 20%, a, 0.5\",\n-        \"1, 20%, 30%, a\",\n-        \"1, 20%, 30%, 0.5, 5\",\n-    ],\n-)\n-def test_hsla_invalid(value):\n-    with pytest.raises(ValueError):\n-        color(f\"hsla({value})\")\n+def test_hex_rgb(value, expected):\n+    assert_parsed_equal_color(value, rgb(*expected))\n \n \n @pytest.mark.parametrize(\n@@ -163,7 +52,7 @@ def test_hsla_invalid(value):\n     ],\n )\n def test_named_color(value, expected):\n-    assert_equal_rgb(value, rgb(*expected))\n+    assert_parsed_equal_color(value, rgb(*expected))\n \n \n def test_named_color_invalid():\n@@ -175,7 +64,23 @@ def test_named_color_invalid():\n     \"num_digits\",\n     [1, 2, 5, 7, 9, 10],\n )\n-def test_hash_mark_invalid(num_digits):\n+def test_hash_mark_invalid_length(num_digits):\n     \"\"\"An invalid number of digts after # raises a ValueError.\"\"\"\n     with pytest.raises(ValueError):\n         color(f\"#{'1' * num_digits}\")\n+\n+\n+def test_invalid_hex_rgb():\n+    \"\"\"Digits out of the hex range raise an error.\"\"\"\n+    with pytest.raises(ValueError):\n+        color(\"#aabbccddhh\")\n+\n+\n+@pytest.mark.parametrize(\n+    \"value\",\n+    [None, 25, rgb],\n+)\n+def test_other_invalid_inputs(value):\n+    \"\"\"Other random junk doesn't work either.\"\"\"\n+    with pytest.raises(ValueError):\n+        color(value)\ndiff --git a/travertino/tests/utils.py b/travertino/tests/utils.py\nindex 4cf8fa3d9b..3373968f98 100644\n--- a/travertino/tests/utils.py\n+++ b/travertino/tests/utils.py\n@@ -5,7 +5,7 @@\n \n import pytest\n \n-from travertino.colors import hsl, hsla, rgb, rgba\n+from travertino.colors import hsl, rgb\n \n if sys.version_info < (3, 10):\n     _DATACLASS_KWARGS = {\"init\": False, \"repr\": False}\n@@ -46,26 +46,20 @@ def __call__(self, *args):\n \n \n def assert_equal_color(actual, expected, abs=1e-6):\n-    if {type(actual), type(expected)} == {rgba}:\n-        assert actual.rgba.r == pytest.approx(expected.rgba.r, abs=abs)\n-        assert actual.rgba.g == pytest.approx(expected.rgba.g, abs=abs)\n-        assert actual.rgba.b == pytest.approx(expected.rgba.b, abs=abs)\n-        assert actual.rgba.a == pytest.approx(expected.rgba.a, abs=abs)\n-    elif {type(actual), type(expected)} == {rgb}:\n-        assert actual.rgb.r == pytest.approx(expected.rgb.r, abs=abs)\n-        assert actual.rgb.g == pytest.approx(expected.rgb.g, abs=abs)\n-        assert actual.rgb.b == pytest.approx(expected.rgb.b, abs=abs)\n-    elif {type(actual), type(expected)} == {hsla}:\n-        assert actual.hsla.h == pytest.approx(expected.hsla.h, abs=abs)\n-        assert actual.hsla.s == pytest.approx(expected.hsla.s, abs=abs)\n-        assert actual.hsla.l == pytest.approx(expected.hsla.l, abs=abs)\n-        assert actual.hsla.a == pytest.approx(expected.hsla.a, abs=abs)\n-    elif {type(actual), type(expected)} == {hsl}:\n-        assert actual.hsl.h == pytest.approx(expected.hsl.h, abs=abs)\n-        assert actual.hsl.s == pytest.approx(expected.hsl.s, abs=abs)\n-        assert actual.hsl.l == pytest.approx(expected.hsl.l, abs=abs)\n+    if type(actual) is type(expected) is rgb:\n+        assert actual.r == pytest.approx(expected.r, abs=abs)\n+        assert actual.g == pytest.approx(expected.g, abs=abs)\n+        assert actual.b == pytest.approx(expected.b, abs=abs)\n+        assert actual.a == pytest.approx(expected.a, abs=abs)\n+    elif type(actual) is type(expected) is hsl:\n+        if not (actual.s == 0 or actual.l in {0, 1}):\n+            # Don't test hue if color is white/black/grey.\n+            assert actual.h == pytest.approx(expected.h, abs=abs)\n+        assert actual.s == pytest.approx(expected.s, abs=abs)\n+        assert actual.l == pytest.approx(expected.l, abs=abs)\n+        assert actual.a == pytest.approx(expected.a, abs=abs)\n     else:\n         raise ValueError(\n             \"Actual color and expected color should be of the same type. \"\n-            f\"But got actual:{type(actual)} and expected:{type(expected)}.\"\n+            f\"But got actual: {type(actual)} and expected: {type(expected)}.\"\n         )\n", "problem_statement": "Quirks and standardization in Colors\n### What is the problem or limitation you are having?\n\nThis is a mix of improvement and arguably some bugfixes.\n\nFirst, there are a number of odd behaviors in the `color()` string-parsing function.\n\n- Trailing commas throw an error:\n  ```python\n  color(\"rgb(1, 2, 3,)\")  # doesn't work\n  ```\n- It doesn't matter what the last character (which should be a `)`) is:\n  ```python\n  color(\"rgb(1, 2, 3q\")  # works\n  ```\n- The docstring says HSL takes `\"hsl(0, 0%, 0%)\"`. That's true, but it interprets S and L as percentages (divided by a hundred) even when no `%` is present. This seems odd considering that calling `hsl(h, s, l)` directly expects them to be floats in the range [0.0 \u2013 1.0].\n\n\n### Describe the solution you'd like\n\nThe first two are simply parsing glitches, but my preferred solution to the third case would be to make the actual constructors more versatile in what they accept. Why not convert percentages (and for that matter hex values) from strings, so that `rgba(\"FF\", \"FF\", \"FF\", \"100%\")` (or for that matter `rgba(\"FF\", \"FF\", \"FF\", \"FF\")` too) becomes equivalent to `rgba(255, 255, 255, 1.0) `?\n\nOn the opposite end of things, the color classes aren't careful about what data type they store as attributes. For instance, regardless of what exactly you supply to `rgba()`, as long as it can be coerced, you ideally should wind up with three ints and a float. However, as it stands, `rgba(255.0, 255.0, 255.0, 1) ` gets stored exactly as supplied.\n\n### Describe alternatives you've considered\n\nIf one were writing this from a blank page, I'm not even positive how much benefit the string-parsing really brings, especially since we already import all the color constructors into the `toga.__` namespace. But I suppose having it around does make things more parallel with how uses can supply values to other style properties either as the named constant or a string literal.\n\nIt might make sense for the `rgb` and `rgba` constructors to be able to take a single string of hex digits as well (e.g. `rgb(\"FF00FF\")`), though I'm not sure how much additional usefulness that would provide.\n\n### Additional context\n\nI have a half-finished conversion of `color` to use structural pattern-matching; it may or may not make sense to worry much about tackling any of this till 3.9 is gone in a few months.\n", "hints_text": "> The first two are simply parsing glitches, but my preferred solution to the third case would be to make the actual constructors more versatile in what they accept. Why not convert percentages (and for that matter hex values) from strings, so that `rgba(\"FF\", \"FF\", \"FF\", \"100%\")` (or for that matter `rgba(\"FF\", \"FF\", \"FF\", \"FF\")` too) becomes equivalent to `rgba(255, 255, 255, 1.0) `?\n\nAlthough that introduces a different ambiguity. Does `color(\"rgb(10, 10, 10)\")` interpret those as base 10 or base 16... : /\nI think this syntax was based on CSS, so we should do whatever CSS does.\nMy two cents: ``rgb(\"FF\", \"FF\", \"00\")`` simply does nothing in CSS, and the correct way is ``#FFFF00`` (also works in lowercase). ``rgb()`` accepts integer values only from my testing in CSS.\nSo this is what I get for not doing research... I've specified plenty of colors in CSS with the various #FFF et al syntax, but had it in my head the hsl() and rgb() versions were just mimicking our own constructors.\n\nThere are still some bugs, but I'll look over the CSS standard before making any more recommendations for or against the intentional parts.\nWell, not research exactly, just testing in a browser, and my third cent is that don't feel bad about this, sometimes it's hard to remember all the guidelines (such as imitating CSS etc)...\nFrom reading the [docs](https://developer.mozilla.org/en-US/docs/Web/CSS/color) and playing around in Firefox, I've learned some things.\n\n- `rgb()` and `rgba()` are supposed to be identical (and accept optional alpha); same for `hsl()` and `hsla()`. The shorter forms are preferred, but the others are maintained as aliases.\n- The `red, green, blue[, alpha]` syntax is similarly supported for backwards compatibility, but the preferred modern syntax is `red green blue[ / alpha]`. And the equivalent for HSL.\n- Alpha values are treated as a percentage if they have a `%`; otherwise `1` is fully opaque. i.e. `50% == .5`\n- On the other hand, saturation and lightness are always interpreted as a percentage out of 100, whether a `%` is present or not.\n- Hue can optionally include `deg` after the number.\n- Hues below `0` and above `360` are accepted, and wrap around. i.e. `100 == 460 == -260`\n\nObviously the string-parsing function should match CSS as closely as possible; how exactly the individual classes and their constructors can best align with that, whether and how much they'd need to change, and if so how best to maintain backwards compatibility, may require some thought.\n\nI'm not sure if @anaelisaramos still had any plans for #3635. If not, I wouldn't mind giving this yak a trim.\nOne other note: in keeping with the general web browser tendency to try and make things work, Firefox, at least, seems perfectly happy to take values out of the allowable range for R, G, B, S, L, and A, simply clamping them to the minimum or maximum. (Hue, as I mentioned above, is a little different, since rather than clamping, it wraps around.)\n\nIt seems to me that it would make sense to follow suit, at least for the string-parsing. Should the explicit constructors too? Or should they maintain their current behavior of throwing an error when an input is out of range?\nTo clarify, when I said \"do whatever CSS does\", I was referring to the names of the functions and the interpretation of their arguments, but not necessarily the surface syntax. I don't think we want to support non-Pythonic syntax like separating arguments with spaces, passing floats as strings with percentage signs, or allowing a \"deg\" suffix.\n> To clarify, when I said \"do whatever CSS does\", I was referring to the names of the functions and the interpretation of their arguments, but not necessarily the surface syntax. I don't think we want to support non-Pythonic syntax like separating arguments with spaces, passing floats as strings with percentage signs, or allowing a \"deg\" suffix.\n\nEven in the string parser? I'm not talking about passing things to the constructors without commas, and despite my initial suggestion, I do agree those shouldn't try to parse string arguments (except perhaps as a side effect of `int(arg)` validation). We're already accepting `%` suffixes in the parser, I don't see how that's different than `deg`.\nOK, I wasn't aware of that parser, and the range of formats it accepts (#3568). I guess the `rgb` and `hsl` formats wrapped inside strings were intended to help with using Travertino to actually implement CSS. But unlike the font shorthand syntax, they aren't of any use in a Toga app, which should always use the `rgb` and `hsl` functions directly.\n\nSo I don't think it's worth the effort of extending them to match the current version of CSS. In fact, since they were never documented, I'd be inclined to deprecate them immediately and save the work of maintaining them. @freakboy3742: what do you think?\n> But unlike the font shorthand syntax, they aren't of any use in a Toga app, which should always use the `rgb` and `hsl` functions directly.\n\nOh, I didn't realize this wasn't intended usage. Guess that's one more reason documenting it is important! Does make sense, though.\n\nI'd argue that users might still find it convenient for us to support the `#rrggbb` string syntax as a shorthand, though.\nYes, definitely, I've got no problem with the `#rrggbb` syntax.\nOkay, so entirely ditch parsing of `\"rgb(...)\"` / `\"hsl(...)\"` strings.\n\nOutside of string-parsing, in order to make things more consistent with how CSS constructs colors, we could:\n- Rename the `rgba` class to `rgb`, make the alpha argument optional, and assign `rgba` as a direct alias. Do the same for `hsl` and `hsla`.\n- When given values outside their acceptable range, clip them to the max/min (or in case of hue, modulo by 360) rather than throwing an error.\n- It *would* be more consistent with CSS to accept (and store?) saturation and brightness as integers from 0 to 100 rather than floats from 0 to 1. But that feels out of place to me in Python, and there'd be no way to handle backwards compatibility without some ambiguity.\n> So I don't think it's worth the effort of extending them to match the current version of CSS. In fact, since they were never documented, I'd be inclined to deprecate them immediately and save the work of maintaining them. [@freakboy3742](https://github.com/freakboy3742): what do you think?\n\nYeah - I think I agree. In the fullness of time (assuming Colosseum ever gains momentum), we'll need some sort of \"fully compliant\" parser; but in the interim, it seems better to lean on `rgb()`/`hsl()` as functions, rather than string-parsed representations.\n\n \n> Outside of string-parsing, in order to make things more consistent with how CSS constructs colors, we could:\n> \n> * Rename the `rgba` class to `rgb`, make the alpha argument optional, and assign `rgba` as a direct alias. Do the same for `hsl` and `hsla`.\n\nThat makes sense to me. I wasn't aware `rgba` was no more than an alias for `rgb`.\n\n> * When given values outside their acceptable range, clip them to the max/min (or in case of hue, modulo by 360) rather than throwing an error.\n\nIf that's what CSS does, then yes - we should do the same.\n\n> * It _would_ be more consistent with CSS to accept (and store?) saturation and brightness as integers from 0 to 100 rather than floats from 0 to 1. But that feels out of place to me in Python, and there'd be no way to handle backwards compatibility without some ambiguity.\n\nWhat are you basing the \"integer would be more consistent\" statement upon? My read is that the S and L channels in the `hsl()` spec are defined as `<percentage>`, which is a `<number>` followed by %; and `<number>` can contain a decimal (as opposed to `<integer>`).\n\n> What are you basing the \"integer would be more consistent\" statement upon? My read is that the S and L channels in the `hsl()` spec are defined as `<percentage>`, which is a `<number>` followed by %; and `<number>` can contain a decimal (as opposed to `<integer>`).\n\nOkay, forget the integer part \u2014 but a number from 0\u2013100 rather than 0\u20131. In CSS, for *alpha*, if you specify a number with a percent sign, it's treated as a percentage (0\u2013100), while if you leave it off, it's interpreted as (and clipped to) 0\u20131. So `50%` is half opaque, but `50` is fully opaque (because it's >= 1).\n\nHowever, saturation and lightness, at least in my testing on Firefox, seem to always be interpreted as percentages, even with no percent sign. So `hsl(..., 1, 1)` looks to CSS like nearly black (saturation and lightness at 1%), while Travertino interprets it as fully white (saturation and lightness at 100%).\n\nHere's what `hsl(120, 1, 1)` looks like in Toga Cocoa:\n\n<img width=\"254\" height=\"79\" alt=\"White text\" src=\"https://github.com/user-attachments/assets/1a3671e7-2f80-4eb0-97ad-802207b5ea76\" />\n\nAnd here's what it looks like when run on web (since the HSL value is output to CSS as-is):\n\n<img width=\"251\" height=\"71\" alt=\"Black text\" src=\"https://github.com/user-attachments/assets/2a8f9db2-2275-41d0-963e-c387d2272210\" />\n\nOne other issue: currently, validation is performed on the arguments when a new RGB or HSL color is created... but there's nothing to prevent them being subsequently set to impossible values. It would probably be a good idea to either:\n\n- Make the attributes read-only properties\n- Take the validation out of `__init__` and put it in simple self-validating descriptors\n\nI'm not sure how useful editable colors are, but I'm also not sure there's a good reason they *need* to be read-only. (Although if they were, then the conversion properties \u2014 `rgb.hsl` and `hsl.rgb` \u2014 could be cached.)\n> Okay, forget the integer part \u2014 but a number from 0\u2013100 rather than 0\u20131. In CSS, for _alpha_, if you specify a number with a percent sign, it's treated as a percentage (0\u2013100), while if you leave it off, it's interpreted as (and clipped to) 0\u20131. So `50%` is half opaque, but `50` is fully opaque (because it's >= 1).\n\nIt looks to me like that might be a quirk of Firefox, rather than something standardized. Safari and Chrome both reject and ignore `hsl(120, 1, 1)` as an invalid CSS color definition. You have to specify `hsl(120, 1%, 1%)` for it to be parsed (and, for the record, `hsl(120, 0.01, 0.01)` is also rejected).\n\n> I'm not sure how useful editable colors are, but I'm also not sure there's a good reason they _need_ to be read-only. (Although if they were, then the conversion properties \u2014 `rgb.hsl` and `hsl.rgb` \u2014 could be cached.)\n\nThe only way I can think that it *might* be useful is in a true MVC-style app, where you define a \"color\" property, connect one channel of the color to a slider, and the slider as the background of a piece of text. Move the slider, the \"data\" changes, and so does the color - without needing to set up an explicit \"on change modify color\" handler.\n\nHowever, to make that work, you'd need to have the cooperation of everything *using* the color - so for the short term at least, I'd be happy to make the channels on a color read only.\n> It looks to me like that might be a quirk of Firefox, rather than something standardized. Safari and Chrome both reject and ignore `hsl(120, 1, 1)` as an invalid CSS color definition. You have to specify `hsl(120, 1%, 1%)` for it to be parsed (and, for the record, `hsl(120, 0.01, 0.01)` is also rejected).\n\nAha, that's what I get for ever guessing something would be consistent across browsers.\n\nI think this means two things:\n- We should keep storing saturation and lightness in the [0\u20131] range.\n- We need to divorce the colors' CSS representation from their Python code. I recommend we keep `__repr__` as copy-pasteable Python, and make `__str__` valid CSS.\n\n> [...] so for the short term at least, I'd be happy to make the channels on a color read only.\n\n\ud83d\udc4d \n\nWith that all more or less settled, and having not heard from Ana, I'll get cooking on this.\n> I think this means two things:\n> \n> * We should keep storing saturation and lightness in the [0\u20131] range.\n> * We need to divorce the colors' CSS representation from their Python code. I recommend we keep `__repr__` as copy-pasteable Python, and make `__str__` valid CSS.\n\n+1 - these both seem like good outcomes.\n \n(also - it looks like GitHub agrees about `hsl()` interpretations. Valid hsl gets a color preview:\n\n<img width=\"177\" height=\"49\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/55f58048-4327-4e79-abb4-f655224bd765\" />\n\ninvalid hsl does not:\n\n<img width=\"261\" height=\"58\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/cbf1a6ef-a967-43d7-aed6-ef993362ed66\" />\n\n)\nOne more thing I just noticed is that R, G, B, and H can all be numbers too, not just integers. Looks like it'll be floats all the way down.\n\n(R, G, B and be can even be percentages, but there's no way to make that unambiguous at the Python level.)\n> One more thing I just noticed is that R, G, B, and H can all be numbers too, not just integers. Looks like it'll be floats all the way down.\n> \n> (R, G, B and be can even be percentages, but there's no way to make that unambiguous at the Python level.)\n\nRGB as numbers may be legal CSS, but at least some color implementations (Android, Winforms) are going to have a problem with that, as they expect integers in the 0-255 range. Using floats will also complicate rendering colors as `#RRGGBB` sequences - I think I'd be comfortable with the loss of fidelity of continuing to store colors as 0-255 integers.\nWhat about hue? The current tests show some ambiguity \u2014 for instance, it expects the `__repr__` of `hsl(10, 0.2, 0.3, 0.5)` to read `10`, not `10.0`; but the HSL / RGB conversion tests use floating-point values for it (and for exactly *one* of them, it makes a big enough difference to fail the comparison as written).\nGiven that hue is an angle (expressed in degrees if there's no explicit unit), I think it makes sense to be a float. There's no simple `#` expression analog for HSL colors, so the fact that the `repr` comes out as `hsl(10.0, 0.2, 0.3, 0.5)` seems fine to me.\n\nAs for the test failure - is that failure caused by the RGB integer simplification? If that's the case, maybe retaining float as an internal RGB representation, but externally rounding to int for external representations that require it might be the way to go...\nSummarized from a discussion with @freakboy3742 on Discord: Storing red/green/blue and/or hue as floats is theoretically more precise, and they could still be displayed as integers for `__repr__` and/or output to CSS. However:\n- The extra precision is unlikely to be beneficial in practice, at least not unless someone's performing a whole bunch of conversions in a row.\n- Floating-point math is slower.\n- Equivalence testing is also slower (and fuzzier) when determining if a property has changed or not.\n- Storing as floats but displaying as integers could cause some odd corner cases where two colors that display the same as integers could convert to colors in the opposite format that display *differently*.\n\nSo R/G/B/H will be stored as integers. And some quick testing indicates that `round` isn't meaningfully slower than `int`, so we'll use that for converting.\n\n", "all_hints_text": "> The first two are simply parsing glitches, but my preferred solution to the third case would be to make the actual constructors more versatile in what they accept. Why not convert percentages (and for that matter hex values) from strings, so that `rgba(\"FF\", \"FF\", \"FF\", \"100%\")` (or for that matter `rgba(\"FF\", \"FF\", \"FF\", \"FF\")` too) becomes equivalent to `rgba(255, 255, 255, 1.0) `?\n\nAlthough that introduces a different ambiguity. Does `color(\"rgb(10, 10, 10)\")` interpret those as base 10 or base 16... : /\nI think this syntax was based on CSS, so we should do whatever CSS does.\nMy two cents: ``rgb(\"FF\", \"FF\", \"00\")`` simply does nothing in CSS, and the correct way is ``#FFFF00`` (also works in lowercase). ``rgb()`` accepts integer values only from my testing in CSS.\nSo this is what I get for not doing research... I've specified plenty of colors in CSS with the various #FFF et al syntax, but had it in my head the hsl() and rgb() versions were just mimicking our own constructors.\n\nThere are still some bugs, but I'll look over the CSS standard before making any more recommendations for or against the intentional parts.\nWell, not research exactly, just testing in a browser, and my third cent is that don't feel bad about this, sometimes it's hard to remember all the guidelines (such as imitating CSS etc)...\nFrom reading the [docs](https://developer.mozilla.org/en-US/docs/Web/CSS/color) and playing around in Firefox, I've learned some things.\n\n- `rgb()` and `rgba()` are supposed to be identical (and accept optional alpha); same for `hsl()` and `hsla()`. The shorter forms are preferred, but the others are maintained as aliases.\n- The `red, green, blue[, alpha]` syntax is similarly supported for backwards compatibility, but the preferred modern syntax is `red green blue[ / alpha]`. And the equivalent for HSL.\n- Alpha values are treated as a percentage if they have a `%`; otherwise `1` is fully opaque. i.e. `50% == .5`\n- On the other hand, saturation and lightness are always interpreted as a percentage out of 100, whether a `%` is present or not.\n- Hue can optionally include `deg` after the number.\n- Hues below `0` and above `360` are accepted, and wrap around. i.e. `100 == 460 == -260`\n\nObviously the string-parsing function should match CSS as closely as possible; how exactly the individual classes and their constructors can best align with that, whether and how much they'd need to change, and if so how best to maintain backwards compatibility, may require some thought.\n\nI'm not sure if @anaelisaramos still had any plans for #3635. If not, I wouldn't mind giving this yak a trim.\nOne other note: in keeping with the general web browser tendency to try and make things work, Firefox, at least, seems perfectly happy to take values out of the allowable range for R, G, B, S, L, and A, simply clamping them to the minimum or maximum. (Hue, as I mentioned above, is a little different, since rather than clamping, it wraps around.)\n\nIt seems to me that it would make sense to follow suit, at least for the string-parsing. Should the explicit constructors too? Or should they maintain their current behavior of throwing an error when an input is out of range?\nTo clarify, when I said \"do whatever CSS does\", I was referring to the names of the functions and the interpretation of their arguments, but not necessarily the surface syntax. I don't think we want to support non-Pythonic syntax like separating arguments with spaces, passing floats as strings with percentage signs, or allowing a \"deg\" suffix.\n> To clarify, when I said \"do whatever CSS does\", I was referring to the names of the functions and the interpretation of their arguments, but not necessarily the surface syntax. I don't think we want to support non-Pythonic syntax like separating arguments with spaces, passing floats as strings with percentage signs, or allowing a \"deg\" suffix.\n\nEven in the string parser? I'm not talking about passing things to the constructors without commas, and despite my initial suggestion, I do agree those shouldn't try to parse string arguments (except perhaps as a side effect of `int(arg)` validation). We're already accepting `%` suffixes in the parser, I don't see how that's different than `deg`.\nOK, I wasn't aware of that parser, and the range of formats it accepts (#3568). I guess the `rgb` and `hsl` formats wrapped inside strings were intended to help with using Travertino to actually implement CSS. But unlike the font shorthand syntax, they aren't of any use in a Toga app, which should always use the `rgb` and `hsl` functions directly.\n\nSo I don't think it's worth the effort of extending them to match the current version of CSS. In fact, since they were never documented, I'd be inclined to deprecate them immediately and save the work of maintaining them. @freakboy3742: what do you think?\n> But unlike the font shorthand syntax, they aren't of any use in a Toga app, which should always use the `rgb` and `hsl` functions directly.\n\nOh, I didn't realize this wasn't intended usage. Guess that's one more reason documenting it is important! Does make sense, though.\n\nI'd argue that users might still find it convenient for us to support the `#rrggbb` string syntax as a shorthand, though.\nYes, definitely, I've got no problem with the `#rrggbb` syntax.\nOkay, so entirely ditch parsing of `\"rgb(...)\"` / `\"hsl(...)\"` strings.\n\nOutside of string-parsing, in order to make things more consistent with how CSS constructs colors, we could:\n- Rename the `rgba` class to `rgb`, make the alpha argument optional, and assign `rgba` as a direct alias. Do the same for `hsl` and `hsla`.\n- When given values outside their acceptable range, clip them to the max/min (or in case of hue, modulo by 360) rather than throwing an error.\n- It *would* be more consistent with CSS to accept (and store?) saturation and brightness as integers from 0 to 100 rather than floats from 0 to 1. But that feels out of place to me in Python, and there'd be no way to handle backwards compatibility without some ambiguity.\n> So I don't think it's worth the effort of extending them to match the current version of CSS. In fact, since they were never documented, I'd be inclined to deprecate them immediately and save the work of maintaining them. [@freakboy3742](https://github.com/freakboy3742): what do you think?\n\nYeah - I think I agree. In the fullness of time (assuming Colosseum ever gains momentum), we'll need some sort of \"fully compliant\" parser; but in the interim, it seems better to lean on `rgb()`/`hsl()` as functions, rather than string-parsed representations.\n\n \n> Outside of string-parsing, in order to make things more consistent with how CSS constructs colors, we could:\n> \n> * Rename the `rgba` class to `rgb`, make the alpha argument optional, and assign `rgba` as a direct alias. Do the same for `hsl` and `hsla`.\n\nThat makes sense to me. I wasn't aware `rgba` was no more than an alias for `rgb`.\n\n> * When given values outside their acceptable range, clip them to the max/min (or in case of hue, modulo by 360) rather than throwing an error.\n\nIf that's what CSS does, then yes - we should do the same.\n\n> * It _would_ be more consistent with CSS to accept (and store?) saturation and brightness as integers from 0 to 100 rather than floats from 0 to 1. But that feels out of place to me in Python, and there'd be no way to handle backwards compatibility without some ambiguity.\n\nWhat are you basing the \"integer would be more consistent\" statement upon? My read is that the S and L channels in the `hsl()` spec are defined as `<percentage>`, which is a `<number>` followed by %; and `<number>` can contain a decimal (as opposed to `<integer>`).\n\n> What are you basing the \"integer would be more consistent\" statement upon? My read is that the S and L channels in the `hsl()` spec are defined as `<percentage>`, which is a `<number>` followed by %; and `<number>` can contain a decimal (as opposed to `<integer>`).\n\nOkay, forget the integer part \u2014 but a number from 0\u2013100 rather than 0\u20131. In CSS, for *alpha*, if you specify a number with a percent sign, it's treated as a percentage (0\u2013100), while if you leave it off, it's interpreted as (and clipped to) 0\u20131. So `50%` is half opaque, but `50` is fully opaque (because it's >= 1).\n\nHowever, saturation and lightness, at least in my testing on Firefox, seem to always be interpreted as percentages, even with no percent sign. So `hsl(..., 1, 1)` looks to CSS like nearly black (saturation and lightness at 1%), while Travertino interprets it as fully white (saturation and lightness at 100%).\n\nHere's what `hsl(120, 1, 1)` looks like in Toga Cocoa:\n\n<img width=\"254\" height=\"79\" alt=\"White text\" src=\"https://github.com/user-attachments/assets/1a3671e7-2f80-4eb0-97ad-802207b5ea76\" />\n\nAnd here's what it looks like when run on web (since the HSL value is output to CSS as-is):\n\n<img width=\"251\" height=\"71\" alt=\"Black text\" src=\"https://github.com/user-attachments/assets/2a8f9db2-2275-41d0-963e-c387d2272210\" />\n\nOne other issue: currently, validation is performed on the arguments when a new RGB or HSL color is created... but there's nothing to prevent them being subsequently set to impossible values. It would probably be a good idea to either:\n\n- Make the attributes read-only properties\n- Take the validation out of `__init__` and put it in simple self-validating descriptors\n\nI'm not sure how useful editable colors are, but I'm also not sure there's a good reason they *need* to be read-only. (Although if they were, then the conversion properties \u2014 `rgb.hsl` and `hsl.rgb` \u2014 could be cached.)\n> Okay, forget the integer part \u2014 but a number from 0\u2013100 rather than 0\u20131. In CSS, for _alpha_, if you specify a number with a percent sign, it's treated as a percentage (0\u2013100), while if you leave it off, it's interpreted as (and clipped to) 0\u20131. So `50%` is half opaque, but `50` is fully opaque (because it's >= 1).\n\nIt looks to me like that might be a quirk of Firefox, rather than something standardized. Safari and Chrome both reject and ignore `hsl(120, 1, 1)` as an invalid CSS color definition. You have to specify `hsl(120, 1%, 1%)` for it to be parsed (and, for the record, `hsl(120, 0.01, 0.01)` is also rejected).\n\n> I'm not sure how useful editable colors are, but I'm also not sure there's a good reason they _need_ to be read-only. (Although if they were, then the conversion properties \u2014 `rgb.hsl` and `hsl.rgb` \u2014 could be cached.)\n\nThe only way I can think that it *might* be useful is in a true MVC-style app, where you define a \"color\" property, connect one channel of the color to a slider, and the slider as the background of a piece of text. Move the slider, the \"data\" changes, and so does the color - without needing to set up an explicit \"on change modify color\" handler.\n\nHowever, to make that work, you'd need to have the cooperation of everything *using* the color - so for the short term at least, I'd be happy to make the channels on a color read only.\n> It looks to me like that might be a quirk of Firefox, rather than something standardized. Safari and Chrome both reject and ignore `hsl(120, 1, 1)` as an invalid CSS color definition. You have to specify `hsl(120, 1%, 1%)` for it to be parsed (and, for the record, `hsl(120, 0.01, 0.01)` is also rejected).\n\nAha, that's what I get for ever guessing something would be consistent across browsers.\n\nI think this means two things:\n- We should keep storing saturation and lightness in the [0\u20131] range.\n- We need to divorce the colors' CSS representation from their Python code. I recommend we keep `__repr__` as copy-pasteable Python, and make `__str__` valid CSS.\n\n> [...] so for the short term at least, I'd be happy to make the channels on a color read only.\n\n\ud83d\udc4d \n\nWith that all more or less settled, and having not heard from Ana, I'll get cooking on this.\n> I think this means two things:\n> \n> * We should keep storing saturation and lightness in the [0\u20131] range.\n> * We need to divorce the colors' CSS representation from their Python code. I recommend we keep `__repr__` as copy-pasteable Python, and make `__str__` valid CSS.\n\n+1 - these both seem like good outcomes.\n \n(also - it looks like GitHub agrees about `hsl()` interpretations. Valid hsl gets a color preview:\n\n<img width=\"177\" height=\"49\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/55f58048-4327-4e79-abb4-f655224bd765\" />\n\ninvalid hsl does not:\n\n<img width=\"261\" height=\"58\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/cbf1a6ef-a967-43d7-aed6-ef993362ed66\" />\n\n)\nOne more thing I just noticed is that R, G, B, and H can all be numbers too, not just integers. Looks like it'll be floats all the way down.\n\n(R, G, B and be can even be percentages, but there's no way to make that unambiguous at the Python level.)\n> One more thing I just noticed is that R, G, B, and H can all be numbers too, not just integers. Looks like it'll be floats all the way down.\n> \n> (R, G, B and be can even be percentages, but there's no way to make that unambiguous at the Python level.)\n\nRGB as numbers may be legal CSS, but at least some color implementations (Android, Winforms) are going to have a problem with that, as they expect integers in the 0-255 range. Using floats will also complicate rendering colors as `#RRGGBB` sequences - I think I'd be comfortable with the loss of fidelity of continuing to store colors as 0-255 integers.\nWhat about hue? The current tests show some ambiguity \u2014 for instance, it expects the `__repr__` of `hsl(10, 0.2, 0.3, 0.5)` to read `10`, not `10.0`; but the HSL / RGB conversion tests use floating-point values for it (and for exactly *one* of them, it makes a big enough difference to fail the comparison as written).\nGiven that hue is an angle (expressed in degrees if there's no explicit unit), I think it makes sense to be a float. There's no simple `#` expression analog for HSL colors, so the fact that the `repr` comes out as `hsl(10.0, 0.2, 0.3, 0.5)` seems fine to me.\n\nAs for the test failure - is that failure caused by the RGB integer simplification? If that's the case, maybe retaining float as an internal RGB representation, but externally rounding to int for external representations that require it might be the way to go...\nSummarized from a discussion with @freakboy3742 on Discord: Storing red/green/blue and/or hue as floats is theoretically more precise, and they could still be displayed as integers for `__repr__` and/or output to CSS. However:\n- The extra precision is unlikely to be beneficial in practice, at least not unless someone's performing a whole bunch of conversions in a row.\n- Floating-point math is slower.\n- Equivalence testing is also slower (and fuzzier) when determining if a property has changed or not.\n- Storing as floats but displaying as integers could cause some odd corner cases where two colors that display the same as integers could convert to colors in the opposite format that display *differently*.\n\nSo R/G/B/H will be stored as integers. And some quick testing indicates that `round` isn't meaningfully slower than `int`, so we'll use that for converting.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/3abc61b8fd7a68068f04530924883055a6d8e8e7", "https://github.com/beeware/toga/commit/a040c3db4101e43581dd4484f0ab617ae2cb3490", "https://github.com/beeware/toga/commit/0be064eb2383eb688a1fba633d1cd8a556049fc1", "https://github.com/beeware/toga/commit/787e98a5cac6051d4346560154f5de636edd5d82", "https://github.com/beeware/toga/commit/7a96a6b9426b5836a14cfa516f606df883d554c1", "https://github.com/beeware/toga/commit/fa05e92214d610569739f2b358da8b506506783e", "https://github.com/beeware/toga/commit/00cd1cc8f0532c658d015ffdc2d7f84689c6e3d1", "https://github.com/beeware/toga/commit/b40afd3dcc6aad6514d5376fc96871c9ab6625c2"], "created_at": "2025-07-28T01:17:56Z"}
{"repo": "beeware/toga", "pull_number": 3684, "instance_id": "beeware__toga-3684", "issue_numbers": [3613], "base_commit": "9eb454ac18ae0662d66e7841717b0df7d34ee9a3", "patch": "diff --git a/changes/3613.feature.rst b/changes/3613.feature.rst\nnew file mode 100644\nindex 0000000000..04340030f7\n--- /dev/null\n+++ b/changes/3613.feature.rst\n@@ -0,0 +1,1 @@\n+The Table example app has been simplified and improved.\ndiff --git a/core/src/toga/sources/list_source.py b/core/src/toga/sources/list_source.py\nindex 263bec29ba..5431b528b8 100644\n--- a/core/src/toga/sources/list_source.py\n+++ b/core/src/toga/sources/list_source.py\n@@ -131,7 +131,7 @@ def __len__(self) -> int:\n         \"\"\"Returns the number of items in the list.\"\"\"\n         return len(self._data)\n \n-    def __getitem__(self, index: int) -> Row:\n+    def __getitem__(self, index: int | slice) -> Row:\n         \"\"\"Returns the item at position ``index`` of the list.\"\"\"\n         return self._data[index]\n \ndiff --git a/examples/table/table/app.py b/examples/table/table/app.py\nindex 052d7795bd..e028d1951c 100644\n--- a/examples/table/table/app.py\n+++ b/examples/table/table/app.py\n@@ -3,12 +3,8 @@\n import toga\n from toga.constants import COLUMN, ROW\n \n-headings = [\"Title\", \"Year\", \"Rating\", \"Genre\"]\n-\n \n class TableApp(toga.App):\n-    lbl_fontsize = None\n-\n     def load_data(self):\n         yak = toga.Icon.DEFAULT_ICON\n         red = toga.Icon(\"icons/red\")\n@@ -25,170 +21,151 @@ def load_data(self):\n             ((None, \"Bees in Paradise\"), 1944, (red, 5.4), None),  # None genre\n             ((yak, \"Keeper of the Bees\"), 1947, (red, 6.3), \"Drama\"),\n         ]\n+        self.initial_data = self.bee_movies * 10\n \n     # Table callback functions\n-    def on_select_handler1(self, widget, **kwargs):\n-        row = self.table1.selection\n-        self.label_table1.text = (\n-            f\"You selected row: {row.title[1]}\"\n-            if row is not None\n-            else \"No row selected\"\n-        )\n-\n-    def on_select_handler2(self, widget, **kwargs):\n-        if self.table2.selection is not None:\n-            self.label_table2.text = f\"Rows selected: {len(self.table2.selection)}\"\n+    def on_select_handler(self, widget, **kwargs):\n+        if selection := self.table.selection:\n+            number = len(selection)\n+            titles = \", \".join(row.title[1] for row in selection[:3])\n+            self.selection_label.text = (\n+                f\"Rows selected: {number} ({titles}{'...' if number > 3 else ''})\"\n+            )\n+            self.btn_delete.enabled = True\n+            self.btn_insert.text = \"Insert random row before selection\"\n         else:\n-            self.label_table2.text = \"No row selected\"\n+            self.selection_label.text = \"No rows selected\"\n+            self.btn_delete.enabled = False\n+            self.btn_insert.text = \"Insert random row at top\"\n \n-    async def on_activate1(self, widget, row, **kwargs):\n-        await self.main_window.dialog(\n-            toga.InfoDialog(\n-                title=\"movie selection\",\n-                message=self.build_activate_message(row=row, table_index=1),\n-            )\n+    async def on_activate(self, widget, row, **kwargs):\n+        adjective = random.choice(\n+            [\"magnificent\", \"amazing\", \"awesome\", \"life-changing\"]\n         )\n+        genre = (getattr(row, \"genre\", \"\") or \"no-genre\").lower()\n+        msg = f\"You selected the {adjective} {genre} movie {row.title[1]} ({row.year})\"\n \n-    async def on_activate2(self, widget, row, **kwargs):\n         await self.main_window.dialog(\n             toga.InfoDialog(\n                 title=\"movie selection\",\n-                message=self.build_activate_message(row=row, table_index=2),\n+                message=msg,\n             )\n         )\n \n     # Button callback functions\n     def insert_handler(self, widget, **kwargs):\n-        self.table1.data.insert(0, random.choice(self.bee_movies))\n+        if selection := self.table.selection:\n+            index = self.table.data.index(selection[0])\n+        else:\n+            index = 0\n+        self.table.data.insert(index, random.choice(self.bee_movies))\n \n     def delete_handler(self, widget, **kwargs):\n-        if self.table1.selection:\n-            self.table1.data.remove(self.table1.selection)\n-        elif len(self.table1.data) > 0:\n-            self.table1.data.remove(self.table1.data[0])\n-        else:\n-            print(\"Table is empty!\")\n+        for row in self.table.selection:\n+            self.table.data.remove(row)\n \n     def clear_handler(self, widget, **kwargs):\n-        self.table1.data.clear()\n+        self.table.data.clear()\n+        # Make sure any selection is cleared.\n+        self.on_select_handler(self.table)\n \n     def reset_handler(self, widget, **kwargs):\n-        self.table1.data = self.bee_movies\n+        self.table.data = self.initial_data\n+        # Make sure any selection is cleared.\n+        self.on_select_handler(self.table)\n \n     def toggle_handler(self, widget, **kwargs):\n         try:\n             # Try to delete the \"genre\" column by accessor.\n             # If the column doesn't exist, this will raise a ValueError,\n             # which means we need to add it.\n-            self.table1.remove_column(\"genre\")\n+            self.table.remove_column(\"genre\")\n+            self.btn_toggle.text = \"Restore genre column\"\n         except ValueError:\n             # Add the genre column. We provide the column *title*,\n             # which is automatically converted into the data accessor `genre`.\n             # If the data accessor can't be determined from the column title,\n             # you could manually specify the accessor here, too.\n-            self.table1.add_column(\"Genre\")\n+            self.table.append_column(\"Genre\")\n+            self.btn_toggle.text = \"Remove genre column\"\n \n     def top_handler(self, widget, **kwargs):\n-        self.table1.scroll_to_top()\n+        self.table.scroll_to_top()\n \n     def bottom_handler(self, widget, **kwargs):\n-        self.table1.scroll_to_bottom()\n+        self.table.scroll_to_bottom()\n \n     def startup(self):\n         self.main_window = toga.MainWindow()\n \n-        # Label to show which row is currently selected.\n-        self.label_table1 = toga.Label(\"Ready.\", flex=1, margin_right=5)\n-        self.label_table2 = toga.Label(\n-            \"Try multiple row selection.\", flex=1, margin_left=5\n-        )\n-        labelbox = toga.Box(\n-            children=[self.label_table1, self.label_table2],\n-            flex=0,\n-            margin_top=5,\n-        )\n-\n-        # Change font size\n-        lbl_fontlabel = toga.Label(\"Font size =\")\n-        self.lbl_fontsize = toga.Label(\"10\")\n-        btn_reduce_size = toga.Button(\" - \", on_press=self.reduce_fontsize, width=40)\n-        btn_increase_size = toga.Button(\n-            \" + \", on_press=self.increase_fontsize, width=40\n-        )\n-        font_box = toga.Box(\n-            children=[\n-                toga.Box(\n-                    children=[btn_reduce_size, btn_increase_size],\n-                    direction=ROW,\n-                ),\n-                toga.Box(\n-                    children=[lbl_fontlabel, self.lbl_fontsize],\n-                    direction=ROW,\n-                ),\n-            ],\n-            direction=COLUMN,\n+        # Label to show which rows are currently selected\n+        self.selection_label = toga.Label(\n+            \"Try multiple row selection.\", flex=0, margin=5\n         )\n \n-        # Data to populate the table.\n+        # The table and its data\n         self.load_data()\n-        if toga.platform.current_platform == \"android\":\n-            # FIXME: beeware/toga#1392 - Android Table doesn't allow lots of content\n-            table_data = self.bee_movies * 10\n-        else:\n-            table_data = self.bee_movies * 1000\n \n-        self.table1 = toga.Table(\n-            headings=headings,\n-            data=table_data,\n+        self.table = toga.Table(\n+            headings=[\"Title\", \"Year\", \"Rating\", \"Genre\"],\n+            data=self.initial_data,\n             flex=1,\n-            margin_right=5,\n-            font_family=\"monospace\",\n-            font_size=int(self.lbl_fontsize.text),\n-            font_style=\"italic\",\n-            multiple_select=False,\n-            on_select=self.on_select_handler1,\n-            on_activate=self.on_activate1,\n-            missing_value=\"Unknown\",\n-        )\n-\n-        self.table2 = toga.Table(\n-            headings=None,\n-            accessors=[h.lower() for h in headings],\n-            data=self.table1.data,\n+            margin=5,\n             multiple_select=True,\n-            flex=1,\n-            margin_left=5,\n-            on_select=self.on_select_handler2,\n-            on_activate=self.on_activate2,\n-            missing_value=\"?\",\n+            on_select=self.on_select_handler,\n+            on_activate=self.on_activate,\n+            missing_value=\"Unknown\",\n         )\n \n-        tablebox = toga.Box(children=[self.table1, self.table2], flex=1)\n-\n         # Buttons\n-        btn_insert = toga.Button(\"Insert\", on_press=self.insert_handler, flex=1)\n-        btn_delete = toga.Button(\"Delete\", on_press=self.delete_handler, flex=1)\n-        btn_clear = toga.Button(\"Clear\", on_press=self.clear_handler, flex=1)\n-        btn_reset = toga.Button(\"Reset\", on_press=self.reset_handler, flex=1)\n-        btn_toggle = toga.Button(\"Column\", on_press=self.toggle_handler, flex=1)\n-        btn_top = toga.Button(\"Top\", on_press=self.top_handler, flex=1)\n-        btn_bottom = toga.Button(\"Bottom\", on_press=self.bottom_handler, flex=1)\n+        btn_style = {\"flex\": 1, \"margin\": 3}\n+\n+        self.btn_insert = toga.Button(\n+            \"Insert random movie at top\", on_press=self.insert_handler, **btn_style\n+        )\n+        self.btn_delete = toga.Button(\n+            \"Delete selected row(s)\",\n+            on_press=self.delete_handler,\n+            enabled=False,\n+            **btn_style,\n+        )\n+        btn_clear = toga.Button(\n+            \"Clear table data\", on_press=self.clear_handler, **btn_style\n+        )\n+        btn_reset = toga.Button(\n+            \"Reset table data\", on_press=self.reset_handler, **btn_style\n+        )\n+        self.btn_toggle = toga.Button(\n+            \"Remove genre column\", on_press=self.toggle_handler, **btn_style\n+        )\n+        btn_top = toga.Button(\"Scroll to top\", on_press=self.top_handler, **btn_style)\n+        btn_bottom = toga.Button(\n+            \"Scroll to bottom\", on_press=self.bottom_handler, **btn_style\n+        )\n \n         controls_1 = toga.Box(\n-            children=[font_box, btn_insert, btn_delete, btn_clear],\n+            children=[self.btn_insert, self.btn_delete],\n             direction=ROW,\n-            margin_bottom=5,\n         )\n         controls_2 = toga.Box(\n-            children=[btn_reset, btn_toggle, btn_top, btn_bottom],\n+            children=[self.btn_toggle, btn_clear, btn_reset],\n+            direction=ROW,\n+        )\n+\n+        controls_3 = toga.Box(\n+            children=[btn_top, btn_bottom],\n             direction=ROW,\n-            margin_bottom=5,\n         )\n \n-        # Most outer box\n+        # Outermost box\n         outer_box = toga.Box(\n-            children=[controls_1, controls_2, tablebox, labelbox],\n-            flex=1,\n+            children=[\n+                controls_1,\n+                controls_2,\n+                controls_3,\n+                self.table,\n+                self.selection_label,\n+            ],\n             direction=COLUMN,\n             margin=10,\n         )\n@@ -199,29 +176,6 @@ def startup(self):\n         # Show the main window\n         self.main_window.show()\n \n-    def reduce_fontsize(self, widget):\n-        font_size = int(self.lbl_fontsize.text) - 1\n-        self.lbl_fontsize.text = str(font_size)\n-        font = toga.Font(family=\"monospace\", size=font_size, style=\"italic\")\n-        self.table1._impl.set_font(font)\n-\n-    def increase_fontsize(self, widget):\n-        font_size = int(self.lbl_fontsize.text) + 1\n-        self.lbl_fontsize.text = str(font_size)\n-        font = toga.Font(family=\"monospace\", size=font_size, style=\"italic\")\n-        self.table1._impl.set_font(font)\n-\n-    @classmethod\n-    def build_activate_message(cls, row, table_index):\n-        adjective = random.choice(\n-            [\"magnificent\", \"amazing\", \"awesome\", \"life-changing\"]\n-        )\n-        genre = (getattr(row, \"genre\", \"\") or \"no-genre\").lower()\n-        return (\n-            f\"You selected the {adjective} {genre} movie \"\n-            f\"{row.title[1]} ({row.year}) from Table {table_index}\"\n-        )\n-\n \n def main():\n     return TableApp(\"Table\", \"org.beeware.toga.examples.table\")\n", "test_patch": "", "problem_statement": "Table example app not applying font styling properly\n### Describe the bug\n\nThe table example sets the font to monospace italic on table 1, but the font style is not being applied. Further, the feature to increase and decrease font size is not applying either.\n\n### Steps to reproduce\n\n1. Run the `table/app.py` file.\n2. See the table on the left does not have either style applied.\n3. Click the `+` or `-` button, the font size does not change.\n\n### Expected behavior\n\nThe table on the left should be monospace, italic font, and the `+` and `-` buttons should increase and decrease the font.\n\n### Screenshots\n\n<img width=\"653\" height=\"492\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/925c0d29-79b3-4106-b29e-fdb25acadaa1\" />\n\n### Environment\n\n- Operating System: MacOS\n- Python version: 3.13\n- Software versions:\n  - Toga: 0.5.1\n\n\n### Logs\n\n```\n\n```\n\n\n### Additional context\n\n_No response_\n", "hints_text": "I'm also curious about the fact that the tables are initially styled the normal way, via Pack properties, but the functions that increase and decrease font size do so by setting the font directly on the implementation. \n\nhttps://github.com/beeware/toga/blob/5d09e19e77ec5e263f27ffe09e9b4ce3e5e41146/examples/table/table/app.py#L214-L224\n\nI see they were added in four years ago, in #1389. It's possible it's merely a historical artefact of the evolving style mechanism, or it may be necessary due to some quirk of tables... @t-arn , do you remember any of the context for that? I haven't messed any with the styling of tables, myself.\nI must have missed that in my code review...  That's definitely unintended usage - examples shouldn't be calling into `_impl`.\n\nHowever, fonts on tables also haven't been implemented everywhere - table styling is complicated because there's lots of different parts to be styled - see #1478 for one attempt at an API. \n\nSo - in this case, the buttons *should* be doing nothing on most platforms (everything *except* Android and Winforms). However, I'm unsure if the right response is:\n\n1. Modify the demo so that an error is printed if the platform doesn't support fonts on tables, or\n2. Remove the font-change aspect of the table demo\n\nIf (1), we should also be using the public API for font setting (i.e., setting style, not calling the `_impl`)\n> However, I'm unsure if the right response is:\n>    1. Modify the demo so that an error is printed if the platform doesn't support fonts on tables, or\n>    2. Remove the font-change aspect of the table demo\n\nI'd lean toward 2. It seems like more confusion than it's worth to have that in the example if it doesn't even work in most places.\n\n\n", "all_hints_text": "I'm also curious about the fact that the tables are initially styled the normal way, via Pack properties, but the functions that increase and decrease font size do so by setting the font directly on the implementation. \n\nhttps://github.com/beeware/toga/blob/5d09e19e77ec5e263f27ffe09e9b4ce3e5e41146/examples/table/table/app.py#L214-L224\n\nI see they were added in four years ago, in #1389. It's possible it's merely a historical artefact of the evolving style mechanism, or it may be necessary due to some quirk of tables... @t-arn , do you remember any of the context for that? I haven't messed any with the styling of tables, myself.\nI must have missed that in my code review...  That's definitely unintended usage - examples shouldn't be calling into `_impl`.\n\nHowever, fonts on tables also haven't been implemented everywhere - table styling is complicated because there's lots of different parts to be styled - see #1478 for one attempt at an API. \n\nSo - in this case, the buttons *should* be doing nothing on most platforms (everything *except* Android and Winforms). However, I'm unsure if the right response is:\n\n1. Modify the demo so that an error is printed if the platform doesn't support fonts on tables, or\n2. Remove the font-change aspect of the table demo\n\nIf (1), we should also be using the public API for font setting (i.e., setting style, not calling the `_impl`)\n> However, I'm unsure if the right response is:\n>    1. Modify the demo so that an error is printed if the platform doesn't support fonts on tables, or\n>    2. Remove the font-change aspect of the table demo\n\nI'd lean toward 2. It seems like more confusion than it's worth to have that in the example if it doesn't even work in most places.\n\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/6728e85172bec32656ac32b475d91b4668659c1f", "https://github.com/beeware/toga/commit/d8e00c50aebdc9056f99ed01d423c3a4b1b4629f"], "created_at": "2025-08-09T16:36:44Z"}
{"repo": "beeware/toga", "pull_number": 3642, "instance_id": "beeware__toga-3642", "issue_numbers": [3625], "base_commit": "1bf98307f5da7900607ff76ffbcb5a0ccc5edee1", "patch": "diff --git a/changes/3625.misc.rst b/changes/3625.misc.rst\nnew file mode 100644\nindex 0000000000..db2a361f04\n--- /dev/null\n+++ b/changes/3625.misc.rst\n@@ -0,0 +1,1 @@\n+Webview example fixed deprecation warning\ndiff --git a/examples/webview/webview/app.py b/examples/webview/webview/app.py\nindex 400cf4b265..a5c7064712 100644\n--- a/examples/webview/webview/app.py\n+++ b/examples/webview/webview/app.py\n@@ -12,10 +12,13 @@ def on_good_js(self, widget, **kwargs):\n             \"+ navigator.userAgent;\"\n         )\n \n-    def on_bad_js(self, widget, **kwargs):\n-        self.webview.evaluate_javascript(\"invalid js\", on_result=self.on_bad_js_result)\n-\n-    def on_bad_js_result(self, result, *, exception=None):\n+    async def on_bad_js(self, widget, **kwargs):\n+        try:\n+            result = await self.webview.evaluate_javascript(\"invalid js\")\n+            exception = None\n+        except Exception as exc:\n+            result = None\n+            exception = exc\n         self.label.text = f\"{result=!r}, {exception=!r}\"\n \n     def on_webview_load(self, widget, **kwargs):\n", "test_patch": "", "problem_statement": "Webview using deprecated `on_result`\n### Describe the bug\n\nWhen running the Webview example, when clicking on one of the `js` buttons, the following deprecation warning is thrown:\n```\nwebview.py:193: DeprecationWarning: Synchronous `on_result` handlers have been deprecated; use `await` on the asynchronous result\n  result = JavaScriptResult(on_result=on_result)\n```\n\n### Steps to reproduce\n\n1. Run the webview example code.\n2. Click on \"good js\" or \"bad js\". \n3. Check console output.\n\n### Expected behavior\n\nPresumably that the error is not present.\n\n### Screenshots\n\n_No response_\n\n### Environment\n\n- Operating System: macOS 15.5\n- Python version: 3.13\n- Software versions:\n  - Toga: 0.5.2.dev139+gef79e0427.d20250705\n\n\n### Logs\n\n```\n\n```\n\n\n### Additional context\n\n_No response_\n", "hints_text": "Good catch.\n\nThe fix here is convert the synchronous `on_bad_js` handler into an asynchronous handler. As the error message suggests - make `on_bad_js` an `async def` method, and instead of passing in an `on_result` completion handler, remove the `on_result` argument, `await` the call to `evaluate_javascript`, and make the contents of the previous `on_result` handler the commands that are invoked *after* the `await` call. \n\nThere's likely some other tweaks and cleanups that will be needed, but they should become apparent once that conversion has been done.\nI will work on this, europython 2025\n\n", "all_hints_text": "Good catch.\n\nThe fix here is convert the synchronous `on_bad_js` handler into an asynchronous handler. As the error message suggests - make `on_bad_js` an `async def` method, and instead of passing in an `on_result` completion handler, remove the `on_result` argument, `await` the call to `evaluate_javascript`, and make the contents of the previous `on_result` handler the commands that are invoked *after* the `await` call. \n\nThere's likely some other tweaks and cleanups that will be needed, but they should become apparent once that conversion has been done.\nI will work on this, europython 2025\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/922ef54bfbf90e245e39ad13a6b8ad93f8c91524", "https://github.com/beeware/toga/commit/134357f66f81d561c1a7105733c7ea164ca77c0c", "https://github.com/beeware/toga/commit/3a3f7df62c3ea4dab233d2131e0c16c00ca49e76"], "created_at": "2025-07-19T11:17:20Z"}
{"repo": "beeware/toga", "pull_number": 3646, "instance_id": "beeware__toga-3646", "issue_numbers": [3632], "base_commit": "92efc2c0cf1f423096336cc2ab47ffe56a375fb1", "patch": "diff --git a/android/src/toga_android/factory.py b/android/src/toga_android/factory.py\nindex fb9e496576..ac2b2e218f 100644\n--- a/android/src/toga_android/factory.py\n+++ b/android/src/toga_android/factory.py\n@@ -88,5 +88,5 @@ def not_implemented(feature):\n ]\n \n \n-def __getattr__(name):  # pragma: no cover\n+def __getattr__(name):\n     raise NotImplementedError(f\"Toga's Android backend doesn't implement {name}\")\ndiff --git a/changes/3632.misc.rst b/changes/3632.misc.rst\nnew file mode 100644\nindex 0000000000..889b37d5f4\n--- /dev/null\n+++ b/changes/3632.misc.rst\n@@ -0,0 +1,1 @@\n+Tests for handling of unsupported widgets, if needed.\ndiff --git a/cocoa/src/toga_cocoa/factory.py b/cocoa/src/toga_cocoa/factory.py\nindex c1549d03f7..a28ec9f846 100644\n--- a/cocoa/src/toga_cocoa/factory.py\n+++ b/cocoa/src/toga_cocoa/factory.py\n@@ -93,5 +93,5 @@ def not_implemented(feature):\n ]\n \n \n-def __getattr__(name):  # pragma: no cover\n+def __getattr__(name):\n     raise NotImplementedError(f\"Toga's Cocoa backend doesn't implement {name}\")\ndiff --git a/dummy/src/toga_dummy/factory.py b/dummy/src/toga_dummy/factory.py\nindex 3747eeacda..6feff3f1d5 100644\n--- a/dummy/src/toga_dummy/factory.py\n+++ b/dummy/src/toga_dummy/factory.py\n@@ -95,5 +95,5 @@ def not_implemented(feature):\n ]\n \n \n-def __getattr__(name):  # pragma: no cover\n+def __getattr__(name):\n     raise NotImplementedError(f\"Toga's Dummy backend doesn't implement {name}\")\ndiff --git a/gtk/src/toga_gtk/factory.py b/gtk/src/toga_gtk/factory.py\nindex 298b09ce13..c5a537a733 100644\n--- a/gtk/src/toga_gtk/factory.py\n+++ b/gtk/src/toga_gtk/factory.py\n@@ -85,5 +85,5 @@ def not_implemented(feature):\n ]\n \n \n-def __getattr__(name):  # pragma: no cover\n+def __getattr__(name):\n     raise NotImplementedError(f\"Toga's GTK backend doesn't implement {name}\")\ndiff --git a/iOS/src/toga_iOS/factory.py b/iOS/src/toga_iOS/factory.py\nindex 654ed498bd..88fc0c0685 100644\n--- a/iOS/src/toga_iOS/factory.py\n+++ b/iOS/src/toga_iOS/factory.py\n@@ -98,5 +98,5 @@ def not_implemented(feature):\n ]\n \n \n-def __getattr__(name):  # pragma: no cover\n+def __getattr__(name):\n     raise NotImplementedError(f\"Toga's iOS backend doesn't implement {name}\")\ndiff --git a/textual/src/toga_textual/factory.py b/textual/src/toga_textual/factory.py\nindex d41f6da7fa..687a57151d 100644\n--- a/textual/src/toga_textual/factory.py\n+++ b/textual/src/toga_textual/factory.py\n@@ -89,5 +89,5 @@ def not_implemented(feature):\n ]\n \n \n-def __getattr__(name):  # pragma: no cover\n+def __getattr__(name):\n     raise NotImplementedError(f\"Toga's Textual backend doesn't implement {name}\")\ndiff --git a/web/src/toga_web/factory.py b/web/src/toga_web/factory.py\nindex 1b683b5269..17b0d1fab1 100644\n--- a/web/src/toga_web/factory.py\n+++ b/web/src/toga_web/factory.py\n@@ -90,5 +90,5 @@ def not_implemented(feature):\n ]\n \n \n-def __getattr__(name):  # pragma: no cover\n+def __getattr__(name):\n     raise NotImplementedError(f\"Toga's Web backend doesn't implement {name}\")\ndiff --git a/winforms/src/toga_winforms/factory.py b/winforms/src/toga_winforms/factory.py\nindex 0744dd008c..f8ca3bef61 100644\n--- a/winforms/src/toga_winforms/factory.py\n+++ b/winforms/src/toga_winforms/factory.py\n@@ -84,5 +84,5 @@ def not_implemented(feature):\n ]\n \n \n-def __getattr__(name):  # pragma: no cover\n+def __getattr__(name):\n     raise NotImplementedError(f\"Toga's Winforms backend doesn't implement {name}\")\n", "test_patch": "diff --git a/core/tests/app/test_app.py b/core/tests/app/test_app.py\nindex 5d64d791bf..42bf7bbad0 100644\n--- a/core/tests/app/test_app.py\n+++ b/core/tests/app/test_app.py\n@@ -33,6 +33,13 @@\n }\n \n \n+async def test_unsupported_widget(app):\n+    \"\"\"If a widget isn't implemented, the factory raises NotImplementedError.\"\"\"\n+    with pytest.raises(NotImplementedError) as exc:\n+        _ = app.factory.NoSuchWidget\n+    assert \"Toga's Dummy backend doesn't implement NoSuchWidget\" in str(exc)\n+\n+\n @pytest.mark.parametrize(\n     (\n         \"kwargs, metadata, main_module, expected_formal_name, expected_app_id, \"\ndiff --git a/testbed/tests/app/test_app.py b/testbed/tests/app/test_app.py\nindex 301affb568..feeb88b187 100644\n--- a/testbed/tests/app/test_app.py\n+++ b/testbed/tests/app/test_app.py\n@@ -1,9 +1,18 @@\n from types import NoneType\n from unittest.mock import Mock\n \n+import pytest\n+\n import toga\n \n \n+async def test_unsupported_widget(app):\n+    \"\"\"If a widget isn't implemented, the factory raises NotImplementedError.\"\"\"\n+    with pytest.raises(NotImplementedError) as exc:\n+        _ = app.factory.NoSuchWidget\n+    assert \"backend doesn't implement NoSuchWidget\" in str(exc)\n+\n+\n async def test_main_window_toolbar(app, main_window, main_window_probe):\n     \"\"\"A toolbar can be added to a main window\"\"\"\n     # Add some items to show the toolbar\n", "problem_statement": "Add tests for non-existent widget support.\n### What is the problem or limitation you are having?\n\nAt present, the `factory` modules for each backend has a `__getattr__()` method to provide better feedback when a backend doesn't support a given widget.\n\nHowever, this functionality is marked `#pragma: no cover` on every backend. As a result, it's not being tested.\n\n### Describe the solution you'd like\n\nWe should add tests of \"missing widget\" functionality.\n\nThis will require 2 tests:\n* a test in `core`, validating that the dummy backend's `__getattr__` method works\n* a test in `testbed`, validating that each of the \"live\" backends have a working `__getattr__` implementation.\n\nThe test will need to use the factory directly - you won't be able to request a *specific* widget, because Dummy and Cocoa both implement *all* widgets. You'll need to call something like `impl = app.factory.NonExistentWidget()` to exercise the `__getattr__` handler.\n\n### Describe alternatives you've considered\n\nLeave as is. It's a moderately obvious implementation, so we're not at a *huge* risk here.\n\n### Additional context\n\nSuggested approach for implementation:\n\n* Remove the `#pragma` from all the `__getattr__` implementations (dummy, android, cocoa, iOS, gtk, winforms, textual, web, winforms). \n* Run `tox -m test-core` to verify that there is now a coverage gap in dummy. \n* (optional) submitting a draft pull request so you can verify that a coverage gap exists on *all* platforms and backends\n* Add a test to `core` to provide coverage for dummy.\n* Run the testbed to verify that there is now a coverage gap on your current desktop platform\n* Add a test to `testbed` to provide coverage for backends.\n* Move the PR to \"ready for review\".\n\n", "hints_text": "I will take a look. Europython 2025.\n\n", "all_hints_text": "I will take a look. Europython 2025.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/2695bb60208ca2eb4afae742ea1def9421595e58", "https://github.com/beeware/toga/commit/50abc61ec8a73d6f59b534f4317f55123573092d", "https://github.com/beeware/toga/commit/f90e22931b3597026b5722909b22682dd9b81083", "https://github.com/beeware/toga/commit/206a09042aa4a5fae4ac15c7f693ba2fd4fe5d2d"], "created_at": "2025-07-20T08:37:53Z"}
{"repo": "beeware/toga", "pull_number": 3667, "instance_id": "beeware__toga-3667", "issue_numbers": [3658], "base_commit": "73450c88cf13549b1ca65764941235eea03c88e3", "patch": "diff --git a/changes/3658.bugfix.rst b/changes/3658.bugfix.rst\nnew file mode 100644\nindex 0000000000..5d4c5f8b80\n--- /dev/null\n+++ b/changes/3658.bugfix.rst\n@@ -0,0 +1,1 @@\n+On GTK, the scroll position will now be correctly reflected if a MultilineTextInput is programmatically scrolled immediately after changing text content.\ndiff --git a/gtk/src/toga_gtk/widgets/base.py b/gtk/src/toga_gtk/widgets/base.py\nindex f88e25e3bb..158f360595 100644\n--- a/gtk/src/toga_gtk/widgets/base.py\n+++ b/gtk/src/toga_gtk/widgets/base.py\n@@ -4,6 +4,7 @@\n \n from ..libs import (\n     GTK_VERSION,\n+    GLib,\n     Gtk,\n     get_background_color_css,\n     get_color_css,\n@@ -221,3 +222,11 @@ def rehint(self):\n             # print(\"REHINT\", self, f\"{width_info[0]}x{height_info[0]}\")\n             self.interface.intrinsic.width = at_least(min_size.width)\n             self.interface.intrinsic.height = at_least(min_size.height)\n+\n+    def flush_gtk_events(self):\n+        if GTK_VERSION < (4, 0, 0):  # pragma: no-cover-if-gtk4\n+            while Gtk.events_pending():\n+                Gtk.main_iteration_do(blocking=False)\n+        else:  # pragma: no-cover-if-gtk3\n+            while GLib.main_context_default().pending():\n+                GLib.main_context_default().iteration(may_block=False)\ndiff --git a/gtk/src/toga_gtk/widgets/multilinetextinput.py b/gtk/src/toga_gtk/widgets/multilinetextinput.py\nindex ddae89858f..8ed39b8693 100644\n--- a/gtk/src/toga_gtk/widgets/multilinetextinput.py\n+++ b/gtk/src/toga_gtk/widgets/multilinetextinput.py\n@@ -91,6 +91,9 @@ def set_value(self, value):\n             else:\n                 self.native_textview.set_buffer(self.buffer)\n \n+        # Wait until the text change is fully completed\n+        self.flush_gtk_events()\n+\n     def get_readonly(self):\n         return not self.native_textview.get_property(\"editable\")\n \n", "test_patch": "diff --git a/testbed/tests/widgets/test_multilinetextinput.py b/testbed/tests/widgets/test_multilinetextinput.py\nindex 32534444c3..0207d9390e 100644\n--- a/testbed/tests/widgets/test_multilinetextinput.py\n+++ b/testbed/tests/widgets/test_multilinetextinput.py\n@@ -99,3 +99,22 @@ async def test_scroll_position(widget, probe):\n     # The scroll position back at the origin.\n     # Due to scroll bounce etc, this might be slightly off 0\n     assert probe.vertical_scroll_position == pytest.approx(0.0, abs=10)\n+\n+\n+async def test_scroll_after_text_change(widget, probe):\n+    \"Scrolling works after the text has been modified.\"\n+    # The scroll position is at the origin.\n+    assert probe.vertical_scroll_position == pytest.approx(0, abs=1)\n+\n+    # Run a lot of text modifications followed by a scroll\n+    for i in range(50):\n+        widget.value += f\"Line {i}\\n\"\n+        widget.scroll_to_bottom()\n+\n+    await probe.wait_for_scroll_completion()\n+    await probe.redraw(\n+        \"The document has been modified a lot and scrolled to the bottom\"\n+    )\n+\n+    scroll_offset = probe.document_height - probe.height\n+    assert probe.vertical_scroll_position == pytest.approx(scroll_offset, abs=30)\n", "problem_statement": "MultilineTextInput scroll_to_bottom() is unreliable with Gtk\n### Describe the bug\n\nToga Version: 0.5.2\ngtk3 3.24.49\ngtk4 4.18.6\n\nI'm make an application with a background working thread, a multiline text box is used as logger, UI status is updated in main thread with `call_soon_threadsafe`. \n\nOn Windows it works pretty well but on Linux the the scrolling is pretty random, usually it stops in the middle or even display a white screen.\n\nOr maybe it's because on Gtk every time the textbox is edited it returns to the original position, scrolling up and down is conflicted.\n\n\nWindows capture:\n\nhttps://github.com/user-attachments/assets/838cd88a-85be-412a-8fe3-8317b84d7c1f\n\nLinux capture:\n\nhttps://github.com/user-attachments/assets/c83bf7f1-0658-4e45-9f99-1843f0041843\n\n### Steps to reproduce\n\nRun this demo code on Linux\n```python\nimport time\nimport toga\nfrom toga.constants import COLUMN, ROW\nfrom toga.style.pack import Pack\n\nclass Demo(toga.App):\n    def __init__(self, *args, **kwargs):\n        super().__init__(*args, **kwargs)\n        self.txt_log: toga.MultilineTextInput\n        self.btn: toga.Button\n        self.main_window: toga.Window\n\n    def startup(self):\n        self.main_window = toga.Window(title=\"demo\")\n        self.txt_log  = toga.MultilineTextInput(\n            style=Pack(flex=1, margin=10, font_size=14, color='black'),\n            placeholder='Log messages will appear here...'\n        )\n\n        self.btn = toga.Button(\n            'Click Me',\n            on_press=self.on_button_press,\n            style=Pack(margin=10, font_size=16)\n        )\n\n        box = toga.Box(\n            children=[\n                self.txt_log,\n                self.btn\n            ],\n            flex=1,\n            direction=COLUMN,\n        )\n\n        self.main_window.content = box\n        self.main_window.show()\n\n    def on_button_press(self, widget):\n        self.txt_log.value = \"Button clicked!\\n\"\n        self.txt_log.refresh()\n        self.btn.enabled = False\n        self.loop.run_in_executor(None, self.background_task)\n        self.btn.enabled = True\n\n    def background_task(self):\n        for i in range(50):\n            self.log_threadsafe(f\"Background task iteration {i + 1}\")\n\n    def log(self, message: str):\n        \"\"\"Append a message to the log text input.\"\"\"\n        self.txt_log.value += message + \"\\n\"\n        self.txt_log.refresh()\n        self.txt_log.scroll_to_bottom()\n\n    def log_threadsafe(self, message: str):\n        \"\"\"Thread-safe logging method.\"\"\"\n        self.loop.call_soon_threadsafe(self.log, message)\n\ndef main():\n    return Demo(\"Background Task Demo\", \"org.examples.updateui\")\n\n\nif __name__ == \"__main__\":\n    main().main_loop()\n\n```\n\n\n### Expected behavior\n\nScrolling with Gtk is the same as on Windows\n\n", "hints_text": "Thanks for the report. \n\nFirstly, a small note about the example code you've provided: As an end user, you should not *ever* need to call `refresh()` on a widget. `refresh()` is effectively an internal method; if you've found an example where it *is* required, that likely indicates a bug in Toga.\n\nRegardless, I was able to reproduce the problem you describe. \n\nI was also able to work around the issue (and simplify your example) by making the handlers asynchronous, and inserting a short (async) sleep between writing the message and scrolling:\n```\n    async def on_button_press(self, widget):\n        self.txt_log.value = \"Button clicked!\\n\"\n        self.btn.enabled = False\n        for i in range(50):\n            await self.log(f\"Background task iteration {i + 1}\")\n        self.btn.enabled = True\n\n    async def log(self, message: str):\n        \"\"\"Append a message to the log text input.\"\"\"\n        self.txt_log.value += message + \"\\n\"\n        await asyncio.sleep(0.01)\n        self.txt_log.scroll_to_bottom()\n```\n\nIf you reduce the sleep, at some point it fails as it did before (0.001 failed for me). This suggests that the issue is in the general area you suggest - that the text isn't fully updated at the end of the `value += ...` call, and thus conflicts with the request to scroll to bottom. \n\nThis may be because the GTK MultilineTextInput is implemented as a \"view on a buffer\". When you change the text in a MultilineTextView, you're setting the text on the buffer, and it may take some redraw cycles before that change is fully reflected in the GUI.\n\nSo - a possible fix is to make sure that the `value += ` call has \"fully completed\" before it returns. One way to do this is to modify the `set_value()` method on the GTK backend to flush GTK events at the completion of the method:\n```\n        while Gtk.events_pending():\n            Gtk.main_iteration_do(blocking=False)\n```\n\nThat flush implementation is GTK3-specific (there's a slightly different set of calls needed on GTK4; see the GTK test probe for details). It may be worth adding a `flush_gtk_events()` method as a base GTK widget capability so that other widgets can  implement a similar flush (as this is unlikely to be a problem specific to MultilineTextView).\n\nWith that change in place, I was able to remove the async sleep from my simplified example, and run your original example. In both cases, the scroll behaved as expected.\n\nIf you can confirm you're seeing the same, we can look into implementing this on the GTK backend.\nHi @freakboy3742,\n\nThank you for your thoughtful test.\n\n> So - a possible fix is to make sure that the value +=  call has \"fully completed\" before it returns. One way to do this is to modify the set_value() method on the GTK backend to flush GTK events at the completion of the method:\n>\n>        while Gtk.events_pending():\n>           Gtk.main_iteration_do(blocking=False)\n\nAdding this code to `set_value()`  indeed resolved the issue.\n\nI assume it would be more complex to resolve the issue by keeping the scrolling position (instead of reset to top) when the text buffer is updated ?\n\nWhen the UI refresh rate and text update rate are roughly the same the output is jumpy:\n```\nasync def on_button_press(self, widget):\n        self.txt_log.value = \"Button clicked!\\n\"\n        self.btn.enabled = False\n        for i in range(100):\n            await self.log(f\"Background task iteration {i + 1}\")\n            await asyncio.sleep(0.05)\n        self.btn.enabled = True\n```\n\nhttps://github.com/user-attachments/assets/21e14ff4-74c3-4443-8270-d4f02eec12ea\n> Adding this code to `set_value()` indeed resolved the issue.\n\nExcellent - would you care to convert that prototype fix into a full pull request?\n \n> I assume it would be more complex to resolve the issue by keeping the scrolling position (instead of reset to top) when the text buffer is updated ?\n\nI presume so, yes... but I have no idea how to make that actually happen. If you want to investigate this option, please do.\n\n", "all_hints_text": "Thanks for the report. \n\nFirstly, a small note about the example code you've provided: As an end user, you should not *ever* need to call `refresh()` on a widget. `refresh()` is effectively an internal method; if you've found an example where it *is* required, that likely indicates a bug in Toga.\n\nRegardless, I was able to reproduce the problem you describe. \n\nI was also able to work around the issue (and simplify your example) by making the handlers asynchronous, and inserting a short (async) sleep between writing the message and scrolling:\n```\n    async def on_button_press(self, widget):\n        self.txt_log.value = \"Button clicked!\\n\"\n        self.btn.enabled = False\n        for i in range(50):\n            await self.log(f\"Background task iteration {i + 1}\")\n        self.btn.enabled = True\n\n    async def log(self, message: str):\n        \"\"\"Append a message to the log text input.\"\"\"\n        self.txt_log.value += message + \"\\n\"\n        await asyncio.sleep(0.01)\n        self.txt_log.scroll_to_bottom()\n```\n\nIf you reduce the sleep, at some point it fails as it did before (0.001 failed for me). This suggests that the issue is in the general area you suggest - that the text isn't fully updated at the end of the `value += ...` call, and thus conflicts with the request to scroll to bottom. \n\nThis may be because the GTK MultilineTextInput is implemented as a \"view on a buffer\". When you change the text in a MultilineTextView, you're setting the text on the buffer, and it may take some redraw cycles before that change is fully reflected in the GUI.\n\nSo - a possible fix is to make sure that the `value += ` call has \"fully completed\" before it returns. One way to do this is to modify the `set_value()` method on the GTK backend to flush GTK events at the completion of the method:\n```\n        while Gtk.events_pending():\n            Gtk.main_iteration_do(blocking=False)\n```\n\nThat flush implementation is GTK3-specific (there's a slightly different set of calls needed on GTK4; see the GTK test probe for details). It may be worth adding a `flush_gtk_events()` method as a base GTK widget capability so that other widgets can  implement a similar flush (as this is unlikely to be a problem specific to MultilineTextView).\n\nWith that change in place, I was able to remove the async sleep from my simplified example, and run your original example. In both cases, the scroll behaved as expected.\n\nIf you can confirm you're seeing the same, we can look into implementing this on the GTK backend.\nHi @freakboy3742,\n\nThank you for your thoughtful test.\n\n> So - a possible fix is to make sure that the value +=  call has \"fully completed\" before it returns. One way to do this is to modify the set_value() method on the GTK backend to flush GTK events at the completion of the method:\n>\n>        while Gtk.events_pending():\n>           Gtk.main_iteration_do(blocking=False)\n\nAdding this code to `set_value()`  indeed resolved the issue.\n\nI assume it would be more complex to resolve the issue by keeping the scrolling position (instead of reset to top) when the text buffer is updated ?\n\nWhen the UI refresh rate and text update rate are roughly the same the output is jumpy:\n```\nasync def on_button_press(self, widget):\n        self.txt_log.value = \"Button clicked!\\n\"\n        self.btn.enabled = False\n        for i in range(100):\n            await self.log(f\"Background task iteration {i + 1}\")\n            await asyncio.sleep(0.05)\n        self.btn.enabled = True\n```\n\nhttps://github.com/user-attachments/assets/21e14ff4-74c3-4443-8270-d4f02eec12ea\n> Adding this code to `set_value()` indeed resolved the issue.\n\nExcellent - would you care to convert that prototype fix into a full pull request?\n \n> I assume it would be more complex to resolve the issue by keeping the scrolling position (instead of reset to top) when the text buffer is updated ?\n\nI presume so, yes... but I have no idea how to make that actually happen. If you want to investigate this option, please do.\nI did some reading, it looks like scroll to 1st row happens because textview.set_buffer deletes the current contents of the buffer and then writes the new one, resulting scrolling mark get removed.\n\nTo resolve the jumpy effect maybe we need to add an insert method and call `do_insert_at_cursor`\nIt definitely makes sense that specific insertions at a cursor would minimise the \"jumping\" of the buffer; the catch is that the current API for TextView doesn't really give us the tools to utilise that. The current API is based on setting the entire content of the text view; while your specific use case is entirely 'append' based, there's no guarantee that the cursor is actually at the end of the current text. \n\nThe only way I can see that we'd be able to make use of that sort of API would be as part of a more broad \"cursor management\" API, allowing code to programmatically set the cursor position, and then insert content at the cursor. That would then allow your use case to be turned into an explicit \"add content to end of current content\", rather than replacing the entire content on every addition.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/b8f403e4b1dbc91e23264d4e6cefcbe96dd2b423", "https://github.com/beeware/toga/commit/f7ca844d089d29b9bf3e98977668ccd8451b0613", "https://github.com/beeware/toga/commit/0babff5323793edb334851137c492eec2b55173a", "https://github.com/beeware/toga/commit/cef90a3b30384c1cced3fe7a7d93d18abc1502be", "https://github.com/beeware/toga/commit/d8e9b54f0b94506a7a3be6d2808b6f64c712ee33", "https://github.com/beeware/toga/commit/dcfe262f4a07fdbd988139f530d91c48418c009b", "https://github.com/beeware/toga/commit/02c59d2fbe8733a7b46314fff2a3be1985d53165"], "created_at": "2025-07-28T09:43:49Z"}
{"repo": "beeware/toga", "pull_number": 3671, "instance_id": "beeware__toga-3671", "issue_numbers": [3661], "base_commit": "601a4e3258e845e53cd13ab841ba896a45095cd2", "patch": "diff --git a/changes/3661.bugfix.rst b/changes/3661.bugfix.rst\nnew file mode 100644\nindex 0000000000..dc2906d531\n--- /dev/null\n+++ b/changes/3661.bugfix.rst\n@@ -0,0 +1,1 @@\n+On GTK, mouse drag events are now triggered when modifier keys (e.g. Num Lock, Shift) are active.\ndiff --git a/gtk/src/toga_gtk/widgets/canvas.py b/gtk/src/toga_gtk/widgets/canvas.py\nindex e0cf90dab9..86d98e61df 100644\n--- a/gtk/src/toga_gtk/widgets/canvas.py\n+++ b/gtk/src/toga_gtk/widgets/canvas.py\n@@ -81,9 +81,11 @@ def mouse_down(self, obj, event):\n             pass\n \n     def mouse_move(self, obj, event):\n-        if event.state == Gdk.ModifierType.BUTTON1_MASK:\n+        \"\"\"Handles mouse movement by calling the drag and/or alternative drag\n+        methods. Modifier keys have no effect.\"\"\"\n+        if event.state & Gdk.ModifierType.BUTTON1_MASK:\n             self.interface.on_drag(event.x, event.y)\n-        if event.state == Gdk.ModifierType.BUTTON3_MASK:\n+        if event.state & Gdk.ModifierType.BUTTON3_MASK:\n             self.interface.on_alt_drag(event.x, event.y)\n \n     def mouse_up(self, obj, event):\n", "test_patch": "diff --git a/gtk/tests_backend/widgets/canvas.py b/gtk/tests_backend/widgets/canvas.py\nindex 31feff9232..1f00c91a6e 100644\n--- a/gtk/tests_backend/widgets/canvas.py\n+++ b/gtk/tests_backend/widgets/canvas.py\n@@ -75,7 +75,9 @@ async def mouse_drag(self, x1, y1, x2, y2):\n \n         event = Gdk.Event.new(Gdk.EventType.MOTION_NOTIFY)\n         event.button = 1\n-        event.state = Gdk.ModifierType.BUTTON1_MASK\n+        # Add an additional modifier to confirm that keyboard modifiers don't\n+        # impact event triggering\n+        event.state = Gdk.ModifierType.BUTTON1_MASK | Gdk.ModifierType.MOD2_MASK\n         event.x = (x1 + x2) // 2\n         event.y = (y1 + y2) // 2\n         self.native.emit(\"motion-notify-event\", event)\n@@ -107,7 +109,9 @@ async def alt_mouse_drag(self, x1, y1, x2, y2):\n         self.native.emit(\"button-press-event\", event)\n \n         event = Gdk.Event.new(Gdk.EventType.MOTION_NOTIFY)\n-        event.state = Gdk.ModifierType.BUTTON3_MASK\n+        # Add an additional modifier to confirm that keyboard modifiers don't\n+        # impact event triggering\n+        event.state = Gdk.ModifierType.BUTTON3_MASK | Gdk.ModifierType.MOD2_MASK\n         event.x = (x1 + x2) // 2\n         event.y = (y1 + y2) // 2\n         self.native.emit(\"motion-notify-event\", event)\n", "problem_statement": "on_drag event in Canvas not triggered when Num Lock is active (Ubuntu 24.04)\n### Describe the bug\n\nIn the example https://github.com/beeware/toga/blob/main/examples/canvas/canvas/app.py the, the on_drag event is never triggered if Num Lock is on. It seems to work normally when Num Lock is off.\n\n### Steps to reproduce\n\n1. Run the example https://github.com/beeware/toga/blob/main/examples/canvas/canvas/app.py with Num Lock off\n2. Try to drag the text\n3. Switch on Num Lock\n4. Try to drag the text\n\nTo make it easier, I slightly changed the code to print \"on_press\", \"on_release\", \"on_drag\" when entering in the corresponding methods. I also added a print of the Num Lock status within the on_press method. I attached the corresponding code here.\n\n[app.py.txt](https://github.com/user-attachments/files/21451333/app.py.txt)\n\n### Expected behavior\n\nIt will be impossible to drag the text when Num Lock is on, while Num Lock on/off should not affect the on_drag event.\n\n### Screenshots\n\n<img width=\"757\" height=\"868\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/c2e02a88-3d13-4a36-8544-20103133dad7\" />\n\n### Environment\n\n- Operating System: 24.04.2 LTS (Noble Numbat)\n- Python version: 3.12.3\n- Software versions:\n  - Briefcase: 0.3.24\n  - toga-core: 0.5.2\n  - toga-gtk: 0.5.2\n\n\n### Logs\n\n[briefcase.log](https://github.com/user-attachments/files/21451381/briefcase.log)\n\n\n\n### Additional context\n\n_No response_\n", "hints_text": "Thanks for the report.\n\nIt appears that this is being cause because numlock is being treated as a modifier key by GTK. The on-drag (and on-alt-drag) handlers in GTK's Canvas implementation are currently looking for unmodified drag events (i.e., `event.state == Gdk.ModifierType.BUTTON1_MASK`); if these are modified to look for a mask (i.e., `event.state | Gdk.ModifierType.BUTTON1_MASK), then the numlock won't alter detection of the mouse event.\n\nFor bonus points, the mouse press/move events could be extended to also include keyboard modifier - however, that would be a feature addition that would also need modifications on other platforms.\nHi, thank you for your quick answer.\n\nAre you willing to change the current implementation to fix this? Otherwise, the simpliest/temporary solution is probably to mention this somewhere in the documentation.\n\nHowever, I'm a little bit confused because I'm not familiar with this, and I'm not sure if I understand that correctlty:\nIf event.state and Gdk.ModifierType.BUTTON1_MASK are binary strings. Then, `event.state | Gdk.ModifierType.BUTTON1_MASK` will always be True, even when `event.state` has no bits set to 1? So, you would use `&` instead of `|`, to make the statement True only if `event.state == Gdk.ModifierType.BUTTON1_MASK | something_else` (where `something_else` is not the alt thing)? \n\n\n> Are you willing to change the current implementation to fix this? Otherwise, the simpliest/temporary solution is probably to mention this somewhere in the documentation.\n\nYes - this is clearly a bug, which is why I've invited you to submit a fix for the bug.\n\n> However, I'm a little bit confused because I'm not familiar with this, and I'm not sure if I understand that correctlty: If event.state and Gdk.ModifierType.BUTTON1_MASK are binary strings. Then, `event.state | Gdk.ModifierType.BUTTON1_MASK` will always be True, even when `event.state` has no bits set to 1? So, you would use `&` instead of `|`, to make the statement True only if `event.state == Gdk.ModifierType.BUTTON1_MASK | something_else` (where `something_else` is not the alt thing)?\n\nMy apologies - I shouldn't answer questions before my morning coffee has taken effect :-) You're completely correct - `&` is the operator needed here.\n\nOkay, I'll try to do a PR to fix that in the next few days.\n\n", "all_hints_text": "Thanks for the report.\n\nIt appears that this is being cause because numlock is being treated as a modifier key by GTK. The on-drag (and on-alt-drag) handlers in GTK's Canvas implementation are currently looking for unmodified drag events (i.e., `event.state == Gdk.ModifierType.BUTTON1_MASK`); if these are modified to look for a mask (i.e., `event.state | Gdk.ModifierType.BUTTON1_MASK), then the numlock won't alter detection of the mouse event.\n\nFor bonus points, the mouse press/move events could be extended to also include keyboard modifier - however, that would be a feature addition that would also need modifications on other platforms.\nHi, thank you for your quick answer.\n\nAre you willing to change the current implementation to fix this? Otherwise, the simpliest/temporary solution is probably to mention this somewhere in the documentation.\n\nHowever, I'm a little bit confused because I'm not familiar with this, and I'm not sure if I understand that correctlty:\nIf event.state and Gdk.ModifierType.BUTTON1_MASK are binary strings. Then, `event.state | Gdk.ModifierType.BUTTON1_MASK` will always be True, even when `event.state` has no bits set to 1? So, you would use `&` instead of `|`, to make the statement True only if `event.state == Gdk.ModifierType.BUTTON1_MASK | something_else` (where `something_else` is not the alt thing)? \n\n\n> Are you willing to change the current implementation to fix this? Otherwise, the simpliest/temporary solution is probably to mention this somewhere in the documentation.\n\nYes - this is clearly a bug, which is why I've invited you to submit a fix for the bug.\n\n> However, I'm a little bit confused because I'm not familiar with this, and I'm not sure if I understand that correctlty: If event.state and Gdk.ModifierType.BUTTON1_MASK are binary strings. Then, `event.state | Gdk.ModifierType.BUTTON1_MASK` will always be True, even when `event.state` has no bits set to 1? So, you would use `&` instead of `|`, to make the statement True only if `event.state == Gdk.ModifierType.BUTTON1_MASK | something_else` (where `something_else` is not the alt thing)?\n\nMy apologies - I shouldn't answer questions before my morning coffee has taken effect :-) You're completely correct - `&` is the operator needed here.\n\nOkay, I'll try to do a PR to fix that in the next few days.\nHi @freakboy3742,\nI prepared the PR, however, running the tests on the main branch with `tox` was leading to an error:\n`coverageplatform: FAIL code error: Multiple top-level packages discovered in a flat-layout: ['web', 'gtk', 'iOS', 'toga', 'core', 'demo', 'dummy', 'cocoa', 'changes', 'testbed', 'android', 'textual', 'winforms', 'positron', 'travertino'].`.\nI don't really know why this is happening as I simply followed https://toga.readthedocs.io/en/stable/how-to/contribute/code.html and had the failure when arriving at the tests. Any tip to fix that before making the PR?\n@Ydrnan Thanks for letting us know - looks like a recent refactor of our tox configuration has a 1 character bug that slipped through testing (the final target on line 2 of tox.ini should read `coverage{,-trav}-platform`, not `coverage{,-trav}platform`).\n\nThe fix for this is in #3670; in the meantime, you can use:\n```\ntox -m test \n```\nto run the test suite and get a coverage report. This tox target will only run on 1 python version, rather than on *every* python version - but that's more than enough for local testing in almost every case, and is a lot faster as well.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/8ee4e92c94265d9af706bb5490746ece3497c5be", "https://github.com/beeware/toga/commit/25faaa5d04ce3617b0a2081117cba3af0cca2c4f", "https://github.com/beeware/toga/commit/b364254fd79942c73853c7d5d723e453af93a502", "https://github.com/beeware/toga/commit/91e2914c9c65196e1c343f03d7fe82aa4863b1a8", "https://github.com/beeware/toga/commit/0dad55930de4961bd52a216b7be23d8a28a5f788"], "created_at": "2025-07-29T07:55:03Z"}
{"repo": "beeware/toga", "pull_number": 3674, "instance_id": "beeware__toga-3674", "issue_numbers": [3672], "base_commit": "903f4e687e92afa99f8d04b9b982734e26ad8321", "patch": "diff --git a/changes/3672.bugfix.rst b/changes/3672.bugfix.rst\nnew file mode 100644\nindex 0000000000..c10b06e4a0\n--- /dev/null\n+++ b/changes/3672.bugfix.rst\n@@ -0,0 +1,1 @@\n+An issue with the text of OptionContainer tab labels being returned as a ``rubicon.objc.collections.ObjCStrInstance`` on macOS instead of a Python ``str`` has been fixed.\ndiff --git a/cocoa/src/toga_cocoa/widgets/optioncontainer.py b/cocoa/src/toga_cocoa/widgets/optioncontainer.py\nindex d53cb224fc..d8668fd357 100644\n--- a/cocoa/src/toga_cocoa/widgets/optioncontainer.py\n+++ b/cocoa/src/toga_cocoa/widgets/optioncontainer.py\n@@ -132,7 +132,7 @@ def get_option_icon(self, index):\n \n     def get_option_text(self, index):\n         tabview = self.native.tabViewItemAtIndex(index)\n-        return tabview.label\n+        return str(tabview.label)\n \n     def get_current_tab_index(self):\n         return self.native.indexOfTabViewItem(self.native.selectedTabViewItem)\n", "test_patch": "diff --git a/testbed/tests/widgets/test_optioncontainer.py b/testbed/tests/widgets/test_optioncontainer.py\nindex 5a20aa2b95..9f2c7f6374 100644\n--- a/testbed/tests/widgets/test_optioncontainer.py\n+++ b/testbed/tests/widgets/test_optioncontainer.py\n@@ -85,6 +85,11 @@ async def widget(content1, content2, content3, on_select_handler):\n )\n \n \n+def assert_tab_text(tab, expected):\n+    assert tab.text == expected\n+    assert type(tab.text) is str\n+\n+\n async def test_select_tab(\n     widget,\n     probe,\n@@ -301,11 +306,11 @@ async def test_select_tab_overflow(widget, probe, on_select_handler):\n         widget.content[probe.max_tabs].icon = \"resources/new-tab\"\n         widget.content[probe.max_tabs].enabled = False\n \n-        assert widget.content[probe.max_tabs].text == \"Extra Tab\"\n+        assert_tab_text(widget.content[probe.max_tabs], \"Extra Tab\")\n         probe.assert_tab_icon(probe.max_tabs, \"new-tab\")\n         assert not widget.content[probe.max_tabs].enabled\n \n-        assert widget.content[probe.max_tabs + 1].text == \"Tab B\"\n+        assert_tab_text(widget.content[probe.max_tabs + 1], \"Tab B\")\n         probe.assert_tab_icon(probe.max_tabs + 1, None)\n         assert widget.content[probe.max_tabs + 1].enabled\n \n@@ -326,7 +331,7 @@ async def test_select_tab_overflow(widget, probe, on_select_handler):\n         await probe.wait_for_tab(\"Inserted item bumped the last item\")\n \n         # Assert the properties of the last visible item\n-        assert widget.content[probe.max_tabs - 1].text == f\"Tab {probe.max_tabs - 1}\"\n+        assert_tab_text(widget.content[probe.max_tabs - 1], f\"Tab {probe.max_tabs - 1}\")\n         probe.assert_tab_icon(probe.max_tabs - 1, None)\n         assert widget.content[probe.max_tabs - 1].enabled\n \n@@ -338,7 +343,7 @@ async def test_select_tab_overflow(widget, probe, on_select_handler):\n         )\n \n         # Assert the properties of the first invisible item\n-        assert widget.content[probe.max_tabs].text == f\"Tab {probe.max_tabs}\"\n+        assert_tab_text(widget.content[probe.max_tabs], f\"Tab {probe.max_tabs}\")\n         probe.assert_tab_icon(probe.max_tabs, None)\n         assert widget.content[probe.max_tabs].enabled\n \n@@ -348,7 +353,7 @@ async def test_select_tab_overflow(widget, probe, on_select_handler):\n \n         await probe.wait_for_tab(\"Deleting an item restores previously bumped item\")\n \n-        assert widget.content[probe.max_tabs - 1].text == f\"Tab {probe.max_tabs}\"\n+        assert_tab_text(widget.content[probe.max_tabs - 1], f\"Tab {probe.max_tabs}\")\n         probe.assert_tab_icon(probe.max_tabs - 1, None)\n         assert widget.content[probe.max_tabs - 1].enabled\n \n@@ -366,7 +371,7 @@ async def test_select_tab_overflow(widget, probe, on_select_handler):\n \n         await probe.wait_for_tab(\"Deleting an item creates a previously excess item\")\n \n-        assert widget.content[probe.max_tabs - 1].text == \"Extra Tab\"\n+        assert_tab_text(widget.content[probe.max_tabs - 1], \"Extra Tab\")\n         probe.assert_tab_icon(probe.max_tabs - 1, \"new-tab\")\n         assert not widget.content[probe.max_tabs - 1].enabled\n \n@@ -427,7 +432,7 @@ async def test_enable_tab(widget, probe, on_select_handler):\n     await probe.wait_for_tab(\"Tab 3 should be selected\")\n \n     assert widget.current_tab.index == 2\n-    assert widget.current_tab.text == \"Tab 3\"\n+    assert_tab_text(widget.current_tab, \"Tab 3\")\n \n     # on_select has been invoked\n     on_select_handler.assert_called_once_with(widget)\n@@ -482,7 +487,7 @@ async def test_change_content(\n     await probe.wait_for_tab(\"New tab has been added disabled\")\n \n     assert len(widget.content) == 4\n-    assert widget.content[1].text == \"New tab\"\n+    assert_tab_text(widget.content[1], \"New tab\")\n     assert not widget.content[1].enabled\n \n     # Enable the new content and select it\n@@ -491,7 +496,7 @@ async def test_change_content(\n     await probe.wait_for_tab(\"New tab has been enabled and selected\")\n \n     assert widget.current_tab.index == 1\n-    assert widget.current_tab.text == \"New tab\"\n+    assert_tab_text(widget.current_tab, \"New tab\")\n \n     # The content should be the same size as the container; these dimensions can\n     # be impacted by the size of tabs and other widget chrome. Test that the\n@@ -508,7 +513,7 @@ async def test_change_content(\n     widget.content[\"Tab 2\"].text = \"New 2\"\n     await probe.wait_for_tab(\"Tab 2 has been renamed\")\n \n-    assert widget.content[2].text == \"New 2\"\n+    assert_tab_text(widget.content[2], \"New 2\")\n \n     # Change the icon of Tab 2\n     widget.content[\"New 2\"].icon = \"resources/new-tab\"\n@@ -535,7 +540,7 @@ async def test_change_content(\n     await probe.wait_for_tab(\"Revised tab 2 has been selected\")\n \n     assert widget.current_tab.index == 3\n-    assert widget.current_tab.text == \"New Tab 2\"\n+    assert_tab_text(widget.current_tab, \"New Tab 2\")\n     # The content should be the same size as the container; these dimensions can\n     # be impacted by the size of tabs and other widget chrome. Test that the\n     # content has expanded by asserting that the content is at least 80% the\n", "problem_statement": "OptionContainer: tabs text is of type `rubicon.objc.collections.ObjCStrInstance`\n### Describe the bug\n\nThe title of tabs of `OptionContainer` is stored in its `text` property. On macOS, this is of type `rubicon.objc.collections.ObjCStrInstance`\n\nEven thought it is printable, it is not serializable, and can be a nuisance in some cases:\n- can't be used as a key in a dict\n- causes json.dumps to raise an exception\n\n### Steps to reproduce\n\nThe following is a snippet derived from the docs for `OptionContainer`\n\n```python\nimport toga\n\ncontainer = toga.OptionContainer(\n    content=[(\"Pizza\", toga.Box())]\n)\n\n# Add another tab of content\ncontainer.content.append(\"Salad\", toga.Box())\n\n# print tabs titles\nprint(container.content[0].text, type(container.content[0].text))\nprint(container.content[1].text, type(container.content[1].text))\n\n# This will raise:\nmydict = {}\nmydict[container.current_tab.text] = 'aaaaaa'\n\n# This too will raise:\nimport json\nprint(json.dumps({'key': container.current_tab.text}))\n```\n\n### Expected behavior\n\nThe `text` property should always return an `str`\n\n### Screenshots\n\n_No response_\n\n### Environment\n\n- Operating System: macOS\n- Python version: 3.13.3\n- Software versions:\n  - Briefcase: 0.3.23\n  - Toga: 0.5.2\n\n\n\n### Logs\n\n_No response_\n\n### Additional context\n\n_No response_\n", "hints_text": "I tested it just now and this, specifically, is fixable by simply changing line 135 of optioncontainer.py to `return str(tabview.label)`.\n\nHowever, I'm not very familiar at all with how Rubicon works, and I don't know if maybe there's supposed to be some upstream conversion so that it's already a string at that point. (And if not, I wouldn't be surprised if there are other places in the core codebase that should be converting to Python strings but aren't.)\n\n@freakboy3742, do you have any insight?\n> [@freakboy3742](https://github.com/freakboy3742), do you have any insight?\n\nYour investigation and proposed fix is [100% on the money](https://rubicon-objc.readthedocs.io/en/stable/how-to/type-mapping.html#strings)\n\nThis is a side effect of a weird friction between ObjC and Python. We preserve the ObjC string instance because the conversion isn't *free*, and there are occasions where we actually need the underlying *original* ObjC reference for a string instance.\n\nObjC string instances and Python strings are *almost* interchangeable - if they're printed, you won't notice a difference, for example. It only becomes an issue when *implicit* conversion to string doesn't occur - and the two examples shown here (use as a `__getitem__` lookup, and in a json serialisation) are two examples where that will happen.\n\nYou'll see explicit conversion to `str()` anywhere that we're surfacing an ObjC string value to the end user - e.g., `TextInput.get_value()`; we've evidently missed a case here, and the testbed check of OptionContainer's labels is doing a simple value equality check (which will pass, because `__eq__` is implemented for ObjC String instances).\n\n", "all_hints_text": "I tested it just now and this, specifically, is fixable by simply changing line 135 of optioncontainer.py to `return str(tabview.label)`.\n\nHowever, I'm not very familiar at all with how Rubicon works, and I don't know if maybe there's supposed to be some upstream conversion so that it's already a string at that point. (And if not, I wouldn't be surprised if there are other places in the core codebase that should be converting to Python strings but aren't.)\n\n@freakboy3742, do you have any insight?\n> [@freakboy3742](https://github.com/freakboy3742), do you have any insight?\n\nYour investigation and proposed fix is [100% on the money](https://rubicon-objc.readthedocs.io/en/stable/how-to/type-mapping.html#strings)\n\nThis is a side effect of a weird friction between ObjC and Python. We preserve the ObjC string instance because the conversion isn't *free*, and there are occasions where we actually need the underlying *original* ObjC reference for a string instance.\n\nObjC string instances and Python strings are *almost* interchangeable - if they're printed, you won't notice a difference, for example. It only becomes an issue when *implicit* conversion to string doesn't occur - and the two examples shown here (use as a `__getitem__` lookup, and in a json serialisation) are two examples where that will happen.\n\nYou'll see explicit conversion to `str()` anywhere that we're surfacing an ObjC string value to the end user - e.g., `TextInput.get_value()`; we've evidently missed a case here, and the testbed check of OptionContainer's labels is doing a simple value equality check (which will pass, because `__eq__` is implemented for ObjC String instances).\nThe reason it fails in the index assignment above \u2014 `mydict[container.current_tab.text] = 'aaaaaa'` \u2014 is because it's unhashable. I know there are mutable and immutable NSStrings... Is this immutable, and if so, should we perhaps give it a hash? I don't know if that would be useful anywhere.\n[Unfortunately no - we can't add a `__hash__()`](https://github.com/beeware/rubicon-objc/blob/main/src/rubicon/objc/collections.py#L59) - or, at least, not without a bunch of other limitations/restrictions.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/24bd8b00cde7826664ad937735ebd790a4eca6b4"], "created_at": "2025-07-31T01:32:15Z"}
{"repo": "beeware/toga", "pull_number": 3678, "instance_id": "beeware__toga-3678", "issue_numbers": [3677], "base_commit": "4c26910d4332b45433021bded49e7c7e05ca2d31", "patch": "diff --git a/changes/3667.bugfix.rst b/changes/3667.bugfix.rst\nnew file mode 100644\nindex 0000000000..27e1eed940\n--- /dev/null\n+++ b/changes/3667.bugfix.rst\n@@ -0,0 +1,1 @@\n+On macOS, the origin of non-primary screens is now correctly calculated when screens are not vertically aligned and the same size.\ndiff --git a/cocoa/src/toga_cocoa/screens.py b/cocoa/src/toga_cocoa/screens.py\nindex fab406b70d..4dea8cfb00 100644\n--- a/cocoa/src/toga_cocoa/screens.py\n+++ b/cocoa/src/toga_cocoa/screens.py\n@@ -4,6 +4,7 @@\n from toga.types import Position, Size\n from toga_cocoa.libs import (\n     NSImage,\n+    NSScreen,\n     core_graphics,\n )\n \n@@ -25,8 +26,15 @@ def get_name(self):\n         return str(self.native.localizedName)\n \n     def get_origin(self) -> Position:\n+        # macOS screen coordinates have the origin at the bottom left.\n         frame_native = self.native.frame\n-        return Position(int(frame_native.origin.x), int(frame_native.origin.y))\n+        return Position(\n+            int(frame_native.origin.x),\n+            int(\n+                NSScreen.screens[0].frame.size.height\n+                - (frame_native.origin.y + frame_native.size.height)\n+            ),\n+        )\n \n     def get_size(self) -> Size:\n         frame_native = self.native.frame\ndiff --git a/cocoa/src/toga_cocoa/window.py b/cocoa/src/toga_cocoa/window.py\nindex 05c156b77f..bd415e7360 100644\n--- a/cocoa/src/toga_cocoa/window.py\n+++ b/cocoa/src/toga_cocoa/window.py\n@@ -329,9 +329,11 @@ def get_position(self) -> Position:\n         # macOS origin is bottom left of screen, and the screen might be\n         # offset relative to other screens. Adjust for this.\n         return Position(\n-            window_frame.origin.x,\n-            primary_screen.size.height\n-            - (window_frame.origin.y + window_frame.size.height),\n+            int(window_frame.origin.x),\n+            int(\n+                primary_screen.size.height\n+                - (window_frame.origin.y + window_frame.size.height)\n+            ),\n         )\n \n     def set_position(self, position):\n", "test_patch": "diff --git a/testbed/tests/app/test_screens.py b/testbed/tests/app/test_screens.py\nindex db167bbf15..27c869b1b9 100644\n--- a/testbed/tests/app/test_screens.py\n+++ b/testbed/tests/app/test_screens.py\n@@ -21,23 +21,19 @@ async def test_origin(app):\n     \"\"\"The origin of the screens can be retrieved\"\"\"\n     for screen in app.screens:\n         origin = screen.origin\n-        assert (\n-            isinstance(origin, tuple)\n-            and len(origin) == 2\n-            and all(isinstance(val, int) for val in origin)\n-        )\n+        assert isinstance(origin, tuple)\n+        assert len(origin) == 2\n+        assert all(isinstance(val, int) for val in origin)\n \n \n async def test_size(app):\n     \"\"\"The size of the screens can be retrieved\"\"\"\n     for screen in app.screens:\n         size = screen.size\n-        assert (\n-            isinstance(size, tuple)\n-            and len(size) == 2\n-            # Check that neither the width or height is zero.\n-            and all(isinstance(val, int) and val > 0 for val in size)\n-        )\n+        assert isinstance(size, tuple)\n+        assert len(size) == 2\n+        # Check that neither the width or height is zero.\n+        assert all(isinstance(val, int) and val > 0 for val in size)\n \n \n async def test_as_image(app):\ndiff --git a/testbed/tests/window/test_window.py b/testbed/tests/window/test_window.py\nindex d2b974cb10..092306e2fb 100644\n--- a/testbed/tests/window/test_window.py\n+++ b/testbed/tests/window/test_window.py\n@@ -1106,9 +1106,12 @@ async def test_screen(second_window, second_window_probe):\n         assert second_window.position != initial_position\n \n         # `position` and `screen_position` will be same as the window will be in\n-        # primary screen.\n+        # primary screen. They are also 2-tuples of integers\n         assert second_window.position == (200, 200)\n+        assert all(isinstance(val, int) for val in second_window.position)\n+\n         assert second_window.screen_position == (200, 200)\n+        assert all(isinstance(val, int) for val in second_window.screen_position)\n \n         # Move the window between available screens and assert its `screen_position`\n         for screen in second_window.app.screens:\n@@ -1121,6 +1124,7 @@ async def test_screen(second_window, second_window_probe):\n                 second_window.position[0] - screen.origin[0],\n                 second_window.position[1] - screen.origin[1],\n             )\n+            assert all(isinstance(val, int) for val in second_window.screen_position)\n \n \n async def test_as_image(main_window, main_window_probe):\n", "problem_statement": "macOS Screen origin is incorrect except on the main screen\n### Describe the bug\n\nin toga_cocoa/screens.py, the get_origin method fails to correct for macos origin being in the bottom left instead of the top left. Code should be:\n\n    def get_origin(self) -> Position:\n\n        primary_screen = NSScreen.screens[0].frame\n        frame_native = self.native.frame\n\n        # macOS origin is bottom left of screen, and the screen might be\n        # offset relative to other screens. Adjust for this.\n        return Position(\n            frame_native.origin.x,\n            primary_screen.size.height\n            - (frame_native.origin.y + frame_native.size.height),\n        )\n\n\n### Steps to reproduce\n\nMove a window to another screen whose top is aligned with NSScreen.screens[0].\n\n### Expected behavior\n\nwindow.screen_position will have a negative y value\n\n### Screenshots\n\n_No response_\n\n### Environment\n\n- Operating System: macos\n- Python version: 3.13.5\n- Software versions:\n  - Briefcase: 0.3.23\n  - Toga: 0.5.1\n  - ...\n\n\n### Logs\n\n```\n\n```\n\n\n### Additional context\n\n_No response_\n", "hints_text": "Thanks for the report - this seems like an entirely *plausible* error, given how Cocoa represents screen positions... but how are you reproducing this? \n\nThe `window` example has code to exercise window positioning (and position reporting). I have a 3 monitor setup (2 external monitors positioned to the left of the laptop screen, with the centre screen being screen 0), and if I run the `window` example, and move the window to the top left of the left-most screen and click the \"report\" button, it reports a relative position of (0, 0), and an absolute position of (-1920, 0). This is on Sequoia 15.4.1.\nYes, window.position works fine. What I wanted was to store a window position so when I restarted the program, I could get the window in the same position that I had left it.\u00a0For that, I was storing the window.screen.name and window.screen_position. But the screen position had a negative y value.\u00a0\nSure - but again, *how are you testing this*? The example I referenced tests both `position` *and* `screen_position` - and if I move the window to the top left of the left hand monitor, I get a `position` of (-1920, 0) and a `screen_position` of (0, 0).\n\n\nGo to your display settings and change your left monitor to be lower than your right monitor. \u00a0That should show the problem.\u00a0Also, the change I made to the code in toga cocoa screen was extracted from the code in cocoa window.position for fixing y\nIf 2 monitors are the same screen.size and they are configured as aligned at top, the origin of the left screen would be the same y origin when viewed in macOS bottom left coordinates as they are in top left\nAh - ok - it's the uneven vertical alignment that is key here. Thanks - I can confirm I can reproduce the problem you're describing.\n\nWould you care to turn this into a pull request? It looks like your proposed fix work as described.\nI would notI\u2019ve used git, but I feel about it like that \u00a0xkcd comic\n\n", "all_hints_text": "Thanks for the report - this seems like an entirely *plausible* error, given how Cocoa represents screen positions... but how are you reproducing this? \n\nThe `window` example has code to exercise window positioning (and position reporting). I have a 3 monitor setup (2 external monitors positioned to the left of the laptop screen, with the centre screen being screen 0), and if I run the `window` example, and move the window to the top left of the left-most screen and click the \"report\" button, it reports a relative position of (0, 0), and an absolute position of (-1920, 0). This is on Sequoia 15.4.1.\nYes, window.position works fine. What I wanted was to store a window position so when I restarted the program, I could get the window in the same position that I had left it.\u00a0For that, I was storing the window.screen.name and window.screen_position. But the screen position had a negative y value.\u00a0\nSure - but again, *how are you testing this*? The example I referenced tests both `position` *and* `screen_position` - and if I move the window to the top left of the left hand monitor, I get a `position` of (-1920, 0) and a `screen_position` of (0, 0).\n\n\nGo to your display settings and change your left monitor to be lower than your right monitor. \u00a0That should show the problem.\u00a0Also, the change I made to the code in toga cocoa screen was extracted from the code in cocoa window.position for fixing y\nIf 2 monitors are the same screen.size and they are configured as aligned at top, the origin of the left screen would be the same y origin when viewed in macOS bottom left coordinates as they are in top left\nAh - ok - it's the uneven vertical alignment that is key here. Thanks - I can confirm I can reproduce the problem you're describing.\n\nWould you care to turn this into a pull request? It looks like your proposed fix work as described.\nI would notI\u2019ve used git, but I feel about it like that \u00a0xkcd comic\nNo worries - I've just pushed a PR that implements your proposed fix. Thanks for the report!\nYour very welcome\u00a0Janice\u00a0On Aug 3, 2025, at 22:11, Russell Keith-Magee ***@***.***> wrote:\ufefffreakboy3742 left a comment (beeware/toga#3677)\r\nNo worries - I've just pushed a PR that implements your proposed fix. Thanks for the report!\r\n\r\n\u2014Reply to this email directly, view it on GitHub, or unsubscribe.You are receiving this because you authored the thread.Message ID: ***@***.***>\nI saw your cast to integer commit mail.\r\n\r\nI didn't notice the original code casting to int.\r\n\r\nYou may want to fix the code in toga_cocoa/window.py, lines 318-322. This is what I copied from, and not an int cast to be found\r\n\r\n    def get_position(self) -> Position:\r\n        # The \"primary\" screen has index 0 and origin (0, 0).\r\n        primary_screen = NSScreen.screens[0].frame\r\n        window_frame = self.native.frame\r\n\r\n        # macOS origin is bottom left of screen, and the screen might be\r\n        # offset relative to other screens. Adjust for this.\r\n        return Position(\r\n            window_frame.origin.x,\r\n            primary_screen.size.height\r\n            - (window_frame.origin.y + window_frame.size.height),\r\n        )\r\n\r\n\r\nJanice\r\n\r\nPS I should have said this before... Thank you so very much for responding so quickly to my bug report\r\n\r\n> On Aug 3, 2025, at 22:11, Russell Keith-Magee ***@***.***> wrote:\r\n> \r\n> \r\n> freakboy3742\r\n>  left a comment \r\n> (beeware/toga#3677)\r\n>  <https://github.com/beeware/toga/issues/3677#issuecomment-3148921127>\r\n> No worries - I've just pushed a PR that implements your proposed fix. Thanks for the report!\r\n> \r\n> \u2014\r\n> Reply to this email directly, view it on GitHub <https://github.com/beeware/toga/issues/3677#issuecomment-3148921127>, or unsubscribe <https://github.com/notifications/unsubscribe-auth/BVQPOMUSTEL3KOTKRVD7YML3L26NNAVCNFSM6AAAAACDANPFVWVHI2DSMVQWIX3LMV43OSLTON2WKQ3PNVWWK3TUHMZTCNBYHEZDCMJSG4>.\r\n> You are receiving this because you authored the thread.\r\n> \r\n\r\n\n> You may want to fix the code in toga_cocoa/window.py, lines 318-322. This is what I copied from, and not an int cast to be found\n\nGood catch - thanks for letting me know! I'll update the patch shortly.\n\n> PS I should have said this before... Thank you so very much for responding so quickly to my bug report\n\nMy pleasure!\n\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/cc2f3e4519b99fca80320e4ee7dec54dfda96c45", "https://github.com/beeware/toga/commit/5884e8c4e83f8d114a1ce89c10a665ab781cd408", "https://github.com/beeware/toga/commit/f10bb8e414252220fec08a4ae180a31c0d5fc0ad"], "created_at": "2025-08-04T02:09:06Z"}
{"repo": "beeware/toga", "pull_number": 4208, "instance_id": "beeware__toga-4208", "issue_numbers": [3685], "base_commit": "779beba688d8f86bdc3fad7ca8642d61739aa48b", "patch": "diff --git a/changes/3685.misc.md b/changes/3685.misc.md\nnew file mode 100644\nindex 0000000000..913ba42c84\n--- /dev/null\n+++ b/changes/3685.misc.md\n@@ -0,0 +1,1 @@\n+Fix intermittent IndexOutOfBoundsException in Android testbed.\n", "test_patch": "diff --git a/android/tests_backend/probe.py b/android/tests_backend/probe.py\nindex 5c60f3f468..fc48f99f8d 100644\n--- a/android/tests_backend/probe.py\n+++ b/android/tests_backend/probe.py\n@@ -37,9 +37,17 @@ def __init__(self, app):\n         self.scale_factor = self.dpi / 160\n \n     def __del__(self):\n-        self.root_view.getViewTreeObserver().removeOnGlobalLayoutListener(\n-            self.layout_listener\n-        )\n+        # Save `self` attributes in local variables, because they may be cleared after\n+        # __del__ returns.\n+        root_view = self.root_view\n+        listener = self.layout_listener\n+\n+        # __del__ may be called on any thread, but Android APIs must be called on the\n+        # main thread.\n+        def cleanup_layout_listener():\n+            root_view.getViewTreeObserver().removeOnGlobalLayoutListener(listener)\n+\n+        self.app.loop.call_soon_threadsafe(cleanup_layout_listener)\n \n     def get_dialog_view(self):\n         new_windows = [\ndiff --git a/android/tests_backend/widgets/base.py b/android/tests_backend/widgets/base.py\nindex 8cb8233fbf..a61c371a0b 100644\n--- a/android/tests_backend/widgets/base.py\n+++ b/android/tests_backend/widgets/base.py\n@@ -10,6 +10,7 @@\n from android.os import Build, SystemClock\n from android.view import MotionEvent, View, ViewGroup\n \n+import toga\n from toga.colors import TRANSPARENT\n from toga.style.pack import JUSTIFY, LEFT\n \n@@ -24,7 +25,9 @@ class SimpleProbe(BaseProbe, FontMixin):\n     invalid_size_while_hidden = False\n \n     def __init__(self, widget):\n-        super().__init__(widget.app)\n+        # Don't use widget.app, because the widget may not be connected to an app yet.\n+        super().__init__(toga.App.app)\n+\n         self.widget = widget\n         self.impl = widget._impl\n         self.native = widget._impl.native\n", "problem_statement": "Intermittent IndexOutOfBoundsException in Android testbed\n### Describe the bug\n\nI keep getting a frustratingly intermittent crash when running the Android testbed test suite. It's reproducible in the sense that I've yet to run the test suite all the way through successfully, but exactly where it happens seems highly variable. I've tried running several of the apparently offending tests in isolation, but haven't gotten any of them to fail except for `tests/window/test_window.py::test_window_state_change`. That one crashes *sometimes*.\n\nVery rarely, it crashes before the tests have even started.\n\n### Steps to reproduce\n\n1. Run the Android testbed: `briefcase run android --test`\n2. See error at a seemingly random point.\n3. Weep.\n\n\n### Expected behavior\n\nThe testbed running successfully and not crashing.\n\n### Screenshots\n\n_No response_\n\n### Environment\n\n- Operating System: macOS Sonoma 14.7.6\n- Python version: 3.12.0\n- Software versions:\n  - Briefcase: 0.3.24 (also tried with 0.3.22)\n  - Toga: main development branch (also tried with 0.5.1 and 0.5.2)\n\n\n### Logs\n\nWhen it crashes during testing (which is the vast majority of the time):\n```\n--------- beginning of crash\nE/AndroidRuntime: FATAL EXCEPTION: main\nE/AndroidRuntime: Process: org.beeware.toga.testbed, PID: 10419\nE/AndroidRuntime: java.lang.IndexOutOfBoundsException: Index: 3, Size: 3\nE/AndroidRuntime:   at java.util.ArrayList.get(ArrayList.java:437)\nE/AndroidRuntime:   at android.view.ViewTreeObserver$CopyOnWriteArray$Access.get(ViewTreeObserver.java:1272)\nE/AndroidRuntime:   at android.view.ViewTreeObserver.dispatchOnGlobalLayout(ViewTreeObserver.java:1061)\nE/AndroidRuntime:   at android.view.ViewRootImpl.performTraversals(ViewRootImpl.java:3197)\nE/AndroidRuntime:   at android.view.ViewRootImpl.doTraversal(ViewRootImpl.java:2126)\nE/AndroidRuntime:   at android.view.ViewRootImpl$TraversalRunnable.run(ViewRootImpl.java:8653)\nE/AndroidRuntime:   at android.view.Choreographer$CallbackRecord.run(Choreographer.java:1037)\nE/AndroidRuntime:   at android.view.Choreographer.doCallbacks(Choreographer.java:845)\nE/AndroidRuntime:   at android.view.Choreographer.doFrame(Choreographer.java:780)\nE/AndroidRuntime:   at android.view.Choreographer$FrameDisplayEventReceiver.run(Choreographer.java:1022)\nE/AndroidRuntime:   at android.os.Handler.handleCallback(Handler.java:938)\nE/AndroidRuntime:   at android.os.Handler.dispatchMessage(Handler.java:99)\nE/AndroidRuntime:   at android.os.Looper.loopOnce(Looper.java:201)\nE/AndroidRuntime:   at android.os.Looper.loop(Looper.java:288)\nE/AndroidRuntime:   at android.app.ActivityThread.main(ActivityThread.java:7839)\nE/AndroidRuntime:   at java.lang.reflect.Method.invoke(Native Method)\nE/AndroidRuntime:   at com.android.internal.os.RuntimeInit$MethodAndArgsCaller.run(RuntimeInit.java:548)\nE/AndroidRuntime:   at com.android.internal.os.ZygoteInit.main(ZygoteInit.java:1003)\nI/Process : Sending signal. PID: 10419 SIG: 9\n```\nThis seems to always be identical, with the exception of the PID and the index / size of the array.\n\nWhen it crashes during test collection, I see this:\n```\n--------- beginning of crash\nE/AndroidRuntime: FATAL EXCEPTION: main\nE/AndroidRuntime: Process: org.beeware.toga.testbed, PID: 1869\nE/AndroidRuntime: java.lang.RuntimeException: Unable to start activity ComponentInfo{org.beeware.toga.testbed/org.beeware.android.MainActivity}:\ncom.chaquo.python.PyException: CoverageWarning: Couldn't import C tracer: No module named 'coverage.tracer' (no-ctracer)                                                 \nE/AndroidRuntime:       at android.app.ActivityThread.performLaunchActivity(ActivityThread.java:3635)\nE/AndroidRuntime:       at android.app.ActivityThread.handleLaunchActivity(ActivityThread.java:3792)\nE/AndroidRuntime:       at android.app.ActivityThread.handleRelaunchActivityInner(ActivityThread.java:5738)\nE/AndroidRuntime:       at android.app.ActivityThread.handleRelaunchActivity(ActivityThread.java:5630)\nE/AndroidRuntime:       at android.app.servertransaction.ActivityRelaunchItem.execute(ActivityRelaunchItem.java:71)\nE/AndroidRuntime:       at android.app.servertransaction.ActivityTransactionItem.execute(ActivityTransactionItem.java:45)\nE/AndroidRuntime:       at android.app.servertransaction.TransactionExecutor.executeCallbacks(TransactionExecutor.java:135)\nE/AndroidRuntime:       at android.app.servertransaction.TransactionExecutor.execute(TransactionExecutor.java:95)\nE/AndroidRuntime:       at android.app.ActivityThread$H.handleMessage(ActivityThread.java:2210)\nE/AndroidRuntime:       at android.os.Handler.dispatchMessage(Handler.java:106)\nE/AndroidRuntime:       at android.os.Looper.loopOnce(Looper.java:201)\nE/AndroidRuntime:       at android.os.Looper.loop(Looper.java:288)\nE/AndroidRuntime:       at android.app.ActivityThread.main(ActivityThread.java:7839)\nE/AndroidRuntime:       at java.lang.reflect.Method.invoke(Native Method)\nE/AndroidRuntime:       at com.android.internal.os.RuntimeInit$MethodAndArgsCaller.run(RuntimeInit.java:548)\nE/AndroidRuntime:       at com.android.internal.os.ZygoteInit.main(ZygoteInit.java:1003)\nE/AndroidRuntime: Caused by: com.chaquo.python.PyException: CoverageWarning: Couldn't import C tracer: No module named 'coverage.tracer' (no-ctracer)\nE/AndroidRuntime:       at <python>.coverage.control._warn(control.py:461)\nE/AndroidRuntime:       at <python>.coverage.core.__init__(core.py:97)\nE/AndroidRuntime:       at <python>.coverage.control._init_for_start(control.py:558)\nE/AndroidRuntime:       at <python>.coverage.control.start(control.py:664)\nE/AndroidRuntime:       at <python>.__main__.<module>(testbed.py:154)\nE/AndroidRuntime:       at <python>.runpy._run_code(<frozen runpy>:88)\nE/AndroidRuntime:       at <python>.runpy._run_module_code(<frozen runpy>:98)\nE/AndroidRuntime:       at <python>.runpy.run_module(<frozen runpy>:226)\nE/AndroidRuntime:       at <python>.chaquopy_java.call(chaquopy_java.pyx:352)\nE/AndroidRuntime:       at <python>.chaquopy_java.Java_com_chaquo_python_PyObject_callAttrThrowsNative(chaquopy_java.pyx:324)\nE/AndroidRuntime:       at com.chaquo.python.PyObject.callAttrThrowsNative(Native Method)\nE/AndroidRuntime:       at com.chaquo.python.PyObject.callAttrThrows(PyObject.java:232)\nE/AndroidRuntime:       at com.chaquo.python.PyObject.callAttr(PyObject.java:221)\nE/AndroidRuntime:       at org.beeware.android.MainActivity.onCreate(MainActivity.java:105)\nE/AndroidRuntime:       at android.app.Activity.performCreate(Activity.java:8051)\nE/AndroidRuntime:       at android.app.Activity.performCreate(Activity.java:8031)\nE/AndroidRuntime:       at android.app.Instrumentation.callActivityOnCreate(Instrumentation.java:1329)\nE/AndroidRuntime:       at android.app.ActivityThread.performLaunchActivity(ActivityThread.java:3608)\nE/AndroidRuntime:       ... 15 more\nI/Process : Sending signal. PID: 1869 SIG: 9\n```\n\n(That is, unfortunately, truncated even in the saved log file.)\n\n### Additional context\n\n_No response_\n", "hints_text": "```\nE/AndroidRuntime: java.lang.IndexOutOfBoundsException: Index: 3, Size: 3\nE/AndroidRuntime:   at java.util.ArrayList.get(ArrayList.java:437)\nE/AndroidRuntime:   at android.view.ViewTreeObserver$CopyOnWriteArray$Access.get(ViewTreeObserver.java:1272)\n```\n\nhttps://stackoverflow.com/questions/67821711 suggests this may be caused by adding or removing a GlobalLayoutListener while the system is iterating through the listener list. We do this in a few places, but the `__del__` method in `BaseProbe` looks like the most likely candidate to happen at an unpredictable time.\n\n```\nE/AndroidRuntime: Caused by: com.chaquo.python.PyException: CoverageWarning: Couldn't import C tracer: No module named 'coverage.tracer' (no-ctracer)\nE/AndroidRuntime:       at <python>.coverage.control._warn(control.py:461)\nE/AndroidRuntime:       at <python>.coverage.core.__init__(core.py:97)\n```\n\nThis looks like a simple case of a warning being raised while Python is set to treat warnings as errors, though I don't know why it would be intermittent.\n\n\"15 more\" is not a truncation, it indicates that the remainder of the low-level exception's stack trace is shared with the high-level exception above the \"Caused by\" line.\n> https://stackoverflow.com/questions/67821711 suggests this may be caused by adding or removing a GlobalLayoutListener while the system is iterating through the listener list. We do this in a few places, but the `__del__` method in `BaseProbe` looks like the most likely candidate to happen at an unpredictable time.\n\nIf nothing else, that should be something we can test - @HalfWhitt If you comment out the `BaseProbe.__del__` method, presumably the app will leak, but it shouldn't *crash*... does that fix the problem for you?\n\nIf it does, the question becomes whether there's any way to put a concurrency lock on removing a listener, or to restructure the way we're handling the listener so that we don't need to add and remove the LayoutListener instance regularly. \n\nOne thought would be to avoid creating a fresh LayoutListener in Probe, and instead add a hook on the LayoutListener that is added as part of the Android implementation of Window. That way we're not adding a fresh listener at the Android level - we're using the same Android listener every time.\nCommenting out `BaseProbe.__del__` does, in fact, prevent the indexing error. However, the testbed then fails consistently with:\n```\n--------- beginning of crash\nE/AndroidRuntime: FATAL EXCEPTION: main\nE/AndroidRuntime: Process: org.beeware.toga.testbed, PID: 1974\nE/AndroidRuntime: com.chaquo.python.PyException: AttributeError: 'Event' object has no attribute '_value'\nE/AndroidRuntime:   at <python>.asyncio.locks.set(locks.py:187)\nE/AndroidRuntime:   at <python>.tests_backend.probe.onGlobalLayout(probe.py:19)\nE/AndroidRuntime:   at <python>.chaquopy_java.call(chaquopy_java.pyx:352)\nE/AndroidRuntime:   at <python>.chaquopy_java.Java_com_chaquo_python_PyObject_callAttrThrowsNative(chaquopy_java.pyx:324)\nE/AndroidRuntime:   at com.chaquo.python.PyObject.callAttrThrowsNative(Native Method)\nE/AndroidRuntime:   at com.chaquo.python.PyObject.callAttrThrows(PyObject.java:232)\nE/AndroidRuntime:   at com.chaquo.python.PyInvocationHandler.invoke(PyInvocationHandler.java:31)\nE/AndroidRuntime:   at java.lang.reflect.Proxy.invoke(Proxy.java:1006)\nE/AndroidRuntime:   at $Proxy25.onGlobalLayout(Unknown Source)\nE/AndroidRuntime:   at android.view.ViewTreeObserver.dispatchOnGlobalLayout(ViewTreeObserver.java:1061)\nE/AndroidRuntime:   at android.view.ViewRootImpl.performTraversals(ViewRootImpl.java:3197)\nE/AndroidRuntime:   at android.view.ViewRootImpl.doTraversal(ViewRootImpl.java:2126)\nE/AndroidRuntime:   at android.view.ViewRootImpl$TraversalRunnable.run(ViewRootImpl.java:8653)\nE/AndroidRuntime:   at android.view.Choreographer$CallbackRecord.run(Choreographer.java:1037)\nE/AndroidRuntime:   at android.view.Choreographer.doCallbacks(Choreographer.java:845)\nE/AndroidRuntime:   at android.view.Choreographer.doFrame(Choreographer.java:780)\nE/AndroidRuntime:   at android.view.Choreographer$FrameDisplayEventReceiver.run(Choreographer.java:1022)\nE/AndroidRuntime:   at android.os.Handler.handleCallback(Handler.java:938)\nE/AndroidRuntime:   at android.os.Handler.dispatchMessage(Handler.java:99)\nE/AndroidRuntime:   at android.os.Looper.loopOnce(Looper.java:201)\nE/AndroidRuntime:   at android.os.Looper.loop(Looper.java:288)\nE/AndroidRuntime:   at android.app.ActivityThread.main(ActivityThread.java:7839)\nE/AndroidRuntime:   at java.lang.reflect.Method.invoke(Native Method)\nE/AndroidRuntime:   at com.android.internal.os.RuntimeInit$MethodAndArgsCaller.run(RuntimeInit.java:548)\nE/AndroidRuntime:   at com.android.internal.os.ZygoteInit.main(ZygoteInit.java:1003)\n```\nIt's being raised by `asyncio.Event.set()`, called here:\n\nhttps://github.com/beeware/toga/blob/9343e1fc10e951c419571f79b0248b49e347e952/android/tests_backend/probe.py#L13-L19\n\nBut `Event` sets its `_value` to `False` in its [`__init__`](https://github.com/python/cpython/blob/23e3c0ae867cca0130e441e776c9955b9027c510/Lib/asyncio/locks.py#L167-L169):\n\n```python\n    def __init__(self):\n        self._waiters = collections.deque()\n        self._value = False\n```\nSo somehow the `Event` is being told to set its flag before initialization is complete. The first line in its [docs](https://docs.python.org/3/library/asyncio-sync.html#asyncio.Event) mentions it's not thread-safe \u2014 is it being created in the testing thread, but called from the tested app's thread? My testbed knowledge is still pretty sketchy.\nThis is mostly becoming consistent in the recent dependabot PRs 3 times in a row -- #4116, #4117, #4118.\n> So somehow the `Event` is being told to set its flag before initialization is complete. The first line in its [docs](https://docs.python.org/3/library/asyncio-sync.html#asyncio.Event) mentions it's not thread-safe \u2014 is it being created in the testing thread, but called from the tested app's thread? My testbed knowledge is still pretty sketchy.\n\nAll testing functions (fixtures and tests) that are declared async are being forwarded to the main thread.   In testbed/tests/conftest.py there is the logic (see ProxyEventLoop).\n\n> But `Event` sets its `_value` to `False` in its [`__init__`](https://github.com/python/cpython/blob/23e3c0ae867cca0130e441e776c9955b9027c510/Lib/asyncio/locks.py#L167-L169):\n> \n>     def __init__(self):\n>         self._waiters = collections.deque()\n>         self._value = False\n\nTry moving self.event = whatever before `super().__init__()` just in case android calls onGlobalLayout during initialization.  If this doesn't work we'd have to figure out other things...\n> Try moving self.event = whatever before super().**init**() just in case android calls onGlobalLayout during initialization. If this doesn't work we'd have to figure out other things...\n\nDidn't seem to have any effect. : (\nSome possible workarounds/solution directions:\n\n1. Can we just ignore the exception? If this is because of something being fired early, but it's being fired again later, then maybe it won't matter if we ignore one of the firings?\n\n2. Can we put a short pause (or a loop-until-OK delay) after the LayoutListener is created, but *before* it is used? If the issue is that the object is being triggered in a separate thread, maybe we won't get the problem if we wait until we *know* the object is fully instantiated before installing it as a listener.\n\n3. Can we defer installing the listener until we need it? AFAICT, the redraw() method is the only thing using the layout listener, and the first thing it does is requests a layout. If we *create* the listener at startup, but defer adding the listener until it is *used*, that might be enough to ensure that the listener isn't triggered until we need it.\n\n", "all_hints_text": "```\nE/AndroidRuntime: java.lang.IndexOutOfBoundsException: Index: 3, Size: 3\nE/AndroidRuntime:   at java.util.ArrayList.get(ArrayList.java:437)\nE/AndroidRuntime:   at android.view.ViewTreeObserver$CopyOnWriteArray$Access.get(ViewTreeObserver.java:1272)\n```\n\nhttps://stackoverflow.com/questions/67821711 suggests this may be caused by adding or removing a GlobalLayoutListener while the system is iterating through the listener list. We do this in a few places, but the `__del__` method in `BaseProbe` looks like the most likely candidate to happen at an unpredictable time.\n\n```\nE/AndroidRuntime: Caused by: com.chaquo.python.PyException: CoverageWarning: Couldn't import C tracer: No module named 'coverage.tracer' (no-ctracer)\nE/AndroidRuntime:       at <python>.coverage.control._warn(control.py:461)\nE/AndroidRuntime:       at <python>.coverage.core.__init__(core.py:97)\n```\n\nThis looks like a simple case of a warning being raised while Python is set to treat warnings as errors, though I don't know why it would be intermittent.\n\n\"15 more\" is not a truncation, it indicates that the remainder of the low-level exception's stack trace is shared with the high-level exception above the \"Caused by\" line.\n> https://stackoverflow.com/questions/67821711 suggests this may be caused by adding or removing a GlobalLayoutListener while the system is iterating through the listener list. We do this in a few places, but the `__del__` method in `BaseProbe` looks like the most likely candidate to happen at an unpredictable time.\n\nIf nothing else, that should be something we can test - @HalfWhitt If you comment out the `BaseProbe.__del__` method, presumably the app will leak, but it shouldn't *crash*... does that fix the problem for you?\n\nIf it does, the question becomes whether there's any way to put a concurrency lock on removing a listener, or to restructure the way we're handling the listener so that we don't need to add and remove the LayoutListener instance regularly. \n\nOne thought would be to avoid creating a fresh LayoutListener in Probe, and instead add a hook on the LayoutListener that is added as part of the Android implementation of Window. That way we're not adding a fresh listener at the Android level - we're using the same Android listener every time.\nCommenting out `BaseProbe.__del__` does, in fact, prevent the indexing error. However, the testbed then fails consistently with:\n```\n--------- beginning of crash\nE/AndroidRuntime: FATAL EXCEPTION: main\nE/AndroidRuntime: Process: org.beeware.toga.testbed, PID: 1974\nE/AndroidRuntime: com.chaquo.python.PyException: AttributeError: 'Event' object has no attribute '_value'\nE/AndroidRuntime:   at <python>.asyncio.locks.set(locks.py:187)\nE/AndroidRuntime:   at <python>.tests_backend.probe.onGlobalLayout(probe.py:19)\nE/AndroidRuntime:   at <python>.chaquopy_java.call(chaquopy_java.pyx:352)\nE/AndroidRuntime:   at <python>.chaquopy_java.Java_com_chaquo_python_PyObject_callAttrThrowsNative(chaquopy_java.pyx:324)\nE/AndroidRuntime:   at com.chaquo.python.PyObject.callAttrThrowsNative(Native Method)\nE/AndroidRuntime:   at com.chaquo.python.PyObject.callAttrThrows(PyObject.java:232)\nE/AndroidRuntime:   at com.chaquo.python.PyInvocationHandler.invoke(PyInvocationHandler.java:31)\nE/AndroidRuntime:   at java.lang.reflect.Proxy.invoke(Proxy.java:1006)\nE/AndroidRuntime:   at $Proxy25.onGlobalLayout(Unknown Source)\nE/AndroidRuntime:   at android.view.ViewTreeObserver.dispatchOnGlobalLayout(ViewTreeObserver.java:1061)\nE/AndroidRuntime:   at android.view.ViewRootImpl.performTraversals(ViewRootImpl.java:3197)\nE/AndroidRuntime:   at android.view.ViewRootImpl.doTraversal(ViewRootImpl.java:2126)\nE/AndroidRuntime:   at android.view.ViewRootImpl$TraversalRunnable.run(ViewRootImpl.java:8653)\nE/AndroidRuntime:   at android.view.Choreographer$CallbackRecord.run(Choreographer.java:1037)\nE/AndroidRuntime:   at android.view.Choreographer.doCallbacks(Choreographer.java:845)\nE/AndroidRuntime:   at android.view.Choreographer.doFrame(Choreographer.java:780)\nE/AndroidRuntime:   at android.view.Choreographer$FrameDisplayEventReceiver.run(Choreographer.java:1022)\nE/AndroidRuntime:   at android.os.Handler.handleCallback(Handler.java:938)\nE/AndroidRuntime:   at android.os.Handler.dispatchMessage(Handler.java:99)\nE/AndroidRuntime:   at android.os.Looper.loopOnce(Looper.java:201)\nE/AndroidRuntime:   at android.os.Looper.loop(Looper.java:288)\nE/AndroidRuntime:   at android.app.ActivityThread.main(ActivityThread.java:7839)\nE/AndroidRuntime:   at java.lang.reflect.Method.invoke(Native Method)\nE/AndroidRuntime:   at com.android.internal.os.RuntimeInit$MethodAndArgsCaller.run(RuntimeInit.java:548)\nE/AndroidRuntime:   at com.android.internal.os.ZygoteInit.main(ZygoteInit.java:1003)\n```\nIt's being raised by `asyncio.Event.set()`, called here:\n\nhttps://github.com/beeware/toga/blob/9343e1fc10e951c419571f79b0248b49e347e952/android/tests_backend/probe.py#L13-L19\n\nBut `Event` sets its `_value` to `False` in its [`__init__`](https://github.com/python/cpython/blob/23e3c0ae867cca0130e441e776c9955b9027c510/Lib/asyncio/locks.py#L167-L169):\n\n```python\n    def __init__(self):\n        self._waiters = collections.deque()\n        self._value = False\n```\nSo somehow the `Event` is being told to set its flag before initialization is complete. The first line in its [docs](https://docs.python.org/3/library/asyncio-sync.html#asyncio.Event) mentions it's not thread-safe \u2014 is it being created in the testing thread, but called from the tested app's thread? My testbed knowledge is still pretty sketchy.\nThis is mostly becoming consistent in the recent dependabot PRs 3 times in a row -- #4116, #4117, #4118.\n> So somehow the `Event` is being told to set its flag before initialization is complete. The first line in its [docs](https://docs.python.org/3/library/asyncio-sync.html#asyncio.Event) mentions it's not thread-safe \u2014 is it being created in the testing thread, but called from the tested app's thread? My testbed knowledge is still pretty sketchy.\n\nAll testing functions (fixtures and tests) that are declared async are being forwarded to the main thread.   In testbed/tests/conftest.py there is the logic (see ProxyEventLoop).\n\n> But `Event` sets its `_value` to `False` in its [`__init__`](https://github.com/python/cpython/blob/23e3c0ae867cca0130e441e776c9955b9027c510/Lib/asyncio/locks.py#L167-L169):\n> \n>     def __init__(self):\n>         self._waiters = collections.deque()\n>         self._value = False\n\nTry moving self.event = whatever before `super().__init__()` just in case android calls onGlobalLayout during initialization.  If this doesn't work we'd have to figure out other things...\n> Try moving self.event = whatever before super().**init**() just in case android calls onGlobalLayout during initialization. If this doesn't work we'd have to figure out other things...\n\nDidn't seem to have any effect. : (\nSome possible workarounds/solution directions:\n\n1. Can we just ignore the exception? If this is because of something being fired early, but it's being fired again later, then maybe it won't matter if we ignore one of the firings?\n\n2. Can we put a short pause (or a loop-until-OK delay) after the LayoutListener is created, but *before* it is used? If the issue is that the object is being triggered in a separate thread, maybe we won't get the problem if we wait until we *know* the object is fully instantiated before installing it as a listener.\n\n3. Can we defer installing the listener until we need it? AFAICT, the redraw() method is the only thing using the layout listener, and the first thing it does is requests a layout. If we *create* the listener at startup, but defer adding the listener until it is *used*, that might be enough to ensure that the listener isn't triggered until we need it.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/be4f3c76b4f6c301d4c69fd7c1bef65199ba371e", "https://github.com/beeware/toga/commit/1b902871c31b1f20f569ce8d97878ed004d5ab57"], "created_at": "2026-02-23T14:24:44Z"}
{"repo": "beeware/toga", "pull_number": 3691, "instance_id": "beeware__toga-3691", "issue_numbers": [3686], "base_commit": "9eb454ac18ae0662d66e7841717b0df7d34ee9a3", "patch": "diff --git a/changes/3686.bugfix.rst b/changes/3686.bugfix.rst\nnew file mode 100644\nindex 0000000000..9b17c9be86\n--- /dev/null\n+++ b/changes/3686.bugfix.rst\n@@ -0,0 +1,1 @@\n+Running a single-file app without an explicit app name under PDB no longer crashes.\ndiff --git a/core/src/toga/app.py b/core/src/toga/app.py\nindex 7109aacaa6..db9fb1032b 100644\n--- a/core/src/toga/app.py\n+++ b/core/src/toga/app.py\n@@ -214,12 +214,13 @@ def __init__(\n             # `python -m appname`, then __main__.__package__ will be an empty string.\n             #\n             # If the code is contained in appname.py, and you start the app using\n-            # `python appname.py`, then __main__.__package__ will be None.\n+            # `python appname.py`, then __main__.__package__ will be None - unless\n+            # the app has been run under pdb, in which case `__package__` doesn't exist.\n             #\n             # If the code is contained in appname/__main__.py, and you start the app\n             # using `python -m appname`, then __main__.__package__ will be \"appname\".\n             try:\n-                main_module_pkg = sys.modules[\"__main__\"].__package__\n+                main_module_pkg = getattr(sys.modules[\"__main__\"], \"__package__\", None)\n                 if main_module_pkg:\n                     app_name = main_module_pkg\n             except KeyError:\n", "test_patch": "diff --git a/core/tests/app/test_app.py b/core/tests/app/test_app.py\nindex 42bf7bbad0..0dea5eaf58 100644\n--- a/core/tests/app/test_app.py\n+++ b/core/tests/app/test_app.py\n@@ -209,6 +209,19 @@ async def test_unsupported_widget(app):\n             \"org.beeware.explicit-app\",\n             \"override-app\",\n         ),\n+        ###########################################################################\n+        # Invoking as python -m pdb my_app.py.\n+        # This causes a main module of \"my_app\", but `__package__` isn't set.\n+        ###########################################################################\n+        # No app name provided; falls back to app_id\n+        (\n+            EXPLICIT_MIN_APP_KWARGS,\n+            None,\n+            Mock(),\n+            \"Explicit App\",\n+            \"org.beeware.explicit-app\",\n+            \"explicit-app\",\n+        ),\n     ],\n )\n async def test_create(\n", "problem_statement": "app_name logic fails when running under pdb\n### Describe the bug\n\nI \"fixed\" it by adding a handler for AttributeError\n\n```            try:\n                main_module_pkg = sys.modules[\"__main__\"].__package__\n                if main_module_pkg:\n                    app_name = main_module_pkg\n            except KeyError:\n                # If there's no __main__ module, we're probably in a test.\n                pass\n            except AttributeError:\n                # If there's no __package__, try something else\n                pass\n```\n\n### Steps to reproduce\n\n1. run your script using `python -m pdb myscript.py'\n2. start it with 'c'\n\n### Expected behavior\n\nI expect it to run in some way.\n\n### Screenshots\n\n_No response_\n\n### Environment\n\n- Operating System: Windows 10\n- Python version:\n- Software versions:\n  - Toga:\n\n\n\n### Logs\n\n_No response_\n\n### Additional context\n\n_No response_\n", "hints_text": "Hm... I'm not sure why that is, but I'm dropping it here for clarity that you've added that handler to line 228 of app.y, in `App.__init__`.\n\n", "all_hints_text": "Hm... I'm not sure why that is, but I'm dropping it here for clarity that you've added that handler to line 228 of app.y, in `App.__init__`.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/0dab5ed775a1c7db6f5e3252fef1fa8cc355c401", "https://github.com/beeware/toga/commit/49d4065ea606d328a7336db6d260561a498ddec1"], "created_at": "2025-08-11T03:11:53Z"}
{"repo": "beeware/toga", "pull_number": 3694, "instance_id": "beeware__toga-3694", "issue_numbers": [3693], "base_commit": "52f0809b012981e4d75f13e130f1ea889b510010", "patch": "diff --git a/changes/3693.misc.rst b/changes/3693.misc.rst\nnew file mode 100644\nindex 0000000000..88f142c3d4\n--- /dev/null\n+++ b/changes/3693.misc.rst\n@@ -0,0 +1,1 @@\n+Table and example documentation was clarified.\ndiff --git a/docs/reference/api/widgets/table-values.rst b/docs/reference/api/widgets/table-values.rst\nindex 549b06d0c4..b6d77ed502 100644\n--- a/docs/reference/api/widgets/table-values.rst\n+++ b/docs/reference/api/widgets/table-values.rst\n@@ -1,3 +1,7 @@\n+Accessor names (whether explicitly provided, or automatically generated from the header\n+names) should be unique. If they are not, column data will be duplicated, as Toga has no\n+way to tell which version of an accessor to use when populating data for a column.\n+\n The value provided by an accessor is interpreted as follows:\n \n * If the value is a :any:`Widget`, that widget will be displayed in the cell. Note that\ndiff --git a/examples/README.md b/examples/README.md\nindex 4073b9563a..c6d5e75103 100644\n--- a/examples/README.md\n+++ b/examples/README.md\n@@ -7,11 +7,10 @@ It also contains working copies of the tutorial code.\n \n # Running the examples\n \n-Each of the examples should run by installing Toga, and running the\n-application as a Python module:\n-\n+Each of the examples can run by copying the example code to your computer\n+(either by cloning this repository, or by manually duplicating the specific\n+files), installing Toga, and running the application as a Python module:\n ```\n-$ python -m pip install toga\n $ cd <example name>\n $ python -m <example name>\n ```\n", "test_patch": "", "problem_statement": "table display with multiple icons on linux seems broken\n### Describe the bug\n\nHi, am making a conways game of life with three species: wolf, deer and trees. \n\nI am using table display to show a grid with in each cell either a wolf, a deer or a tree. \nHowever, when I display a number of icons in a table the dislay shows them wrongly: each row has only one icon, where there should be several (see screenshot)\n\n<img width=\"623\" height=\"502\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/42e32e98-369a-495c-a68d-824f994feebc\" />\n\n### Steps to reproduce\n\n1. make a beeware project\n2. take my app.py plus toml\n3. install icons\n4. see display of icons in table\n\n[icons.zip](https://github.com/user-attachments/files/21761626/icons.zip)\n\n[code.zip](https://github.com/user-attachments/files/21761632/code.zip)\n\n\n### Expected behavior\n\nthe icons should be in the order the table describes\n\n### Screenshots\n\n_No response_\n\n### Environment\n\n- Operating System: ubunutu 24.x\n- Python version: 3.12\n- Software versions:\n  - Briefcase: 03.24\n  - Toga: latest\n  - ...\n\n\n### Logs\n\n```\n\n```\n\n\n### Additional context\n\n_No response_\n", "hints_text": "\n\n", "all_hints_text": "Thanks for the report; in this case, the problem is an error of usage. \n\nIn your table, you've defined:\n```\nheadings=[\"o\", \"o\", \"o\", \"o\", \"o\", \"o\", \"o\", \"o\", \"o\", \"o\", \"o\", \"o\"]\n```\n\nThat means every heading has the same heading - and thus, the data store that is constructed from your data has a single accessor - `o` - that is used to store and retrieve *all* the data. As a result, it's consistently returning the same data element for each row in a column.\n\nTo fix this, either make the header names unique; or, if for some reason, you want to use the same column name, *also* define a list of `accessors` when constructing your table:\n```\ntoga.Table(\n    headings=['o','o','o','o','o','o'],\n    accessors=[\"a\", \"b\", \"c\", \"d\", \"e\", \"f\"],\n    ...\n```\n(I've stopped at `f` because your data only has 6 columns; the key detail is that the accessor names need to be unique).\n\nAdmittedly, the documentation doesn't say that headers need to be unique (or if they're not, that accessors need to be unique);  I've added a comment clarifying this point in #3694.\nYou made my day, many thanks! That indeed solves it. \n\nI have also opened a bug on your tutorial doc buglist, I am not sure thats the right place so mentioning it here as well. \nhttps://github.com/beeware/beeware-tutorial/issues/2\n\nthanks for your wonderful project! Its something else as a python hacker to be able to make something for an android phone! \n\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/bcc7f1be15840fe230ea4abea9a1ec9ff8810797", "https://github.com/beeware/toga/commit/d786c6621580c864d4af0effb8a411d18d2d568d", "https://github.com/beeware/toga/commit/36cb8ef7986f139934213414405c152e49af10c1", "https://github.com/beeware/toga/commit/024a4777bfb62bcdf5f85d5e50c68a24c9de5728"], "created_at": "2025-08-13T22:44:56Z"}
{"repo": "beeware/toga", "pull_number": 4212, "instance_id": "beeware__toga-4212", "issue_numbers": [3727], "base_commit": "cb701887b60f21b9829c17ff5f1c7984369be716", "patch": "diff --git a/changes/4212.misc.md b/changes/4212.misc.md\nnew file mode 100644\nindex 0000000000..9676c04553\n--- /dev/null\n+++ b/changes/4212.misc.md\n@@ -0,0 +1,1 @@\n+Clarified platform-specific behavior for primary and secondary actions, and documented refresh behavior, in DetailedList.\ndiff --git a/docs/en/reference/api/widgets/detailedlist.md b/docs/en/reference/api/widgets/detailedlist.md\nindex 52a99223d8..061cab0c5e 100644\n--- a/docs/en/reference/api/widgets/detailedlist.md\n+++ b/docs/en/reference/api/widgets/detailedlist.md\n@@ -59,11 +59,23 @@ If the value provided by the title or subtitle accessor is `None`, or the access\n \n The icon accessor should return an [`Icon`][toga.Icon]. If it returns `None`, or the accessor isn't defined, then no icon will be displayed, but space for the icon will remain in the layout.\n \n-Items in a DetailedList can respond to a primary and secondary action. On platforms that use swipe interactions, the primary action will be associated with \"swipe left\", and the secondary action will be associated with \"swipe right\". Other platforms may implement the primary and secondary actions using a different UI interaction (e.g., a right-click context menu). The primary and secondary actions will only be enabled in the DetailedList UI if a handler has been provided.\n+Items in a DetailedList will respond to a primary and secondary action if the `on_primary_action` and `on_secondary_action` handlers are set:\n+\n+* On **Android**, a long press displays a menu with the primary and secondary actions.\n+* On **iOS**, swiping left triggers the primary action, and swiping right triggers the secondary action.\n+* On **GTK**, a right click displays buttons for the primary and secondary actions.\n+* On **macOS**, a right click displays a context menu with the primary and secondary actions.\n+* On **Qt**, the primary and secondary actions are displayed as standalone buttons.\n+* On **Windows**, the implementation does not currently support primary or secondary actions.\n \n By default, the primary and secondary action will be labeled as \"Delete\" and \"Action\", respectively. These names can be overridden by providing a `primary_action` and `secondary_action` argument when constructing the DetailedList. Although the primary action is labeled \"Delete\" by default, the DetailedList will not perform any data deletion as part of the UI interaction. It is the responsibility of the application to implement any data deletion behavior as part of the `on_primary_action` handler.\n \n-The DetailedList as a whole can also respond to a refresh UI action. This is usually implemented as a \"pull down\" action, such as you might see on a social media timeline. This action will only be enabled in the UI if an `on_refresh` handler has been provided.\n+The DetailedList as a whole will also respond to a refresh UI action if an `on_refresh` handler is set:\n+\n+* On **macOS**, **iOS** and **Android**, pulling down at the top of the list triggers a refresh.\n+* On **Qt**, a button bar displays a refresh button.\n+* On **GTK**, a floating refresh button is displayed when scrolled to the top.\n+* On **Windows**, the implementation does not currently support refresh.\n \n ## Notes\n \n", "test_patch": "", "problem_statement": "Android DetailedList doesn't respond to left/right swipes\n### Describe the bug\n\nThe [documentation for DetailedList](https://toga.readthedocs.io/en/stable/reference/api/widgets/detailedlist.html) currently says:\n\n> On platforms that use swipe interactions, the primary action will be associated with \u201cswipe left\u201d, and the secondary action will be associated with \u201cswipe right\u201d. Other platforms may implement the primary and secondary actions using a different UI interaction (e.g., a right-click context menu). The primary and secondary actions will only be enabled in the DetailedList UI if a handler has been provided.\n\nWhile technically correct, this is somewhat misleading for Android. Most people would say that Android is a \"platform that uses swipe interactions\"; but Android implements actions as a pop up menu.\n\n### Steps to reproduce\n\nSee the [documentation for DetailedList](https://toga.readthedocs.io/en/stable/reference/api/widgets/detailedlist.html).\n\n### Expected behavior\n\n1. As an immediate bugfix, the documentation should be updated to better describe which platforms use which UI interaction\n2. Longer term, we should investigate if swipe-based interactions can (or even should) be implemented on Android.\n\n### Screenshots\n\n_No response_\n\n### Environment\n\n- Operating System: Android\n- Python version: All\n- Software versions:\n  - Toga: 0.5.2\n\n\n### Logs\n\n```\n\n```\n\n\n### Additional context\n\nIt's not clear to me from the Material3 guidelines if swipe interactions on a DetailedList would be idiomatic on Android. If it's not, the \"enhancement\" portion of this ticket can be ignored. \n\nFrom a quick API search, it definitely isn't a feature that is easily exposed as an \"on_fling\" handler (or similar) - it looks like it would need a whole RecyclerView infrastructure piece.\n", "hints_text": "can i try this ???\n\nIf you want to clarify the documentation, then you're welcome to create a PR.\n\nIf you want to change the implementation, then please first post a comment describing how you would change it, and your reasoning for doing it that way.\nJust my 2 cents, maybe it clarifies things a bit:\n\nI just found that **swipe** did **not work** for me **on Android**.\n\nMy expectation was that I can swipe the DetailedList entry from left to right (or vice versa) since the term \"swipe\" is mentioned in the Toga documentation **and** \"androidx.**swipe**refreshlayout:**swipe**refreshlayout:1.1.0\" has to be added to the Gradle dependencies for Android.\n\nMy expectation was wrong. **DetailedList on Android does not support swiping.**\n\nThanks to this issue I found that I needed to **long-press** a DetailedList item. When I do it, a dialog with \"Delete\" and \"Action\" opens which correspond to the primary_action_handler and secondary_action_handler.\n\nBased on the issue description, Android uses a popup menu rather than swipe. Can you confirm which other platforms currently implement swipe interactions before I update the docs?\n@tabibeyal Here's a summary of the current behavior:\n\n* Android - Long press displays popup menu.\n* iOS - Swipe\n* GTK - Right click displays buttons for available actions\n* macOS - Right click displays a context menu with available actions\n* QT - buttons for all actions are provided without any additional action\n* Windows - Doesn't currently support actions or delete.\n\nSo... swipe is really only used on iOS. \n\n", "all_hints_text": "can i try this ???\n\nIf you want to clarify the documentation, then you're welcome to create a PR.\n\nIf you want to change the implementation, then please first post a comment describing how you would change it, and your reasoning for doing it that way.\nJust my 2 cents, maybe it clarifies things a bit:\n\nI just found that **swipe** did **not work** for me **on Android**.\n\nMy expectation was that I can swipe the DetailedList entry from left to right (or vice versa) since the term \"swipe\" is mentioned in the Toga documentation **and** \"androidx.**swipe**refreshlayout:**swipe**refreshlayout:1.1.0\" has to be added to the Gradle dependencies for Android.\n\nMy expectation was wrong. **DetailedList on Android does not support swiping.**\n\nThanks to this issue I found that I needed to **long-press** a DetailedList item. When I do it, a dialog with \"Delete\" and \"Action\" opens which correspond to the primary_action_handler and secondary_action_handler.\n\nBased on the issue description, Android uses a popup menu rather than swipe. Can you confirm which other platforms currently implement swipe interactions before I update the docs?\n@tabibeyal Here's a summary of the current behavior:\n\n* Android - Long press displays popup menu.\n* iOS - Swipe\n* GTK - Right click displays buttons for available actions\n* macOS - Right click displays a context menu with available actions\n* QT - buttons for all actions are provided without any additional action\n* Windows - Doesn't currently support actions or delete.\n\nSo... swipe is really only used on iOS. \nAndroid swiping is idiomatic:\n\nhttps://developer.android.com/develop/ui/compose/touch-input/user-interactions/swipe-to-dismiss\n\nAlso FYI and FWIW -- the correct caps is Qt (pronounced cute) instead of QT (typically QuikTrip).  Sorry for pointing this out... I too frequently associate wiht QuikTrip, and go down a wikipedia rabbithole looking up that restaurant chain\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/ec115ea37655e82b679e88a6710e204edb6ca2a9", "https://github.com/beeware/toga/commit/a57b9324a1db73a613a7cec63457f789b14568e2", "https://github.com/beeware/toga/commit/5f517e308f7d7351f6297cbb691f443cd0c7186f", "https://github.com/beeware/toga/commit/db6297ff106ec6f1becbb26045cf4cb242c42eb0", "https://github.com/beeware/toga/commit/3447ca9fc76b20994b1863c090fe6db09ed08f86", "https://github.com/beeware/toga/commit/30a4db4d6aaf36841bdd27f533fda74495c0ae33", "https://github.com/beeware/toga/commit/4e0043aeb54b8261e01026e88140177a59df6c01", "https://github.com/beeware/toga/commit/66bb2b1dc6f5cf55817cc51e4527664cacd3d0fe", "https://github.com/beeware/toga/commit/ba504b1eed0eec74b7a47503b1c704ef7070c2ba", "https://github.com/beeware/toga/commit/4f91edb5c4ae0101c97b44b2ca07f1f9c71f9b01", "https://github.com/beeware/toga/commit/72ed375977ad43ec811d9a746bf879713be19af4", "https://github.com/beeware/toga/commit/ad9fe5ac844f18b5901fc346845ce4ca28efdbb7"], "created_at": "2026-03-01T14:47:53Z"}
{"repo": "beeware/toga", "pull_number": 3751, "instance_id": "beeware__toga-3751", "issue_numbers": [3747], "base_commit": "7c4a689026ebf91c172881c70728b275b242a238", "patch": "diff --git a/android/src/toga_android/widgets/base.py b/android/src/toga_android/widgets/base.py\nindex 567c7507d5..9afebd60b9 100644\n--- a/android/src/toga_android/widgets/base.py\n+++ b/android/src/toga_android/widgets/base.py\n@@ -150,6 +150,17 @@ def set_text_align(self, alignment):\n     def set_color(self, color):\n         pass  # If appropriate, a widget subclass will implement this.\n \n+    def get_theme_color(self, attr_id: int) -> int:\n+        ta = self._native_activity.getTheme().obtainStyledAttributes([attr_id])\n+        try:\n+            if not ta.hasValue(0):\n+                raise RuntimeError(  # pragma: no cover\n+                    f\"Required theme color attribute not found: {attr_id}\"\n+                )\n+            return ta.getColor(0, 0)\n+        finally:\n+            ta.recycle()\n+\n     # INTERFACE\n \n     def add_child(self, child):\ndiff --git a/android/src/toga_android/widgets/detailedlist.py b/android/src/toga_android/widgets/detailedlist.py\nindex 8c1f0bedca..915c7702bd 100644\n--- a/android/src/toga_android/widgets/detailedlist.py\n+++ b/android/src/toga_android/widgets/detailedlist.py\n@@ -8,6 +8,8 @@\n from android.widget import ImageView, LinearLayout, RelativeLayout, ScrollView, TextView\n from java import dynamic_proxy\n \n+from .base import Widget\n+\n try:\n     from androidx.swiperefreshlayout.widget import SwipeRefreshLayout\n except ImportError:  # pragma: no cover\n@@ -16,9 +18,6 @@\n     SwipeRefreshLayout = None\n \n \n-from .base import Widget\n-\n-\n class DetailedListOnClickListener(dynamic_proxy(View.OnClickListener)):\n     def __init__(self, impl, row_number):\n         super().__init__()\n@@ -106,10 +105,7 @@ def create(self):\n                 \"your app's dependencies.\"\n             )\n         # get the selection color from the current theme\n-        attrs = [R.attr.colorControlHighlight]\n-        typed_array = self._native_activity.obtainStyledAttributes(attrs)\n-        self.color_selected = typed_array.getColor(0, 0)\n-        typed_array.recycle()\n+        self.color_selected = self.get_theme_color(R.attr.colorControlHighlight)\n \n         self.native = self._refresh_layout = SwipeRefreshLayout(self._native_activity)\n         self._refresh_layout.setOnRefreshListener(OnRefreshListener(self.interface))\n@@ -180,15 +176,11 @@ def get_string(value):\n         top_text = TextView(self._native_activity)\n         top_text.setText(get_string(title))\n         top_text.setTextSize(20.0)\n-        top_text.setTextColor(\n-            self._native_activity.getResources().getColor(R.color.black)\n-        )\n+        top_text.setTextColor(self.get_theme_color(R.attr.textColorPrimary))\n         bottom_text = TextView(self._native_activity)\n-        bottom_text.setTextColor(\n-            self._native_activity.getResources().getColor(R.color.black)\n-        )\n         bottom_text.setText(get_string(subtitle))\n         bottom_text.setTextSize(16.0)\n+        bottom_text.setTextColor(self.get_theme_color(R.attr.textColorSecondary))\n         top_text_params = LinearLayout.LayoutParams(\n             RelativeLayout.LayoutParams.WRAP_CONTENT,\n             RelativeLayout.LayoutParams.MATCH_PARENT,\ndiff --git a/android/src/toga_android/widgets/table.py b/android/src/toga_android/widgets/table.py\nindex 91a7ecb6eb..93d0bf256c 100644\n--- a/android/src/toga_android/widgets/table.py\n+++ b/android/src/toga_android/widgets/table.py\n@@ -52,10 +52,7 @@ class Table(Widget):\n \n     def create(self):\n         # get the selection color from the current theme\n-        attrs = [R.attr.colorControlHighlight]\n-        typed_array = self._native_activity.obtainStyledAttributes(attrs)\n-        self.color_selected = typed_array.getColor(0, 0)\n-        typed_array.recycle()\n+        self.color_selected = self.get_theme_color(R.attr.colorControlHighlight)\n \n         # add vertical scroll view\n         self.native = vscroll_view = ScrollView(self._native_activity)\ndiff --git a/changes/3751.bugfix.rst b/changes/3751.bugfix.rst\nnew file mode 100644\nindex 0000000000..5772f42bfb\n--- /dev/null\n+++ b/changes/3751.bugfix.rst\n@@ -0,0 +1,1 @@\n+Android: DetailedList now uses theme-resolved text colors (Primary/Secondary) instead of hard-coded black, fixing unreadable text in dark mode.\n", "test_patch": "", "problem_statement": "DetailedList text color hard-coded to black on Android (breaks dark mode)\n### Describe the bug\n\nOn Android, toga.DetailedList item text is rendered in hard-coded black.\nThis makes it unreadable when the app is in dark mode (Theme.Material3.DayNight.NoActionBar).\niOS adapts correctly to system dark/light mode.\nAndroid theme background switches correctly, but list text does not follow.\n\n### Steps to reproduce\n\n1) Set up a Toga app on Android with:\n\nbase_theme = \"Theme.Material3.DayNight.NoActionBar\"\n\n2) Add a DetailedList with a few items.\n\n3) Switch the device/emulator to dark mode.\n\n\n\n### Expected behavior\n\nDetailedList item text should use the theme\u2019s primary/secondary text colors (white-ish in dark mode, black-ish in light mode).\n\n### Screenshots\n\n<img width=\"1053\" height=\"999\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/6b8a64cd-fcf4-4522-aa01-5a07344693a8\" />\n\n<img width=\"1068\" height=\"1011\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/2eea407c-f590-447a-b017-e4ade625c32a\" />\n\n### Environment\n\n- Operating System: macOS 15.6.1\n- Python: 3.13.4\n- Briefcase: 0.3.24\n- Toga: 0.5.2\n\n\n### Logs\n\n```\n\n```\n\n\n### Additional context\n\nhttps://github.com/beeware/toga/tree/main/android/src/toga_android/widgets/detailedlist.py lines 183-185 state:\n```\ntop_text.setTextColor(\n    self._native_activity.getResources().getColor(R.color.black)\n)\n```\nand lines 187-189 state:\n```\nbottom_text.setTextColor(\n    self._native_activity.getResources().getColor(R.color.black)\n) \n```\nPotential fix: Maybe black should be replaced with ?android:attr/textColorPrimary and ?android:attr/textColorSecondary (resolved at runtime).\n", "hints_text": "Thanks for the report ; and your proposed fix of, using a system color rather than hard-coding black would make sense. I'd need to dig into the specifics to see if textColorPrimary/Secondary is an appropriate pair, or if we should just use textColorPrimary for both - but the general idea you're suggesting is definitely sound.\n\nIf you'd like to try your hand at a pull request (and provide screenshots of what the result looks like), we'd be happy to consider the patch.\nI would be glad to have a go at a pull request, and I will look into it as soon as possible.\n\n", "all_hints_text": "Thanks for the report ; and your proposed fix of, using a system color rather than hard-coding black would make sense. I'd need to dig into the specifics to see if textColorPrimary/Secondary is an appropriate pair, or if we should just use textColorPrimary for both - but the general idea you're suggesting is definitely sound.\n\nIf you'd like to try your hand at a pull request (and provide screenshots of what the result looks like), we'd be happy to consider the patch.\nI would be glad to have a go at a pull request, and I will look into it as soon as possible.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/317937dd34c67fb21f88dea7b16104898ba360ca", "https://github.com/beeware/toga/commit/fef6e376301224908a1a7698f5a2e67fc221ad37", "https://github.com/beeware/toga/commit/aa06f393ceec8af72affd194b18f8b6420a0469f", "https://github.com/beeware/toga/commit/5d663032c2d8bf37f7b68a32a07fed662a5371a2", "https://github.com/beeware/toga/commit/e3e46209566694fc33f2646767e6d64cdf69edaf", "https://github.com/beeware/toga/commit/cf2dc87b8f9c8bc5384875c4d151ce3155aca647", "https://github.com/beeware/toga/commit/52989ae40be24371e14acc96fc148b2c7e14e7b0", "https://github.com/beeware/toga/commit/79592a8fc77101d4bb6768f80a3721188ab92728", "https://github.com/beeware/toga/commit/c7a03d6b744e7c77635c224e9b3ab2d6eecc65e5", "https://github.com/beeware/toga/commit/65935bbd1259399bd35ae3557a791f5415852f6f", "https://github.com/beeware/toga/commit/331775698446b1241020ec49e0ffacd7944ad2e9", "https://github.com/beeware/toga/commit/56d0ef70eec6226b9930486ee0b6ea3eb404bf7d", "https://github.com/beeware/toga/commit/80b0fcc62806e76b8f4bad2105c8a19bf16380c9", "https://github.com/beeware/toga/commit/d5d983dd4f9dc7bc0b8c9b8d968605cb9aa73bba"], "created_at": "2025-09-05T21:12:48Z"}
{"repo": "beeware/toga", "pull_number": 3785, "instance_id": "beeware__toga-3785", "issue_numbers": [3783], "base_commit": "c30d08f45f49732002c1813ded65b8344fbd5e84", "patch": "diff --git a/changes/3783.bugfix.rst b/changes/3783.bugfix.rst\nnew file mode 100644\nindex 0000000000..7b209423ce\n--- /dev/null\n+++ b/changes/3783.bugfix.rst\n@@ -0,0 +1,1 @@\n+The show/hide cursor test was made more reliable on Winforms.\n", "test_patch": "diff --git a/winforms/tests_backend/app.py b/winforms/tests_backend/app.py\nindex aaab18ea15..2f9bee05fb 100644\n--- a/winforms/tests_backend/app.py\n+++ b/winforms/tests_backend/app.py\n@@ -82,10 +82,16 @@ class CURSORINFO(ctypes.Structure):\n         if not GetCursorInfo(ctypes.byref(info)):\n             raise RuntimeError(\"GetCursorInfo failed\")\n \n-        # `flags` is 0 or 1 in local testing, but the GitHub Actions runner always\n-        # returns 2 (\"the system is not drawing the cursor because the user is providing\n-        # input through touch or pen instead of the mouse\"). hCursor is more reliable.\n-        return info.hCursor is not None\n+        # Visibility *should* be exposed by CursorInfo.flags; but in CI,\n+        # CursorInfo.flags returns 2 (\"the system is not drawing the cursor\n+        # because the user is providing input through touch or pen instead of\n+        # the mouse\"). In that case, we have to fall back to the backend's\n+        # boolean representation, because there doesn't appear to be any\n+        # more reliable mechanism for determining cursor state.\n+        if info.flags == 2:\n+            return self.app._impl._cursor_visible\n+        else:\n+            return info.flags == 1\n \n     def unhide(self):\n         pytest.xfail(\"This platform doesn't have an app level unhide.\")\n", "problem_statement": "Winforms test failure in CI\n### Describe the bug\n\nThis log gets emitted in every PR CI run recently -- examples of PRs include the Qt backend, Enable keyboard ``activate``, fix font registrations that shadows builtin names.  None of those concerns hiding or showing cursors and/or Winforms.\n\n```\n================================== FAILURES ===================================\n____________________________ test_show_hide_cursor ____________________________\nTraceback (most recent call last):\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\_pytest\\runner.py\", line 344, in from_call\n    result: TResult | None = func()\n                             ^^^^^^\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\_pytest\\runner.py\", line 246, in <lambda>\n    lambda: runtest_hook(item=item, **kwds), when=when, reraise=reraise\n            ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_hooks.py\", line 512, in __call__\n    return self._hookexec(self.name, self._hookimpls.copy(), kwargs, firstresult)\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_manager.py\", line 120, in _hookexec\n    return self._inner_hookexec(hook_name, methods, kwargs, firstresult)\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_callers.py\", line 167, in _multicall\n    raise exception\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_callers.py\", line 139, in _multicall\n    teardown.throw(exception)\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\_pytest\\logging.py\", line 850, in pytest_runtest_call\n    yield\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_callers.py\", line 139, in _multicall\n    teardown.throw(exception)\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\_pytest\\capture.py\", line 900, in pytest_runtest_call\n    return (yield)\n            ^^^^^\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_callers.py\", line 139, in _multicall\n    teardown.throw(exception)\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\_pytest\\skipping.py\", line 263, in pytest_runtest_call\n    return (yield)\n            ^^^^^\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_callers.py\", line 121, in _multicall\n    res = hook_impl.function(*args)\n          ^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\_pytest\\runner.py\", line 178, in pytest_runtest_call\n    item.runtest()\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pytest_asyncio\\plugin.py\", line 474, in runtest\n    super().runtest()\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\_pytest\\python.py\", line 1671, in runtest\n    self.ihook.pytest_pyfunc_call(pyfuncitem=self)\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_hooks.py\", line 512, in __call__\n    return self._hookexec(self.name, self._hookimpls.copy(), kwargs, firstresult)\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_manager.py\", line 120, in _hookexec\n    return self._inner_hookexec(hook_name, methods, kwargs, firstresult)\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_callers.py\", line 167, in _multicall\n    raise exception\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_callers.py\", line 139, in _multicall\n    teardown.throw(exception)\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_callers.py\", line 53, in run_old_style_hookwrapper\n    return result.get_result()\n           ^^^^^^^^^^^^^^^^^^^\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_result.py\", line 103, in get_result\n    raise exc.with_traceback(tb)\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_callers.py\", line 38, in run_old_style_hookwrapper\n    res = yield\n          ^^^^^\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pluggy\\_callers.py\", line 121, in _multicall\n    res = hook_impl.function(*args)\n          ^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\_pytest\\python.py\", line 157, in pytest_pyfunc_call\n    result = testfunction(**testargs)\n             ^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app_packages\\pytest_asyncio\\plugin.py\", line 721, in inner\n    runner.run(coro, context=context)\n  File \"asyncio\\runners.py\", line 118, in run\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app\\tests\\conftest.py\", line 167, in run_until_complete\n    return asyncio.run_coroutine_threadsafe(coro, self.loop).result()\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"concurrent\\futures\\_base.py\", line 456, in result\n  File \"concurrent\\futures\\_base.py\", line 401, in __get_result\n  File \"D:\\a\\toga\\toga\\testbed\\build\\testbed\\windows\\app\\src\\app\\tests\\app\\test_desktop.py\", line 508, in test_show_hide_cursor\n    assert app_probe.is_cursor_visible\nAssertionError: assert False\n +  where False = <tests_backend.app.AppProbe object at 0x000001D6A896A300>.is_cursor_visible\n=========================== short test summary info ===========================\nFAILED tests\\app\\test_desktop.py::test_show_hide_cursor - assert False\n +  where False = <tests_backend.app.AppProbe object at 0x000001D6A896A300>.is_cursor_visible\n====== 1 failed, 578 passed, 31 skipped, 7 xfailed in 438.46s (0:07:18) =======\n\n[testbed] Test suite failed!\nSaving log... started\n\nLog saved to D:\\a\\toga\\toga\\testbed\\logs\\briefcase.2025_09_28-19_04_58.run.log\n\nSaving log... done\nError: Process completed with exit code 232.\n```\n\n### Steps to reproduce\n\n1. Open a PR with appropriate linting and changenotes\n2. See error\n\n### Expected behavior\n\nNo testbed fail\n\n### Screenshots\n\n_No response_\n\n### Environment\n\nGithub runner settings\n\n### Logs\n\n```\n\n```\n\n\n### Additional context\n\n_No response_\n", "hints_text": "Most likely hypothesis:  GitHub is in the middle of switching to a new Windows build with slightly different things and they're gradually rolling out this new version\n\nThat said:  I have no idea how to debug Windows stuff.\n\n", "all_hints_text": "Thanks for the report. Confirming I saw this a couple of times last week, but chalked it up to an intermittent problem. It looks like it is a very repeatable issue, though. Not sure what has changed in the interim to make this happen.\n\nEDIT: it definitely *is* repeatable....\nMost likely hypothesis:  GitHub is in the middle of switching to a new Windows build with slightly different things and they're gradually rolling out this new version\n\nThat said:  I have no idea how to debug Windows stuff.\nAnother data point: https://github.com/beeware/toga/pull/3784\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/c0e58fce4d35a4ffd419126a49ad97d72b6b06a3", "https://github.com/beeware/toga/commit/1479f4638aa1468af060e37dc03c0d484ef59c3e", "https://github.com/beeware/toga/commit/f6f9872d71ad0b2e7051ccc332c0e8b0e5ca16dc"], "created_at": "2025-09-29T00:01:43Z"}
{"repo": "beeware/toga", "pull_number": 3793, "instance_id": "beeware__toga-3793", "issue_numbers": [3787], "base_commit": "e4276575818386bf06eb3dc90061c23a941942f8", "patch": "diff --git a/changes/3787.bugfix.rst b/changes/3787.bugfix.rst\nnew file mode 100644\nindex 0000000000..81202da255\n--- /dev/null\n+++ b/changes/3787.bugfix.rst\n@@ -0,0 +1,1 @@\n+OptionContainer and ScrollContainer widgets will now resize continuously during the drag of a parent SplitContainer on macOS.\ndiff --git a/cocoa/src/toga_cocoa/widgets/optioncontainer.py b/cocoa/src/toga_cocoa/widgets/optioncontainer.py\nindex d8668fd357..aaaa69189a 100644\n--- a/cocoa/src/toga_cocoa/widgets/optioncontainer.py\n+++ b/cocoa/src/toga_cocoa/widgets/optioncontainer.py\n@@ -1,6 +1,6 @@\n import warnings\n \n-from rubicon.objc import SEL, objc_method\n+from rubicon.objc import objc_method\n from travertino.size import at_least\n \n from toga_cocoa.container import Container\n@@ -58,11 +58,10 @@ def set_bounds(self, x, y, width, height):\n         super().set_bounds(x, y, width, height)\n \n         # Setting the bounds changes the constraints, but that doesn't mean\n-        # the constraints have been fully applied. Schedule a refresh to be done\n-        # as soon as possible in the future\n-        self.native.performSelector(\n-            SEL(\"refreshContent\"), withObject=None, afterDelay=0\n-        )\n+        # the constraints have been fully applied. Force realization of the\n+        # new layout, and then refresh the content.\n+        self.interface.window._impl.native.layoutIfNeeded()\n+        self.native.refreshContent()\n \n     def content_refreshed(self, container):\n         container.min_width = container.content.interface.layout.min_width\ndiff --git a/cocoa/src/toga_cocoa/widgets/scrollcontainer.py b/cocoa/src/toga_cocoa/widgets/scrollcontainer.py\nindex 40721bdeee..7fab4a80bb 100644\n--- a/cocoa/src/toga_cocoa/widgets/scrollcontainer.py\n+++ b/cocoa/src/toga_cocoa/widgets/scrollcontainer.py\n@@ -75,11 +75,10 @@ def set_bounds(self, x, y, width, height):\n         super().set_bounds(x, y, width, height)\n \n         # Setting the bounds changes the constraints, but that doesn't mean\n-        # the constraints have been fully applied. Schedule a refresh to be done\n-        # as soon as possible in the future\n-        self.native.performSelector(\n-            SEL(\"refreshContent\"), withObject=None, afterDelay=0\n-        )\n+        # the constraints have been fully applied. Force realization of the\n+        # new layout, and then refresh the content.\n+        self.interface.window._impl.native.layoutIfNeeded()\n+        self.native.refreshContent()\n \n     def content_refreshed(self, container):\n         width = self.native.frame.size.width\n", "test_patch": "", "problem_statement": "Delay in update of SplitContainer width on macOS\n### Describe the bug\n\nThis is by pip-installing everything with the target option into the directory of a fresh compiled CPython on macOS Tahoe and running ./python.exe -m toga_demo we get\n\nhttps://github.com/user-attachments/assets/45cf39c0-75e4-4447-86ba-0f7b9a09b112\n\nthe width updating of the layout is sort of slow...\n\n### Steps to reproduce\n\nSee overview section: pip-installing everything with the target option into the directory of a fresh compiled CPython on macOS Tahoe and running ./python.exe -m toga_demo.\n\n### Expected behavior\n\nWidth of layouts on the two sides updating instantly\n\n### Screenshots\n\n_No response_\n\n### Environment\n\nmacOS Tahoe, Python 3.13.7, latest packages off of PyPI\n\n### Logs\n\n_No response_\n\n### Additional context\n\nSeems that Chrome has a slightly analogous issue however this is nowhere near enough to pinpoint that it's the same API call -- Chrome's resizing layout *eventually* updates to the correct width when you *don't* Let it go [EDITED HERE -- clarity] but not immediate either.  All I'm saying is that Tahoe is making layout really hard on non-cocoa-layouting devs...\n\nhttps://github.com/user-attachments/assets/70d8b02d-94ce-46f1-a175-5214f70b07a5\n", "hints_text": "This isn't a Tahoe-specific issue - I can reproduce this on Sequoia. \n\nIn terms of the mechanics of what is going on - you can see that the underlying geometry calculations are being passed down to the OptionContainer and ScrollContainer that are the most immediate children of the SplitContainer; but the resize request on the OptionContainer isn't being passed down to the Table that is a child of the OptionContainer until the resize *ends* and the final child size propagates. \n\nThe fix will be working out how to either:\n1. propegate the size change to the child widget *during* the drag; or\n2. construct the native constraints in such a way that they respond automatically to the resize.\n@freakboy3742 I have this solution\n\n```patch\ndiff --git a/cocoa/src/toga_cocoa/widgets/optioncontainer.py b/cocoa/src/toga_cocoa/widgets/optioncontainer.py\nindex d8668fd35..426b6c3c5 100644\n--- a/cocoa/src/toga_cocoa/widgets/optioncontainer.py\n+++ b/cocoa/src/toga_cocoa/widgets/optioncontainer.py\n@@ -56,13 +56,12 @@ class OptionContainer(Widget):\n \n     def set_bounds(self, x, y, width, height):\n         super().set_bounds(x, y, width, height)\n-\n+        \n         # Setting the bounds changes the constraints, but that doesn't mean\n-        # the constraints have been fully applied. Schedule a refresh to be done\n-        # as soon as possible in the future\n-        self.native.performSelector(\n-            SEL(\"refreshContent\"), withObject=None, afterDelay=0\n-        )\n+        # the constraints have been fully applied. Force realization of the\n+        # new layout, and then refresh the content.\n+        self.interface.window._impl.native.layoutIfNeeded()\n+        self.native.refreshContent()\n \n     def content_refreshed(self, container):\n         container.min_width = container.content.interface.layout.min_width\ndiff --git a/cocoa/src/toga_cocoa/widgets/scrollcontainer.py b/cocoa/src/toga_cocoa/widgets/scrollcontainer.py\nindex 40721bdee..7fab4a80b 100644\n--- a/cocoa/src/toga_cocoa/widgets/scrollcontainer.py\n+++ b/cocoa/src/toga_cocoa/widgets/scrollcontainer.py\n@@ -75,11 +75,10 @@ class ScrollContainer(Widget):\n         super().set_bounds(x, y, width, height)\n \n         # Setting the bounds changes the constraints, but that doesn't mean\n-        # the constraints have been fully applied. Schedule a refresh to be done\n-        # as soon as possible in the future\n-        self.native.performSelector(\n-            SEL(\"refreshContent\"), withObject=None, afterDelay=0\n-        )\n+        # the constraints have been fully applied. Force realization of the\n+        # new layout, and then refresh the content.\n+        self.interface.window._impl.native.layoutIfNeeded()\n+        self.native.refreshContent()\n \n     def content_refreshed(self, container):\n         width = self.native.frame.size.width\n```\n\nI don't have quite enough time to actually make a PR, this is done like in 2 5-minute breaks.  The issue is that if you use afterDelay, moving the split location will block, making it not run before the resize actually finish.\n\nAre you okay with the layoutIfNeeded approach?\n\nIf so: anyone who sees this issue can make a PR with my patch, I give you permission to do that as long as the final commit as Co-Authored-By: johnzhou721 <[USERNAME] at [Google mail] dot com> flag on it.  If I'm not that busy I may pull a request.\nAlso should we be testing this?  AFAIK there's no way to simulate a \"user drag\" that would block like this...\n> Are you okay with the layoutIfNeeded approach?\n\nThe approach is definitely acceptable, assuming it works. The `performSelector` based approach was very deliberate, so I'd be surprised if this simplification works in the general case. However, calling `layoutIfNeeded()` before dispatching the `refreshContent` message should have the same net effect.\n\n> If so: anyone who sees this issue can make a PR with my patch, I give you permission to do that as long as the final commit as Co-Authored-By: johnzhou721 <[USERNAME] at [Google mail] dot com> flag on it. If I'm not that busy I may pull a request.\n\nThere is nothing sufficiently urgent about this issue that it can't wait until you've got enough time to compose it as a PR. *Not* posting it as a PR is actually generating more work. In future, I'd suggest waiting a couple of hours/days until you can composed a proposed modification as a formal PR, rather than racing to submit a diff.\n\n> Also should we be testing this? AFAIK there's no way to simulate a \"user drag\" that would block like this...\n\nIdeally, yes, we'd be testing; but pragmatically, I don't know that I have a good way to do so - so as long as the existing testbed tests pass, that's fine.\n\n", "all_hints_text": "This isn't a Tahoe-specific issue - I can reproduce this on Sequoia. \n\nIn terms of the mechanics of what is going on - you can see that the underlying geometry calculations are being passed down to the OptionContainer and ScrollContainer that are the most immediate children of the SplitContainer; but the resize request on the OptionContainer isn't being passed down to the Table that is a child of the OptionContainer until the resize *ends* and the final child size propagates. \n\nThe fix will be working out how to either:\n1. propegate the size change to the child widget *during* the drag; or\n2. construct the native constraints in such a way that they respond automatically to the resize.\n@freakboy3742 I have this solution\n\n```patch\ndiff --git a/cocoa/src/toga_cocoa/widgets/optioncontainer.py b/cocoa/src/toga_cocoa/widgets/optioncontainer.py\nindex d8668fd35..426b6c3c5 100644\n--- a/cocoa/src/toga_cocoa/widgets/optioncontainer.py\n+++ b/cocoa/src/toga_cocoa/widgets/optioncontainer.py\n@@ -56,13 +56,12 @@ class OptionContainer(Widget):\n \n     def set_bounds(self, x, y, width, height):\n         super().set_bounds(x, y, width, height)\n-\n+        \n         # Setting the bounds changes the constraints, but that doesn't mean\n-        # the constraints have been fully applied. Schedule a refresh to be done\n-        # as soon as possible in the future\n-        self.native.performSelector(\n-            SEL(\"refreshContent\"), withObject=None, afterDelay=0\n-        )\n+        # the constraints have been fully applied. Force realization of the\n+        # new layout, and then refresh the content.\n+        self.interface.window._impl.native.layoutIfNeeded()\n+        self.native.refreshContent()\n \n     def content_refreshed(self, container):\n         container.min_width = container.content.interface.layout.min_width\ndiff --git a/cocoa/src/toga_cocoa/widgets/scrollcontainer.py b/cocoa/src/toga_cocoa/widgets/scrollcontainer.py\nindex 40721bdee..7fab4a80b 100644\n--- a/cocoa/src/toga_cocoa/widgets/scrollcontainer.py\n+++ b/cocoa/src/toga_cocoa/widgets/scrollcontainer.py\n@@ -75,11 +75,10 @@ class ScrollContainer(Widget):\n         super().set_bounds(x, y, width, height)\n \n         # Setting the bounds changes the constraints, but that doesn't mean\n-        # the constraints have been fully applied. Schedule a refresh to be done\n-        # as soon as possible in the future\n-        self.native.performSelector(\n-            SEL(\"refreshContent\"), withObject=None, afterDelay=0\n-        )\n+        # the constraints have been fully applied. Force realization of the\n+        # new layout, and then refresh the content.\n+        self.interface.window._impl.native.layoutIfNeeded()\n+        self.native.refreshContent()\n \n     def content_refreshed(self, container):\n         width = self.native.frame.size.width\n```\n\nI don't have quite enough time to actually make a PR, this is done like in 2 5-minute breaks.  The issue is that if you use afterDelay, moving the split location will block, making it not run before the resize actually finish.\n\nAre you okay with the layoutIfNeeded approach?\n\nIf so: anyone who sees this issue can make a PR with my patch, I give you permission to do that as long as the final commit as Co-Authored-By: johnzhou721 <[USERNAME] at [Google mail] dot com> flag on it.  If I'm not that busy I may pull a request.\nAlso should we be testing this?  AFAIK there's no way to simulate a \"user drag\" that would block like this...\n> Are you okay with the layoutIfNeeded approach?\n\nThe approach is definitely acceptable, assuming it works. The `performSelector` based approach was very deliberate, so I'd be surprised if this simplification works in the general case. However, calling `layoutIfNeeded()` before dispatching the `refreshContent` message should have the same net effect.\n\n> If so: anyone who sees this issue can make a PR with my patch, I give you permission to do that as long as the final commit as Co-Authored-By: johnzhou721 <[USERNAME] at [Google mail] dot com> flag on it. If I'm not that busy I may pull a request.\n\nThere is nothing sufficiently urgent about this issue that it can't wait until you've got enough time to compose it as a PR. *Not* posting it as a PR is actually generating more work. In future, I'd suggest waiting a couple of hours/days until you can composed a proposed modification as a formal PR, rather than racing to submit a diff.\n\n> Also should we be testing this? AFAIK there's no way to simulate a \"user drag\" that would block like this...\n\nIdeally, yes, we'd be testing; but pragmatically, I don't know that I have a good way to do so - so as long as the existing testbed tests pass, that's fine.\n@freakboy3742 I've came up with an approach for testing -- let's continue the discussion on the PR I opened.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/e8301dcc537489db3d6ae6666c8048d3d95a9d9d", "https://github.com/beeware/toga/commit/262bc49e50d6941f53ea3e6da7a96481a2fc5b18", "https://github.com/beeware/toga/commit/cba8602dd32d821ad15fb36819af3404ae306a7b", "https://github.com/beeware/toga/commit/0837c3d800d7388ed5deca2df7b204ef85824dbe", "https://github.com/beeware/toga/commit/d279fb22938ba09ee2901d4f72528e755311b40c"], "created_at": "2025-10-08T02:22:26Z"}
{"repo": "beeware/toga", "pull_number": 3836, "instance_id": "beeware__toga-3836", "issue_numbers": [3818], "base_commit": "c7e2c7fbb5b97b97a8405f9449b53c83f5b84831", "patch": "diff --git a/changes/3818.doc.md b/changes/3818.doc.md\nnew file mode 100644\nindex 0000000000..ae3d7ed24b\n--- /dev/null\n+++ b/changes/3818.doc.md\n@@ -0,0 +1,1 @@\n+The links on the APIs by platform docs page have been standardized to match their equivalents in the main API reference index: plain text rather than code-formatted, and linking to the top of their respective pages rather than to anchors for the specific classes.\ndiff --git a/changes/3836.misc.md b/changes/3836.misc.md\nnew file mode 100644\nindex 0000000000..fd1ae887ab\n--- /dev/null\n+++ b/changes/3836.misc.md\n@@ -0,0 +1,1 @@\n+The information and display mechanisms relating to API components have been consolidated, to ease maintenance and reduce likelihood of drift.\ndiff --git a/docs/config.yml b/docs/config.yml\nindex 08b77ced0d..44663c39bc 100644\n--- a/docs/config.yml\n+++ b/docs/config.yml\n@@ -93,7 +93,6 @@ plugins:\n   literate-nav:\n        nav_file: SUMMARY.md\n   macros: {}\n-  table-reader: {}\n   mkdocstrings:\n       enable_inventory: true\n       default_handler: python\ndiff --git a/docs/en/reference/api/app.md b/docs/en/reference/api/app.md\nindex df589f9b1d..2491b0a501 100644\n--- a/docs/en/reference/api/app.md\n+++ b/docs/en/reference/api/app.md\n@@ -1,11 +1,4 @@\n-# App\n-\n-The top-level representation of an application.\n-\n-Availability ([Key][api-status-key])  <!-- rumdl-disable-line MD013 -->\n-{: .availability-title }\n-\n-{{ pd_read_csv(\"../data/widgets_by_platform.csv\", na_filter=False, usecols=[4,5,6,7,8,9,10])[pd_read_csv(\"../data/widgets_by_platform.csv\")[[\"ComponentName\"]].isin([\"Application\"]).all(axis=1)] | convert_to_md_table }}\n+{{ component_header(\"App\") }}\n \n ## Usage\n \ndiff --git a/docs/en/reference/api/constants.md b/docs/en/reference/api/constants.md\nindex 4c09ca5e17..06486d859c 100644\n--- a/docs/en/reference/api/constants.md\n+++ b/docs/en/reference/api/constants.md\n@@ -1,4 +1,6 @@\n-# Constants\n+{{ component_header(\"Constants\") }}\n+\n+## Reference\n \n ::: toga.constants\n     options:\ndiff --git a/docs/en/reference/api/containers/box.md b/docs/en/reference/api/containers/box.md\nindex cba5676d2c..6e62140166 100644\n--- a/docs/en/reference/api/containers/box.md\n+++ b/docs/en/reference/api/containers/box.md\n@@ -1,11 +1,4 @@\n-# Box\n-\n-A generic container for other widgets. Used to construct layouts.\n-\n-Availability ([Key][api-status-key])  <!-- rumdl-disable-line MD013 -->\n-{: .availability-title }\n-\n-{{ pd_read_csv(\"../../data/widgets_by_platform.csv\", na_filter=False, usecols=[4,5,6,7,8,9,10])[pd_read_csv(\"../../data/widgets_by_platform.csv\")[[\"ComponentName\"]].isin([\"Box\"]).all(axis=1)] | convert_to_md_table }}\n+{{ component_header(\"Box\") }}\n \n ## Usage\n \ndiff --git a/docs/en/reference/api/containers/optioncontainer.md b/docs/en/reference/api/containers/optioncontainer.md\nindex 6846691571..c0bf0f7e17 100644\n--- a/docs/en/reference/api/containers/optioncontainer.md\n+++ b/docs/en/reference/api/containers/optioncontainer.md\n@@ -1,78 +1,4 @@\n-# OptionContainer\n-\n-A container that can display multiple labeled tabs of content.\n-\n-/// tab | macOS\n-\n-![/reference/images/optioncontainer-cocoa.png](/reference/images/optioncontainer-cocoa.png){ width=\"450\" }\n-\n-/// caption\n-\n-///\n-\n-<!-- TODO: Update alt text -->\n-\n-///\n-\n-/// tab | Linux\n-\n-![/reference/images/optioncontainer-gtk.png](/reference/images/optioncontainer-gtk.png){ width=\"450\" }\n-\n-/// caption\n-\n-///\n-\n-<!-- TODO: Update alt text -->\n-\n-///\n-\n-/// tab | Windows\n-\n-![/reference/images/optioncontainer-winforms.png](/reference/images/optioncontainer-winforms.png){ width=\"450\" }\n-\n-/// caption\n-\n-///\n-\n-<!-- TODO: Update alt text -->\n-\n-///\n-\n-/// tab | Android\n-\n-![/reference/images/optioncon