+    def _get_vars(self) -> list[Var]:
+        """Walk all Vars used in this component, including those in match cases.
+
+        Returns:
+            Each var referenced by the component and its match cases.
+        """
+        vars = super()._get_vars()
+
+        # Collect vars from all match cases
+        for case in self.match_cases:
+            for element in case:
+                if isinstance(element, BaseVar):
+                    vars.append(element)
+                elif isinstance(element, BaseComponent):
+                    # Recursively collect vars from the component
+                    vars.extend(self._collect_vars_from_component(element))
+
+        # Collect vars from default case
+        if isinstance(self.default, BaseVar):
+            vars.append(self.default)
+        elif isinstance(self.default, BaseComponent):
+            vars.extend(self._collect_vars_from_component(self.default))
+
+        return vars
+
+    def _collect_vars_from_component(self, component: BaseComponent) -> list[Var]:
+        """Recursively collect vars from a component and its children.
+
+        Args:
+            component: The component to collect vars from.
+
+        Returns:
+            List of vars from the component and its children.
+        """
+        vars = []
+
+        # Collect vars from the component itself
+        vars.extend(component._get_vars())
+
+        # If the component has children, recursively collect vars from them
+        if hasattr(component, 'children') and component.children:
+            for child in component.children:
+                if isinstance(child, BaseVar):
+                    vars.append(child)
+                elif isinstance(child, BaseComponent):
+                    vars.extend(self._collect_vars_from_component(child))
+
+        return vars
