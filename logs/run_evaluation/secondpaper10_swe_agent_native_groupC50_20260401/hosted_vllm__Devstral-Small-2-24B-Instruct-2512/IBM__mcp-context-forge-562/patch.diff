+    @field_validator("gateway_protocol", mode="before")
+    @classmethod
+    def _validate_gateway_protocol(cls, v):
+        """Validate gateway_protocol setting.
+
+        Args:
+            v: The protocol value to validate.
+
+        Returns:
+            str: Validated protocol string.
+
+        Raises:
+            ValueError: If protocol is not one of the valid options.
