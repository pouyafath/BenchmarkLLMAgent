ew_command.build_gui_context.assert_called_once_with(mock.ANY, {})\n \n     # Template is updated\n     assert new_command.update_cookiecutter_cache.mock_calls == [\n@@ -281,14 +287,14 @@ def test_new_app_with_template(monkeypatch, new_command, tmp_path):\n         \"app_name\": \"myapplication\",\n     }\n     new_command.build_app_context = mock.MagicMock(return_value=app_context)\n-    bootstrap = BaseGuiBootstrap(new_command.console, {})\n-    new_command.create_bootstrap = mock.MagicMock(return_value=bootstrap)\n+    new_command.select_bootstrap = mock.MagicMock(return_value=BaseGuiBootstrap)\n     new_command.build_gui_context = mock.MagicMock(\n         return_value={\n             \"app_source\": \"main()\",\n             \"pyproject_requires\": \"toga\",\n         }\n     )\n+\n     new_command.update_cookiecutter_cache = mock.MagicMock(\n         return_value=\"https://example.com/other.git\"\n     )\n@@ -298,9 +304,9 @@ def test_new_app_with_template(monkeypatch, new_command, tmp_path):\n     new_command.new_app(template=\"https://example.com/other.git\", project_overrides={})\n \n     # App context is constructed\n+    new_command.select_bootstrap.assert_called_once_with({})\n     new_command.build_app_context.assert_called_once_with({})\n-    new_command.create_bootstrap.assert_called_once_with(app_context, {})\n-    new_command.build_gui_context.assert_called_once_with(bootstrap, {})\n+    new_command.build_gui_context.assert_called_once_with(mock.ANY, {})\n \n     # Template is updated\n     new_command.update_cookiecutter_cache.assert_called_once_with(\n@@ -339,14 +345,14 @@ def test_new_app_with_invalid_template(monkeypatch, new_command, tmp_path):\n         \"app_name\": \"myapplication\",\n     }\n     new_command.build_app_context = mock.MagicMock(return_value=app_context)\n-    bootstrap = BaseGuiBootstrap(new_command.console, {})\n-    new_command.create_bootstrap = mock.MagicMock(return_value=bootstrap)\n+    new_command.select_bootstrap = mock.MagicMock(return_value=BaseGuiBootstrap)\n     new_command.build_gui_context = mock.MagicMock(\n         return_value={\n             \"app_source\": \"main()\",\n             \"pyproject_requires\": \"toga\",\n         }\n     )\n+\n     new_command.update_cookiecutter_cache = mock.MagicMock(\n         return_value=\"https://example.com/other.git\"\n     )\n@@ -366,8 +372,8 @@ def test_new_app_with_invalid_template(monkeypatch, new_command, tmp_path):\n \n     # App context is constructed\n     new_command.build_app_context.assert_called_once_with({})\n-    new_command.create_bootstrap.assert_called_once_with(app_context, {})\n-    new_command.build_gui_context.assert_called_once_with(bootstrap, {})\n+    new_command.select_bootstrap.assert_called_once_with({})\n+    new_command.build_gui_context.assert_called_once_with(mock.ANY, {})\n \n     # Template is updated\n     new_command.update_cookiecutter_cache.assert_called_once_with(\n@@ -407,14 +413,15 @@ def test_new_app_with_invalid_template_branch(monkeypatch, new_command, tmp_path\n         \"app_name\": \"myapplication\",\n     }\n     new_command.build_app_context = mock.MagicMock(return_value=app_context)\n-    bootstrap = BaseGuiBootstrap(new_command.console, {})\n-    new_command.create_bootstrap = mock.MagicMock(return_value=bootstrap)\n+\n+    new_command.select_bootstrap = mock.MagicMock(return_value=BaseGuiBootstrap)\n     new_command.build_gui_context = mock.MagicMock(\n         return_value={\n             \"app_source\": \"main()\",\n             \"pyproject_requires\": \"toga\",\n         }\n     )\n+\n     new_command.update_cookiecutter_cache = mock.MagicMock(\n         return_value=\"https://example.com/other.git\"\n     )\n@@ -433,9 +440,9 @@ def test_new_app_with_invalid_template_branch(monkeypatch, new_command, tmp_path\n         )\n \n     # App context is constructed\n+    new_command.select_bootstrap.assert_called_once_with({})\n     new_command.build_app_context.assert_called_once_with({})\n-    new_command.create_bootstrap.assert_called_once_with(app_context, {})\n-    new_command.build_gui_context.assert_called_once_with(bootstrap, {})\n+    new_command.build_gui_context.assert_called_once_with(mock.ANY, {})\n \n     # Template is updated\n     new_command.update_cookiecutter_cache.assert_called_once_with(\n@@ -475,14 +482,14 @@ def test_new_app_with_branch(monkeypatch, new_command, tmp_path):\n         \"app_name\": \"myapplication\",\n     }\n     new_command.build_app_context = mock.MagicMock(return_value=app_context)\n-    bootstrap = BaseGuiBootstrap(new_command.console, {})\n-    new_command.create_bootstrap = mock.MagicMock(return_value=bootstrap)\n+    new_command.select_bootstrap = mock.MagicMock(return_value=BaseGuiBootstrap)\n     new_command.build_gui_context = mock.MagicMock(\n         return_value={\n             \"app_source\": \"main()\",\n             \"pyproject_requires\": \"toga\",\n         }\n     )\n+\n     new_command.update_cookiecutter_cache = mock.MagicMock(\n         return_value=\"https://example.com/other.git\"\n     )\n@@ -492,9 +499,9 @@ def test_new_app_with_branch(monkeypatch, new_command, tmp_path):\n     new_command.new_app(template_branch=\"experimental\", project_overrides={})\n \n     # App context is constructed\n+    new_command.select_bootstrap.assert_called_once_with({})\n     new_command.build_app_context.assert_called_once_with({})\n-    new_command.create_bootstrap.assert_called_once_with(app_context, {})\n-    new_command.build_gui_context.assert_called_once_with(bootstrap, {})\n+    new_command.build_gui_context.assert_called_once_with(mock.ANY, {})\n \n     # Template is updated\n     new_command.update_cookiecutter_cache.assert_called_once_with(\n@@ -538,14 +545,14 @@ def test_new_app_unused_project_overrides(\n         \"app_name\": \"myapplication\",\n     }\n     new_command.build_app_context = mock.MagicMock(return_value=app_context)\n-    bootstrap = BaseGuiBootstrap(new_command.console, {})\n-    new_command.create_bootstrap = mock.MagicMock(return_value=bootstrap)\n+    new_command.select_bootstrap = mock.MagicMock(return_value=BaseGuiBootstrap)\n     new_command.build_gui_context = mock.MagicMock(\n         return_value={\n             \"app_source\": \"main()\",\n             \"pyproject_requires\": \"toga\",\n         }\n     )\n+\n     new_command.update_cookiecutter_cache = mock.MagicMock(\n         return_value=\"~/.cookiecutters/briefcase-template\"\n     )\n@@ -555,12 +562,10 @@ def test_new_app_unused_project_overrides(\n     new_command.new_app(project_overrides={\"unused\": \"override\"})\n \n     # App context is constructed\n+    new_command.select_bootstrap.assert_called_once_with({\"unused\": \"override\"})\n     new_command.build_app_context.assert_called_once_with({\"unused\": \"override\"})\n-    new_command.create_bootstrap.assert_called_once_with(\n-        app_context, {\"unused\": \"override\"}\n-    )\n     new_command.build_gui_context.assert_called_once_with(\n-        bootstrap, {\"unused\": \"override\"}\n+        mock.ANY, {\"unused\": \"override\"}\n     )\n     # Template is updated\n     new_command.update_cookiecutter_cache.assert_called_once_with(\n@@ -609,14 +614,14 @@ def test_abort_if_directory_exists(monkeypatch, new_command, tmp_path):\n         \"app_name\": \"myapplication\",\n     }\n     new_command.build_app_context = mock.MagicMock(return_value=app_context)\n-    bootstrap = BaseGuiBootstrap(new_command.console, {})\n-    new_command.create_bootstrap = mock.MagicMock(return_value=bootstrap)\n+    new_command.select_bootstrap = mock.MagicMock(return_value=BaseGuiBootstrap)\n     new_command.build_gui_context = mock.MagicMock(\n         return_value={\n             \"app_source\": \"main()\",\n             \"pyproject_requires\": \"toga\",\n         }\n     )\n+\n     new_command.update_cookiecutter_cache = mock.MagicMock(\n         return_value=\"~/.cookiecutters/briefcase-template\"\n     )\n@@ -628,9 +633,9 @@ def test_abort_if_directory_exists(monkeypatch, new_command, tmp_path):\n         new_command.new_app(project_overrides={})\n \n     # App context is constructed\n+    new_command.select_bootstrap.assert_called_once_with({})\n     new_command.build_app_context.assert_called_once_with({})\n-    new_command.create_bootstrap.assert_called_once_with(app_context, {})\n-    new_command.build_gui_context.assert_called_once_with(bootstrap, {})\n+    new_command.build_gui_context.assert_called_once_with(mock.ANY, {})\n \n     # Template won't be updated or unrolled\n     # Cookiecutter was *not* invoked\ndiff --git a/tests/commands/new/test_select_bootstrap.py b/tests/commands/new/test_select_bootstrap.py\nnew file mode 100644\nindex 0000000000..3969dcd3ad\n--- /dev/null\n+++ b/tests/commands/new/test_select_bootstrap.py\n@@ -0,0 +1,204 @@\n+from importlib import metadata\n+from unittest.mock import MagicMock\n+\n+import pytest\n+\n+from briefcase.bootstraps import (\n+    ConsoleBootstrap,\n+    EmptyBootstrap,\n+    PygameGuiBootstrap,\n+    PySide6GuiBootstrap,\n+    TogaGuiBootstrap,\n+)\n+\n+\n+def test_question_sequence_toga(new_command):\n+    \"\"\"The Toga bootstrap can be selected.\"\"\"\n+    new_command.console.values = [\n+        \"1\",  # Toga GUI toolkit\n+    ]\n+\n+    bootstrap_class = new_command.select_bootstrap(project_overrides={})\n+\n+    assert bootstrap_class is TogaGuiBootstrap\n+\n+\n+def test_question_sequence_console(new_command):\n+    \"\"\"A console bootstrap can be constructed.\"\"\"\n+    new_command.console.values = [\n+        \"4\",  # Console app\n+    ]\n+\n+    bootstrap_class = new_command.select_bootstrap(project_overrides={})\n+\n+    assert bootstrap_class is ConsoleBootstrap\n+\n+\n+def test_question_sequence_pyside6(new_command):\n+    \"\"\"A PySide6 bootstrap can be created.\"\"\"\n+    new_command.console.values = [\n+        \"2\",  # PySide6 app\n+    ]\n+\n+    bootstrap_class = new_command.select_bootstrap(project_overrides={})\n+\n+    assert bootstrap_class is PySide6GuiBootstrap\n+\n+\n+def test_question_sequence_pygame(new_command):\n+    \"\"\"A Pygame bootstrap can be constructed.\"\"\"\n+    new_command.console.values = [\n+        \"3\",  # PyGame\n+    ]\n+\n+    bootstrap_class = new_command.select_bootstrap(project_overrides={})\n+\n+    assert bootstrap_class is PygameGuiBootstrap\n+\n+\n+def test_question_sequence_none(new_command):\n+    \"\"\"If no bootstrap is selected, the empty bootstrap is used.\"\"\"\n+    new_command.console.values = [\n+        \"6\",  # No toolkit\n+    ]\n+\n+    bootstrap_class = new_command.select_bootstrap(project_overrides={})\n+\n+    assert bootstrap_class is EmptyBootstrap\n+\n+\n+def test_question_sequence_other_framework(new_command, capsys):\n+    \"\"\"Selecting 'Other frameworks' shows guidance and aborts cleanly.\"\"\"\n+    new_command.console.values = [\n+        \"5\",  # Other framework\n+        \"1\",  # The first community framework (Toga Positron)\n+    ]\n+\n+    with pytest.raises(SystemExit) as excinfo:\n+        new_command.select_bootstrap(project_overrides={})\n+\n+    assert excinfo.value.code == 0\n+\n+    out = capsys.readouterr().out\n+\n+    assert \"1) Toga Positron: \" in out\n+    assert \"2) Pygame-ce: \" in out\n+    assert \"3) No GUI framework\" in out\n+\n+    # And install instructions were displayed\n+    assert \"python -m pip install toga-positron\" in out\n+\n+\n+def test_question_sequence_other_none(new_command, capsys):\n+    \"\"\"'None' can be selected from the 'Other frameworks' menu.\"\"\"\n+    new_command.console.values = [\n+        \"5\",  # Other framework\n+        \"3\",  # No framework selected from the \"other\" menu\n+    ]\n+\n+    bootstrap_class = new_command.select_bootstrap(project_overrides={})\n+\n+    out = capsys.readouterr().out\n+\n+    assert \"1) Toga Positron: \" in out\n+    assert \"2) Pygame-ce: \" in out\n+    assert \"3) No GUI framework\" in out\n+\n+    # Empty bootstrap was selected.\n+    assert bootstrap_class is EmptyBootstrap\n+\n+\n+def test_other_frameworks_hide_installed(new_command, capsys, monkeypatch):\n+    \"\"\"Installed community bootstraps are not shown in the submenu.\"\"\"\n+\n+    # Fake the installation of pygame-ce\n+    def _metadata(package_name):\n+        if package_name == \"pygame-ce\":\n+            return\n+        raise metadata.PackageNotFoundError()\n+\n+    monkeypatch.setattr(metadata, \"metadata\", MagicMock(side_effect=_metadata))\n+\n+    new_command.console.values = [\n+        \"5\",  # Other framework\n+        \"1\",  # The first community framework (Toga Positron)\n+    ]\n+\n+    with pytest.raises(SystemExit) as excinfo:\n+        new_command.select_bootstrap(project_overrides={})\n+\n+    assert excinfo.value.code == 0\n+\n+    out = capsys.readouterr().out\n+\n+    assert \"1) Toga Positron: \" in out\n+    assert \"2) No GUI framework\" in out\n+\n+    # Pygame-ce doesn't appear\n+    assert \"Pygame-ce: \" not in out\n+\n+\n+def test_other_frameworks_all_installed(new_command, capsys, monkeypatch):\n+    \"\"\"If all community GUI bootstraps are installed, a warning is shown.\"\"\"\n+\n+    # Fake the installation of all plugins\n+    def _metadata(package_name):\n+        return\n+\n+    monkeypatch.setattr(metadata, \"metadata\", MagicMock(side_effect=_metadata))\n+\n+    new_command.console.values = [\n+        \"5\",  # Other framework\n+        \"1\",  # The first community framework (Toga Positron)\n+    ]\n+\n+    bootstrap_class = new_command.select_bootstrap(project_overrides={})\n+\n+    out = capsys.readouterr().out\n+\n+    # The user is warned there are no more bootstraps\n+    assert \"All known community GUI bootstraps are currently installed.\" in out\n+\n+    # The only menu option is \"nothing\"\n+    assert \"1) No GUI framework\" in out\n+\n+    # No community plugin appears\n+    assert \"Toga Positron: \" not in out\n+    assert \"Pygame-ce: \" not in out\n+\n+    assert bootstrap_class is EmptyBootstrap\n+\n+\n+def test_question_sequence_with_overrides(new_command, monkeypatch):\n+    \"\"\"The answer to the bootstrap question can be overridden.\"\"\"\n+\n+    bootstrap_class = new_command.select_bootstrap(\n+        project_overrides={\"bootstrap\": \"Toga\"}\n+    )\n+\n+    assert bootstrap_class is TogaGuiBootstrap\n+\n+\n+def test_question_sequence_with_bad_bootstrap_override(new_command, monkeypatch):\n+    \"\"\"A bad override for the bootstrap uses user input instead.\"\"\"\n+\n+    # Simulate user selecting Toga from the menu after bad override.\n+    new_command.console.values = [\n+        \"1\",  # Toga\n+    ]\n+\n+    bootstrap_class = new_command.select_bootstrap(\n+        project_overrides={\"bootstrap\": \"BAD I don't exist GUI\"}\n+    )\n+\n+    assert bootstrap_class is TogaGuiBootstrap\n+\n+\n+def test_question_sequence_with_no_user_input(new_command):\n+    \"\"\"If no user input is provided, all user inputs are taken as default.\"\"\"\n+\n+    new_command.console.input_enabled = False\n+\n+    bootstrap_class = new_command.select_bootstrap(project_overrides={})\n+\n+    assert bootstrap_class is TogaGuiBootstrap\n", "problem_statement": "Add option to aid discoverability of third-party Briefcase bootstraps\n### What is the problem or limitation you are having?\n\nVia @tronical on #2340:\n\nWe currently encourage third-parties to publish their own Briefcase bootstrap plugins, rather than shipping them with Briefcase. This is good for Briefcase *maintainers*, because we don't have to stay on top of every GUI toolkit in the world; but it's a problem for the maintainers of those GUI toolkits and frameworks, because there's limited discoverability of options that aren't in Briefcase itself.\n\n### Describe the solution you'd like\n\nThe selection of GUI toolkits should have a \"second to last\" option \"Other frameworks (select to see options)\". This menu option would then list other frameworks with know Briefcase plugins, and if you select one of them, provide installation instructions. \n\nThere should also be a mild warning that the plugins on this secondary menu are not Briefcase's responsibility.\n\n### Describe alternatives you've considered\n\nThe current implementation provides a link to documentation for other frameworks. We could preserve this as a documentation issue; but given that the user is in the tool and has a question, we might as well solve the problem where they are.\n\n### Additional context\n\n_No response_\n", "hints_text": "I would like to solve this issue\n@aviralgarg05 If you want to try your hand at fixing this, go right ahead. We don't formally assign issues to users; we'll consider any PR that implements the feature as described. However, please stick to one PR in flight at a time (cf #2545), at least until you're familiar with Briefcase's contribution processes.\n\n", "all_hints_text": "I would like to solve this issue\n@aviralgarg05 If you want to try your hand at fixing this, go right ahead. We don't formally assign issues to users; we'll consider any PR that implements the feature as described. However, please stick to one PR in flight at a time (cf #2545), at least until you're familiar with Briefcase's contribution processes.\n\n", "commit_urls": ["https://github.com/beeware/briefcase/commit/867d88ce064ed0263fc28bda53279fcb2418d1a4", "https://github.com/beeware/briefcase/commit/2780510df9e3d1561b8a478d9a48153a6e74baf3", "https://github.com/beeware/briefcase/commit/d6c5a6ac0a5ea740c83ab312854d44b1027c47ba", "https://github.com/beeware/briefcase/commit/0267fdadc30fbc51cee485001962fc00463a748c", "https://github.com/beeware/briefcase/commit/787544b3706c0f34f7addddff5c6140dbe9b5c2f", "https://github.com/beeware/briefcase/commit/c9a7c8be1cc83f75d0815c562ac9431f3b385f72", "https://github.com/beeware/briefcase/commit/d129f3b77b91e4c532b9e4b02c324ea9bc831bcb", "https://github.com/beeware/briefcase/commit/72ba8f9a7e26b13a98c78e2c3385a3ac302ef920", "https://github.com/beeware/briefcase/commit/78c21dd0ccd8c5d204c8d9d5b120f0cc7235e9a4", "https://github.com/beeware/briefcase/commit/0e6a4e182fa2ef24fba6fbd387bb5766d4485442", "https://github.com/beeware/briefcase/commit/b6af4400d907da00acc7f41976f9b2af1db02deb", "https://github.com/beeware/briefcase/commit/036e54af71934c7a3f14f931da38318b12694e7a", "https://github.com/beeware/briefcase/commit/fb14a9c01d7a98200b2f12479be63bab40869500", "https://github.com/beeware/briefcase/commit/ec758ca88f8ed03f7a07561cb4b89adb6511e34b", "https://github.com/beeware/briefcase/commit/0c51c19207982af17c0e893badd1ccd34c3100ed", "https://github.com/beeware/briefcase/commit/1ed448c9f7e72147c1ce870aa08192183b916d6e", "https://github.com/beeware/briefcase/commit/470f158b1bd58badf916a15b5c2f847c9ec72c0e", "https://github.com/beeware/briefcase/commit/8d025594739260aa73dba2fff1e2dc6e0524d0b4", "https://github.com/beeware/briefcase/commit/654ab34c9d9a01bbb4c0bb0458c0a084f4d6232c", "https://github.com/beeware/briefcase/commit/1f472cae634b05f9a7e069b685370efc8ef4c999", "https://github.com/beeware/briefcase/commit/0381aa855b433d67bf4c74ce2c41e80ea6910972", "https://github.com/beeware/briefcase/commit/4fe95fa0dd4db877597b8459bab32bf1c42cf72a", "https://github.com/beeware/briefcase/commit/2caf3b9ff0b8dcfba6f4239f664101237cd2e7e8", "https://github.com/beeware/briefcase/commit/36f0e09640ed117cd146056ac8f1b142ae6cfc47", "https://github.com/beeware/briefcase/commit/465e24c226b2703a84d0d9ab004ff50df9a4ef05", "https://github.com/beeware/briefcase/commit/7daf35581b38f18e34509ad3e15df3e9c9d6314a", "https://github.com/beeware/briefcase/commit/13505419b23efbc2024eb76d146c0b3d662a6aa7", "https://github.com/beeware/briefcase/commit/d10186bbc0fa26061bae7edbd0aede3cfaec4add", "https://github.com/beeware/briefcase/commit/e08850e0ea3824df15c1516f7079133f187c7b55", "https://github.com/beeware/briefcase/commit/0fae5cc18be9c8810c43eeca91c8581a36f043bc", "https://github.com/beeware/briefcase/commit/c24f73f5bb912d2596ee430de1b040faaa606f8b", "https://github.com/beeware/briefcase/commit/3062e7d52142054e2027178f86c249ece3f4a2a4", "https://github.com/beeware/briefcase/commit/0840591f6e9778995f67aea3aefe1493e9da56c4", "https://github.com/beeware/briefcase/commit/ddca57c780d8e7c049c626826822c31457701746", "https://github.com/beeware/briefcase/commit/38f7a3902edde94c3a6e42a009d9b60a98916d02", "https://github.com/beeware/briefcase/commit/130d0ff96c4dceca952b6cc553c986110387bd6e", "https://github.com/beeware/briefcase/commit/162b5b223a2eba4c8db5376bef3f419d8abfd878", "https://github.com/beeware/briefcase/commit/f8d991f8b5bfb04c8698f66ffad804c130fbf8c8"], "created_at": "2026-01-24T19:37:49Z"}
{"repo": "beeware/briefcase", "pull_number": 2410, "instance_id": "beeware__briefcase-2410", "issue_numbers": [2364], "base_commit": "9f455b0cf4346d512c7be1e13d0c8085bf1362b4", "patch": "diff --git a/changes/2364.misc.rst b/changes/2364.misc.rst\nnew file mode 100644\nindex 000000000..7f8624243\n--- /dev/null\n+++ b/changes/2364.misc.rst\n@@ -0,0 +1,1 @@\n+Add link to the ``briefcase package iOS`` warning message to the iOS deployment documentation.\ndiff --git a/docs/reference/platforms/iOS/xcode.rst b/docs/reference/platforms/iOS/xcode.rst\nindex 69deab80d..35ddb9d11 100644\n--- a/docs/reference/platforms/iOS/xcode.rst\n+++ b/docs/reference/platforms/iOS/xcode.rst\n@@ -225,6 +225,7 @@ can do this using the ``cleanup_paths`` configuration option::\n This will find and purge all ``.a`` content in your app's dependencies. You can add\n additional patterns to remove other problematic content.\n \n+.. _ios-deploy:\n \n Deployment to Simulated and Physical iOS Devices\n ------------------------------------------------\ndiff --git a/src/briefcase/platforms/iOS/xcode.py b/src/briefcase/platforms/iOS/xcode.py\nindex c7ad4f31a..76dc1ca7d 100644\n--- a/src/briefcase/platforms/iOS/xcode.py\n+++ b/src/briefcase/platforms/iOS/xcode.py\n@@ -68,7 +68,9 @@ def distribution_path(self, app):\n \n         briefcase open iOS\n \n-    and use Xcode's app distribution workflow.\n+    and use Xcode's app distribution workflow described at:\n+\n+        https://briefcase.readthedocs.io/en/stable/reference/platforms/iOS/xcode.html#ios-deploy\n \n *************************************************************************\n \"\"\"\n", "test_patch": "", "problem_statement": "`briefcase package iOS` message could direct to a documentation page\n### What is the problem or limitation you are having?\n\nThe current message displayed when the user runs `briefcase package iOS` is:\n```\n*************************************************************************\n** WARNING: No distributable artefact has been generated               **\n*************************************************************************\n\n    Briefcase has not generated a standalone iOS artefact, as iOS apps\n    must be published through Xcode.\n\n    To open Xcode for your iOS project, run:\n\n        briefcase open iOS\n\n    and use Xcode's app distribution workflow.\n\n*************************************************************************\n```\nbut it doesn't say what to do after opening Xcode.  I'm left to search for an explanation of what to do next.\n\n### Describe the solution you'd like\n\nI found the instructions in #860 to be helpful.  They could be expanded into a documentation page on how to test an app with a physical device with a few screen shots and arrows where things need to be clicked.  I think the desired documentation is different than [the docs page on how to publish to the App Store](https://briefcase.readthedocs.io/en/stable/how-to/publishing/iOS.html), since the goal is just to run on a device tied to the developer's Apple account.  The URL to the new page in the documentation could then be shown to the user when they run `briefcase package iOS` so they know what to do next.\n\n### Describe alternatives you've considered\n\nAt a minimum, `briefcase package iOS` could link to #860 directly, but that seems like not a good long term solution.\n\n### Additional context\n\n_No response_\n", "hints_text": "To clarify scope - there's two changes needed:\n\n1. A new page in the documentation, describing how to deploy an app onto an iOS device. This documentation shared a lot of similarities with the [App Store publication docs](https://briefcase.readthedocs.io/en/stable/how-to/publishing/iOS.html), \n2. Modifying the error handling in `briefcase package iOS` to provide 2 links:\n   - A link to the newly added page describing how to run the app on your personal device\n   - A link to the existing App Store publication docs\n\nInstead of a completely new page, it may be possible to adapt the iOS publication docs to support both \"personal device\" and \"App Store\" publication - the general workflow is *almost* identical, with \"own device\" stopping at \"select device and press run\", but App Store publication going through the whole archiving process.\n\n#2293 added documentation that meets the requirement of (1). \nHello, I am going to work on this during the EuroPython sprints.\n\n", "all_hints_text": "To clarify scope - there's two changes needed:\n\n1. A new page in the documentation, describing how to deploy an app onto an iOS device. This documentation shared a lot of similarities with the [App Store publication docs](https://briefcase.readthedocs.io/en/stable/how-to/publishing/iOS.html), \n2. Modifying the error handling in `briefcase package iOS` to provide 2 links:\n   - A link to the newly added page describing how to run the app on your personal device\n   - A link to the existing App Store publication docs\n\nInstead of a completely new page, it may be possible to adapt the iOS publication docs to support both \"personal device\" and \"App Store\" publication - the general workflow is *almost* identical, with \"own device\" stopping at \"select device and press run\", but App Store publication going through the whole archiving process.\n\n#2293 added documentation that meets the requirement of (1). \nHello, I am going to work on this during the EuroPython sprints.\nHello, I am not sure how to properly format the link in the warning message. The best solution I have was inspired by the similar link to the documentation in \nhttps://github.com/beeware/briefcase/blob/e06571a428bf5871fcb25a7809e8230e0316ba5f/src/briefcase/platforms/android/gradle.py#L187-L210\n\nThis is how it looks in the 80 columns terminal window:\n\n<img width=\"682\" height=\"319\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/6c62b7c4-849c-4920-9560-42247c167dd0\" />\nWhile it's unfortunate that this URL runs over 80 chars, there's not much we can do while preserving the URL as a useful link. \n\nI guess we *could* add a shortlink - i.e., make `https://beeware.org/b/briefcase-ios-device-deployment` (or similar) a link to the docs page - but if we did that, we'd likely want to audit all the Briefcase external links so we can manage them consistently. \n\nSo - my suggestion would be to submit a PR with the >80 char link as is, and we can open a separate issue to audit for shortlink references to BeeWare (and other) docs.\n> I guess we _could_ add a shortlink - i.e., make `https://beeware.org/b/briefcase-ios-device-deployment` (or similar) a link to the docs page\n\nI don't think a minor increase in readability justifies that maintenance burden, especially when it would involve coordination between multiple repositories. However, we can still shorten the link by adding an anchor ID, as has already been done in the \"third-party packages\" section. That would allow the URL fragment to be shortened to something like `#ios-deploy`.\n\n", "commit_urls": ["https://github.com/beeware/briefcase/commit/5245bf7232106e020a2299d4b33f96b0fbb8e10e", "https://github.com/beeware/briefcase/commit/6699704db7c7815f0790fa7b44b6cfda783af699"], "created_at": "2025-07-22T17:28:49Z"}
{"repo": "beeware/briefcase", "pull_number": 2401, "instance_id": "beeware__briefcase-2401", "issue_numbers": [2378], "base_commit": "4c1fb37399d94d2d1e21216e70bb6dfb1cec0b1a", "patch": "diff --git a/README.md b/README.md\nnew file mode 100644\nindex 000000000..2666610b2\n--- /dev/null\n+++ b/README.md\n@@ -0,0 +1,75 @@\n+[<img src=\"https://beeware.org/project/briefcase/briefcase.png\" width=\"72\" alt=\"logo\" />](https://beeware.org/briefcase)\n+\n+# Briefcase\n+\n+[![Python Versions](https://img.shields.io/pypi/pyversions/briefcase.svg)](https://pypi.python.org/pypi/briefcase)\n+[![PyPI Version](https://img.shields.io/pypi/v/briefcase.svg)](https://pypi.python.org/pypi/briefcase)\n+[![Maturity](https://img.shields.io/pypi/status/briefcase.svg)](https://pypi.python.org/pypi/briefcase)\n+[![BSD License](https://img.shields.io/pypi/l/briefcase.svg)](https://github.com/beeware/briefcase/blob/main/LICENSE)\n+[![Build Status](https://github.com/beeware/briefcase/workflows/CI/badge.svg?branch=main)](https://github.com/beeware/briefcase/actions)\n+[![Discord server](https://img.shields.io/discord/836455665257021440?label=Discord%20Chat&logo=discord&style=plastic)](https://beeware.org/bee/chat/)\n+\n+Briefcase is a tool for converting a Python project into a standalone\n+native application. You can package projects for:\n+\n+- Mac\n+- Windows\n+- Linux\n+- iPhone/iPad\n+- Android\n+- Web\n+\n+Support for AppleTV, watchOS, and wearOS deployments is planned.\n+\n+## Getting started\n+\n+To install Briefcase, run:\n+\n+    $ python -m pip install briefcase\n+\n+If you would like a full introduction to using Briefcase, try the\n+[BeeWare tutorial](https://docs.beeware.org). This tutorial walks you\n+through the process of creating and packaging a new application with\n+Briefcase.\n+\n+## Financial support\n+\n+The BeeWare project would not be possible without the generous support\n+of our financial members:\n+\n+[![Anaconda logo](https://beeware.org/community/members/anaconda/anaconda-large.png)](https://anaconda.com/)\n+\n+Anaconda Inc. - Advancing AI through open source.\n+\n+Plus individual contributions from [users like\n+you](https://beeware.org/community/members/). If you find Briefcase, or\n+other BeeWare tools useful, please consider becoming a financial member.\n+\n+## Documentation\n+\n+Documentation for Briefcase can be found on [Read The\n+Docs](https://briefcase.readthedocs.io).\n+\n+## Community\n+\n+Briefcase is part of the [BeeWare suite](https://beeware.org). You can\n+talk to the community through:\n+\n+- [@beeware@fosstodon.org on Mastodon](https://fosstodon.org/@beeware)\n+- [Discord](https://beeware.org/bee/chat/)\n+- The Briefcase [GitHub Discussions\n+  forum](https://github.com/beeware/briefcase/discussions)\n+\n+We foster a welcoming and respectful community as described in our\n+[BeeWare Community Code of\n+Conduct](https://beeware.org/community/behavior/).\n+\n+## Contributing\n+\n+If you experience problems with Briefcase, [log them on\n+GitHub](https://github.com/beeware/briefcase/issues).\n+\n+If you'd like to contribute to Briefcase development, our [contribution\n+guide](https://briefcase.readthedocs.io/en/latest/how-to/contribute/index.html)\n+details how to set up a development environment, and other requirements\n+we have as part of our contribution process.\ndiff --git a/README.rst b/README.rst\ndeleted file mode 100644\nindex 93c137d52..000000000\n--- a/README.rst\n+++ /dev/null\n@@ -1,105 +0,0 @@\n-.. |logo| image:: https://beeware.org/project/briefcase/briefcase.png\n-   :width: 72px\n-   :target: https://beeware.org/briefcase\n-\n-.. |pyversions| image:: https://img.shields.io/pypi/pyversions/briefcase.svg\n-   :target: https://pypi.python.org/pypi/briefcase\n-   :alt: Python Versions\n-\n-.. |version| image:: https://img.shields.io/pypi/v/briefcase.svg\n-   :target: https://pypi.python.org/pypi/briefcase\n-   :alt: PyPI Version\n-\n-.. |maturity| image:: https://img.shields.io/pypi/status/briefcase.svg\n-   :target: https://pypi.python.org/pypi/briefcase\n-   :alt: Maturity\n-\n-.. |license| image:: https://img.shields.io/pypi/l/briefcase.svg\n-   :target: https://github.com/beeware/briefcase/blob/main/LICENSE\n-   :alt: BSD License\n-\n-.. |ci| image:: https://github.com/beeware/briefcase/workflows/CI/badge.svg?branch=main\n-   :target: https://github.com/beeware/briefcase/actions\n-   :alt: Build Status\n-\n-.. |social| image:: https://img.shields.io/discord/836455665257021440?label=Discord%20Chat&logo=discord&style=plastic\n-   :target: https://beeware.org/bee/chat/\n-   :alt: Discord server\n-\n-|logo|\n-\n-Briefcase\n-=========\n-\n-|pyversions| |version| |maturity| |license| |ci| |social|\n-\n-Briefcase is a tool for converting a Python project into a standalone native\n-application. You can package projects for:\n-\n-* Mac\n-* Windows\n-* Linux\n-* iPhone/iPad\n-* Android\n-* Web\n-\n-Support for AppleTV, watchOS, and wearOS deployments is planned.\n-\n-Getting started\n----------------\n-\n-To install Briefcase, run::\n-\n-   $ python -m pip install briefcase\n-\n-If you would like a full introduction to using Briefcase, try the `BeeWare tutorial\n-<https://docs.beeware.org>`__. This tutorial walks you through the process of creating\n-and packaging a new application with Briefcase.\n-\n-Financial support\n------------------\n-\n-The BeeWare project would not be possible without the generous support of our financial\n-members:\n-\n-.. image:: https://beeware.org/community/members/anaconda/anaconda-large.png\n-    :target: https://anaconda.com/\n-    :alt: Anaconda logo\n-\n-Anaconda Inc. - Advancing AI through open source.\n-\n-Plus individual contributions from `users like you\n-<https://beeware.org/community/members/>`__. If you find Briefcase, or other BeeWare\n-tools useful, please consider becoming a financial member.\n-\n-Documentation\n--------------\n-\n-Documentation for Briefcase can be found on `Read The Docs\n-<https://briefcase.readthedocs.io>`__.\n-\n-Community\n----------\n-\n-Briefcase is part of the `BeeWare suite <https://beeware.org>`__. You can talk to the\n-community through:\n-\n-* `@beeware@fosstodon.org on Mastodon <https://fosstodon.org/@beeware>`__\n-\n-* `Discord <https://beeware.org/bee/chat/>`__\n-\n-* The Briefcase `GitHub Discussions forum <https://github.com/beeware/briefcase/discussions>`__\n-\n-We foster a welcoming and respectful community as described in our `BeeWare Community\n-Code of Conduct <https://beeware.org/community/behavior/>`__.\n-\n-Contributing\n-------------\n-\n-If you experience problems with Briefcase, `log them on GitHub\n-<https://github.com/beeware/briefcase/issues>`__.\n-\n-If you'd like to contribute to Briefcase development, our `contribution guide\n-<https://briefcase.readthedocs.io/en/latest/how-to/contribute/index.html>`__\n-details how to set up a development environment, and other requirements we have\n-as part of our contribution process.\ndiff --git a/changes/2378.misc.rst b/changes/2378.misc.rst\nnew file mode 100644\nindex 000000000..424394b5f\n--- /dev/null\n+++ b/changes/2378.misc.rst\n@@ -0,0 +1,1 @@\n+Rewritten the ``README.rst`` to markdown (``README.md``) using pandoc.\ndiff --git a/pyproject.toml b/pyproject.toml\nindex 5d778ba4c..7c879ebcd 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -10,7 +10,7 @@ build-backend = \"setuptools.build_meta\"\n dynamic = [\"version\"]\n name = \"briefcase\"\n description = \"Tools to support converting a Python project into a standalone native application.\"\n-readme = \"README.rst\"\n+readme = \"README.md\"\n requires-python = \">= 3.9\"\n license = \"BSD-3-Clause\"\n license-files = [\n", "test_patch": "", "problem_statement": "Convert `README.rst` from reStructuredText to GitHub-flavored Markdown\n### What is the problem or limitation you are having?\n\nThe README file for this repository is currently formatted using reStructuredText.\n\n### Describe the solution you'd like\n\nThe README should be converted to GitHub-flavored Markdown from rST. There are multiple methods to convert rST to Markdown. \n\nOnce conversion is complete, verify that the two files are rendering the same. This may require some cleanup, especially around headers and code syntax.\n\nDelete the `README.rst` file before submitting a PR.\n\n### Describe alternatives you've considered\n\nNone.\n\n### Additional context\n\nOne possible conversion option is `pandoc`. Pandoc installation instructions can be found [here](https://pandoc.org/installing.html).\n\nTo use `pandoc` to convert the `README.rst` file from rST to GitHub-flavored Markdown, run the following command from the same directory as the `README.rst` file:\n\n```\npandoc -s README.rst -t gfm -o README.md\n```\n\nThis command may result in an incorrect formatting of the title; the title should be formatted as `# Title`. Ensure you are verifying that the results you are getting are what you expect.\n\nThen verify the two files are rendering the same.\n\n", "hints_text": "\n\n", "all_hints_text": "Hi, I am looking into this issue on the EuroPython sprints.\n\n", "commit_urls": ["https://github.com/beeware/briefcase/commit/53748b20e56ea9e4ae862494a8cecbd848e1e8a4", "https://github.com/beeware/briefcase/commit/2b0099c84ea11ba2ca6fe8655660e253f30de1cd", "https://github.com/beeware/briefcase/commit/e02f91a41b373171b528ad2628b7a15b37f0ca61", "https://github.com/beeware/briefcase/commit/ed044a4eec6d5a2f719facd236b6a1d48a2554fe", "https://github.com/beeware/briefcase/commit/0705ac5d0b8d7e693c15d1e101b77fcfa7754b5a"], "created_at": "2025-07-19T11:09:30Z"}
{"repo": "beeware/briefcase", "pull_number": 2398, "instance_id": "beeware__briefcase-2398", "issue_numbers": [2379], "base_commit": "b710701eade01d6cc412f72425fb4b4707bc5464", "patch": "diff --git a/.pre-commit-config.yaml b/.pre-commit-config.yaml\nindex db813c110..f97b08f14 100644\n--- a/.pre-commit-config.yaml\n+++ b/.pre-commit-config.yaml\n@@ -19,6 +19,7 @@ repos:\n     hooks:\n       - id: ruff-format\n       - id: ruff-check\n+        args: [ --fix ]\n   - repo: https://github.com/codespell-project/codespell\n     rev: v2.4.1\n     hooks:\ndiff --git a/changes/2379.misc.rst b/changes/2379.misc.rst\nnew file mode 100644\nindex 000000000..3d20a7c1b\n--- /dev/null\n+++ b/changes/2379.misc.rst\n@@ -0,0 +1,1 @@\n+The ``pre-commit`` hook was updated to include the ``--fix`` argument for the ruff-check command.\n", "test_patch": "", "problem_statement": "Add `--fix` arg to `ruff-check` pre-commit configuration.\n### What is the problem or limitation you are having?\n\nThe current `ruff-check` configuration does not resolve fixable errors when pre-commit is run. \n\n### Describe the solution you'd like\n\nThe `--fix` arg should be added to the configuration as shown [here](https://github.com/beeware/toga/blob/22000bb10e5f24ea8909e80e246cd40fb87fbad9/.pre-commit-config.yaml#L16).\n\n### Describe alternatives you've considered\n\nThere are none.\n\n### Additional context\n\n_No response_\n", "hints_text": "Picking up this one\n\n", "all_hints_text": "Picking up this one\n\n", "commit_urls": ["https://github.com/beeware/briefcase/commit/44df8200b91278950e6532fe251b110e5d8cbe84", "https://github.com/beeware/briefcase/commit/8cb877eaa76e4bc601414caf31624806fe3d056c", "https://github.com/beeware/briefcase/commit/70cfcbb41756afadf14d23b98e01ab1985ecb846", "https://github.com/beeware/briefcase/commit/c13b7f0011128369212b5ffff9b6f4c729a80326"], "created_at": "2025-07-19T09:42:44Z"}
{"repo": "beeware/briefcase", "pull_number": 2515, "instance_id": "beeware__briefcase-2515", "issue_numbers": [2381], "base_commit": "e5aac65aa01e214fec43c412182254bd0eff869f", "patch": "diff --git a/changes/2381.misc.rst b/changes/2381.misc.rst\nnew file mode 100644\nindex 000000000..4258b7582\n--- /dev/null\n+++ b/changes/2381.misc.rst\n@@ -0,0 +1,1 @@\n+Resolved ruff rule ``B904`` - raise-without-from-inside-except.\ndiff --git a/pyproject.toml b/pyproject.toml\nindex 695868dc4..a05cd00e7 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -252,7 +252,6 @@ extend-select = [\n # for future fixes throughout the project.\n ignore = [\n     \"E501\",    # line length\n-    \"B904\",    # use raise ... from ...\n ]\n \n \ndiff --git a/src/briefcase/cmdline.py b/src/briefcase/cmdline.py\nindex 1709b5dce..179986d59 100644\n--- a/src/briefcase/cmdline.py\n+++ b/src/briefcase/cmdline.py\n@@ -159,7 +159,7 @@ def parse_known_args(args):\n         try:\n             platform_module = platforms[platform]\n         except KeyError:\n-            raise InvalidPlatformError(platform, platforms.keys())\n+            raise InvalidPlatformError(platform, platforms.keys()) from None\n \n         # If the output format wasn't explicitly specified, check to see\n         # Otherwise, extract and use the default output_format for the platform.\n@@ -184,11 +184,11 @@ def parse_known_args(args):\n             raise InvalidFormatError(\n                 requested=output_format,\n                 choices=list(output_formats.keys()),\n-            )\n+            ) from None\n         except AttributeError:\n             raise UnsupportedCommandError(\n                 platform=platform,\n                 output_format=output_format,\n                 command=options.command,\n-            )\n+            ) from None\n     return Command, extra\ndiff --git a/src/briefcase/commands/base.py b/src/briefcase/commands/base.py\nindex 92a3ec73e..c16167d78 100644\n--- a/src/briefcase/commands/base.py\n+++ b/src/briefcase/commands/base.py\n@@ -254,7 +254,7 @@ def validate_data_path(self, data_path):\n                     )\n                 else:  # pragma: no-cover-if-is-windows\n                     os.makedirs(data_path, exist_ok=True)\n-            except (subprocess.CalledProcessError, OSError):\n+            except (subprocess.CalledProcessError, OSError) as e:\n                 raise BriefcaseCommandError(\n                     f\"\"\"\n Failed to create the Briefcase directory to store tools and support files:\n@@ -265,7 +265,7 @@ def validate_data_path(self, data_path):\n a custom location for Briefcase's tools.\n \n \"\"\"\n-                )\n+                ) from e\n \n         return Path(data_path)\n \ndiff --git a/src/briefcase/commands/build.py b/src/briefcase/commands/build.py\nindex fb0f49a9d..750d39837 100644\n--- a/src/briefcase/commands/build.py\n+++ b/src/briefcase/commands/build.py\n@@ -143,7 +143,7 @@ def __call__(\n             except KeyError:\n                 raise BriefcaseCommandError(\n                     f\"App '{app_name}' does not exist in this project.\"\n-                )\n+                ) from None\n         elif app:\n             apps_to_build = {app.app_name: app}\n         else:\ndiff --git a/src/briefcase/commands/create.py b/src/briefcase/commands/create.py\nindex 6d9dab64b..aa7148b4b 100644\n--- a/src/briefcase/commands/create.py\n+++ b/src/briefcase/commands/create.py\n@@ -359,7 +359,7 @@ def _download_support_package(self, app: AppConfig):\n                             platform=self.platform,\n                             host_arch=self.tools.host_arch,\n                             is_32bit=self.tools.is_32bit_python,\n-                        )\n+                        ) from None\n \n                 support_package_url = self.support_package_url(support_revision)\n                 custom_support_package = False\n@@ -1015,7 +1015,7 @@ def __call__(\n             except KeyError:\n                 raise BriefcaseCommandError(\n                     f\"App '{app_name}' does not exist in this project.\"\n-                )\n+                ) from None\n         elif app:\n             apps_to_create = {app.app_name: app}\n         else:\ndiff --git a/src/briefcase/commands/package.py b/src/briefcase/commands/package.py\nindex 750997bbd..5d7698504 100644\n--- a/src/briefcase/commands/package.py\n+++ b/src/briefcase/commands/package.py\n@@ -193,7 +193,7 @@ def __call__(\n             except KeyError:\n                 raise BriefcaseCommandError(\n                     f\"App '{app_name}' does not exist in this project.\"\n-                )\n+                ) from None\n         elif app:\n             apps_to_package = {app.app_name: app}\n         else:\ndiff --git a/src/briefcase/commands/update.py b/src/briefcase/commands/update.py\nindex a09019c6e..c0270983a 100644\n--- a/src/briefcase/commands/update.py\n+++ b/src/briefcase/commands/update.py\n@@ -112,7 +112,7 @@ def __call__(\n             except KeyError:\n                 raise BriefcaseCommandError(\n                     f\"App '{app_name}' does not exist in this project.\"\n-                )\n+                ) from None\n         elif app:\n             apps_to_update = {app.app_name: app}\n         else:\ndiff --git a/src/briefcase/config.py b/src/briefcase/config.py\nindex f2d724eb9..1bcc2bc88 100644\n--- a/src/briefcase/config.py\n+++ b/src/briefcase/config.py\n@@ -113,7 +113,7 @@ def validate_document_type_config(document_type_id, document_type):\n     except KeyError:\n         raise BriefcaseConfigError(\n             f\"Document type {document_type_id!r} does not provide an extension.\"\n-        )\n+        ) from None\n \n     try:\n         if not isinstance(document_type[\"icon\"], str):\n@@ -123,7 +123,7 @@ def validate_document_type_config(document_type_id, document_type):\n     except KeyError:\n         raise BriefcaseConfigError(\n             f\"Document type {document_type_id!r} does not define an icon.\"\n-        )\n+        ) from None\n \n     try:\n         if not isinstance(document_type[\"description\"], str):\n@@ -133,18 +133,18 @@ def validate_document_type_config(document_type_id, document_type):\n     except KeyError:\n         raise BriefcaseConfigError(\n             f\"Document type {document_type_id!r} does not provide a description.\"\n-        )\n+        ) from None\n \n     try:\n         validate_url(document_type[\"url\"])\n     except KeyError:\n         raise BriefcaseConfigError(\n             f\"Document type {document_type_id!r} does not provide a URL.\"\n-        )\n+        ) from None\n     except ValueError as e:\n         raise BriefcaseConfigError(\n             f\"The URL associated with document type {document_type_id!r} is invalid: {e}\"\n-        )\n+        ) from None\n \n     if sys.platform == \"darwin\":  # pragma: no-cover-if-not-macos\n         from briefcase.platforms.macOS.utils import is_uti_core_type, mime_type_to_uti\ndiff --git a/src/briefcase/console.py b/src/briefcase/console.py\nindex 45318ff04..3ebda6421 100644\n--- a/src/briefcase/console.py\n+++ b/src/briefcase/console.py\n@@ -718,7 +718,7 @@ def input(self, prompt: str, *, markup: bool = False):\n             # Use underlying Rich input() to read from user\n             input_value = self._console_impl.input(escaped_prompt, markup=True)\n         except EOFError:\n-            raise KeyboardInterrupt\n+            raise KeyboardInterrupt from None\n \n         self.to_log(prompt)\n         self.to_log(f\"User input: {input_value}\")\n@@ -950,7 +950,7 @@ def selection_question(\n             try:\n                 default = str([option[0] for option in ordered].index(default) + 1)\n             except ValueError:\n-                raise ValueError(f\"{default!r} is not a valid default value\")\n+                raise ValueError(f\"{default!r} is not a valid default value\") from None\n \n         for i, (_, value) in enumerate(ordered, start=1