+        if version and isinstance(version, list) and len(version) > 0:
+            version_str = version[0]
+            if isinstance(version_str, str) and re.search(SEMANTIC_VERSION_PATTERN, version_str):
+                return CheckResult.PASSED
 
+        return CheckResult.FAILED
 
 check = RevisionVersionTag()
