+
+def export_scm_data(conanfile, scm_type="git", remote="origin", repository=False):
+    """
+    Helper function to simplify exporting SCM data to conandata.yml.
+
+    This function encapsulates the logic for fetching SCM URL and commit hash
+    and updating conandata.yml with the SCM data in a standardized format.
+
+    :param conanfile: The current recipe object. Always use ``self``.
+    :param scm_type: Type of SCM system (default: "git").
+    :param remote: Name of the remote git repository (default: "origin").
+    :param repository: By default gets the commit of the defined folder, use repo=True to get
+                     the commit of the repository instead.
+    """
+    from conan.tools.scm.git import Git
+
+    if scm_type == "git":
+        git = Git(conanfile, conanfile.recipe_folder)
+        scm_url, scm_commit = git.get_url_and_commit(remote=remote, repository=repository)
+        update_conandata(conanfile, {"scm": {"commit": scm_commit, "url": scm_url}})
+    else:
+        raise ConanException("Unsupported SCM type: {}".format(scm_type))
