@@ -20,6 +20,12 @@ def _scalar_or_array(validator: Validator, subschema: Any, instance: Any, schema
         for index, i in enumerate(instance):
             yield from validator.descend(i, subschema, path=index)
     else:
+        # Check if the instance is a CloudFormation function object
