{"repo": "Pennyw0rth/NetExec", "pull_number": 982, "instance_id": "Pennyw0rth__NetExec-982", "issue_numbers": [731], "base_commit": "cb9ad2d6b8da049a14267d301e70b0f0dcb80c56", "patch": "diff --git a/nxc/protocols/ldap.py b/nxc/protocols/ldap.py\nindex f06f52a71c..75cd5c63e7 100644\n--- a/nxc/protocols/ldap.py\n+++ b/nxc/protocols/ldap.py\n@@ -337,7 +337,9 @@ def enum_host_info(self):\n                 self.host,\n                 self.hostname,\n                 self.domain,\n-                self.server_os\n+                self.server_os,\n+                self.signing_required,\n+                self.cbt_status\n             )\n         except Exception as e:\n             self.logger.debug(f\"Error adding host {self.host} into db: {e!s}\")\ndiff --git a/nxc/protocols/ldap/database.py b/nxc/protocols/ldap/database.py\nindex 9816b30978..466b1d5e05 100644\n--- a/nxc/protocols/ldap/database.py\n+++ b/nxc/protocols/ldap/database.py\n@@ -1,5 +1,5 @@\n \n-from sqlalchemy import Column, ForeignKeyConstraint, Integer, PrimaryKeyConstraint, String, func, select, delete\n+from sqlalchemy import Boolean, Column, ForeignKeyConstraint, Integer, PrimaryKeyConstraint, String, func, select, delete\n from sqlalchemy.dialects.sqlite import Insert  # used for upsert\n from sqlalchemy.ext.declarative import declarative_base\n \n@@ -37,6 +37,8 @@ class Host(Base):\n         hostname = Column(String)\n         domain = Column(String)\n         os = Column(String)\n+        signing_required = Column(Boolean)\n+        channel_binding = Column(String)\n \n         __table_args__ = (\n             PrimaryKeyConstraint(\"id\"),\n@@ -50,7 +52,7 @@ def reflect_tables(self):\n         self.UsersTable = self.reflect_table(self.User)\n         self.HostsTable = self.reflect_table(self.Host)\n \n-    def add_host(self, ip, hostname, domain, os):\n+    def add_host(self, ip, hostname, domain, os, signing_required, channel_binding):\n         \"\"\"Check if this host has already been added to the database, if not, add it in.\"\"\"\n         hosts = []\n         updated_ids = []\n@@ -64,7 +66,9 @@ def add_host(self, ip, hostname, domain, os):\n                 \"ip\": ip,\n                 \"hostname\": hostname,\n                 \"domain\": domain,\n-                \"os\": os\n+                \"os\": os,\n+                \"signing_required\": signing_required,\n+                \"channel_binding\": channel_binding\n             }\n             hosts = [new_host]\n         # update existing hosts data\n@@ -78,6 +82,12 @@ def add_host(self, ip, hostname, domain, os):\n                     host_data[\"hostname\"] = hostname\n                 if domain is not None:\n                     host_data[\"domain\"] = domain\n+                if os is not None:\n+                    host_data[\"os\"] = os\n+                if signing_required is not None:\n+                    host_data[\"signing_required\"] = signing_required\n+                if channel_binding is not None:\n+                    host_data[\"channel_binding\"] = channel_binding\n                 # only add host to be updated if it has changed\n                 if host_data not in hosts:\n                     hosts.append(host_data)\ndiff --git a/nxc/protocols/ldap/db_navigator.py b/nxc/protocols/ldap/db_navigator.py\nindex 18a02be38b..52c21efdec 100644\n--- a/nxc/protocols/ldap/db_navigator.py\n+++ b/nxc/protocols/ldap/db_navigator.py\n@@ -10,7 +10,9 @@ def display_hosts(self, hosts):\n                 \"IP\",\n                 \"Hostname\",\n                 \"Domain\",\n-                \"OS\"\n+                \"OS\",\n+                \"LDAP signing required\",\n+                \"LDAPS channel binding\"\n             ]\n         ]\n \n@@ -25,13 +27,18 @@ def display_hosts(self, hosts):\n             except Exception:\n                 os = host[4]\n \n+            signing_required = host[5]\n+            channel_binding = host[6]\n+\n             data.append(\n                 [\n                     host_id,\n                     ip,\n                     hostname,\n                     domain,\n-                    os\n+                    os,\n+                    signing_required,\n+                    channel_binding\n                 ]\n             )\n         print_table(data, title=\"Hosts\")\n@@ -54,7 +61,9 @@ def do_hosts(self, line):\n                         \"IP\",\n                         \"Hostname\",\n                         \"Domain\",\n-                        \"OS\"\n+                        \"OS\",\n+                        \"LDAP signing required\",\n+                        \"LDAPS channel binding\"\n                     ]\n                 ]\n                 host_id_list = []\n@@ -71,13 +80,18 @@ def do_hosts(self, line):\n                     except Exception:\n                         os = host[4]\n \n+                    signing_required = host[5]\n+                    channel_binding = host[6]\n+\n                     data.append(\n                         [\n                             host_id,\n                             ip,\n                             hostname,\n                             domain,\n-                            os\n+                            os,\n+                            signing_required,\n+                            channel_binding\n                         ]\n                     )\n                 print_table(data, title=\"Host\")\n", "test_patch": "", "problem_statement": "LDAP Database Enhancement\nAdd channel binding and signing to LDAP hosts table in database just like the SMB hosts database. \n", "hints_text": "\n\n", "all_hints_text": "woot woot!!!!!\n\n", "commit_urls": ["https://github.com/Pennyw0rth/NetExec/commit/34f624fdc83c6dc5954bc861ea4836fc3f911574", "https://github.com/Pennyw0rth/NetExec/commit/bd1aec630d01e63e329508437fa3bb264b95982d", "https://github.com/Pennyw0rth/NetExec/commit/1ea2d8ce1c83f967fa8f868a2dcef9b86c9c3b72"], "created_at": "2025-11-02T16:14:39Z"}
{"repo": "Pennyw0rth/NetExec", "pull_number": 741, "instance_id": "Pennyw0rth__NetExec-741", "issue_numbers": [740], "base_commit": "fde3de726e276dc5984d72711fbed12a4396e782", "patch": "diff --git a/nxc/protocols/ldap.py b/nxc/protocols/ldap.py\nindex 413590c309..6f4237ae47 100644\n--- a/nxc/protocols/ldap.py\n+++ b/nxc/protocols/ldap.py\n@@ -312,7 +312,10 @@ def enum_host_info(self):\n             self.domain = self.targetDomain\n \n         self.check_ldap_signing()\n-        self.check_ldaps_cbt()\n+        if getattr(self.args, \"port_explicitly_set\", False) and self.port == 389:\n+            self.cbt_status = \"Unknown\"\n+        else:\n+            self.check_ldaps_cbt()\n \n         # using kdcHost is buggy on impacket when using trust relation between ad so we kdcHost must stay to none if targetdomain is not equal to domain\n         if not self.kdcHost and self.domain and self.domain == self.targetDomain:\ndiff --git a/nxc/protocols/ldap/proto_args.py b/nxc/protocols/ldap/proto_args.py\nindex 03530f9392..996c947d5b 100644\n--- a/nxc/protocols/ldap/proto_args.py\n+++ b/nxc/protocols/ldap/proto_args.py\n@@ -1,10 +1,10 @@\n-from nxc.helpers.args import DisplayDefaultsNotNone\n+from nxc.helpers.args import DefaultTrackingAction, DisplayDefaultsNotNone\n \n \n def proto_args(parser, parents):\n     ldap_parser = parser.add_parser(\"ldap\", help=\"own stuff using LDAP\", parents=parents, formatter_class=DisplayDefaultsNotNone)\n     ldap_parser.add_argument(\"-H\", \"--hash\", metavar=\"HASH\", dest=\"hash\", nargs=\"+\", default=[], help=\"NTLM hash(es) or file(s) containing NTLM hashes\")\n-    ldap_parser.add_argument(\"--port\", type=int, default=389, help=\"LDAP port\")\n+    ldap_parser.add_argument(\"--port\", type=int, default=389, action=DefaultTrackingAction, help=\"LDAP port\")\n \n     dgroup = ldap_parser.add_mutually_exclusive_group()\n     dgroup.add_argument(\"-d\", metavar=\"DOMAIN\", dest=\"domain\", type=str, default=None, help=\"domain to authenticate to\")\n", "test_patch": "", "problem_statement": "Ldap module not working without port 636\n**Describe the bug**\nI have a DC that supports only ldap on port 389 despite the port 636 being open.\nI can't make the ldap module of nxc to work only on port 389.\nOther tools work correctly on port 389, it's not a problem with my DC.\n\n**To Reproduce**\nWhen specifying no port, it starts with port 389 and it goes on port 636.\n<img width=\"542\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/1b4292c0-be01-4bb7-ae6c-afc42f458003\" />\n\nWhen specifying port 389, it still tries to go on port 636.\n<img width=\"544\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/72ccf208-a761-45c3-80fc-fcb979e98914\" />\n\nWhen specifying port 636, it works correctly by going only on port 636 (not supported by my DC).\n<img width=\"542\" alt=\"Image\" src=\"https://github.com/user-attachments/assets/fc622e33-3641-40f7-bef3-86e9c79e280e\" />\n\n**Expected behavior**\nWhen specifying port 389 it shouldn't try to go on port 636.\n\n**NetExec info**\n - Version of nxc: netexec 1.4.0+393.fde3de72\n - Installed from: pipx\n\n", "hints_text": "i yes, it's for the binding and signing check no @NeffIsBack ? maybe a new flag should be added like smb `--no-smbv1`\nExactly\nYeah probably. Or we just skip the check when `--port 363` is explicitly specified\n> Yeah probably. Or we just skip the check when `--port 363` is explicitly specified\n\nyes ^^\n\n", "all_hints_text": "i yes, it's for the binding and signing check no @NeffIsBack ? maybe a new flag should be added like smb `--no-smbv1`\nExactly\nYeah probably. Or we just skip the check when `--port 363` is explicitly specified\n> Yeah probably. Or we just skip the check when `--port 363` is explicitly specified\n\nyes ^^\n\n", "commit_urls": ["https://github.com/Pennyw0rth/NetExec/commit/659c2256dcdf80ab5bbb93faf8862cd49be0110a"], "created_at": "2025-06-16T18:36:48Z"}
{"repo": "Pennyw0rth/NetExec", "pull_number": 743, "instance_id": "Pennyw0rth__NetExec-743", "issue_numbers": [742], "base_commit": "0630e22503444d68b433de6d64a75449b55e8e2d", "patch": "diff --git a/nxc/protocols/ldap.py b/nxc/protocols/ldap.py\nindex 6f4237ae47..5ecf095c86 100644\n--- a/nxc/protocols/ldap.py\n+++ b/nxc/protocols/ldap.py\n@@ -276,7 +276,7 @@ def check_ldaps_cbt(self):\n                 self.logger.debug(f\"LDAPSessionError while checking for channel binding requirements (likely NTLM disabled): {e!s}\")\n         except SysCallError as e:\n             self.logger.debug(f\"Received SysCallError when trying to enumerate channel binding support: {e!s}\")\n-            if e.args[1] == \"ECONNRESET\":\n+            if e.args[1] in [\"ECONNRESET\", \"WSAECONNRESET\"]:\n                 self.cbt_status = \"No TLS cert\"\n             else:\n                 raise\n", "test_patch": "", "problem_statement": "Ldap win errors\nLdap errors on windows netexec (pipx install)\n\nnxc ldap 192.168.100.1 -u user -p 'password' -M enum_trusts \nand other ldap commands . on Debian all ok .\n```\n[01:30:23] ERROR    Exception while calling proto_flow() on target 192.168.100.11: (10054,             connection.py:176\n                    'WSAECONNRESET')\n                    \u256d\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 Traceback (most recent call last) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\n                    \u2502 C:\\Users\\4\\pipx\\venvs\\netexec\\Lib\\site-packages\\nxc\\connection.py:168 in       \u2502\n                    \u2502 __init__                                                                       \u2502\n                    \u2502                                                                                \u2502\n                    \u2502   165 \u2502   \u2502   self.logger.info(f\"Socket info: host={self.host}, hostname={self \u2502\n                    \u2502       kerberos={self.kerberos}, ipv6={self.is_ipv6}, link-local                \u2502\n                    \u2502       ipv6={self.is_link_local_ipv6}\")                                         \u2502\n                    \u2502   166 \u2502   \u2502                                                                    \u2502\n                    \u2502   167 \u2502   \u2502   try:                                                             \u2502\n                    \u2502 \u2771 168 \u2502   \u2502   \u2502   self.proto_flow()                                            \u2502\n                    \u2502   169 \u2502   \u2502   except Exception as e:                                           \u2502\n                    \u2502   170 \u2502   \u2502   \u2502   if \"ERROR_DEPENDENT_SERVICES_RUNNING\" in str(e):             \u2502\n                    \u2502   171 \u2502   \u2502   \u2502   \u2502   self.logger.error(f\"Exception while calling proto_flow() \u2502\n                    \u2502       {target}: {e}\")                                                          \u2502\n                    \u2502                                                                                \u2502\n                    \u2502 C:\\Users\\4\\pipx\\venvs\\netexec\\Lib\\site-packages\\nxc\\connection.py:233 in       \u2502\n                    \u2502 proto_flow                                                                     \u2502\n                    \u2502                                                                                \u2502\n                    \u2502   230 \u2502   \u2502   \u2502   self.logger.info(f\"Failed to create connection object for ta \u2502\n                    \u2502       {self.host}, exiting...\")                                                \u2502\n                    \u2502   231 \u2502   \u2502   else:                                                            \u2502\n                    \u2502   232 \u2502   \u2502   \u2502   self.logger.debug(\"Created connection object\")               \u2502\n                    \u2502 \u2771 233 \u2502   \u2502   \u2502   self.enum_host_info()                                        \u2502\n                    \u2502   234 \u2502   \u2502   \u2502   self.print_host_info()                                       \u2502\n                    \u2502   235 \u2502   \u2502   \u2502   if self.login() or (self.username == \"\" and self.password == \u2502\n                    \u2502   236 \u2502   \u2502   \u2502   \u2502   if hasattr(self.args, \"module\") and self.args.module:    \u2502\n                    \u2502                                                                                \u2502\n                    \u2502 C:\\Users\\4\\pipx\\venvs\\netexec\\Lib\\site-packages\\nxc\\protocols\\ldap.py:318 in   \u2502\n                    \u2502 enum_host_info                                                                 \u2502\n                    \u2502                                                                                \u2502\n                    \u2502    315 \u2502   \u2502   if getattr(self.args, \"port_explicitly_set\", False) and self.po \u2502\n                    \u2502    316 \u2502   \u2502   \u2502   self.cbt_status = \"Unknown\"                                 \u2502\n                    \u2502    317 \u2502   \u2502   else:                                                           \u2502\n                    \u2502 \u2771  318 \u2502   \u2502   \u2502   self.check_ldaps_cbt()                                      \u2502\n                    \u2502    319 \u2502   \u2502                                                                   \u2502\n                    \u2502    320 \u2502   \u2502   # using kdcHost is buggy on impacket when using trust relation  \u2502\n                    \u2502        kdcHost must stay to none if targetdomain is not equal to domain        \u2502\n                    \u2502    321 \u2502   \u2502   if not self.kdcHost and self.domain and self.domain == self.tar \u2502\n                    \u2502                                                                                \u2502\n                    \u2502 C:\\Users\\4\\pipx\\venvs\\netexec\\Lib\\site-packages\\nxc\\protocols\\ldap.py:256 in   \u2502\n                    \u2502 check_ldaps_cbt                                                                \u2502\n                    \u2502                                                                                \u2502\n                    \u2502    253 \u2502   \u2502   self.cbt_status = \"Never\"                                       \u2502\n                    \u2502    254 \u2502   \u2502   ldap_url = f\"ldaps://{self.target}\"                             \u2502\n                    \u2502    255 \u2502   \u2502   try:                                                            \u2502\n                    \u2502 \u2771  256 \u2502   \u2502   \u2502   ldap_connection = ldap_impacket.LDAPConnection(url=ldap_url \u2502\n                    \u2502        baseDN=self.baseDN, dstIp=self.host)                                    \u2502\n                    \u2502    257 \u2502   \u2502   \u2502   ldap_connection._LDAPConnection__channel_binding_value = No \u2502\n                    \u2502    258 \u2502   \u2502   \u2502   ldap_connection.login(user=\" \", domain=self.domain)         \u2502\n                    \u2502    259 \u2502   \u2502   except ldap_impacket.LDAPSessionError as e:                     \u2502\n                    \u2502                                                                                \u2502\n                    \u2502 C:\\Users\\4\\pipx\\venvs\\netexec\\Lib\\site-packages\\impacket\\ldap\\ldap.py:144 in   \u2502\n                    \u2502 __init__                                                                       \u2502\n                    \u2502                                                                                \u2502\n                    \u2502   141 \u2502   \u2502   \u2502   ctx.set_options(SSL_OP_ALLOW_UNSAFE_LEGACY_RENEGOTIATION)    \u2502\n                    \u2502   142 \u2502   \u2502   \u2502   self._socket = SSL.Connection(ctx, self._socket)             \u2502\n                    \u2502   143 \u2502   \u2502   \u2502   self._socket.connect(sa)                                     \u2502\n                    \u2502 \u2771 144 \u2502   \u2502   \u2502   self._socket.do_handshake()                                  \u2502\n                    \u2502   145 \u2502   \u2502   \u2502                                                                \u2502\n                    \u2502   146 \u2502   \u2502   \u2502   # From:                                                      \u2502\n                    \u2502       https://github.com/ly4k/ldap3/commit/87f5760e5a68c2f91eac8ba375f4ea3928e \u2502\n                    \u2502       790cfa0a948362bf47d72df8ddd6daac12e5757afd9d371d89385b27ef6R1383         \u2502\n                    \u2502   147 \u2502   \u2502   \u2502   from hashlib import md5                                      \u2502\n                    \u2502                                                                                \u2502\n                    \u2502 C:\\Users\\4\\pipx\\venvs\\netexec\\Lib\\site-packages\\OpenSSL\\SSL.py:2202 in         \u2502\n                    \u2502 do_handshake                                                                   \u2502\n                    \u2502                                                                                \u2502\n                    \u2502   2199 \u2502   \u2502   :return: None.                                                  \u2502\n                    \u2502   2200 \u2502   \u2502   \"\"\"                                                             \u2502\n                    \u2502   2201 \u2502   \u2502   result = _lib.SSL_do_handshake(self._ssl)                       \u2502\n                    \u2502 \u2771 2202 \u2502   \u2502   self._raise_ssl_error(self._ssl, result)                        \u2502\n                    \u2502   2203 \u2502                                                                       \u2502\n                    \u2502   2204 \u2502   def renegotiate_pending(self):                                      \u2502\n                    \u2502   2205 \u2502   \u2502   \"\"\"                                                             \u2502\n                    \u2502                                                                                \u2502\n                    \u2502 C:\\Users\\4\\pipx\\venvs\\netexec\\Lib\\site-packages\\OpenSSL\\SSL.py:1827 in         \u2502\n                    \u2502 _raise_ssl_error                                                               \u2502\n                    \u2502                                                                                \u2502\n                    \u2502   1824 \u2502   \u2502   \u2502   \u2502   \u2502   \u2502   errno = _ffi.errno                              \u2502\n                    \u2502   1825 \u2502   \u2502   \u2502   \u2502   \u2502                                                       \u2502\n                    \u2502   1826 \u2502   \u2502   \u2502   \u2502   \u2502   if errno != 0:                                      \u2502\n                    \u2502 \u2771 1827 \u2502   \u2502   \u2502   \u2502   \u2502   \u2502   raise SysCallError(errno, errorcode.get(errno)) \u2502\n                    \u2502   1828 \u2502   \u2502   \u2502   \u2502   raise SysCallError(-1, \"Unexpected EOF\")                \u2502\n                    \u2502   1829 \u2502   \u2502   \u2502   else:                                                       \u2502\n                    \u2502   1830 \u2502   \u2502   \u2502   \u2502   # TODO: This is untested.                               \u2502\n                    \u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\n                    SysCallError: (10054, 'WSAECONNRESET')\n...\n```\n\n**NetExec info**\n - OS: win\n - Version of nxc: 1.4.0+395.a48cbdb5, installed using Python 3.11.0\n- pipx \n\n\n**Additional context**\npackage impacket 0.12.0, installed using Python 3.11.0\n\n\n", "hints_text": "Dang it, of course python throws other syscall errors on windows then on Linux. We just need to add the WSAECONNRESET error to the existing check line 279 in ldap.py\n\n", "all_hints_text": "Dang it, of course python throws other syscall errors on windows then on Linux. We just need to add the WSAECONNRESET error to the existing check line 279 in ldap.py\n\n", "commit_urls": ["https://github.com/Pennyw0rth/NetExec/commit/79b6c7a2ad8a331207392901c37770b158b0f5fa"], "created_at": "2025-06-17T11:42:46Z"}
{"repo": "Pennyw0rth/NetExec", "pull_number": 750, "instance_id": "Pennyw0rth__NetExec-750", "issue_numbers": [746], "base_commit": "4d0f950de044eba0f3dbfc99307d3c0b7d4aded8", "patch": "diff --git a/nxc/logger.py b/nxc/logger.py\nindex ad707e0738..3edee2bc31 100755\n--- a/nxc/logger.py\n+++ b/nxc/logger.py\n@@ -182,9 +182,9 @@ def add_file_log(self, log_file=None):\n \n         with file_handler._open() as f:\n             if file_creation:\n-                f.write(f\"[{datetime.now().strftime('%d-%m-%Y %H:%M:%S')}]> {' '.join(sys.argv)}\\n\\n\")\n+                f.write(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}]> {' '.join(sys.argv)}\\n\\n\")\n             else:\n-                f.write(f\"\\n[{datetime.now().strftime('%d-%m-%Y %H:%M:%S')}]> {' '.join(sys.argv)}\\n\\n\")\n+                f.write(f\"\\n[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}]> {' '.join(sys.argv)}\\n\\n\")\n \n         file_handler.setFormatter(file_formatter)\n         self.logger.addHandler(file_handler)\ndiff --git a/nxc/protocols/ldap.py b/nxc/protocols/ldap.py\nindex 491c4b57a2..b2fd110161 100644\n--- a/nxc/protocols/ldap.py\n+++ b/nxc/protocols/ldap.py\n@@ -323,7 +323,8 @@ def enum_host_info(self):\n             self.kdcHost = result[\"host\"] if result else None\n             self.logger.info(f\"Resolved domain: {self.domain} with dns, kdcHost: {self.kdcHost}\")\n \n-        self.output_filename = os.path.expanduser(f\"{NXC_PATH}/logs/{self.hostname}_{self.host}\".replace(\":\", \"-\"))\n+        filename = f\"{self.hostname}_{self.host}\".replace(\":\", \"-\")\n+        self.output_filename = os.path.expanduser(os.path.join(NXC_PATH, \"logs\", filename))\n \n         try:\n             self.db.add_host(\n", "test_patch": "", "problem_statement": "Ldap --bloodhound --collection All does not correctly save on Windows\n**Describe the bug**\nSaving Bloodhound collection data fails on Windows with a `No such file or directory` error.\n\n**To Reproduce**\nCommand: `nxc ldap 10