@@ -5158,9 +5138,9 @@ dependencies = [\n     { name = \"tokenizers\" },\n     { name = \"tqdm\" },\n ]\n-sdist = { url = \"https://files.pythonhosted.org/packages/84/eb/259afff0df9ece338dc224007bbe7dd6c9aae8e26957dc4033a3ec857588/transformers-4.42.4.tar.gz\", hash = \"sha256:f956e25e24df851f650cb2c158b6f4352dfae9d702f04c113ed24fc36ce7ae2d\", size = 8054872, upload-time = \"2024-07-11T17:09:40.505Z\" }\n+sdist = { url = \"https://files.pythonhosted.org/packages/c4/35/67252acc1b929dc88b6602e8c4a982e64f31e733b804c14bc24b47da35e6/transformers-4.57.6.tar.gz\", hash = \"sha256:55e44126ece9dc0a291521b7e5492b572e6ef2766338a610b9ab5afbb70689d3\", size = 10134912, upload-time = \"2026-01-16T10:38:39.284Z\" }\n wheels = [\n-    { url = \"https://files.pythonhosted.org/packages/6a/dc/23c26b7b0bce5aaccf2b767db3e9c4f5ae4331bd47688c1f2ef091b23696/transformers-4.42.4-py3-none-any.whl\", hash = \"sha256:6d59061392d0f1da312af29c962df9017ff3c0108c681a56d1bc981004d16d24\", size = 9337817, upload-time = \"2024-07-11T17:09:33.96Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/03/b8/e484ef633af3887baeeb4b6ad12743363af7cce68ae51e938e00aaa0529d/transformers-4.57.6-py3-none-any.whl\", hash = \"sha256:4c9e9de11333ddfe5114bc872c9f370509198acf0b87a832a0ab9458e2bd0550\", size = 11993498, upload-time = \"2026-01-16T10:38:31.289Z\" },\n ]\n \n [[package]]\n", "test_patch": "diff --git a/tests/test_cpu_only_install.py b/tests/test_cpu_only_install.py\nnew file mode 100644\nindex 00000000..1e1e52c0\n--- /dev/null\n+++ b/tests/test_cpu_only_install.py\n@@ -0,0 +1,61 @@\n+\"\"\"Packaging metadata checks for CPU-only installs.\"\"\"\n+\n+from pathlib import Path\n+\n+import pytest\n+\n+try:\n+    import tomllib\n+except ModuleNotFoundError:  # pragma: no cover - fallback for Python < 3.11\n+    tomllib = pytest.importorskip(\"tomli\")\n+\n+\n+def _load_leann_pyproject():\n+    pyproject_path = Path(__file__).resolve().parents[1] / \"packages\" / \"leann\" / \"pyproject.toml\"\n+    return tomllib.loads(pyproject_path.read_text())\n+\n+\n+def _load_leann_core_pyproject():\n+    pyproject_path = (\n+        Path(__file__).resolve().parents[1] / \"packages\" / \"leann-core\" / \"pyproject.toml\"\n+    )\n+    return tomllib.loads(pyproject_path.read_text())\n+\n+\n+def test_leann_base_dependencies_include_diskann():\n+    data = _load_leann_pyproject()\n+    deps = data[\"project\"].get(\"dependencies\", [])\n+\n+    assert \"leann-core>=0.1.0\" in deps\n+    assert \"leann-backend-hnsw>=0.1.0\" in deps\n+    assert \"leann-backend-diskann>=0.1.0\" in deps\n+\n+\n+def test_leann_core_numpy_pinned_below_2():\n+    data = _load_leann_core_pyproject()\n+    deps = data[\"project\"].get(\"dependencies\", [])\n+\n+    assert any(dep.startswith(\"numpy\") and \"<2\" in dep for dep in deps)\n+\n+\n+def test_leann_core_cpu_extra_pins_cpu_torch():\n+    data = _load_leann_core_pyproject()\n+    extras = data[\"project\"].get(\"optional-dependencies\", {})\n+\n+    cpu_deps = extras.get(\"cpu\", [])\n+    assert cpu_deps, \"cpu extra should be defined\"\n+    assert any(\n+        dep.startswith(\"torch\")\n+        and \"==2.2.2\" in dep\n+        and \"platform_system == 'Linux'\" in dep\n+        and \"python_version < '3.13'\" in dep\n+        for dep in cpu_deps\n+    )\n+\n+\n+def test_leann_cpu_extra_defined():\n+    data = _load_leann_pyproject()\n+    extras = data[\"project\"].get(\"optional-dependencies\", {})\n+\n+    assert \"cpu\" in extras\n+    assert \"leann-core[cpu]>=0.1.0\" in extras[\"cpu\"]\n", "problem_statement": "CPU only package install\n### What problem does this solve?\n\nMany of us would like to use LEANN in their local environments or containers without GPU. When someone `uv tool install leann-core@0.3.6 --with leann`, the package installer installs various GPU-only packages, like `nvidia*` including a huge and unnecessary dependency tree into the final build. This makes it really hard to build LEANN into a container.\n\n### Proposed solution\n\nOffer a LEANN subpackage like `leann-core[cpu]` or similar that would depend only on CPU-only dependencies, including transitive dependencies, like pythorch.\n\n### Example usage\n\n```python\n`uv tool install leann-core[cpu]@0.3.6 --with leann`\n```\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/yichuan-w/LEANN/commit/60c94fa9cb2aecdbcae554eb9c5997cde4f74e07", "https://github.com/yichuan-w/LEANN/commit/0c467e1aa4f9da24f6ab0badb217c7c27ffb2fd3", "https://github.com/yichuan-w/LEANN/commit/0c31b1e14b1a1a44e393fde1994269896eadf2e4", "https://github.com/yichuan-w/LEANN/commit/fb3dfd85995d3712e45f35267f361e00d08914c1", "https://github.com/yichuan-w/LEANN/commit/02a77742245dbbac4efbf3a74ab2c10c9d5397af", "https://github.com/yichuan-w/LEANN/commit/720ac8a584b0b3a94670db0ee8e572ac9e4413a7", "https://github.com/yichuan-w/LEANN/commit/ec2e3917fb2ca3d7985c7616591992f5d0ab7587"], "created_at": "2026-02-11T08:12:34Z"}
