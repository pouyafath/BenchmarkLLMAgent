n} \"\n+                    '. \"$HOME/.local/bin/env\"; '\n+                    f\"mini-swe-agent --yolo --model={self.model_name} --task={escaped_instruction} \"\n                     f\"--output={self._mini_swe_agent_trajectory_path} --cost-limit=0 \"\n                     f\"--exit-immediately 2>&1 </dev/null | tee /logs/agent/mini-swe-agent.txt\"\n                 ),\ndiff --git a/src/harbor/agents/installed/opencode.py b/src/harbor/agents/installed/opencode.py\nindex 6982ce90ed7..032e1094cd3 100644\n--- a/src/harbor/agents/installed/opencode.py\n+++ b/src/harbor/agents/installed/opencode.py\n@@ -365,6 +365,7 @@ def create_run_agent_commands(self, instruction: str) -> list[ExecInput]:\n         commands.append(\n             ExecInput(\n                 command=(\n+                    \". ~/.nvm/nvm.sh; \"\n                     f\"opencode --model={self.model_name} run --format=json -- {escaped_instruction} \"\n                     f\"2>&1 | tee /logs/agent/opencode.txt\"\n                 ),\ndiff --git a/src/harbor/agents/installed/qwen_code.py b/src/harbor/agents/installed/qwen_code.py\nindex 5574b59f5dd..6444584c562 100644\n--- a/src/harbor/agents/installed/qwen_code.py\n+++ b/src/harbor/agents/installed/qwen_code.py\n@@ -84,6 +84,7 @@ def create_run_agent_commands(self, instruction: str) -> list[ExecInput]:\n         commands.append(\n             ExecInput(\n                 command=(\n+                    \". ~/.nvm/nvm.sh; \"\n                     f\"qwen --yolo --prompt={escaped_instruction} \"\n                     f\"2>&1 | tee /logs/agent/qwen-code.txt\"\n                 ),\ndiff --git a/src/harbor/agents/installed/swe_agent.py b/src/harbor/agents/installed/swe_agent.py\nindex aa2ca704701..295b884efd8 100644\n--- a/src/harbor/agents/installed/swe_agent.py\n+++ b/src/harbor/agents/installed/swe_agent.py\n@@ -323,6 +323,7 @@ def create_run_agent_commands(self, instruction: str) -> list[ExecInput]:\n \n         full_cmd = (\n             \"set -euo pipefail\\n\"\n+            \". /etc/profile.d/testbed-conda.sh\\n\"\n             f\"{download_config_cmd}\"\n             f\"{write_instruction_cmd}\"\n             f\"{command} 2>&1 | tee /logs/agent/swe-agent.txt\\n\"\ndiff --git a/src/harbor/environments/daytona.py b/src/harbor/environments/daytona.py\nindex 6954ac1daa0..fea332c0bcf 100644\n--- a/src/harbor/environments/daytona.py\n+++ b/src/harbor/environments/daytona.py\n@@ -481,7 +481,7 @@ async def exec(\n         try:\n             await self._sandbox.process.create_session(session_id)\n \n-            command = f\"bash -lc {shlex.quote(command)}\"\n+            command = f\"bash -c {shlex.quote(command)}\"\n \n             if env:\n                 for key, value in env.items():\ndiff --git a/src/harbor/environments/docker/docker.py b/src/harbor/environments/docker/docker.py\nindex fb814770af1..0f0f6536318 100644\n--- a/src/harbor/environments/docker/docker.py\n+++ b/src/harbor/environments/docker/docker.py\n@@ -342,7 +342,7 @@ async def exec(\n                 exec_command.extend([\"-e\", f\"{key}={shlex.quote(value)}\"])\n \n         exec_command.append(\"main\")\n-        exec_command.extend([\"bash\", \"-lc\", command])\n+        exec_command.extend([\"bash\", \"-c\", command])\n \n         return await self._run_docker_compose_command(\n             exec_command, check=False, timeout_sec=timeout_sec\ndiff --git a/src/harbor/environments/gke.py b/src/harbor/environments/gke.py\nindex 2e7ffd0873c..1d37a5ada3c 100644\n--- a/src/harbor/environments/gke.py\n+++ b/src/harbor/environments/gke.py\n@@ -583,7 +583,7 @@ async def exec(\n         \"\"\"Execute command in pod using kubectl exec equivalent.\"\"\"\n         await self._ensure_client()\n \n-        full_command = f\"bash -lc {shlex.quote(command)}\"\n+        full_command = f\"bash -c {shlex.quote(command)}\"\n \n         if env:\n             for key, value in env.items():\ndiff --git a/src/harbor/environments/modal.py b/src/harbor/environments/modal.py\nindex 4853480c552..af7964d400a 100644\n--- a/src/harbor/environments/modal.py\n+++ b/src/harbor/environments/modal.py\n@@ -341,7 +341,7 @@ async def exec(\n \n         process = await self._sandbox.exec.aio(\n             \"bash\",\n-            \"-lc\",\n+            \"-c\",\n             command,\n             workdir=cwd,\n             secrets=[Secret.from_dict(env)] if env else [],  # type: ignore\ndiff --git a/src/harbor/environments/runloop.py b/src/harbor/environments/runloop.py\nindex d9f24be1b80..4565dcabcb8 100644\n--- a/src/harbor/environments/runloop.py\n+++ b/src/harbor/environments/runloop.py\n@@ -398,7 +398,7 @@ async def exec(\n         if not self._devbox or not self._client:\n             raise RuntimeError(\"Devbox not found. Please build the environment first.\")\n \n-        full_command = f\"bash -lc {shlex.quote(command)}\"\n+        full_command = f\"bash -c {shlex.quote(command)}\"\n \n         # Add environment variables\n         if env:\n", "test_patch": "diff --git a/tests/runtime/test_installed_agent.py b/tests/runtime/test_installed_agent.py\nindex 8fc0fbe3026..e084c062ff8 100644\n--- a/tests/runtime/test_installed_agent.py\n+++ b/tests/runtime/test_installed_agent.py\n@@ -135,9 +135,6 @@ async def test_successful_agent_installation(dummy_success_agent, mock_environme\n     await dummy_success_agent.setup(mock_environment)\n \n     # Verify setup calls were made correctly\n-    mock_environment.exec.assert_any_call(\n-        command=\"echo 'PS1=1 . ~/.bashrc 2>/dev/null; unset PS1' >> ~/.bash_profile\"\n-    )\n     mock_environment.exec.assert_any_call(command=\"mkdir -p /installed-agent\")\n     mock_environment.upload_file.assert_called_once()\n     mock_environment.exec.assert_any_call(\n@@ -164,9 +161,6 @@ async def test_failed_agent_installation(dummy_failure_agent, mock_environment):\n     assert \"Agent setup failed with exit code 1\" in str(exc_info.value)\n \n     # Verify setup calls were made\n-    mock_environment.exec.assert_any_call(\n-        command=\"echo 'PS1=1 . ~/.bashrc 2>/dev/null; unset PS1' >> ~/.bash_profile\"\n-    )\n     mock_environment.exec.assert_any_call(command=\"mkdir -p /installed-agent\")\n     mock_environment.upload_file.assert_called_once()\n     mock_environment.exec.assert_any_call(\ndiff --git a/tests/unit/agents/installed/test_agent_install_execution.py b/tests/unit/agents/installed/test_agent_install_execution.py\nindex eb3cfd7114e..03373b4bf7f 100644\n--- a/tests/unit/agents/installed/test_agent_install_execution.py\n+++ b/tests/unit/agents/installed/test_agent_install_execution.py\n@@ -163,6 +163,21 @@ def create_mock_bin_directory(tmpdir: Path) -> Path:\n \"\"\")\n     (bin_dir / \"uv\").chmod(0o755)\n \n+    # Mock pip/pip3/pipx\n+    for name in [\n+        \"aider\",\n+        \"claude\",\n+        \"codex\",\n+        \"cursor-agent\",\n+        \"gemini\",\n+        \"goose\",\n+        \"mini-swe-agent\",\n+        \"opencode\",\n+        \"qwen\",\n+    ]:\n+        (bin_dir / name).write_text(f'#!/bin/bash\\necho \"mock {name} $@\" >&2\\n')\n+        (bin_dir / name).chmod(0o755)\n+\n     return bin_dir\n \n \ndiff --git a/tests/unit/agents/installed/test_claude_code_mcp.py b/tests/unit/agents/installed/test_claude_code_mcp.py\nindex 0de99138a10..62d097d8d07 100644\n--- a/tests/unit/agents/installed/test_claude_code_mcp.py\n+++ b/tests/unit/agents/installed/test_claude_code_mcp.py\n@@ -99,5 +99,5 @@ def test_uses_bypass_permissions_mode(self, temp_dir):\n         agent = ClaudeCode(logs_dir=temp_dir)\n         commands = agent.create_run_agent_commands(\"do something\")\n         run_cmd = commands[1].command\n-        assert \"--permission-mode bypassPermissions\" in run_cmd\n+        assert \"--permission-mode=bypassPermissions\" in run_cmd\n         assert \"--allowedTools\" not in run_cmd\ndiff --git a/tests/unit/agents/installed/test_mini_swe_agent.py b/tests/unit/agents/installed/test_mini_swe_agent.py\nindex c53cbe09698..b5f6628f36e 100644\n--- a/tests/unit/agents/installed/test_mini_swe_agent.py\n+++ b/tests/unit/agents/installed/test_mini_swe_agent.py\n@@ -24,7 +24,6 @@\n )\n from harbor.models.agent.context import AgentContext\n \n-\n # ---------------------------------------------------------------------------\n # Fixtures: realistic v2 tool-calling trajectory data\n # ---------------------------------------------------------------------------\n@@ -710,7 +709,7 @@ def test_uses_mini_command(self, temp_dir):\n \n         assert len(commands) == 1\n         cmd = commands[0].command\n-        assert cmd.startswith(\"mini \")\n+        assert \"mini-swe-agent \" in cmd\n         assert \"--yolo\" in cmd\n         assert \"--model=anthropic/claude-sonnet-4-5-20250929\" in cmd\n         assert \"--cost-limit=0\" in cmd\n", "problem_statement": "Bug: breaking change from `bash -ic` to `bash -lc`\nSee https://github.com/laude-institute/harbor/commit/0451b64acba4fe61685fed5008111b5c2fec6f71\n\nBefore:\n\n```sh\ndocker run --rm rust:1.82 bash -ic 'echo $PATH && cargo --version'\n\nbash: cannot set terminal process group (-1): Inappropriate ioctl for device\nbash: no job control in this shell\n/usr/local/cargo/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\ncargo 1.82.0 (8f40fc59f 2024-08-21)\n```\n\nIt works well \n\nAfter:\n\n```sh\ndocker run --rm rust:1.82 bash -lc 'echo $PATH && cargo --version'\n\n/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\nbash: line 1: cargo: command not found\n```\n\ncargo: command not found\n\n\n---\n\nWhy this will break harbor tasks?\n\n```sh\ndocker run --rm rust:1.82 head -n9 /etc/profile\n\n# /etc/profile: system-wide .profile file for the Bourne shell (sh(1))\n# and Bourne compatible shells (bash(1), ksh(1), ash(1), ...).\n\nif [ \"$(id -u)\" -eq 0 ]; then\n  PATH=\"/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\"\nelse\n  PATH=\"/usr/local/bin:/usr/bin:/bin:/usr/local/games:/usr/games\"\nfi\nexport PATH\n```\n\n`bash -lc` will execute code write in `/etc/profile` and overwrite PATH defined in [Rust's Dockerfile](https://github.com/rust-lang/docker-rust/blob/f3d1333d1021c326a214ce9d0f1c298e8576a961/Dockerfile-slim.template#L5-L8)\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/harbor-framework/harbor/commit/3106cc4a12902ba04169c9123f39dca89385b9d2"], "created_at": "2026-02-14T15:23:31Z"}
{"repo": "harbor-framework/harbor", "pull_number": 700, "instance_id": "harbor-framework__harbor-700", "issue_numbers": [698], "base_commit": "fabc82b724b2d5f4eaa0cd3e8d718a55c3ca3525", "patch": "diff --git a/src/harbor/agents/installed/openhands.py b/src/harbor/agents/installed/openhands.py\nindex 3eb8b612aed..da557f69a4c 100644\n--- a/src/harbor/agents/installed/openhands.py\n+++ b/src/harbor/agents/installed/openhands.py\n@@ -33,7 +33,7 @@ def __init__(\n         self,\n         disable_tool_calls: bool = False,\n         trajectory_config: TrajectoryConfig | None = None,\n-        reasoning_effort: str | None = \"medium\",\n+        reasoning_effort: str | None = \"high\",\n         *args,\n         **kwargs,\n     ):\n@@ -865,8 +865,6 @@ def create_run_agent_commands(self, instruction: str) -> list[ExecInput]:\n         reasoning_effort = self._reasoning_effort\n         if reasoning_effort is not None:\n             env[\"LLM_REASONING_EFFORT\"] = str(reasoning_effort)\n-        elif \"LLM_REASONING_EFFORT\" in os.environ:\n-            env[\"LLM_REASONING_EFFORT\"] = os.environ[\"LLM_REASONING_EFFORT\"]\n \n         # Disable browsing and prompt extensions\n         env[\"AGENT_ENABLE_PROMPT_EXTENSIONS\"] = \"false\"\n", "test_patch": "", "problem_statement": "reasoning_effort default in OpenHands silently blocks env var fallback\n## Description\n\nTwo issues with `reasoning_effort` in OpenHands agent:\n\n1. **Inconsistent default value**: OpenHands defaults to `\"medium\"` while Codex defaults to `\"high\"`.\n\n2. **Dead code / env var never used**: Because `reasoning_effort` defaults to `\"medium\"` in `__init__`, `self._reasoning_effort` is always non-`None`. This means the elif branch in `create_run_agent_commands` is never reached:\n\n```python\n# Set reasoning_effort from kwargs or environment variable\nreasoning_effort = self._reasoning_effort\nif reasoning_effort is not None:\n    env[\"LLM_REASONING_EFFORT\"] = str(reasoning_effort)\nelif \"LLM_REASONING_EFFORT\" in os.environ:\n    env[\"LLM_REASONING_EFFORT\"] = os.environ[\"LLM_REASONING_EFFORT\"]\n```\n\n## Expected behavior\nTo be consistent with the Codex, maybe we need to:\n1. set `reasoning_effort` defaults to `\"high\"`\n2. uniformly use `--agent-kwarg` to pass in `reasoning_effort` and no longer read it from env var to avoid confusion.\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/harbor-framework/harbor/commit/d4539562f302ffd6eb73bbb3ebb5ab19030b665c"], "created_at": "2026-02-13T16:00:13Z"}
{"repo": "harbor-framework/harbor", "pull_number": 1186, "instance_id": "harbor-framework__harbor-1186", "issue_numbers": [1185], "base_commit": "3aab9a695a616f45174dc3eba9a455b9ddbaa0b9", "patch": "diff --git a/src/harbor/agents/installed/kimi_cli.py b/src/harbor/agents/installed/kimi_cli.py\nindex 60274a57333..cc0c39d067d 100644\n--- a/src/harbor/agents/installed/kimi_cli.py\n+++ b/src/harbor/agents/installed/kimi_cli.py\n@@ -5,6 +5,8 @@\n from pathlib import Path\n from typing import Any\n \n+from litellm.utils import get_model_info\n+\n from harbor.agents.installed.base import BaseInstalledAgent, ExecInput\n from harbor.models.agent.context import AgentContext\n from harbor.models.agent.name import AgentName\n@@ -99,11 +101,21 @@ def get_version_command(self) -> str | None:\n \n     SUPPORTS_ATIF: bool = True\n \n+    _DEFAULT_MAX_CONTEXT_SIZE: int = 131072\n+\n     def __init__(self, *args, **kwargs):\n         self._api_key: str | None = kwargs.pop(\"api_key\", None)\n         self._base_url: str | None = kwargs.pop(\"base_url\", None)\n+        model_info: dict[str, Any] | None = kwargs.pop(\"model_info\", None)\n         super().__init__(*args, **kwargs)\n \n+        if model_info and self.model_name:\n+            import litellm\n+\n+            litellm.register_model({self.model_name: model_info})\n+\n+        self._max_context_size = self._resolve_max_context_size()\n+\n     @staticmethod\n     def name() -> str:\n         return AgentName.KIMI_CLI.value\n@@ -122,6 +134,15 @@ def _resolve_api_key(self, provider: str) -> str:\n                 return val\n         return \"\"\n \n+    def _resolve_max_context_size(self) -> int:\n+        if not self.model_name:\n+            return self._DEFAULT_MAX_CONTEXT_SIZE\n+        try:\n+            info = get_model_info(self.model_name)\n+            return info.get(\"max_input_tokens\") or self._DEFAULT_MAX_CONTEXT_SIZE\n+        except Exception:\n+            return self._DEFAULT_MAX_CONTEXT_SIZE\n+\n     def _build_config_json(self, provider: str, model: str) -> str:\n         pcfg = _PROVIDER_CONFIG.get(provider)\n         if pcfg is None:\n@@ -145,7 +166,7 @@ def _build_config_json(self, provider: str, model: str) -> str:\n                 \"model\": {\n                     \"provider\": \"harbor\",\n                     \"model\": model,\n-                    \"max_context_size\": 131072,\n+                    \"max_context_size\": self._max_context_size,\n                 }\n             },\n         }\n", "test_patch": "diff --git a/tests/unit/agents/installed/test_kimi_cli.py b/tests/unit/agents/installed/test_kimi_cli.py\nindex b60ef82a9f3..8bcaa11e223 100644\n--- a/tests/unit/agents/installed/test_kimi_cli.py\n+++ b/tests/unit/agents/installed/test_kimi_cli.py\n@@ -300,6 +300,59 @@ def test_no_output_file(self, kimi_agent: KimiCli):\n         assert context.n_input_tokens is None\n \n \n+class TestMaxContextSize:\n+    def test_model_info_registered_and_used(self, tmp_path: Path):\n+        \"\"\"model_info kwarg registers with litellm so get_model_info lookup returns it.\"\"\"\n+        agent = KimiCli(\n+            logs_dir=tmp_path,\n+            model_name=\"moonshot/kimi-k2-0905-preview\",\n+            api_key=\"sk-test\",\n+            model_info={\"max_input_tokens\": 262144, \"max_output_tokens\": 8192},\n+        )\n+        config = json.loads(\n+            agent._build_config_json(\"moonshot\", \"kimi-k2-0905-preview\")\n+        )\n+        assert config[\"models\"][\"model\"][\"max_context_size\"] == 262144\n+\n+    def test_litellm_lookup(self, tmp_path: Path, monkeypatch):\n+        \"\"\"When no model_info kwarg, falls back to LiteLLM database lookup.\"\"\"\n+\n+        def fake_get_model_info(model, *args, **kwargs):\n+            return {\"max_input_tokens\": 200000, \"max_tokens\": 200000}\n+\n+        monkeypatch.setattr(\n+            \"harbor.agents.installed.kimi_cli.get_model_info\", fake_get_model_info\n+        )\n+        agent = KimiCli(\n+            logs_dir=tmp_path,\n+            model_name=\"moonshot/kimi-k2-0905-preview\",\n+            api_key=\"sk-test\",\n+        )\n+        config = json.loads(\n+            agent._build_config_json(\"moonshot\", \"kimi-k2-0905-preview\")\n+        )\n+        assert config[\"models\"][\"model\"][\"max_context_size\"] == 200000\n+\n+    def test_fallback_when_litellm_fails(self, tmp_path: Path, monkeypatch):\n+        \"\"\"When LiteLLM has no info, falls back to 131072.\"\"\"\n+\n+        def fake_get_model_info(model, *args, **kwargs):\n+            raise Exception(\"model not found\")\n+\n+        monkeypatch.setattr(\n+            \"harbor.agents.installed.kimi_cli.get_model_info\", fake_get_model_info\n+        )\n+        agent = KimiCli(\n+            logs_dir=tmp_path,\n+            model_name=\"moonshot/kimi-k2-0905-preview\",\n+            api_key=\"sk-test\",\n+        )\n+        config = json.loads(\n+            agent._build_config_json(\"moonshot\", \"kimi-k2-0905-preview\")\n+        )\n+        assert config[\"models\"][\"model\"][\"max_context_size\"] == 131072\n+\n+\n class TestCreateRunCommands:\n     def test_creates_commands(self, tmp_path: Path):\n         agent = KimiCli(\n", "problem_statement": "kimi-cli fixed context length\nkimi-cli's `max_context_size: 131072` is set to fixed, but is outdated. The new `kimi-k2.5` supports 256k context window: https://platform.moonshot.ai/docs/guide/kimi-k2-5-quickstart#ultra-long-context-support.\n\nA change could follow the Terminus 2 pattern: accept an optional `model_info` dict kwarg, register it with `litellm.register_model()` if provided, then use `litellm.utils.get_model_info()` to resolve the model's `max_input_tokens` at config-build time. Priority: `model_info` registration (makes LiteLLM lookup succeed for custom models) > LiteLLM database lookup > hardcoded default (131072).\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/harbor-framework/harbor/commit/f9c78e51641e5b70e0a6267cd39b8757dd90eede"], "created_at": "2026-03-14T22:02:15Z"}
{"repo": "harbor-framework/harbor", "pull_number": 1217, "instance_id": "harbor-framework__harbor-1217", "issue_numbers": [1216], "base_commit": "a5c775f9c8cc0cffa72d84ebb459dfdbc608b5db", "patch": "diff --git a/src/harbor/environments/modal.py b/src/harbor/environments/modal.py\nindex f7c61e88140..d8825fe762f 100644\n--- a/src/harbor/environments/modal.py\n+++ b/src/harbor/environments/modal.py\n@@ -1,4 +1,6 @@\n+import asyncio\n import os\n+import shlex\n from pathlib import Path, PurePosixPath\n \n from modal import App, Image, Sandbox, Secret, Volume\n@@ -313,21 +315,32 @@ async def download_dir(self, source_dir: str, target_dir: Path | str):\n         target_dir = Path(target_dir)\n         target_dir.mkdir(parents=True, exist_ok=True)\n \n-        children = await self._sandbox.ls.aio(source_dir)\n+        result = await self.exec(f\"find {shlex.quote(source_dir)} -type f\")\n+        if result.return_code != 0:\n+            raise RuntimeError(f\"Failed to list files in {source_dir}: {result.stderr}\")\n \n-        for child_name in children:\n-            # Modal's ls returns just filenames, not full paths\n-            # Construct the full path by joining source_dir with the child name\n-            child_path = str(Path(source_dir) / child_name)\n-            relative_path = Path(child_name)\n-            local_path = target_dir / relative_path\n+        if not result.stdout or not result.stdout.strip():\n+            return\n+\n+        file_paths = [p for p in result.stdout.strip().split(\"\\n\") if p.strip()]\n+\n+        sem = asyncio.Semaphore(5)\n \n-            try:\n-                await self._sandbox.ls.aio(child_path)\n-                await self.download_dir(child_path, local_path)\n-            except NotADirectoryError:\n+        async def _download_one(remote_path: str) -> None:\n+            async with sem:\n+                rel = Path(remote_path).relative_to(Path(source_dir))\n+                local_path = target_dir / rel\n                 local_path.parent.mkdir(parents=True, exist_ok=True)\n-                await self.download_file(child_path, local_path)\n+                await self.download_file(remote_path, local_path)\n+\n+        results = await asyncio.gather(\n+            *[_download_one(p) for p in file_paths],\n+            return_exceptions=True,\n+        )\n+\n+        for r in results:\n+            if isinstance(r, Exception):\n+                raise r\n \n     async def is_dir(self, path: str) -> bool:\n         if not self._sandbox:\n", "test_patch": "", "problem_statement": "ModalEnvironment.download_dir() stalls on large directory trees (~80+ files)\n## Summary\n\n`ModalEnvironment.download_dir()` stalls indefinitely when downloading directory trees\nwith ~80+ files from a sandbox. The stall occurs in `sandbox.ls.aio()` after ~50-70\nsequential RPC calls, causing the verifier timeout to fire.\n\n## Root Cause\n\n`download_dir()` (modal.py:274-303) uses `sandbox.ls.aio()` as a type probe for every\nchild entry: call `ls(child_path)` \u2014 if it succeeds, recurse as directory; if it raises\n`NotADirectoryError`, download as file. This creates ~440 sequential RPCs for a 90-file\ntree, which triggers gRPC channel congestion in the Modal SDK after ~50-70 calls.\n\n## Reproduction\n\nSelf-contained reproduction: https://gist.github.com/ashtonchew/26d0b9de70ea67cb07aa6fc8e1f4dcb4\n\n```\ndataset/download-repro/\n\u251c\u2500\u2500 environment/Dockerfile     # python:3.12-slim\n\u251c\u2500\u2500 instruction.md             # \"Do nothing\"\n\u251c\u2500\u2500 main.py                    # print(\"ok\")\n\u251c\u2500\u2500 solution/solve.sh          # no-op\n\u251c\u2500\u2500 task.toml                  # 60s verifier timeout\n\u2514\u2500\u2500 tests/test.sh              # generates ~90 files across ~25 dirs\n```\n\nRun: `harbor run -c job.yaml`\n\n### Evidence\n\n- **Unpatched run (fails)**: https://gist.github.com/ashtonchew/35079504a9945819df56100c2d12af6e\n  - `VerifierTimeoutError` after 60 seconds\n  - Partial download: 27 of ~82 files\n  - `reward.txt` never downloaded\n\n- **Patched run (succeeds)**: https://gist.github.com/ashtonchew/cf4639d54815a2b81f729a3f4f0fa0c7\n  - Replaced `ls()`-probe with `exec(\"find -type f\")` + `asyncio.Semaphore(5)`\n  - All files downloaded, reward=1.0, verifier ~33s\n\n### Stack trace (unpatched)\n\n```\nFile \".../harbor/environments/modal.py\", line 300, in download_dir\n    await self.download_dir(child_path, local_path)\n  File \".../harbor/environments/modal.py\", line 299, in download_dir\n    await self._sandbox.ls.aio(child_path)\n  ...\n  File \".../synchronicity/synchronizer.py\", line 474, in _run_function_async\n    await a_fut\nasyncio.exceptions.CancelledError\n\u2192 TimeoutError \u2192 VerifierTimeoutError\n```\n\n## Environment\n\n- Harbor: 0.1.45\n- Modal SDK: 1.3.5\n- Python: 3.12\n- OS: macOS (Darwin 25.1.0, aarch64)\n\n## Suggested Fix\n\nReplace the recursive `ls()`-probe pattern with `exec(\"find <dir> -type f\")` +\n`asyncio.Semaphore(5)` + `asyncio.gather()`. This matches the existing pattern in\n`RunloopEnvironment.download_dir()` (runloop.py:434-455) and reduces RPCs from ~440\nsequential to ~291 with max ~20 in-flight.\n\nI have a PR ready to fix this and I'm happy to submit it.\n", "hints_text": "I can take this issue.\n\n", "all_hints_text": "I can take this issue.\n\n", "commit_urls": ["https://github.com/harbor-framework/harbor/commit/e7e63f77b7642767eac80129e2fa4b515566f47b", "https://github.com/harbor-framework/harbor/commit/e6f18a707abcfd0ff80f51f10c87b62e24880fe8", "https://github.com/harbor-framework/harbor/commit/b1c7b9b4031972057ce32ee0c6d4d6cac57a2754"], "created_at": "2026-03-17T19:18:43Z"}
{"repo": "harbor-framework/harbor", "pull_number": 1227, "instance_id": "harbor-framework__harbor-1227", "issue_numbers": [1226], "base_commit": "2b696492fc3c98485f8974fa655829094d07c172", "patch": "diff --git a/src/harbor/models/trial/config.py b/src/harbor/models/trial/config.py\nindex d5262aa44bf..75f523d1498 100644\n--- a/src/harbor/models/trial/config.py\n+++ b/src/harbor/models/trial/config.py\n@@ -152,4 +152,4 @@ def set_default_trial_name(self):\n     def generate_trial_name(self):\n         task_id = self.task.get_task_id()\n         task_name = task_id.get_name()\n-        return f\"{task_name[:32]}__{ShortUUID().random(length=7)}\"\n+        return f\"{task_name[:32].rstrip('-')}__{ShortUUID().random(length=7)}\"\n", "test_patch": "", "problem_statement": "Trailing hyphen in truncated trial name produces invalid Docker tag\n## Bug\n\nWhen a task name is longer than 32 characters and the truncation boundary falls right after a hyphen, `generate_trial_name` produces a name with a trailing hyphen before the `__` separator (e.g. `some-long-task-name-with-hyphens-__qxfbryt`), which Docker rejects as an invalid tag reference format.\n\n## Error\n\n```\ninvalid tag \"...-__qxfbryt-main\": invalid reference format\n```\n\n## Expected behavior\n\nTrailing hyphens should be stripped after truncation so the generated name is a valid Docker tag.\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/harbor-framework/harbor/commit/cf903f889c2bc51c097552efbd26fc4e15488e2d"], "created_at": "2026-03-18T17:48:51Z"}
{"repo": "harbor-framework/harbor", "pull_number": 1317, "instance_id": "harbor-framework__harbor-1317", "issue_numbers": [1278], "base_commit": "1bb632ab01e648f286e7ef1890673dc720ccc17c", "patch": "diff --git a/src/harbor/environments/gke.py b/src/harbor/environments/gke.py\nindex 04c99a00fe0..7d00161f368 100644\n--- a/src/harbor/environments/gke.py\n+++ b/src/harbor/environments/gke.py\n@@ -720,9 +720,42 @@ def _read_exec_output(self, resp):\n \n         return stdout, stderr\n \n+    async def _check_pod_terminated(self) -> None:\n+        \"\"\"Raise immediately if the pod or any container is in a terminal state.\"\"\"\n+        try:\n+            pod = await asyncio.to_thread(\n+                self._api.read_namespaced_pod,\n+                name=self.pod_name,\n+                namespace=self.namespace,\n+            )\n+        except ApiException:\n+            return\n+\n+        phase = pod.status.phase if pod.status else None\n+        if phase in (\"Failed\", \"Succeeded\"):\n+            raise RuntimeError(\n+                f\"Pod {self.pod_name} is in terminal phase '{phase}' and cannot accept exec.\"\n+            )\n+\n+        if pod.status and pod.status.container_statuses:\n+            for cs in pod.status.container_statuses:\n+                terminated = None\n+                if cs.state and cs.state.terminated:\n+                    terminated = cs.state.terminated\n+                elif cs.last_state and cs.last_state.terminated:\n+                    terminated = cs.last_state.terminated\n+                if terminated is not None:\n+                    reason = terminated.reason or \"\"\n+                    exit_code = terminated.exit_code\n+                    raise RuntimeError(\n+                        f\"Container '{cs.name}' in pod {self.pod_name} has terminated \"\n+                        f\"(reason={reason!r}, exit_code={exit_code}). Cannot exec into dead container.\"\n+                    )\n+\n     async def _wait_for_container_exec_ready(self, max_attempts: int = 60):\n         \"\"\"Wait for container to be ready for exec operations.\"\"\"\n         for attempt in range(max_attempts):\n+            await self._check_pod_terminated()\n             try:\n                 test_command = [\"true\"]\n                 resp = await asyncio.to_thread(\n", "test_patch": "", "problem_statement": "GKE: Verifier stuck in infinite retry loop when container is OOMKilled\n  ## Bug Description\n\n  When a container is OOMKilled (or otherwise terminated) during or after agent execution, the verifier phase gets stuck in an infinite retry\n  loop trying to exec into the dead container. This causes trials to hang indefinitely, blocking concurrent trial slots.\n\n  ## Root Cause\n\n  `_wait_for_container_exec_ready` in `src/harbor/environments/gke.py` (line 862) loops 60 attempts, but callers like `upload_dir` and\n  `upload_file` have `@retry(stop=stop_after_attempt(5))` decorators. When the container is dead (OOMKilled, exit code 137), each retry cycle\n  exhausts all 60 attempts, then the outer retry restarts. This creates a ~15 min retry window \u2014 but the loop effectively never terminates\n  because the verifier's `exec` calls also retry independently.\n\n  Critically, `_wait_for_container_exec_ready` never checks if the pod/container is in a terminated state \u2014 it only catches `ApiException` and\n  generic exceptions, so it keeps retrying even when the container can never come back (pod restart policy is `Never`).\n\n  ## Steps to Reproduce\n\n  1. Run a Terminal-Bench task that causes OOMKill (e.g., `caffe-cifar-10` with `memory_limit_multiplier: 3.0`)\n  2. Agent completes, but processes it launched exceed memory limit\n  3. Container is OOMKilled (exit code 137)\n  4. Verifier attempts to upload test files / exec into the dead container\n  5. Trial hangs indefinitely in \"Container not ready\" retry loop\n\n  ## Observed Behavior\n\n  From `trial.log`:\n  Session has ended, breaking out of agent loop\n  Failed to download logs to .../agent\n  Container not ready, attempt 1/60\n  Container not ready, attempt 11/60\n  ...\n  Container not ready, attempt 51/60\n  Container not ready, attempt 1/60    # resets \u2014 outer retry kicked in\n  Container not ready, attempt 11/60\n  ...\n\n  This repeats indefinitely, well past the task's configured timeout. Multiple stuck trials were observed consuming all `n_concurrent_trials`\n  slots, blocking the entire job.\n\n  ## Expected Behavior\n\n  - `_wait_for_container_exec_ready` should check pod/container status and fail fast if the container is in a terminated state (OOMKilled,\n  Error, etc.)\n  - The verifier phase should have a hard wall-clock timeout that prevents infinite retries\n  - The trial should record an error (reward 0) and clean up the pod promptly\n\n  ## Affected Code\n\n  - `src/harbor/environments/gke.py` lines 862-902: `_wait_for_container_exec_ready`\n  - `src/harbor/environments/gke.py` lines 904-907, 944-947: `@retry` decorators on `upload_file` / `upload_dir`\n  - `src/harbor/verifier/verifier.py` line 83: `upload_dir` call in verifier\n  - `src/harbor/verifier/verifier.py` lines 121-127: `exec` calls in verifier\n\n  ## Environment\n\n  - GKE with n2-standard-32 nodes\n  - Pod restart policy: Never\n  - memory_limit_multiplier: 3.0\n  - Terminal-Bench 2.0\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/harbor-framework/harbor/commit/dcce788ab003c72b7f37e816b65877cb46a3f461"], "created_at": "2026-03-30T14:07:25Z"}
{"repo": "harbor-framework/harbor", "pull_number": 1292, "instance_id": "harbor-framework__harbor-1292", "issue_numbers": [1288], "base_commit": "e8076f71254ffa2c707941eb044aa4a0dfe06ea7", "patch": "diff --git a/src/harbor/agents/terminus_2/terminus_2.py b/src/harbor/agents/terminus_2/terminus_2.py\nindex 489dcc612ed..61b77ab2658 100644\n--- a/src/harbor/agents/terminus_2/terminus_2.py\n+++ b/src/harbor/agents/terminus_2/terminus_2.py\n@@ -602,6 +602,10 @@ def _collect_subagent_rollout_detail(self, response: LLMResponse) -> None:\n             rollout_detail[\"completion_token_ids\"] = [response.completion_token_ids]\n         if response.logprobs is not None:\n             rollout_detail[\"logprobs\"] = [response.logprobs]\n+        if response.extra is not None:\n+            rollout_detail[\"extra\"] = {\n+                key: [value] for key, value in response.extra.items()\n+            }\n \n         if rollout_detail:\n             self._subagent_rollout_details.append(rollout_detail)\ndiff --git a/src/harbor/llms/base.py b/src/harbor/llms/base.py\nindex 881cdb25131..6aae21542a5 100644\n--- a/src/harbor/llms/base.py\n+++ b/src/harbor/llms/base.py\n@@ -1,6 +1,7 @@\n from abc import ABC, abstractmethod\n from dataclasses import dataclass\n from enum import Enum\n+from typing import Any\n \n from harbor.models.metric import UsageInfo\n \n@@ -33,6 +34,7 @@ class LLMResponse:\n     prompt_token_ids: list[int] | None = None\n     completion_token_ids: list[int] | None = None\n     logprobs: list[float] | None = None\n+    extra: dict[str, Any] | None = None\n \n \n class ContextLengthExceededError(Exception):\ndiff --git a/src/harbor/llms/chat.py b/src/harbor/llms/chat.py\nindex 52299258134..51eddf35295 100644\n--- a/src/harbor/llms/chat.py\n+++ b/src/harbor/llms/chat.py\n@@ -1,4 +1,5 @@\n from pathlib import Path\n+from typing import Any\n \n from harbor.llms.base import BaseLLM, LLMResponse\n from harbor.models.agent.rollout_detail import RolloutDetail\n@@ -15,6 +16,7 @@ def __init__(self, model: BaseLLM, interleaved_thinking: bool = False):\n         self._prompt_token_ids_list: list[list[int]] = []\n         self._completion_token_ids_list: list[list[int]] = []\n         self._logprobs_list: list[list[float]] = []\n+        self._extra_list: list[dict[str, Any]] = []\n         self._interleaved_thinking = interleaved_thinking\n         self._last_response_id: str | None = None\n \n@@ -53,6 +55,7 @@ def rollout_details(self) -> list[RolloutDetail]:\n             not self._prompt_token_ids_list\n             and not self._completion_token_ids_list\n             and not self._logprobs_list\n+            and not self._extra_list\n         ):\n             return []\n \n@@ -67,6 +70,14 @@ def rollout_details(self) -> list[RolloutDetail]:\n         if self._logprobs_list:\n             rollout_detail[\"logprobs\"] = self._logprobs_list\n \n+        if self._extra_list:\n+            # Pivot per-turn dicts to per-field lists for consistent indexing\n+            all_keys = {k for d in self._extra_list for k in d}\n+            rollout_detail[\"extra\"] = {\n+                key: [turn.get(key) for turn in self._extra_list]\n+                for key in sorted(all_keys)\n+            }\n+\n         return [rollout_detail]\n \n     async def chat(\n@@ -138,3 +149,7 @@ def _accumulate_rollout_details(self, llm_response: LLMResponse) -> None:\n             # Store logprobs for this turn (if available)\n             if llm_response.logprobs:\n                 self._logprobs_list.append(llm_response.logprobs)\n+\n+        # Accumulate extra provider-specific fields per turn\n+        if llm_response.extra:\n+            self._extra_list.append(llm_response.extra)\ndiff --git a/src/harbor/llms/lite_llm.py b/src/harbor/llms/lite_llm.py\nindex 42768bf1d7a..b62755785aa 100644\n--- a/src/harbor/llms/lite_llm.py\n+++ b/src/harbor/llms/lite_llm.py\n@@ -405,10 +405,12 @@ async def call(\n         prompt_token_ids = None\n         completion_token_ids = None\n         logprobs = None\n+        extra = None\n \n         if self._collect_rollout_details:\n             prompt_token_ids, completion_token_ids = self._extract_token_ids(response)\n             logprobs = self._extract_logprobs(response)\n+            extra = self._extract_provider_extra(response)\n \n         choice = response[\"choices\"][0]\n         message = choice[\"message\"]\n@@ -434,6 +436,7 @@ async def call(\n             prompt_token_ids=prompt_token_ids,\n             completion_token_ids=completion_token_ids,\n             logprobs=logprobs,\n+            extra=extra,\n         )\n \n     def _extract_token_ids(self, response) -> tuple[list[int] | None, list[int] | None]:\n@@ -496,6 +499,39 @@ def _extract_logprobs(self, response) -> list[float] | None:\n         except (KeyError, TypeError, IndexError):\n             return None\n \n+    def _extract_provider_extra(self, response) -> dict[str, Any] | None:\n+        \"\"\"Extract non-token_ids fields from provider_specific_fields.\n+\n+        Returns all fields from provider_specific_fields except 'token_ids'\n+        (which is handled separately by _extract_token_ids). This captures\n+        provider-specific data such as router expert indices for MoE models.\n+\n+        Returns:\n+            Dictionary of extra provider-specific data, or None if not available.\n+        \"\"\"\n+        try:\n+            choices = response.get(\"choices\", [])\n+            if not choices:\n+                return None\n+\n+            choice = choices[0]\n+            if (\n+                not hasattr(choice, \"provider_specific_fields\")\n+                or not choice.provider_specific_fields\n+            ):\n+                return None\n+\n+            extra = {\n+                k: v\n+                for k, v in choice.provider_specific_fields.items()\n+                if k != \"token_ids\"\n+            }\n+            return extra if extra else None\n+\n+        except Exception as e:\n+            self._logger.debug(f\"Error extracting provider extra fields: {e}\")\n+            return None\n+\n     def _extract_cost(self, response) -> float:\n         \"\"\"Extract cost from a response's _hidden_params or compute via litellm.\n \ndiff --git a/src/harbor/models/agent/rollout_detail.py b/src/harbor/models/agent/rollout_detail.py\nindex 9c1d71af81d..a1a7235764b 100644\n--- a/src/harbor/models/agent/rollout_detail.py\n+++ b/src/harbor/models/agent/rollout_detail.py\n@@ -1,4 +1,4 @@\n-from typing import TypedDict\n+from typing import Any, TypedDict\n \n \n class RolloutDetail(TypedDict, total=False):\n@@ -22,3 +22,6 @@ class RolloutDetail(TypedDict, total=False):\n     logprobs: list[\n         list[float]\n     ]  # Each element contains logprobs corresponding to completion_token_ids for that turn\n+    extra: dict[\n+        str, list[Any]\n+    ]  # Per-turn provider-specific data keyed by field name (e.g. {\"routed_experts\": [turn1_data, ...]})\n", "test_patch": "diff --git a/tests/unit/llms/test_chat.py b/tests/unit/llms/test_chat.py\nindex ab66267a7d4..b34b4fcd68a 100644\n--- a/tests/unit/llms/test_chat.py\n+++ b/tests/unit/llms/test_chat.py\n@@ -152,3 +152,92 @@ async def test_chat_no_response_id_when_none():\n \n     await chat.chat(\"hello\")\n     assert chat._last_response_id is None\n+\n+\n+def _usage() -> UsageInfo:\n+    return UsageInfo(\n+        prompt_tokens=10, completion_tokens=5, cache_tokens=0, cost_usd=0.0\n+    )\n+\n+\n+@pytest.mark.asyncio\n+async def test_chat_accumulates_extra_in_rollout_details():\n+    \"\"\"Verify extra provider-specific fields are accumulated and pivoted by field name.\"\"\"\n+    fake_llm = FakeLLM(\n+        responses=[\n+            LLMResponse(\n+                content=\"turn1\",\n+                usage=_usage(),\n+                completion_token_ids=[1, 2, 3],\n+                extra={\"routed_experts\": [[0, 1], [2, 3]], \"router_logits\": [0.5, 0.8]},\n+            ),\n+            LLMResponse(\n+                content=\"turn2\",\n+                usage=_usage(),\n+                completion_token_ids=[4, 5, 6],\n+                extra={\"routed_experts\": [[4, 5], [6, 7]], \"router_logits\": [0.1, 0.9]},\n+            ),\n+        ]\n+    )\n+    chat = Chat(model=fake_llm)\n+    await chat.chat(\"msg1\")\n+    await chat.chat(\"msg2\")\n+\n+    details = chat.rollout_details\n+    assert len(details) == 1\n+    assert \"extra\" in details[0]\n+    extra = details[0][\"extra\"]\n+    assert extra[\"routed_experts\"] == [[[0, 1], [2, 3]], [[4, 5], [6, 7]]]\n+    assert extra[\"router_logits\"] == [[0.5, 0.8], [0.1, 0.9]]\n+\n+\n+@pytest.mark.asyncio\n+async def test_chat_rollout_details_no_extra_when_absent():\n+    \"\"\"Verify 'extra' key is absent from RolloutDetail when no response has extra.\"\"\"\n+    fake_llm = FakeLLM(\n+        responses=[\n+            LLMResponse(\n+                content=\"turn1\",\n+                usage=_usage(),\n+                completion_token_ids=[1, 2, 3],\n+            ),\n+        ]\n+    )\n+    chat = Chat(model=fake_llm)\n+    await chat.chat(\"msg1\")\n+\n+    details = chat.rollout_details\n+    assert len(details) == 1\n+    assert \"extra\" not in details[0]\n+    assert \"completion_token_ids\" in details[0]\n+\n+\n+@pytest.mark.asyncio\n+async def test_chat_rollout_details_mixed_extra():\n+    \"\"\"Verify None fills for turns missing a given extra key.\"\"\"\n+    fake_llm = FakeLLM(\n+        responses=[\n+            LLMResponse(\n+                content=\"turn1\",\n+                usage=_usage(),\n+                completion_token_ids=[1, 2],\n+                extra={\"routed_experts\": [[0, 1]], \"field_a\": \"val1\"},\n+            ),\n+            LLMResponse(\n+                content=\"turn2\",\n+                usage=_usage(),\n+                completion_token_ids=[3, 4],\n+                extra={\"routed_experts\": [[2, 3]]},\n+            ),\n+        ]\n+    )\n+    chat = Chat(model=fake_llm)\n+    await chat.chat(\"msg1\")\n+    await chat.chat(\"msg2\")\n+\n+    details = chat.rollout_details\n+    extra = details[0][\"extra\"]\n+    # field_a only present in turn 1\n+    assert extra[\"field_a\"] == [\"val1\", None]\n+    # routed_experts present in both turns\n+    assert extra[\"routed_experts\"] == [[[0, 1]], [[2, 3]]]\ndiff --git a/tests/unit/llms/test_lite_llm.py b/tests/unit/llms/test_lite_llm.py\nindex 581ca0ccae8..4488eeb9703 100644\n--- a/tests/unit/llms/test_lite_llm.py\n+++ b/tests/unit/llms/test_lite_llm.py\n@@ -353,3 +353,65 @@ async def fake_aresponses(**kwargs):\n \n     assert acompletion_called\n     assert not aresponses_called\n+\n+\n+# ===== _extract_provider_extra Tests =====\n+\n+\n+def test_extract_provider_extra_with_extra_fields():\n+    \"\"\"Verify non-token_ids fields are extracted from provider_specific_fields.\"\"\"\n+    llm = LiteLLM(model_name=\"fake/model\", collect_rollout_details=True)\n+\n+    response = {\n+        \"choices\": [\n+            SimpleNamespace(\n+                provider_specific_fields={\n+                    \"token_ids\": [1, 2, 3],\n+                    \"routed_experts\": [[0, 1], [2, 3]],\n+                    \"router_logits\": [0.5, 0.8],\n+                },\n+            )\n+        ],\n+    }\n+\n+    result = llm._extract_provider_extra(response)\n+    assert result == {\n+        \"routed_experts\": [[0, 1], [2, 3]],\n+        \"router_logits\": [0.5, 0.8],\n+    }\n+    assert \"token_ids\" not in result\n+\n+\n+def test_extract_provider_extra_only_token_ids():\n+    \"\"\"Verify None is returned when provider_specific_fields only has token_ids.\"\"\"\n+    llm = LiteLLM(model_name=\"fake/model\", collect_rollout_details=True)\n+\n+    response = {\n+        \"choices\": [\n+            SimpleNamespace(\n+                provider_specific_fields={\"token_ids\": [1, 2, 3]},\n+            )\n+        ],\n+    }\n+\n+    assert llm._extract_provider_extra(response) is None\n+\n+\n+def test_extract_provider_extra_no_provider_fields():\n+    \"\"\"Verify None is returned when choice has no provider_specific_fields.\"\"\"\n+    llm = LiteLLM(model_name=\"fake/model\", collect_rollout_details=True)\n+\n+    response = {\n+        \"choices\": [\n+            SimpleNamespace()  # no provider_specific_fields attribute\n+        ],\n+    }\n+\n+    assert llm._extract_provider_extra(response) is None\n+\n+\n+def test_extract_provider_extra_empty_choices():\n+    \"\"\"Verify None is returned when response has no choices.\"\"\"\n+    llm = LiteLLM(model_name=\"fake/model\", collect_rollout_details=True)\n+\n+    assert llm._extract_provider_extra({\"choices\": []}) is None\n", "problem_statement": "Support router replay (R3) for MoE model RL training\n## Problem\n\nWhen training MoE models with RL, the inference engine (sglang) and training engine (Megatron) select different experts for the same tokens due to floating-point divergence, causing training collapse. The fix is to capture the router's expert selection indices during inference and replay them during training \u2014 known as Router Recomputation-free Routing (R3), described in [arXiv:2510.11370](https://arxiv.org/abs/2510.11370).\n\n## What's needed\n\n[Miles](https://github.com/search?q=miles+moe+rl&type=repositories) has a `rollout_routed_experts` field in its `Sample` dataclass (`list[list[int]]`, expert indices per token per MoE layer). Harbor needs to capture this data during inference and pass it back alongside token IDs and logprobs.\n\n## Current gap\n\n`RolloutDetail` captures `prompt_token_ids`, `completion_token_ids`, and `logprobs`, but nothing for router indices. The `provider_specific_fields` path in `lite_llm.py` seems like a natural extension point.\n\n## Upstream support\n\n- **sglang** is adding support for returning router indices: [sgl-project/sglang#12075](https://github.com/sgl-project/sglang/issues/12075)\n- **verl** added this via vLLM: [vllm-project/vllm#28284](https://github.com/vllm-project/vllm/pull/28284)\n\n## Data size\n\n~120KB per 4k-token response \u2014 minimal overhead.\n\n## Open question\n\nWould you prefer this as a first-class field on `RolloutDetail`, or handled via `Metrics.extra`? Happy to contribute a PR either way.\n", "hints_text": "@DavidBellamy Thanks for this! Let's do `RolloutDetail.extra`. If you contribute a PR, we can merge very quickly to unblock you.\n\n", "all_hints_text": "@DavidBellamy Thanks for this! Let's do `RolloutDetail.extra`. If you contribute a PR, we can merge very quickly to unblock you.\n\n", "commit_urls": ["https://github.com/harbor-framework/harbor/commit/aef1270bbfd14036b04788b641e25b9bace60508"], "created_at": "2026-03-27T03:56:36Z"}
{"repo": "harbor-framework/harbor", "pull_number": 1354, "instance_id": "harbor-framework__harbor-1354", "issue_numbers": [1315], "base_commit": "8fa7d43f6ae1c16f43e4ba6a0a29a511e70f4f7e", "patch": "diff --git a/scripts/sync_registry_to_supabase.py b/scripts/sync_registry_to_supabase.py\nindex 9a2e5f1de37..eb8460be2fe 100644\n--- a/scripts/sync_registry_to_supabase.py\n+++ b/scripts/sync_registry_to_supabase.py\n@@ -231,6 +231,28 @@ def db_upsert_batch(supabase, table: str, rows: list):\n         supabase.table(table).upsert(data).execute()\n \n \n+@db_retry\n+def db_insert_batch(supabase, table: str, rows: list):\n+    if rows:\n+        data = [\n+            r.model_dump(exclude_none=True) if isinstance(r, BaseModel) else r\n+            for r in rows\n+        ]\n+        supabase.table(table).insert(data).execute()\n+\n+\n+@db_retry\n+def db_update_dataset_descriptions(supabase, rows: list[dict]):\n+    for row in rows:\n+        (\n+            supabase.table(\"dataset\")\n+            .update({\"description\": row[\"description\"]})\n+            .eq(\"name\", row[\"name\"])\n+            .eq(\"version\", row[\"version\"])\n+            .execute()\n+        )\n+\n+\n @db_retry\n def db_delete(supabase, table: str, filters: dict):\n     query = supabase.table(table).delete()\n@@ -264,8 +286,7 @@ def get_supabase_client():\n \n \n def load_registry(registry_path: Path) -> list[RegistryDataset]:\n-    with open(registry_path) as f:\n-        data = json.load(f)\n+    data = json.loads(registry_path.read_text())\n     return [RegistryDataset.model_validate(d) for d in data]\n \n \n@@ -292,10 +313,12 @@ class FetchResult:\n     def __init__(\n         self,\n         datasets: dict[tuple[str, str], SupabaseDataset],\n+        duplicate_dataset_ids: list[int],\n         duplicate_task_ids: list[int],\n         duplicate_metric_ids: list[int],\n     ):\n         self.datasets = datasets\n+        self.duplicate_dataset_ids = duplicate_dataset_ids\n         self.duplicate_task_ids = duplicate_task_ids\n         self.duplicate_metric_ids = duplicate_metric_ids\n \n@@ -304,8 +327,15 @@ def fetch_supabase_datasets(supabase) -> FetchResult:\n     resp = supabase.table(\"dataset\").select(\"*\").execute()\n \n     datasets: dict[tuple[str, str], SupabaseDataset] = {}\n+    duplicate_dataset_ids: list[int] = []\n     for d in resp.data or []:\n         key = (d[\"name\"], d[\"version\"])\n+        if key in datasets:\n+            dataset_id = d.get(\"id\")\n+            if dataset_id is not None:\n+                duplicate_dataset_ids.append(dataset_id)\n+            continue\n+\n         datasets[key] = SupabaseDataset(\n             name=d[\"name\"],\n             version=d[\"version\"],\n@@ -335,7 +365,12 @@ def fetch_supabase_datasets(supabase) -> FetchResult:\n             else:\n                 datasets[key].metrics[metric_key] = m[\"id\"]\n \n-    return FetchResult(datasets, duplicate_task_ids, duplicate_metric_ids)\n+    return FetchResult(\n+        datasets,\n+        duplicate_dataset_ids,\n+        duplicate_task_ids,\n+        duplicate_metric_ids,\n+    )\n \n \n # =============================================================================\n@@ -351,7 +386,8 @@ def sync_datasets(\n ) -> SyncStats:\n     stats = SyncStats()\n \n-    datasets_to_upsert: list[dict] = []\n+    datasets_to_insert: list[dict] = []\n+    datasets_to_update: list[dict] = []\n     tasks_to_insert: list[SupabaseTask] = []\n     task_ids_to_delete: list[int] = []\n     metrics_to_insert: list[SupabaseMetric] = []\n@@ -372,13 +408,22 @@ def sync_datasets(\n         print(f\"  [{diff.status.value.upper()}] {dataset.name}@{dataset.version}\")\n \n         if diff.dataset_to_upsert:\n-            datasets_to_upsert.append(diff.dataset_to_upsert)\n+            if diff.status == DiffStatus.CREATED:\n+                datasets_to_insert.append(diff.dataset_to_upsert)\n+            else:\n+                datasets_to_update.append(diff.dataset_to_upsert)\n         tasks_to_insert.extend(diff.tasks_to_insert)\n         task_ids_to_delete.extend(diff.task_ids_to_delete)\n         metrics_to_insert.extend(diff.metrics_to_insert)\n         metric_ids_to_delete.extend(diff.metric_ids_to_delete)\n \n     if dry_run:\n+        if datasets_to_insert:\n+            print(f\"    Would insert {len(datasets_to_insert)} dataset row(s)\")\n+        if datasets_to_update:\n+            print(\n+                f\"    Would update {len(datasets_to_update)} dataset description row(s)\"\n+            )\n         if tasks_to_insert:\n             print(f\"    Would insert {len(tasks_to_insert)} task(s)\")\n         if task_ids_to_delete:\n@@ -389,7 +434,8 @@ def sync_datasets(\n             print(f\"    Would delete {len(metric_ids_to_delete)} metric(s)\")\n         return stats\n \n-    db_upsert_batch(supabase, \"dataset\", datasets_to_upsert)\n+    db_insert_batch(supabase, \"dataset\", datasets_to_insert)\n+    db_update_dataset_descriptions(supabase, datasets_to_update)\n     db_upsert_batch(supabase, \"dataset_task\", tasks_to_insert)\n     db_upsert_batch(supabase, \"dataset_metric\", metrics_to_insert)\n     db_delete_by_ids(supabase, \"dataset_task\", task_ids_to_delete)\n@@ -450,23 +496,32 @@ def main():\n     print(\"Fetching existing data from Supabase...\")\n     result = fetch_supabase_datasets(supabase)\n     print(f\"Found {len(result.datasets)} existing datasets\")\n+    if result.duplicate_dataset_ids:\n+        print(f\"Found {len(result.duplicate_dataset_ids)} duplicate dataset row(s)\")\n     if result.duplicate_task_ids:\n         print(f\"Found {len(result.duplicate_task_ids)} duplicate task row(s)\")\n     if result.duplicate_metric_ids:\n         print(f\"Found {len(result.duplicate_metric_ids)} duplicate metric row(s)\")\n     print()\n \n-    if result.duplicate_task_ids or result.duplicate_metric_ids:\n+    if (\n+        result.duplicate_dataset_ids\n+        or result.duplicate_task_ids\n+        or result.duplicate_metric_ids\n+    ):\n         if args.dry_run:\n             print(\n-                f\"  Would delete {len(result.duplicate_task_ids)} duplicate task(s)\"\n+                f\"  Would delete {len(result.duplicate_dataset_ids)} duplicate\"\n+                f\" dataset(s), {len(result.duplicate_task_ids)} duplicate task(s),\"\n                 f\" and {len(result.duplicate_metric_ids)} duplicate metric(s)\"\n             )\n         else:\n+            db_delete_by_ids(supabase, \"dataset\", result.duplicate_dataset_ids)\n             db_delete_by_ids(supabase, \"dataset_task\", result.duplicate_task_ids)\n             db_delete_by_ids(supabase, \"dataset_metric\", result.duplicate_metric_ids)\n             print(\n-                f\"  Deleted {len(result.duplicate_task_ids)} duplicate task(s)\"\n+                f\"  Deleted {len(result.duplicate_dataset_ids)} duplicate\"\n+                f\" dataset(s), {len(result.duplicate_task_ids)} duplicate task(s),\"\n                 f\" and {len(result.duplicate_metric_ids)} duplicate metric(s)\"\n             )\n \n@@ -485,9 +540,14 @@ def main():\n     print(f\"Updated: {stats.updated}\")\n     print(f\"Unchanged: {stats.unchanged}\")\n     print(f\"Deleted: {len(deleted)}\")\n-    if result.duplicate_task_ids or result.duplicate_metric_ids:\n+    if (\n+        result.duplicate_dataset_ids\n+        or result.duplicate_task_ids\n+        or result.duplicate_metric_ids\n+    ):\n         print(\n-            f\"Duplicates cleaned: {len(result.duplicate_task_ids)} task(s),\"\n+            f\"Duplicates cleaned: {len(result.duplicate_dataset_ids)} dataset(s),\"\n+            f\" {len(result.duplicate_task_ids)} task(s),\"\n             f\" {len(result.duplicate_metric_ids)} metric(s)\"\n         )\n \ndiff --git a/src/harbor/registry/client/harbor/harbor.py b/src/harbor/registry/client/harbor/harbor.py\nindex 706ef8c19bf..cb96b51d2cc 100644\n--- a/src/harbor/registry/client/harbor/harbor.py\n+++ b/src/harbor/registry/client/harbor/harbor.py\n@@ -17,6 +17,7 @@\n     HARBOR_SUPABASE_PUBLISHABLE_KEY,\n     HARBOR_SUPABASE_URL,\n )\n+from harbor.utils.logger import logger\n \n \n async def _get_supabase_client():\n@@ -26,6 +27,38 @@ async def _get_supabase_client():\n     )\n \n \n+def _task_key(task: RegistryTaskId) -> tuple[str, str | None, str | None, Path]:\n+    return (task.name, task.git_url, task.git_commit_id, task.path)\n+\n+\n+def _dedupe_tasks(\n+    tasks: list[RegistryTaskId], *, dataset_name: str, dataset_version: str\n+) -> list[RegistryTaskId]:\n+    unique_tasks: list[RegistryTaskId] = []\n+    seen: set[tuple[str, str | None, str | None, Path]] = set()\n+    duplicate_count = 0\n+\n+    for task in tasks:\n+        key = _task_key(task)\n+        if key in seen:\n+            duplicate_count += 1\n+            continue\n+\n+        seen.add(key)\n+        unique_tasks.append(task)\n+\n+    if duplicate_count:\n+        logger.warning(\n+            \"Harbor registry RPC returned %s duplicate task(s) for %s@%s; \"\n+            \"ignoring duplicate rows from the legacy registry backend\",\n+            duplicate_count,\n+            dataset_name,\n+            dataset_version,\n+        )\n+\n+    return unique_tasks\n+\n+\n def _parse_dataset_data(data: dict[str, Any]) -> DatasetSpec:\n     tasks = [\n         RegistryTaskId(\n@@ -44,6 +77,11 @@ def _parse_dataset_data(data: dict[str, Any]) -> DatasetSpec:\n         )\n         for item in data.get(\"dataset_metric\", [])\n     ]\n+    tasks = _dedupe_tasks(\n+        tasks,\n+        dataset_name=data[\"name\"],\n+        dataset_version=data[\"version\"],\n+    )\n \n     return DatasetSpec(\n         name=data[\"name\"],\n@@ -111,6 +149,11 @@ async def _get_dataset_spec(self, name: str, version: str) -> DatasetSpec:\n             )\n             for m in data.get(\"metrics\", [])\n         ]\n+        tasks = _dedupe_tasks(\n+            tasks,\n+            dataset_name=data[\"name\"],\n+            dataset_version=data[\"version\"],\n+        )\n \n         return DatasetSpec(\n             name=data[\"name\"],\n", "test_patch": "diff --git a/tests/unit/models/test_registry.py b/tests/unit/models/test_registry.py\nindex 7683253c361..a0daf8a346d 100644\n--- a/tests/unit/models/test_registry.py\n+++ b/tests/unit/models/test_registry.py\n@@ -81,6 +81,34 @@ def test_no_duplicate_dataset_keys(self):\n             )\n \n \n+class TestNoDuplicateTasks:\n+    \"\"\"Test that each dataset has unique task keys.\"\"\"\n+\n+    def test_no_duplicate_task_keys_within_dataset(self):\n+        \"\"\"Verify no dataset contains the same task key more than once.\"\"\"\n+        registry = Registry.from_path(REGISTRY_PATH)\n+\n+        duplicate_info: list[str] = []\n+        for dataset in registry.datasets:\n+            seen_keys: dict[tuple[str, str | None, str | None, Path], int] = {}\n+            for task in dataset.tasks:\n+                key = (task.name, task.git_url, task.git_commit_id, task.path)\n+                seen_keys[key] = seen_keys.get(key, 0) + 1\n+\n+            duplicates = [key for key, count in seen_keys.items() if count > 1]\n+            for task_name, git_url, git_commit_id, path in duplicates:\n+                duplicate_info.append(\n+                    f\"{dataset.name}@{dataset.version}: \"\n+                    f\"{task_name} ({git_url}, {git_commit_id}, {path})\"\n+                )\n+\n+        if duplicate_info:\n+            pytest.fail(\n+                \"Found duplicate task keys in registry.json:\\n\"\n+                + \"\\n\".join(f\"  - {item}\" for item in duplicate_info)\n+            )\n+\n+\n class TestTasksHaveGitInfo:\n     \"\"\"Test that all tasks have git_url and git_commit_id specified.\"\"\"\n \ndiff --git a/tests/unit/test_harbor_registry_client.py b/tests/unit/test_harbor_registry_client.py\nnew file mode 100644\nindex 00000000000..3c2f9c36ad0\n--- /dev/null\n+++ b/tests/unit/test_harbor_registry_client.py\n@@ -0,0 +1,103 @@\n+import logging\n+from pathlib import Path\n+from types import SimpleNamespace\n+\n+import pytest\n+\n+from harbor.models.registry import RegistryTaskId\n+from harbor.registry.client.harbor.harbor import HarborRegistryClient, _dedupe_tasks\n+\n+\n+class _FakeRpcQuery:\n+    def __init__(self, data: dict):\n+        self._data = data\n+\n+    async def execute(self):\n+        return SimpleNamespace(data=self._data)\n+\n+\n+class _FakeSupabase:\n+    def __init__(self, data: dict):\n+        self._data = data\n+        self.rpc_calls: list[tuple[str, dict[str, str]]] = []\n+\n+    def rpc(self, name: str, params: dict[str, str]) -> _FakeRpcQuery:\n+        self.rpc_calls.append((name, params))\n+        return _FakeRpcQuery(self._data)\n+\n+\n+@pytest.mark.asyncio\n+async def test_get_dataset_spec_dedupes_duplicate_rpc_tasks(monkeypatch, caplog):\n+    response_data = {\n+        \"name\": \"swebenchpro\",\n+        \"version\": \"1.0\",\n+        \"description\": \"SWE-Bench Pro dataset\",\n+        \"tasks\": [\n+            {\n+                \"name\": \"princeton-nlp/SWE-bench_Verified-test_0\",\n+                \"git_url\": \"https://github.com/laude-institute/terminal-bench-datasets.git\",\n+                \"git_commit_id\": \"abc123\",\n+                \"path\": \"tasks/swebenchpro/task-0\",\n+            },\n+            {\n+                \"name\": \"princeton-nlp/SWE-bench_Verified-test_0\",\n+                \"git_url\": \"https://github.com/laude-institute/terminal-bench-datasets.git\",\n+                \"git_commit_id\": \"abc123\",\n+                \"path\": \"tasks/swebenchpro/task-0\",\n+            },\n+        ],\n+        \"metrics\": [],\n+    }\n+    fake_supabase = _FakeSupabase(response_data)\n+\n+    async def _fake_get_supabase_client():\n+        return fake_supabase\n+\n+    monkeypatch.setattr(\n+        \"harbor.registry.client.harbor.harbor._get_supabase_client\",\n+        _fake_get_supabase_client,\n+    )\n+\n+    with caplog.at_level(logging.WARNING):\n+        spec = await HarborRegistryClient()._get_dataset_spec(\"swebenchpro\", \"1.0\")\n+\n+    assert fake_supabase.rpc_calls == [\n+        (\"get_dataset\", {\"p_name\": \"swebenchpro\", \"p_version\": \"1.0\"})\n+    ]\n+    assert len(spec.tasks) == 1\n+    assert spec.tasks[0].name == \"princeton-nlp/SWE-bench_Verified-test_0\"\n+    assert \"duplicate task(s)\" in caplog.text\n+    assert \"swebenchpro@1.0\" in caplog.text\n+\n+\n+def test_dedupe_tasks_preserves_first_seen_order():\n+    tasks = [\n+        RegistryTaskId(\n+            name=\"task-a\",\n+            git_url=\"https://example.com/repo.git\",\n+            git_commit_id=\"1\",\n+            path=Path(\"a\"),\n+        ),\n+        RegistryTaskId(\n+            name=\"task-b\",\n+            git_url=\"https://example.com/repo.git\",\n+            git_commit_id=\"2\",\n+            path=Path(\"b\"),\n+        ),\n+        RegistryTaskId(\n+            name=\"task-a\",\n+            git_url=\"https://example.com/repo.git\",\n+            git_commit_id=\"1\",\n+            path=Path(\"a\"),\n+        ),\n+        RegistryTaskId(\n+            name=\"task-c\",\n+            git_url=\"https://example.com/repo.git\",\n+            git_commit_id=\"3\",\n+            path=Path(\"c\"),\n+        ),\n+    ]\n+\n+    deduped = _dedupe_tasks(tasks, dataset_name=\"demo\", dataset_version=\"1.0\")\n+\n+    assert [task.name for task in deduped] == [\"task-a\", \"task-b\", \"task-c\"]\ndiff --git a/tests/unit/test_sync_registry_to_supabase.py b/tests/unit/test_sync_registry_to_supabase.py\nnew file mode 100644\nindex 00000000000..523bf4d7414\n--- /dev/null\n+++ b/tests/unit/test_sync_registry_to_supabase.py\n@@ -0,0 +1,184 @@\n+import importlib.util\n+from pathlib import Path\n+from types import SimpleNamespace\n+\n+\n+def _load_sync_module():\n+    module_path = (\n+        Path(__file__).resolve().parents[2] / \"scripts\" / \"sync_registry_to_supabase.py\"\n+    )\n+    spec = importlib.util.spec_from_file_location(\n+        \"sync_registry_to_supabase\", module_path\n+    )\n+    assert spec is not None and spec.loader is not None\n+\n+    module = importlib.util.module_from_spec(spec)\n+    spec.loader.exec_module(module)\n+    return module\n+\n+\n+class _FakeTableQuery:\n+    def __init__(self, rows: list[dict]):\n+        self._rows = rows\n+        self._range: tuple[int, int] | None = None\n+\n+    def select(self, *_args):\n+        return self\n+\n+    def range(self, start: int, end: int):\n+        self._range = (start, end)\n+        return self\n+\n+    def execute(self):\n+        if self._range is None:\n+            data = self._rows\n+        else:\n+            start, end = self._range\n+            data = self._rows[start : end + 1]\n+        self._range = None\n+        return SimpleNamespace(data=data)\n+\n+\n+class _FakeSupabase:\n+    def __init__(self, rows_by_table: dict[str, list[dict]]):\n+        self._rows_by_table = rows_by_table\n+\n+    def table(self, name: str) -> _FakeTableQuery:\n+        return _FakeTableQuery(self._rows_by_table[name])\n+\n+\n+def test_fetch_supabase_datasets_collects_duplicate_dataset_rows():\n+    sync_module = _load_sync_module()\n+    supabase = _FakeSupabase(\n+        {\n+            \"dataset\": [\n+                {\n+                    \"id\": 1,\n+                    \"name\": \"swebenchpro\",\n+                    \"version\": \"1.0\",\n+                    \"description\": \"first copy\",\n+                },\n+                {\n+                    \"id\": 2,\n+                    \"name\": \"swebenchpro\",\n+                    \"version\": \"1.0\",\n+                    \"description\": \"duplicate copy\",\n+                },\n+            ],\n+            \"dataset_task\": [\n+                {\n+                    \"id\": 10,\n+                    \"dataset_name\": \"swebenchpro\",\n+                    \"dataset_version\": \"1.0\",\n+                    \"name\": \"task-0\",\n+                    \"git_url\": \"https://github.com/laude-institute/terminal-bench-datasets.git\",\n+                    \"git_commit_id\": \"abc123\",\n+                    \"path\": \"tasks/swebenchpro/task-0\",\n+                },\n+                {\n+                    \"id\": 11,\n+                    \"dataset_name\": \"swebenchpro\",\n+                    \"dataset_version\": \"1.0\",\n+                    \"name\": \"task-0\",\n+                    \"git_url\": \"https://github.com/laude-institute/terminal-bench-datasets.git\",\n+                    \"git_commit_id\": \"abc123\",\n+                    \"path\": \"tasks/swebenchpro/task-0\",\n+                },\n+            ],\n+            \"dataset_metric\": [\n+                {\n+                    \"id\": 20,\n+                    \"dataset_name\": \"swebenchpro\",\n+                    \"dataset_version\": \"1.0\",\n+                    \"metric_name\": \"pass_at_1\",\n+                    \"kwargs\": {},\n+                },\n+                {\n+                    \"id\": 21,\n+                    \"dataset_name\": \"swebenchpro\",\n+                    \"dataset_version\": \"1.0\",\n+                    \"metric_name\": \"pass_at_1\",\n+                    \"kwargs\": {},\n+                },\n+            ],\n+        }\n+    )\n+\n+    result = sync_module.fetch_supabase_datasets(supabase)\n+\n+    assert set(result.datasets.keys()) == {(\"swebenchpro\", \"1.0\")}\n+    assert result.duplicate_dataset_ids == [2]\n+    assert result.duplicate_task_ids == [11]\n+    assert result.duplicate_metric_ids == [21]\n+\n+\n+def test_sync_datasets_splits_dataset_inserts_from_description_updates(monkeypatch):\n+    sync_module = _load_sync_module()\n+\n+    inserted_batches: list[tuple[str, list[dict]]] = []\n+    updated_rows: list[dict] = []\n+    upsert_batches: list[tuple[str, list[object]]] = []\n+    delete_batches: list[tuple[str, list[int]]] = []\n+\n+    monkeypatch.setattr(\n+        sync_module,\n+        \"db_insert_batch\",\n+        lambda _supabase, table, rows: inserted_batches.append((table, rows)),\n+    )\n+    monkeypatch.setattr(\n+        sync_module,\n+        \"db_update_dataset_descriptions\",\n+        lambda _supabase, rows: updated_rows.extend(rows),\n+    )\n+    monkeypatch.setattr(\n+        sync_module,\n+        \"db_upsert_batch\",\n+        lambda _supabase, table, rows: upsert_batches.append((table, rows)),\n+    )\n+    monkeypatch.setattr(\n+        sync_module,\n+        \"db_delete_by_ids\",\n+        lambda _supabase, table, ids: delete_batches.append((table, ids)),\n+    )\n+\n+    registry_datasets = [\n+        sync_module.RegistryDataset(name=\"new-dataset\", version=\"1.0\"),\n+        sync_module.RegistryDataset(\n+            name=\"existing-dataset\",\n+            version=\"1.0\",\n+            description=\"new description\",\n+        ),\n+    ]\n+    existing = {\n+        (\"existing-dataset\", \"1.0\"): sync_module.SupabaseDataset(\n+            name=\"existing-dataset\",\n+            version=\"1.0\",\n+            description=\"old description\",\n+        )\n+    }\n+\n+    stats = sync_module.sync_datasets(\n+        supabase=object(),\n+        registry_datasets=registry_datasets,\n+        existing=existing,\n+        dry_run=False,\n+    )\n+\n+    assert stats.created == 1\n+    assert stats.updated == 1\n+    assert stats.unchanged == 0\n+    assert inserted_batches == [\n+        (\n+            \"dataset\",\n+            [{\"name\": \"new-dataset\", \"version\": \"1.0\", \"description\": \"\"}],\n+        )\n+    ]\n+    assert updated_rows == [\n+        {\n+            \"name\": \"existing-dataset\",\n+            \"version\": \"1.0\",\n+            \"description\": \"new description\",\n+        }\n+    ]\n+    assert upsert_batches == [(\"dataset_task\", []), (\"dataset_metric\", [])]\n+    assert delete_batches == [(\"dataset_task\", []), (\"dataset_metric\", [])]\n", "problem_statement": "swebenchpro has 1462 tasks instead of 731\nWhen starting swebenchpro it suspiciously kicks of twice as many tasks as there are in the dataset.\n\nMy agent tells me it is likely the remote response coming back with too many results, as if there are too many in the database.\n\nNot sure how accurate that is, but it is suspicious that the number is exactly 2x the number of tasks.\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/harbor-framework/harbor/commit/9f82ca987b888d3d86b2584702aed7936601800f", "https://github.com/harbor-framework/harbor/commit/c41d8a42e573512bdbd50220e2461dadeb51550c"], "created_at": "2026-04-02T22:55:17Z"}
