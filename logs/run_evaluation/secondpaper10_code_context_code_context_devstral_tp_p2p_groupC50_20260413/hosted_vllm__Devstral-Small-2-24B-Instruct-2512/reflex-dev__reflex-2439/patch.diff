+                    # Get vars from the component itself
+                    vars.extend(element._get_vars())
+                    # Also get vars from event triggers in the component
+                    for _, event_vars in element._get_vars_from_event_triggers(element.event_triggers):
+                        vars.extend(event_vars)
+
