+    @staticmethod
+    def var(cache: bool = False) -> Callable[[Callable[[Any], Any]], Any]:
+        """
+        Decorator for defining reactive variables on a ``State`` subclass.
+
+        When ``cache`` is ``True`` the result of the function is cached until
+        any of its dependencies change. Dependencies are other ``@var`` values
+        accessed during the function execution. The dependency graph is
+        automatically built and used to invalidate dependent caches.
+        """
+
+        def decorator(func: Callable[[Any], Any]) -> Any:
+            name = func.__name__
+
+            @property
+            def wrapper(self: "State"):
+                # Record dependency if this var is accessed while another var is computing
+                self._record_dependency(name)
+
+                # Return cached value if available
+                if cache and name in self._var_cache:
+                    return self._var_cache[name]
+
+                # Set up context to track dependencies during computation
+                prev = getattr(self._var_compute_context, "current", None)
+                self._var_compute_context.current = name
+                try:
+                    value = func(self)
+                finally:
+                    # Restore previous context
+                    self._var_compute_context.current = prev
+
+                # Cache the computed value
+                if cache:
+                    self._var_cache[name] = value
+                    # Invalidate any vars that depend on this one, because its value may have changed
+                    self._invalidate_dependents(name)
+                return value
+
+            return wrapper
+
+        return decorator