+class StopGradient(Operation):
+    """Keras operation that stops gradient flow for a tensor."""
+
+    def __init__(self):
+        super().__init__()
+
+    def call(self, x):
+        # In eager mode we delegate to the backend implementation.
+        return backend.core.stop_gradient(x)
+
+    def compute_output_spec(self, x):
+        """
+        The output of `stop_gradient` has the same shape, dtype and sparsity
+        as the input. For symbolic tensors we simply return the input spec.
+        """
+        # `x` is expected to be a KerasTensor when this method is called.
+        # Returning `x` directly preserves the symbolic information.
+        return x
+
