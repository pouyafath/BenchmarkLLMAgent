\n+      \"\\n\",\n       \"*get_metric_dict(confidence_interval=0.95)*\\n\",\n       \"\\n\",\n       \"Return metric dictionary\\n\",\n@@ -2068,6 +2015,46 @@\n       \"\\n\",\n       \"<hr>\\n\",\n       \"\\n\",\n+      \"*set_fit_request(self: mlxtend.feature_selection.exhaustive_feature_selector.ExhaustiveFeatureSelector, *, groups: Union[bool, NoneType, str] = '$UNCHANGED$') -> mlxtend.feature_selection.exhaustive_feature_selector.ExhaustiveFeatureSelector*\\n\",\n+      \"\\n\",\n+      \"Configure whether metadata should be requested to be passed to the ``fit`` method.\\n\",\n+      \"\\n\",\n+      \"    Note that this method is only relevant when this estimator is used as a\\n\",\n+      \"    sub-estimator within a :term:`meta-estimator` and metadata routing is enabled\\n\",\n+      \"    with ``enable_metadata_routing=True`` (see :func:`sklearn.set_config`).\\n\",\n+      \"    Please check the :ref:`User Guide <metadata_routing>` on how the routing\\n\",\n+      \"    mechanism works.\\n\",\n+      \"\\n\",\n+      \"    The options for each parameter are:\\n\",\n+      \"\\n\",\n+      \"    - ``True``: metadata is requested, and passed to ``fit`` if provided. The request is ignored if metadata is not provided.\\n\",\n+      \"\\n\",\n+      \"    - ``False``: metadata is not requested and the meta-estimator will not pass it to ``fit``.\\n\",\n+      \"\\n\",\n+      \"    - ``None``: metadata is not requested, and the meta-estimator will raise an error if the user provides it.\\n\",\n+      \"\\n\",\n+      \"    - ``str``: metadata should be passed to the meta-estimator with this given alias instead of the original name.\\n\",\n+      \"\\n\",\n+      \"    The default (``sklearn.utils.metadata_routing.UNCHANGED``) retains the\\n\",\n+      \"    existing request. This allows you to change the request for some\\n\",\n+      \"    parameters and not others.\\n\",\n+      \"\\n\",\n+      \"    .. versionadded:: 1.3\\n\",\n+      \"\\n\",\n+      \"**Parameters**\\n\",\n+      \"\\n\",\n+      \"- `groups` : str, True, False, or None,                     default=sklearn.utils.metadata_routing.UNCHANGED\\n\",\n+      \"\\n\",\n+      \"    Metadata routing for ``groups`` parameter in ``fit``.\\n\",\n+      \"\\n\",\n+      \"**Returns**\\n\",\n+      \"\\n\",\n+      \"- `self` : object\\n\",\n+      \"\\n\",\n+      \"    The updated object.\\n\",\n+      \"\\n\",\n+      \"<hr>\\n\",\n+      \"\\n\",\n       \"*set_params(**params)*\\n\",\n       \"\\n\",\n       \"Set the parameters of this estimator.\\n\",\n@@ -2134,7 +2121,7 @@\n    \"name\": \"python\",\n    \"nbconvert_exporter\": \"python\",\n    \"pygments_lexer\": \"ipython3\",\n-   \"version\": \"3.9.16\"\n+   \"version\": \"3.11.11\"\n   },\n   \"toc\": {\n    \"nav_menu\": {},\ndiff --git a/docs/sources/user_guide/plotting/plot_decision_regions.ipynb b/docs/sources/user_guide/plotting/plot_decision_regions.ipynb\nindex 6f884f298..5df2ad203 100644\n--- a/docs/sources/user_guide/plotting/plot_decision_regions.ipynb\n+++ b/docs/sources/user_guide/plotting/plot_decision_regions.ipynb\n@@ -55,7 +55,7 @@\n    \"outputs\": [\n     {\n      \"data\": {\n-      \"image/png\": \"\",\n+      \"image/png\": \"\",\n       \"text/plain\": [\n        \"<Figure size 640x480 with 1 Axes>\"\n       ]\n@@ -104,7 +104,7 @@\n    \"outputs\": [\n     {\n      \"data\": {\n-      \"image/png\": \"\",\n+      \"image/png\": \"\",\n       \"text/plain\": [\n        \"<Figure size 640x480 with 1 Axes>\"\n       ]\n@@ -160,9 +160,7 @@\n     \"import numpy as np\\n\",\n     \"\\n\",\n     \"# Initializing Classifiers\\n\",\n-    \"clf1 = LogisticRegression(random_state=1,\\n\",\n-    \"                          solver='newton-cg',\\n\",\n-    \"                          multi_class='multinomial')\\n\",\n+    \"clf1 = LogisticRegression(random_state=1, solver='newton-cg')\\n\",\n     \"clf2 = RandomForestClassifier(random_state=1, n_estimators=100)\\n\",\n     \"clf3 = GaussianNB