+#!/usr/bin/env python3
+
+"""
+Example script demonstrating how to use the SDPO (Self-Distillation Preference Optimization) trainer.
+
+SDPO is a reinforcement learning approach where one model serves as both the teacher and student,
+eliminating the need for a separate reference model.
+"""
+
+from datasets import load_dataset
+from trl.experimental.sdpo import SDPOConfig, SDPOTrainer
+
+def main():
+    # Load a preference dataset
+    # For this example, we'll use a small subset of a preference dataset
+    dataset = load_dataset("trl-lib/ultrafeedback_binarized", split="train[:10%]")
+
+    # Initialize the SDPO trainer
+    trainer = SDPOTrainer(
+        model="Qwen/Qwen2.5-0.5B-Instruct",  # or your own model
+        train_dataset=dataset,
+        args=SDPOConfig(
+            output_dir="./sdpo_results",
+            beta=0.1,  # Controls the "temperature" of the policy update
+            learning_rate=5e-6,
+            per_device_train_batch_size=4,
+            num_train_epochs=1,
+        ),
+    )
+
+    # Train the model
+    trainer.train()
+
+    # Save the trained model
+    trainer.save_model("./sdpo_results")
+
+    print("Training completed successfully!")
+
+if __name__ == "__main__":
+    main()
