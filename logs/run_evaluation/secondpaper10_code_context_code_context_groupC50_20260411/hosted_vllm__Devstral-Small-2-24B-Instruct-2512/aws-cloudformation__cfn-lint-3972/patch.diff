+"""
+Copyright Amazon.com, Inc. or its affiliates. All Rights Reserved.
+SPDX-License-Identifier: MIT-0
+"""
+
+from test.unit.rules import BaseRuleTestCase
+
+# ruff: noqa: E501
+from cfnlint.rules.resources.UniqueResourceNames import UniqueResourceNames
+
+class TestUniqueResourceNames(BaseRuleTestCase):
+    """Test base template"""
+
+    def setUp(self):
+        """Setup"""
+        super(TestUniqueResourceNames, self).setUp()
+        self.collection.register(UniqueResourceNames())
+        self.success_templates = [
+            "test/fixtures/templates/good/resources/unique_resource_names.yaml",
+        ]
+
+    def test_file_positive(self):
+        """Test Positive"""
+        self.helper_file_positive()
+
+    def test_file_negative_codebuild(self):
+        """Test failure for CodeBuild projects with duplicate names"""
+        self.helper_file_negative(
+            "test/fixtures/templates/bad/resources/unique_resource_names.yaml", 2
+        )
