+    def _match_trigger(
+        self,
+        trigger: Union[None, str, type, Agent, Callable, List],
+        agent: Agent,
+        message_content: Optional[str] = None
+    ) -> bool:
+        """Check if the agent matches the trigger.
+
+        Args:
+            trigger: The trigger to match against.
+            agent: The agent to check.
+            message_content: Optional message content for context.
+
+        Returns:
+            bool: True if the agent matches the trigger.
+        """
+        if trigger is None:
+            return False
+        elif isinstance(trigger, str):
+            return trigger == agent.name
+        elif isinstance(trigger, type):
+            return isinstance(agent, trigger)
+        elif isinstance(trigger, Agent):
+            return trigger == agent
+        elif isinstance(trigger, Callable):
+            rst = trigger(agent)
+            assert rst in [True, False], f"trigger {trigger} must return a boolean value."
+            return rst
