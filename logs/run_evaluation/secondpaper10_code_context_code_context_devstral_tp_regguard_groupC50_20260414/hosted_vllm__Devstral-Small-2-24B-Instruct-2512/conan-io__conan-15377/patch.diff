diff --git a/conan/tools/scm/git.py b/conan/tools/scm/git.py
index 77d0e6dbb..77c7fa49e 100644
--- a/conan/tools/scm/git.py
+++ b/conan/tools/scm/git.py
@@ -237,3 +237,54 @@ class Git:
         files = self.run("ls-files --full-name --others --cached --exclude-standard")
         files = files.splitlines()
         return files
+    def coordinates_to_conandata(self, remote="origin", repository=False):
+        """
+        Stores the current git URL and commit in conandata.yml. This method is intended to be
+        used in the ``export()`` method of a recipe to capture the SCM coordinates.
+
+        :param remote: Name of the remote git repository ('origin' by default).
+        :param repository: By default gets the commit of the defined folder, use repo=True to get
+                     the commit of the repository instead.
+        """
+        from conan.tools.files import update_conandata
+
+        url, commit = self.get_url_and_commit(remote=remote, repository=repository)
+        # Store under version-specific key to work with trim_conandata
+        version = str(self._conanfile.version)
+        update_conandata(self._conanfile, {"scm": {version: {"commit": commit, "url": url}}})
+
+    def checkout_from_conandata_coordinates(self, target="."):
+        """
+        Checks out the git repository from the coordinates stored in conandata.yml. This method
+        is intended to be used in the ``source()`` method of a recipe.
+
+        :param target: Target directory to clone the repository into.
+
+        :return: The path to the cloned repository.
+        """
+        from conan.tools.files import load
+        import yaml
+
+        # Load conandata.yml
+        conandata_path = os.path.join(self._conanfile.export_folder or self._conanfile.recipe_folder, "conandata.yml")
+        if not os.path.exists(conandata_path):
+            raise ConanException("conandata.yml file doesn't exist")
+
+        conandata = load(self._conanfile, conandata_path)
+        conandata = yaml.safe_load(conandata)
+
+        # Get SCM coordinates
+        version = str(self._conanfile.version)
+        scm_data = conandata.get("scm", {})
+        version_scm_data = scm_data.get(version, {})
+        url = version_scm_data.get("url")
+        commit = version_scm_data.get("commit")
+
+        if not url or not commit:
+            raise ConanException("SCM coordinates (url and commit) not found in conandata.yml")
+
+        # Clone and checkout
+        self.clone(url, target=target)
+        with chdir(self._conanfile, target):
+            self.checkout(commit)
+        return target
