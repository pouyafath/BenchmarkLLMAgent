+        class CustomDumper(yaml.SafeDumper):
+            pass
+
+        # Create custom loader class
+        class CustomLoader(yaml.SafeLoader):
+            pass
+
+        # Add fallback representer for other non-serializable types first
+        CustomDumper.add_representer(object, _represent_generic)
+
+        # Add custom representers to dumper
+        try:
+            import torch
+            if hasattr(torch, 'dtype') and hasattr(torch, 'float16'):
+                CustomDumper.add_representer(torch.dtype, _represent_torch_dtype)
+            if hasattr(torch, 'Tensor'):
+                CustomDumper.add_representer(torch.Tensor, _represent_torch_tensor)
+        except ImportError:
+            pass
+
+        # Add custom constructors to loader
