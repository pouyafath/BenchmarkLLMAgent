/agents/installed/gemini_cli.py\n+++ b/src/harbor/agents/installed/gemini_cli.py\n@@ -458,6 +458,7 @@ def create_run_agent_commands(self, instruction: str) -> list[ExecInput]:\n         commands.append(\n             ExecInput(\n                 command=(\n+                    \". ~/.nvm/nvm.sh; \"\n                     f\"gemini --yolo --model={model} --prompt={escaped_instruction} \"\n                     f\"2>&1 </dev/null | tee /logs/agent/gemini-cli.txt\"\n                 ),\ndiff --git a/src/harbor/agents/installed/install-aider.sh.j2 b/src/harbor/agents/installed/install-aider.sh.j2\nindex 0c98c4627c0..88666906554 100644\n--- a/src/harbor/agents/installed/install-aider.sh.j2\n+++ b/src/harbor/agents/installed/install-aider.sh.j2\n@@ -5,4 +5,5 @@ apt-get update\n apt-get install -y curl\n \n curl -LsSf https://aider.chat/install.sh | sh\n-source $HOME/.local/bin/env\n\\ No newline at end of file\n+source $HOME/.local/bin/env\n+aider --version\ndiff --git a/src/harbor/agents/installed/install-claude-code.sh.j2 b/src/harbor/agents/installed/install-claude-code.sh.j2\nindex 9c89a18cf4e..59b21c39057 100644\n--- a/src/harbor/agents/installed/install-claude-code.sh.j2\n+++ b/src/harbor/agents/installed/install-claude-code.sh.j2\n@@ -16,4 +16,5 @@ curl -fsSL https://claude.ai/install.sh | bash -s -- {{ version }}\n curl -fsSL https://claude.ai/install.sh | bash\n {% endif %}\n \n-echo 'export PATH=\"$HOME/.local/bin:$PATH\"' >> ~/.bashrc\n+export PATH=\"$HOME/.local/bin:$PATH\"\n+claude --version\ndiff --git a/src/harbor/agents/installed/install-codex.sh.j2 b/src/harbor/agents/installed/install-codex.sh.j2\nindex 097c8212f09..23ca383aba1 100644\n--- a/src/harbor/agents/installed/install-codex.sh.j2\n+++ b/src/harbor/agents/installed/install-codex.sh.j2\n@@ -19,4 +19,6 @@ npm -v\n npm install -g @openai/codex@{{ version }}\n {% else %}\n npm install -g @openai/codex@latest\n-{% endif %}\n\\ No newline at end of file\n+{% endif %}\n+\n+codex --version\ndiff --git a/sr