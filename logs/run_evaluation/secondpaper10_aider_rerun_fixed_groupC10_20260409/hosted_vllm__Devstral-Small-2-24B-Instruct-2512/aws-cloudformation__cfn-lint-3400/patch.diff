+def _has_cfn_function_in_principal(instance: Any) -> bool:
+    """Check if the instance contains CloudFormation functions in Principal field"""
+    if isinstance(instance, dict):
+        if "Statement" in instance:
+            statements = instance["Statement"]
+            if isinstance(statements, list):
+                for statement in statements:
+                    if isinstance(statement, dict):
+                        if _check_statement_principal(statement):
+                            return True
+        elif "Principal" in instance:
+            return _check_statement_principal(instance)
+    return False
+
+def _check_statement_principal(statement: Any) -> bool:
+    """Check a single statement for CFN functions in Principal"""
+    if isinstance(statement, dict) and "Principal" in statement:
+        principal = statement["Principal"]
+        if isinstance(principal, dict):
+            for key in principal:
+                value = principal[key]
+                if isinstance(value, dict):
+                    if any(fn in value for fn in ["Ref", "Fn::GetAtt", "Fn::Join", "Fn::Sub"]):
+                        return True
+                elif isinstance(value, list):
+                    for item in value:
+                        if isinstance(item, dict):
+                            if any(fn in item for fn in ["Ref", "Fn::GetAtt", "Fn::Join", "Fn::Sub"]):
+                                return True
+    return False
 
