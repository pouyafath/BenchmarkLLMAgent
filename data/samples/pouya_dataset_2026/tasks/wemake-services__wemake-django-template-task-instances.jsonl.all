ngo-permissions-policy\" },\n+    { name = \"django-split-settings\" },\n+    { name = \"django-stubs-ext\" },\n+    { name = \"gunicorn\" },\n+    { name = \"psycopg2-binary\" },\n+    { name = \"punq\" },\n+    { name = \"python-decouple\" },\n+    { name = \"structlog\" },\n+    { name = \"wheel\" },\n+]\n+\n+[package.dev-dependencies]\n+dev = [\n+    { name = \"covdefaults\" },\n+    { name = \"dennis\" },\n+    { name = \"django-coverage-plugin\" },\n+    { name = \"django-debug-toolbar\" },\n+    { name = \"django-drifter\" },\n+    { name = \"django-extra-checks\" },\n+    { name = \"django-migration-linter\" },\n+    { name = \"django-query-counter\" },\n+    { name = \"django-safe-migrations\" },\n+    { name = \"django-stubs\", extra = [\"compatible-mypy\"] },\n+    { name = \"django-test-migrations\" },\n+    { name = \"django-zeal\" },\n+    { name = \"djangofmt\" },\n+    { name = \"dotenv-linter\" },\n+    { name = \"dump-env\" },\n+    { name = \"hypothesis\" },\n+    { name = \"import-linter\" },\n+    { name = \"ipython\" },\n+    { name = \"polint\" },\n+    { name = \"pytest\" },\n+    { name = \"pytest-cov\" },\n+    { name = \"pytest-django\" },\n+    { name = \"pytest-randomly\" },\n+    { name = \"pytest-timeout\" },\n+    { name = \"ruff\" },\n+    { name = \"safety\" },\n+    { name = \"schemathesis\" },\n+    { name = \"wemake-python-styleguide\" },\n+    { name = \"yamllint\" },\n+]\n+docs = [\n+    { name = \"furo\" },\n+    { name = \"myst-parser\" },\n+    { name = \"sphinx\" },\n+    { name = \"sphinx-autodoc-typehints\" },\n+]\n+\n+[package.metadata]\n+requires-dist = [\n+    { name = \"django\", extras = [\"argon2\"], specifier = \">=6.0,<6.1\" },\n+    { name = \"django-axes\", specifier = \">=8.0,<9.0\" },\n+    { name = \"django-health-check\", specifier = \">=4.0,<5.0\" },\n+    { name = \"django-modern-rest\", extras = [\"msgspec\", \"pydantic\", \"attrs\", \"jwt\", \"openapi\"], specifier = \">=0.4,<1.0\" },\n+    { name = \"django-permissions-policy\", specifier = \">=4.27,<5.0\" },\n+    { name = \"django-split-settings\", specifier = \">=1.3,<2.0\" },\n+    { name = \"django-stubs-ext\", specifier = \">=6.0,<7.0\" },\n+    { name = \"gunicorn\", specifier = \">=25.0,<26.0\" },\n+    { name = \"psycopg2-binary\", specifier = \">=2.9,<3.0\" },\n+    { name = \"punq\", specifier = \">=0.7,<1.0\" },\n+    { name = \"python-decouple\", specifier = \">=3.8,<4.0\" },\n+    { name = \"structlog\", specifier = \">=25.4,<26.0\" },\n+    { name = \"wheel\", specifier = \">=0.46,<1.0\" },\n+]\n+\n+[package.metadata.requires-dev]\n+dev = [\n+    { name = \"covdefaults\", specifier = \">=2.3,<3.0\" },\n+    { name = \"dennis\", specifier = \">=1.1,<2.0\" },\n+    { name = \"django-coverage-plugin\", specifier = \">=3.1,<4.0\" },\n+    { name = \"django-debug-toolbar\", specifier = \">=6.0,<7.0\" },\n+    { name = \"django-drifter\", specifier = \">=0.1,<1.0\" },\n+    { name = \"django-extra-checks\", specifier = \">=0.16,<1.0\" },\n+    { name = \"django-migration-linter\", specifier = \">=6.0,<7.0\" },\n+    { name = \"django-query-counter\", specifier = \">=0.5,<1.0\" },\n+    { name = \"django-safe-migrations\", specifier = \">=0.6,<1.0\" },\n+    { name = \"django-stubs\", extras = [\"compatible-mypy\"], specifier = \">=6.0,<6.1\" },\n+    { name = \"django-test-migrations\", specifier = \">=1.5,<2.0\" },\n+    { name = \"django-zeal\", specifier = \">=2.0,<3.0\" },\n+    { name = \"djangofmt\", specifier = \">=0.2,<1.0\" },\n+    { name = \"dotenv-linter\", specifier = \">=0.7,<1.0\" },\n+    { name = \"dump-env\", specifier = \">=1.5,<2.0\" },\n+    { name = \"hypothesis\", specifier = \">=6.123,<7.0\" },\n+    { name = \"import-linter\", specifier = \">=2.10,<3.0\" },\n+    { name = \"ipython\", specifier = \">=9.5,<10.0\" },\n+    { name = \"polint\", specifier = \">=0.5,<1.0\" },\n+    { name = \"pytest\", specifier = \">=9.0,<10.0\" },\n+    { name = \"pytest-cov\", specifier = \">=7.1,<8.0\" },\n+    { name = \"pytest-django\", specifier = \">=4.9,<5.0\" },\n+    { name = \"pytest-randomly\", specifier = \">=4.0,<5.0\" },\n+    { name = \"pytest-timeout\", specifier = \">=2.3,<3.0\" },\n+    { name = \"ruff\", specifier = \">=0.15,<1.0\" },\n+    { name = \"safety\", specifier = \">=3.6,<4.0\" },\n+    { name = \"schemathesis\", specifier = \">=4.12,<5.0\" },\n+    { name = \"wemake-python-styleguide\", specifier = \">=1.6,<2.0\" },\n+    { name = \"yamllint\", specifier = \">=1.35,<2.0\" },\n+]\n+docs = [\n+    { name = \"furo\", specifier = \">=2025.12\" },\n+    { name = \"myst-parser\", specifier = \">=5.0,<6.0\" },\n+    { name = \"sphinx\", specifier = \">=9.1,<10.0\" },\n+    { name = \"sphinx-autodoc-typehints\", specifier = \">=3.0,<4.0\" },\n+]\n+\n+[[package]]\n+name = \"wemake-python-styleguide\"\n+version = \"1.6.1\"\n+source = { registry = \"https://pypi.org/simple\" }\n+dependencies = [\n+    { name = \"attrs\" },\n+    { name = \"flake8\" },\n+    { name = \"pygments\" },\n+]\n+sdist = { url = \"https://files.pythonhosted.org/packages/b3/b3/3ade9b1595052bf15b94bedd458768b596de02d701075ba87e95b5d6b392/wemake_python_styleguide-1.6.1.tar.gz\", hash = \"sha256:72eb81dc421dde9f32ce1f67b25d1a13060c264bac12857897b582f83e6bbdbf\", size = 158266, upload-time = \"2026-02-28T18:55:54.801Z\" }\n+wheels = [\n+    { url = \"https://files.pythonhosted.org/packages/e1/75/fb15010739383946c532f157836bb3ca826f0252333a07f60743999a7799/wemake_python_styleguide-1.6.1-py3-none-any.whl\", hash = \"sha256:799690b3654e9eb6db4bf021053c64f907eff9845646a634e22f89a34c3b6ef0\", size = 221563, upload-time = \"2026-02-28T18:55:56.336Z\" },\n+]\n+\n+[[package]]\n+name = \"werkzeug\"\n+version = \"3.1.7\"\n+source = { registry = \"https://pypi.org/simple\" }\n+dependencies = [\n+    { name = \"markupsafe\" },\n+]\n+sdist = { url = \"https://files.pythonhosted.org/packages/b5/43/76ded108b296a49f52de6bac5192ca1c4be84e886f9b5c9ba8427d9694fd/werkzeug-3.1.7.tar.gz\", hash = \"sha256:fb8c01fe6ab13b9b7cdb46892b99b1d66754e1d7ab8e542e865ec13f526b5351\", size = 875700, upload-time = \"2026-03-24T01:08:07.687Z\" }\n+wheels = [\n+    { url = \"https://files.pythonhosted.org/packages/7f/b2/0bba9bbb4596d2d2f285a16c2ab04118f6b957d8441566e1abb892e6a6b2/werkzeug-3.1.7-py3-none-any.whl\", hash = \"sha256:4b314d81163a3e1a169b6a0be2a000a0e204e8873c5de6586f453c55688d422f\", size = 226295, upload-time = \"2026-03-24T01:08:06.133Z\" },\n+]\n+\n+[[package]]\n+name = \"wheel\"\n+version = \"0.46.3\"\n+source = { registry = \"https://pypi.org/simple\" }\n+dependencies = [\n+    { name = \"packaging\" },\n+]\n+sdist = { url = \"https://files.pythonhosted.org/packages/89/24/a2eb353a6edac9a0303977c4cb048134959dd2a51b48a269dfc9dde00c8a/wheel-0.46.3.tar.gz\", hash = \"sha256:e3e79874b07d776c40bd6033f8ddf76a7dad46a7b8aa1b2787a83083519a1803\", size = 60605, upload-time = \"2026-01-22T12:39:49.136Z\" }\n+wheels = [\n+    { url = \"https://files.pythonhosted.org/packages/87/22/b76d483683216dde3d67cba61fb2444be8d5be289bf628c13fc0fd90e5f9/wheel-0.46.3-py3-none-any.whl\", hash = \"sha256:4b399d56c9d9338230118d705d9737a2a468ccca63d5e813e2a4fc7815d8bc4d\", size = 30557, upload-time = \"2026-01-22T12:39:48.099Z\" },\n+]\n+\n+[[package]]\n+name = \"yamllint\"\n+version = \"1.38.0\"\n+source = { registry = \"https://pypi.org/simple\" }\n+dependencies = [\n+    { name = \"pathspec\" },\n+    { name = \"pyyaml\" },\n+]\n+sdist = { url = \"https://files.pythonhosted.org/packages/28/a0/8fc2d68e132cf918f18273fdc8a1b8432b60d75ac12fdae4b0ef5c9d2e8d/yamllint-1.38.0.tar.gz\", hash = \"sha256:09e5f29531daab93366bb061e76019d5e91691ef0a40328f04c927387d1d364d\", size = 142446, upload-time = \"2026-01-13T07:47:53.276Z\" }\n+wheels = [\n+    { url = \"https://files.pythonhosted.org/packages/05/92/aed08e68de6e6a3d7c2328ce7388072cd6affc26e2917197430b646aed02/yamllint-1.38.0-py3-none-any.whl\", hash = \"sha256:fc394a5b3be980a4062607b8fdddc0843f4fa394152b6da21722f5d59013c220\", size = 68940, upload-time = \"2026-01-13T07:47:51.343Z\" },\n+]\n", "test_patch": "diff --git a/.github/workflows/test.yml b/.github/workflows/test.yml\nindex 59cad4710..e5948c691 100644\n--- a/.github/workflows/test.yml\n+++ b/.github/workflows/test.yml\n@@ -14,8 +14,7 @@ concurrency:\n permissions:\n   contents: read\n \n-env:  # Keep in sync with `POETRY_VERSION` in `Dockerfile`\n-  POETRY_VERSION: \"2.3.2\"\n+env:\n   PYTHON_VERSION: \"3.13\"\n \n jobs:\n@@ -32,18 +31,14 @@ jobs:\n       with:\n         python-version: ${{ env.PYTHON_VERSION }}\n \n-    - name: Install poetry\n-      run: |\n-        curl -sSL 'https://install.python-poetry.org' | python -\n-\n-        # Adding `poetry` to `$PATH`:\n-        echo \"$HOME/.local/bin\" >> \"$GITHUB_PATH\"\n+    - name: Install uv\n+      uses: astral-sh/setup-uv@v5\n \n     - name: Install dependencies\n-      run: poetry install\n+      run: uv sync\n \n     - name: Run template's tests\n-      run: poetry run bash tests/test_github.sh\n+      run: uv run bash tests/test_github.sh\n \n   test-internal:\n     runs-on: ubuntu-latest\n@@ -58,24 +53,18 @@ jobs:\n       with:\n         python-version: ${{ env.PYTHON_VERSION }}\n \n-    - name: Install poetry\n-      run: |\n-        curl -sSL 'https://install.python-poetry.org' | python -\n-\n-        # Adding `poetry` to `$PATH`:\n-        echo \"$HOME/.local/bin\" >> \"$GITHUB_PATH\"\n+    - name: Install uv\n+      uses: astral-sh/setup-uv@v5\n \n     - name: Install dependencies\n-      run: |\n-        poetry config virtualenvs.in-project true\n-        poetry install\n+      run: uv sync\n \n     - name: Run internal project checks\n       run: |\n-        poetry run ruff check --exit-non-zero-on-fix --diff\n-        poetry run ruff format --check --diff\n-        poetry run flake8 .\n-        poetry run mypy .\n-        poetry run pytest\n-        poetry run poetry check\n-        poetry run pip check\n+        uv run ruff check --exit-non-zero-on-fix --diff\n+        uv run ruff format --check --diff\n+        uv run flake8 .\n+        uv run mypy .\n+        uv run pytest\n+        uv lock --check\n+        uv run pip check\ndiff --git a/tests/build_docs.sh b/tests/build_docs.sh\nindex d98b69375..bf34d168d 100644\n--- a/tests/build_docs.sh\n+++ b/tests/build_docs.sh\n@@ -14,10 +14,10 @@ run_cookiecutter_build \"$GITHUB_WORKSPACE\"\n cd \"$PROJECT_PATH\"\n \n # Install deps from the project:\n-poetry sync --only=main --only=docs\n+uv sync --group docs --no-dev\n \n # Build docs:\n-make -C docs html\n+uv run make -C docs html\n \n # Move the result docs to the dest:\n ls docs/_build/html\ndiff --git a/tests/test_project_generation.py b/tests/test_project_generation.py\nindex 5b7c50ad6..046abcfaa 100644\n--- a/tests/test_project_generation.py\n+++ b/tests/test_project_generation.py\n@@ -79,11 +79,11 @@ def test_pyproject_toml(\n \n     pyproject = tomllib.loads(path.read_text())\n     project = pyproject['project']\n-    poetry = pyproject['tool']['poetry']\n \n     assert project['name'] == context['project_name']\n     assert project['description'] == context['project_verbose_name']\n-    assert poetry\n+    assert project['dependencies']\n+    assert pyproject['dependency-groups']\n \n \n @pytest.mark.parametrize(\n", "problem_statement": "[OPEN QUESTION] Migrate from poetry to uv\nHi there,\r\nAre we interested in using `uv` instead of `poetry` in that project-template? \n", "hints_text": "I will! I have the only blocker: https://github.com/dependabot/dependabot-core/issues/10478\r\n\r\nAlso see https://github.com/mkniewallner/migrate-to-uv\nAlso some links which I bookmarked:\r\n* https://micro.webology.dev/2024/11/03/uv-does-everything.html\r\n* https://github.com/mkniewallner/migrate-to-uv (already mentioned above)\r\n* https://micro.webology.dev/2024/02/29/pythons-uv-tool.html\r\n* https://micro.webology.dev/2024/03/14/pythons-uv-tool.html\r\n* https://blog.pecar.me/uv-with-django\r\n* https://micro.webology.dev/2024/11/03/uv-does-everything.html\n* https://github.com/stvnksslr/uv-migrator\n\n", "all_hints_text": "I will! I have the only blocker: https://github.com/dependabot/dependabot-core/issues/10478\r\n\r\nAlso see https://github.com/mkniewallner/migrate-to-uv\nAlso some links which I bookmarked:\r\n* https://micro.webology.dev/2024/11/03/uv-does-everything.html\r\n* https://github.com/mkniewallner/migrate-to-uv (already mentioned above)\r\n* https://micro.webology.dev/2024/02/29/pythons-uv-tool.html\r\n* https://micro.webology.dev/2024/03/14/pythons-uv-tool.html\r\n* https://blog.pecar.me/uv-with-django\r\n* https://micro.webology.dev/2024/11/03/uv-does-everything.html\n* https://github.com/stvnksslr/uv-migrator\n\n", "commit_urls": ["https://github.com/wemake-services/wemake-django-template/commit/c8a74a5dbdd17a2e5da1fb2cce6b3f247b8064b8"], "created_at": "2026-04-02T11:50:37Z"}
{"repo": "wemake-services/wemake-django-template", "pull_number": 2808, "instance_id": "wemake-services__wemake-django-template-2808", "issue_numbers": [2805], "base_commit": "1b7bd18d1fca34dd762cfa4c06d4754a1b62b947", "patch": "diff --git a/pyproject.toml b/pyproject.toml\nindex 99b8715b7..05c41cc40 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -148,7 +148,7 @@ addopts = [\n \n \n [tool.mypy]\n-# The mypy configurations: http://bit.ly/2zEl9WI\n+# The mypy configurations: https://mypy.readthedocs.io/en/stable/config_file.html\n ignore_missing_imports = true\n strict = true\n strict_bytes = true\n", "test_patch": "", "problem_statement": "Dead mypy configurations URL\nhttps://github.com/wemake-services/wemake-django-template/blob/e6209a7902f9c8e8518182bd72c085ba777d7c44/pyproject.toml#L151\n\nhttp://bit.ly/2zEl9W seems to be dead now :(\n", "hints_text": "Please, send a PR with a real link, not `bit.ly` :)\n> Please, send a PR with a real link, not `bit.ly` :)\n\nWell I would but... I'm not sure what the original author was trying to link to exactly... since the link is dead now... \ud83e\udd14 \nTo https://mypy.readthedocs.io/en/stable/config_file.html :)\n\n", "all_hints_text": "Please, send a PR with a real link, not `bit.ly` :)\n> Please, send a PR with a real link, not `bit.ly` :)\n\nWell I would but... I'm not sure what the original author was trying to link to exactly... since the link is dead now... \ud83e\udd14 \nTo https://mypy.readthedocs.io/en/stable/config_file.html :)\n@sobolevn i can ?:^) https://github.com/wemake-services/wemake-django-template/pull/2808\n\n", "commit_urls": ["https://github.com/wemake-services/wemake-django-template/commit/2ebb4e331b45e9ee90f9baf0dfc41fc025eb2653"], "created_at": "2025-05-14T12:50:04Z"}
{"repo": "wemake-services/wemake-django-template", "pull_number": 2894, "instance_id": "wemake-services__wemake-django-template-2894", "issue_numbers": [2892], "base_commit": "ab979b4beaf9a66f1c8b54a359812e918471e0f1", "patch": "diff --git a/{{cookiecutter.project_name}}/server/urls.py b/{{cookiecutter.project_name}}/server/urls.py\nindex 335a275e2..2aa318d03 100644\n--- a/{{cookiecutter.project_name}}/server/urls.py\n+++ b/{{cookiecutter.project_name}}/server/urls.py\n@@ -36,6 +36,7 @@\n             template_name='common/txt/robots.txt',\n             content_type='text/plain',\n         ),\n+        name='robots_txt',\n     ),\n     path(\n         'humans.txt',\n@@ -43,6 +44,7 @@\n             template_name='common/txt/humans.txt',\n             content_type='text/plain',\n         ),\n+        name='humans_txt',\n     ),\n     # It is a good practice to have explicit index view:\n     path('', index, name='index'),\n", "test_patch": "diff --git a/{{cookiecutter.project_name}}/tests/test_server/test_urls.py b/{{cookiecutter.project_name}}/tests/test_server/test_urls.py\nindex 151631366..bc3e8ce66 100644\n--- a/{{cookiecutter.project_name}}/tests/test_server/test_urls.py\n+++ b/{{cookiecutter.project_name}}/tests/test_server/test_urls.py\n@@ -1,41 +1,49 @@\n from http import HTTPStatus\n+from typing import Final\n \n import pytest\n from django.test import Client\n+from django.urls import reverse\n+\n+_HEALTH_URL: Final = reverse('health_check:health_check_home')\n+_ADMIN_URL: Final = reverse('admin:index')\n+_ADMIN_DOC_URL: Final = reverse('django-admindocs-docroot')\n+_ROBOTS_URL: Final = reverse('robots_txt')\n+_HUMANS_URL: Final = reverse('humans_txt')\n \n \n @pytest.mark.django_db\n def test_health_check(client: Client) -> None:\n     \"\"\"Ensures that health check is accessible.\"\"\"\n-    response = client.get('/health/')\n+    response = client.get(_HEALTH_URL)\n \n     assert response.status_code == HTTPStatus.OK\n \n \n def test_admin_unauthorized(client: Client) -> None:\n     \"\"\"Ensures that admin panel requires auth.\"\"\"\n-    response = client.get('/admin/')\n+    response = client.get(_ADMIN_URL)\n \n     assert response.status_code == HTTPStatus.FOUND\n \n \n def test_admin_authorized(admin_client: Client) -> None:\n     \"\"\"Ensures that admin panel is accessible.\"\"\"\n-    response = admin_client.get('/admin/')\n+    response = admin_client.get(_ADMIN_URL)\n \n     assert response.status_code == HTTPStatus.OK\n \n \n def test_admin_docs_unauthorized(client: Client) -> None:\n     \"\"\"Ensures that admin panel docs requires auth.\"\"\"\n-    response = client.get('/admin/doc/')\n+    response = client.get(_ADMIN_DOC_URL)\n \n     assert response.status_code == HTTPStatus.FOUND\n \n \n def test_admin_docs_authorized(admin_client: Client) -> None:\n     \"\"\"Ensures that admin panel docs are accessible.\"\"\"\n-    response = admin_client.get('/admin/doc/')\n+    response = admin_client.get(_ADMIN_DOC_URL)\n \n     assert response.status_code == HTTPStatus.OK\n     assert b'docutils' not in response.content\n@@ -44,8 +52,8 @@ def test_admin_docs_authorized(admin_client: Client) -> None:\n @pytest.mark.parametrize(\n     'page',\n     [\n-        '/robots.txt',\n-        '/humans.txt',\n+        _ROBOTS_URL,\n+        _HUMANS_URL,\n     ],\n )\n def test_specials_txt(client: Client, page: str) -> None:\n", "problem_statement": "Using `reverse()` instead direct link\nNeed to correct [this](https://github.com/wemake-services/wemake-django-template/blob/master/%7B%7Bcookiecutter.project_name%7D%7D/tests/test_server/test_urls.py) file to use `reverse()` instead direct links. This will allow the tests to continue working correctly if the url path changes.\n\n", "hints_text": "please, go ahead :)\n\n", "all_hints_text": "please, go ahead :)\n\n", "commit_urls": ["https://github.com/wemake-services/wemake-django-template/commit/53b4f1b15fc60678483e9ce77ad0be0b05b8850b", "https://github.com/wemake-services/wemake-django-template/commit/ea7f3cf182acd75f3c354cb2abc3bf97929976f7"], "created_at": "2025-11-12T05:40:39Z"}
{"repo": "wemake-services/wemake-django-template", "pull_number": 2966, "instance_id": "wemake-services__wemake-django-template-2966", "issue_numbers": [2898], "base_commit": "549f4ed8e3c53f00d32b9cf1020c795450cd4fd3", "patch": "diff --git a/{{cookiecutter.project_name}}/pyproject.toml b/{{cookiecutter.project_name}}/pyproject.toml\nindex f3345b4e..fdcfcdd0 100644\n--- a/{{cookiecutter.project_name}}/pyproject.toml\n+++ b/{{cookiecutter.project_name}}/pyproject.toml\n@@ -167,3 +167,111 @@ pydocstyle.convention = \"google\"\n \"server/common/typing/*.py\" = [\"F401\"]\n \"server/implemented.py\" = [\"PLC0415\", \"D103\"]\n \"tests/*.py\" = [\"S101\"]\n+\n+\n+[tool.pytest.ini_options]\n+# pytest configuration:\n+# https://docs.pytest.org/en/stable/customize.html\n+\n+# pytest-django configuration:\n+# https://pytest-django.readthedocs.io/en/latest/\n+DJANGO_SETTINGS_MODULE = \"server.settings\"\n+\n+# Timeout for tests, so they can not take longer\n+# than this amount of seconds.\n+# You should adjust this value to be as low as possible.\n+# Configuration:\n+# https://pypi.org/project/pytest-timeout/\n+timeout = 5\n+\n+# Strict `@xfail` by default:\n+xfail_strict = true\n+\n+# Directories that are not visited by pytest collector:\n+norecursedirs = [\n+  \"*.egg\",\n+  \".eggs\",\n+  \"dist\",\n+  \"build\",\n+  \"docs\",\n+  \".tox\",\n+  \".git\",\n+  \"__pycache__\",\n+  \".hypothesis\",\n+]\n+\n+# You will need to measure your tests speed with `-n auto` and without it,\n+# so you can see whether it gives you any performance gain, or just gives\n+# you an overhead. See `docs/template/development-process.rst`.\n+addopts = [\n+  \"--strict-markers\",\n+  \"--strict-config\",\n+  \"--doctest-modules\",\n+  \"--fail-on-template-vars\",\n+  # Output:\n+  \"--tb=short\",\n+  # Coverage:\n+  \"--cov=server\",\n+  \"--cov=tests\",\n+  \"--cov-branch\",\n+  \"--cov-report=term-missing:skip-covered\",\n+  \"--cov-report=html\",\n+  \"--cov-report=xml\",\n+  \"--cov-fail-under=100\",\n+]\n+\n+# Fail on warnings:\n+filterwarnings = [\"error\"]\n+\n+\n+[tool.coverage.run]\n+# Coverage configuration:\n+# https://coverage.readthedocs.io/en/latest/config.html\n+plugins = [\n+  # Docs: https://github.com/nedbat/django_coverage_plugin\n+  \"django_coverage_plugin\",\n+  # Docs: https://pypi.org/project/covdefaults\n+  \"covdefaults\",\n+]\n+\n+omit = [\n+  # Is not reported, because is imported during setup:\n+  \"server/settings/components/logging.py\",\n+]\n+\n+\n+[tool.mypy]\n+# Mypy configuration:\n+# https://mypy.readthedocs.io/en/latest/config_file.html\n+enable_error_code = [\n+  \"truthy-bool\",\n+  \"truthy-iterable\",\n+  \"redundant-expr\",\n+  \"unused-awaitable\",\n+  \"ignore-without-code\",\n+  \"possibly-undefined\",\n+  \"redundant-self\",\n+  \"explicit-override\",\n+  \"unimported-reveal\",\n+  \"deprecated\",\n+  \"exhaustive-match\",\n+]\n+\n+explicit_package_bases = true\n+ignore_missing_imports = true\n+local_partial_types = true\n+strict = true\n+strict_bytes = true\n+warn_unreachable = true\n+\n+plugins = [\"mypy_django_plugin.main\"]\n+\n+[[tool.mypy.overrides]]\n+module = \"server.apps.*.migrations.*\"\n+# Django migrations should not produce any errors (they are tested anyway):\n+ignore_errors = true\n+\n+[tool.django-stubs]\n+# Docs: https://github.com/typeddjango/django-stubs\n+django_settings_module = \"server.settings\"\n+strict_settings = false\ndiff --git a/{{cookiecutter.project_name}}/setup.cfg b/{{cookiecutter.project_name}}/setup.cfg\nindex 5841ab91..8e589ae1 100644\n--- a/{{cookiecutter.project_name}}/setup.cfg\n+++ b/{{cookiecutter.project_name}}/setup.cfg\n@@ -35,97 +35,3 @@ per-file-ignores =\n   server/apps/main/api/views.py: WPS201\n   # Enable `assert` keyword and magic numbers for tests:\n   tests/*.py: WPS432\n-\n-\n-[tool:pytest]\n-# pytest configuration:\n-# https://docs.pytest.org/en/stable/customize.html\n-\n-# pytest-django configuration:\n-# https://pytest-django.readthedocs.io/en/latest/\n-DJANGO_SETTINGS_MODULE = server.settings\n-\n-# Timeout for tests, so they can not take longer\n-# than this amount of seconds.\n-# You should adjust this value to be as low as possible.\n-# Configuration:\n-# https://pypi.org/project/pytest-timeout/\n-timeout = 5\n-\n-# Strict `@xfail` by default:\n-xfail_strict = true\n-\n-# Directories that are not visited by pytest collector:\n-norecursedirs = *.egg .eggs dist build docs .tox .git __pycache__ .hypothesis\n-\n-# You will need to measure your tests speed with `-n auto` and without it,\n-# so you can see whether it gives you any performance gain, or just gives\n-# you an overhead. See `docs/template/development-process.rst`.\n-addopts =\n-  --strict-markers\n-  --strict-config\n-  --doctest-modules\n-  --fail-on-template-vars\n-  # Output:\n-  --tb=short\n-  # Coverage:\n-  --cov=server\n-  --cov=tests\n-  --cov-branch\n-  --cov-report=term-missing:skip-covered\n-  --cov-report=html\n-  --cov-report=xml\n-  --cov-fail-under=100\n-\n-filterwarnings =\n-  error\n-\n-\n-[coverage:run]\n-# Coverage configuration:\n-# https://coverage.readthedocs.io/en/latest/config.html\n-plugins =\n-  # Docs: https://github.com/nedbat/django_coverage_plugin\n-  django_coverage_plugin\n-  # Docs: https://pypi.org/project/covdefaults\n-  covdefaults\n-\n-omit =\n-  # Is not reported, because is imported during setup:\n-  server/settings/components/logging.py\n-\n-\n-[mypy]\n-# Mypy configuration:\n-# https://mypy.readthedocs.io/en/latest/config_file.html\n-enable_error_code =\n-  truthy-bool,\n-  truthy-iterable,\n-  redundant-expr,\n-  unused-awaitable,\n-  ignore-without-code,\n-  possibly-undefined,\n-  redundant-self,\n-  explicit-override,\n-  unimported-reveal,\n-  deprecated,\n-  exhaustive-match,\n-\n-explicit_package_bases = true\n-ignore_missing_imports = true\n-local_partial_types = true\n-strict = true\n-strict_bytes = true\n-warn_unreachable = true\n-\n-plugins =\n-  mypy_django_plugin.main\n-\n-[mypy-server.apps.*.migrations.*]\n-# Django migrations should not produce any errors (they are tested anyway):\n-ignore_errors = true\n-\n-[mypy.plugins.django-stubs]\n-# Docs: https://github.com/typeddjango/django-stubs\n-django_settings_module = server.settings\n-strict_settings = false\n", "test_patch": "", "problem_statement": "Consider using `pyproject.toml` for `pytest` configuration\nFinally we can use `.toml` format for [configuration](https://docs.pytest.org/en/stable/changelog.html#new-features). @sobolevn do you think it's worth switching between?\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/wemake-services/wemake-django-template/commit/489fa92610f32849f571e0e4b5ba9aa8ce0453f4"], "created_at": "2026-04-03T04:01:53Z"}
