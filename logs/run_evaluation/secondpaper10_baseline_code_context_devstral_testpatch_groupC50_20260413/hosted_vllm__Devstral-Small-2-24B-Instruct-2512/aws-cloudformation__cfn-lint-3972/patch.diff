+"""
+Copyright Amazon.com, Inc. or its affiliates. All Rights Reserved.
+SPDX-License-Identifier: MIT-0
+"""
+
+from cfnlint.rules import CloudFormationLintRule, RuleMatch
+from cfnlint.template import Template
+
+
+class CodeBuildProjectUniqueNames(CloudFormationLintRule):
+    id = "E3060"
+    shortdesc = "CodeBuild projects must have unique names"
+    description = "AWS::CodeBuild::Project resources must have unique Name properties"
+    source_url = "https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/aws-resource-codebuild-project.html"
+    tags = ["resources", "codebuild"]
+
+    def match(self, cfn: Template):
+        matches = []
+        codebuild_projects = {}
+
+        # Collect all CodeBuild projects and their names
+        for resource_name, resource_props in cfn.get_resources("AWS::CodeBuild::Project").items():
+            properties = resource_props.get("Properties", {})
+            name = properties.get("Name")
+
+            if name:
+                # Handle intrinsic functions (Ref, GetAtt, etc.) which are represented as dicts
+                if isinstance(name, dict):
+                    # If it's a function, we can't determine the value at lint time
+                    # Skip this check to avoid false positives
+                    continue
+
+                # Convert name to string to handle different types
+                name_str = str(name)
+
+                if name_str in codebuild_projects:
+                    # Found a duplicate name
+                    existing_resource = codebuild_projects[name_str]
+                    matches.append(
+                        RuleMatch(
+                            ["Resources", resource_name, "Properties", "Name"],
+                            f"CodeBuild project name '{name_str}' is not unique. "
+                            f"Also defined in resource '{existing_resource}'"
+                        )
+                    )
+                    matches.append(
+                        RuleMatch(
+                            ["Resources", existing_resource, "Properties", "Name"],
+                            f"CodeBuild project name '{name_str}' is not unique. "
+                            f"Also defined in resource '{resource_name}'"
+                        )
+                    )
+                else:
+                    codebuild_projects[name_str] = resource_name
+
+        return matches
