+
+    def coordinates_to_conandata(self, remote="origin", repository=False):
+        """
+        Stores the current git repository URL and commit in the conandata.yml file.
+        This method should be called in the ``export()`` method of the recipe.
+
+        It captures the current remote coordinates (URL and commit) and stores them in
+        the conandata.yml file under the "scm" key. This information can later be used
+        by ``checkout_from_conandata_coordinates()`` to checkout the exact same commit.
+
+        :param remote: Name of the remote git repository ('origin' by default).
+        :param repository: By default gets the commit of the defined folder, use repo=True to get
+                     the commit of the repository instead.
+        """
+        from conan.tools.files import update_conandata
+
+        url, commit = self.get_url_and_commit(remote=remote, repository=repository)
+        update_conandata(self._conanfile, {"scm": {"commit": commit, "url": url}})
+
+    def checkout_from_conandata_coordinates(self, target="."):
+        """
+        Checks out the source code from the coordinates stored in conandata.yml.
+        This method should be called in the ``source()`` method of the recipe.
+
+        It reads the URL and commit from the conandata.yml file (under the "scm" key)
+        and performs a git clone and checkout to that specific commit.
+
+        :param target: Target folder for the clone operation (default is current directory).
+        """
+        scm_data = self._conanfile.conan_data.get("scm", {})
+        url = scm_data.get("url")
+        commit = scm_data.get("commit")
+
+        if not url or not commit:
+            raise ConanException("No SCM coordinates found in conandata.yml. "
+                                 "Use Git.coordinates_to_conandata() in export() method")
+
+        self.clone(url=url, target=target)
+        self.checkout(commit=commit)
