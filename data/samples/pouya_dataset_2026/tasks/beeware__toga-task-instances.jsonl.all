plete(task)\n  File \"/Users/runner/work/toga/toga/testbed/build/testbed/macos/app/Toga Testbed.app/Contents/Resources/app/tests/conftest.py\", line 167, in run_until_complete\n    return asyncio.run_coroutine_threadsafe(coro, self.loop).result()\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"/Users/runner/work/toga/toga/testbed/build/testbed/macos/app/Toga Testbed.app/Contents/Frameworks/Python.framework/Versions/3.12/lib/python3.12/concurrent/futures/_base.py\", line 456, in result\n    return self.__get_result()\n           ^^^^^^^^^^^^^^^^^^^\n  File \"/Users/runner/work/toga/toga/testbed/build/testbed/macos/app/Toga Testbed.app/Contents/Frameworks/Python.framework/Versions/3.12/lib/python3.12/concurrent/futures/_base.py\", line 401, in __get_result\n    raise self._exception\n  File \"/Users/runner/work/toga/toga/testbed/build/testbed/macos/app/Toga Testbed.app/Contents/Resources/app/tests/widgets/test_webview.py\", line 180, in test_load_url\n    await assert_content_change(\n  File \"/Users/runner/work/toga/toga/testbed/build/testbed/macos/app/Toga Testbed.app/Contents/Resources/app/tests/widgets/test_webview.py\", line 55, in assert_content_change\n    new_content = await get_content(widget)\n                  ^^^^^^^^^^^^^^^^^^^^^^^^^\n  File \"/Users/runner/work/toga/toga/testbed/build/testbed/macos/app/Toga Testbed.app/Contents/Resources/app/tests/widgets/test_webview.py\", line 27, in get_content\n    return await wait_for(\n           ^^^^^^^^^^^^^^^\n  File \"/Users/runner/work/toga/toga/testbed/build/testbed/macos/app/Toga Testbed.app/Contents/Frameworks/Python.framework/Versions/3.12/lib/python3.12/asyncio/tasks.py\", line 520, in wait_for\n    return await fut\n           ^^^^^^^^^\nRuntimeError: Error Domain=WKErrorDomain Code=4 \"A JavaScript exception occurred\" UserInfo={WKJavaScriptExceptionLineNumber=1, WKJavaScriptExceptionMessage=TypeError: null is not an object (evaluating 'document.body.innerHTML'), WKJavaScriptExceptionColumnNumber=14, WKJavaScriptExceptionSourceURL=https://github.com/beeware, NSLocalizedDescription=A JavaScript exception occurred}\n---------------------------- Captured stdout setup -----------------------------\nResetting main_window\n=========================== short test summary info ============================\nFAILED tests/widgets/test_webview.py::test_load_url - RuntimeError: Error Domain=WKErrorDomain Code=4 \"A JavaScript exception occurred\" UserInfo={WKJavaScriptExceptionLineNumber=1, WKJavaScriptExceptionMessage=TypeError: null is not an object (evaluating 'document.body.innerHTML'), WKJavaScriptExceptionColumnNumber=14, WKJavaScriptExceptionSourceURL=https://github.com/beeware, NSLocalizedDescription=A JavaScript exception occurred}\n= 1 failed, 546 passed, 29 skipped, 28 xfailed, 2 xpassed in 337.24s (0:05:37) =\n\n[testbed] Test suite failed!\nSaving log... started\n\nLog saved to /Users/runner/work/toga/toga/testbed/logs/briefcase.2025_05_28-13_35_48.run.log\n\nSaving log... done\nError: Process completed with exit code 232.\n```\n\n\n### Additional context\n\n_No response_\n", "hints_text": "Refs https://github.com/beeware/toga/actions/runs/15571601361/job/43848585678\nHmm... Happened twice in a row in PR 3547!\n\nhttps://github.com/beeware/toga/actions/runs/15573438924/job/43853964555\nOn all Apple platforms, actually. We're getting 4 failures (all consecutive, with the first 3 listed being exact same code just different pushing) in one day!\n\nhttps://github.com/beeware/toga/actions/runs/15657081928\nhttps://github.com/beeware/toga/actions/runs/15657243276\nhttps://github.com/beeware/toga/actions/runs/15657081928\nhttps://github.com/beeware/toga/actions/runs/15655068946/job/44105055254\n\n\n", "all_hints_text": "Refs https://github.com/beeware/toga/actions/runs/15571601361/job/43848585678\nHmm... Happened twice in a row in PR 3547!\n\nhttps://github.com/beeware/toga/actions/runs/15573438924/job/43853964555\nOn all Apple platforms, actually. We're getting 4 failures (all consecutive, with the first 3 listed being exact same code just different pushing) in one day!\n\nhttps://github.com/beeware/toga/actions/runs/15657081928\nhttps://github.com/beeware/toga/actions/runs/15657243276\nhttps://github.com/beeware/toga/actions/runs/15657081928\nhttps://github.com/beeware/toga/actions/runs/15655068946/job/44105055254\n\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/6346713f08bde6e3e5af7807b34fdefff839c07a", "https://github.com/beeware/toga/commit/6c068ca3e26b5c675bf5ffc72ff79c7ad7a5f6b0", "https://github.com/beeware/toga/commit/9e74523088733e9eda60a8cbb3bf88ddd131b668", "https://github.com/beeware/toga/commit/d535b945363f5253b4aa01c30b25554b3d00e025", "https://github.com/beeware/toga/commit/f14255b0bd58524d04b464e25c141a75daacde35", "https://github.com/beeware/toga/commit/99a41aa021a31607aeabceb156a91c8cf6d92bed", "https://github.com/beeware/toga/commit/b7922921932ce273be1a11bef8f933dad96bb022"], "created_at": "2025-06-15T00:46:24Z"}
{"repo": "beeware/toga", "pull_number": 3525, "instance_id": "beeware__toga-3525", "issue_numbers": [3524], "base_commit": "5895501bd7ac9229858910e4f4f752d2a5a94f50", "patch": "diff --git a/changes/3525.bugfix.rst b/changes/3525.bugfix.rst\nnew file mode 100644\nindex 0000000000..2c46d6f9c8\n--- /dev/null\n+++ b/changes/3525.bugfix.rst\n@@ -0,0 +1,1 @@\n+Older Linux distributions (such as Ubuntu 22.04) that ship with GLib < 2.74 can now use GTK4 with Toga.\ndiff --git a/gtk/src/toga_gtk/app.py b/gtk/src/toga_gtk/app.py\nindex da18895239..93a2142d98 100644\n--- a/gtk/src/toga_gtk/app.py\n+++ b/gtk/src/toga_gtk/app.py\n@@ -6,6 +6,7 @@\n \n from .keys import gtk_accel\n from .libs import (\n+    GLIB_VERSION,\n     GTK_VERSION,\n     IS_WAYLAND,\n     TOGA_DEFAULT_STYLES,\n@@ -33,7 +34,11 @@ def __init__(self, interface):\n         self.loop = self.policy.get_event_loop()\n \n         # Stimulate the build of the app\n-        if GTK_VERSION < (4, 0, 0):  # pragma: no-cover-if-gtk4\n+        # *Note* -- the coverage may be inaccurate if GTK3 is used with\n+        # a newer version of glib or if GTK4 is used with an older version\n+        # of glib.  On local runs, coverage errors here can be safely\n+        # ignored if the version of software is as described above.\n+        if GLIB_VERSION < (2, 74, 0):  # pragma: no-cover-if-gtk4\n             self.native = Gtk.Application(\n                 application_id=self.interface.app_id,\n                 flags=Gio.ApplicationFlags.FLAGS_NONE,\ndiff --git a/gtk/src/toga_gtk/libs/gtk.py b/gtk/src/toga_gtk/libs/gtk.py\nindex 9768fbe597..90e7c5a21b 100644\n--- a/gtk/src/toga_gtk/libs/gtk.py\n+++ b/gtk/src/toga_gtk/libs/gtk.py\n@@ -23,6 +23,12 @@\n     Gtk.get_micro_version(),\n )\n \n+GLIB_VERSION: tuple[int, int, int] = (\n+    GLib.MAJOR_VERSION,\n+    GLib.MAJOR_VERSION,\n+    GLib.MAJOR_VERSION,\n+)\n+\n if GTK_VERSION < (4, 0, 0):  # pragma: no-cover-if-gtk4\n     default_display = Gdk.Screen.get_default()\n else:  # pragma: no-cover-if-gtk3\n", "test_patch": "", "problem_statement": "GTK4 App Not Starting on Ubuntu 22.04\n### Describe the bug\n\nUsing this script\n```\nimport toga\nfrom toga.style import Pack\nfrom toga.style.pack import COLUMN, CENTER\n\n\nclass ActivityApp(toga.App):\n    def startup(self):\n        # Main box\n        main_box = toga.Box(style=Pack(direction=COLUMN, alignment=CENTER, padding=20))\n\n        self.act = toga.ActivityIndicator()\n        act.start()\n        main_box.add(self.act)\n\n        # Create a main window\n        self.main_window = toga.MainWindow(title=self.formal_name)\n        self.main_window.content = main_box\n        self.main_window.show()\n\n\ndef main():\n    return ActivityApp('ActivityIndicator App', 'org.beeware.activity')\n\n\nif __name__ == '__main__':\n    main().main_loop()\n```\n\nand the latest version of Toga obtained from pip with a pin on PyGObject 3.50.0 on Ubuntu 22.04, plus an export TOGA_GTK=4, an exception gets thrown when you run the script:\n```\njohnzhou@johnzhou-QEMU-Virtual-Machine:~$ python testai.py\nTraceback (most recent call last):\n  File \"/home/johnzhou/testai.py\", line 26, in <module>\n    main().main_loop()\n  File \"/home/johnzhou/testai.py\", line 22, in main\n    return ActivityApp('ActivityIndicator App', 'org.beeware.activity')\n  File \"/home/johnzhou/.local/lib/python3.10/site-packages/toga/app.py\", line 326, in __init__\n    self.factory.App(interface=self)\n  File \"/home/johnzhou/.local/lib/python3.10/site-packages/toga_gtk/app.py\", line 44, in __init__\n    flags=Gio.ApplicationFlags.DEFAULT_FLAGS,\nAttributeError: type object 'ApplicationFlags' has no attribute 'DEFAULT_FLAGS'\n```\n\n### Steps to reproduce\n\n1. touch testai.py (ai stands for activityindicator)\n2. open testai.py\n3. Paste in the code\n4. export TOGA_GTK=4\n5. python testai.py\n\n### Expected behavior\n\nEither we figure out what's going on or document that you can't test GTK4 using my environment.\n\n### Screenshots\n\n_No response_\n\n### Environment\n\n- Operating System: Ubuntu 22.04 (in a vm)\n- Python version: 3.10.12\n- Software versions:\n  - Briefcase: irrelevant\n  - Toga: 0.5.1\n  - PyGObject: 3.50.0 Pin\n\n\n### Logs\n\n```\njohnzhou@johnzhou-QEMU-Virtual-Machine:~$ python testai.py\nTraceback (most recent call last):\n  File \"/home/johnzhou/testai.py\", line 26, in <module>\n    main().main_loop()\n  File \"/home/johnzhou/testai.py\", line 22, in main\n    return ActivityApp('ActivityIndicator App', 'org.beeware.activity')\n  File \"/home/johnzhou/.local/lib/python3.10/site-packages/toga/app.py\", line 326, in __init__\n    self.factory.App(interface=self)\n  File \"/home/johnzhou/.local/lib/python3.10/site-packages/toga_gtk/app.py\", line 44, in __init__\n    flags=Gio.ApplicationFlags.DEFAULT_FLAGS,\nAttributeError: type object 'ApplicationFlags' has no attribute 'DEFAULT_FLAGS'\n```\n\n\n### Additional context\n\nSpent so much time shaving yak yesterday setting up the VM...\n", "hints_text": "This may have been fixed in https://github.com/beeware/toga/pull/3296. I would ensure everything is the latest version.\nNope. Line 44 is exactly where that line is added in that PR\nAlso, this is GTK4.\nI can confirm I see this behavior as well.\n\nHowever, Ubuntu 22.04 is a 3 old version of Ubuntu, from a time when GTK4 was in rapid initial development development (22.04 ships with GTK 4.6.9, AFAICT). \n\nIf modifying the logic check for this one specific flag is all we need to do to get a GTK4 app working, then maybe it's worth it; but if we need more substantial checks, I think we'll be better served to set a minimum GTK version closer to what 24.04 uses (4.10?) and move on.\n> I can confirm I see this behavior as well.\n\nYes! My yak shaving yesterday paid off (setting up different vm versions, but ultimately deleted everything except for 22.04 because my disk ran out of space :( )\n\n\n\n\n> However, Ubuntu 22.04 is a 3 old version of Ubuntu, from a time when GTK4 was in rapid initial development development (22.04 ships with GTK 4.6.9, AFAICT).\n\nhttps://docs.gtk.org/gio/flags.ApplicationFlags.html shows that none and defaultflags are the same value, so let's just use none for everything.\nWorking on a PR (going to be my first one from the VM!\n\n", "all_hints_text": "This may have been fixed in https://github.com/beeware/toga/pull/3296. I would ensure everything is the latest version.\nNope. Line 44 is exactly where that line is added in that PR\nAlso, this is GTK4.\nI can confirm I see this behavior as well.\n\nHowever, Ubuntu 22.04 is a 3 old version of Ubuntu, from a time when GTK4 was in rapid initial development development (22.04 ships with GTK 4.6.9, AFAICT). \n\nIf modifying the logic check for this one specific flag is all we need to do to get a GTK4 app working, then maybe it's worth it; but if we need more substantial checks, I think we'll be better served to set a minimum GTK version closer to what 24.04 uses (4.10?) and move on.\n> I can confirm I see this behavior as well.\n\nYes! My yak shaving yesterday paid off (setting up different vm versions, but ultimately deleted everything except for 22.04 because my disk ran out of space :( )\n\n\n\n\n> However, Ubuntu 22.04 is a 3 old version of Ubuntu, from a time when GTK4 was in rapid initial development development (22.04 ships with GTK 4.6.9, AFAICT).\n\nhttps://docs.gtk.org/gio/flags.ApplicationFlags.html shows that none and defaultflags are the same value, so let's just use none for everything.\nWorking on a PR (going to be my first one from the VM!\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/f14dbf105b1e6ade343b0ccfee6cd4c41fc7b5f5", "https://github.com/beeware/toga/commit/6230945dcf3e4925b9ba047a716212981cd1e9c9", "https://github.com/beeware/toga/commit/b74ff17d338e23f13ed6fcb5178a893c2b3010b9", "https://github.com/beeware/toga/commit/c93e1f43f404db04b0070bc47aee6f0989763b0e", "https://github.com/beeware/toga/commit/4ba85752ef393268c4d80a8842dca6fd77eb998a"], "created_at": "2025-06-02T23:16:36Z"}
{"repo": "beeware/toga", "pull_number": 3555, "instance_id": "beeware__toga-3555", "issue_numbers": [3554], "base_commit": "32619e37cc23649d67a469948807deff51ddb6bc", "patch": "diff --git a/android/src/toga_android/app.py b/android/src/toga_android/app.py\nindex a6dfd7e3f3..fcc14e7901 100644\n--- a/android/src/toga_android/app.py\n+++ b/android/src/toga_android/app.py\n@@ -40,17 +40,17 @@ def onStart(self):\n \n     def onResume(self):  # pragma: no cover\n         print(\"Toga app: onResume\")\n-        # onTopResumedActivityChanged is not available on android versions less\n-        # than Q. onResume is the best indicator for the gain input focus event.\n+        # onTopResumedActivityChanged is not available on android versions less than Q\n+        # (API level 29). onResume is the best indicator for the gain input focus event.\n         # https://developer.android.com/reference/android/app/Activity#onWindowFocusChanged(boolean):~:text=If%20the%20intent,the%20best%20indicator.\n-        if Build.VERSION.SDK_INT < Build.VERSION_CODES.Q:\n+        if Build.VERSION.SDK_INT < 29:\n             self._impl.interface.current_window.on_gain_focus()\n \n     def onPause(self):  # pragma: no cover\n         print(\"Toga app: onPause\")\n-        # onTopResumedActivityChanged is not available on android versions less\n-        # than Q. onPause is the best indicator for the lost input focus event.\n-        if Build.VERSION.SDK_INT < Build.VERSION_CODES.Q:\n+        # onTopResumedActivityChanged is not available on android versions less than Q\n+        # (API level 29). onPause is the best indicator for the lost input focus event.\n+        if Build.VERSION.SDK_INT < 29:\n             self._impl.interface.current_window.on_lose_focus()\n \n     def onStop(self):  # pragma: no cover\ndiff --git a/changes/3554.bugfix.rst b/changes/3554.bugfix.rst\nnew file mode 100644\nindex 0000000000..d8fdb9ac79\n--- /dev/null\n+++ b/changes/3554.bugfix.rst\n@@ -0,0 +1,1 @@\n+A crash on Android 9 (and earlier) caused by a symbol that wasn't available on those versions has been resolved.\n", "test_patch": "", "problem_statement": "Toga apps crash if executed on Android 9 or earlier\n### Describe the bug\n\nReported via Discord by ChuksT:\n\nTried running the tutorial app on a physical android device (version 9 - 'pie') but the app kept crashing with an error messsge along the line of: \"BUILD$VERSION_CODES does not have the atrribute Q\"\n\n\n### Steps to reproduce\n\n1. Run BeeWare tutorial app on an Android 9 device (or earlier).\n2. See error\n\n\n### Expected behavior\n\nApp should start and run without error.\n\n### Screenshots\n\n_No response_\n\n### Environment\n\n- Operating System: Android 9 (Pie)\n- Python version: any (tested on 3.13.1)\n- Software versions:\n  - Briefcase: 0.3.23\n  - Toga: 0.5.1\n\n\n### Logs\n\n[briefcase.2025_06_14-13_35_25.run.log](https://github.com/user-attachments/files/20735580/briefcase.2025_06_14-13_35_25.run.log)\n\n\n\n### Additional context\n\nThe problem appears to be the literal use of the `Build$VERSION_CODES.Q` symbol. In every other instance where we check a version number, we use the underlying integer (29 in this case), rather than the symbolic representation.\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/e2c3cd8d712992fef85fac27e3f8bfb318e0672d"], "created_at": "2025-06-14T06:14:14Z"}
{"repo": "beeware/toga", "pull_number": 3782, "instance_id": "beeware__toga-3782", "issue_numbers": [3567], "base_commit": "4cbaeb705de621b557e7e16d96496648d24f572b", "patch": "diff --git a/changes/3567.bugfix.rst b/changes/3567.bugfix.rst\nnew file mode 100644\nindex 0000000000..982fb52a7c\n--- /dev/null\n+++ b/changes/3567.bugfix.rst\n@@ -0,0 +1,1 @@\n+Registering a font with a name that shadows a built-in font family name now raises an error instead of falling back to the system font silently.\ndiff --git a/core/src/toga/fonts.py b/core/src/toga/fonts.py\nindex a87441df26..f8ea6451bf 100644\n--- a/core/src/toga/fonts.py\n+++ b/core/src/toga/fonts.py\n@@ -112,7 +112,23 @@ def register(\n         :param weight: The :ref:`font weight <pack-font-weight>`.\n         :param style: The :ref:`font style <pack-font-style>`.\n         :param variant: The :ref:`font variant <pack-font-variant>`.\n+\n+        :raises ValueError: When the registered family has the same name as the standard\n+            font families ``\"cursive\"``, ``\"fantasy\"``, ``\"message\"``, ``\"monospace\"``,\n+            `\"sans-serif\"``, \"serif\", or \"system\".\n         \"\"\"\n+        if family in (\n+            CURSIVE,\n+            FANTASY,\n+            MESSAGE,\n+            MONOSPACE,\n+            SANS_SERIF,\n+            SERIF,\n+            SYSTEM,\n+        ):\n+            raise ValueError(\n+                \"Custom fonts cannot be registered with a built-in font family name\"\n+            )\n         font_key = Font._registered_font_key(family, weight, style, variant)\n         _REGISTERED_FONT_CACHE[font_key] = str(toga.App.app.paths.app / path)\n \n", "test_patch": "diff --git a/core/tests/test_fonts.py b/core/tests/test_fonts.py\nindex 8f43c43ca4..c5f8e996a9 100644\n--- a/core/tests/test_fonts.py\n+++ b/core/tests/test_fonts.py\n@@ -6,9 +6,14 @@\n from toga.fonts import (\n     _REGISTERED_FONT_CACHE,\n     BOLD,\n+    CURSIVE,\n+    FANTASY,\n     ITALIC,\n+    MESSAGE,\n+    MONOSPACE,\n     NORMAL,\n     SANS_SERIF,\n+    SERIF,\n     SMALL_CAPS,\n     SYSTEM,\n     SYSTEM_DEFAULT_FONT_SIZE,\n@@ -171,6 +176,26 @@ def test_register_font(app, path, registered):\n     )\n \n \n+@pytest.mark.parametrize(\n+    \"family\",\n+    [\n+        CURSIVE,\n+        FANTASY,\n+        MESSAGE,\n+        MONOSPACE,\n+        SANS_SERIF,\n+        SERIF,\n+        SYSTEM,\n+    ],\n+)\n+def test_register_shadowed_font(app, family):\n+    with pytest.raises(\n+        ValueError,\n+        match=\"Custom fonts cannot be registered with a built-in font family name\",\n+    ):\n+        toga.Font.register(family, Path(\"path/to/custom/font.otf\"))\n+\n+\n @pytest.mark.parametrize(\n     \"path, registered\",\n     [\n", "problem_statement": "Handling font registrations that overwrite a builtin name\n### Describe the bug\n\nIf you register a custom font with a name like `SERIF`, then attempt to display it on a widget, it will fall back to system \u2014 at least on macOS, iOS, and Android.\n\n### Steps to reproduce\n\n```python\nFont.register(SERIF, self.paths.app / \"resources/ENDOR___.ttf\")\nmystery_label = toga.Label(\"Endor, serif, or system?\", font_family=SERIF)\n```\n\n\n### Expected behavior\n\nI'm not entirely sure, but I think this would be my order of preference.\n\n1. Throw an error at time of registration.\n    **(Edit: this is the behavior that should be implemented, at least for the time being.)**\n3. ~~Display the custom font.~~\n4. ~~Display the named font (in this case `SERIF`).~~\n5. ~~Display `SYSTEM` (current behavior).~~\n\n### Environment\n\nAt least macOS, Android, and iOS\n\n\n### Logs\n\n\n\n\n### Additional context\n\nCSS is perfectly okay with custom font families having the same name as the constants and not overwriting them, but only because CSS differentiates between `serif` (the keyword) and `\"serif\"` (a string), which doesn't really translate to a Python environment. This could be relevant sometime down the road with Colosseum, but I don't think it's worth trying to accommodate now.\n\nTesting this was how I found #3566.\n", "hints_text": "I agree that this is an edge case. However, I can imagine we might be able to make a differentiation between `serif` and `\"serif\"` by making the `SERIF` symbol something other than a string.\nTrue, but that would break the current (and consistent) behavior that anywhere in Toga you would use one of the constants, you can just use the string instead...\nI'm not necessarily against the idea, but I think we should consider it carefully. It would break what's been a consistent design convention \u2014 and if we're going to amend it here, it would make sense to do an audit, looking at CSS compatibility, and decide if any other constants should be changed over as well, up to and including all of them. We'd also need to update Pack's documentation, and provide some variety of shim.\n\nWe'd also have to decide *what* to change them to \u2014 integers are usually an obvious choice for such things, but for our purposes that could collide with *actual* integers for many properties.\n> I'm not necessarily against the idea, but I think we should consider it carefully. \n\nI'm not necessarily *for* it either :-) I mentioned it because it seemed like the obvious solution... but as with many obvious solutions, there are consequences :-)\n\nThat said, if I'm understanding correctly, there are two failure modes here:\n* A user that actually has a font named \"serif\"; and\n* A user that has used `Pack(font_family=\"serif\")`. \n\nThe former seems like an edge case that won't exist in practice... are there any type designers who are that pathological? \ud83e\udd23 \n\nThe latter is definitely a concern, though. Is it a manageable backwards compatibility? Maybe.\n\n> We'd also have to decide _what_ to change them to \u2014 integers are usually an obvious choice for such things, but for our purposes that could collide with _actual_ integers for many properties.\n\nMy go-to for symbolic objects is usually just that - `object()`. It has identity, can't be typed accidentally, and isn't ambiguous with primitive types.\n> That said, if I'm understanding correctly, there are two failure modes here:\n>  * A user that actually has a font named \"serif\"; and\n>  * A user that has used `Pack(font_family=\"serif\")`.\n\nI'm not sure I understand what you mean by two failure modes. Those two steps (assuming the first one includes registering it with that name) reproduce the one failure mode: a user registers a font named \"serif\" (or another built-in name), then tries to apply it to a font.\n\n> The former seems like an edge case that won't exist in practice... are there any type designers who are that pathological? \ud83e\udd23\n\nI mean, probably not. Which is why I think it would be perfectly reasonable if we we don't accommodate it. Currently we fall back to *system*, which doesn't seem right. But I think rendering the (original) serif font while issuing a warning about the naming collision would be sufficient.\n\n> My go-to for symbolic objects is usually just that - `object()`. It has identity, can't be typed accidentally, and isn't ambiguous with primitive types.\n\nThat would certainly make sense, assuming we decide to accommodate the sufficiently pathological.\n\nIt would still be very strange, however, if all the other constants stayed strings, and only these became anonymous objects.\n> > That said, if I'm understanding correctly, there are two failure modes here:\n> > \n> > * A user that actually has a font named \"serif\"; and\n> > * A user that has used `Pack(font_family=\"serif\")`.\n> \n> I'm not sure I understand what you mean by two failure modes. Those two steps (assuming the first one includes registering it with that name) reproduce the one failure mode: a user registers a font named \"serif\" (or another built-in name), then tries to apply it to a font.\n\nSorry - in the second case, I was referring to a user right now who is using a literal string to refer to the \"symbolic\" serif (i.e., `serif` not `\"serif\"` in CSS).\n \n> But I think rendering the (original) serif font while issuing a warning about the naming collision would be sufficient.\n\nYeah - an error at time of registration sounds more than fair.\n \n> > My go-to for symbolic objects is usually just that - `object()`. It has identity, can't be typed accidentally, and isn't ambiguous with primitive types.\n> \n> That would certainly make sense, assuming we decide to accommodate the sufficiently pathological.\n> \n> It would still be very strange, however, if all the other constants stayed strings, and only these became anonymous objects.\n\nThis is true. I don't know that I have a good answer for that, other than documenting \"fonts are different because `serif` vs `\"serif\"` etc\".\n> > I'm not sure I understand what you mean by two failure modes. Those two steps (assuming the first one includes registering it with that name) reproduce the one failure mode: a user registers a font named \"serif\" (or another built-in name), then tries to apply it to a font.\n> \n> Sorry - in the second case, I was referring to a user right now who is using a literal string to refer to the \"symbolic\" serif (i.e., `serif` not `\"serif\"` in CSS).\n\nAh, I see, you mean currently working code would fail if we were to switch the constants away from strings? We could always do a shim for that \u2014 if `\"serif\"` is requested, and nothing's registered in that name, honor the previous behavior \u2014 at least for some period of time.\n\nThat said...\n\n> Yeah - an error at time of registration sounds more than fair.\n\nI'm thinking this is the way to go, at least for the time being. We can always revisit this at a later date if need be.\n> That said...\n> \n> > Yeah - an error at time of registration sounds more than fair.\n> \n> I'm thinking this is the way to go, at least for the time being. We can always revisit this at a later date if need be.\n\nSo... since I have some time to grab this issue... is this the final decision for what to do?\n> So... since I have some time to grab this issue... is this the final decision for what to do?\n\nI'd say so, yes. However, I have #3569 in flight, which is already altering quite a bit in the font backends, and may do significantly more by the time it's finished. For that matter, I might even end up fixing this as part of it. So, probably not the best issue to try and tackle at the moment, I'm afraid.\n> > So... since I have some time to grab this issue... is this the final decision for what to do?\n> \n> I'd say so, yes. However, I have [#3569](https://github.com/beeware/toga/pull/3569) in flight, which is already altering quite a bit in the font backends, and may do significantly more by the time it's finished. For that matter, I might even end up fixing this as part of it. So, probably not the best issue to try and tackle at the moment, I'm afraid.\n\nNo worries. My plan is that I will ``{{% if pr3569.fixes(3567) %}} celebrate{{% else %}} make an error when registering with standard names{{% endif %}}``.\n\n**EDIT** explanation: I've been messing with Jinja a lot lately such that this was my first instinct to write.\n```jinja\n{% if discourse.becomes(Format.JINJA) %}\n    {% do assert could_go_wrong is None %}\n{% endif %}\n```\nGood and got me laughing. To save some spaces {{- like_this -}}, I suggest marking those comments as resolved.\n\nEDIT: I mean all comments before the first message you posted after I dropped in here\u2026\n@johnzhou721 #3569 is merged now, so the font machinery should be in a more stable state, in case you'd still like to work on this (and/or #3566) and have time amidst your other projects.\nAs I've indicated, I've got plenty of more stuff to do, so no for now, leaving this open for anyone else who wants to work on this. \n\n", "all_hints_text": "I agree that this is an edge case. However, I can imagine we might be able to make a differentiation between `serif` and `\"serif\"` by making the `SERIF` symbol something other than a string.\nTrue, but that would break the current (and consistent) behavior that anywhere in Toga you would use one of the constants, you can just use the string instead...\nI'm not necessarily against the idea, but I think we should consider it carefully. It would break what's been a consistent design convention \u2014 and if we're going to amend it here, it would make sense to do an audit, looking at CSS compatibility, and decide if any other constants should be changed over as well, up to and including all of them. We'd also need to update Pack's documentation, and provide some variety of shim.\n\nWe'd also have to decide *what* to change them to \u2014 integers are usually an obvious choice for such things, but for our purposes that could collide with *actual* integers for many properties.\n> I'm not necessarily against the idea, but I think we should consider it carefully. \n\nI'm not necessarily *for* it either :-) I mentioned it because it seemed like the obvious solution... but as with many obvious solutions, there are consequences :-)\n\nThat said, if I'm understanding correctly, there are two failure modes here:\n* A user that actually has a font named \"serif\"; and\n* A user that has used `Pack(font_family=\"serif\")`. \n\nThe former seems like an edge case that won't exist in practice... are there any type designers who are that pathological? \ud83e\udd23 \n\nThe latter is definitely a concern, though. Is it a manageable backwards compatibility? Maybe.\n\n> We'd also have to decide _what_ to change them to \u2014 integers are usually an obvious choice for such things, but for our purposes that could collide with _actual_ integers for many properties.\n\nMy go-to for symbolic objects is usually just that - `object()`. It has identity, can't be typed accidentally, and isn't ambiguous with primitive types.\n> That said, if I'm understanding correctly, there are two failure modes here:\n>  * A user that actually has a font named \"serif\"; and\n>  * A user that has used `Pack(font_family=\"serif\")`.\n\nI'm not sure I understand what you mean by two failure modes. Those two steps (assuming the first one includes registering it with that name) reproduce the one failure mode: a user registers a font named \"serif\" (or another built-in name), then tries to apply it to a font.\n\n> The former seems like an edge case that won't exist in practice... are there any type designers who are that pathological? \ud83e\udd23\n\nI mean, probably not. Which is why I think it would be perfectly reasonable if we we don't accommodate it. Currently we fall back to *system*, which doesn't seem right. But I think rendering the (original) serif font while issuing a warning about the naming collision would be sufficient.\n\n> My go-to for symbolic objects is usually just that - `object()`. It has identity, can't be typed accidentally, and isn't ambiguous with primitive types.\n\nThat would certainly make sense, assuming we decide to accommodate the sufficiently pathological.\n\nIt would still be very strange, however, if all the other constants stayed strings, and only these became anonymous objects.\n> > That said, if I'm understanding correctly, there are two failure modes here:\n> > \n> > * A user that actually has a font named \"serif\"; and\n> > * A user that has used `Pack(font_family=\"serif\")`.\n> \n> I'm not sure I understand what you mean by two failure modes. Those two steps (assuming the first one includes registering it with that name) reproduce the one failure mode: a user registers a font named \"serif\" (or another built-in name), then tries to apply it to a font.\n\nSorry - in the second case, I was referring to a user right now who is using a literal string to refer to the \"symbolic\" serif (i.e., `serif` not `\"serif\"` in CSS).\n \n> But I think rendering the (original) serif font while issuing a warning about the naming collision would be sufficient.\n\nYeah - an error at time of registration sounds more than fair.\n \n> > My go-to for symbolic objects is usually just that - `object()`. It has identity, can't be typed accidentally, and isn't ambiguous with primitive types.\n> \n> That would certainly make sense, assuming we decide to accommodate the sufficiently pathological.\n> \n> It would still be very strange, however, if all the other constants stayed strings, and only these became anonymous objects.\n\nThis is true. I don't know that I have a good answer for that, other than documenting \"fonts are different because `serif` vs `\"serif\"` etc\".\n> > I'm not sure I understand what you mean by two failure modes. Those two steps (assuming the first one includes registering it with that name) reproduce the one failure mode: a user registers a font named \"serif\" (or another built-in name), then tries to apply it to a font.\n> \n> Sorry - in the second case, I was referring to a user right now who is using a literal string to refer to the \"symbolic\" serif (i.e., `serif` not `\"serif\"` in CSS).\n\nAh, I see, you mean currently working code would fail if we were to switch the constants away from strings? We could always do a shim for that \u2014 if `\"serif\"` is requested, and nothing's registered in that name, honor the previous behavior \u2014 at least for some period of time.\n\nThat said...\n\n> Yeah - an error at time of registration sounds more than fair.\n\nI'm thinking this is the way to go, at least for the time being. We can always revisit this at a later date if need be.\n> That said...\n> \n> > Yeah - an error at time of registration sounds more than fair.\n> \n> I'm thinking this is the way to go, at least for the time being. We can always revisit this at a later date if need be.\n\nSo... since I have some time to grab this issue... is this the final decision for what to do?\n> So... since I have some time to grab this issue... is this the final decision for what to do?\n\nI'd say so, yes. However, I have #3569 in flight, which is already altering quite a bit in the font backends, and may do significantly more by the time it's finished. For that matter, I might even end up fixing this as part of it. So, probably not the best issue to try and tackle at the moment, I'm afraid.\n> > So... since I have some time to grab this issue... is this the final decision for what to do?\n> \n> I'd say so, yes. However, I have [#3569](https://github.com/beeware/toga/pull/3569) in flight, which is already altering quite a bit in the font backends, and may do significantly more by the time it's finished. For that matter, I might even end up fixing this as part of it. So, probably not the best issue to try and tackle at the moment, I'm afraid.\n\nNo worries. My plan is that I will ``{{% if pr3569.fixes(3567) %}} celebrate{{% else %}} make an error when registering with standard names{{% endif %}}``.\n\n**EDIT** explanation: I've been messing with Jinja a lot lately such that this was my first instinct to write.\n```jinja\n{% if discourse.becomes(Format.JINJA) %}\n    {% do assert could_go_wrong is None %}\n{% endif %}\n```\nGood and got me laughing. To save some spaces {{- like_this -}}, I suggest marking those comments as resolved.\n\nEDIT: I mean all comments before the first message you posted after I dropped in here\u2026\n@johnzhou721 #3569 is merged now, so the font machinery should be in a more stable state, in case you'd still like to work on this (and/or #3566) and have time amidst your other projects.\nAs I've indicated, I've got plenty of more stuff to do, so no for now, leaving this open for anyone else who wants to work on this. \n\n", "commit_urls": ["https://github.com/beeware/toga/commit/a7dc25d2f1de40b7bbea1d2a3448af9466fb827b", "https://github.com/beeware/toga/commit/cddc7414ca2907c5110bf6e7114b2e83aab8a0ef", "https://github.com/beeware/toga/commit/2f305e68f7a09211df5f501975f2b3b9c9b5dcd9", "https://github.com/beeware/toga/commit/6be3624d267a7e6953af6d1c2a9dd4bf95d7a592", "https://github.com/beeware/toga/commit/02f122d1e7cbce6124d13becbc5d4fc53d9e9ebf", "https://github.com/beeware/toga/commit/f993d926bd1a948a998e4a083be851583e7a15da", "https://github.com/beeware/toga/commit/0b204a4f7c9cdbcf6659ebe2cc8619f233fd5e40", "https://github.com/beeware/toga/commit/97a3601ecdf104311497960cb4c4d726354ea827", "https://github.com/beeware/toga/commit/f06c70842088c5b92a3bca0db91c9d093c29a4c9", "https://github.com/beeware/toga/commit/4b3ceacaf29ef2bbad7340f7cdb72e9056530b23", "https://github.com/beeware/toga/commit/1df9b6ce0f947212a69a3ed8e74008061894e2f8", "https://github.com/beeware/toga/commit/ad0d76e462e92b44fa01bd6c635fb3dc0678bae7", "https://github.com/beeware/toga/commit/1837c0769440090c5bd20a9f6db17da2417ce664"], "created_at": "2025-09-26T19:55:58Z"}
{"repo": "beeware/toga", "pull_number": 3945, "instance_id": "beeware__toga-3945", "issue_numbers": [3568], "base_commit": "ef8305c4b35032f958a14298471ab4a604f0c038", "patch": "diff --git a/changes/3568.doc.md b/changes/3568.doc.md\nnew file mode 100644\nindex 0000000000..dc8b32d0bd\n--- /dev/null\n+++ b/changes/3568.doc.md\n@@ -0,0 +1,1 @@\n+Documentation has been added for colors.\ndiff --git a/changes/3945.misc.md b/changes/3945.misc.md\nnew file mode 100644\nindex 0000000000..eaa4830e57\n--- /dev/null\n+++ b/changes/3945.misc.md\n@@ -0,0 +1,1 @@\n+Some incomplete type hints for colors in the Canvas API have been fixed.\ndiff --git a/core/src/toga/colors.py b/core/src/toga/colors.py\nindex 18f3611c8b..87316a03bd 100644\n--- a/core/src/toga/colors.py\n+++ b/core/src/toga/colors.py\n@@ -1,2 +1,52 @@\n-# Use the Travertino color definitions as-is\n-from travertino.colors import *  # noqa: F401, F403\n+from typing import TYPE_CHECKING\n+\n+# Color, rgb, and hsl need to be explicitly imported in order for mkdocstrings to see\n+# them. However, we also want to import all 148 named colors, and it seems silly to\n+# list them here individually.\n+from travertino.colors import *  # noqa: F401, F403, I001\n+from travertino.colors import Color, hsl, rgb  # noqa: F401, I001\n+\n+if TYPE_CHECKING:\n+    from typing import TypeAlias\n+\n+    ColorT: TypeAlias = Color | str\n+    \"\"\"\n+    Toga's color APIs accept:\n+\n+    - An instance of Toga's [`rgb`][toga.colors.rgb] or [`hsl`][toga.colors.hsl] class.\n+    - The name of a [CSS named color](https://developer.mozilla.org/en-US/docs/Web/CSS/Reference/Values/named-color).\n+      Strings of all available color names are available as constants. These constants\n+      are named the same as their value, except in all caps, as is the convention for\n+      Python constants. In other words, `toga.colors.ORANGE == \"orange\"`.\n+    - A string representing the color as [hexadecimal RGB or RGBA](https://developer.mozilla.org/en-US/docs/Web/CSS/Reference/Values/hex-color).\n+\n+    The following color definitions would all be equivalent:\n+\n+    ```python\n+    import toga\n+    from toga.colors import hsl, rgb, REBECCAPURPLE\n+\n+    toga.Box(color=rgb(102, 51, 153))\n+    toga.Box(color=hsl(270, 0.5, 0.4))\n+    toga.Box(color=\"rebeccapurple\")\n+    toga.Box(color=REBECCAPURPLE)\n+    toga.Box(color=\"#639\")\n+    toga.Box(color=\"#663399\")\n+    ```\n+\n+    None of these specify alpha (transparency), so the color defaults to fully opaque.\n+    [`rgb`][toga.colors.rgb], [`hsl`][toga.colors.hsl], and the hex string format allow\n+    alpha to be specified as well. Thus, the following, which explicitly set the alpha\n+    to opaque, are *also* equivalent:\n+\n+    ```python\n+    toga.Box(color=rgb(102, 51, 153, 1.0))\n+    toga.Box(color=hsl(270, 0.5, 0.4, 1.0))\n+    toga.Box(color=\"#639\")\n+    toga.Box(color=\"#663399FF\")\n+    ```\n+\n+    As is the case in CSS, `rgba` and `hsla` are available as aliases for `rgb` and\n+    `hsl`, respectively. `rgb` and `hsl` are the preferred forms, but either will work\n+    identically.\n+    \"\"\"\ndiff --git a/core/src/toga/widgets/canvas/canvas.py b/core/src/toga/widgets/canvas/canvas.py\nindex 23111efef1..8c283217ab 100644\n--- a/core/src/toga/widgets/canvas/canvas.py\n+++ b/core/src/toga/widgets/canvas/canvas.py\n@@ -9,7 +9,7 @@\n )\n \n import toga\n-from toga.colors import BLACK, Color\n+from toga.colors import BLACK\n from toga.constants import FillRule\n from toga.fonts import (\n     SYSTEM,\n@@ -22,6 +22,7 @@\n from .context import ClosedPathContext, Context, FillContext, StrokeContext\n \n if TYPE_CHECKING:\n+    from toga.colors import ColorT\n     from toga.images import ImageT\n \n \n@@ -159,7 +160,7 @@ def Fill(\n         self,\n         x: float | None = None,\n         y: float | None = None,\n-        color: Color | str | None = BLACK,\n+        color: ColorT | None = BLACK,\n         fill_rule: FillRule = FillRule.NONZERO,\n     ) -> ContextManager[FillContext]:\n         \"\"\"Construct and yield a new [`FillContext`][toga.widgets.canvas.FillContext]\n@@ -185,7 +186,7 @@ def Stroke(\n         self,\n         x: float | None = None,\n         y: float | None = None,\n-        color: Color | str | None = BLACK,\n+        color: ColorT | None = BLACK,\n         line_width: float = 2.0,\n         line_dash: list[float] | None = None,\n     ) -> ContextManager[StrokeContext]:\ndiff --git a/core/src/toga/widgets/canvas/context.py b/core/src/toga/widgets/canvas/context.py\nindex e9c61eef3b..fb5ef720be 100644\n--- a/core/src/toga/widgets/canvas/context.py\n+++ b/core/src/toga/widgets/canvas/context.py\n@@ -31,6 +31,8 @@\n )\n \n if TYPE_CHECKING:\n+    from toga.colors import ColorT\n+\n     from .canvas import Canvas\n \n \n@@ -313,7 +315,7 @@ def rect(self, x: float, y: float, width: float, height: float) -> Rect:\n \n     def fill(\n         self,\n-        color: str = BLACK,\n+        color: ColorT = BLACK,\n         fill_rule: FillRule = FillRule.NONZERO,\n     ) -> Fill:\n         \"\"\"Fill the current path.\n@@ -335,7 +337,7 @@ def fill(\n \n     def stroke(\n         self,\n-        color: str = BLACK,\n+        color: ColorT = BLACK,\n         line_width: float = 2.0,\n         line_dash: list[float] | None = None,\n     ) -> Stroke:\n@@ -479,7 +481,7 @@ def Fill(\n         self,\n         x: float | None = None,\n         y: float | None = None,\n-        color: str = BLACK,\n+        color: ColorT = BLACK,\n         fill_rule: FillRule = FillRule.NONZERO,\n     ) -> Iterator[FillContext]:\n         \"\"\"Construct and yield a new `Fill` sub-context\n@@ -519,7 +521,7 @@ def Stroke(\n         self,\n         x: float | None = None,\n         y: float | None = None,\n-        color: str = BLACK,\n+        color: ColorT = BLACK,\n         line_width: float = 2.0,\n         line_dash: list[float] | None = None,\n     ) -> Iterator[StrokeContext]:\n@@ -633,7 +635,7 @@ def __init__(\n         canvas: toga.Canvas,\n         x: float | None = None,\n         y: float | None = None,\n-        color: str = BLACK,\n+        color: ColorT = BLACK,\n         fill_rule: FillRule = FillRule.NONZERO,\n     ):\n         super().__init__(canvas=canvas, x=x, y=y)\n@@ -673,7 +675,7 @@ def color(self) -> Color:\n         return self._color\n \n     @color.setter\n-    def color(self, value: Color | str | None) -> None:\n+    def color(self, value: ColorT | None) -> None:\n         if value is None:\n             self._color = Color.parse(BLACK)\n         else:\n@@ -704,7 +706,7 @@ def __init__(\n         canvas: toga.Canvas,\n         x: float | None = None,\n         y: float | None = None,\n-        color: str | None = BLACK,\n+        color: ColorT | None = BLACK,\n         line_width: float = 2.0,\n         line_dash: list[float] | None = None,\n     ):\ndiff --git a/core/src/toga/widgets/canvas/drawingobject.py b/core/src/toga/widgets/canvas/drawingobject.py\nindex b14c754aa0..e3d6c0c9aa 100644\n--- a/core/src/toga/widgets/canvas/drawingobject.py\n+++ b/core/src/toga/widgets/canvas/drawingobject.py\n@@ -2,7 +2,7 @@\n \n from abc import ABC, abstractmethod\n from math import pi\n-from typing import Any\n+from typing import TYPE_CHECKING, Any\n from warnings import filterwarnings, warn\n \n from toga.colors import BLACK, Color\n@@ -13,6 +13,9 @@\n     Font,\n )\n \n+if TYPE_CHECKING:\n+    from toga.colors import ColorT\n+\n # Make sure deprecation warnings are shown by default\n filterwarnings(\"default\", category=DeprecationWarning)\n \n@@ -100,7 +103,7 @@ def _draw(self, impl: Any, **kwargs: Any) -> None:\n class Fill(DrawingObject):\n     def __init__(\n         self,\n-        color: str = BLACK,\n+        color: ColorT = BLACK,\n         fill_rule: FillRule = FillRule.NONZERO,\n     ):\n         super().__init__()\n@@ -129,7 +132,7 @@ def color(self) -> Color:\n         return self._color\n \n     @color.setter\n-    def color(self, value: Color | str | None) -> None:\n+    def color(self, value: ColorT | None) -> None:\n         if value is None:\n             self._color = Color.parse(BLACK)\n         else:\n@@ -139,7 +142,7 @@ def color(self, value: Color | str | None) -> None:\n class Stroke(DrawingObject):\n     def __init__(\n         self,\n-        color: Color | str | None = BLACK,\n+        color: ColorT | None = BLACK,\n         line_width: float = 2.0,\n         line_dash: list[float] | None = None,\n     ):\n@@ -162,7 +165,7 @@ def color(self) -> Color:\n         return self._color\n \n     @color.setter\n-    def color(self, value: Color | str | None) -> None:\n+    def color(self, value: ColorT | None) -> None:\n         if value is None:\n             self._color = Color.parse(BLACK)\n         else:\ndiff --git a/docs/config.yml b/docs/config.yml\nindex add02477ed..eb66d5c4cb 100644\n--- a/docs/config.yml\n+++ b/docs/config.yml\n@@ -104,6 +104,9 @@ plugins:\n             - https://docs.python.org/3/objects.inv\n             - https://pillow.readthedocs.io/en/stable/objects.inv\n           options:\n+            preload_modules:\n+              - travertino\n+              - toga\n             docstring_style: sphinx  # Parses docstrings from Sphinx formatting - the `:param` formatting, not parsing rST links\n             allow_inspection: false  # True includes *more* dunder methods, can be enabled on individual class entries if you want them\n             show_source: false  # Otherwise, source code is shown collapsed for all\ndiff --git a/docs/en/reference/api/resources/color.md b/docs/en/reference/api/resources/color.md\nnew file mode 100644\nindex 0000000000..1db7516004\n--- /dev/null\n+++ b/docs/en/reference/api/resources/color.md\n@@ -0,0 +1,24 @@\n+{{ component_header(\"Color\") }}\n+\n+## Usage\n+\n+When specifying colors for style properties such as [color][pack-color] and [background-color][background_color], or on widget APIs that use colors explicitly (such as any `color` arguments for the [`Canvas`](/reference/api/widgets/canvas.md) API), Toga will accept values in a [range of possible formats][toga.colors.ColorT].\n+\n+## Reference\n+\n+::: toga.colors.ColorT\n+\n+::: toga.colors.Color\n+\toptions:\n+\t\tmembers: [rgb, hsl]\n+\t\tshow_signature_annotations: false\n+\n+::: toga.colors.rgb\n+\toptions:\n+\t\tmembers: [r, g, b, a]\n+\t\tinherited_members: [a]\n+\n+::: toga.colors.hsl\n+\toptions:\n+\t\tmembers: [h, s, l, a]\n+\t\tinherited_members: [a]\ndiff --git a/docs/en/reference/data/apis_by_platform.yaml b/docs/en/reference/data/apis_by_platform.yaml\nindex 51c705dead..e530398c3c 100644\n--- a/docs/en/reference/data/apis_by_platform.yaml\n+++ b/docs/en/reference/data/apis_by_platform.yaml\n@@ -241,14 +241,17 @@ Resources:\n       - web\n \n   Command:\n-    description: A representation of app functionality that the user can invoke from\n-      menus or toolbars.\n+    description: A representation of app functionality that the user can invoke from menus or toolbars.\n     display: table\n     unsupported:\n       - iOS\n       - web\n       - textual\n \n+  Color:\n+    description: A representation of a color.\n+    display: hide\n+\n   Dialogs:\n     description: Short-lived windows asking the user for input.\n     display: table\ndiff --git a/docs/en/reference/style/pack.md b/docs/en/reference/style/pack.md\nindex 0dfacf26a6..6bd8c94893 100644\n--- a/docs/en/reference/style/pack.md\n+++ b/docs/en/reference/style/pack.md\n@@ -132,9 +132,9 @@ If 3 integers are provided, the first value will be used as the top margin, the\n \n If 4 integers are provided, they will be used as the top, right, bottom and left margin, respectively.\n \n-### `color`\n+### `color` { #pack-color }\n \n-**Value:** a color or `None`\n+**Value:** a [color][toga.colors.ColorT] or `None`\n \n **Initial value:** `None`; will use the system default\n \n@@ -144,7 +144,7 @@ Some objects may not use the value.\n \n ### `background_color`\n \n-**Value:** a color, `\"transparent\"`, or `None`\n+**Value:** a [color][toga.colors.ColorT], `\"transparent\"`, or `None`\n \n **Initial value:** `None`; will use the system default\n \ndiff --git a/docs/spelling_wordlist b/docs/spelling_wordlist\nindex bb0590f4d9..6165a1e8e9 100644\n--- a/docs/spelling_wordlist\n+++ b/docs/spelling_wordlist\n@@ -150,6 +150,7 @@ RemoteCommand\n Ren\n resizable\n reStructuredText\n+RGB\n RGBA\n rumdl\n runtime\ndiff --git a/tox.ini b/tox.ini\nindex f78f6bc0e2..16bf7d56a6 100644\n--- a/tox.ini\n+++ b/tox.ini\n@@ -104,9 +104,9 @@ deps =\n     ./travertino\n     ./core\n commands =\n-    !lint-!all-!live-!en : build_md_translations {posargs} en --source-code=core{/}src --source-code=android{/}src\n+    !lint-!all-!live-!en : build_md_translations {posargs} en --source-code=core{/}src --source-code=travertino{/}src --source-code=android{/}src\n     lint : markdown-checker --dir {[docs]docs_dir} --func check_broken_urls\n     lint : pyspelling\n-    live : live_serve_en {posargs} core{/}src --source-code=core{/}src --source-code=android{/}src\n-    all : build_md_translations {posargs} en --source-code=core{/}src --source-code=android{/}src\n-    en : build_md_translations {posargs} en --source-code=core{/}src --source-code=android{/}src\n+    live : live_serve_en {posargs} core{/}src --source-code=core{/}src --source-code=travertino{/}src --source-code=android{/}src\n+    all : build_md_translations {posargs} en --source-code=core{/}src --source-code=travertino{/}src --source-code=android{/}src\n+    en : build_md_translations {posargs} en --source-code=core{/}src --source-code=travertino{/}src --source-code=android{/}src\ndiff --git a/travertino/src/travertino/colors.py b/travertino/src/travertino/colors.py\nindex 3ba08ad0c4..85a1516a51 100644\n--- a/travertino/src/travertino/colors.py\n+++ b/travertino/src/travertino/colors.py\n@@ -14,7 +14,10 @@ def _clamp(value, lower, upper):\n \n \n class Color:\n-    \"\"\"A base class for all colorspace representations.\"\"\"\n+    \"\"\"A base class for all colorspace representations.\n+\n+    Not meant to be used directly.\n+    \"\"\"\n \n     @staticmethod\n     def parse(value: Color | str) -> Color:\n@@ -79,12 +82,29 @@ def _validate_zero_to_one(name, value):\n \n     @property\n     def a(self) -> float:\n+        \"\"\"The color's alpha, or transparency, as a float from 0 to 1.\"\"\"\n         return self._a\n \n+    @property\n+    def rgb(self) -> rgb:  # pragma: no cover\n+        \"\"\"This color in RGB format. If it's already RGB, returns the object itself.\n+\n+        Also accessible via the alias `rgba`.\n+        \"\"\"\n+        raise NotImplementedError\n+\n     @property\n     def rgba(self) -> rgb:\n         return self.rgb\n \n+    @property\n+    def hsl(self) -> hsl:  # pragma: no cover\n+        \"\"\"This color in HSL format. If it's already HSL, returns the object itself.\n+\n+        Also accessible via the alias `rgba`.\n+        \"\"\"\n+        raise NotImplementedError\n+\n     @property\n     def hsla(self) -> hsl:\n         return self.hsl\n@@ -183,9 +203,20 @@ def unblend_over(self, back_color: Color, front_color_alpha: float) -> rgb:\n \n \n class rgb(Color):\n-    \"\"\"A representation of an RGB(A) color.\"\"\"\n-\n-    def __init__(self, r, g, b, a=1.0):\n+    def __init__(self, r: int, g: int, b: int, a: float = 1.0):\n+        \"\"\"A color specified via red, green, and blue channels, plus transparency.\n+\n+        Also accessible via the alias `rgba`.\n+\n+        :param r: The color's red value, as an integer from 0 to 255. Higher or lower\n+            values will be clipped.\n+        :param g: The color's green value, as an integer from 0 to 255. Higher or lower\n+            values will be clipped.\n+        :param b: The color's blue value, as an integer from 0 to 255. Higher or lower\n+            values will be clipped.\n+        :param a: The color's alpha, or transparency, as a float from 0 to 1. Higher or\n+            lower values will be clipped. Defaults to fully opaque.\n+        \"\"\"\n         self._r = self._validate_band(\"red\", r)\n         self._g = self._validate_band(\"green\", g)\n         self._b = self._validate_band(\"blue\", b)\n@@ -211,14 +242,17 @@ def _validate_band(name, value):\n \n     @property\n     def r(self) -> int:\n+        \"\"\"The color's red value, as an integer from 0 to 255.\"\"\"\n         return self._r\n \n     @property\n     def g(self) -> int:\n+        \"\"\"The color's green value, as an integer from 0 to 255.\"\"\"\n         return self._g\n \n     @property\n     def b(self) -> int:\n+        \"\"\"The color's blue value, as an integer from 0 to 255.\"\"\"\n         return self._b\n \n     @property\n@@ -265,9 +299,20 @@ def hsl(self) -> hsl:\n \n \n class hsl(Color):\n-    \"\"\"A representation of an HSL(A) color.\"\"\"\n-\n-    def __init__(self, h, s, l, a=1.0):  # noqa: E741\n+    def __init__(self, h: int, s: float, l: float, a: float = 1.0):  # noqa: E741\n+        \"\"\"A color specified via hue, saturation, and lightness, plus transparency.\n+\n+        Also accessible via the alias `hsla`.\n+\n+        :param h: The color's hue, as an integer from 0 to 360. Higher or lower values\n+            will wrap around.\n+        :param s: The color's saturation, as a float from 0 to 1. Higher or lower values\n+            will be clipped.\n+        :param l: The color's lightness, as a float from 0 to 1. Higher or lower values\n+            will be clipped.\n+        :param a: The color's alpha, or transparency, as a float from 0 to 1. Higher or\n+            lower values will be clipped. Defaults to fully opaque.\n+        \"\"\"\n         try:\n             self._h = round(h) % 360\n         except TypeError as exc:\n@@ -287,14 +332,17 @@ def __str__(self):\n \n     @property\n     def h(self) -> int:\n+        \"\"\"The color's hue, as an integer from 0 to 360.\"\"\"\n         return self._h\n \n     @property\n     def s(self) -> float:\n+        \"\"\"The color's saturation, as a float from 0 to 1.\"\"\"\n         return self._s\n \n     @property\n     def l(self) -> float:  # noqa: E743\n+        \"\"\"The color's lightness, as a float from 0 to 1.\"\"\"\n         return self._l\n \n     @property\n", "test_patch": "", "problem_statement": "Document colors\n### What is the problem or limitation you are having?\n\nToga's docs *mention* colors in the context of Pack and Canvas, but offer no explanation of what formats are available.\n\n### Describe the solution you'd like\n\nI think a page on Color would make a good addition to the Style category (and Pack can finally stop being lonely). It should go over:\n\n- All the predefined colors (ideally with a swatch for each), and explain using string literals or the constants\n- The various string formats that can be parsed:\n    * '#rgb'\n    * '#rgba'\n    * '#rrggbb'\n    * '#rrggbbaa'\n    * '#RGB'\n    * '#RGBA'\n    * '#RRGGBB'\n    * '#RRGGBBAA'\n    * ~~'rgb(0, 0, 0)'~~\n    * ~~'rgba(0, 0, 0, 0.0)'~~\n    * ~~'hsl(0, 0%, 0%)'~~\n    * ~~'hsla(0, 0%, 0%, 0.0)'~~\n - Instances of the actual color classes, just for completeness's sake\n \nI'm realizing that I don't even know, myself, whether (and where) transparent colors work, i.e. if you give a widget a transparent color, will it respect the alpha value and composite its text over its background. This would be a good thing to describe as well.\n\n### Describe alternatives you've considered\n\nIt could also go in Resources... but each of those is a well-defined class in Toga itself that users are likely to use directly, whereas this would be more a general coverage of \"what can you supply to a parameter that expects a color\".\n\n### Additional context\n\n_No response_\n", "hints_text": "+1. Sounds like an ideal topic guide (for how to specify colors) and/or reference guide (for the color swatches and definition of allowed formats). \n\nAs for transparent colors - On most platforms, transparency will work. Will a transparent color work as a background/foreground color on a widget?... maybe, depends on the widget and the platform. It definitely works on the background for a Box, which will be the major use case (I hope...), and we've recently added a bunch of code to implement transparent blending on the one platform that doesn't do blending out of the box (Winforms).\nProbably worth waiting till after (or handling as part of) #3611.\n\n", "all_hints_text": "+1. Sounds like an ideal topic guide (for how to specify colors) and/or reference guide (for the color swatches and definition of allowed formats). \n\nAs for transparent colors - On most platforms, transparency will work. Will a transparent color work as a background/foreground color on a widget?... maybe, depends on the widget and the platform. It definitely works on the background for a Box, which will be the major use case (I hope...), and we've recently added a bunch of code to implement transparent blending on the one platform that doesn't do blending out of the box (Winforms).\nProbably worth waiting till after (or handling as part of) #3611.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/ab4544431a080e109d7862a0b413b54a9d68883c", "https://github.com/beeware/toga/commit/6e3e2d38ff4f9f3a4f8d75f9f7e102547dbedb2f", "https://github.com/beeware/toga/commit/cd32788dfb6e31e84003cf8187088692a45a5b38", "https://github.com/beeware/toga/commit/c876a9e8aae966e7f7f170b27bde366443d4a010", "https://github.com/beeware/toga/commit/c7222715a78805cdfcfe897b9056d297a7f091e4", "https://github.com/beeware/toga/commit/254430f408258cc9444a35ac2bd4f84ee9a4c985", "https://github.com/beeware/toga/commit/5602dc7af2273a206f24947e72047bbbff729e60", "https://github.com/beeware/toga/commit/65b6edce1abd369131963474616b63ab1ec8bdf9", "https://github.com/beeware/toga/commit/d481936b977a4a06c3365d6e111d47afe48a8d64", "https://github.com/beeware/toga/commit/fe1e18d345b5a2867626e50c81af20457fcf411a", "https://github.com/beeware/toga/commit/b2442457a28af2734d188edade4d7f1ebd74f1c5", "https://github.com/beeware/toga/commit/ca32eb4366495aecc0549fa889a742def09e740b", "https://github.com/beeware/toga/commit/8561bc43f721362587cd723662286a2c5d301e4d", "https://github.com/beeware/toga/commit/f252f61d43a179479e21785e2f7cc5c6814aa581", "https://github.com/beeware/toga/commit/6e0cd51e8ca08db64916385a4bc79bb18c50e585"], "created_at": "2025-12-05T15:59:25Z"}
{"repo": "beeware/toga", "pull_number": 3581, "instance_id": "beeware__toga-3581", "issue_numbers": [3580], "base_commit": "22000bb10e5f24ea8909e80e246cd40fb87fbad9", "patch": "diff --git a/changes/3580.bugfix.rst b/changes/3580.bugfix.rst\nnew file mode 100644\nindex 0000000000..1b0317c5bf\n--- /dev/null\n+++ b/changes/3580.bugfix.rst\n@@ -0,0 +1,1 @@\n+The minimum width hint of the iOS ``DateInput`` and ``TimeInput`` widgets will now fit to the actual displayed size of the picker.\ndiff --git a/iOS/src/toga_iOS/widgets/dateinput.py b/iOS/src/toga_iOS/widgets/dateinput.py\nindex def6c827bb..b7c41b1681 100644\n--- a/iOS/src/toga_iOS/widgets/dateinput.py\n+++ b/iOS/src/toga_iOS/widgets/dateinput.py\n@@ -1,4 +1,5 @@\n import datetime\n+from math import ceil\n \n from rubicon.objc import SEL, CGSize, objc_method, objc_property\n from travertino.size import at_least\n@@ -24,6 +25,13 @@ class TogaDatePicker(UIDatePicker):\n     @objc_method\n     def dateInputDidChange_(self, dateInput) -> None:\n         self.interface.on_change()\n+        # The width of the widget is dependent on the date being displayed. If the value\n+        # changes, we also need to force the iOS widget to lay itself out again to\n+        # ensure minimum size hints are accurate, and then trigger a Toga refresh to\n+        # apply the new hints.\n+        self.setNeedsLayout()\n+        self.layoutIfNeeded()\n+        self.interface.refresh()\n \n \n def py_date(native_date):\n@@ -77,11 +85,11 @@ def get_value(self):\n \n     def set_value(self, value):\n         self.native.date = native_date(value)\n-        self.interface.on_change()\n+        self.native.sendActionsForControlEvents(UIControlEventValueChanged)\n \n     def rehint(self):\n         fitting_size = self.native.systemLayoutSizeFittingSize(CGSize(0, 0))\n-        self.interface.intrinsic.width = at_least(self.interface._MIN_WIDTH)\n+        self.interface.intrinsic.width = at_least(ceil(fitting_size.width))\n         self.interface.intrinsic.height = fitting_size.height\n \n     def get_min_date(self):\ndiff --git a/iOS/src/toga_iOS/widgets/timeinput.py b/iOS/src/toga_iOS/widgets/timeinput.py\nindex 8616ca44ad..f7666933f1 100644\n--- a/iOS/src/toga_iOS/widgets/timeinput.py\n+++ b/iOS/src/toga_iOS/widgets/timeinput.py\n@@ -1,4 +1,5 @@\n import datetime\n+from math import ceil\n \n from rubicon.objc import SEL, CGSize\n from travertino.size import at_least\n@@ -67,11 +68,11 @@ def get_value(self):\n \n     def set_value(self, value):\n         self.native.date = native_time(value.replace(second=0, microsecond=0))\n-        self.interface.on_change()\n+        self.native.sendActionsForControlEvents(UIControlEventValueChanged)\n \n     def rehint(self):\n         fitting_size = self.native.systemLayoutSizeFittingSize(CGSize(0, 0))\n-        self.interface.intrinsic.width = at_least(self.interface._MIN_WIDTH)\n+        self.interface.intrinsic.width = at_least(ceil(fitting_size.width))\n         self.interface.intrinsic.height = fitting_size.height\n \n     def get_min_time(self):\n", "test_patch": "", "problem_statement": "Allow iOS DateInput and TimeInput widgets to fit snugly\n### Describe the bug\n\nhttps://imgur.com/a/56zxBxA\n\nSo the iOS DateInput width is a bit dynamic... and it clearly is not fitting on the right side.  We can change the imposed minimum width through rehint on the iOS backend, but I feel like we should allow the other items on the right to be able to go left and go right with the widget. Would this be a good idea?\n\n### Steps to reproduce\n\nStack a DateInput and label horizontally in a box.\n\n### Expected behavior\n\nEither:\n- A reasonable minimum width for iOS _or_\n- auto-fit to the system width.  We can see that the actual displayed width on iOS is not what Toga think it is. I mean the layout algorithm says its width should be at least 200 but we see that iOS is not filling up all that space in the specified width.\n\n### Screenshots\n\nhttps://imgur.com/a/56zxBxA\n\n\n### Environment\n\nPython 3.13, briefcase latest through pip, toga latest dev.\n\n### Logs\n\n```\nRunning app module: helloworld\n---------------------------------------------------------------------------\nWARNING: Can't find app icon; falling back to default icon\nApp finished launching.\n<string>:30: DeprecationWarning: Pack.padding is deprecated. Use Pack.margin instead.\nApp became active.\n```\n\n\n### Additional context\n\n_No response_\n", "hints_text": "For iOS the visual size actually wiggles but if you do any larger size it doesn't extend the picker. So careful handling is needed here.\n\nHaving said that: Does Toga relayout whenever you change the intrinsic size? If not how can you trigger one? Because it's probably desirable to make the size flexible and retrigger layout anytime you have a new date selected -- it shrinks and extends (by default to the right, in Toga to the left) as you pick different dates.\n> For iOS the visual size actually wiggles but if you do any larger size it doesn't extend the picker. So careful handling is needed here.\n\nAs noted on #3574, the issue here is likely that the enforced MIN_SIZE likely isn't required at all. If the platform already enforces an appropriate minimum size (i.e., default behavior is that the minimum size for widget display allows the full display of the widget), then Toga should be using that intrinsic size. MIN_SIZE is only required when the default behaviour of the widget allows the widget to be resized to 0 (or a similar impractical-in-practice size).\n\n> Having said that: Does Toga relayout whenever you change the intrinsic size? If not how can you trigger one? Because it's probably desirable to make the size flexible and retrigger layout anytime you have a new date selected -- it shrinks and extends (by default to the right, in Toga to the left) as you pick different dates.\n\nYou've got the ordering the wrong way around. Toga determines the intrinsic size *when* a layout is triggered. If something changes in the properties of the widget (e.g., a font size changes, which might change the minimum size of the widget), the widget impl should call `self.refresh()`, which will trigger a re-layout, causing a re-evaluation of the intrinsic size.\n> > Having said that: Does Toga relayout whenever you change the intrinsic size? If not how can you trigger one? Because it's probably desirable to make the size flexible and retrigger layout anytime you have a new date selected -- it shrinks and extends (by default to the right, in Toga to the left) as you pick different dates.\n> \n> You've got the ordering the wrong way around. Toga determines the intrinsic size _when_ a layout is triggered. If something changes in the properties of the widget (e.g., a font size changes, which might change the minimum size of the widget), the widget impl should call `self.refresh()`, which will trigger a re-layout, causing a re-evaluation of the intrinsic size.\n\nSorry for not learning my lesson from last time when Winforms activityindicator used refresh... working on a PR.\n\n", "all_hints_text": "For iOS the visual size actually wiggles but if you do any larger size it doesn't extend the picker. So careful handling is needed here.\n\nHaving said that: Does Toga relayout whenever you change the intrinsic size? If not how can you trigger one? Because it's probably desirable to make the size flexible and retrigger layout anytime you have a new date selected -- it shrinks and extends (by default to the right, in Toga to the left) as you pick different dates.\n> For iOS the visual size actually wiggles but if you do any larger size it doesn't extend the picker. So careful handling is needed here.\n\nAs noted on #3574, the issue here is likely that the enforced MIN_SIZE likely isn't required at all. If the platform already enforces an appropriate minimum size (i.e., default behavior is that the minimum size for widget display allows the full display of the widget), then Toga should be using that intrinsic size. MIN_SIZE is only required when the default behaviour of the widget allows the widget to be resized to 0 (or a similar impractical-in-practice size).\n\n> Having said that: Does Toga relayout whenever you change the intrinsic size? If not how can you trigger one? Because it's probably desirable to make the size flexible and retrigger layout anytime you have a new date selected -- it shrinks and extends (by default to the right, in Toga to the left) as you pick different dates.\n\nYou've got the ordering the wrong way around. Toga determines the intrinsic size *when* a layout is triggered. If something changes in the properties of the widget (e.g., a font size changes, which might change the minimum size of the widget), the widget impl should call `self.refresh()`, which will trigger a re-layout, causing a re-evaluation of the intrinsic size.\n> > Having said that: Does Toga relayout whenever you change the intrinsic size? If not how can you trigger one? Because it's probably desirable to make the size flexible and retrigger layout anytime you have a new date selected -- it shrinks and extends (by default to the right, in Toga to the left) as you pick different dates.\n> \n> You've got the ordering the wrong way around. Toga determines the intrinsic size _when_ a layout is triggered. If something changes in the properties of the widget (e.g., a font size changes, which might change the minimum size of the widget), the widget impl should call `self.refresh()`, which will trigger a re-layout, causing a re-evaluation of the intrinsic size.\n\nSorry for not learning my lesson from last time when Winforms activityindicator used refresh... working on a PR.\nSimilar to #1289?\n\n**EDIT** Sorry for short comment, but #1289 is not on iOS, so back to the drawing board.\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/1b30ee4da9d581d8628303da4b3ae0303f0bb2ce", "https://github.com/beeware/toga/commit/8f10f3531842a919545c5e7dfbabbf15e1356dfb", "https://github.com/beeware/toga/commit/379244b5554fa209d8208991512a19d3cd50e6ec", "https://github.com/beeware/toga/commit/d78ac715f15012b3ea3411f02157c497d1413dfe", "https://github.com/beeware/toga/commit/15a40827eeaebc27dc09266410e37d0a81626b0b", "https://github.com/beeware/toga/commit/bb09b248b06c687cfb2d5697c22e2af020fe1b69", "https://github.com/beeware/toga/commit/e4ed8ea31811945bc3e4bcabde26067b2bf03bfb", "https://github.com/beeware/toga/commit/83c76b4d63605531a40e99d6eb7ef24695034b11", "https://github.com/beeware/toga/commit/84971b7f56957ec51392bed933eeca2a4155f580", "https://github.com/beeware/toga/commit/4e57f3d31282f4163c7cf4c3bb18f40a3d723ada", "https://github.com/beeware/toga/commit/a2c42a3e9875686f6fc43cc86bca5cadfcba6c93", "https://github.com/beeware/toga/commit/f1bccee51e55a5356631c74485b1f35a05bff533"], "created_at": "2025-06-23T02:00:42Z"}
{"repo": "beeware/toga", "pull_number": 3640, "instance_id": "beeware__toga-3640", "issue_numbers": [3609], "base_commit": "1bf98307f5da7900607ff76ffbcb5a0ccc5edee1", "patch": "diff --git a/changes/3609.feature.rst b/changes/3609.feature.rst\nnew file mode 100644\nindex 0000000000..7714f172ff\n--- /dev/null\n+++ b/changes/3609.feature.rst\n@@ -0,0 +1,1 @@\n+``ListSource.find`` now has a ``default`` parameter which is returned when no match is found.\ndiff --git a/core/src/toga/sources/list_source.py b/core/src/toga/sources/list_source.py\nindex 767b45a43e..263bec29ba 100644\n--- a/core/src/toga/sources/list_source.py\n+++ b/core/src/toga/sources/list_source.py\n@@ -1,11 +1,12 @@\n from __future__ import annotations\n \n from collections.abc import Iterable, Mapping, Sequence\n-from typing import Generic, TypeVar\n+from typing import Any, Generic, TypeVar\n \n from .base import Source\n \n T = TypeVar(\"T\")\n+UNDEFINED = object()\n \n \n def _find_item(\n@@ -218,7 +219,9 @@ def index(self, row: Row) -> int:\n         \"\"\"\n         return self._data.index(row)\n \n-    def find(self, data: object, start: Row | None = None) -> Row:\n+    def find(\n+        self, data: object, start: Row | None = None, default: Any = UNDEFINED\n+    ) -> Row:\n         \"\"\"Find the first item in the data that matches all the provided\n         attributes.\n \n@@ -233,13 +236,21 @@ def find(self, data: object, start: Row | None = None) -> Row:\n             they won't be considered as part of the match.\n         :param start: The instance from which to start the search. Defaults to ``None``,\n             indicating that the first match should be returned.\n-        :return: The matching Row object\n-        :raises ValueError: If no match is found.\n+        :param default: If provided, this value will be returned if no match is found.\n+        :return: The matching Row object if found, or the value of ``default`` if\n+            provided.\n+        :raises ValueError: If no match is found and ``default`` is not provided.\n         \"\"\"\n-        return _find_item(\n-            candidates=self._data,\n-            data=data,\n-            accessors=self._accessors,\n-            start=start,\n-            error=f\"No row matching {data!r} in data\",\n-        )\n+        try:\n+            return _find_item(\n+                candidates=self._data,\n+                data=data,\n+                accessors=self._accessors,\n+                start=start,\n+                error=f\"No row matching {data!r} in data\",\n+            )\n+        except ValueError:\n+            if default is UNDEFINED:\n+                raise\n+            else:\n+                return default\n", "test_patch": "diff --git a/core/tests/sources/test_list_source.py b/core/tests/sources/test_list_source.py\nindex 1597b5d640..9454615942 100644\n--- a/core/tests/sources/test_list_source.py\n+++ b/core/tests/sources/test_list_source.py\n@@ -405,7 +405,7 @@ def test_find(source):\n     # A partial match is enough\n     assert source.find({\"val1\": \"third\"}) == source[2]\n \n-    # find will fail if the object doesn't exist\n+    # find will raise ValueError if no match is found and no default is provided\n     with pytest.raises(\n         ValueError,\n         match=r\"No row matching {'val1': 'not there', 'val2': 999} in data\",\n@@ -421,3 +421,16 @@ def test_find(source):\n         ),\n     ):\n         source.find({\"val1\": \"first\", \"val2\": 111, \"value\": \"overspecified\"})\n+\n+\n+def test_find_with_default(source):\n+    \"\"\"You can provide a default return value to the find method.\"\"\"\n+\n+    # Duplicate row 1 of the data.\n+    source.append({\"val1\": \"second\", \"val2\": 222})\n+\n+    # If a default is provided, it will be returned if no match is found\n+    assert source.find({\"val1\": \"not there\", \"val2\": 999}, default=-1) == -1\n+\n+    # If the given default value is None, None will be returned if no match is found\n+    assert source.find({\"val1\": \"not there\", \"val2\": 999}, default=None) is None\n", "problem_statement": "Modify ListSource.find to provide a default result when no matches found\n**NOTE** This was originally proposed as a change to `find()` so that it would return -1 rather than raising ValueError when no match was found. The \"default\" option proposed as an alternative is what has been accepted.\n\n### What is the problem or limitation you are having?\n\nCurrently, when `ListSource.find` does not find a matching `Row`, it raises a `ValueError`. This means we have to guard every `ListSource.find` call with a try/except block. This means an otherwise one-liner becomes four and the code quickly gets cluttered:\n\n### Example Code\n```python\ntry:\n\tpreset = preset_items.find({'name': preset_name})\nexcept:\n\tpreset = None\n```\n\nFurthermore, this pattern is inconsistent, for example, with `str.find`, which broad Python developers are more familiar with, that returns `-1` when no matches are found.\n\n### Describe the solution you'd like\n\nUpdate `ListSource.find` to return `None` or `-1` when no matches are found.\n\nThis allows us to shrink `Example Code` to just one line:\n```python\npreset = preset_items.find({'name': preset_name})\n```\n\n### Describe alternatives you've considered\n\nAllow us to provide a default value for when no matches are found \u2014 which would make it behave more like `getattr`:\n```python\npreset = preset_items.find({'name': preset_name}, default=None)\n```\n\n### Additional context\n\n_No response_\n", "hints_text": "In the Python standard library, there's no `find` method on lists, only on strings. The string method returns an index, whereas our method returns a value from the list. This inconsistency is unfortunate, but it's too late to change now.\n\nOf all the options mentioned, the only one that wouldn't break existing code is to add a `default` argument.\n>  This inconsistency is unfortunate, but it's too late to change now.\n\nWe should absolutely have a high bar for this sort of breaking change, but if there's a really good case to be made for a backwards incompatible change, we shouldn't rule it out. \n\nThat said - the -1 response is a side effect of C string APIs, not a strong API design case in itself. I'd argue that for Python, it's a *worse* result that `ValueError` - because `my_list[my_list.find(value)]` will *always* return a value, as long as the list has 1 or more elements - in the case of \"not found\", it will reliably return the *last* element in the list.\n \n> Of all the options mentioned, the only one that wouldn't break existing code is to add a `default` argument.\n\nThat would make sense to me as an API. I'll update the ticket to reflect this.\n\nI will (_attempt to)_ look at this (EuroPython 2025 sprint)\n\n", "all_hints_text": "In the Python standard library, there's no `find` method on lists, only on strings. The string method returns an index, whereas our method returns a value from the list. This inconsistency is unfortunate, but it's too late to change now.\n\nOf all the options mentioned, the only one that wouldn't break existing code is to add a `default` argument.\n>  This inconsistency is unfortunate, but it's too late to change now.\n\nWe should absolutely have a high bar for this sort of breaking change, but if there's a really good case to be made for a backwards incompatible change, we shouldn't rule it out. \n\nThat said - the -1 response is a side effect of C string APIs, not a strong API design case in itself. I'd argue that for Python, it's a *worse* result that `ValueError` - because `my_list[my_list.find(value)]` will *always* return a value, as long as the list has 1 or more elements - in the case of \"not found\", it will reliably return the *last* element in the list.\n \n> Of all the options mentioned, the only one that wouldn't break existing code is to add a `default` argument.\n\nThat would make sense to me as an API. I'll update the ticket to reflect this.\n\nI will (_attempt to)_ look at this (EuroPython 2025 sprint)\n\n", "commit_urls": ["https://github.com/beeware/toga/commit/03db3502d49e61fb4c9c6983c6a710bc8fd169a8", "https://github.com/beeware/toga/commit/f9c341b59b75fe78272803b26bcac7c10869f267", "https://github.com/beeware/toga/commit/e885cf77e6dc3e33dce03b77b04be371878793ba", "https://github.com/beeware/toga/commit/5afffa56e86ca9bd4e14aee961a8bbf9eb1d77f6", "https://github.com/beeware/toga/commit/1da2dca6fe71fe743b19bdfa9cfbfd801abf83b9", "https://github.com/beeware/toga/commit/526eae26463cd492f3e4868e0bc95bc93949a44d", "https://github.com/beeware/toga/commit/b8d99f252d4bc3de32db5fa301638e261589b02d"], "created_at": "2025-07-19T09:27:45Z"}
{"repo": "beeware/toga", "pull_number": 3665, "instance_id": "beeware__toga-3665", "issue_numbers": [3611], "base_commit": "b9196fcc4376c780e8dd53eac06ee19f849ca7dc", "patch": "diff --git a/changes/3611.bugfix.rst b/changes/3611.bugfix.rst\nnew file mode 100644\nindex 0000000000..03ea5d3f03\n--- /dev/null\n+++ b/changes/3611.bugfix.rst\n@@ -0,0 +1,1 @@\n+The ``rgb`` and ``hsl`` classes, in addition to their copy-pasteable-into-Python ``__repr__``, gain a ``__str__`` that uses modern CSS syntax. For ``rgb`` this is simply a nice update, but for ``hsl`` it corrects color rendering issues when using the web backend.\ndiff --git a/changes/3611.removal.1.rst b/changes/3611.removal.1.rst\nnew file mode 100644\nindex 0000000000..b4d1f2e583\n--- /dev/null\n+++ b/changes/3611.removal.1.rst\n@@ -0,0 +1,1 @@\n+Previously, Travertino provided an ``rgba`` and an ``hsla`` class, as well as ``rgb`` and ``hsl`` subclasses that enforce opaque alpha. In order to better match CSS, there is now no difference between these names; the shorter ``rgb`` and ``hsl`` are the preferred forms, but ``rgba`` and ``hsla`` are direct aliases for them. This can have backwards-incompatible implications; for instance, ``rgba(255, 255, 255, .5).rgb`` would previously have returned a fully opaque ``rgb`` instance, while now it will preserve its alpha channel information.\ndiff --git a/changes/3611.removal.2.rst b/changes/3611.removal.2.rst\nnew file mode 100644\nindex 0000000000..3c776bd6ff\n--- /dev/null\n+++ b/changes/3611.removal.2.rst\n@@ -0,0 +1,1 @@\n+In order to better match CSS, the ``rgb`` and ``hsl`` constructors now silently clip (or in the case of hue, wrap) out-of-range values rather than throwing errors. They also convert them to consistent types: integers for red, blue, green, and hue; and floats for saturation, lightness, and alpha.\ndiff --git a/changes/3611.removal.3.rst b/changes/3611.removal.3.rst\nnew file mode 100644\nindex 0000000000..418792ba10\n--- /dev/null\n+++ b/changes/3611.removal.3.rst\n@@ -0,0 +1,1 @@\n+``rgb`` and ``hsl`` color objects are now read-only; their ``r``/``g``/``b``/``a`` or ``h``/``s``/``l``/``a`` attributes can't be altered after creation. Because of this, format conversions (``rgb(...).hsl`` or ``hsl(...).rgb``) can now cache their results, only performing calculations once. \"Converting\" a color object to its own type (``rgb(...).rgb`` or ``hsl(...).hsl``) now returns the original object, rather than a new instance with the same values.\ndiff --git a/changes/3611.removal.4.rst b/changes/3611.removal.4.rst\nnew file mode 100644\nindex 0000000000..01fe1e6cb3\n--- /dev/null\n+++ b/changes/3611.removal.4.rst\n@@ -0,0 +1,1 @@\n+Travertino's color-parsing ``color()`` function interprets hex strings, e.g. ``#123``, ``#112233``, as well as predefined named colors. Previously, while this was never documented, it also parsed CSS-like declarations like ``\"rgb(...)\"``; this feature has been removed.\ndiff --git a/pyproject.toml b/pyproject.toml\nindex 433bf74d39..1a256345b6 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -39,6 +39,8 @@ exclude_lines = [\n no-cover-if-missing-setuptools_scm = \"not is_installed('setuptools_scm')\"\n no-cover-if-missing-PIL = \"not is_installed('PIL')\"\n no-cover-if-PIL-installed = \"is_installed('PIL')\"\n+no-cover-if-lt-py312 = \"sys_version_info < (3, 12) and os_environ.get('COVERAGE_EXCLUDE_PYTHON_VERSION') != 'disable'\"\n+no-cover-if-gte-py312 = \"sys_version_info > (3, 12) and os_environ.get('COVERAGE_EXCLUDE_PYTHON_VERSION') != 'disable'\"\n no-cover-if-lt-py311 = \"sys_version_info < (3, 11) and os_environ.get('COVERAGE_EXCLUDE_PYTHON_VERSION') != 'disable'\"\n no-cover-if-gte-py311 = \"sys_version_info > (3, 11) and os_environ.get('COVERAGE_EXCLUDE_PYTHON_VERSION') != 'disable'\"\n no-cover-if-lt-py310 = \"sys_version_info < (3, 10) and os_environ.get('COVERAGE_EXCLUDE_PYTHON_VERSION') != 'disable'\"\ndiff --git a/travertino/src/travertino/colors.py b/travertino/src/travertino/colors.py\nindex 00ba2f92e3..c6cbbc57b0 100644\n--- a/travertino/src/travertino/colors.py\n+++ b/travertino/src/travertino/colors.py\n@@ -1,49 +1,49 @@\n from __future__ import annotations\n \n-from .constants import *  # noqa: F403\n-\n+import string\n \n-def _clamp(value, upper=1):\n-    return min(upper, max(0, value))\n+from .constants import *  # noqa: F403\n \n \n-def _clamp_hex(value):\n-    return round(_clamp(value, upper=255))\n+def _clamp(value, lower, upper):\n+    return min(upper, max(lower, value))\n \n \n class Color:\n-    \"A base class for all colorspace representations.\"\n+    \"\"\"A base class for all colorspace representations.\"\"\"\n \n     def __eq__(self, other):\n         try:\n-            c1 = self.rgba\n-            c2 = other.rgba\n+            c1 = self.rgb\n+            c2 = other.rgb\n \n             return c1.r == c2.r and c1.g == c2.g and c1.b == c2.b and c1.a == c2.a\n         except AttributeError:\n             return False\n \n-    @classmethod\n-    def _validate_between(cls, content_name, value, min_value, max_value):\n-        if value < min_value or value > max_value:\n-            raise ValueError(\n-                f\"{content_name} value should be between {min_value}-{max_value}. \"\n-                f\"Got {value}\"\n-            )\n+    @staticmethod\n+    def _validate_zero_to_one(name, value):\n+        try:\n+            return _clamp(float(value), 0.0, 1.0)\n+        except (ValueError, TypeError) as exc:\n+            raise TypeError(\n+                f\"Value for {name} must be a number; got {value!r}\"\n+            ) from exc\n \n-    @classmethod\n-    def _validate_partial(cls, content_name, value):\n-        cls._validate_between(content_name, value, 0, 1)\n+    @property\n+    def a(self) -> float:\n+        return self._a\n+\n+    @property\n+    def rgba(self) -> rgb:\n+        return self.rgb\n \n-    @classmethod\n-    def _validate_alpha(cls, value):\n-        cls._validate_partial(\"alpha\", value)\n+    @property\n+    def hsla(self) -> hsl:\n+        return self.hsl\n \n-    def blend_over(\n-        self,\n-        back_color: Color,\n-    ) -> rgba:\n-        \"\"\"Performs the \"over\" straight alpha blending operation, compositing\n+    def blend_over(self, back_color: Color) -> rgb:\n+        \"\"\"Perform the \"over\" straight alpha blending operation, compositing\n         the front color over the back color.\n \n         **Straight alpha blending** is not the same as\n@@ -59,43 +59,44 @@ def blend_over(\n         # https://en.wikipedia.org/wiki/Alpha_compositing#Description\n \n         # Convert the input colors to rgba in order to do the calculation.\n-        front_color = self.rgba\n-        back_color = back_color.rgba\n+        front_color = self.rgb\n+        back_color = back_color.rgb\n \n         if front_color.a == 1:\n             # If the front color is fully opaque then the result will be the same as\n             # front color.\n             return front_color\n \n-        blended_alpha = _clamp(front_color.a + ((1 - front_color.a) * back_color.a))\n+        blended_alpha = _clamp(\n+            front_color.a + ((1 - front_color.a) * back_color.a),\n+            0.0,\n+            1.0,\n+        )\n \n         if blended_alpha == 0:\n             # Don't further blend the color, to prevent divide by 0.\n-            return rgba(0, 0, 0, 0)\n+            return rgb(0, 0, 0, 0)\n         else:\n             bands = {}\n             for band in \"rgb\":\n                 front = getattr(front_color, band)\n                 back = getattr(back_color, band)\n-                bands[band] = _clamp_hex(\n-                    (\n-                        (front * front_color.a)\n-                        + (back * back_color.a * (1 - front_color.a))\n-                    )\n-                    / blended_alpha\n-                )\n+                bands[band] = (\n+                    (front * front_color.a)\n+                    + (back * back_color.a * (1 - front_color.a))\n+                ) / blended_alpha\n \n-            return rgba(**bands, a=blended_alpha)\n+            return rgb(**bands, a=blended_alpha)\n \n-    def unblend_over(self, back_color: Color, front_color_alpha: float) -> rgba:\n-        \"\"\"Performs the reverse of the \"over\" straight alpha blending operation,\n+    def unblend_over(self, back_color: Color, front_color_alpha: float) -> rgb:\n+        \"\"\"Perform the reverse of the \"over\" straight alpha blending operation,\n         returning the front color.\n \n         Note: Unblending of blended colors might produce front color with slightly\n         imprecise component values compared to the original front color. This is\n         due to the loss of some amount of precision during the calculation and\n         conversion process between the different color formats. For example,\n-        unblending of a hsla blended color might might produce a slightly imprecise\n+        unblending of an hsla blended color might might produce a slightly imprecise\n         original front color, since the alpha blending and unblending is calculated\n         after conversion to rgba values.\n \n@@ -115,8 +116,8 @@ def unblend_over(self, back_color: Color, front_color_alpha: float) -> rgba:\n         # are derived from the \"over\" straight alpha blending operation formula,\n         # see: https://en.wikipedia.org/wiki/Alpha_compositing#Description\n \n-        blended_color = self.rgba\n-        back_color = back_color.rgba\n+        blended_color = self.rgb\n+        back_color = back_color.rgb\n         if not 0 < front_color_alpha <= 1:\n             raise ValueError(\n                 \"The value of front_color_alpha must be within the range of (0, 1].\"\n@@ -126,54 +127,62 @@ def unblend_over(self, back_color: Color, front_color_alpha: float) -> rgba:\n             for band in \"rgb\":\n                 blended = getattr(blended_color, band)\n                 back = getattr(back_color, band)\n-                bands[band] = _clamp_hex(\n-                    (\n-                        (blended * blended_color.a)\n-                        - (back * back_color.a * (1 - front_color_alpha))\n-                    )\n-                    / front_color_alpha\n-                )\n+                bands[band] = (\n+                    (blended * blended_color.a)\n+                    - (back * back_color.a * (1 - front_color_alpha))\n+                ) / front_color_alpha\n \n-            return rgba(**bands, a=front_color_alpha)\n+            return rgb(**bands, a=front_color_alpha)\n \n \n-class rgba(Color):\n-    \"A representation of an RGBA color.\"\n+class rgb(Color):\n+    \"\"\"A representation of an RGB(A) color.\"\"\"\n \n-    def __init__(self, r, g, b, a):\n-        self._validate_rgb(\"red\", r)\n-        self._validate_rgb(\"green\", g)\n-        self._validate_rgb(\"blue\", b)\n-        self._validate_alpha(a)\n-        self.r = r\n-        self.g = g\n-        self.b = b\n-        self.a = a\n+    def __init__(self, r, g, b, a=1.0):\n+        self._r = self._validate_band(\"red\", r)\n+        self._g = self._validate_band(\"green\", g)\n+        self._b = self._validate_band(\"blue\", b)\n+        self._a = self._validate_zero_to_one(\"alpha\", a)\n \n     def __hash__(self):\n-        return hash((\"RGBA-color\", self.r, self.g, self.b, self.a))\n+        return hash((\"RGB-color\", self.r, self.g, self.b, self.a))\n \n     def __repr__(self):\n-        return f\"rgba({self.r}, {self.g}, {self.b}, {self.a})\"\n+        return f\"rgb({self.r}, {self.g}, {self.b}, {self.a})\"\n+\n+    def __str__(self):\n+        return f\"rgb({self.r} {self.g} {self.b} / {self.a})\"\n+\n+    @staticmethod\n+    def _validate_band(name, value):\n+        try:\n+            return _clamp(round(value), 0, 255)\n+        except TypeError as exc:\n+            raise TypeError(\n+                f\"Value for {name} must be a number; got {value!r}\"\n+            ) from exc\n \n-    @classmethod\n-    def _validate_rgb(cls, content_name, value):\n-        cls._validate_between(content_name, value, 0, 255)\n+    @property\n+    def r(self) -> int:\n+        return self._r\n \n     @property\n-    def rgba(self):\n-        # Explicitly return a rgba value, to ensure that classes which inherit the\n-        # parent rgba class, actually return the rgba() value, instead of the child\n-        # class. For example, without this fix, doing rgb(20, 20, 20).rgba will\n-        # return rgb(20, 20, 20), instead of rgba(20, 20, 20, 1).\n-        return rgba(self.r, self.g, self.b, self.a)\n+    def g(self) -> int:\n+        return self._g\n \n     @property\n-    def rgb(self):\n-        return rgb(self.r, self.g, self.b)\n+    def b(self) -> int:\n+        return self._b\n \n     @property\n-    def hsla(self) -> hsla:\n+    def rgb(self) -> rgb:\n+        return self\n+\n+    @property\n+    def hsl(self) -> hsl:\n+        if cached := getattr(self, \"_hsl\", None):\n+            return cached\n+\n         # Formula used here is from: https://en.wikipedia.org/wiki/HSL_and_HSV#From_RGB\n         r_prime = self.r / 255\n         g_prime = self.g / 255\n@@ -200,61 +209,56 @@ def hsla(self) -> hsla:\n         else:\n             saturation = chroma / (1 - abs((2 * value) - chroma - 1))\n \n-        return hsla(\n-            hue % 360,  # [0,360)\n-            _clamp(saturation),  # [0,1]\n-            _clamp(lightness),  # [0,1]\n-            self.a,  # [0,1]\n-        )\n-\n-    @property\n-    def hsl(self):\n-        return self.hsla.hsl\n-\n-\n-class rgb(rgba):\n-    \"A representation of an RGB color\"\n+        self._hsl = hsl(hue, saturation, lightness, self.a)\n+        return self._hsl\n \n-    def __init__(self, r, g, b):\n-        super().__init__(r, g, b, 1.0)\n \n-    def __repr__(self):\n-        return f\"rgb({self.r}, {self.g}, {self.b})\"\n+# As in CSS, rgba is simply a direct alias for rgb.\n+rgba = rgb\n \n \n-class hsla(Color):\n-    \"A representation of an HSLA color.\"\n+class hsl(Color):\n+    \"\"\"A representation of an HSL(A) color.\"\"\"\n \n     def __init__(self, h, s, l, a=1.0):  # noqa: E741\n-        self._validate_between(\"hue\", h, 0, 360)\n-        self._validate_partial(\"saturation\", s)\n-        self._validate_partial(\"lightness\", l)\n-        self._validate_alpha(a)\n-        self.h = h\n-        self.s = s\n-        self.l = l\n-        self.a = a\n+        try:\n+            self._h = round(h) % 360\n+        except TypeError as exc:\n+            raise TypeError(f\"Value for hue must be a number; got {h!r}\") from exc\n+        self._s = self._validate_zero_to_one(\"saturation\", s)\n+        self._l = self._validate_zero_to_one(\"lightness\", l)\n+        self._a = self._validate_zero_to_one(\"alpha\", a)\n \n     def __hash__(self):\n-        return hash((\"HSLA-color\", self.h, self.s, self.l, self.a))\n+        return hash((\"HSL-color\", self.h, self.s, self.l, self.a))\n \n     def __repr__(self):\n-        return f\"hsla({self.h}, {self.s}, {self.l}, {self.a})\"\n+        return f\"hsl({self.h}, {self.s}, {self.l}, {self.a})\"\n+\n+    def __str__(self):\n+        return f\"hsl({self.h} {round(self.s * 100)}% {round(self.l * 100)}% / {self.a})\"\n+\n+    @property\n+    def h(self) -> int:\n+        return self._h\n+\n+    @property\n+    def s(self) -> float:\n+        return self._s\n \n     @property\n-    def hsla(self):\n-        # Explicitly return a hsla value, to ensure that classes which inherit the\n-        # parent hsla class, actually return the hsla() value, instead of the child\n-        # class. For example, without this fix, doing hsl(210, 1, 0.5).hsla will\n-        # return hsl(210, 1, 0.5), instead of hsla(210, 1, 0.5, 1).\n-        return hsla(self.h, self.s, self.l, self.a)\n+    def l(self) -> float:  # noqa: E743\n+        return self._l\n \n     @property\n-    def hsl(self):\n-        return hsl(self.h, self.s, self.l)\n+    def hsl(self) -> hsl:\n+        return self\n \n     @property\n-    def rgba(self):\n+    def rgb(self) -> rgb:\n+        if cached := getattr(self, \"_rgb\", None):\n+            return cached\n+\n         c = (1.0 - abs(2.0 * self.l - 1.0)) * self.s\n         h = self.h / 60.0\n         x = c * (1.0 - abs(h % 2 - 1.0))\n@@ -273,137 +277,54 @@ def rgba(self):\n         else:\n             r, g, b = c + m, m, x + m\n \n-        return rgba(\n-            round(r * 0xFF),\n-            round(g * 0xFF),\n-            round(b * 0xFF),\n-            self.a,\n-        )\n+        self._rgb = rgb(r * 0xFF, g * 0xFF, b * 0xFF, self.a)\n+        return self._rgb\n \n-    @property\n-    def rgb(self):\n-        return self.rgba.rgb\n \n+# As in CSS, hsla is simply a direct alias for hsl.\n+hsla = hsl\n \n-class hsl(hsla):\n-    \"A representation of an HSL color\"\n \n-    def __init__(self, h, s, l):  # noqa: E741\n-        super().__init__(h, s, l, 1.0)\n-\n-    def __repr__(self):\n-        return f\"hsl({self.h}, {self.s}, {self.l})\"\n-\n-\n-def color(value):\n+def color(value: str) -> Color:\n     \"\"\"Parse a color from a value.\n \n     Accepts:\n-    * rgb() instances\n-    * hsl() instances\n+    * An rgb() or hsl() instance\n+    * A named color\n     * '#rgb'\n     * '#rgba'\n     * '#rrggbb'\n     * '#rrggbbaa'\n-    * '#RGB'\n-    * '#RGBA'\n-    * '#RRGGBB'\n-    * '#RRGGBBAA'\n-    * 'rgb(0, 0, 0)'\n-    * 'rgba(0, 0, 0, 0.0)'\n-    * 'hsl(0, 0%, 0%)'\n-    * 'hsla(0, 0%, 0%, 0.0)'\n-    * A named color\n     \"\"\"\n \n     if isinstance(value, Color):\n         return value\n \n     elif isinstance(value, str):\n-        if value[0] == \"#\":\n-            if len(value) == 4:\n+        if result := NAMED_COLOR.get(value.lower()):\n+            return result\n+\n+        pound, *digits = value\n+        if pound == \"#\" and all(d in string.hexdigits for d in digits):\n+            if len(digits) in {3, 4}:\n+                r, b, g, *a = digits\n                 return rgb(\n-                    r=int(value[1] + value[1], 16),\n-                    g=int(value[2] + value[2], 16),\n-                    b=int(value[3] + value[3], 16),\n-                )\n-            elif len(value) == 5:\n-                return rgba(\n-                    r=int(value[1] + value[1], 16),\n-                    g=int(value[2] + value[2], 16),\n-                    b=int(value[3] + value[3], 16),\n-                    a=int(value[4] + value[4], 16) / 0xFF,\n+                    r=int(f\"{r}{r}\", 16),\n+                    g=int(f\"{b}{b}\", 16),\n+                    b=int(f\"{g}{g}\", 16),\n+                    a=(int(f\"{a[0]}{a[0]}\", 16) / 0xFF) if a else 1.0,\n                 )\n-            elif len(value) == 7:\n+\n+            elif len(digits) in {6, 8}:\n+                r1, r2, b1, b2, g1, g2, *a = digits\n                 return rgb(\n-                    r=int(value[1:3], 16),\n-                    g=int(value[3:5], 16),\n-                    b=int(value[5:7], 16),\n+                    r=int(f\"{r1}{r2}\", 16),\n+                    g=int(f\"{b1}{b2}\", 16),\n+                    b=int(f\"{g1}{g2}\", 16),\n+                    a=(int(f\"{a[0]}{a[1]}\", 16) / 0xFF) if a else 1.0,\n                 )\n-            elif len(value) == 9:\n-                return rgba(\n-                    r=int(value[1:3], 16),\n-                    g=int(value[3:5], 16),\n-                    b=int(value[5:7], 16),\n-                    a=int(value[7:9], 16) / 0xFF,\n-                )\n-        elif value.startswith(\"rgba\"):\n-            try:\n-                values = value[5:-1].split(\",\")\n-                if len(values) == 4:\n-                    return rgba(\n-                        int(values[0]),\n-                        int(values[1]),\n-                        int(values[2]),\n-                        float(\n-                            values[3],\n-                        ),\n-                    )\n-            except ValueError:\n-                pass\n-        elif value.startswith(\"rgb\"):\n-            try:\n-                values = value[4:-1].split(\",\")\n-                if len(values) == 3:\n-                    return rgb(\n-                        int(values[0]),\n-                        int(values[1]),\n-                        int(values[2]),\n-                    )\n-            except ValueError:\n-                pass\n-\n-        elif value.startswith(\"hsla\"):\n-            try:\n-                values = value[5:-1].split(\",\")\n-                if len(values) == 4:\n-                    return hsla(\n-                        int(values[0]),\n-                        int(values[1].strip().rstrip(\"%\")) / 100.0,\n-                        int(values[2].strip().rstrip(\"%\")) / 100.0,\n-                        float(values[3]),\n-                    )\n-            except ValueError:\n-                pass\n-\n-        elif value.startswith(\"hsl\"):\n-            try:\n-                values = value[4:-1].split(\",\")\n-                if len(values) == 3:\n-                    return hsl(\n-                        int(values[0]),\n-                        int(values[1].strip().rstrip(\"%\")) / 100.0,\n-                        int(values[2].strip().rstrip(\"%\")) / 100.0,\n-                    )\n-            except ValueError:\n-                pass\n-        else:\n-            try:\n-                return NAMED_COLOR[value.lower()]\n-            except KeyError:\n-                pass\n \n-    raise ValueError(f\"Unknown color {value}\")\n+    raise ValueError(f\"Unknown color: {value!r}\")\n \n \n NAMED_COLOR = {\n", "test_patch": "diff --git a/core/tests/style/pack/test_css.py b/core/tests/style/pack/test_css.py\nindex 45e1478c7b..2589bce537 100644\n--- a/core/tests/style/pack/test_css.py\n+++ b/core/tests/style/pack/test_css.py\n@@ -355,7 +355,7 @@\n         # Color\n         pytest.param(\n             Pack(color=REBECCAPURPLE),\n-  