+            vars.append(self.default)
+        elif isinstance(self.default, BaseComponent):
+            # Get vars from the default component
+            vars.extend(self.default._get_vars())
+            # Also get vars from event triggers in the default component
+            for _, event_vars in self.default._get_vars_from_event_triggers(self.default.event_triggers):
+                vars.extend(event_vars)
+
