4b\u540e\u4f1a\u62a5\u9519\uff0c\u62a5\u9519\u4fe1\u606f\u5982\u4e0b\uff1a\n```sh\nTraceback (most recent call last):\n  File \"***/process_pdf.py\", line 10, in <module>\n    for block in extractor.extract(pdf=\"data/charityservices/pdf/TheVoice_559.pdf\"):\n  File \"***miniconda3/envs/***/lib/python3.10/site-packages/pdf_craft/pdf/extractor.py\", line 100, in extract\n    for _, blocks, _ in self.extract_enumerated_blocks_and_image(\n  File \"***miniconda3/envs/***/lib/python3.10/site-packages/pdf_craft/pdf/extractor.py\", line 113, in extract_enumerated_blocks_and_image\n    for page_index, result, layouts in self._doc_extractor.extract(DocumentParams(\n  File \"***miniconda3/envs/***/lib/python3.10/site-packages/pdf_craft/pdf/document.py\", line 39, in extract\n    for result, section in self._extract_results_and_sections(params):\n  File \"***miniconda3/envs/***/lib/python3.10/site-packages/pdf_craft/pdf/document.py\", line 52, in _extract_results_and_sections\n    for page_index, result in self._extract_page_result(params):\n  File \"***miniconda3/envs/***/lib/python3.10/site-packages/pdf_craft/pdf/document.py\", line 88, in _extract_page_result\n    result = self._doc_extractor.extract(\n  File \"***miniconda3/envs/***/lib/python3.10/site-packages/doc_page_extractor/extractor.py\", line 84, in extract\n    self._parse_table_and_formula_layouts(layouts, raw_optimizer, extract_formula=extract_formula, extract_table_format=extract_table_format)\n  File \"***miniconda3/envs/***/lib/python3.10/site-packages/doc_page_extractor/extractor.py\", line 159, in _parse_table_and_formula_layouts\n    parsed = self._table.predict(image, extract_table_format)\n  File \"***miniconda3/envs/***/lib/python3.10/site-packages/doc_page_extractor/table.py\", line 36, in predict\n    model = self._get_model()\n  File \"***miniconda3/envs/***/lib/python3.10/site-packages/doc_page_extractor/table.py\", line 48, in _get_model\n    from .struct_eqtable import build_model\nModuleNotFoundError: No module named 'doc_page_extractor.struct_eqtable'\n```\n", "hints_text": "\u4e00\u6837\u7684\u6709\u8fd9\u4e2a\u9519\u8bef\n\n", "all_hints_text": "\u4e00\u6837\u7684\u6709\u8fd9\u4e2a\u9519\u8bef\n\u5347\u7ea7\u5230 0.2.6 \u53ef\u4fee\u590d\u8fd9\u4e2a\u95ee\u9898\n\n", "commit_urls": ["https://github.com/oomol-lab/pdf-craft/commit/4f8978b0eda8ac74732c05f0b95cb001bed5a85c", "https://github.com/oomol-lab/pdf-craft/commit/22b6657c6822a41ef17a8fad58de2d6fec3085b6"], "created_at": "2025-07-16T07:56:58Z"}
