:55.296Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/5c/5b/4e4fff7bad39adf89f735f2bc87248c81db71205b62bcc0d5ca5b606b3c3/nvidia_nccl_cu12-2.27.3-py3-none-manylinux2014_x86_64.manylinux_2_17_x86_64.whl\", hash = \"sha256:adf27ccf4238253e0b826bce3ff5fa532d65fc42322c8bfdfaf28024c0fbe039\", size = 322364134, upload-time = \"2025-06-03T21:58:04.013Z\" },\n ]\n \n [[package]]\n@@ -2867,7 +2868,7 @@ wheels = [\n \n [[package]]\n name = \"torch\"\n-version = \"2.7.1+cu126\"\n+version = \"2.8.0+cu126\"\n source = { registry = \"https://download.pytorch.org/whl/cu126/\" }\n dependencies = [\n     { name = \"filelock\" },\n@@ -2893,8 +2894,8 @@ dependencies = [\n     { name = \"typing-extensions\" },\n ]\n wheels = [\n-    { url = \"https://download.pytorch.org/whl/cu126/torch-2.7.1%2Bcu126-cp310-cp310-manylinux_2_28_x86_64.whl\", hash = \"sha256:03b83a0f2c1e90afafd7a5728b956e211bb3e6c56ea3d7d8c7638a659e448d5f\" },\n-    { url = \"https://download.pytorch.org/whl/cu126/torch-2.7.1%2Bcu126-cp310-cp310-win_amd64.whl\", hash = \"sha256:30119a54e1b4ccefe20dfe5d4b13f6aef76c17ec605b40e26d39789db00906f2\" },\n+    { url = \"https://download.pytorch.org/whl/cu126/torch-2.8.0%2Bcu126-cp310-cp310-manylinux_2_28_x86_64.whl\", hash = \"sha256:6bf3c0085af4176137f216c39995dede9beda9af1307fd1dee2305f4f351eb42\" },\n+    { url = \"https://download.pytorch.org/whl/cu126/torch-2.8.0%2Bcu126-cp310-cp310-win_amd64.whl\", hash = \"sha256:3b43acaa40ac87495d858bb1dbe574aaaff4e60e9da6221825ece694fd1d2b80\" },\n ]\n \n [[package]]\n@@ -2951,13 +2952,13 @@ wheels = [\n \n [[package]]\n name = \"triton\"\n-version = \"3.3.1\"\n+version = \"3.4.0\"\n source = { registry = \"https://pypi.org/simple\" }\n dependencies = [\n     { name = \"setuptools\", marker = \"sys_platform == 'linux'\" },\n ]\n wheels = [\n-    { url = \"https://files.pythonhosted.org/packages/8d/a9/549e51e9b1b2c9b854fd761a1d23df0ba2fbc60bd0c13b489ffa518cfcb7/triton-3.3.1-cp310-cp310-manylinux_2_27_x86_64.manylinux_2_28_x86_64.whl\", hash = \"sha256:b74db445b1c562844d3cfad6e9679c72e93fdfb1a90a24052b03bb5c49d1242e\", size = 155600257, upload-time = \"2025-05-29T23:39:36.085Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/62/ee/0ee5f64a87eeda19bbad9bc54ae5ca5b98186ed00055281fd40fb4beb10e/triton-3.4.0-cp310-cp310-manylinux_2_27_x86_64.manylinux_2_28_x86_64.whl\", hash = \"sha256:7ff2785de9bc02f500e085420273bb5cc9c9bb767584a4aa28d6e360cec70128\", size = 155430069, upload-time = \"2025-07-30T19:58:21.715Z\" },\n ]\n \n [[package]]\n", "test_patch": "", "problem_statement": "FedRAMP Vulnerability Remediation - 2026-02-17\n# FedRAMP Vulnerability Remediation - 2026-02-17\n\n**Due Date**: 2026-02-25\n**Tracking Issue**: [h2oai/cloud-platform#932](https://github.com/h2oai/cloud-platform/issues/932)\n\n## \u26a0\ufe0f Important Information\n\n### Accelerated Timeline\n\nWe are asking you to prioritize resolving this issue and the enclosed vulnerabilities by the due date (2026-02-25).  If you have any questions or concerns, reach out to: David Epperson, Cody Harris or Ophir Zahavi.\n\n### Fix Version Number\n\n* \u26a0\ufe0f\u26a0\ufe0f\u26a0\ufe0f Release the version with a -1 suffix but otherwise the same version (eg if 1.2.3 of an image is listed, please release a 1.2.3-1)\n  * We need a semver compatible way to articlate a version between 1.2.3 and 1.2.4\n  * Semver can only contain 3 digits\n  * We're looking for a consistent naming system spanning all products\n### What to Fix\n\n* Ensure that the minimal changes are performed (avoid bugfixes, no features)\n* ALL VULNERABILITIES HERIN MUST BE REMEDIATED - EVEN MEDIUMS AND LOWS\n  * Vulnerabilities not due for remediation by 2025-03-14 have been filtered out to be addressed in future iterations\n* Focus on criticals, highs and mediums in that order\n* Acknowledge this issue promptly and provide a fix plan as a comment\n* ONLY close this issue when the fix has been released and announced in , and list the fix version\n\n### Remediation Timeline (Yes mediums and lows are important too!)\n\nPer [FedRAMP vulnerability scanning requirements](https://www.fedramp.gov/assets/resources/documents/CSP_Vulnerability_Scanning_Requirements.pdf) and [NIST SP 800-53 RA-5](https://csrc.nist.gov/projects/cprt/catalog#/cprt/framework/version/SP_800_53_5_1_1/home?element=RA-5):\n\n| Severity | Remediation Timeline |\n|----------|----------------------|\n| **CRITICAL** | 30 days |\n| **HIGH** | 30 days |\n| **MEDIUM** | 90 days |\n| **LOW** | 180 days |\n\n### Version Notice\n\n\u26a0\ufe0f **The image versions listed below may not represent the most recent versions available.** Please verify that the vulnerabilities still exist in the latest version of each image before beginning remediation work.\n\n### Verifying Vulnerabilities with Trivy\n\nThese scan results were generated using [Trivy](https://github.com/aquasecurity/trivy). To verify vulnerabilities locally:\n\n```bash\n# Scan a specific image\ntrivy image --severity HIGH,CRITICAL <image-name>:<tag>\n\n# Scan with detailed output\ntrivy image --severity HIGH,CRITICAL --format table <image-name>:<tag>\n\n# Generate JSON output for processing\ntrivy image --severity HIGH,CRITICAL --format json -o results.json <image-name>:<tag>\n```\n\n---\n\n## Vulnerabilities by Image\n\n## h2oai-llmstudio-app-stg:v1.14.8\n\n| CVE | Severity | Packages | Version | Fix | Description |\n|-----|----------|----------|---------|-----|-------------|\n| CVE-2025-68121 | HIGH | stdlib, stdlib | v1.24.12 | N/A | During session resumption in crypto/tls, if the underlying Config has its ClientCAs or RootCAs field... |\n| CVE-2025-3730 | MEDIUM | torch | 2.7.1+cu126 | N/A | A vulnerability, which was classified as problematic, was found in PyTorch 2.6.0. Affected is the fu... |\n\n\n", "hints_text": "\n\n", "all_hints_text": "can you please provide the updated image? I'm not seeing `v1.14.8-1` in mc ecr.\nv1.14.9\n\n", "commit_urls": ["https://github.com/h2oai/h2o-llmstudio/commit/a57b1a87821e473095abb78ce73e3e40da3b25f6", "https://github.com/h2oai/h2o-llmstudio/commit/47f12644d0c419ac216ed95e13fe5059cf48a0b7", "https://github.com/h2oai/h2o-llmstudio/commit/ddca1dd88049746876b4be85f3c423534b2def1a", "https://github.com/h2oai/h2o-llmstudio/commit/e56dad6173a51a2a03c83f7c5ca5f250b37edf86", "https://github.com/h2oai/h2o-llmstudio/commit/a1575b060f94b4d598228a6ad2bea118fde15dd3"], "created_at": "2026-02-19T11:39:00Z"}
