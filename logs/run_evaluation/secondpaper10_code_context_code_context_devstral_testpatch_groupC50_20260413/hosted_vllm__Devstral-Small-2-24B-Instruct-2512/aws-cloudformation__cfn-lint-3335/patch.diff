+    def _parse_dynamic_reference(self, dynamic_ref: str):
+        """
+        Parse a dynamic reference string into its components.
+        Ignores colons inside ${...} blocks.
+        """
+        # Check if there are any ${...} blocks
+        has_brace_blocks = '${' in dynamic_ref
+
+        if not has_brace_blocks:
+            # If no ${...} blocks, use simple split for backward compatibility
+            return dynamic_ref.split(':')
+
+        # The dynamic_ref parameter is already the content inside {{ }}
+        # e.g., "resolve:ssm:${AWS::AccountId}/${AWS::Region}/ac"
+        parts = []
+        current_part = []
+        in_brace = False
+
+        i = 0
+        while i < len(dynamic_ref):
+            char = dynamic_ref[i]
+            if char == '$' and i + 1 < len(dynamic_ref) and dynamic_ref[i+1] == '{':
+                # Start of ${...} block
+                in_brace = True
+                current_part.append(char)
+                current_part.append('{')
+                i += 2  # Skip '${'
+                # Add everything until we find '}'
+                while i < len(dynamic_ref) and dynamic_ref[i] != '}':
+                    current_part.append(dynamic_ref[i])
+                    i += 1
+                if i < len(dynamic_ref):
+                    current_part.append('}')  # Add the closing brace
+                    i += 1  # Skip '}'
+                    in_brace = False  # Reset the flag after closing brace
+            elif char == ':' and not in_brace:
+                # Colon outside ${...} - this is a separator
+                parts.append(''.join(current_part))
+                current_part = []
+                i += 1
+            else:
+                current_part.append(char)
+                i += 1
+
+        # Add the last part
+        if current_part:
+            parts.append(''.join(current_part))
+
+        return parts
+
