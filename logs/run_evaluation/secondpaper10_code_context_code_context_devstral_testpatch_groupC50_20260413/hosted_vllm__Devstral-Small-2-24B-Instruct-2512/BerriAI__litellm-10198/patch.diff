+    def is_candidate_token_count_inclusive(self, usage_metadata: dict) -> bool:
+        """
+        Check if candidatesTokenCount includes thoughtsTokenCount
+        For Gemini 2.5 Flash and similar models, the candidatesTokenCount may or may not include the thinking tokens.
+        This method determines which case we're dealing with.
+        """
+        candidates_token_count = usage_metadata.get("candidatesTokenCount", 0)
+        thoughts_token_count = usage_metadata.get("thoughtsTokenCount", 0)
+        total_token_count = usage_metadata.get("totalTokenCount", 0)
+        prompt_token_count = usage_metadata.get("promptTokenCount", 0)
+
+        # If there are no thinking tokens, candidates is always inclusive
+        if thoughts_token_count == 0:
+            return True
+
+        # Calculate expected completion tokens
+        expected_completion_tokens = total_token_count - prompt_token_count
+
+        # If candidates + thoughts equals expected completion tokens, then candidates is exclusive
+        if candidates_token_count + thoughts_token_count == expected_completion_tokens:
+            return False
+        # If candidates equals expected completion tokens, then candidates is inclusive
+        elif candidates_token_count == expected_completion_tokens:
+            return True
+        else:
+            # Default to inclusive for safety
+            return True
+
