{"repository": {"pullRequest": {"number": 208, "title": "Add majority voting plugin for candidate selection", "body": "Introduces a plugin that generates multiple candidate solutions using the OpenAI API and selects the most frequent answer via majority voting. Includes answer extraction, normalization, and a summary of the voting process. Useful for tasks with discrete answers such as math, coding, and multiple choice problems.\r\n\r\nfixes #201 \r\nsuperseeds #83 ", "baseRefName": "main", "baseRefOid": "7904463799373a478ac37166b1a5af594bbdd353", "baseRepository": {"nameWithOwner": "algorithmicsuperintelligence/optillm"}, "url": "https://github.com/algorithmicsuperintelligence/optillm/pull/208", "createdAt": "2025-07-08T12:27:46Z", "mergedAt": "2025-07-10T22:04:50Z"}}, "base": {"repo": {"full_name": "algorithmicsuperintelligence/optillm"}, "sha": "7904463799373a478ac37166b1a5af594bbdd353"}, "diff_url": "https://github.com/algorithmicsuperintelligence/optillm/pull/208.diff", "number": 208, "created_at": "2025-07-08T12:27:46Z", "merged_at": "2025-07-10T22:04:50Z", "resolved_issues": [201]}
