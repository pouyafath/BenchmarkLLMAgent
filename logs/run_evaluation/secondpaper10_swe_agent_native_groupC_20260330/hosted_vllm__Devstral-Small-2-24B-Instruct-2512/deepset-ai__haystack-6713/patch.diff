+def _resolve_torch_dtype(dtype_str: str):
+    """
+    Resolve a string representation of a torch dtype back to the actual dtype object.
+
+    Args:
+        dtype_str: String representation of the torch dtype (e.g., "torch.float16")
+
+    Returns:
+        The corresponding torch.dtype object
+    """
+    try:
+        import torch
+        return getattr(torch, dtype_str.split('.')[-1])
+    except (ImportError, AttributeError) as e:
+        logger.warning(f"Could not resolve torch dtype '{dtype_str}': {e}")
+        return dtype_str
+
+def _represent_torch_dtype(dumper, data):
+    """
+    Custom YAML representer for torch.dtype objects.
+
+    Args:
+        dumper: YAML dumper instance
+        data: torch.dtype object to represent
+
+    Returns:
+        YAML node representing the dtype as a string
+    """
+    return dumper.represent_str(f"{data}")
+
+def _represent_torch_tensor(dumper, data):
+    """
+    Custom YAML representer for torch.Tensor objects.
+
+    Args:
+        dumper: YAML dumper instance
+        data: torch.Tensor object to represent
+
+    Returns:
+        YAML node representing the tensor as a string
+    """
+    return dumper.represent_str(f"torch.tensor({list(data.tolist())})")
+
+def _represent_generic(dumper, data):
+    """
+    Fallback representer for objects that have a string representation.
 
+    Args:
+        dumper: YAML dumper instance
+        data: Object to represent
+
+    Returns:
+        YAML node representing the object as a string
+    """
+    return dumper.represent_str(str(data))
 
 class YamlMarshaller:
+    def __init__(self):
