-np.pi / 4, initial_phase)\n+    a, b, d, e = _extract_abde(A_M)\n+\n+    _decompose_0_cnots(M_2, wires, 0.0)\n+    _central_circuit(a, b, d, wires)\n+    _decompose_0_cnots(M_1, wires, 0.0)\n+    # global phases here are zero because we are guaranteed that M_1 and M_2 have unit determinant\n+\n+    # Return the global phase obtained from A_M. It will be combined with initial_phase\n+    # in `two_qubit_decomposition`\n+    return math.cast_like(-e, initial_phase)\n \n \n def _compute_udv(a, b):\n@@ -911,6 +939,8 @@ def cossin_decomposition(U, p):\n \n \n def _global_phase(phase):\n+    \"\"\"Calls the GlobalPhase with a negative sign. Used in a ``cond`` call which requires\n+    no variable to be returned.\"\"\"\n     ops.GlobalPhase(-phase)\n \n \ndiff --git a/pennylane/ops/qubit/matrix_ops.py b/pennylane/ops/qubit/matrix_ops.py\nindex 9019d4c74c9..c6849bdf0b2 100644\n--- a/pennylane/ops/qubit/matrix_ops.py\n+++ b/pennylane/ops/qubit/matrix_ops.py\n@@ -302,7 +302,8 @@ def has_matrix(self) -> bool:\n     # pylint: disable=arguments-renamed, invalid-overridden-method\n     @property\n     def has_decomposition(self) -> bool:\n-        return len(self.wires) < 3 if self.has_matrix else len(self.wires) == 1\n+        # We are unable to decompose sparse matrices larger than 1 qubit.\n+        return self.has_matrix or len(self.wires) == 1\n \n     def adjoint(self) -> \"QubitUnitary\":\n         if self.has_matrix:\n", "test_patch": "diff --git a/tests/ops/op_math/test_controlled_decompositions.py b/tests/ops/op_math/test_controlled_decompositions.py\nindex ddb51ede92c..0793d07409f 100644\n--- a/tests/ops/op_math/test_controlled_decompositions.py\n+++ b/tests/ops/op_math/test_controlled_decompositions.py\n@@ -1041,21 +1041,3 @@ def test_private_mcx_decomposition_raises_error(self):\n             _ = _decompose_mcx_with_two_workers(\n                 control_wires, target_wire, work_wires, work_wire_type=\"clean\"\n             )\n-\n-\n-def test_ControlledQubitUnitary_has_decomposition_correct():\n-    \"\"\"Test that ControlledQubitUnitary reports has_decomposition=False if it is False\"\"\"\n-    U = qml.Toffoli(wires=[0, 1, 2]).matrix()\n-    op = qml.ControlledQubitUnitary(U, wires=[0, 1, 2, 3])\n-\n-    assert not op.has_decomposition\n-    with pytest.raises(qml.operation.DecompositionUndefinedError):\n-        op.decomposition()\n-\n-\n-def test_ControlledQubitUnitary_has_decomposition_super_False(mocker):\n-    \"\"\"Test that has_decomposition returns False if super() returns False\"\"\"\n-    spy = mocker.spy(qml.QueuingManager, \"stop_recording\")\n-    op = qml.ControlledQubitUnitary(np.diag((1.0,) * 8), wires=[0, 1, 2, 3, 4])\n-    assert not op.has_decomposition\n-    spy.assert_not_called()\ndiff --git a/tests/ops/op_math/test_decompositions.py b/tests/ops/op_math/test_decompositions.py\nindex 2ac083a78ae..0dc191bd4e9 100644\n--- a/tests/ops/op_math/test_decompositions.py\n+++ b/tests/ops/op_math/test_decompositions.py\n@@ -630,6 +630,32 @@ def test_rot_decomposition_jax(self, U, expected_gates, expected_params):\n             -0.4168424055846296 + 0.3576772276508062j,\n         ],\n     ],\n+    [  # this matrix caused issues before: https://github.com/PennyLaneAI/pennylane/issues/7467\n+        [\n+            -0.40836553 - 0.28850926j,\n+            0.23864466 - 0.4393731j,\n+            0.02190401 + 0.06284322j,\n+            -0.23169726 - 0.66474606j,\n+        ],\n+        [\n+            -0.48865844 - 0.10589111j,\n+            0.49770294 + 0.04787262j,\n+            -0.02177958 + 0.45019526j,\n+            -0.02632749 + 0.54420285j,\n+        ],\n+        [\n+            0.49276489 - 0.08475118j,\n+            0.47943096 - 0.14193644j,\n+            0.51448332 - 0.17932317j,\n+            -0.42560958 + 0.14834623j,\n+        ],\n+        [\n+            0.42041002 - 0.27065738j,\n+            -0.31807806 - 0.38578018j,\n+            -0.03401683 + 0.70314565j,\n+            -0.00321586 + 0.06647341j,\n+        ],\n+    ],\n ]\n \n samples_2_cnots = [\n@@ -987,13 +1013,14 @@ def test_two_qubit_decomposition_3_cnots(self, U, wires):\n     @pytest.mark.parametrize(\"U\", samples_2_cnots)\n     def test_two_qubit_decomposition_2_cnots(self, U, wires):\n         \"\"\"Test that a two-qubit matrix using 2 CNOTs isolation is correctly decomposed.\"\"\"\n+        # NOTE: Currently, we defer to the 3-CNOTs function for the 2-CNOTs case.\n \n         U = qml.math.convert_to_su4(np.array(U))\n \n         assert _compute_num_cnots(U) == 2\n \n         obtained_decomposition = two_qubit_decomposition(U, wires=wires)\n-        assert len(obtained_decomposition) == 8\n+        assert len(obtained_decomposition) == 11  # 8 # 8 would be the count with 2-CNOT circuit\n \n         tape = qml.tape.QuantumScript(obtained_decomposition)\n         obtained_matrix = qml.matrix(tape, wire_order=wires)\n@@ -1545,13 +1572,7 @@ def circuit(mat):\n     @pytest.mark.parametrize(\n         \"U, n_wires\",\n         [\n-            pytest.param(\n-                qml.matrix(qml.CRX(0.123, [0, 2]) @ qml.CRY(0.456, [1, 3])),\n-                4,\n-                marks=pytest.mark.xfail(\n-                    strict=False, reason=\"https://github.com/PennyLaneAI/pennylane/issues/7467\"\n-                ),\n-            ),\n+            (qml.matrix(qml.CRX(0.123, [0, 2]) @ qml.CRY(0.456, [1, 3])), 4),\n             (qml.QFT.compute_matrix(5), 5),\n             (qml.GroverOperator.compute_matrix(6, []), 6),\n         ],\ndiff --git a/tests/templates/test_subroutines/test_qmc.py b/tests/templates/test_subroutines/test_qmc.py\nindex 4a68de9b030..c1898280ed2 100644\n--- a/tests/templates/test_subroutines/test_qmc.py\n+++ b/tests/templates/test_subroutines/test_qmc.py\n@@ -302,8 +302,8 @@ def test_expected_circuit(self):\n         # Do expansion in two steps to avoid also decomposing the first QubitUnitary\n         queue_before_qpe = tape.operations[:2]\n \n-        # 2-qubit decomposition has 11 operations, and after is a 3-qubit gate so start at 11\n-        queue_after_qpe = tape.expand().operations[11:]\n+        # Build a new tape from all operations following the two QubitUnitary ops and expand it\n+        queue_after_qpe = qml.tape.QuantumScript(tape.operations[2:]).expand().operations\n \n         A = probs_to_unitary(p)\n         R = func_to_unitary(self.func, 4)\ndiff --git a/tests/transforms/test_cliffordt_transform.py b/tests/transforms/test_cliffordt_transform.py\nindex eb701955632..0fe38aa4ccf 100644\n--- a/tests/transforms/test_cliffordt_transform.py\n+++ b/tests/transforms/test_cliffordt_transform.py\n@@ -410,7 +410,10 @@ def test_merge_param_gates(self):\n     def test_raise_with_cliffordt_decomposition(self):\n         \"\"\"Test that exception is correctly raise when decomposing gates without any decomposition\"\"\"\n \n-        tape = qml.tape.QuantumScript([qml.QubitUnitary(qml.math.eye(8), wires=[0, 1, 2])])\n+        class CustomOp(qml.operation.Operation):  # pylint: disable=too-few-public-methods\n+            pass\n+\n+        tape = qml.tape.QuantumScript([CustomOp(wires=[0, 1, 2])])\n \n         with pytest.raises(ValueError, match=\"Cannot unroll\"):\n             clifford_t_decomposition(tape)\ndiff --git a/tests/transforms/test_unitary_to_rot.py b/tests/transforms/test_unitary_to_rot.py\nindex 06143bea1e6..2e0fbf3bd05 100644\n--- a/tests/transforms/test_unitary_to_rot.py\n+++ b/tests/transforms/test_unitary_to_rot.py\n@@ -18,6 +18,7 @@\n \n import pytest\n from gate_data import H, I, S, T, X, Z\n+from scipy.stats import unitary_group\n from test_optimization.utils import check_matrix_equivalence\n \n import pennylane as qml\n@@ -501,15 +502,18 @@ def qfunc_with_qubit_unitary(angles):\n \n \n @pytest.mark.parametrize(\"num_reps\", [1, 2, 3, 4, 5])\n-def test_unitary_to_rot_multiple_two_qubit(num_reps):\n+def test_unitary_to_rot_multiple_two_qubit(num_reps, seed):\n     \"\"\"Test that numerous two-qubit unitaries can be decomposed sequentially.\"\"\"\n \n     dev = qml.device(\"default.qubit\", wires=2)\n \n-    U = np.array(test_two_qubit_unitaries[1], dtype=np.complex128)\n+    Us = unitary_group.rvs(4, size=num_reps, random_state=seed)\n+    if num_reps == 1:\n+        # Batch dim is squeezed away by rvs() for size = 1\n+        Us = [Us]\n \n     def my_circuit():\n-        for _ in range(num_reps):\n+        for U in Us:\n             qml.QubitUnitary(U, wires=[0, 1])\n         return qml.expval(qml.PauliZ(0))\n \n", "problem_statement": "[BUG] Decomposition of QubitUnitary on two wires is incorrect\n### Expected behavior\n\nThe `two_qubit_decomposition` is correrct.\n\n### Actual behavior\n\nIt is, for the most part, but here's a random matrix that it fails on:\n\n```python\nimport pennylane as qml\nimport numpy as np\nfrom pennylane.ops.op_math.decompositions.unitary_decompositions import two_qubit_decomposition\n\nU = np.array(\n    [[-0.40836553 - 0.28850926j, 0.23864466 - 0.4393731j,\n      0.02190401 + 0.06284322j, -0.23169726 - 0.66474606j],\n     [-0.48865844 - 0.10589111j, 0.49770294 + 0.04787262j,\n      -0.02177958 + 0.45019526j, -0.02632749 + 0.54420285j],\n     [0.49276489 - 0.08475118j, 0.47943096 - 0.14193644j,\n      0.51448332 - 0.17932317j, -0.42560958 + 0.14834623j],\n     [0.42041002 - 0.27065738j, -0.31807806 - 0.38578018j,\n      -0.03401683 + 0.70314565j, -0.00321586 + 0.06647341j]]\n)\n\ndecomp = two_qubit_decomposition(U, wires=[0, 1])\nmatrix = qml.matrix(qml.tape.QuantumScript(decomp), wire_order=[0, 1])\n```\n```pycon\n>>> qml.math.allclose(matrix, U, atol=1e-7)\nFalse\n```\n\n\n### Additional information\n\nThis is an old bug coming back to haunt us. See https://github.com/PennyLaneAI/pennylane/issues/5308 and https://github.com/PennyLaneAI/pennylane/issues/7339\n\n### Source code\n\n```shell\n\n```\n\n### Tracebacks\n\n```shell\n\n```\n\n### System information\n\n```shell\nName: Pennylane\nVersion: 0.42.0.dev31\nSummary: PennyLane is a cross-platform Python library for quantum computing, quantum machine learning, and quantum chemistry. Train a quantum computer the same way as a neural network.\nHome-page: \nAuthor: \nAuthor-email: \nLicense-Expression: Apache-2.0\nLocation: /Users/astral.cai/Workspace/pennylane\nRequires: appdirs, autograd, autoray, cachetools, diastatic-malt, networkx, numpy, packaging, pennylane-lightning, requests, rustworkx, scipy, tomlkit, typing_extensions\nRequired-by: PennyLane_Lightning\n\nPlatform info:           macOS-15.5-arm64-arm-64bit\nPython version:          3.10.14\nNumpy version:           1.26.4\nScipy version:           1.15.3\nInstalled devices:\n- default.clifford (Pennylane-0.42.0.dev31)\n- default.gaussian (Pennylane-0.42.0.dev31)\n- default.mixed (Pennylane-0.42.0.dev31)\n- default.qubit (Pennylane-0.42.0.dev31)\n- default.qutrit (Pennylane-0.42.0.dev31)\n- default.qutrit.mixed (Pennylane-0.42.0.dev31)\n- default.tensor (Pennylane-0.42.0.dev31)\n- null.qubit (Pennylane-0.42.0.dev31)\n- reference.qubit (Pennylane-0.42.0.dev31)\n- lightning.qubit (PennyLane_Lightning-0.41.1)\n```\n\n### Existing GitHub issues\n\n- [x] I have searched existing GitHub issues to make sure the issue does not already exist.\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/PennyLaneAI/pennylane/commit/9b0a7d2d1235078e4eeb863c748e74a2075623f1", "https://github.com/PennyLaneAI/pennylane/commit/d2c99802a8a8abe0f2e57d29949c1f29d1c824c1", "https://github.com/PennyLaneAI/pennylane/commit/e62e2146832a54d08af54445ecbac3254472cd24", "https://github.com/PennyLaneAI/pennylane/commit/aeedc9bfd5d736724e9f1cb70be8686b2058f1c3", "https://github.com/PennyLaneAI/pennylane/commit/a1e04da7a298cd32fa4564ebdd31fb804a38fa0a", "https://github.com/PennyLaneAI/pennylane/commit/9b9f4ba6a9f574e6f6c366aeb233e51b823100c4", "https://github.com/PennyLaneAI/pennylane/commit/5edf8e66184bec93fbd96e2520fe4af9dff351a7", "https://github.com/PennyLaneAI/pennylane/commit/a8e733cbce7f8ba1eee594ddce5d72053e1d8c5e", "https://github.com/PennyLaneAI/pennylane/commit/d6815bbef2af7d1b482c2237466f446ac8884e39", "https://github.com/PennyLaneAI/pennylane/commit/ba3c3932f80c90ab8ff5ecef2ec9dade61be0e07", "https://github.com/PennyLaneAI/pennylane/commit/d9b2f08769c2e87dfb971e7121df62e8b4f90817", "https://github.com/PennyLaneAI/pennylane/commit/83fff41562c3716595398f12d5182621ca57a29d", "https://github.com/PennyLaneAI/pennylane/commit/dedacd62901d8a72d9cffa8fc6cde59752d74017", "https://github.com/PennyLaneAI/pennylane/commit/8dd677f513b4ae2341bdf58db52611e81da82125", "https://github.com/PennyLaneAI/pennylane/commit/b1a25db40085329997dacd585c9b2e57117fee08", "https://github.com/PennyLaneAI/pennylane/commit/ec8fe14d7346f122706071fb85cec76f6ff54ff4", "https://github.com/PennyLaneAI/pennylane/commit/254446ccb8c130d4a28ef19df196c7d660880439", "https://github.com/PennyLaneAI/pennylane/commit/7c0ef162dd8421fefc9179eba52794bc1ef76b9d", "https://github.com/PennyLaneAI/pennylane/commit/1e7ab6dc56b0d9b234100efa76bae56340d392dc", "https://github.com/PennyLaneAI/pennylane/commit/ef525ec66ece5f8c1c415e3160b81920e8485865", "https://github.com/PennyLaneAI/pennylane/commit/cdd9e2ace58e5c9db47cbeb3f8ad48147dfda0d0", "https://github.com/PennyLaneAI/pennylane/commit/2abf665e253adef0da89537032ca4b624bdd4be5", "https://github.com/PennyLaneAI/pennylane/commit/14d766ea5fe4799623fb39b7e6ef961220f1be43", "https://github.com/PennyLaneAI/pennylane/commit/3b1092263d1456fe3a667a34ac93a1e47596f4aa"], "created_at": "2025-05-23T15:40:34Z"}
{"repo": "PennyLaneAI/pennylane", "pull_number": 7581, "instance_id": "PennyLaneAI__pennylane-7581", "issue_numbers": [7580], "base_commit": "29d3a49c2e8c3789c47b5452a66e0ee96147c0b5", "patch": "diff --git a/doc/releases/changelog-dev.md b/doc/releases/changelog-dev.md\nindex c5036ebe11d..8c391fa298d 100644\n--- a/doc/releases/changelog-dev.md\n+++ b/doc/releases/changelog-dev.md\n@@ -636,6 +636,10 @@ Here's a list of deprecations made this release. For a more detailed breakdown o\n \n <h3>Bug fixes \ud83d\udc1b</h3>\n \n+* The mapping to standard wires (consecutive integers) of `qml.tape.QuantumScript` has been fixed\n+  to correctly consider work wires that are not used otherwise in the circuit.\n+  [(#7581)](https://github.com/PennyLaneAI/pennylane/pull/7581)\n+\n * Fixed a bug where certain transforms with a native program capture implementation give incorrect results when\n   dynamic wires were present in the circuit. The affected transforms were:\n   * :func:`~pennylane.transforms.cancel_inverses`\ndiff --git a/pennylane/tape/qscript.py b/pennylane/tape/qscript.py\nindex 71419f1bcbc..00785ba5025 100644\n--- a/pennylane/tape/qscript.py\n+++ b/pennylane/tape/qscript.py\n@@ -1306,7 +1306,8 @@ def map_to_standard_wires(self) -> \"QuantumScript\":\n         The standard order is defined by the operator wires being increasing\n         integers starting at zero, to match array indices. If there are any\n         measurement wires that are not in any operations, those will be mapped\n-        to higher values.\n+        to higher values. If there are any work wires that are not used in\n+        any operations or measurements, those will be mapped to higher values.\n \n         **Example:**\n \n@@ -1326,19 +1327,45 @@ def map_to_standard_wires(self) -> \"QuantumScript\":\n         >>> circuit.map_to_standard_wires() is circuit\n         True\n \n+        Work wires that are not used in operations or measurements are mapped to the last\n+        positions in the circuit:\n+\n+        >>> mcx = qml.MultiControlledX([1, 4, \"b\", 2], work_wires=[0, 6])\n+        >>> circuit = qml.tape.QuantumScript([mcx], [qml.probs(wires=[2, 3, 6])])\n+        >>> mapped_circuit = circuit.map_to_standard_wires()\n+        >>> mapped_circuit.circuit\n+        [MultiControlledX(wires=[0, 1, 2, 3], control_values=[True, True, True]),\n+         probs(wires=[3, 4, 5])]\n+        >>> mapped_circuit[0].work_wires\n+        Wires([6, 5])\n         \"\"\"\n+        wire_map = self._get_standard_wire_map()\n+        if wire_map is None:\n+            return self\n+        tapes, fn = qml.map_wires(self, wire_map)\n+        return fn(tapes)\n+\n+    def _get_standard_wire_map(self) -> dict:\n+        \"\"\"Helper function to produce the wire map for map_to_standard_wires.\"\"\"\n         op_wires = Wires.all_wires(op.wires for op in self.operations)\n+        work_wires = Wires.all_wires(getattr(op, \"work_wires\", []) for op in self.operations)\n         meas_wires = Wires.all_wires(mp.wires for mp in self.measurements)\n         num_op_wires = len(op_wires)\n         meas_only_wires = set(meas_wires) - set(op_wires)\n-        if set(op_wires) == set(range(num_op_wires)) and meas_only_wires == set(\n-            range(num_op_wires, num_op_wires + len(meas_only_wires))\n+        num_op_meas_wires = num_op_wires + len(meas_only_wires)\n+        work_only_wires = set(work_wires) - set(op_wires) - meas_only_wires\n+        # If the op wires are consecutive integers, followed by measurement-only wires, followed\n+        # by work-only wires, we do not perform a mapping, signaled by returning `None`.\n+        if (\n+            set(op_wires) == set(range(num_op_wires))\n+            and meas_only_wires == set(range(num_op_wires, num_op_wires + len(meas_only_wires)))\n+            and work_only_wires\n+            == set(range(num_op_meas_wires, num_op_meas_wires + len(work_only_wires)))\n         ):\n-            return self\n+            return None\n \n-        wire_map = {w: i for i, w in enumerate(op_wires + meas_only_wires)}\n-        tapes, fn = qml.map_wires(self, wire_map)\n-        return fn(tapes)\n+        wire_map = {w: i for i, w in enumerate(op_wires + meas_only_wires + work_only_wires)}\n+        return wire_map\n \n \n # ParamSpec is used to preserve the exact signature of the input function `fn`\n", "test_patch": "diff --git a/tests/tape/test_qscript.py b/tests/tape/test_qscript.py\nindex fab525f624a..652c179af8b 100644\n--- a/tests/tape/test_qscript.py\n+++ b/tests/tape/test_qscript.py\n@@ -334,6 +334,133 @@ def test_lazy_batch_size(self):\n         assert copied._batch_size == 2\n \n \n+class TestMapToStandardWires:\n+    \"\"\"Tests for the ``_get_standard_wire_map`` method.\"\"\"\n+\n+    @pytest.mark.parametrize(\n+        \"ops\",\n+        [\n+            [qml.X(0)],\n+            [qml.X(1), qml.Z(0)],\n+            [qml.X(3), qml.IsingXY(0.6, [0, 2]), qml.Z(1)],\n+        ],\n+    )\n+    def test_only_ops_do_nothing(self, ops):\n+        \"\"\"Test that no mapping is done if there are only operators and they act on standard wires.\"\"\"\n+        tape = QuantumScript(ops)\n+        wire_map = tape._get_standard_wire_map()\n+        assert wire_map is None\n+\n+    @pytest.mark.parametrize(\n+        \"ops, meas\",\n+        [\n+            ([qml.X(0)], [qml.expval(qml.Z(0))]),\n+            ([qml.X(0)], [qml.expval(qml.Z(1))]),\n+            ([qml.X(0)], [qml.probs(wires=[0, 1])]),\n+            ([qml.X(0)], [qml.probs(wires=[1, 2])]),\n+            ([qml.X(1), qml.Z(0)], [qml.expval(qml.X(0)), qml.probs(wires=[1, 2])]),\n+            ([qml.X(1), qml.Z(0)], [qml.expval(qml.Y(2))]),\n+            ([qml.X(1), qml.Z(0)], [qml.state()]),\n+            ([qml.X(3), qml.IsingXY(0.6, [0, 2]), qml.Z(1)], [qml.probs(wires=[1])]),\n+        ],\n+    )\n+    def test_op_and_meas_do_nothing(self, ops, meas):\n+        \"\"\"Test that no mapping is done if there are operators and measurements\n+        and they act on standard wires.\n+        \"\"\"\n+        tape = QuantumScript(ops, meas)\n+        wire_map = tape._get_standard_wire_map()\n+        assert wire_map is None\n+\n+    @pytest.mark.parametrize(\n+        \"ops, meas\",\n+        [\n+            ([qml.MultiControlledX([0, 1, 2], work_wires=[3, 4])], []),\n+            ([qml.MultiControlledX([0, 2], work_wires=[3, 4]), qml.X(1)], [qml.expval(qml.Z(1))]),\n+            (\n+                [qml.RX(0.6, 0), qml.MultiControlledX([1, 2, 3], work_wires=[5])],\n+                [qml.probs([0, 4, 2, 1])],\n+            ),\n+        ],\n+    )\n+    def test_with_work_wires_do_nothing(self, ops, meas):\n+        \"\"\"Test that no mapping is done if there are operators with work wires (and measurements)\n+        and they act on standard wires.\n+        \"\"\"\n+        tape = QuantumScript(ops, meas)\n+        wire_map = tape._get_standard_wire_map()\n+        assert wire_map is None\n+\n+    @pytest.mark.parametrize(\n+        \"ops, expected\",\n+        [\n+            ([qml.X(0), qml.RX(0.8, 2)], {0: 0, 2: 1}),\n+            ([qml.X(1), qml.Z(0), qml.X(\"a\")], {1: 0, 0: 1, \"a\": 2}),\n+            ([qml.X(3), qml.IsingXY(0.6, [\"b\", 2]), qml.Z(99)], {3: 0, \"b\": 1, 2: 2, 99: 3}),\n+        ],\n+    )\n+    def test_only_ops(self, ops, expected):\n+        \"\"\"Test that the mapping is correct if there are only operators.\"\"\"\n+        tape = QuantumScript(ops)\n+        wire_map = tape._get_standard_wire_map()\n+        assert wire_map == expected\n+\n+    @pytest.mark.parametrize(\n+        \"ops, meas, expected\",\n+        [\n+            ([qml.X(\"a\")], [qml.expval(qml.Z(\"a\"))], {\"a\": 0}),\n+            ([qml.X(1)], [qml.expval(qml.Z(0))], {1: 0, 0: 1}),\n+            ([qml.X(\"z\")], [qml.probs(wires=[0, 1])], {\"z\": 0, 0: 1, 1: 2}),\n+            ([qml.X(2)], [qml.probs(wires=[1, 2])], {2: 0, 1: 1}),\n+            ([qml.X(1), qml.Z(2)], [qml.expval(qml.Y(0))], {1: 0, 2: 1, 0: 2}),\n+            ([qml.X(1), qml.Z(3)], [qml.state()], {1: 0, 3: 1}),\n+            (\n+                [qml.X(3), qml.IsingXY(0.6, [4, 2]), qml.Z(1)],\n+                [qml.probs()],\n+                {3: 0, 4: 1, 2: 2, 1: 3},\n+            ),\n+        ],\n+    )\n+    def test_op_and_meas(self, ops, meas, expected):\n+        \"\"\"Test that the mapping is correct if there are operators and measurements.\"\"\"\n+        tape = QuantumScript(ops, meas)\n+        wire_map = tape._get_standard_wire_map()\n+        assert wire_map == expected\n+\n+    @pytest.mark.parametrize(\n+        \"ops, meas, expected\",\n+        [\n+            (\n+                [qml.MultiControlledX([2, 3, 4], work_wires=[0, 1])],\n+                [],\n+                {2: 0, 3: 1, 4: 2, 0: 3, 1: 4},\n+            ),\n+            (\n+                [qml.MultiControlledX([0, 1, 3], work_wires=[2, 4])],\n+                [],\n+                {0: 0, 1: 1, 3: 2, 2: 3, 4: 4},\n+            ),\n+            (\n+                [qml.MultiControlledX([0, 2], work_wires=[3, 4])],\n+                [qml.expval(qml.Z(1))],\n+                {0: 0, 2: 1, 1: 2, 3: 3, 4: 4},\n+            ),\n+            (\n+                [qml.MultiControlledX([1, 2, 3], work_wires=[5])],\n+                [qml.probs([0, 4, 2, 1])],\n+                {1: 0, 2: 1, 3: 2, 0: 3, 4: 4, 5: 5},\n+            ),\n+        ],\n+    )\n+    def test_with_work_wires(self, ops, meas, expected):\n+        \"\"\"Test that the mapping is correct if there are operators with work wires\n+        (and measurements).\n+        \"\"\"\n+        tape = QuantumScript(ops, meas)\n+        wire_map = tape._get_standard_wire_map()\n+        assert wire_map == expected\n+\n+\n class TestIteration:\n     \"\"\"Test the capabilities related to iterating over quantum script.\"\"\"\n \n", "problem_statement": "[BUG] `map_to_standard_wires` does not consider work wires\n### Expected behavior\n\ndev level: Mapping the wires of a `QuantumScript` or `QuantumTape` to standard wires via `map_to_standard_wires` works even if there are work wires used in the circuit.\n\nuser level: Executing a circuit with work wires like the one in the example below works without a problem.\n\n### Actual behavior\n\nMapping the circuit wires does not succeed if work wires are used that are not un-occupied in the new wire mapping (see example below).\nLikewise, execution fails in that case.\n\n### Additional information\n\nThis problem is not surprising, given that \n- `map_to_standard_wires` only considers the property `op.wires` for each `op` in the script/tape\n- `op.wires` (sometimes) do not contain work wires. (c.f. #7204)\n\nNote that in order to solve this bug, one has to think about how work wires should be handled if the operation is not decomposed to actually use them. @isaacdevlugt I think this is a good data point arising from a practical implementation regarding the ongoing discussion about this.\n\n### Source code\n\n```shell\nop = qml.MultiControlledX([0, 2, 3, 4], work_wires=[1])\ntape = qml.tape.QuantumScript([op])\ntape.map_to_standard_wires() # Raises ValueError\n\n@qml.qnode(qml.device(\"default.qubit\"))\ndef circ(): \n    qml.apply(op)\n    return qml.probs()\ncirc() # Raises ValueError based on ValueError for `map_to_standard_wires`\n```\n\n### Tracebacks\n\n```shell\n---------------------------------------------------------------------------\nValueError                                Traceback (most recent call last)\nCell In[17], line 3\n      1 ops = [qml.MultiControlledX([0, 2, 3, 4], work_wires=[1])]\n      2 tape = qml.tape.QuantumScript(ops)\n----> 3 print(tape.map_to_standard_wires().operations[0].work_wires)\n\nFile ~/repos/pennylane/pennylane/tape/qscript.py:1340, in QuantumScript.map_to_standard_wires(self)\n   1337     return self\n   1339 wire_map = {w: i for i, w in enumerate(op_wires + meas_only_wires)}\n-> 1340 tapes, fn = qml.map_wires(self, wire_map)\n   1341 return fn(tapes)\n\nFile ~/repos/pennylane/pennylane/ops/functions/map_wires.py:229, in map_wires(input, wire_map, queue, replace)\n    227         return new_op\n    228     return input.map_wires(wire_map=wire_map)\n--> 229 return _map_wires_transform(input, wire_map=wire_map, queue=queue)\n\nFile ~/repos/pennylane/pennylane/transforms/core/transform_dispatcher.py:254, in TransformDispatcher.__call__(self, *targs, **tkwargs)\n    251         return expand_processing(processed_results)\n    253 else:\n--> 254     transformed_tapes, processing_fn = self._transform(obj, *targs, **tkwargs)\n    256 if self.is_informative:\n    257     return processing_fn(transformed_tapes)\n\nFile ~/repos/pennylane/pennylane/ops/functions/map_wires.py:241, in _map_wires_transform(tape, wire_map, queue)\n    237 @partial(transform, plxpr_transform=map_wires_plxpr_to_plxpr)\n    238 def _map_wires_transform(\n    239     tape: QuantumScript, wire_map=None, queue=False\n    240 ) -> tuple[QuantumScriptBatch, PostprocessingFn]:\n--> 241     ops = [\n    242         (\n    243             map_wires(op, wire_map, queue=queue)\n    244             if not isinstance(op, QuantumScript)\n    245             else map_wires(op, wire_map, queue=queue)[0][0]\n    246         )\n    247         for op in tape.operations\n    248     ]\n    249     measurements = [map_wires(m, wire_map, queue=queue) for m in tape.measurements]\n    251     out = tape.__class__(\n    252         ops=ops, measurements=measurements, shots=tape.shots, trainable_params=tape.trainable_params\n    253     )\n\nFile ~/repos/pennylane/pennylane/ops/functions/map_wires.py:243, in <listcomp>(.0)\n    237 @partial(transform, plxpr_transform=map_wires_plxpr_to_plxpr)\n    238 def _map_wires_transform(\n    239     tape: QuantumScript, wire_map=None, queue=False\n    240 ) -> tuple[QuantumScriptBatch, PostprocessingFn]:\n    241     ops = [\n    242         (\n--> 243             map_wires(op, wire_map, queue=queue)\n    244             if not isinstance(op, QuantumScript)\n    245             else map_wires(op, wire_map, queue=queue)[0][0]\n    246         )\n    247         for op in tape.operations\n    248     ]\n    249     measurements = [map_wires(m, wire_map, queue=queue) for m in tape.measurements]\n    251     out = tape.__class__(\n    252         ops=ops, measurements=measurements, shots=tape.shots, trainable_params=tape.trainable_params\n    253     )\n\nFile ~/repos/pennylane/pennylane/ops/functions/map_wires.py:228, in map_wires(input, wire_map, queue, replace)\n    226             qml.apply(new_op)\n    227         return new_op\n--> 228     return input.map_wires(wire_map=wire_map)\n    229 return _map_wires_transform(input, wire_map=wire_map, queue=queue)\n\nFile ~/repos/pennylane/pennylane/ops/op_math/controlled.py:616, in Controlled.map_wires(self, wire_map)\n    613 new_control_wires = Wires([wire_map.get(wire, wire) for wire in self.control_wires])\n    614 new_work_wires = Wires([wire_map.get(wire, wire) for wire in self.work_wires])\n--> 616 return ctrl(\n    617     op=new_base,\n    618     control=new_control_wires,\n    619     control_values=self.control_values,\n    620     work_wires=new_work_wires,\n    621 )\n\nFile ~/repos/pennylane/pennylane/ops/op_math/controlled.py:151, in ctrl(op, control, control_values, work_wires)\n    149 if qml.math.is_abstract(op):\n    150     return Controlled(op, control, control_values=control_values, work_wires=work_wires)\n--> 151 return create_controlled_op(op, control, control_values=control_values, work_wires=work_wires)\n\nFile ~/repos/pennylane/pennylane/ops/op_math/controlled.py:176, in create_controlled_op(op, control, control_values, work_wires)\n    174 if isinstance(op, pauli_x_based_ctrl_ops):\n    175     qml.QueuingManager.remove(op)\n--> 176     return _handle_pauli_x_based_controlled_ops(op, control, control_values, work_wires)\n    178 # Flatten nested controlled operations to a multi-controlled operation for better\n    179 # decomposition algorithms. This includes special cases like CRX, CRot, etc.\n    180 if isinstance(op, Controlled):\n\nFile ~/repos/pennylane/pennylane/ops/op_math/controlled.py:347, in _handle_pauli_x_based_controlled_ops(op, control, control_values, work_wires)\n    344     return op_map[custom_key](wires=control + op.wires)\n    346 if isinstance(op, qml.PauliX):\n--> 347     return qml.MultiControlledX(\n    348         wires=control + op.wires, control_values=control_values, work_wires=work_wires\n    349     )\n    351 work_wires = work_wires or []\n    352 return qml.MultiControlledX(\n    353     wires=control + op.wires,\n    354     control_values=control_values + op.control_values,\n    355     work_wires=work_wires + op.work_wires,\n    356 )\n\nFile ~/repos/pennylane/pennylane/capture/capture_meta.py:30, in _stop_autograph.<locals>.new_f(*args, **kwargs)\n     29 def new_f(*args, **kwargs):\n---> 30     return f(*args, **kwargs)\n\nFile ~/repos/pennylane/pennylane/capture/capture_meta.py:97, in CaptureMeta.__call__(cls, *args, **kwargs)\n     93 if enabled():\n     94     # when tracing is enabled, we want to\n     95     # use bind to construct the class if we want class construction to add it to the jaxpr\n     96     return cls._primitive_bind_call(*args, **kwargs)\n---> 97 return type.__call__(cls, *args, **kwargs)\n\nFile ~/repos/pennylane/pennylane/ops/op_math/controlled_ops.py:1444, in MultiControlledX.__init__(self, wires, control_values, work_wires, work_wire_type)\n   1441 # We use type.__call__ instead of calling the class directly so that we don't bind the\n   1442 # operator primitive when new program capture is enabled\n   1443 base = type.__call__(qml.X, wires=wires)\n-> 1444 super().__init__(\n   1445     base,\n   1446     control_wires=control_wires,\n   1447     control_values=control_values,\n   1448     work_wires=work_wires,\n   1449 )\n   1450 self._hyperparameters[\"work_wire_type\"] = work_wire_type\n\nFile ~/repos/pennylane/pennylane/ops/op_math/controlled.py:940, in __init__(self, base, control_wires, control_values, work_wires, id)\n    927 class ControlledOp(Controlled, operation.Operation):\n    928     \"\"\"Operation-specific methods and properties for the :class:`~.ops.op_math.Controlled` class.\n    929 \n    930     When an :class:`~.operation.Operation` is provided to the :class:`~.ops.op_math.Controlled`\n   (...)\n    937     .. seealso:: :class:`~.Controlled`\n    938     \"\"\"\n--> 940     def __new__(cls, *_, **__):\n    941         # overrides dispatch behaviour of ``Controlled``\n    942         return object.__new__(cls)\n    944     # pylint: disable=too-many-positional-arguments\n\nFile ~/repos/pennylane/pennylane/ops/op_math/controlled.py:520, in Controlled.__init__(self, base, control_wires, control_values, work_wires, id)\n    517     raise ValueError(\"The control wires must be different from the base operation wires.\")\n    519 if len(Wires.shared_wires([work_wires, base.wires + control_wires])) != 0:\n--> 520     raise ValueError(\n    521         \"Work wires must be different the control_wires and base operation wires.\"\n    522     )\n    524 self.hyperparameters[\"control_wires\"] = control_wires\n    525 self.hyperparameters[\"control_values\"] = control_values\n\nValueError: Work wires must be different the control_wires and base operation wires.\n```\n\n### System information\n\n```shell\npl dev\n```\n\n### Existing GitHub issues\n\n- [x] I have searched existing GitHub issues to make sure the issue does not already exist.\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/PennyLaneAI/pennylane/commit/0cda9ab4f3a9266779614c5f04524fd68bcb0d41", "https://github.com/PennyLaneAI/pennylane/commit/1393de1fb3b2916e653fdedd3b2474ba1441edd6", "https://github.com/PennyLaneAI/pennylane/commit/9a522ea6d06f817f30fdc9738a83b61765bdff70", "https://github.com/PennyLaneAI/pennylane/commit/39c2dfc294ad939f912f9b7722ffb86b10312473", "https://github.com/PennyLaneAI/pennylane/commit/ebec1a478855f04e95bad543e5281a4f4a221baf", "https://github.com/PennyLaneAI/pennylane/commit/10ff8a79f2dd8e034bb08e80fdb2d69e6df08041"], "created_at": "2025-06-02T10:13:16Z"}
{"repo": "PennyLaneAI/pennylane", "pull_number": 7644, "instance_id": "PennyLaneAI__pennylane-7644", "issue_numbers": [7643], "base_commit": "be5ef993d84f86afe0d79ca4cbe0c775da3897ad", "patch": "diff --git a/doc/releases/changelog-dev.md b/doc/releases/changelog-dev.md\nindex 8b62cd6813c..02dcf14c2ec 100644\n--- a/doc/releases/changelog-dev.md\n+++ b/doc/releases/changelog-dev.md\n@@ -364,6 +364,13 @@\n \n <h3>Improvements \ud83d\udee0</h3>\n \n+* Caching with finite shots now always warns about the lack of expected noise.\n+  [(#7644)](https://github.com/PennyLaneAI/pennylane/pull/7644)\n+\n+* `cache` now defaults to `\"auto\"` with `qml.execute`, matching the behavior of `QNode` and reducing the \n+  performance cost of using `qml.execute` for standard executions.\n+  [(#7644)](https://github.com/PennyLaneAI/pennylane/pull/7644)\n+\n * `qml.grad` and `qml.jacobian` can now handle inputs with dynamic shapes being captured into plxpr.\n   [(#7544)](https://github.com/PennyLaneAI/pennylane/pull/7544/)\n \n@@ -547,6 +554,10 @@\n \n <h3>Breaking changes \ud83d\udc94</h3>\n \n+* The default value of `cache` is now `\"auto\"` with `qml.execute`. Like `QNode`, `\"auto\"` only turns on caching\n+  when `max_diff > 1`.\n+  [(#7644)](https://github.com/PennyLaneAI/pennylane/pull/7644)\n+\n * A new decomposition for two-qubit unitaries was implemented in `two_qubit_decomposition`.\n   It ensures the correctness of the decomposition in some edge cases but uses 3 CNOT gates\n   even if 2 CNOTs would suffice theoretically.\ndiff --git a/pennylane/workflow/_cache_transform.py b/pennylane/workflow/_cache_transform.py\nindex 03dc85640a9..70262b5cf81 100644\n--- a/pennylane/workflow/_cache_transform.py\n+++ b/pennylane/workflow/_cache_transform.py\n@@ -43,7 +43,7 @@ def _cache_transform(tape: QuantumScript, cache: MutableMapping):\n     def cache_hit_postprocessing(_results: ResultBatch) -> Result:\n         result = cache[tape.hash]\n         if result is not None:\n-            if tape.shots and getattr(cache, \"_persistent_cache\", True):\n+            if tape.shots:\n                 warnings.warn(_CACHED_EXECUTION_WITH_FINITE_SHOTS_WARNINGS, UserWarning)\n             return result\n \ndiff --git a/pennylane/workflow/_setup_transform_program.py b/pennylane/workflow/_setup_transform_program.py\nindex fd1ba0c3c0e..325e5e0be3f 100644\n--- a/pennylane/workflow/_setup_transform_program.py\n+++ b/pennylane/workflow/_setup_transform_program.py\n@@ -90,9 +90,13 @@ def _setup_transform_program(\n     _prune_dynamic_transform(outer_transform_program, inner_transform_program)\n \n     # If caching is desired but an explicit cache is not provided, use an ``LRUCache``.\n+    if cache == \"auto\":\n+        if resolved_execution_config.derivative_order == 1:\n+            cache = None\n+        else:\n+            cache = True\n     if cache is True:\n         cache = LRUCache(maxsize=cachesize)\n-        setattr(cache, \"_persistent_cache\", False)\n \n     # Ensure that ``cache`` is not a Boolean to simplify downstream code.\n     elif cache is False:\ndiff --git a/pennylane/workflow/execution.py b/pennylane/workflow/execution.py\nindex d42450d56ae..97aa4dbc083 100644\n--- a/pennylane/workflow/execution.py\n+++ b/pennylane/workflow/execution.py\n@@ -47,7 +47,7 @@ def execute(\n     *,\n     transform_program: TransformProgram = None,\n     grad_on_execution: Literal[True, False, \"best\"] = \"best\",\n-    cache: Union[None, bool, dict, Cache] = True,\n+    cache: Union[None, bool, dict, Cache, Literal[\"auto\"]] = \"auto\",\n     cachesize: int = 10000,\n     max_diff: int = 1,\n     device_vjp: Union[bool, None] = False,\n@@ -75,8 +75,13 @@ def execute(\n             if the device is queried for the gradient; gradient transform\n             functions available in ``qml.gradients`` are only supported on the backward\n             pass. The 'best' option chooses automatically between the two options and is default.\n-        cache (None, bool, dict, Cache): Whether to cache evaluations. This can result in\n-            a significant reduction in quantum evaluations during gradient computations.\n+        cache=\"auto\" (str or bool or dict or Cache): Whether to cache evalulations.\n+            ``\"auto\"`` indicates to cache only when ``max_diff > 1``. This can result in\n+            a reduction in quantum evaluations during higher order gradient computations.\n+            If ``True``, a cache with corresponding ``cachesize`` is created for each batch\n+            execution. If ``False``, no caching is used. You may also pass your own cache\n+            to be used; this can be any object that implements the special methods\n+            ``__getitem__()``, ``__setitem__()``, and ``__delitem__()``, such as a dictionary.\n         cachesize (int): the size of the cache.\n         max_diff (int): If ``diff_method`` is a gradient transform, this option specifies\n             the maximum number of derivatives to support. Increasing this value allows\ndiff --git a/pennylane/workflow/qnode.py b/pennylane/workflow/qnode.py\nindex 7563bb9dc82..47bbb697901 100644\n--- a/pennylane/workflow/qnode.py\n+++ b/pennylane/workflow/qnode.py\n@@ -613,7 +613,6 @@ def __init__(\n             _validate_jax_version()\n         self.diff_method = diff_method\n         _validate_diff_method(self.device, self.diff_method)\n-        cache = (max_diff > 1) if cache == \"auto\" else cache\n \n         self.capture_cache = LRUCache(maxsize=1000)\n         if isinstance(static_argnums, int):\n", "test_patch": "diff --git a/tests/test_qnode.py b/tests/test_qnode.py\nindex ceb261d0092..d801fc77101 100644\n--- a/tests/test_qnode.py\n+++ b/tests/test_qnode.py\n@@ -229,7 +229,7 @@ def test_cache_initialization_maxdiff_1(self):\n         def f():\n             return qml.state()\n \n-        assert f.execute_kwargs[\"cache\"] is False\n+        assert f.execute_kwargs[\"cache\"] == \"auto\"\n \n     def test_cache_initialization_maxdiff_2(self):\n         \"\"\"Test that when max_diff = 2, the cache initialization to True.\"\"\"\n@@ -238,7 +238,7 @@ def test_cache_initialization_maxdiff_2(self):\n         def f():\n             return qml.state()\n \n-        assert f.execute_kwargs[\"cache\"] is True\n+        assert f.execute_kwargs[\"cache\"] == \"auto\"\n \n \n # pylint: disable=too-many-public-methods\n@@ -1394,6 +1394,20 @@ def test_warning_finite_shots_tape(self):\n         with pytest.warns(UserWarning, match=\"Cached execution with finite shots detected\"):\n             qml.execute([tape], dev, None, cache=cache)\n \n+        cache2 = {}\n+        with pytest.warns(UserWarning, match=\"Cached execution with finite shots detected\"):\n+            qml.execute([tape, tape], dev, cache=cache2)\n+\n+    def test_no_caching_by_default(self):\n+        \"\"\"Test that caching is turned off by default.\"\"\"\n+\n+        dev = qml.device(\"default.qubit\", wires=1)\n+\n+        tape = qml.tape.QuantumScript([qml.H(0)], [qml.sample(wires=0)], shots=1000)\n+\n+        res1, res2 = qml.execute([tape, tape], dev)\n+        assert not np.allclose(res1, res2)\n+\n     def test_no_warning_infinite_shots(self):\n         \"\"\"Tests that no warning is raised when caching is used with infinite shots.\"\"\"\n         dev = qml.device(\"default.qubit\", wires=1)\ndiff --git a/tests/workflow/interfaces/execute/test_jax_jit.py b/tests/workflow/interfaces/execute/test_jax_jit.py\nindex bb3285a8784..c8aa45fc38c 100644\n--- a/tests/workflow/interfaces/execute/test_jax_jit.py\n+++ b/tests/workflow/interfaces/execute/test_jax_jit.py\n@@ -195,6 +195,7 @@ def cost(a, cachesize):\n                 [tape],\n                 dev,\n                 diff_method=param_shift,\n+                cache=True,\n                 cachesize=cachesize,\n             )[0]\n \ndiff --git a/tests/workflow/interfaces/test_transform_program_integration.py b/tests/workflow/interfaces/test_transform_program_integration.py\nindex c346ea86810..bf0dc9b5c9c 100644\n--- a/tests/workflow/interfaces/test_transform_program_integration.py\n+++ b/tests/workflow/interfaces/test_transform_program_integration.py\n@@ -156,7 +156,7 @@ def split_sum_terms(tape):\n         )\n         with dev.tracker:\n             results = qml.execute(\n-                (tape1, tape2, tape3), dev, interface=interface, transform_program=prog\n+                (tape1, tape2, tape3), dev, interface=interface, transform_program=prog, cache=True\n             )\n \n         assert qml.math.allclose(results[0], np.cos(1.2))\ndiff --git a/tests/workflow/test_cache_transform.py b/tests/workflow/test_cache_transform.py\nindex a270387f1ea..41087a40e80 100644\n--- a/tests/workflow/test_cache_transform.py\n+++ b/tests/workflow/test_cache_transform.py\n@@ -101,13 +101,13 @@ def test_batch_of_identical_tapes(cache):\n     assert batch_fns((result,)) == (result, result, result)\n \n \n-def test_finite_shots_with_persistent_cache_warning(cache):\n+def test_finite_shots_with_persistent_cache_warning():\n     \"\"\"Tests that a UserWarning is emitted if a cache hit occurs for a tape with\n-    finite shots that uses a persistent cache.\n+    finite shots that uses a cache.\n     \"\"\"\n     tape = QuantumScript([], [qml.expval(qml.Z(0))], shots=1)\n \n-    batch_tapes, batch_fns = _cache_transform([tape, tape], cache=cache)\n+    batch_tapes, batch_fns = _cache_transform([tape, tape], cache={})\n     assert len(batch_tapes) == 1\n \n     with pytest.warns(UserWarning, match=r\"Cached execution with finite shots detected!\"):\n", "problem_statement": "[BUG] Repeated outputs from single-shot tape batches due to shared RNG/cache\n### Expected behavior\n\nGet random behaviour when executing a batch of tapes using `qml.execute` or a warning about cache. \n\n### Actual behavior\n\nIf we have a list of tapes with the same tape, each execution gives the same results (due to cache being on by default)\n\n### Additional information\n\nThis has been discussed on a Slack thread and comes from a question in the [PL forum.](https://discuss.pennylane.ai/t/pennylane-quantum-tapes-yield-different-outcomes/8551) \n\nThe suggested 'solution' is to always warn when caching is on and users request shots/sampling.\naligning `qml.execute` caching behavior with `QNode`\n\n### Source code\n\n```shell\n### List of tapes (same tape n times)\nimport pennylane as qml\nfrom pennylane import numpy as np\n\nnp.random.seed(666)\n\npauli_map = {0: qml.Identity, 1: qml.PauliX, 2: qml.PauliY, 3: qml.PauliZ}\n\nn_qubits=2\nn_tapes=10\n\ndev = qml.device(\"lightning.qubit\", wires=n_qubits, shots=1)\n\nmeasurements = [qml.expval(pauli_map[i](i)) for i in range(n_qubits)]\nops=[qml.RY(0.5, wires=1)]\ntape_list=[]\nfor i in range(n_tapes):\n\ttape = qml.tape.QuantumTape(ops=ops, measurements=measurements, shots=1)\n\ttape_list.append(tape)\n\noutcomes=qml.execute(tape_list, device=dev, diff_method=None)\nprint(outcomes)\n```\n\n### Tracebacks\n\n```shell\n\n```\n\n### System information\n\n```shell\nnot relevant\n```\n\n### Existing GitHub issues\n\n- [x] I have searched existing GitHub issues to make sure the issue does not already exist.\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/PennyLaneAI/pennylane/commit/716bf5866810113f1f389273fcaf9507376259d7", "https://github.com/PennyLaneAI/pennylane/commit/9c85b23bab7e3156b8884020e171fc8992aaacc4", "https://github.com/PennyLaneAI/pennylane/commit/4598cfb9e6fdc7dc95e75822b3d64071bf0425bd", "https://github.com/PennyLaneAI/pennylane/commit/ec24db6e9c6ea56a83ee2deaa5fba6a4f0a5caf3", "https://github.com/PennyLaneAI/pennylane/commit/3c66f220e56c830210e3bdbcb42dbaba7434bb22", "https://github.com/PennyLaneAI/pennylane/commit/a642b82dc6f672ec69ff749c957f67bda1355abe", "https://github.com/PennyLaneAI/pennylane/commit/c15365b26b6160dd456690649a83a9addfd649f5", "https://github.com/PennyLaneAI/pennylane/commit/2dc5aa36303ca4ced08c19a61ae0fc6456546315"], "created_at": "2025-06-10T15:04:34Z"}
{"repo": "PennyLaneAI/pennylane", "pull_number": 7668, "instance_id": "PennyLaneAI__pennylane-7668", "issue_numbers": [7659], "base_commit": "297db3875bf5d9ebae155838c0b8d753358207ed", "patch": "diff --git a/doc/releases/changelog-dev.md b/doc/releases/changelog-dev.md\nindex 6a4d6a6e59b..cad043c9b3a 100644\n--- a/doc/releases/changelog-dev.md\n+++ b/doc/releases/changelog-dev.md\n@@ -806,6 +806,11 @@ Here's a list of deprecations made this release. For a more detailed breakdown o\n \n <h3>Bug fixes \ud83d\udc1b</h3>\n \n+* A bug in `qml.draw_mpl` for circuits with work wires has been fixed. The previously\n+  inconsistent mapping for these wires has been resolved, ensuring accurate assignment during\n+  drawing.\n+  [(#7668)](https://github.com/PennyLaneAI/pennylane/pull/7668)\n+\n * A bug in `ops.op_math.Prod.simplify()` has been fixed that led to global phases being discarded\n   in special cases. Concretely, this problem occurs when Pauli factors combine into the identity\n   up to a global phase _and_ there is no Pauli representation of the product operator.\ndiff --git a/pennylane/drawer/drawable_layers.py b/pennylane/drawer/drawable_layers.py\nindex 98a91652959..9a4b267582b 100644\n--- a/pennylane/drawer/drawable_layers.py\n+++ b/pennylane/drawer/drawable_layers.py\n@@ -149,7 +149,7 @@ def drawable_layers(operations, wire_map=None, bit_map=None):\n \n     \"\"\"\n \n-    wire_map = wire_map or default_wire_map(operations)\n+    wire_map = wire_map or default_wire_map(operations)[1]\n     bit_map = bit_map or {}\n \n     # initialize for operation layers\ndiff --git a/pennylane/drawer/tape_mpl.py b/pennylane/drawer/tape_mpl.py\nindex 1ef83cab025..cc1477b7856 100644\n--- a/pennylane/drawer/tape_mpl.py\n+++ b/pennylane/drawer/tape_mpl.py\n@@ -289,9 +289,11 @@ def _tape_mpl(tape, wire_order=None, show_all_wires=False, max_length=None, **kw\n         When max_length is None: tuple(Figure, Axes) for the complete circuit\n         Otherwise: list[tuple(Figure, Axes)] with one pair per circuit segment\n     \"\"\"\n-    wire_map = convert_wire_order(tape, wire_order=wire_order, show_all_wires=show_all_wires)\n+    full_wire_map, used_wire_map = convert_wire_order(\n+        tape, wire_order=wire_order, show_all_wires=show_all_wires\n+    )\n     tape = transform_deferred_measurements_tape(tape)\n-    tape = ops.functions.map_wires(tape, wire_map=wire_map)[0][0]\n+    tape = ops.functions.map_wires(tape, wire_map=full_wire_map)[0][0]\n     bit_map = default_bit_map(tape)\n \n     layers = drawable_layers(tape.operations, wire_map={i: i for i in tape.wires}, bit_map=bit_map)\n@@ -311,7 +313,9 @@ def _tape_mpl(tape, wire_order=None, show_all_wires=False, max_length=None, **kw\n     )\n \n     if max_length is None:\n-        return _draw_layers(layers, tape.measurements, config=config, wire_map=wire_map, **kwargs)\n+        return _draw_layers(\n+            layers, tape.measurements, config=config, wire_map=used_wire_map, **kwargs\n+        )\n \n     layer_count = len(layers)\n     return [\n@@ -319,7 +323,7 @@ def _tape_mpl(tape, wire_order=None, show_all_wires=False, max_length=None, **kw\n             layers=layers[i : i + max_length],\n             measurements=tape.measurements if i + max_length >= layer_count else \"dots\",\n             config=config,\n-            wire_map=wire_map,\n+            wire_map=used_wire_map,\n             starting_dots=i > 0,\n             **kwargs,\n         )\ndiff --git a/pennylane/drawer/tape_text.py b/pennylane/drawer/tape_text.py\nindex 5db64c61bbd..ffb1d2c861f 100644\n--- a/pennylane/drawer/tape_text.py\n+++ b/pennylane/drawer/tape_text.py\n@@ -414,7 +414,7 @@ def tape_text(\n     cache.setdefault(\"matrices\", [])\n     tape_cache = []\n \n-    wire_map = convert_wire_order(tape, wire_order=wire_order, show_all_wires=show_all_wires)\n+    _, wire_map = convert_wire_order(tape, wire_order=wire_order, show_all_wires=show_all_wires)\n     bit_map = default_bit_map(tape)\n     n_wires = len(wire_map)\n     if n_wires == 0:\ndiff --git a/pennylane/drawer/utils.py b/pennylane/drawer/utils.py\nindex 8a33479d03c..6d39796e189 100644\n--- a/pennylane/drawer/utils.py\n+++ b/pennylane/drawer/utils.py\n@@ -27,12 +27,19 @@ def default_wire_map(tape):\n         tape [~.tape.QuantumTape): the QuantumTape containing operations and measurements\n \n     Returns:\n-        dict: map from wires to sequential positive integers\n+        tuple[dict]: A tuple of maps from wires to sequential positive integers. The first map\n+        includes work wires whereas the second map excludes work wires.\n     \"\"\"\n \n     # Use dictionary to preserve ordering, sets break order\n     used_wires = {wire: None for op in tape for wire in op.wires}\n-    return {wire: ind for ind, wire in enumerate(used_wires)}\n+    used_wire_map = {wire: ind for ind, wire in enumerate(used_wires)}\n+    # Will only add wires that are not present in used_wires yet, and to the end of used_wires\n+    used_and_work_wires = used_wires | {\n+        wire: None for op in tape for wire in getattr(op, \"work_wires\", [])\n+    }\n+    full_wire_map = {wire: ind for ind, wire in enumerate(used_and_work_wires)}\n+    return full_wire_map, used_wire_map\n \n \n def default_bit_map(tape):\n@@ -83,20 +90,29 @@ def convert_wire_order(tape, wire_order=None, show_all_wires=False):\n             or only include ones used by operations in ``ops``\n \n     Returns:\n-        dict: map from wire labels to sequential positive integers\n+        tuple[dict]: Two maps from wire labels to sequential positive integers. The first map\n+        includes work wires, the second map excludes work wires.\n     \"\"\"\n-    default = default_wire_map(tape)\n+    full_wire_map, used_wire_map = default_wire_map(tape)\n \n     if wire_order is None:\n-        return default\n+        # If no external wire order is dictated, the tape ordering is all we need to consider\n+        return full_wire_map, used_wire_map\n \n-    wire_order = list(wire_order) + [wire for wire in default if wire not in wire_order]\n+    # Create wire order complemented by all wires in the tape mapping that are not in the order yet\n+    full_wire_order = list(wire_order) + [wire for wire in full_wire_map if wire not in wire_order]\n+    used_wire_order = list(wire_order) + [wire for wire in used_wire_map if wire not in wire_order]\n \n     if not show_all_wires:\n-        used_wires = {wire for op in tape for wire in op.wires}\n-        wire_order = [wire for wire in wire_order if wire in used_wires]\n+        # Filter out wires that are in wire_order but not in full_wire_map/used_wire_map\n+        full_wire_order = [wire for wire in full_wire_order if wire in full_wire_map]\n+        used_wire_order = [wire for wire in used_wire_order if wire in used_wire_map]\n+\n+    # Create consecutive integer mapping from ordered list\n+    full_wire_map = {wire: ind for ind, wire in enumerate(full_wire_order)}\n+    used_wire_map = {wire: ind for ind, wire in enumerate(used_wire_order)}\n \n-    return {wire: ind for ind, wire in enumerate(wire_order)}\n+    return full_wire_map, used_wire_map\n \n \n def unwrap_controls(op):\n", "test_patch": "diff --git a/tests/drawer/test_drawer_utils.py b/tests/drawer/test_drawer_utils.py\nindex 179e0c3087e..8daafd48b41 100644\n--- a/tests/drawer/test_drawer_utils.py\n+++ b/tests/drawer/test_drawer_utils.py\n@@ -34,24 +34,40 @@ class TestDefaultWireMap:\n     def test_empty(self):\n         \"\"\"Test creating an empty wire map\"\"\"\n \n-        wire_map = default_wire_map([])\n-        assert wire_map == {}\n+        full_wire_map, used_wire_map = default_wire_map([])\n+        assert full_wire_map == used_wire_map == {}\n \n     def test_simple(self):\n         \"\"\"Test creating a wire map with wires that do not have successive ordering\"\"\"\n \n         ops = [qml.PauliX(0), qml.PauliX(2), qml.PauliX(1)]\n \n-        wire_map = default_wire_map(ops)\n-        assert wire_map == {0: 0, 2: 1, 1: 2}\n+        full_wire_map, used_wire_map = default_wire_map(ops)\n+        assert full_wire_map == used_wire_map == {0: 0, 2: 1, 1: 2}\n \n     def test_string_wires(self):\n         \"\"\"Test wire map works with string labelled wires.\"\"\"\n \n         ops = [qml.PauliY(\"a\"), qml.CNOT(wires=(\"b\", \"c\"))]\n \n-        wire_map = default_wire_map(ops)\n-        assert wire_map == {\"a\": 0, \"b\": 1, \"c\": 2}\n+        full_wire_map, used_wire_map = default_wire_map(ops)\n+        assert full_wire_map == used_wire_map == {\"a\": 0, \"b\": 1, \"c\": 2}\n+\n+    def test_work_wires(self):\n+        \"\"\"Test wire map works with string work wires, leading to a difference\n+        between full_wire_map and used_wire_map.\"\"\"\n+\n+        ops = [qml.PauliY(\"a\"), qml.MultiControlledX([\"b\", 0, 9, 4], work_wires=[1, 5, \"a\"])]\n+\n+        full_wire_map, used_wire_map = default_wire_map(ops)\n+        assert full_wire_map == {\"a\": 0, \"b\": 1, 0: 2, 9: 3, 4: 4, 1: 5, 5: 6}\n+        assert used_wire_map == {\"a\": 0, \"b\": 1, 0: 2, 9: 3, 4: 4}\n+\n+        ops = [qml.MultiControlledX([\"b\", 0, 9, 4], work_wires=[1, 5, \"a\"]), qml.PauliY(\"a\")]\n+        full_wire_map, used_wire_map = default_wire_map(ops)\n+        # Work-only wires always come after used wires\n+        assert full_wire_map == {\"b\": 0, 0: 1, 9: 2, 4: 3, \"a\": 4, 1: 5, 5: 6}\n+        assert used_wire_map == {\"b\": 0, 0: 1, 9: 2, 4: 3, \"a\": 4}\n \n \n class TestDefaultBitMap:\n@@ -88,9 +104,8 @@ def test_no_wire_order(self):\n \n         ops = [qml.PauliX(0), qml.PauliX(2), qml.PauliX(1)]\n \n-        wire_map = convert_wire_order(ops)\n-\n-        assert wire_map == {0: 0, 2: 1, 1: 2}\n+        full_wire_map, used_wire_map = convert_wire_order(ops)\n+        assert full_wire_map == used_wire_map == {0: 0, 2: 1, 1: 2}\n \n     def test_wire_order_ints(self):\n         \"\"\"Tests wire map produced when initial wires are integers.\"\"\"\n@@ -98,8 +113,8 @@ def test_wire_order_ints(self):\n         ops = [qml.PauliX(0), qml.PauliX(2), qml.PauliX(1)]\n         wire_order = [2, 1, 0]\n \n-        wire_map = convert_wire_order(ops, wire_order)\n-        assert wire_map == {2: 0, 1: 1, 0: 2}\n+        full_wire_map, used_wire_map = convert_wire_order(ops, wire_order)\n+        assert full_wire_map == used_wire_map == {2: 0, 1: 1, 0: 2}\n \n     def test_wire_order_str(self):\n         \"\"\"Test wire map produced when initial wires are strings.\"\"\"\n@@ -107,8 +122,8 @@ def test_wire_order_str(self):\n         ops = [qml.CNOT(wires=(\"a\", \"b\")), qml.PauliX(\"c\")]\n         wire_order = (\"c\", \"b\", \"a\")\n \n-        wire_map = convert_wire_order(ops, wire_order)\n-        assert wire_map == {\"c\": 0, \"b\": 1, \"a\": 2}\n+        full_wire_map, used_wire_map = convert_wire_order(ops, wire_order)\n+        assert full_wire_map == used_wire_map == {\"c\": 0, \"b\": 1, \"a\": 2}\n \n     def test_show_all_wires_false(self):\n         \"\"\"Test when `show_all_wires` is set to `False` only used wires are in the map.\"\"\"\n@@ -116,17 +131,43 @@ def test_show_all_wires_false(self):\n         ops = [qml.PauliX(\"a\"), qml.PauliY(\"c\")]\n         wire_order = [\"a\", \"b\", \"c\", \"d\"]\n \n-        wire_map = convert_wire_order(ops, wire_order, show_all_wires=False)\n-        assert wire_map == {\"a\": 0, \"c\": 1}\n+        full_wire_map, used_wire_map = convert_wire_order(ops, wire_order, show_all_wires=False)\n+        assert full_wire_map == used_wire_map == {\"a\": 0, \"c\": 1}\n \n     def test_show_all_wires_true(self):\n         \"\"\"Test when `show_all_wires` is set to `True` everything in ``wire_order`` is included.\"\"\"\n \n-        ops = [qml.PauliX(\"a\"), qml.PauliY(\"c\")]\n+        ops = [qml.X(\"a\"), qml.PauliY(\"c\")]\n         wire_order = [\"a\", \"b\", \"c\", \"d\"]\n \n-        wire_map = convert_wire_order(ops, wire_order, show_all_wires=True)\n-        assert wire_map == {\"a\": 0, \"b\": 1, \"c\": 2, \"d\": 3}\n+        full_wire_map, used_wire_map = convert_wire_order(ops, wire_order, show_all_wires=True)\n+        assert full_wire_map == used_wire_map == {\"a\": 0, \"b\": 1, \"c\": 2, \"d\": 3}\n+\n+    def test_with_work_wires(self):\n+        \"\"\"Tests wire map produced when work wires are present.\"\"\"\n+\n+        ops = [qml.X(0), qml.ctrl(qml.X(2), control=[3, 1, 5], work_wires=[4, 0]), qml.X(1)]\n+\n+        # The work-only wire 4 does not show up in used_wire_map\n+        full_wire_map, used_wire_map = convert_wire_order(ops, None)\n+        # Control wires are added before target wires\n+        assert full_wire_map == {0: 0, 3: 1, 1: 2, 5: 3, 2: 4, 4: 5}\n+        assert used_wire_map == {0: 0, 3: 1, 1: 2, 5: 3, 2: 4}\n+\n+    def test_with_work_wires_wire_order(self):\n+        \"\"\"Tests wire map produced when work wires are present.\"\"\"\n+\n+        ops = [qml.X(0), qml.ctrl(qml.X(2), control=[3, 1, 5], work_wires=[4, 0]), qml.X(1)]\n+\n+        wire_order = [2, 1, 0, 4]\n+        # If we set show_all_wires to False, the work-only wire 4 does not show in used_wire_map\n+        full_wire_map, used_wire_map = convert_wire_order(ops, wire_order, show_all_wires=False)\n+        assert full_wire_map == {2: 0, 1: 1, 0: 2, 4: 3, 3: 4, 5: 5}\n+        assert used_wire_map == {2: 0, 1: 1, 0: 2, 3: 3, 5: 4}\n+\n+        # If we set show_all_wires to True, the work-only wire 4 also appears in used_wire_map\n+        full_wire_map, used_wire_map = convert_wire_order(ops, wire_order, show_all_wires=True)\n+        assert full_wire_map == used_wire_map == {2: 0, 1: 1, 0: 2, 4: 3, 3: 4, 5: 5}\n \n \n class TestUnwrapControls:\n", "problem_statement": "[BUG] `draw_mpl` is not fully compatible with work wires\n### Expected behavior\n\nA circuit can be drawn even if the operators contain work wires (that are not to be drawn!)\n\n### Actual behavior\n\nMapping around wires fails in `draw_mpl` if there are work wires present that get overwritten.\n\n\n### Additional information\n\nThis is quite similar to #7580 , fixed in #7581 .\n\n### Source code\n\n```shell\nimport pennylane as qml\n\n\ndev = qml.device(\"default.qubit\")\n@qml.qnode(dev)\ndef circuit():\n\n    qml.ctrl(qml.CRZ(0.5, [0, 2]), control=[3], work_wires=[1])\n    return qml.probs(wires=[3])\n\nqml.draw_mpl(circuit)()\n```\n\n### Tracebacks\n\n```shell\n---------------------------------------------------------------------------\nValueError                                Traceback (most recent call last)\nCell In[5], line 11\n      8     qml.ctrl(qml.CRZ(0.5, [0, 2]), control=[3], work_wires=[1])\n      9     return qml.probs(wires=[3])\n---> 11 qml.draw_mpl(circuit)()\n\nFile ~/repos/pennylane/pennylane/drawer/draw.py:858, in _draw_mpl_qnode.<locals>.wrapper(*args, **kwargs_qnode)\n    855     except TypeError:\n    856         _wire_order = tape.wires\n--> 858 return tape_mpl(\n    859     tape,\n    860     wire_order=_wire_order,\n    861     show_all_wires=show_all_wires,\n    862     decimals=decimals,\n    863     style=style,\n    864     fig=fig,\n    865     **kwargs,\n    866 )\n\nFile ~/repos/pennylane/pennylane/drawer/tape_mpl.py:545, in tape_mpl(tape, wire_order, show_all_wires, decimals, style, fig, max_length, **kwargs)\n    542     _set_style(style)\n    544 try:\n--> 545     return _tape_mpl(\n    546         tape,\n    547         wire_order=wire_order,\n    548         show_all_wires=show_all_wires,\n    549         decimals=decimals,\n    550         fig=fig,\n    551         max_length=max_length,\n    552         **kwargs,\n    553     )\n    554 finally:\n    555     if update_style:\n    556         # we don't want to mess with how it modifies whether the interface is interactive\n    557         # but we want to restore everything else\n\nFile ~/repos/pennylane/pennylane/drawer/tape_mpl.py:294, in _tape_mpl(tape, wire_order, show_all_wires, max_length, **kwargs)\n    292 wire_map = convert_wire_order(tape, wire_order=wire_order, show_all_wires=show_all_wires)\n    293 tape = transform_deferred_measurements_tape(tape)\n--> 294 tape = ops.functions.map_wires(tape, wire_map=wire_map)[0][0]\n    295 bit_map = default_bit_map(tape)\n    297 layers = drawable_layers(tape.operations, wire_map={i: i for i in tape.wires}, bit_map=bit_map)\n\nFile ~/repos/pennylane/pennylane/ops/functions/map_wires.py:229, in map_wires(input, wire_map, queue, replace)\n    227         return new_op\n    228     return input.map_wires(wire_map=wire_map)\n--> 229 return _map_wires_transform(input, wire_map=wire_map, queue=queue)\n\nFile ~/repos/pennylane/pennylane/transforms/core/transform_dispatcher.py:254, in TransformDispatcher.__call__(self, *targs, **tkwargs)\n    251         return expand_processing(processed_results)\n    253 else:\n--> 254     transformed_tapes, processing_fn = self._transform(obj, *targs, **tkwargs)\n    256 if self.is_informative:\n    257     return processing_fn(transformed_tapes)\n\nFile ~/repos/pennylane/pennylane/ops/functions/map_wires.py:241, in _map_wires_transform(tape, wire_map, queue)\n    237 @partial(transform, plxpr_transform=map_wires_plxpr_to_plxpr)\n    238 def _map_wires_transform(\n    239     tape: QuantumScript, wire_map=None, queue=False\n    240 ) -> tuple[QuantumScriptBatch, PostprocessingFn]:\n--> 241     ops = [\n    242         (\n    243             map_wires(op, wire_map, queue=queue)\n    244             if not isinstance(op, QuantumScript)\n    245             else map_wires(op, wire_map, queue=queue)[0][0]\n    246         )\n    247         for op in tape.operations\n    248     ]\n    249     measurements = [map_wires(m, wire_map, queue=queue) for m in tape.measurements]\n    251     out = tape.__class__(\n    252         ops=ops, measurements=measurements, shots=tape.shots, trainable_params=tape.trainable_params\n    253     )\n\nFile ~/repos/pennylane/pennylane/ops/functions/map_wires.py:243, in <listcomp>(.0)\n    237 @partial(transform, plxpr_transform=map_wires_plxpr_to_plxpr)\n    238 def _map_wires_transform(\n    239     tape: QuantumScript, wire_map=None, queue=False\n    240 ) -> tuple[QuantumScriptBatch, PostprocessingFn]:\n    241     ops = [\n    242         (\n--> 243             map_wires(op, wire_map, queue=queue)\n    244             if not isinstance(op, QuantumScript)\n    245             else map_wires(op, wire_map, queue=queue)[0][0]\n    246         )\n    247         for op in tape.operations\n    248     ]\n    249     measurements = [map_wires(m, wire_map, queue=queue) for m in tape.measurements]\n    251     out = tape.__class__(\n    252         ops=ops, measurements=measurements, shots=tape.shots, trainable_params=tape.trainable_params\n    253     )\n\nFile ~/repos/pennylane/pennylane/ops/functions/map_wires.py:228, in map_wires(input, wire_map, queue, replace)\n    226             qml.apply(new_op)\n    227         return new_op\n--> 228     return input.map_wires(wire_map=wire_map)\n    229 return _map_wires_transform(input, wire_map=wire_map, queue=queue)\n\nFile ~/repos/pennylane/pennylane/ops/op_math/controlled.py:699, in Controlled.map_wires(self, wire_map)\n    696 new_control_wires = Wires([wire_map.get(wire, wire) for wire in self.control_wires])\n    697 new_work_wires = Wires([wire_map.get(wire, wire) for wire in self.work_wires])\n--> 699 return ctrl(\n    700     op=new_base,\n    701     control=new_control_wires,\n    702     control_values=self.control_values,\n    703     work_wires=new_work_wires,\n    704 )\n\nFile ~/repos/pennylane/pennylane/ops/op_math/controlled.py:169, in ctrl(op, control, control_values, work_wires, work_wire_type)\n    161 if math.is_abstract(op):\n    162     return Controlled(\n    163         op,\n    164         control,\n   (...)\n    167         work_wire_type=work_wire_type,\n    168     )\n--> 169 return create_controlled_op(\n    170     op,\n    171     control,\n    172     control_values=control_values,\n    173     work_wires=work_wires,\n    174     work_wire_type=work_wire_type,\n    175 )\n\nFile ~/repos/pennylane/pennylane/ops/op_math/controlled.py:229, in create_controlled_op(op, control, control_values, work_wires, work_wire_type)\n    220     return ctrl(\n    221         op.base,\n    222         control=control + op.control_wires,\n   (...)\n    225         work_wire_type=work_wire_type,\n    226     )\n    228 if isinstance(op, Operator):\n--> 229     return Controlled(\n    230         op,\n    231         control_wires=control,\n    232         control_values=control_values,\n    233         work_wires=work_wires,\n    234         work_wire_type=work_wire_type,\n    235     )\n    237 if not callable(op):\n    238     raise ValueError(\n    239         f\"The object {op} of type {type(op)} is not an Operator or callable. \"\n    240         \"This error might occur if you apply ctrl to a list \"\n    241         \"of operations instead of a function or Operator.\"\n    242     )\n\nFile ~/repos/pennylane/pennylane/capture/capture_meta.py:30, in _stop_autograph.<locals>.new_f(*args, **kwargs)\n     29 def new_f(*args, **kwargs):\n---> 30     return f(*args, **kwargs)\n\nFile ~/repos/pennylane/pennylane/capture/capture_meta.py:97, in CaptureMeta.__call__(cls, *args, **kwargs)\n     93 if enabled():\n     94     # when tracing is enabled, we want to\n     95     # use bind to construct the class if we want class construction to add it to the jaxpr\n     96     return cls._primitive_bind_call(*args, **kwargs)\n---> 97 return type.__call__(cls, *args, **kwargs)\n\nFile ~/repos/pennylane/pennylane/ops/op_math/controlled.py:1048, in ControlledOp.__init__(self, base, control_wires, control_values, work_wires, work_wire_type, id)\n   1039 def __init__(\n   1040     self,\n   1041     base,\n   (...)\n   1046     id=None,\n   1047 ):\n-> 1048     super().__init__(base, control_wires, control_values, work_wires, work_wire_type, id)\n   1049     # check the grad_recipe validity\n   1050     if self.grad_recipe is None:\n   1051         # Make sure grad_recipe is an iterable of correct length instead of None\n\nFile ~/repos/pennylane/pennylane/ops/op_math/controlled.py:597, in Controlled.__init__(self, base, control_wires, control_values, work_wires, work_wire_type, id)\n    594     raise ValueError(\"The control wires must be different from the base operation wires.\")\n    596 if len(Wires.shared_wires([work_wires, base.wires + control_wires])) != 0:\n--> 597     raise ValueError(\n    598         \"Work wires must be different the control_wires and base operation wires.\"\n    599     )\n    601 if work_wire_type not in {\"clean\", \"dirty\"}:\n    602     raise ValueError(\n    603         f\"work_wire_type must be either 'clean' or 'dirty'. Got '{work_wire_type}'.\"\n    604     )\n\nValueError: Work wires must be different the control_wires and base operation wires.\n```\n\n### System information\n\n```shell\npl dev\n```\n\n### Existing GitHub issues\n\n- [x] I have searched existing GitHub issues to make sure the issue does not already exist.\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/PennyLaneAI/pennylane/commit/18275457bb96a942b880c55ea1ffd9b8041f539e", "https://github.com/PennyLaneAI/pennylane/commit/e690ecca9dbe85518bdd62227032150aaf7c4066", "https://github.com/PennyLaneAI/pennylane/commit/6415eae93f55f9f3b398931104dd50e4daed7e1f", "https://github.com/PennyLaneAI/pennylane/commit/0e461d099b1d9f8e3863a0157869fc93429b509b"], "created_at": "2025-06-13T08:57:43Z"}
{"repo": "PennyLaneAI/pennylane", "pull_number": 7689, "instance_id": "PennyLaneAI__pennylane-7689", "issue_numbers": [7660], "base_commit": "07d1abd990a14de89bb5dccad362ac4dfe756959", "patch": "diff --git a/doc/releases/changelog-dev.md b/doc/releases/changelog-dev.md\nindex 5c31c5debb1..142f65e72bb 100644\n--- a/doc/releases/changelog-dev.md\n+++ b/doc/releases/changelog-dev.md\n@@ -639,6 +639,10 @@ Here's a list of deprecations made this release. For a more detailed breakdown o\n \n <h3>Internal changes \u2699\ufe0f</h3>\n \n+* `Pennylane` has been renamed to `pennylane` in the `pyproject.toml` file \n+  to match the expected binary distribution format naming conventions.\n+  [(#7689)](https://github.com/PennyLaneAI/pennylane/pull/7689)\n+\n * The `qml.compiler.python_compiler` submodule has been restructured.\n   [(#7645)](https://github.com/PennyLaneAI/pennylane/pull/7645)\n \ndiff --git a/pyproject.toml b/pyproject.toml\nindex 1fb1e9fe069..7df79f7e226 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -3,7 +3,7 @@ requires = [\"setuptools>=75.8.1\"]\n build-backend = \"setuptools.build_meta\"\n \n [project]\n-name = \"Pennylane\"\n+name = \"pennylane\"\n description = \"PennyLane is a cross-platform Python library for quantum computing, quantum machine learning, and quantum chemistry. Train a quantum computer the same way as a neural network.\"\n readme = \"README.md\"\n license =  \"Apache-2.0\"\n", "test_patch": "", "problem_statement": "`Pennylane` should be `pennylane` in pyproject.toml\nhttps://github.com/PennyLaneAI/pennylane/blob/7f6a2785e29a2cc648954831c69e2cb7716165d3/pyproject.toml#L6\n\nAs above, the project name does not match with the expected binary distribution format naming conventions (see https://packaging.python.org/en/latest/specifications/binary-distribution-format/).\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/PennyLaneAI/pennylane/commit/bd7b9ccef2040289706ff2dc218080678bf8b93e", "https://github.com/PennyLaneAI/pennylane/commit/8a325220f59b976ff4c53c48180be977dfc4a48e", "https://github.com/PennyLaneAI/pennylane/commit/47a37e328d5e64550e967ae4a43aa57d8dc3a5eb"], "created_at": "2025-06-16T14:07:53Z"}
{"repo": "PennyLaneAI/pennylane", "pull_number": 7899, "instance_id": "PennyLaneAI__pennylane-7899", "issue_numbers": [7669], "base_commit": "91d878d280f44afd849d9e536ef768a9fd7d6934", "patch": "diff --git a/doc/releases/changelog-dev.md b/doc/releases/changelog-dev.md\nindex 147c716bb39..3c034a3b4fa 100644\n--- a/doc/releases/changelog-dev.md\n+++ b/doc/releases/changelog-dev.md\n@@ -168,6 +168,10 @@\n \n <h3>Bug fixes \ud83d\udc1b</h3>\n \n+* Fixes issue related to :func:`~.transforms.to_zx` adding the support for\n+  `Toffoli` and `CCZ` gates conversion into their ZX-graph representation.\n+  [(#7899)](https://github.com/PennyLaneAI/pennylane/pull/7899)\n+\n * `get_best_diff_method` now correctly aligns with `execute` and `construct_batch` logic in workflows.\n   [(#7898)](https://github.com/PennyLaneAI/pennylane/pull/7898)\n \ndiff --git a/pennylane/transforms/zx/converter.py b/pennylane/transforms/zx/converter.py\nindex 68806596203..5a2d2b3970c 100644\n--- a/pennylane/transforms/zx/converter.py\n+++ b/pennylane/transforms/zx/converter.py\n@@ -29,6 +29,52 @@\n from pennylane.wires import Wires\n \n \n+def _toffoli_clifford_t_decomp(wires):\n+    \"\"\"Return the explicit Clifford+T decomposition of the Toffoli gate,\n+    replacing Adjoint(T) with PhaseShift(-\u03c0/4).\"\"\"\n+\n+    return [\n+        qml.Hadamard(wires=wires[2]),\n+        qml.CNOT(wires=[wires[1], wires[2]]),\n+        qml.PhaseShift(-np.pi / 4, wires=wires[2]),\n+        qml.CNOT(wires=[wires[0], wires[2]]),\n+        qml.T(wires=wires[2]),\n+        qml.CNOT(wires=[wires[1], wires[2]]),\n+        qml.PhaseShift(-np.pi / 4, wires=wires[2]),\n+        qml.CNOT(wires=[wires[0], wires[2]]),\n+        qml.T(wires=wires[2]),\n+        qml.T(wires=wires[1]),\n+        qml.CNOT(wires=[wires[0], wires[1]]),\n+        qml.Hadamard(wires=wires[2]),\n+        qml.T(wires=wires[0]),\n+        qml.PhaseShift(-np.pi / 4, wires=wires[1]),\n+        qml.CNOT(wires=[wires[0], wires[1]]),\n+    ]\n+\n+\n+def _ccz_clifford_t_decomp(wires):\n+    \"\"\"Return the explicit Clifford+T decomposition of the CCZ gate,\n+    replacing Adjoint(T) with PhaseShift(-\u03c0/4).\"\"\"\n+\n+    return [\n+        qml.CNOT(wires=[wires[1], wires[2]]),\n+        qml.PhaseShift(-np.pi / 4, wires=wires[2]),\n+        qml.CNOT(wires=[wires[0], wires[2]]),\n+        qml.T(wires=wires[2]),\n+        qml.CNOT(wires=[wires[1], wires[2]]),\n+        qml.PhaseShift(-np.pi / 4, wires=wires[2]),\n+        qml.CNOT(wires=[wires[0], wires[2]]),\n+        qml.T(wires=wires[2]),\n+        qml.T(wires=wires[1]),\n+        qml.CNOT(wires=[wires[0], wires[1]]),\n+        qml.Hadamard(wires=wires[2]),\n+        qml.T(wires=wires[0]),\n+        qml.PhaseShift(-np.pi / 4, wires=wires[1]),\n+        qml.CNOT(wires=[wires[0], wires[1]]),\n+        qml.Hadamard(wires=wires[2]),\n+    ]\n+\n+\n class VertexType:  # pylint: disable=too-few-public-methods\n     \"\"\"Type of a vertex in the graph.\n \n@@ -254,6 +300,13 @@ def mod_5_4():\n         It is a PennyLane adapted and reworked `circuit_to_graph <https://github.com/Quantomatic/pyzx/blob/master/pyzx/circuit/graphparser.py>`_\n         function.\n \n+    .. note::\n+\n+        Prior to being added to the graph, Toffoli and CCZ gates are replaced by particular decompositions. These decompositions\n+        are described in detail in: J. Welch, A. Bocharov, and K. Svore, \u201cEfficient Approximation of Diagonal Unitaries over the Clifford+T Basis,\u201d\n+        Quantum information & computation, vol. 16, Dec. 2014, doi: 10.26421/QIC16.1-2-6.\n+        This is necessary because Toffoli and CCZ gates are not directly supported in PyZX.\n+\n         Copyright (C) 2018 - Aleks Kissinger and John van de Wetering\n     \"\"\"\n     # If it is a simple operation just transform it to a tape\n@@ -284,17 +337,22 @@ def _to_zx_transform(\n \n     # Dictionary of gates (PennyLane to PyZX circuit)\n     gate_types = {\n-        \"PauliX\": pyzx.circuit.gates.NOT,\n-        \"PauliZ\": pyzx.circuit.gates.Z,\n+        \"X\": pyzx.circuit.gates.NOT,\n+        \"Y\": pyzx.circuit.gates.Y,\n+        \"Z\": pyzx.circuit.gates.Z,\n         \"S\": pyzx.circuit.gates.S,\n         \"T\": pyzx.circuit.gates.T,\n         \"Hadamard\": pyzx.circuit.gates.HAD,\n         \"RX\": pyzx.circuit.gates.XPhase,\n+        \"RY\": pyzx.circuit.gates.YPhase,\n         \"RZ\": pyzx.circuit.gates.ZPhase,\n         \"PhaseShift\": pyzx.circuit.gates.ZPhase,\n         \"SWAP\": pyzx.circuit.gates.SWAP,\n         \"CNOT\": pyzx.circuit.gates.CNOT,\n+        \"CY\": pyzx.circuit.gates.CY,\n         \"CZ\": pyzx.circuit.gates.CZ,\n+        \"CRX\": pyzx.circuit.gates.CRX,\n+        \"CRY\": pyzx.circuit.gates.CRY,\n         \"CRZ\": pyzx.circuit.gates.CRZ,\n         \"CH\": pyzx.circuit.gates.CHAD,\n         \"CCZ\": pyzx.circuit.gates.CCZ,\n@@ -331,17 +389,12 @@ def processing_fn(res):\n         )\n \n         expanded_operations = []\n-\n-        # Define specific decompositions\n         for op in mapped_tape.operations:\n-            if op.name == \"RY\":\n-                theta = op.data[0]\n-                decomp = [\n-                    qml.RX(np.pi / 2, wires=op.wires),\n-                    qml.RZ(theta + np.pi, wires=op.wires),\n-                    qml.RX(np.pi / 2, wires=op.wires),\n-                    qml.RZ(3 * np.pi, wires=op.wires),\n-                ]\n+            if op.name == \"Toffoli\":\n+                decomp = _toffoli_clifford_t_decomp(op.wires)\n+                expanded_operations.extend(decomp)\n+            elif op.name == \"CCZ\":\n+                decomp = _ccz_clifford_t_decomp(op.wires)\n                 expanded_operations.extend(decomp)\n             else:\n                 expanded_operations.append(op)\n", "test_patch": "diff --git a/tests/transforms/test_zx.py b/tests/transforms/test_zx.py\nindex 733cbc0f975..c8a6f82dbdc 100644\n--- a/tests/transforms/test_zx.py\n+++ b/tests/transforms/test_zx.py\n@@ -26,31 +26,30 @@\n from pennylane.transforms import TransformError\n \n pyzx = pytest.importorskip(\"pyzx\")\n-\n pytestmark = pytest.mark.external\n-\n supported_operations = [\n-    qml.PauliX(wires=0),\n-    qml.PauliZ(wires=0),\n-    qml.Hadamard(wires=0),\n+    qml.X(wires=0),\n+    qml.Y(wires=0),\n+    qml.Z(wires=0),\n     qml.S(wires=0),\n     qml.T(wires=0),\n+    qml.Hadamard(wires=0),\n     qml.SWAP(wires=[0, 1]),\n     qml.CNOT(wires=[0, 1]),\n+    qml.CY(wires=[0, 1]),\n     qml.CZ(wires=[0, 1]),\n     qml.CH(wires=[0, 1]),\n-]\n-\n-supported_operations_params = [\n     qml.RX(0.3, wires=0),\n+    qml.RY(0.3, wires=0),\n     qml.RZ(0.3, wires=0),\n+    qml.PhaseShift(0.3, wires=0),\n+    qml.CRX(0.3, wires=[0, 1]),\n+    qml.CRY(0.3, wires=[0, 1]),\n     qml.CRZ(0.3, wires=[0, 1]),\n+    qml.Toffoli(wires=[0, 1, 2]),\n+    qml.CCZ(wires=[0, 1, 2]),\n ]\n \n-expanded_operations = [qml.PauliY(wires=0), qml.PhaseShift(0.3, wires=0), qml.RY(0.3, wires=0)]\n-\n-non_diagram_like_operations = [qml.CCZ(wires=[0, 1, 2]), qml.Toffoli(wires=[0, 1, 2])]\n-\n decompose_phases = [True, False]\n qscript = [True, False]\n \n@@ -81,7 +80,7 @@ def test_invalid_argument(self):\n \n     @pytest.mark.parametrize(\"script\", qscript)\n     @pytest.mark.parametrize(\"operation\", supported_operations)\n-    def test_supported_operation_no_params(self, operation, script):\n+    def test_supported_operations(self, operation, script):\n         \"\"\"Test to convert the script to a ZX graph and back for supported operations.\"\"\"\n \n         I = qml.math.eye(2 ** len(operation.wires))\n@@ -118,109 +117,11 @@ def test_supported_operation_no_params(self, operation, script):\n \n         assert qml.math.allclose(mat_product, I)\n \n-    @pytest.mark.parametrize(\"script\", qscript)\n-    @pytest.mark.parametrize(\"operation\", supported_operations_params)\n-    def test_supported_operation_params(self, operation, script):\n-        \"\"\"Test to convert the script to a ZX graph and back for supported operations with parameters.\"\"\"\n-\n-        if script:\n-            qs = QuantumScript([operation])\n-        else:\n-            qs = operation\n-\n-        I = qml.math.eye(2 ** len(operation.wires))\n-\n-        matrix_qscript = qml.matrix(qs, wire_order=qs.wires)\n-\n-        zx_g = qml.transforms.to_zx(qs)\n-\n-        matrix_zx = zx_g.to_matrix()\n-\n-        assert isinstance(zx_g, pyzx.graph.graph_s.GraphS)\n-        # Check whether the two matrices are each others conjugate transposes\n-        mat_product = qml.math.dot(matrix_qscript, qml.math.conj(matrix_zx.T))\n-        # Remove global phase\n-        mat_product /= mat_product[0, 0]\n-\n-        assert qml.math.allclose(mat_product, I)\n-\n-        qscript_back = qml.transforms.from_zx(zx_g)\n-        assert isinstance(qscript_back, qml.tape.QuantumScript)\n-\n-        matrix_qscript_back = qml.matrix(qscript_back, wire_order=list(range(len(qs.wires))))\n-\n-        # Check whether the two matrices are each others conjugate transposes\n-        mat_product = qml.math.dot(matrix_qscript, qml.math.conj(matrix_qscript_back.T))\n-        # Remove global phase\n-        mat_product /= mat_product[0, 0]\n-\n-        assert qml.math.allclose(mat_product, I)\n-\n-    @pytest.mark.parametrize(\"script\", qscript)\n-    @pytest.mark.parametrize(\"operation\", expanded_operations)\n-    def test_operation_need_expansion(self, operation, script):\n-        \"\"\"Test to convert the script to a ZX graph and back for operations that needs expansions.\"\"\"\n-\n-        if script:\n-            qs = QuantumScript([operation])\n-        else:\n-            qs = operation\n-\n-        I = qml.math.eye(2 ** len(operation.wires))\n-\n-        matrix_qscript = qml.matrix(qs, wire_order=qs.wires)\n-\n-        zx_g = qml.transforms.to_zx(qs)\n-\n-        matrix_zx = zx_g.to_matrix()\n-\n-        assert isinstance(zx_g, pyzx.graph.graph_s.GraphS)\n-        # Check whether the two matrices are each others conjugate transposes\n-        mat_product = qml.math.dot(matrix_qscript, qml.math.conj(matrix_zx.T))\n-        # Remove global phase\n-        mat_product /= mat_product[0, 0]\n-\n-        assert qml.math.allclose(mat_product, I)\n-\n-        qscript_back = qml.transforms.from_zx(zx_g)\n-        assert isinstance(qscript_back, qml.tape.QuantumScript)\n-\n-        matrix_qscript_back = qml.matrix(qscript_back, wire_order=list(range(len(qs.wires))))\n-\n-        # Check whether the two matrices are each others conjugate transposes\n-        mat_product = qml.math.dot(matrix_qscript, qml.math.conj(matrix_qscript_back.T))\n-        # Remove global phase\n-        mat_product /= mat_product[0, 0]\n-\n-        assert qml.math.allclose(mat_product, I)\n-\n-    @pytest.mark.parametrize(\"operation\", non_diagram_like_operations)\n-    def test_non_diagram_like_op(self, operation):\n-        \"\"\"Test operations that result in a non diagram like circuit.\"\"\"\n-\n-        I = qml.math.eye(2 ** len(operation.wires))\n-\n-        qs = QuantumScript([operation], [])\n-        matrix_qscript = qml.matrix(qs, wire_order=qs.wires)\n-\n-        zx_g = qml.transforms.to_zx(qs)\n-        assert isinstance(zx_g, pyzx.graph.graph_s.GraphS)\n-\n-        matrix_zx = zx_g.to_matrix()\n-        # Check whether the two matrices are each others conjugate transposes\n-        mat_product = qml.math.dot(matrix_qscript, qml.math.conj(matrix_zx.T))\n-        # Remove global phase\n-        mat_product /= mat_product[0, 0]\n-        assert qml.math.allclose(mat_product, I)\n-\n-        with pytest.raises(QuantumFunctionError, match=\"Graph doesn't seem circuit like\"):\n-            qml.transforms.from_zx(zx_g)\n-\n     @pytest.mark.parametrize(\"decompose\", decompose_phases)\n     def test_circuit(self, decompose):\n         \"\"\"Test a simple circuit.\"\"\"\n \n-        I = qml.math.eye(2**2)\n+        I = qml.math.eye(2**3)\n \n         operations = [\n             qml.RZ(5 / 4 * np.pi, wires=0),\n@@ -234,6 +135,8 @@ def test_circuit(self, decompose):\n             qml.CNOT(wires=[0, 1]),\n             qml.CNOT(wires=[1, 0]),\n             qml.SWAP(wires=[0, 1]),\n+            qml.Toffoli(wires=[0, 1, 2]),\n+            qml.CCZ(wires=[0, 1, 2]),\n         ]\n \n         qs = QuantumScript(operations, [])\n", "problem_statement": "[BUG] transforms.to_zx breaks circuit\n### Expected behavior\n\n```python\nimport pyzx as zx\nfrom fractions import Fraction\ncirc = zx.Circuit(3)\ncirc.add_gate(\"Z\", 0)\ncirc.add_gate(\"CNOT\", 0, 1)\ncirc.add_gate(\"ZPhase\", 0, Fraction(1, 4))\ncirc.add_gate(\"TOF\", 0, 1, 2)\ncirc.add_gate(\"T\", 2)\nzx.draw(circ)\n```\n\n![Image](https://github.com/user-attachments/assets/ea91d10c-6811-4691-b998-9e847b068177)\n\n```python\ncirc = circ.to_graph()\nzx.full_reduce(circ)\nzx.draw(circ)\n```\n\n![Image](https://github.com/user-attachments/assets/b7f3336e-12e1-4221-8f97-92e3ec898235)\n\n### Actual behavior\n\nI do the same circuit, the ZX-diagrams look identical, but something is broken as pyzx cant process the graph.\n\n```python\ndef qfunc():\n    qml.Z(0)\n    qml.CNOT((0, 1))\n    qml.RZ(np.pi/4, 0)\n    qml.Toffoli((0, 1, 2))\n    qml.T(2)\n\nzx_circ = qml.transforms.to_zx(qfunc)()\n\nzx.draw(zx_circ)\n```\n\n![Image](https://github.com/user-attachments/assets/19f3c218-9cbd-4084-97d1-6bd3395fec9f)\n\n```python\nzx.full_reduce(zx_circ)\nzx.draw(zx_circ)\n```\n\n```pycon\nValueError: Input graph is not a ZX-diagram as it contains an H-box. Maybe call pyzx.hsimplify.from_hypergraph_form(g) first?\n```\n\n### Additional information\n\nThe first weird thing is that the transform actually returns a graph instance rather than a pyzx.Circuit instance. I guess there is something weird going on in the translation.\n\n### Source code\n\n```shell\n\n```\n\n### Tracebacks\n\n```shell\n\n```\n\n### System information\n\n```shell\nName: Pennylane\nVersion: 0.42.0.dev39\nSummary: PennyLane is a cross-platform Python library for quantum computing, quantum machine learning, and quantum chemistry. Train a quantum computer the same way as a neural network.\nHome-page: \nAuthor: \nAuthor-email: \nLicense-Expression: Apache-2.0\nLocation: /Users/korbinian.kottmann/virtualenvs/pennylane/lib/python3.11/site-packages\nEditable project location: /Users/korbinian.kottmann/Xanadu/pennylane\nRequires: appdirs, autograd, autoray, cachetools, diastatic-malt, networkx, numpy, packaging, pennylane-lightning, requests, rustworkx, scipy, tomlkit, typing_extensions\nRequired-by: kak-tools, PennyLane-Catalyst, PennyLane-qiskit, PennyLane_Lightning, pytket-pennylane, qsvt-compilation\n\nPlatform info:           macOS-15.5-arm64-arm-64bit\nPython version:          3.11.11\nNumpy version:           2.2.6\nScipy version:           1.15.3\nInstalled devices:\n- default.clifford (Pennylane-0.42.0.dev39)\n- default.gaussian (Pennylane-0.42.0.dev39)\n- default.mixed (Pennylane-0.42.0.dev39)\n- default.qubit (Pennylane-0.42.0.dev39)\n- default.qutrit (Pennylane-0.42.0.dev39)\n- default.qutrit.mixed (Pennylane-0.42.0.dev39)\n- default.tensor (Pennylane-0.42.0.dev39)\n- null.qubit (Pennylane-0.42.0.dev39)\n...\n- qiskit.basicaer (PennyLane-qiskit-0.40.0)\n- qiskit.basicsim (PennyLane-qiskit-0.40.0)\n- qiskit.remote (PennyLane-qiskit-0.40.0)\n- pytket.pytketdevice (pytket-pennylane-0.20.0)\n```\n\n### Existing GitHub issues\n\n- [x] I have searched existing GitHub issues to make sure the issue does not already exist.\n", "hints_text": "I've at least localized it to being something wrong with how we convert the `Toffoli`.  I'm tempted to say we just stop natively converting `Toffoli` gates and instead just let it decompose before we convert it to the graph.\n\n", "all_hints_text": "I've at least localized it to being something wrong with how we convert the `Toffoli`.  I'm tempted to say we just stop natively converting `Toffoli` gates and instead just let it decompose before we convert it to the graph.\n@albi3ro It seems indeed that gates like `Toffoli` and `CCZ` are not directly supported by the `to_zx` and `from_zx` transforms at the moment (see [here](https://github.com/PennyLaneAI/pennylane/blob/master/tests/transforms/test_zx.py#L52)). However, it should be possible to provide an explicit decomposition of those gates using operations already included in the predefined gates set used to transform a PL circuit into its ZX-diagram representation. This is already the case for the `RY` gate (see [here](https://github.com/PennyLaneAI/pennylane/blob/master/pennylane/transforms/zx/converter.py#L337)).\n\n", "commit_urls": ["https://github.com/PennyLaneAI/pennylane/commit/c3b31936f524704d9bc9a7e0d94b8307beef8e9b", "https://github.com/PennyLaneAI/pennylane/commit/11fd231e21294f07b2c3e9ce0fe9252d52f26f49", "https://github.com/PennyLaneAI/pennylane/commit/a77a881235067fc98a1549dea436ab89ea19de82", "https://github.com/PennyLaneAI/pennylane/commit/df43619e7b3183122c203757b89ed8aec3158ba9", "https://github.com/PennyLaneAI/pennylane/commit/29a40d4dcba892df3ab7cdb211ee5ce3ae7d0b65", "https://github.com/PennyLaneAI/pennylane/commit/8e55ec2255f17e40e5a0cdc442a92447c3f55fae", "https://github.com/PennyLaneAI/pennylane/commit/2e365d4ad0d379f138f5ee2be642437838b0f4a9", "https://github.com/PennyLaneAI/pennylane/commit/45bd365731ec3bb78ebbf889ba24c9aeaa82b138", "https://github.com/PennyLaneAI/pennylane/commit/c4ebd8f1c7912c41d330c8b0596cc8b3a9746e20", "https://github.com/PennyLaneAI/pennylane/commit/a8c6f2fa4447c02a42e58751b1924972de8ea3c8", "https://github.com/PennyLaneAI/pennylane/commit/09d96d1b7b9e7e74858edd4c3289c9b76286ae0f", "https://github.com/PennyLaneAI/pennylane/commit/1d4e8965e5a24e099691f3fc625f382dba1ab3a2", "https://github.com/PennyLaneAI/pennylane/commit/0d8df8f146ac7056a1453dde0e9bc3830a54122b", "https://github.com/PennyLaneAI/pennylane/commit/d44d8e87ff97ab68f7f1d253c6cbefd93449728b", "https://github.com/PennyLaneAI/pennylane/commit/0d5418522aee9efc6228bcb5a6c4240d387ebbd3", "https://github.com/PennyLaneAI/pennylane/commit/472a6f44c7ad319fc64df7a80c8d00b6c80857a0", "https://github.com/PennyLaneAI/pennylane/commit/f5c9c76bec572c36eb988f35486ff2dc4fcadeef", "https://github.com/PennyLaneAI/pennylane/commit/da7a60c2f9989516ed8aa172e8d7e5908af2204a", "https://github.com/PennyLaneAI/pennylane/commit/67881256f43a680539a4c4c1a8a8cfbe44219b3f", "https://github.com/PennyLaneAI/pennylane/commit/eca656e1ac7ce5b0c06ce4ee16848113c524ca57", "https://github.com/PennyLaneAI/pennylane/commit/f07fd24aa331f469d119e2814e8867df965eab87"], "created_at": "2025-07-16T20:01:59Z"}
{"repo": "PennyLaneAI/pennylane", "pull_number": 7671, "instance_id": "PennyLaneAI__pennylane-7671", "issue_numbers": [7670], "base_commit": "32b5fd9f50a7226e649f9641eb40573fa6ce6bdd", "patch": "diff --git a/doc/releases/changelog-dev.md b/doc/releases/changelog-dev.md\nindex 949c355bc95..6ec541d8efa 100644\n--- a/doc/releases/changelog-dev.md\n+++ b/doc/releases/changelog-dev.md\n@@ -742,6 +742,11 @@ Here's a list of deprecations made this release. For a more detailed breakdown o\n \n <h3>Bug fixes \ud83d\udc1b</h3>\n \n+* A bug in `ops.op_math.Prod.simplify()` has been fixed that led to global phases being discarded\n+  in special cases. Concretely, this problem occurs when Pauli factors combine into the identity\n+  up to a global phase _and_ there is no Pauli representation of the product operator.\n+  [(#7671)](https://github.com/PennyLaneAI/pennylane/pull/7671)\n+\n * The behaviour of the `qml.FlipSign` operation has been fixed: passing an integer `m` as the wires argument is now\n   interpreted as a single wire (i.e. `wires=[m]`). This is different from the previous interpretation of `wires=range(m)`.\n   Also, the `qml.FlipSign.wires` attribute is now returning the correct `Wires` object as for all other operations in PennyLane.\ndiff --git a/pennylane/ops/op_math/prod.py b/pennylane/ops/op_math/prod.py\nindex 0108408aec7..6c4f24cee98 100644\n--- a/pennylane/ops/op_math/prod.py\n+++ b/pennylane/ops/op_math/prod.py\n@@ -54,7 +54,8 @@ def prod(*ops, id=None, lazy=True):\n \n     Keyword Args:\n         id (str or None): id for the product operator. Default is None.\n-        lazy=True (bool): If ``lazy=False``, a simplification will be performed such that when any of the operators is already a product operator, its operands will be used instead.\n+        lazy=True (bool): If ``lazy=False``, a simplification will be performed such that when any\n+            of the operators is already a product operator, its operands will be used instead.\n \n     Returns:\n         ~ops.op_math.Prod: the operator representing the product.\n@@ -639,7 +640,7 @@ def _remove_pauli_factors(self, wires: list[int]):\n             if pauli_word != \"Identity\":\n                 pauli_op = self._paulis[pauli_word](wire)\n                 self._factors += ((pauli_op,),)\n-                self.global_phase *= pauli_coeff\n+            self.global_phase *= pauli_coeff\n \n     def remove_factors(self, wires: list[int]):\n         \"\"\"Remove all factors from the ``self._pauli_factors`` and ``self._non_pauli_factors``\n", "test_patch": "diff --git a/tests/ops/op_math/test_prod.py b/tests/ops/op_math/test_prod.py\nindex 3eb5d3b908e..98bec399dae 100644\n--- a/tests/ops/op_math/test_prod.py\n+++ b/tests/ops/op_math/test_prod.py\n@@ -1244,6 +1244,33 @@ def test_grouping_with_product_of_sum(self):\n         simplified_op = prod_op.simplify()\n         qml.assert_equal(simplified_op, final_op)\n \n+    def test_grouping_with_equal_paulis_single_wire(self):\n+        \"\"\"Test that equal Pauli operators, creating global phase contributions, are simplified\n+        correctly on one wire.\"\"\"\n+        prod_op = qml.prod(qml.X(0) @ qml.Y(0) @ qml.Z(0) @ qml.H(0))\n+        final_op = 1j * qml.H(0)\n+        simplified_op = prod_op.simplify()\n+        assert np.allclose(qml.matrix(prod_op), qml.matrix(final_op))\n+        qml.assert_equal(simplified_op, final_op)\n+\n+    def test_grouping_with_equal_paulis_two_wires(self):\n+        \"\"\"Test that equal Pauli operators, creating global phase contributions, are simplified\n+        correctly on two wires.\"\"\"\n+        prod_op = qml.prod(\n+            qml.X(0)\n+            @ qml.Z(\"a\")\n+            @ qml.Y(0)\n+            @ qml.Z(0)\n+            @ qml.X(\"a\")\n+            @ qml.Y(\"a\")\n+            @ qml.H(0)\n+            @ qml.H(\"a\")\n+        )\n+        final_op = qml.simplify(-1 * qml.H(0) @ qml.H(\"a\"))\n+        simplified_op = prod_op.simplify()\n+        assert np.allclose(qml.matrix(prod_op), qml.matrix(final_op))\n+        qml.assert_equal(simplified_op, final_op)\n+\n     def test_grouping_with_product_of_sums(self):\n         \"\"\"Test that grouping works with product of two sums\"\"\"\n         prod_op = qml.prod(qml.S(0) + qml.H(1), qml.S(0) + qml.H(1))\n", "problem_statement": "[BUG] `qml.simplify` does not handle products with global phases correctly\n### Expected behavior\n\n`qml.simplify` returns outputs equivalent to its inputs.\n\n### Actual behavior\n\nThe example operator below is \"simplified\" into an in-equivalent operator by swallowing a global phase.\n\n\n### Additional information\n\nNote that this bug only occurs if\n- There are Pauli factors on at least one wire that combine into the identity with a non-trivial global phase\n- There are non-Pauli factors, so that no `pauli_rep` can be used.\n\n### Source code\n\n```shell\nop = qml.X(0) @ qml.Y(0) @ qml.Z(0) @ qml.H(0)\nnp.allclose(qml.matrix(op), qml.matrix(qml.simplify(op))) # False\n```\n\n### Tracebacks\n\n```shell\nFalse\n```\n\n### System information\n\n```shell\npl dev.\n```\n\n### Existing GitHub issues\n\n- [x] I have searched existing GitHub issues to make sure the issue does not already exist.\n", "hints_text": "\n\n", "all_hints_text": "\n\n", "commit_urls": ["https://github.com/PennyLaneAI/pennylane/commit/c24e2e3dc452f861c645492f3d43bcc121ce2d53", "https://github.com/PennyLaneAI/pennylane/commit/131673d60bdbd3f5c60b995ea65b5656d497293f", "https://github.com/PennyLaneAI/pennylane/commit/29f0e2d556316b950b48e24275f457d65119e47e"], "created_at": "2025-06-13T10:18:30Z"}
{"repo": "PennyLaneAI/pennylane", "pull_number": 8211, "instance_id": "PennyLaneAI__pennylane-8211", "issue_numbers": [7695], "base_commit": "123d90b8a80ff81a00e9f7edc7a00caa42e9ed83", "patch": "diff --git a/doc/releases/changelog-dev.md b/doc/releases/changelog-dev.md\nindex 6081eaf04a1..df45ff4cf7f 100644\n--- a/doc/releases/changelog-dev.md\n+++ b/doc/releases/changelog-dev.md\n@@ -323,6 +323,9 @@\n \n <h3>Improvements \ud83d\udee0</h3>\n \n+* Templates have been made compatible with `qml.capture`.\n+  [(#8211)](https://github.com/PennyLaneAI/pennylane/pull/8211)\n+\n * :func:`pennylane.snapshots` can now be used with `mcm_method=\"one-shot\"` and `mcm_method=\"tree-traversal\"`.\n   [(#8140)](https://github.com/PennyLaneAI/pennylane/pull/8140)\n \ndiff --git a/pennylane/ops/functions/__init__.py b/pennylane/ops/functions/__init__.py\nindex f53a22d0361..8208dbf2c28 100644\n--- a/pennylane/ops/functions/__init__.py\n+++ b/pennylane/ops/functions/__init__.py\n@@ -38,12 +38,12 @@\n     ~comm\n \n \"\"\"\n-from .assert_valid import assert_valid\n from .bind_new_parameters import bind_new_parameters\n+from .equal import equal, assert_equal\n+from .assert_valid import assert_valid\n from .commutator import comm, commutator\n from .dot import dot\n from .eigvals import eigvals\n-from .equal import equal, assert_equal\n from .evolve import evolve\n from .generator import generator\n from .is_commuting import is_commuting\ndiff --git a/pennylane/ops/functions/assert_valid.py b/pennylane/ops/functions/assert_valid.py\nindex b3f04675f78..a9ceecea2d5 100644\n--- a/pennylane/ops/functions/assert_valid.py\n+++ b/pennylane/ops/functions/assert_valid.py\n@@ -29,6 +29,8 @@\n from pennylane.decomposition import DecompositionRule\n from pennylane.exceptions import EigvalsUndefinedError\n \n+from .equal import assert_equal\n+\n \n def _assert_error_raised(func, error, failure_comment):\n     def inner_func(*args, **kwargs):\n@@ -370,7 +372,12 @@ def test_fn(*args):\n \n         jaxpr = jax.make_jaxpr(test_fn)(*data)\n         new_op = jax.core.eval_jaxpr(jaxpr.jaxpr, jaxpr.consts, *data)[0]\n-        assert op == new_op\n+        assert_equal(op, new_op)\n+\n+        leaves = jax.tree_util.tree_leaves(jaxpr.eqns[-1].params)\n+        assert not any(\n+            qml.math.is_abstract(l) for l in leaves\n+        ), \"capture params cannot contain tracers\"\n     except Exception as e:\n         raise ValueError(\n             \"The capture of the operation into jaxpr failed somehow.\"\ndiff --git a/pennylane/ops/functions/equal.py b/pennylane/ops/functions/equal.py\nindex 15f7a69aec5..70c2b8fac5f 100644\n--- a/pennylane/ops/functions/equal.py\n+++ b/pennylane/ops/functions/equal.py\n@@ -31,7 +31,7 @@\n from pennylane.pauli import PauliSentence, PauliWord\n from pennylane.pulse.parametrized_evolution import ParametrizedEvolution\n from pennylane.tape import QuantumScript\n-from pennylane.templates.subroutines import ControlledSequence, PrepSelPrep, Select\n+from pennylane.templates.subroutines import QSVT, ControlledSequence, PrepSelPrep, Select\n \n OPERANDS_MISMATCH_ERROR_MESSAGE = \"op1 and op2 have different operands because \"\n \n@@ -797,6 +797,23 @@ def _equal_prep_sel_prep(op1: PrepSelPrep, op2: PrepSelPrep, **kwargs):\n     return True\n \n \n+@_equal_dispatch.register\n+def _equal_qsvt(op1: QSVT, op2: QSVT, **kwargs):\n+    \"\"\"Determine whether two QSVT are equal\"\"\"\n+    if not equal(UA1 := op1.hyperparameters[\"UA\"], UA2 := op2.hyperparameters[\"UA\"], **kwargs):\n+        return f\"op1 and op2 have different block encodings UA. Got {UA1} and {UA2}.\"\n+    projectors1 = op1.hyperparameters[\"projectors\"]\n+    projectors2 = op2.hyperparameters[\"projectors\"]\n+    if len(projectors1) != len(projectors2):\n+        return f\"op1 and op2 have a different number of projectors. Got {projectors1} and {projectors2}.\"\n+    for i, (p1, p2) in enumerate(zip(projectors1, projectors2)):\n+        try:\n+            assert_equal(p1, p2, **kwargs)\n+        except AssertionError as e:\n+            return f\"op1 and op2 have different projectors at position {i}. Got {p1} and {p2}, which differ: {e}.\"\n+    return True\n+\n+\n @_equal_dispatch.register\n def _equal_select(op1: Select, op2: Select, **kwargs):\n     \"\"\"Determine whether two Select are equal\"\"\"\ndiff --git a/pennylane/templates/state_preparations/state_prep_mps.py b/pennylane/templates/state_preparations/state_prep_mps.py\nindex c0fe522bec2..815594ec352 100644\n--- a/pennylane/templates/state_preparations/state_prep_mps.py\n+++ b/pennylane/templates/state_preparations/state_prep_mps.py\n@@ -404,15 +404,12 @@ def map_wires(self, wire_map):\n             self.mps, new_wires, new_work_wires, self.hyperparameters[\"right_canonicalize\"]\n         )\n \n+    # pylint: disable=arguments-differ, too-many-arguments\n     @classmethod\n-    def _primitive_bind_call(cls, mps, wires, work_wires=None, id=None):\n-        # pylint: disable=arguments-differ\n-        if cls._primitive is None:\n-            # guard against this being called when primitive is not defined.\n-            return type.__call__(\n-                cls, mps=mps, wires=wires, id=id, work_wires=work_wires\n-            )  # pragma: no cover\n-        return cls._primitive.bind(*mps, wires=wires, id=id, work_wires=work_wires)\n+    def _primitive_bind_call(cls, mps, wires, work_wires=None, id=None, right_canonicalize=False):\n+        return super()._primitive_bind_call(\n+            *mps, wires=wires, work_wires=work_wires, id=id, right_canonicalize=right_canonicalize\n+        )\n \n     def decomposition(self):\n         filtered_hyperparameters = {\n@@ -508,8 +505,9 @@ def compute_decomposition(\n if MPSPrep._primitive is not None:  # pylint: disable=protected-access\n \n     @MPSPrep._primitive.def_impl  # pylint: disable=protected-access\n-    def _(*args, **kwargs):\n-        return type.__call__(MPSPrep, args, **kwargs)\n+    def _(*args, n_wires, **kwargs):\n+        mps, wires = args[:-n_wires], args[-n_wires:]\n+        return type.__call__(MPSPrep, mps, wires=wires, **kwargs)\n \n \n def _mps_prep_decomposition_resources(\ndiff --git a/pennylane/templates/subroutines/gqsp.py b/pennylane/templates/subroutines/gqsp.py\nindex 344d0d5b33a..e651fec3216 100644\n--- a/pennylane/templates/subroutines/gqsp.py\n+++ b/pennylane/templates/subroutines/gqsp.py\n@@ -105,19 +105,17 @@ def resource_params(self) -> dict:\n         }\n \n     def _flatten(self):\n-        data = self.parameters\n-        return data, (\n-            self.hyperparameters[\"unitary\"],\n-            self.hyperparameters[\"control\"],\n-        )\n+        return (*self.data, self.hyperparameters[\"unitary\"]), (self.hyperparameters[\"control\"],)\n \n     @classmethod\n     def _unflatten(cls, data, metadata):\n-        return cls(unitary=metadata[0], angles=data[0], control=metadata[1])\n+        # Data contains (angles, derived_data_from_unitary, unitary)\n+        return cls(unitary=data[-1], angles=data[0], control=metadata[0])\n \n+    # pylint: disable=arguments-differ\n     @classmethod\n-    def _primitive_bind_call(cls, *args, **kwargs):\n-        return cls._primitive.bind(*args, **kwargs)\n+    def _primitive_bind_call(cls, unitary, angles, control, id=None):\n+        return super()._primitive_bind_call(unitary, angles, wires=control, id=id)\n \n     def map_wires(self, wire_map: dict):\n         # pylint: disable=protected-access\n@@ -219,7 +217,7 @@ def _GQSP_decomposition(*parameters, **hyperparameters):\n \n     for theta, phi, lamb in zip(thetas[1:], phis[1:], lambds[1:]):\n \n-        ops.Controlled(unitary, control_wires=[control], control_values=[0])\n+        ops.ctrl(unitary, control=control, control_values=[0])\n \n         ops.X(control)\n         ops.U3(2 * theta, phi, lamb, wires=control)\n@@ -228,3 +226,11 @@ def _GQSP_decomposition(*parameters, **hyperparameters):\n \n \n add_decomps(GQSP, _GQSP_decomposition)\n+\n+# pylint: disable=protected-access\n+if GQSP._primitive is not None:\n+\n+    @GQSP._primitive.def_impl\n+    def _(*args, n_wires, **kwargs):\n+        (unitary, angles), control = args[:-n_wires], args[-n_wires:]\n+        return type.__call__(GQSP, unitary, angles, control=control, **kwargs)\ndiff --git a/pennylane/templates/subroutines/prepselprep.py b/pennylane/templates/subroutines/prepselprep.py\nindex dc563aea05c..f037f9cb82d 100644\n--- a/pennylane/templates/subroutines/prepselprep.py\n+++ b/pennylane/templates/subroutines/prepselprep.py\n@@ -108,6 +108,10 @@ def __init__(self, lcu, control=None, id=None):\n     def _flatten(self):\n         return (self.lcu,), (self.control,)\n \n+    @classmethod\n+    def _primitive_bind_call(cls, lcu, control, **kwargs):\n+        return super()._primitive_bind_call(lcu, wires=control, **kwargs)\n+\n     @classmethod\n     def _unflatten(cls, data, metadata) -> \"PrepSelPrep\":\n         return cls(data[0], metadata[0])\n@@ -243,3 +247,11 @@ def _prepselprep_decomp(*_, wires, lcu, control, target_wires):\n \n \n add_decomps(PrepSelPrep, _prepselprep_decomp)\n+\n+# pylint: disable=protected-access\n+if PrepSelPrep._primitive is not None:\n+\n+    @PrepSelPrep._primitive.def_impl\n+    def _(*args, n_wires, **kwargs):\n+        (lcu,), control = args[:-n_wires], args[-n_wires:]\n+        return type.__call__(PrepSelPrep, lcu, control, **kwargs)\ndiff --git a/pennylane/templates/subroutines/reflection.py b/pennylane/templates/subroutines/reflection.py\nindex 3370289955f..61701409724 100644\n--- a/pennylane/templates/subroutines/reflection.py\n+++ b/pennylane/templates/subroutines/reflection.py\n@@ -115,17 +115,14 @@ def circuit():\n \n     resource_keys = {\"base_class\", \"base_params\", \"num_wires\", \"num_reflection_wires\"}\n \n-    @classmethod\n-    def _primitive_bind_call(cls, *args, **kwargs):\n-        return cls._primitive.bind(*args, **kwargs)\n-\n     def _flatten(self):\n         data = (self.hyperparameters[\"base\"], self.parameters[0])\n         return data, (self.hyperparameters[\"reflection_wires\"],)\n \n+    # pylint: disable=arguments-differ\n     @classmethod\n-    def _primitive_bind_call(cls, *args, **kwargs):\n-        return cls._primitive.bind(*args, **kwargs)\n+    def _primitive_bind_call(cls, U, alpha, reflection_wires, **kwargs):\n+        return super()._primitive_bind_call(U, alpha, wires=reflection_wires, **kwargs)\n \n     @classmethod\n     def _unflatten(cls, data, metadata):\n@@ -278,3 +275,11 @@ def _reflection_decomposition(*parameters, wires=None, **hyperparameters):\n \n \n add_decomps(Reflection, _reflection_decomposition)\n+\n+# pylint: disable=protected-access\n+if Reflection._primitive is not None:\n+\n+    @Reflection._primitive.def_impl\n+    def _(*args, n_wires, **kwargs):\n+        (U, alpha), reflection_wires = args[:-n_wires], args[-n_wires:]\n+        return type.__call__(Reflection, U, alpha, reflection_wires=reflection_wires, **kwargs)\ndiff --git a/pennylane/templates/subroutines/select.py b/pennylane/templates/subroutines/select.py\nindex 4e516d88a57..85139e47635 100644\n--- a/pennylane/templates/subroutines/select.py\n+++ b/pennylane/templates/subroutines/select.py\n@@ -362,15 +362,16 @@ def resource_params(self):\n         }\n \n     def _flatten(self):\n-        return (self.ops), (\n+        return tuple(self.ops), (\n             self.control,\n             self.work_wires,\n             self.partial,\n         )\n \n+    # pylint: disable=arguments-differ\n     @classmethod\n-    def _primitive_bind_call(cls, *args, **kwargs):\n-        return cls._primitive.bind(*args, **kwargs)\n+    def _primitive_bind_call(cls, ops, control, **kwargs):\n+        return super()._primitive_bind_call(*ops, wires=control, **kwargs)\n \n     @classmethod\n     def _unflatten(cls, data, metadata) -> \"Select\":\n@@ -1174,3 +1175,11 @@ def _select_decomp_multi_control_work_wire(*_, ops, control, work_wires, partial\n \n \n add_decomps(Select, _select_decomp_multi_control_work_wire)\n+\n+# pylint: disable=protected-access\n+if Select._primitive is not None:\n+\n+    @Select._primitive.def_impl\n+    def _(*args, n_wires, **kwargs):\n+        ops, control = args[:-n_wires], args[-n_wires:]\n+        return type.__call__(Select, ops, control=control, **kwargs)\ndiff --git a/pennylane/templates/subroutines/select_pauli_rot.py b/pennylane/templates/subroutines/select_pauli_rot.py\nindex 944e02fbf00..4c328ed244c 100644\n--- a/pennylane/templates/subroutines/select_pauli_rot.py\n+++ b/pennylane/templates/subroutines/select_pauli_rot.py\n@@ -141,10 +141,11 @@ def map_wires(self, wire_map: dict):\n             rot_axis=self.hyperparameters[\"rot_axis\"],\n         )\n \n+    # pylint: disable=arguments-differ\n     @classmethod\n-    def _primitive_bind_call(cls, *args, **kwargs):\n-        \"\"\"Bind arguments to the primitive operation.\"\"\"\n-        return cls._primitive.bind(*args, **kwargs)\n+    def _primitive_bind_call(cls, angles, control_wires, target_wire, **kwargs):\n+        wires = [*control_wires, target_wire]\n+        return super()._primitive_bind_call(angles, wires=wires, **kwargs)\n \n     def decomposition(self):\n         \"\"\"Return the operator's decomposition using its parameters and hyperparameters.\"\"\"\n@@ -210,3 +211,11 @@ def decompose_select_pauli_rot(angles, wires, rot_axis, **__):\n \n \n add_decomps(SelectPauliRot, decompose_select_pauli_rot)\n+\n+# pylint: disable=protected-access\n+if SelectPauliRot._primitive is not None:\n+\n+    @SelectPauliRot._primitive.def_impl\n+    def _(*args, n_wires, **kwargs):\n+        (angles,), (*control_wires, target_wire) = args[:-n_wires], args[-n_wires:]\n+        return type.__call__(SelectPauliRot, angles, control_wires, target_wire, **kwargs)\n", "test_patch": "diff --git a/tests/capture/test_templates.py b/tests/capture/test_templates.py\nindex aef5c5d57a1..1bbd55eec46 100644\n--- a/tests/capture/test_templates.py\n+++ b/tests/capture/test_templates.py\n@@ -653,8 +653,14 @@ def qfunc(mps):\n \n         eqn = jaxpr.eqns[0]\n         assert eqn.primitive == qml.MPSPrep._primitive\n-        assert eqn.invars == jaxpr.jaxpr.invars\n-        assert eqn.params == {\"id\": None, \"wires\": wires, \"work_wires\": None}\n+        assert eqn.invars[:4] == jaxpr.jaxpr.invars\n+        assert [invar.val for invar in eqn.invars[4:]] == [0, 1, 2]\n+        assert eqn.params == {\n+            \"id\": None,\n+            \"n_wires\": 3,\n+            \"work_wires\": None,\n+            \"right_canonicalize\": False,\n+        }\n         assert len(eqn.outvars) == 1\n         assert isinstance(eqn.outvars[0], jax.core.DropVar)\n \n@@ -812,36 +818,37 @@ def qfunc():\n     def test_multiplexed_rotation(self):\n         \"\"\"Test the primitive bind call of SelectPauliRot.\"\"\"\n \n+        angles = np.arange(1, 9)\n         kwargs = {\n-            \"angles\": np.array([1, 2, 3, 4, 5, 6, 7, 8]),\n             \"control_wires\": [0, 1, 2],\n-            \"target_wire\": [3],\n+            \"target_wire\": 3,\n             \"rot_axis\": \"X\",\n         }\n \n-        def qfunc():\n-            qml.SelectPauliRot(**kwargs)\n+        def qfunc(angles):\n+            qml.SelectPauliRot(angles, **kwargs)\n \n         # Validate inputs\n-        qfunc()\n+        qfunc(angles)\n \n         # Actually test primitive bind\n-        jaxpr = jax.make_jaxpr(qfunc)()\n+        jaxpr = jax.make_jaxpr(qfunc)(angles)\n \n         assert len(jaxpr.eqns) == 1\n \n         eqn = jaxpr.eqns[0]\n         assert eqn.primitive == qml.SelectPauliRot._primitive\n-        assert eqn.invars == jaxpr.jaxpr.invars\n-        assert eqn.params == kwargs\n+        assert eqn.invars[:1] == jaxpr.jaxpr.invars\n+        assert [invar.val for invar in eqn.invars[1:]] == [0, 1, 2, 3]\n+        assert eqn.params == {\"n_wires\": 4, \"rot_axis\": \"X\"}\n         assert len(eqn.outvars) == 1\n         assert isinstance(eqn.outvars[0], jax.core.DropVar)\n \n         with qml.queuing.AnnotatedQueue() as q:\n-            jax.core.eval_jaxpr(jaxpr.jaxpr, jaxpr.consts)\n+            jax.core.eval_jaxpr(jaxpr.jaxpr, jaxpr.consts, angles)\n \n         assert len(q) == 1\n-        qml.assert_equal(q.queue[0], qml.SelectPauliRot(**kwargs))\n+        qml.assert_equal(q.queue[0], qml.SelectPauliRot(angles, **kwargs))\n \n     def test_phase_adder(self):\n         \"\"\"Test the primitive bind call of PhaseAdder.\"\"\"\n@@ -1126,50 +1133,82 @@ def qfunc():\n     def test_gqsp(self):\n         \"\"\"Test the primitive bind call of GQSP.\"\"\"\n \n-        kwargs = {\n-            \"unitary\": qml.RX(1, wires=1),\n-            \"control\": 0,\n-            \"angles\": np.ones([3, 3]),\n-        }\n+        def qfunc(unitary, angles):\n+            qml.GQSP(unitary, angles, control=0)\n \n-        def qfunc():\n-            qml.GQSP(**kwargs)\n+        angles = np.ones([3, 3])\n+        unitary = qml.RX(1, wires=1)\n+        # Validate inputs\n+        qfunc(unitary, angles)\n+\n+        # Actually test primitive bind\n+        jaxpr = jax.make_jaxpr(qfunc)(unitary, angles)\n+\n+        assert len(jaxpr.eqns) == 2\n+\n+        rx_eqn = jaxpr.eqns[0]\n+        assert rx_eqn.primitive == qml.RX._primitive\n+        gqps_eqn = jaxpr.eqns[1]\n+        assert gqps_eqn.primitive == qml.GQSP._primitive\n+        assert gqps_eqn.invars[0] == rx_eqn.outvars[0]\n+        assert gqps_eqn.invars[1] == jaxpr.jaxpr.invars[1]\n+        assert gqps_eqn.invars[2].val == 0  # Control wire\n+        assert gqps_eqn.params == {\"n_wires\": 1, \"id\": None}\n+        assert len(gqps_eqn.outvars) == 1\n+        assert isinstance(gqps_eqn.outvars[0], jax.core.DropVar)\n+\n+        with qml.queuing.AnnotatedQueue() as q:\n+            jax.core.eval_jaxpr(jaxpr.jaxpr, jaxpr.consts, unitary.data, angles)\n+\n+        assert len(q) == 1\n+        qml.assert_equal(q.queue[0], qml.GQSP(unitary, angles, control=0))\n+\n+    def test_reflection(self):\n+    