\n-        self.server_port: int | None = None\n+        self.server_process: Optional[subprocess.Popen] = None\n+        self.server_port: Optional[int] = None\n         self._atexit_registered = False\n \n     def start_server(\ndiff --git a/packages/leann-core/src/leann/interface.py b/packages/leann-core/src/leann/interface.py\nindex d63078be..b98c28df 100644\n--- a/packages/leann-core/src/leann/interface.py\n+++ b/packages/leann-core/src/leann/interface.py\n@@ -1,5 +1,5 @@\n from abc import ABC, abstractmethod\n-from typing import Any, Literal\n+from typing import Any, Literal, Union\n \n import numpy as np\n \n@@ -34,7 +34,9 @@ def __init__(self, index_path: str, **kwargs):\n         pass\n \n     @abstractmethod\n-    def _ensure_server_running(self, passages_source_file: str, port: int | None, **kwargs) -> int:\n+    def _ensure_server_running(\n+        self, passages_source_file: str, port: Union[int, None], **kwargs\n+    ) -> int:\n         \"\"\"Ensure server is running\"\"\"\n         pass\n \n@@ -48,7 +50,7 @@ def search(\n         prune_ratio: float = 0.0,\n         recompute_embeddings: bool = False,\n         pruning_strategy: Literal[\"global\", \"local\", \"proportional\"] = \"global\",\n-        zmq_port: int | None = None,\n+        zmq_port: Union[int, None] = None,\n         **kwargs,\n     ) -> dict[str, Any]:\n         \"\"\"Search for nearest neighbors\n@@ -74,7 +76,7 @@ def compute_query_embedding(\n         self,\n         query: str,\n         use_server_if_available: bool = True,\n-        zmq_port: int | None = None,\n+        zmq_port: Union[int, None] = None,\n     ) -> np.ndarray:\n         \"\"\"Compute embedding for a query string\n \ndiff --git a/packages/leann-core/src/leann/searcher_base.py b/packages/leann-core/src/leann/searcher_base.py\nindex 02ec430f..ff368c87 100644\n--- a/packages/leann-core/src/leann/searcher_base.py\n+++ b/packages/leann-core/src/leann/searcher_base.py\n@@ -1,7 +1,7 @@\n import json\n from abc import ABC, abstractmethod\n from pathlib import Path\n-from typing import Any, Literal\n+from typing import Any, Literal, Optional\n \n import numpy as np\n \n@@ -169,7 +169,7 @@ def search(\n         prune_ratio: float = 0.0,\n         recompute_embeddings: bool = False,\n         pruning_strategy: Literal[\"global\", \"local\", \"proportional\"] = \"global\",\n-        zmq_port: int | None = None,\n+        zmq_port: Optional[int] = None,\n         **kwargs,\n     ) -> dict[str, Any]:\n         \"\"\"\ndiff --git a/pyproject.toml b/pyproject.toml\nindex 5d424a2f..7992b424 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -40,8 +40,8 @@ dependencies = [\n     # Other dependencies\n     \"ipykernel==6.29.5\",\n     \"msgpack>=1.1.1\",\n-    \"mlx>=0.26.3; sys_platform == 'darwin'\",\n-    \"mlx-lm>=0.26.0; sys_platform == 'darwin'\",\n+    \"mlx>=0.26.3; sys_platform == 'darwin' and platform_machine == 'arm64'\",\n+    \"mlx-lm>=0.26.0; sys_platform == 'darwin' and platform_machine == 'arm64'\",\n     \"psutil>=5.8.0\",\n     \"pathspec>=0.12.1\",\n     \"nbconvert>=7.16.6\",\n@@ -91,7 +91,7 @@ leann-backend-diskann = { path = \"packages/leann-backend-diskann\", editable = tr\n leann-backend-hnsw = { path = \"packages/leann-backend-hnsw\", editable = true }\n \n [tool.ruff]\n-target-version = \"py310\"\n+target-version = \"py39\"\n line-length = 100\n extend-exclude = [\n     \"third_party\",\n", "test_patch": "", "problem_statement": "Setup doesn't work on mac intel\n(base) seven@mac-mini-real leann % source .venv/bin/activate\n\n(leann) (base) seven@mac-mini-real leann % uv pip install leann\n\n  \u00d7 No solution found when resolving dependencies:\n  \u2570\u2500\u25b6 Because only the following versions of leann-backend-hnsw are available:\n          leann-backend-hnsw<=0.1.0\n          leann-backend-hnsw==0.1.1\n          leann-backend-hnsw==0.1.5\n          leann-backend-hnsw==0.1.7\n          leann-backend-hnsw==0.1.8\n          leann-backend-hnsw==0.1.9\n          leann-backend-hnsw==0.1.10\n          leann-backend-hnsw==0.1.11\n          leann-backend-hnsw==0.1.12\n          leann-backend-hnsw==0.1.13\n          leann-backend-hnsw==0.1.14\n          leann-backend-hnsw==0.1.15\n          leann-backend-hnsw==0.1.16\n          leann-backend-hnsw==0.2.0\n          leann-backend-hnsw==0.2.1\n          leann-backend-hnsw==0.2.2\n          leann-backend-hnsw==0.2.4\n          leann-backend-hnsw==0.2.5\n      and leann-backend-hnsw==0.1.0 has no wheels with a matching Python implementation tag, we can conclude that\n      leann-backend-hnsw<0.1.1 cannot be used.\n      And because leann-backend-hnsw>=0.1.1 has no wheels with a matching platform tag, we can conclude that\n      leann-backend-hnsw>=0.1.1 cannot be used.\n      And because all versions of leann depend on leann-backend-hnsw and you require leann, we can conclude that your requirements\n      are unsatisfiable.\n(leann) (base) seven@mac-mini-real leann % uv tool install leann\n\n  \u00d7 No solution found when resolving dependencies:\n  \u2570\u2500\u25b6 Because all versions of leann-backend-hnsw have no wheels with a matching platform tag and all versions of leann depend on\n      leann-backend-hnsw, we can conclude that all versions of leann cannot be used.\n      And because you require leann, we can conclude that your requirements are unsatisfiable.\n(leann) (base) seven@mac-mini-real leann %\n", "hints_text": "Sorry right now we only support Apple Silicon Mac but will fix soon\n\n", "all_hints_text": "Sorry right now we only support Apple Silicon Mac but will fix soon\ntry to build from source, should work. I just did this because my ubuntu is still 20.04, and some components, especially libabsl-dev is not available until 22.04. I saw the same error as yours . Then I opt to build from source. Not so difficult. Just follow: https://github.com/yichuan-w/LEANN?tab=readme-ov-file#-quick-install then build from source part. consult some good LLMs if anything wrong then you should be fine. @iSevenDays \nThanks for pointing out the wrong wheel in 20.04! I'll fix it soon. @ww2283 Also, thanks for your help \n@iSevenDays this is fixed by our latest PR #26 \n\n", "commit_urls": ["https://github.com/yichuan-w/LEANN/commit/368c587c4f89742d78ef07fc9e583c262bb6d52b", "https://github.com/yichuan-w/LEANN/commit/e16c369bfb6360d02f486c4c7b2711916a424176", "https://github.com/yichuan-w/LEANN/commit/a620c2077a89750e3d7498eedb240194be6c9595", "https://github.com/yichuan-w/LEANN/commit/1b01725dd1233d637a8f7c987d33e87acdcea6a7", "https://github.com/yichuan-w/LEANN/commit/754c9aaedd9a0f0e762d1346bffc0bc4dfb1bf13", "https://github.com/yichuan-w/LEANN/commit/5f5b97fb5459b3009a546b0abd39e94e72a9764a", "https://github.com/yichuan-w/LEANN/commit/4a5db385f04d12dac090af8cd88b636983bb260f", "https://github.com/yichuan-w/LEANN/commit/c1832765cd2fe92a5f6fe04d82f2af5e84cd8922", "https://github.com/yichuan-w/LEANN/commit/abcc1fed311b81451c5412f785828983c8c6f407", "https://github.com/yichuan-w/LEANN/commit/0543d61572f48f0c88f1cf3903297d0750e9d4c9", "https://github.com/yichuan-w/LEANN/commit/1dfc2f37371edeb45ed021a39f11664e3161d87a", "https://github.com/yichuan-w/LEANN/commit/f009d2add3fd8ce760f94b6499a8ac180bc22b53", "https://github.com/yichuan-w/LEANN/commit/8d1e04d7a1298efbb1bc46c3ef49f6d39e934a76", "https://github.com/yichuan-w/LEANN/commit/1bc4bf06f0092b9a45150350fb3e7e6ac89e4ece", "https://github.com/yichuan-w/LEANN/commit/4fc8943ca7fff75f7282ca000d75f08f6070a760", "https://github.com/yichuan-w/LEANN/commit/756864d058da68adccb630ccef62a6932a37606f", "https://github.com/yichuan-w/LEANN/commit/2be39db799bdd447a3f312821bff99e0cdecf0cc", "https://github.com/yichuan-w/LEANN/commit/6ae9e0f4f9153b61938508af495b040dbf3a796c", "https://github.com/yichuan-w/LEANN/commit/f08132c525b520f073b1e2d836b1176c8d9e4c27", "https://github.com/yichuan-w/LEANN/commit/5094e6800a9e9275366fe17585babb70cd1366fd", "https://github.com/yichuan-w/LEANN/commit/ded0decd17a494ef68692b6