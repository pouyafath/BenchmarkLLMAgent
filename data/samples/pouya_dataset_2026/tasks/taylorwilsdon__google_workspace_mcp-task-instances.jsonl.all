26d65e2cad8dc5f97d34c27b19199b6414a40cb36b52f41b79014be\", size = 329361, upload_time = \"2025-06-10T00:45:10.11Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/93/8f/b811b9d1f617c83c907e7082a76e2b92b655400e61730cd61a1f67178393/yarl-1.20.1-cp313-cp313t-musllinux_1_2_aarch64.whl\", hash = \"sha256:67e708dfb8e78d8a19169818eeb5c7a80717562de9051bf2413aca8e3696bf16\", size = 346460, upload_time = \"2025-06-10T00:45:12.055Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/70/fd/af94f04f275f95da2c3b8b5e1d49e3e79f1ed8b6ceb0f1664cbd902773ff/yarl-1.20.1-cp313-cp313t-musllinux_1_2_armv7l.whl\", hash = \"sha256:595c07bc79af2494365cc96ddeb772f76272364ef7c80fb892ef9d0649586513\", size = 334486, upload_time = \"2025-06-10T00:45:13.995Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/84/65/04c62e82704e7dd0a9b3f61dbaa8447f8507655fd16c51da0637b39b2910/yarl-1.20.1-cp313-cp313t-musllinux_1_2_i686.whl\", hash = \"sha256:7bdd2f80f4a7df852ab9ab49484a4dee8030023aa536df41f2d922fd57bf023f\", size = 342219, upload_time = \"2025-06-10T00:45:16.479Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/91/95/459ca62eb958381b342d94ab9a4b6aec1ddec1f7057c487e926f03c06d30/yarl-1.20.1-cp313-cp313t-musllinux_1_2_ppc64le.whl\", hash = \"sha256:c03bfebc4ae8d862f853a9757199677ab74ec25424d0ebd68a0027e9c639a390\", size = 350693, upload_time = \"2025-06-10T00:45:18.399Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/a6/00/d393e82dd955ad20617abc546a8f1aee40534d599ff555ea053d0ec9bf03/yarl-1.20.1-cp313-cp313t-musllinux_1_2_s390x.whl\", hash = \"sha256:344d1103e9c1523f32a5ed704d576172d2cabed3122ea90b1d4e11fe17c66458\", size = 355803, upload_time = \"2025-06-10T00:45:20.677Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/9e/ed/c5fb04869b99b717985e244fd93029c7a8e8febdfcffa06093e32d7d44e7/yarl-1.20.1-cp313-cp313t-musllinux_1_2_x86_64.whl\", hash = \"sha256:88cab98aa4e13e1ade8c141daeedd300a4603b7132819c484841bb7af3edce9e\", size = 341709, upload_time = \"2025-06-10T00:45:23.221Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/24/fd/725b8e73ac2a50e78a4534ac43c6addf5c1c2d65380dd48a9169cc6739a9/yarl-1.20.1-cp313-cp313t-win32.whl\", hash = \"sha256:b121ff6a7cbd4abc28985b6028235491941b9fe8fe226e6fdc539c977ea1739d\", size = 86591, upload_time = \"2025-06-10T00:45:25.793Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/94/c3/b2e9f38bc3e11191981d57ea08cab2166e74ea770024a646617c9cddd9f6/yarl-1.20.1-cp313-cp313t-win_amd64.whl\", hash = \"sha256:541d050a355bbbc27e55d906bc91cb6fe42f96c01413dd0f4ed5a5240513874f\", size = 93003, upload_time = \"2025-06-10T00:45:27.752Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/b4/2d/2345fce04cfd4bee161bf1e7d9cdc702e3e16109021035dbb24db654a622/yarl-1.20.1-py3-none-any.whl\", hash = \"sha256:83b8eb083fe4683c6115795d9fc1cfaf2cbbefb19b3a1cb68f6527460f483a77\", size = 46542, upload_time = \"2025-06-10T00:46:07.521Z\" },\n+]\n", "test_patch": "", "problem_statement": "feat: Implement 06/18 MCP Spec Authentication - OAuth 2.1, Passthrough & Multi-User Session Handling\nref: https://github.com/taylorwilsdon/google_workspace_mcp/issues/88, https://github.com/taylorwilsdon/google_workspace_mcp/issues/101\n\n## Feature Request: OAuth 2.1 Authentication with Bearer Token Support and Multi-User Session Handling\n\n### Summary\n\nImplement comprehensive OAuth 2.1 authentication support for MCP servers following the June 18, 2025 specification, including bearer token authentication capabilities and robust multi-user session handling.\n\n### Background\n\nThe current authentication implementation has limitations that affect both security and usability:\n\n1. **Bearer Token Support (#101)**: Currently, user identification requires passing email as a tool parameter. This approach is insecure and inconvenient. We need to support standard Bearer token authentication where the client passes a token containing user identity information.\n\n2. **Multi-User Session Management (#88)**: Users experience inconsistent authentication states when multiple users access the same MCP server. Sessions are not properly tied to individual users, causing frequent re-authentication requests and session confusion.\n\n### Objectives\n\n1. Implement OAuth 2.1 compliant authentication as specified in the MCP Protocol (2025-06-18)\n2. Enable Bearer token authentication for secure user identification\n3. Implement robust session management for multi-user environments\n4. Support token passthrough for simplified authentication flows\n5. Ensure backward compatibility with existing authentication methods\n\n### Requirements\n\n#### OAuth 2.1 Implementation\n- Support OAuth 2.1 authorization flow with PKCE\n- Implement Protected Resource Metadata (RFC9728) for authorization server discovery\n- Support Authorization Server Metadata (RFC8414) discovery\n- Implement Resource Indicators (RFC8707) for token audience binding\n- Support Dynamic Client Registration (RFC7591) where applicable\n\n#### Bearer Token Authentication\n- Parse and validate Bearer tokens from Authorization headers\n- Extract user identity (email) from validated tokens\n- Support JWT and opaque token formats\n- Implement token introspection for opaque tokens\n\n#### Session Management\n- Create unique session identifiers for each authenticated user\n- Maintain session-to-user mapping across requests\n- Implement session persistence and recovery\n- Support concurrent multi-user sessions\n- Provide session cleanup and expiration\n\n#### Security\n- Validate token audience to prevent token misuse\n- Implement secure token storage\n- Support token rotation and refresh\n- Prevent session hijacking and fixation attacks\n\n### Expected Behavior\n\n1. **Initial Authentication Flow**:\n   - Client discovers authorization server via Protected Resource Metadata\n   - Client performs OAuth 2.1 flow with PKCE\n   - Server validates tokens and creates user session\n   - Session ID is returned to client for subsequent requests\n\n2. **Subsequent Requests**:\n   - Client includes Bearer token and session ID\n   - Server validates token and matches to existing session\n   - User context is maintained across requests\n   - No unnecessary re-authentication\n\n3. **Multi-User Support**:\n   - Each user has isolated session\n   - Sessions persist across multiple requests\n   - Clear session lifecycle management\n   - Graceful handling of session expiration\n\n\n### References\n\n- [[MCP Authorization Specification (2025-06-18)](https://modelcontextprotocol.io/specification/2025-06-18/basic/authorization)](https://modelcontextprotocol.io/specification/2025-06-18/basic/authorization)\n- [[Issue #101: Enable fastmcp Bearer Token Authentication](https://github.com/modelcontextprotocol/python-sdk/issues/101)](https://github.com/modelcontextprotocol/python-sdk/issues/101)\n- [[Issue #88: Multi-User Session Handling](https://github.com/modelcontextprotocol/python-sdk/issues/88)](https://github.com/modelcontextprotocol/python-sdk/issues/88)\n- [[OAuth 2.1 Draft Specification](https://datatracker.ietf.org/doc/html/draft-ietf-oauth-v2-1-13)](https://datatracker.ietf.org/doc/html/draft-ietf-oauth-v2-1-13)\n", "hints_text": "\n\n", "all_hints_text": "Looking forward to this!\nHi @taylorwilsdon ,\n\nIs there any ETA for this? Can I help?\nHey @eladrave - I've actually got it working already, but I built all the oauth logic manually. FastMCP's latest version (17 hrs ago) exposes native oauth abstraction so I'm going to implement that and should have it up today. Very few clients support it at this point BUT its incredibly cool with those that do (including just mcp inspector) and feels like a taste of the future. \nhttps://github.com/taylorwilsdon/google_workspace_mcp/pull/137\n\n", "commit_urls": ["https://github.com/taylorwilsdon/google_workspace_mcp/commit/ad981dbd988dfb090b9012b37ca35f371d803e7c", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/8d053680c0f3c54c420b1d875dc2e0727cc945d3", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/dad52829f88dfdfd8af72d4840039942cf736591", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/b2f5ec1052206199bb8dc1dedfd4ec3bea47d38a", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/5aae243b223e9557c01b07c4fc8ef91c28b688ab", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/06ef1223dddc18a9890461b830a876c6b83f35ba", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/9470a41ddeed5da562b468d4155bf82a66ae3c3c", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/c45bb3956c30ccafcf1a5b9881d563e7e155f4e2", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/e37803240ab59c7df57462717a11eacc0398aded", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/2a4118bb65f1dcec7068188331df08c0068f0091", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/d5949ee5b1235ac27121024420aeb4269c2ee55e", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/2836f6c45fea102104c4bcc7c8d58bfe584874b6", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/065889fedea11a4e532900d175aa908cb55a6f07", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/bb55feed837de1c0728fa798c97d50d538926464", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/ba48a4803d23ff3f52cfeda88a6e0e460cca48f7", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/737e4ea807213e6465f03f3322d28ce60889b517", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/ff6845c86d27f4c99a384ac1b27ea43e41af88b7", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/ff9b7ecd0799440a107c6d716bfd8d27b74385a3", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/71e2f1ba3e720cacb8d68962864f905a1ad5a775", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/3012880098451436ea44b6d5781966c44579ea89", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/09675940970821267fcbc035f9f2c3173590af31", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/07c065c57b0fad1cc827d38104c60e931e16bcde", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/e54450cdad9f5d9719783ed4235d3689647c8883", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/ee792b65d86369ac00ac3132233fbc33f8ad5e85", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/e03b10c024d7426476afbf2f1b359bebd04ffa55", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/fd8935e7cda267b8b5b4acf161cc8c91a8a59435", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/61f3e38f0a0bc6a2c2cbe53ea6fb2939a205f3e6", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/58d9c4464e0d648224c31e97dc44d3fcbfb87c37", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/63ead78f9138f31a42281668705281b9b47336ad", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/7593163506bac7976e0eba6d49323ebd3b2585a1", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/c861d7484aa8883f5baec65f79663298f857b9f3", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/2f08cec1337725ead10ad62deef38ac814c5424e", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/b9361647cae6a5b0f17f68fda3ffe7944a4244f3", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/13dad566078081c71a39a109961bd1a23abdadfe", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/d8a6f76981328f4c1692f202b38f1040776fc5a1", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/96f0e234cad2857245fe58ddc1879c90d681a878", "https://github.com/taylorwilsdon/google_workspace_mcp/commit/9059691b85e2ee12d34ffe386d6132ddc2ca86a0"], "created_at": "2025-08-02T18:34:16Z"}
{"repo": "taylorwilsdon/google_workspace_mcp", "pull_number": 435, "instance_id": "taylorwilsdon__google_workspace_mcp-435", "issue_numbers": [422], "base_commit": "5ed87d8d10d6edbb87cf0ad403ca697ef4a0cc0e", "patch": "diff --git a/README.md b/README.md\nindex e25386895..332618991 100644\n--- a/README.md\n+++ b/README.md\n@@ -846,6 +846,7 @@ cp .env.oauth21 .env\n | `update_drive_permission` | Extended | Modify permission role |\n | `remove_drive_permission` | Extended | Revoke file access |\n | `transfer_drive_ownership` | Extended | Transfer file ownership to another user |\n+| `set_drive_file_permissions` | Extended | Set link sharing and file-level sharing settings |\n | `get_drive_file_permissions` | Complete | Get detailed file permissions |\n | `check_drive_file_public_access` | Complete | Check public sharing status |\n \ndiff --git a/core/tool_tiers.yaml b/core/tool_tiers.yaml\nindex 7f75b033f..a7acae91a 100644\n--- a/core/tool_tiers.yaml\n+++ b/core/tool_tiers.yaml\n@@ -38,6 +38,7 @@ drive:\n     - remove_drive_permission\n     - transfer_drive_ownership\n     - batch_share_drive_file\n+    - set_drive_file_permissions\n   complete:\n     - get_drive_file_permissions\n     - check_drive_file_public_access\ndiff --git a/gdrive/drive_tools.py b/gdrive/drive_tools.py\nindex 1e0cbd3f6..5bcbfb0e8 100644\n--- a/gdrive/drive_tools.py\n+++ b/gdrive/drive_tools.py\n@@ -1902,3 +1902,174 @@ async def transfer_drive_ownership(\n     output_parts.extend([\"\", \"Note: Previous owner now has editor access.\"])\n \n     return \"\\n\".join(output_parts)\n+\n+\n+@server.tool()\n+@handle_http_errors(\n+    \"set_drive_file_permissions\", is_read_only=False, service_type=\"drive\"\n+)\n+@require_google_service(\"drive\", \"drive_file\")\n+async def set_drive_file_permissions(\n+    service,\n+    user_google_email: str,\n+    file_id: str,\n+    link_sharing: Optional[str] = None,\n+    writers_can_share: Optional[bool] = None,\n+    copy_requires_writer_permission: Optional[bool] = None,\n+) -> str:\n+    \"\"\"\n+    Sets file-level sharing settings and controls link sharing for a Google Drive file or folder.\n+\n+    This is a high-level tool for the most common permission changes. Use this to toggle\n+    \"anyone with the link\" access or configure file-level sharing behavior. For managing\n+    individual user/group permissions, use share_drive_file or update_drive_permission instead.\n+\n+    Args:\n+        user_google_email (str): The user's Google email address. Required.\n+        file_id (str): The ID of the file or folder. Required.\n+        link_sharing (Optional[str]): Control \"anyone with the link\" access for the file.\n+            - \"off\": Disable \"anyone with the link\" access for this file.\n+            - \"reader\": Anyone with the link can view.\n+            - \"commenter\": Anyone with the link can comment.\n+            - \"writer\": Anyone with the link can edit.\n+        writers_can_share (Optional[bool]): Whether editors can change permissions and share.\n+            If False, only the owner can share. Defaults to None (no change).\n+        copy_requires_writer_permission (Optional[bool]): Whether viewers and commenters\n+            are prevented from copying, printing, or downloading. Defaults to None (no change).\n+\n+    Returns:\n+        str: Summary of all permission changes applied to the file.\n+    \"\"\"\n+    logger.info(\n+        f\"[set_drive_file_permissions] Invoked. Email: '{user_google_email}', \"\n+        f\"File ID: '{file_id}', Link sharing: '{link_sharing}', \"\n+        f\"Writers can share: {writers_can_share}, Copy restriction: {copy_requires_writer_permission}\"\n+    )\n+\n+    if (\n+        link_sharing is None\n+        and writers_can_share is None\n+        and copy_requires_writer_permission is None\n+    ):\n+        raise ValueError(\n+            \"Must provide at least one of: link_sharing, writers_can_share, copy_requires_writer_permission\"\n+        )\n+\n+    valid_link_sharing = {\"off\", \"reader\", \"commenter\", \"writer\"}\n+    if link_sharing is not None and link_sharing not in valid_link_sharing:\n+        raise ValueError(\n+            f\"Invalid link_sharing '{link_sharing}'. Must be one of: {', '.join(sorted(valid_link_sharing))}\"\n+        )\n+\n+    resolved_file_id, file_metadata = await resolve_drive_item(\n+        service, file_id, extra_fields=\"name, webViewLink\"\n+    )\n+    file_id = resolved_file_id\n+    file_name = file_metadata.get(\"name\", \"Unknown\")\n+\n+    output_parts = [f\"Permission settings updated for '{file_name}'\", \"\"]\n+    changes_made = []\n+\n+    # Handle file-level settings via files().update()\n+    file_update_body = {}\n+    if writers_can_share is not None:\n+        file_update_body[\"writersCanShare\"] = writers_can_share\n+    if copy_requires_writer_permission is not None:\n+        file_update_body[\"copyRequiresWriterPermission\"] = (\n+            copy_requires_writer_permission\n+        )\n+\n+    if file_update_body:\n+        await asyncio.to_thread(\n+            service.files()\n+            .update(\n+                fileId=file_id,\n+                body=file_update_body,\n+                supportsAllDrives=True,\n+                fields=\"id\",\n+            )\n+            .execute\n+        )\n+        if writers_can_share is not None:\n+            state = \"allowed\" if writers_can_share else \"restricted to owner\"\n+            changes_made.append(f\"  - Editors sharing: {state}\")\n+        if copy_requires_writer_permission is not None:\n+            state = \"restricted\" if copy_requires_writer_permission else \"allowed\"\n+            changes_made.append(f\"  - Viewers copy/print/download: {state}\")\n+\n+    # Handle link sharing via permissions API\n+    if link_sharing is not None:\n+        current_permissions = await asyncio.to_thread(\n+            service.permissions()\n+            .list(\n+                fileId=file_id,\n+                supportsAllDrives=True,\n+                fields=\"permissions(id, type, role)\",\n+            )\n+            .execute\n+        )\n+        anyone_perms = [\n+            p\n+            for p in current_permissions.get(\"permissions\", [])\n+            if p.get(\"type\") == \"anyone\"\n+        ]\n+\n+        if link_sharing == \"off\":\n+            if anyone_perms:\n+                for perm in anyone_perms:\n+                    await asyncio.to_thread(\n+                        service.permissions()\n+                        .delete(\n+                            fileId=file_id,\n+                            permissionId=perm[\"id\"],\n+                            supportsAllDrives=True,\n+                        )\n+                        .execute\n+                    )\n+                changes_made.append(\n+                    \"  - Link sharing: disabled (restricted to specific people)\"\n+                )\n+            else:\n+                changes_made.append(\"  - Link sharing: already off (no change)\")\n+        else:\n+            if anyone_perms:\n+                await asyncio.to_thread(\n+                    service.permissions()\n+                    .update(\n+                        fileId=file_id,\n+                        permissionId=anyone_perms[0][\"id\"],\n+                        body={\n+                            \"role\": link_sharing,\n+                            \"allowFileDiscovery\": False,\n+                        },\n+                        supportsAllDrives=True,\n+                        fields=\"id, type, role\",\n+                    )\n+                    .execute\n+                )\n+                changes_made.append(f\"  - Link sharing: updated to '{link_sharing}'\")\n+            else:\n+                await asyncio.to_thread(\n+                    service.permissions()\n+                    .create(\n+                        fileId=file_id,\n+                        body={\n+                            \"type\": \"anyone\",\n+                            \"role\": link_sharing,\n+                            \"allowFileDiscovery\": False,\n+                        },\n+                        supportsAllDrives=True,\n+                        fields=\"id, type, role\",\n+                    )\n+                    .execute\n+                )\n+                changes_made.append(f\"  - Link sharing: enabled as '{link_sharing}'\")\n+\n+    output_parts.append(\"Changes:\")\n+    if changes_made:\n+        output_parts.extend(changes_made)\n+    else:\n+        output_parts.append(\"  - No changes (already configured)\")\n+    output_parts.extend([\"\", f\"View link: {file_metadata.get('webViewLink', 'N/A')}\"])\n+\n+    return \"\\n\".join(output_parts)\ndiff --git a/uv.lock b/uv.lock\nindex b05122135..869196441 100644\n--- a/uv.lock\n+++ b/uv.lock\n@@ -1,5 +1,5 @@\n version = 1\n-revision = 2\n+revision = 1\n requires-python = \">=3.10\"\n resolution-markers = [\n     \"python_full_version >= '3.13'\",\n@@ -10,18 +10,18 @@ resolution-markers = [\n name = \"annotated-doc\"\n version = \"0.0.4\"\n source = { registry = \"https://pypi.org/simple\" }\n-sdist = { url = \"https://files.pythonhosted.org/packages/57/ba/046ceea27344560984e26a590f90bc7f4a75b06701f653222458922b558c/annotated_doc-0.0.4.tar.gz\", hash = \"sha256:fbcda96e87e9c92ad167c2e53839e57503ecfda18804ea28102353485033faa4\", size = 7288, upload-time = \"2025-11-10T22:07:42.062Z\" }\n+sdist = { url = \"https://files.pythonhosted.org/packages/57/ba/046ceea27344560984e26a590f90bc7f4a75b06701f653222458922b558c/annotated_doc-0.0.4.tar.gz\", hash = \"sha256:fbcda96e87e9c92ad167c2e53839e57503ecfda18804ea28102353485033faa4\", size = 7288 }\n wheels = [\n-    { url = \"https://files.pythonhosted.org/packages/1e/d3/26bf1008eb3d2daa8ef4cacc7f3bfdc11818d111f7e2d0201bc6e3b49d45/annotated_doc-0.0.4-py3-none-any.whl\", hash = \"sha256:571ac1dc6991c450b25a9c2d84a3705e2ae7a53467b5d111c24fa8baabbed320\", size = 5303, upload-time = \"2025-11-10T22:07:40.673Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/1e/d3/26bf1008eb3d2daa8ef4cacc7f3bfdc11818d111f7e2d0201bc6e3b49d45/annotated_doc-0.0.4-py3-none-any.whl\", hash = \"sha256:571ac1dc6991c450b25a9c2d84a3705e2ae7a53467b5d111c24fa8baabbed320\", size = 5303 },\n ]\n \n [[package]]\n name = \"annotated-types\"\n version = \"0.7.0\"\n source = { registry = \"https://pypi.org/simple\" }\n-sdist = { url = \"https://files.pythonhosted.org/packages/ee/67/531ea369ba64dcff5ec9c3402f9f51bf748cec26dde048a2f973a4eea7f5/annotated_types-0.7.0.tar.gz\", hash = \"sha256:aff07c09a53a08bc8cfccb9c85b05f1aa9a2a6f23728d790723543408344ce89\", size = 16081, upload-time = \"2024-05-20T21:33:25.928Z\" }\n+sdist = { url = \"https://files.pythonhosted.org/packages/ee/67/531ea369ba64dcff5ec9c3402f9f51bf748cec26dde048a2f973a4eea7f5/annotated_types-0.7.0.tar.gz\", hash = \"sha256:aff07c09a53a08bc8cfccb9c85b05f1aa9a2a6f23728d790723543408344ce89\", size = 16081 }\n wheels = [\n-    { url = \"https://files.pythonhosted.org/packages/78/b6/6307fbef88d9b5ee7421e68d78a9f162e0da4900bc5f5793f6d3d0e34fb8/annotated_types-0.7.0-py3-none-any.whl\", hash = \"sha256:1f02e8b43a8fbbc3f3e0d4f0f4bfc8131bcb4eebe8849b8e5c773f3a1c582a53\", size = 13643, upload-time = \"2024-05-20T21:33:24.1Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/78/b6/6307fbef88d9b5ee7421e68d78a9f162e0da4900bc5f5793f6d3d0e34fb8/annotated_types-0.7.0-py3-none-any.whl\", hash = \"sha256:1f02e8b43a8fbbc3f3e0d4f0f4bfc8131bcb4eebe8849b8e5c773f3a1c582a53\", size = 13643 },\n ]\n \n [[package]]\n@@ -33,27 +33,27 @@ dependencies = [\n     { name = \"idna\" },\n     { name = \"typing-extensions\", marker = \"python_full_version < '3.13'\" },\n ]\n-sdist = { url = \"https://files.pythonhosted.org/packages/96/f0/5eb65b2bb0d09ac6776f2eb54adee6abe8228ea05b20a5ad0e4945de8aac/anyio-4.12.1.tar.gz\", hash = \"sha256:41cfcc3a4c85d3f05c932da7c26d0201ac36f72abd4435ba90d0464a3ffed703\", size = 228685, upload-time = \"2026-01-06T11:45:21.246Z\" }\n+sdist = { url = \"https://files.pythonhosted.org/packages/96/f0/5eb65b2bb0d09ac6776f2eb54adee6abe8228ea05b20a5ad0e4945de8aac/anyio-4.12.1.tar.gz\", hash = \"sha256:41cfcc3a4c85d3f05c932da7c26d0201ac36f72abd4435ba90d0464a3ffed703\", size = 228685 }\n wheels = [\n-    { url = \"https://files.pythonhosted.org/packages/38/0e/27be9fdef66e72d64c0cdc3cc2823101b80585f8119b5c112c2e8f5f7dab/anyio-4.12.1-py3-none-any.whl\", hash = \"sha256:d405828884fc140aa80a3c667b8beed277f1dfedec42ba031bd6ac3db606ab6c\", size = 113592, upload-time = \"2026-01-06T11:45:19.497Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/38/0e/27be9fdef66e72d64c0cdc3cc2823101b80585f8119b5c112c2e8f5f7dab/anyio-4.12.1-py3-none-any.whl\", hash = \"sha256:d405828884fc140aa80a3c667b8beed277f1dfedec42ba031bd6ac3db606ab6c\", size = 113592 },\n ]\n \n [[package]]\n name = \"async-timeout\"\n version = \"5.0.1\"\n source = { registry = \"https://pypi.org/simple\" }\n-sdist = { url = \"https://files.pythonhosted.org/packages/a5/ae/136395dfbfe00dfc94da3f3e136d0b13f394cba8f4841120e34226265780/async_timeout-5.0.1.tar.gz\", hash = \"sha256:d9321a7a3d5a6a5e187e824d2fa0793ce379a202935782d555d6e9d2735677d3\", size = 9274, upload-time = \"2024-11-06T16:41:39.6Z\" }\n+sdist = { url = \"https://files.pythonhosted.org/packages/a5/ae/136395dfbfe00dfc94da3f3e136d0b13f394cba8f4841120e34226265780/async_timeout-5.0.1.tar.gz\", hash = \"sha256:d9321a7a3d5a6a5e187e824d2fa0793ce379a202935782d555d6e9d2735677d3\", size = 9274 }\n wheels = [\n-    { url = \"https://files.pythonhosted.org/packages/fe/ba/e2081de779ca30d473f21f5b30e0e737c438205440784c7dfc81efc2b029/async_timeout-5.0.1-py3-none-any.whl\", hash = \"sha256:39e3809566ff85354557ec2398b55e096c8364bacac9405a7a1fa429e77fe76c\", size = 6233, upload-time = \"2024-11-06T16:41:37.9Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/fe/ba/e2081de779ca30d473f21f5b30e0e737c438205440784c7dfc81efc2b029/async_timeout-5.0.1-py3-none-any.whl\", hash = \"sha256:39e3809566ff85354557ec2398b55e096c8364bacac9405a7a1fa429e77fe76c\", size = 6233 },\n ]\n \n [[package]]\n name = \"attrs\"\n version = \"25.4.0\"\n source = { registry = \"https://pypi.org/simple\" }\n-sdist = { url = \"https://files.pythonhosted.org/packages/6b/5c/685e6633917e101e5dcb62b9dd76946cbb57c26e133bae9e0cd36033c0a9/attrs-25.4.0.tar.gz\", hash = \"sha256:16d5969b87f0859ef33a48b35d55ac1be6e42ae49d5e853b597db70c35c57e11\", size = 934251, upload-time = \"2025-10-06T13:54:44.725Z\" }\n+sdist = { url = \"https://files.pythonhosted.org/packages/6b/5c/685e6633917e101e5dcb62b9dd76946cbb57c26e133bae9e0cd36033c0a9/attrs-25.4.0.tar.gz\", hash = \"sha256:16d5969b87f0859ef33a48b35d55ac1be6e42ae49d5e853b597db70c35c57e11\", size = 934251 }\n wheels = [\n-    { url = \"https://files.pythonhosted.org/packages/3a/2a/7cc015f5b9f5db42b7d48157e23356022889fc354a2813c15934b7cb5c0e/attrs-25.4.0-py3-none-any.whl\", hash = \"sha256:adcf7e2a1fb3b36ac48d97835bb6d8ade15b8dcce26aba8bf1d14847b57a3373\", size = 67615, upload-time = \"2025-10-06T13:54:43.17Z\" },\n+    { url = \"https://files.pythonhosted.org/packages/3a/2a/7cc015f5b9f5db42b7d48157e23356022889fc354a2813c15934b7cb5c0e/attrs-25.4.0-py3-none-any.whl\", hash = \"sha256:adcf7e2a1fb3b36ac48d97835bb6d8ade15b8dcce26aba8bf1d14847b57a3373\", size = 67615 },\n ]\n \n [[package]]\n@@ -63,54 +63,54 @@ source = { registry = \"https://pypi.org/simple\" }\n dependencies = [\n     { name = \"cryptography\" },\n ]\n-sdist = { url = \"https://files.pythonhosted.org/packages/49/dc/ed1681bf1339dd6ea1ce56136bad4baabc6f7ad466e375810702b0237047/authlib-1.6.7.tar.gz\", hash = \"sha256:dbf10100011d1e1b34048c9d120e83f13b35d69a826ae762b93d2fb5aafc337b\", size = 164950, upload-time = \"2026-02-06T14:04:14.171Z\" }\n+sdist = { url = \"https://files.pythonhosted.org/packages/49/dc/ed1681bf1339dd6ea1ce56136bad4baabc6f7ad466e375810702b0237047/authlib-1.6.7.tar.gz\", hash = \"sha256:dbf10100011d1e1b34048c9d120e8