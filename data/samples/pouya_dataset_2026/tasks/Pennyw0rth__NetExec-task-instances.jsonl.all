                                                                                                                                                                                     \u2502                  \n                    \u2502   507 \u2502   \u2502   while not done:                                                                                                                                                                                                                                              \u2502                  \n                    \u2502 \u2771 508 \u2502   \u2502   \u2502   response = self.sendReceive(searchRequest, searchControls)                                                                                                                                                                                               \u2502                  \n                    \u2502   509 \u2502   \u2502   \u2502   for message in response:                                                                                                                                                                                                                                 \u2502                  \n                    \u2502   510 \u2502   \u2502   \u2502   \u2502   searchResult = message['protocolOp'].getComponent()                                                                                                                                                                                                  \u2502                  \n                    \u2502   511 \u2502   \u2502   \u2502   \u2502   if searchResult.isSameTypeWith(SearchResultDone()):                                                                                                                                                                                                  \u2502                  \n                    \u2502                                                                                  