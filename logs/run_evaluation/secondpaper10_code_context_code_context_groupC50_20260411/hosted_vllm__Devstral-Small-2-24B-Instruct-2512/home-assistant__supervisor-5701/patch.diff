@@ -62,6 +61,31 @@ class GitRepo(CoreSysAttributes):
             except (
                 git.InvalidGitRepositoryError,
                 git.NoSuchPathError,
+            ) as err:
+                # If the directory exists but is not a valid git repository,
+                # it might be empty or corrupted. Try to clone it again.
+                # Only do this if the directory is empty (no files in it).
+                if self.path.is_dir() and not any(self.path.iterdir()):
+                    _LOGGER.warning(
+                        "Repository directory %s exists but is empty. Attempting to clone.",
+                        self.path,
+                    )
+                    try:
+                        await self.clone()
+                        return
+                    except StoreJobError:
+                        # If the clone fails due to job conditions (e.g., no internet),
+                        # fall through to raise StoreGitError
+                        _LOGGER.error(
+                            "Failed to clone %s due to job conditions. Directory exists but is empty.",
+                            self.path,
+                        )
+                        pass
+
+                _LOGGER.error("Can't load %s", self.path)
+                raise StoreGitError() from err
+
+            except (
                 git.CommandError,
                 UnicodeDecodeError,
             ) as err:
@@ -197,7 +221,6 @@ class GitRepo(CoreSysAttributes):
         async with self.lock:
             await self.sys_run_in_executor(_remove_git_dir, self.path)
 
