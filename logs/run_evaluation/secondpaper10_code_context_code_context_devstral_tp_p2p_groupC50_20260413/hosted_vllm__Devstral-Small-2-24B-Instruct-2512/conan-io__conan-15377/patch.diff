diff --git a/conan/tools/scm/git.py b/conan/tools/scm/git.py
index 77d0e6dbb..ab21e1937 100644
--- a/conan/tools/scm/git.py
+++ b/conan/tools/scm/git.py
@@ -237,3 +237,36 @@ class Git:
         files = self.run("ls-files --full-name --others --cached --exclude-standard")
         files = files.splitlines()
         return files
+
+    def coordinates_to_conandata(self, remote="origin", repository=False):
+        """
+        Captures the current git coordinates (URL and commit) and stores them in conandata.yml.
+        This is a helper method that combines get_url_and_commit() with update_conandata().
+
+        The coordinates are stored in a version-specific way to be compatible with trim_conandata().
+
+        :param remote: Name of the remote git repository ('origin' by default).
+        :param repository: By default gets the commit of the defined folder, use repo=True to get
+                     the commit of the repository instead.
+        """
+        from conan.tools.files import update_conandata
+        scm_url, scm_commit = self.get_url_and_commit(remote=remote, repository=repository)
+        version = str(self._conanfile.version)
+        update_conandata(self._conanfile, {"scm": {version: {"commit": scm_commit, "url": scm_url}}})
+
+    def checkout_from_conandata_coordinates(self, target="."):
+        """
+        Checks out the source code from the coordinates stored in conandata.yml.
+        This method reads the URL and commit from conandata.yml and performs a git clone and checkout.
+
+        :param target: Target folder for the clone operation (default is current directory).
+        """
+        version = str(self._conanfile.version)
+        scm_data = self._conanfile.conan_data.get("scm", {}).get(version, {})
+        url = scm_data.get("url")
+        commit = scm_data.get("commit")
+        if not url or not commit:
+            raise ConanException("No SCM coordinates found in conandata.yml. "
+                                 "Run coordinates_to_conandata() in export() method first.")
+        self.clone(url=url, target=target)
+        self.checkout(commit=commit)
