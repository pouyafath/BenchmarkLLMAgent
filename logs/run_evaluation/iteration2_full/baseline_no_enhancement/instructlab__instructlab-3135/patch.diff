diff --git a/instructlab/train/sdg.py b/instructlab/train/sdg.py
--- a/instructlab/train/sdg.py
+++ b/instructlab/train/sdg.py
@@ -1,2 +1,5 @@
-        except Exception as e:
-            logger.error("Synthetic data generation failed: %s", e)
+        except Exception as e:
+            # Log the exception with its traceback. Using ``logger.exception`` ensures
+            # that the exception is formatted correctly and avoids issues where the
+            # exception object is passed as a formatting argument to ``logger.error``.
+            logger.exception("Synthetic data generation failed")
@@ -103,2 +106,5 @@
-        except Exception as e:
-            logger.error("Failed to train SDG model: %s", e)
+        except Exception as e:
