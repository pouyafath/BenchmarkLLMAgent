+    def items(self, cfn: Any) -> Iterator[Any]:
+        """Yield each item from the values list, handling empty lists gracefully."""
+        # Resolve the values list (second element of the ForEach definition)
+        values = self._resolve_values(cfn)
+        # The values must be a list; otherwise raise a resolve error.
+        if not isinstance(values, list):
+            raise _ResolveError(
+                f"Fn::ForEach values must be a list, got {type(values).__name__}",
+                self.key,
+            )
+        # If the list is empty, simply return without yielding any items.
+        if len(values) == 0:
+            return iter([])
+        for item in values:
+            yield item