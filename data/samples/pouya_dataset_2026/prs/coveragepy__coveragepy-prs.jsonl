{"repository": {"pullRequest": {"number": 1952, "title": "Support `.coveragerc.toml` for configuration", "body": "This patch provides a new configuration \u2014 `.coveragerc.toml `. Considering that many projects have switched to toml configurations, this change offers a more flexible approach to manage coverage settings.\r\n\r\nResolves #1643", "baseRefName": "main", "baseRefOid": "d5e7c3ad0d557de2aff73d33a59f31a80b36ba6c", "baseRepository": {"nameWithOwner": "coveragepy/coveragepy"}, "url": "https://github.com/coveragepy/coveragepy/pull/1952", "createdAt": "2025-04-15T23:38:00Z", "mergedAt": "2025-12-07T15:45:24Z"}}, "base": {"repo": {"full_name": "coveragepy/coveragepy"}, "sha": "d5e7c3ad0d557de2aff73d33a59f31a80b36ba6c"}, "diff_url": "https://github.com/coveragepy/coveragepy/pull/1952.diff", "number": 1952, "created_at": "2025-04-15T23:38:00Z", "merged_at": "2025-12-07T15:45:24Z", "resolved_issues": [1643]}
{"repository": {"pullRequest": {"number": 1967, "title": "fix: add encoding arguments", "body": "This fixes https://github.com/nedbat/coveragepy/issues/1966 by adding `encoding=\"utf-8\"` everywhere. See https://peps.python.org/pep-0597/.\n", "baseRefName": "master", "baseRefOid": "fd8be1ddb525c524a6de19cd11493340f8ee99dd", "baseRepository": {"nameWithOwner": "coveragepy/coveragepy"}, "url": "https://github.com/coveragepy/coveragepy/pull/1967", "createdAt": "2025-05-14T21:25:11Z", "mergedAt": "2025-05-16T10:40:37Z"}}, "base": {"repo": {"full_name": "coveragepy/coveragepy"}, "sha": "fd8be1ddb525c524a6de19cd11493340f8ee99dd"}, "diff_url": "https://github.com/coveragepy/coveragepy/pull/1967.diff", "number": 1967, "created_at": "2025-05-14T21:25:11Z", "merged_at": "2025-05-16T10:40:37Z", "resolved_issues": [1966]}
{"repository": {"pullRequest": {"number": 1972, "title": "Add support for Windows arm64", "body": "Closes #1971 \r\n\r\nThis would add builds for arm64 windows wheels to `kit.yml` for use in the publish workflow, as well as add windows arm64 to the test and coverage workflows. ", "baseRefName": "master", "baseRefOid": "2fe622506356424406ddcac01bf1775eca5a92d3", "baseRepository": {"nameWithOwner": "coveragepy/coveragepy"}, "url": "https://github.com/coveragepy/coveragepy/pull/1972", "createdAt": "2025-05-22T16:51:32Z", "mergedAt": "2025-05-22T22:43:20Z"}}, "base": {"repo": {"full_name": "coveragepy/coveragepy"}, "sha": "2fe622506356424406ddcac01bf1775eca5a92d3"}, "diff_url": "https://github.com/coveragepy/coveragepy/pull/1972.diff", "number": 1972, "created_at": "2025-05-22T16:51:32Z", "merged_at": "2025-05-22T22:43:20Z", "resolved_issues": [1971]}
{"repository": {"pullRequest": {"number": 2004, "title": "Use flaky pytest fixture instead of decorator", "body": "Replace the direct use of `flaky.flaky` decorator with the equivalent pytest fixture.  This is both more canonical, and has the additional advantage of being compatible with the more modern `pytest-rerunfailures` plugin, that can be used in place of `flaky`.\r\n\r\nFixes #2003", "baseRefName": "master", "baseRefOid": "99a97aa1473ff7db9715a849913f83c2f7954308", "baseRepository": {"nameWithOwner": "coveragepy/coveragepy"}, "url": "https://github.com/coveragepy/coveragepy/pull/2004", "createdAt": "2025-07-21T19:16:40Z", "mergedAt": "2025-07-22T09:20:09Z"}}, "base": {"repo": {"full_name": "coveragepy/coveragepy"}, "sha": "99a97aa1473ff7db9715a849913f83c2f7954308"}, "diff_url": "https://github.com/coveragepy/coveragepy/pull/2004.diff", "number": 2004, "created_at": "2025-07-21T19:16:40Z", "merged_at": "2025-07-22T09:20:09Z", "resolved_issues": [2003]}
